ALTER TABLE CONTROL_PROCESOS ADD COMPANIA VARCHAR2(11 CHAR);
COMMIT;
UPDATE CONTROL_PROCESOS SET COMPANIA = '001';
COMMIT;
ALTER TABLE CONTROL_PROCESOS MODIFY COMPANIA NOT NULL;
COMMIT;
ALTER TABLE CONTROL_PROCESOS DROP CONSTRAINT PK_CONTROL_PROCESOS;
COMMIT;
ALTER TABLE CONTROL_PROCESOS ADD (
CONSTRAINT PK_CONTROL_PROCESOS PRIMARY KEY (COMPANIA, ID_PROCESO)
  USING INDEX TABLESPACE TN_UNIST
  STORAGE ( INITIAL 6 K NEXT 10 K PCTINCREASE 0 MINEXTENTS 1 MAXEXTENTS 90 ));
COMMIT;
