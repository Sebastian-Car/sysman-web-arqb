ALTER TABLE CM_ARCHIVO_MEDICAMENTOS DROP COLUMN CONSECUTIVOCUM;
COMMIT;
ALTER TABLE CM_ARCHIVO_MEDICAMENTOS RENAME COLUMN CONSECUTIVOCUM_NEW TO CONSECUTIVOCUM;
COMMIT;