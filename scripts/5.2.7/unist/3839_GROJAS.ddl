ALTER TABLE CM_ARCHIVO_MEDICAMENTOS ADD CONSECUTIVOCUM_NEW VARCHAR2(25);
COMMIT;
UPDATE CM_ARCHIVO_MEDICAMENTOS SET CONSECUTIVOCUM_NEW = TO_CHAR(CONSECUTIVOCUM);
