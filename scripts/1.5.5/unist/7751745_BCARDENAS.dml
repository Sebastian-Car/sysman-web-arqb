MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000356  ID_CODIGO ,TO_CLOB(q'[Error al insertar en la tabla DISTPERSONAL para el proceso: --PROCESO-- , año: --ANIO-- ,mes: --MES-- y periodo: --PERIODO--]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_INSERT_DISTRIB]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;
MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000357  ID_CODIGO ,TO_CLOB(q'[Error al eliminar los registros de la tabla DISTPERSONAL para el proceso: --PROCESO-- , año: --ANIO-- ,mes: --MES-- y periodo: --PERIODO--]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_DELETE_DISTRIB]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;