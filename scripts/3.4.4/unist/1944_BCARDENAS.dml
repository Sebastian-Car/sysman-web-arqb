MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 10000184  ID_CODIGO ,TO_CLOB(q'[No tiene permisos para modificar el nombre de la dependencia.]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_ALM_CAMBIAR_NOMBRE_DEP]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;