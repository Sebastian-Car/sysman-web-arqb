MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 10000183  ID_CODIGO ,TO_CLOB(q'[Error al acualizar los datos de depreciacion acumulada para el elemento: --ELEMENTO-- y placa: --PLACA--.]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_ALM_DEP_ACUM_NO_CALCULADA]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;