MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 300000006  ID_CODIGO ,TO_CLOB(q'[Los dias desde la fecha de la ultima bonificacion son mayor a 360 dias, debe revisar el ultimo pago de bonificacion, no debe ser mayor a 360 dias. = --FECHA--, --NOMBRECOMPLETO--,--ID_EMPLEADO--, Cedula No. --NUMERO_DCTO--, Tipo: --ID_TIPO--]') MSG_INTERFAZ ,TO_CLOB(q'[ALERT_DIASFINICIOPS]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;