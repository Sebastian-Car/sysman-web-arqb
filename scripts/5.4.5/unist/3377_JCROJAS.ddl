    ANO NUMBER(4,0) NOT NULL,
    MES NUMBER(2,0) NOT NULL,
    PERIODO NUMBER(2,0) NOT NULL,
    SBM NUMBER(20,2) DEFAULT 0 NOT NULL,
	GR NUMBER(20,2) DEFAULT 0 NOT NULL,
    PT NUMBER(20,2) DEFAULT 0 NOT NULL,
	DIASLNRBASP NUMBER(20,2) DEFAULT 0 NOT NULL,
    PORCBASP NUMBER(20,2) DEFAULT 0 NOT NULL,
    SOBRESUELDO NUMBER(20,2) DEFAULT 0 NOT NULL,
    AUXT NUMBER(20,2) DEFAULT 0 NOT NULL,
    AUXA NUMBER(20,2) DEFAULT 0 NOT NULL,
	PA NUMBER(20,2) DEFAULT 0 NOT NULL,
	BASP NUMBER(20,2) DEFAULT 0 NOT NULL,
    EXTRAS NUMBER(20,2) DEFAULT 0 NOT NULL,
	FECHAINIPS TIMESTAMP (6) WITH LOCAL TIME ZONE,
	DIASLNRPS NUMBER(20,2) DEFAULT 0 NOT NULL,
	PS NUMBER(20,2) DEFAULT 0 NOT NULL,
	FECHAINIPSV TIMESTAMP (6) WITH LOCAL TIME ZONE,
