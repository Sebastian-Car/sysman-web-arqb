	DIASLNRPN NUMBER(20,2) DEFAULT 0 NOT NULL,
	PN NUMBER(20,2) DEFAULT 0 NOT NULL,
	FECHAINIPSCES TIMESTAMP (6) WITH LOCAL TIME ZONE,
	DIASLNRCES NUMBER(20,2) DEFAULT 0 NOT NULL,
	ANTICIPOS NUMBER(20,2) DEFAULT 0 NOT NULL,
    CREATED_BY VARCHAR2(32 CHAR),
    MODIFIED_BY VARCHAR2(32 CHAR),
    DATE_CREATED TIMESTAMP (6) WITH LOCAL TIME ZONE, 
    DATE_MODIFIED TIMESTAMP (6) WITH LOCAL TIME ZONE,
    CONSTRAINT PK_TMP_INF_BECPNOM PRIMARY KEY (COMPANIA,ID_DE_EMPLEADO,PROCESO,ANO,MES,PERIODO)
)
