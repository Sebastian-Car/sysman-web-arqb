MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000363  ID_CODIGO ,TO_CLOB(q'[El empleado --NOMEMPLEADO--, cuenta con el concepto 62 incluido por novedad. Por favor, verifique el porcentaje de gastos de representación para su escalafón y categoría.]') MSG_INTERFAZ ,TO_CLOB(q'[ERRRR_ALERCN62]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;