INSERT INTO CONCEPTOS(COMPANIA,ID_DE_CONCEPTO,NOMBRE_CONCEPTO,CLASE,DENOVEDAD,UNIDAD,REPORTEEPS,DEVRETENCION,NITDE,TIPOAGRCONCEPTOS,FACTOR_LEGALES,DOCPS,DOCPV,DOCVC,DOCPN,DOCCS,CONCEPTO_CUNE)
(SELECT COMPANIA,596,'AUXILIO SINDICAL POR INCAPACIDAD',CLASE,DENOVEDAD,UNIDAD,REPORTEEPS,DEVRETENCION,NITDE,TIPOAGRCONCEPTOS,FACTOR_LEGALES,DOCPS,DOCPV,DOCVC,DOCPN,DOCCS,CONCEPTO_CUNE FROM CONCEPTOS WHERE ID_DE_CONCEPTO = 378);
COMMIT;