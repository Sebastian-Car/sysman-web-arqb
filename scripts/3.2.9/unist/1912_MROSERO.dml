MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 1000340  ID_CODIGO ,TO_CLOB(q'[Error al crear la configuración Control Cartera para el año --ANIO--]') MSG_INTERFAZ ,TO_CLOB(q'[ER_CONTAB_INSECONTROLCASRTERA]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;