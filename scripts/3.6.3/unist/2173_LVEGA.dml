MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000362  ID_CODIGO ,TO_CLOB(q'[No se puede liquidar el periodo para aprendiz en etapa lectiva: --CODIGO-- ,--NOMEMPLEADO--]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_SENAL7]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;
