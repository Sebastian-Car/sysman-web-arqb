,'NOMBRE SECRETARIO PLANEACION' 
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'' 
,''  
,-1 
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'NOMBRE SECRETARIO PLANEACION' 
                        AND MODULO = -1); 
COMMIT;                       
