INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'MANEJA NOMINA HIBRIDA' 
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO' 
,'determina si la entidad maneja nominas mensuale y quincenales a la vez'  
,6 
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'MANEJA NOMINA HIBRIDA' 
                        AND MODULO = 6); 
COMMIT;