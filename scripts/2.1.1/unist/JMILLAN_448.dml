INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'RUTA CERTIFICADO CLOUDMERSIVE' 
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'/opt/sysman/CERTIFICADO/CLOUDMERSIVE/' 
,'Parametro que contiene la ruta del cetificado CLOUDMERSIVE'  
,87 
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                     FROM PARAMETRO
                     WHERE NOMBRE = 'RUTA CERTIFICADO CLOUDMERSIVE');
COMMIT;