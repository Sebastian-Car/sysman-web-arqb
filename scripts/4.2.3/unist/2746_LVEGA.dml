MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 84000015  ID_CODIGO ,TO_CLOB(q'[Error al insertar el registro --LINEA-- de --TABLA--.]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_CM_RIPS_JSON]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;
MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 84000016  ID_CODIGO ,TO_CLOB(q'[El número de factura --FACTURA-- ya se encuentra registrado para este tercero en el radicado --CONSECUTIVO--. No se pueden cargar los archivos]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_CM_EXISTEFACT_JSON]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;