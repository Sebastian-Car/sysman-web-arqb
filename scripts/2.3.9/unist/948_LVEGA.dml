INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'MANEJA FACTURAS CON IVA'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO' 
,'Habilita en facturación llevar el IVA al comprobante presupuestal'  
,69 
,SYSDATE
,'5'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'MANEJA FACTURAS CON IVA'
                        AND MODULO = 69);
COMMIT;