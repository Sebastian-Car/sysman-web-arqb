INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,MODULO
,DESCRIPCION
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'TIPOS CONCEPTOS ARRENDAMIENTOS' 
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO' 
,69
,'Parametro que permite listar los tipos de concepto de arrendamiento.'
,SYSDATE
,'5' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'TIPOS CONCEPTOS ARRENDAMIENTOS' 
                        AND MODULO = 69);
COMMIT;