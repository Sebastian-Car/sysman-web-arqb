INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'PERMITIR FACTURACION ARRENDAMIENTO' 
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO' 
,69
,SYSDATE
,'5' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'PERMITIR FACTURACION ARRENDAMIENTO' 
                        AND MODULO = 69);
COMMIT;
