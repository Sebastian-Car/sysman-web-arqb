INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'ALMACEN INTERCOMPANIAS'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO'
,'Determina si maneja almacén con intercompanias'
,-1
,SYSDATE
,'5'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'ALMACEN INTERCOMPANIAS'
                        AND MODULO = -1);
COMMIT;