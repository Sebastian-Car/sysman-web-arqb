  MERGE INTO PORCENTAJES_FSP_Y_ADICIONAL FIN
USING (SELECT '001' AS COMPANIA, '2025' AS ANO, 'A' AS ESTADO, 7 AS LIMITE_INFERIOR, 11 AS LIMITE_SUPERIOR,
 1 PORCENTAJE_FSP,
 0.8 PORCENTAJE_ADICIONALFSP,
 9964500 VALOR_MINIMO,
 15658499 VALOR_MAXIMO,
 'ADMIN' CREATED_BY,
 SYSDATE DATE_CREATED FROM DUAL) INI
 ON (FIN.COMPANIA = INI.COMPANIA 
AND FIN.ANO = INI.ANO 
AND FIN.ESTADO = INI.ESTADO 
AND FIN.LIMITE_INFERIOR = INI.LIMITE_INFERIOR 
AND FIN.LIMITE_SUPERIOR = INI.LIMITE_SUPERIOR)
WHEN MATCHED THEN UPDATE SET
  FIN.PORCENTAJE_FSP = INI.PORCENTAJE_FSP,
  FIN.PORCENTAJE_ADICIONALFSP = INI.PORCENTAJE_ADICIONALFSP,
  FIN.VALOR_MINIMO = INI.VALOR_MINIMO,
  FIN.VALOR_MAXIMO = INI.VALOR_MAXIMO,
  FIN.MODIFIED_BY = INI.CREATED_BY,
  FIN.DATE_MODIFIED = INI.DATE_CREATED
WHEN NOT MATCHED THEN
  INSERT (FIN.COMPANIA, FIN.ANO, FIN.ESTADO, FIN.LIMITE_INFERIOR, FIN.LIMITE_SUPERIOR, FIN.PORCENTAJE_FSP, FIN.PORCENTAJE_ADICIONALFSP, FIN.VALOR_MINIMO, FIN.VALOR_MAXIMO, FIN.CREATED_BY, FIN.DATE_CREATED)
  VALUES (INI.COMPANIA, INI.ANO, INI.ESTADO, INI.LIMITE_INFERIOR, INI.LIMITE_SUPERIOR, INI.PORCENTAJE_FSP, INI.PORCENTAJE_ADICIONALFSP, INI.VALOR_MINIMO, INI.VALOR_MAXIMO, INI.CREATED_BY, INI.DATE_CREATED);
COMMIT;
