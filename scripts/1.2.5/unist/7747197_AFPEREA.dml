MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000354  ID_CODIGO ,TO_CLOB(q'[Al empleado --NOMBRE--, se le calcularon los conceptos 115 y 132 en los ID -- ID--.]') MSG_INTERFAZ ,TO_CLOB(q'[ALERT_DOS_ID]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;