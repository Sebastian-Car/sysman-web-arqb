MERGE INTO FORMULARIO_APLICACION FIN USING (SELECT '35' APLICACION,'459' FORMULARIO,'Panel Principal\Precontractual\Procesos\Estudios Previos ' RUTA,null CREATED_BY,null MODIFIED_BY,null DATE_CREATED,null DATE_MODIFIED FROM DUAL) INI ON (FIN.APLICACION = INI.APLICACION AND FIN.FORMULARIO = INI.FORMULARIO) WHEN NOT MATCHED THEN INSERT (APLICACION,FORMULARIO,RUTA,CREATED_BY,MODIFIED_BY,DATE_CREATED,DATE_MODIFIED) VALUES (INI.APLICACION,INI.FORMULARIO,INI.RUTA,INI.CREATED_BY,INI.MODIFIED_BY,INI.DATE_CREATED,INI.DATE_MODIFIED);
COMMIT;
BEGIN
	INSERT INTO GRUPO_FORMULARIO (COMPANIA,GRUPO,FORMULARIO,APLICACION,ADICIONAR,BORRAR,MODIFICAR,CONSULTAR,EXPORTAR)
	(
	SELECT 	CODIGO COMPANIA, DWL.GRUPO, DWL.FORMULARIO, DWL.APLICACION, '-1' ADICIONAR, '-1' BORRAR, '-1' MODIFICAR, '-1' CONSULTAR, '-1' EXPORTAR 
	FROM 	COMPANIA, ( SELECT 'ADMIN_WORKFLOW' GRUPO, '459' FORMULARIO, '35' APLICACION FROM DUAL) DWL
	WHERE   COMPANIA.CODIGO IN (SELECT COMPANIA FROM GRUPO_COMPANIA WHERE GRUPO = 'ADMIN_WORKFLOW')
	);
EXCEPTION WHEN DUP_VAL_ON_INDEX THEN
    NULL;
END;
/
COMMIT;