	"METODO_HTTP" VARCHAR2(10 CHAR), 
	"METODO" VARCHAR2(150 CHAR), 
	"SERVICIO_CONTEO" NUMBER(4,0), 
	"RECURSO_CONTEO" VARCHAR2(3 CHAR), 
	"CREATED_BY" VARCHAR2(32 CHAR), 
	"MODIFIED_BY" VARCHAR2(32 CHAR), 
	"DATE_CREATED" TIMESTAMP (6) WITH LOCAL TIME ZONE, 
	"DATE_MODIFIED" TIMESTAMP (6) WITH LOCAL TIME ZONE
   ) SEGMENT CREATION IMMEDIATE 
  PCTFREE 10 PCTUSED 40 INITRANS 1 MAXTRANS 255 
 NOCOMPRESS LOGGING
  STORAGE(INITIAL 589824 NEXT 1048576 MINEXTENTS 1 MAXEXTENTS 2147483645
  PCTINCREASE 0 FREELISTS 1 FREELIST GROUPS 1
  BUFFER_POOL DEFAULT FLASH_CACHE DEFAULT CELL_FLASH_CACHE DEFAULT)
  TABLESPACE "#TB_ESQUELETO_IRIS#" ;
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."API_RECURSOS"."SERVICIO" IS 'ID del servicio padre del recurso';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."API_RECURSOS"."ID" IS 'ID del recurso, se usa para complementar la ruta, por ejemplo: /numerozonas';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."API_RECURSOS"."URL" IS 'Ruta que identifica al recuros dentro del servicio, por ejemplo: /contar/id';
