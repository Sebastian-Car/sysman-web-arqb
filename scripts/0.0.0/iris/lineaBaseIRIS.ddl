--------------------------------------------------------
--  DDL for Trigger BIU_USUARIO
--------------------------------------------------------
  CREATE OR REPLACE EDITIONABLE TRIGGER "#ESQUELETO_IRIS#"."BIU_USUARIO" 
/*
Release 2.0.0
*/
BEFORE INSERT OR UPDATE OF PASSWORD ON USUARIO 
FOR EACH ROW
BEGIN
 IF :NEW.TIPOCUENTA LIKE 'U' THEN
    IF :NEW.PASSWORD IS NULL THEN
      BEGIN
      RAISE PCK_EXCEPCIONES.EXC_GENERAL;           
      EXCEPTION WHEN PCK_EXCEPCIONES.EXC_GENERAL THEN 
          PCK_ERR_MSG.RAISE_WITH_MSG(
                 UN_EXC_COD => SQLCODE,
                 UN_TABLAERROR=>'USUARIO',
                 UN_ERROR_COD => 'El usuario no puede quedar sin contrase?a'
               );
      END; 
    END IF;
   IF INSERTING THEN
      SELECT UPPER(PCK_SYSMAN_UTL.FC_ENCRIPTARMD5(:NEW.PASSWORD))
        INTO :NEW.PASSWORD
      FROM DUAL;
   END IF;    
   IF UPDATING AND :NEW.PASSWORD <> :OLD.PASSWORD  THEN
      SELECT UPPER(PCK_SYSMAN_UTL.FC_ENCRIPTARMD5(:NEW.PASSWORD))
        INTO :NEW.PASSWORD
      FROM DUAL;
    END IF;
 ELSE
  :NEW.PASSWORD :=NULL;
 END IF;
END;
/
ALTER TRIGGER "#ESQUELETO_IRIS#"."BIU_USUARIO" ENABLE;
