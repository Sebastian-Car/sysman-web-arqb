	"FECHA" TIMESTAMP (6) WITH LOCAL TIME ZONE DEFAULT NULL, 
	"IND_ACTIVACION" NUMBER(1,0) DEFAULT 0, 
	"MODULO" NUMBER(5,0), 
	"CARGO" VARCHAR2(12 CHAR), 
	"DIAS" NUMBER(3,0) DEFAULT 0, 
	"HORAS" NUMBER(3,0) DEFAULT 0, 
	"MINUTOS" NUMBER(3,0) DEFAULT 0, 
	"ULTIMA_FECHA" TIMESTAMP (6) WITH LOCAL TIME ZONE, 
	"COMPANIA" VARCHAR2(11 CHAR), 
	"MENSAJE" CLOB DEFAULT EMPTY_CLOB(), 
	"DEPENDENCIA" VARCHAR2(12 CHAR)
   ) SEGMENT CREATION IMMEDIATE 
  PCTFREE 5 PCTUSED 80 INITRANS 1 MAXTRANS 255 
