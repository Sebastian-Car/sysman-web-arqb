  CREATE OR REPLACE EDITIONABLE PACKAGE "#ESQUELETO_IRIS#"."PCK_SUBTIPOS" AS 
/*
Release 2.0.0
*/
   TYPE CLAVE_VALOR IS RECORD 
   (
     CLAVE                VARCHAR2(100),
     VALOR                VARCHAR2(1000)
   );  
   TYPE TI_CLAVEVALOR IS TABLE OF CLAVE_VALOR INDEX BY BINARY_INTEGER ;
   MI_CLAVEVALORNULL TI_CLAVEVALOR;
  --Tipos genericos para el manejo de números
  SUBTYPE TI_DOBLE        IS NUMBER(20,2);
  SUBTYPE TI_ENTERO       IS NUMBER(9 ,0);
  SUBTYPE TI_ENTERO_LARGO IS NUMBER(12 ,0);
  SUBTYPE TI_PORCENTAJE   IS NUMBER(9 ,6);
  SUBTYPE TI_LOGICO       IS NUMBER(1 ,0);
  SUBTYPE TI_MODULO       IS NUMBER(4 ,0);
  --Manejo de Errores y DAtos del ACME
  SUBTYPE TI_ERROR_FUN  IS NUMBER(15,0);
  SUBTYPE TI_TABLA      IS VARCHAR2(30 CHAR);
  SUBTYPE TI_CONDICION  IS VARCHAR2(15000 CHAR);
  SUBTYPE TI_EXCLUIDOS  IS VARCHAR2(15000 CHAR);
  SUBTYPE TI_CAMPOS     IS VARCHAR2(15000 CHAR);
  SUBTYPE TI_VALORES    IS VARCHAR2(15000 CHAR);
  SUBTYPE TI_CONSULTA   IS VARCHAR2(15000 CHAR);  
  SUBTYPE TI_MERGEUSING    IS VARCHAR2(15000 CHAR);  
  SUBTYPE TI_MERGEENLACE   IS VARCHAR2(15000 CHAR);  
  SUBTYPE TI_MERGEEXISTE   IS VARCHAR2(15000 CHAR);  
  SUBTYPE TI_MERGENOEXISTE IS VARCHAR2(15000 CHAR); 
  SUBTYPE TI_STRSQL     IS VARCHAR2(32000 CHAR);
  SUBTYPE TI_RTA_ACME   IS VARCHAR2(4000 CHAR);
  SUBTYPE TI_USUARIO    IS VARCHAR2(50 CHAR);
  -- Manejo de datos Modulo Predial
  SUBTYPE TI_CODPREDIO  IS VARCHAR2(50 CHAR);   --Código o cédula catastral del predio
  SUBTYPE TI_NUMORDEN   IS VARCHAR2(3 CHAR);    --Número de orden del propietario del predio
  SUBTYPE TI_DOCNUM     IS VARCHAR2(10 CHAR);   -- Número de Factura en predial
END PCK_SUBTIPOS;
