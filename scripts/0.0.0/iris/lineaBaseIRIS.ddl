  PCTINCREASE 0
  BUFFER_POOL DEFAULT FLASH_CACHE DEFAULT CELL_FLASH_CACHE DEFAULT)) ;
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."CODIGO" IS 'Código que identifica la alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."TEXTO" IS 'Texto de alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."MOVIMIENTO" IS 'Indicador que identifica si la alerta tiene movimiento.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."CREATED_BY" IS 'Campo de auditoria que almacena el código del usuario que creó el registro.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."MODIFIED_BY" IS 'Campo de auditoria que almacena el código del usuario que realizo modificación más reciente.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."DATE_CREATED" IS 'Campo de auditoria que almacena la fecha de creación del registro.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."DATE_MODIFIED" IS 'Campo de auditoria que almacena la fecha de modificación más reciente.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."ROL" IS 'Rol del usuario que identifica la alerta.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."USUARIO" IS 'Usuario al cual se registra la alerta.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."FECHA" IS 'Fecha en la cual se genero la alerta.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."IND_ACTIVACION" IS 'Indica si se activa o desactiva la alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."MODULO" IS 'Código del módulo de la aplicación.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."CARGO" IS 'Campo que almacena el cargo';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."DIAS" IS 'Día de la alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."HORAS" IS 'Hora de la alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."MINUTOS" IS 'Minuto de la alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."ULTIMA_FECHA" IS 'Ultima fecha en la cual fue generada la alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."COMPANIA" IS 'Código de la compañía.';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."MENSAJE" IS 'Campo en el cual se registra el select de la alerta';
   COMMENT ON COLUMN "#ESQUELETO_IRIS#"."ALERTAS"."DEPENDENCIA" IS 'Código de la dependencia a la cual se le asignan los cargos';
