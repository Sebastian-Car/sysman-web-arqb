  )
RETURN VARCHAR2
AS
  MI_FECHA VARCHAR2(128);
BEGIN
  MI_FECHA := ' TO_DATE(''' || TO_CHAR(UN_FECHA, 'MM/DD/YYYY HH:MI:SS') || ''',  ''MM/DD/YYYY HH:MI:SS'')';  
  RETURN MI_FECHA;
END FC_SDATE;
