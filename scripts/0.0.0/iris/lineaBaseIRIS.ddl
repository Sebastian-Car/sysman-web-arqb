      AUTHOR MIGRACION  : CARLOS ALBERTO MANRIQUE PALACIOS
      DATE MIGRADOR     : 17/10/2015
      TIME              : 14:00 PM
      SOURCE MODULE     : General
      MODIFIER          : 
      DATE MODIFIED     : 
      TIME              : 
      DESCRIPTION       : AL RELACIONAR UNA COMPA?IA CON UN GRUPO  RELACIONA TODAS LAS OPCIONES DE MENU Y FORMULARIOS
                          DE LA APLIACION A DEL GRUPO CON TODOS LOS PERMISOS EN VERDADERO 
    */
  DECLARE 
    MI_RETURN NUMBER;
  BEGIN
    MI_RETURN:= PCK_DATOS.FC_ACME( UN_TABLA => 'GRUPO_MENU', 
                                  UN_ACCION => 'IS', 
                                  UN_CAMPOS => 'COMPANIA,GRUPO,MENU,APLICACION,VER',
                                  UN_VALORES=> 'SELECT '''||:NEW.COMPANIA||''','''|| :NEW.GRUPO||''',CODIGO,APLICACION,-1 
                                                FROM MENU
                                                WHERE APLICACION='||'(SELECT APLICACION 
                                                                      FROM USUARIO 
                                                                      WHERE CODIGO LIKE '''||:NEW.GRUPO||''')');
   MI_RETURN:= PCK_DATOS.FC_ACME( UN_TABLA => 'GRUPO_FORMULARIO', 
                                  UN_ACCION => 'IS', 
                                  UN_CAMPOS => 'COMPANIA,GRUPO,FORMULARIO,APLICACION,ADICIONAR,BORRAR,MODIFICAR,CONSULTAR,EXPORTAR',
                                  UN_VALORES=> 'SELECT '''||:NEW.COMPANIA||''','''|| :NEW.GRUPO||''',FORMULARIO,APLICACION,-1,-1,-1,-1,-1
                                                FROM FORMULARIO_APLICACION
                                                WHERE APLICACION='||'(SELECT APLICACION 
                                                                      FROM USUARIO 
                                                                      WHERE CODIGO LIKE '''||:NEW.GRUPO||''')');
  END;
/
ALTER TRIGGER "#ESQUELETO_IRIS#"."AI_GRUPO_COMPANIA" ENABLE;
--------------------------------------------------------
--  DDL for Trigger AL_SYSMANIRISST
--------------------------------------------------------
  CREATE OR REPLACE EDITIONABLE TRIGGER "#ESQUELETO_IRIS#"."AL_SYSMANIRISST" 
AFTER LOGON ON #ESQUELETO_IRIS#.SCHEMA 
/*
Release 2.0.0
*/
BEGIN
  EXECUTE IMMEDIATE 'ALTER SESSION SET NLS_NUMERIC_CHARACTERS = ''.,''';
  EXECUTE IMMEDIATE 'ALTER SESSION SET NLS_TIMESTAMP_FORMAT =''DD/MM/YYYY HH24:MI:SS'''; 
  EXECUTE IMMEDIATE 'ALTER SESSION SET NLS_DATE_FORMAT =''DD/MM/YYYY HH24:MI:SS'''; 
  EXECUTE IMMEDIATE 'ALTER SESSION SET NLS_TIMESTAMP_TZ_FORMAT =''DD/MM/YYYY HH24:MI:SS'''; 
  EXECUTE IMMEDIATE 'ALTER SESSION SET TIME_ZONE=''-05:00'''; 
END;
/
ALTER TRIGGER "#ESQUELETO_IRIS#"."AL_SYSMANIRISST" ENABLE;
--------------------------------------------------------
--  DDL for Trigger BI_EVENTOS_CALENDARIO
--------------------------------------------------------
  CREATE OR REPLACE EDITIONABLE TRIGGER "#ESQUELETO_IRIS#"."BI_EVENTOS_CALENDARIO" 
/*
Release 2.0.0
*/
/*
  NAME             : BI_EVENTOS_CALENDARIO
  AUTHORS          : SYSMAN SAS
  AUTHOR MIGRACION : JUAN CARLOS RODRIGUEZ AMEZQUITA
  DATE MIGRADOR    : 05/09/2017
  TIME             : 03:13 PM
  DESCRIPTION      : Trigger antes de insertar la tabla EVENTOS_CALENDARIO, para 
                     generar auto numerico para el codigo del evento.
*/
   BEFORE INSERT ON EVENTOS_CALENDARIO
   FOR EACH ROW 
BEGIN  
  -- Genera consecutivo
  SELECT NVL(MAX(CODIGO),0)+1
  INTO :NEW.CODIGO
  FROM EVENTOS_CALENDARIO;
END;
/
ALTER TRIGGER "#ESQUELETO_IRIS#"."BI_EVENTOS_CALENDARIO" ENABLE;
