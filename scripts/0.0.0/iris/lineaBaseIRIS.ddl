FUNCTION FC_IIF     
  (
    UN_CONDICION  BOOLEAN,
    UN_SI         VARCHAR2,
    UN_NO         VARCHAR2 DEFAULT NULL
  )
RETURN VARCHAR2 
AS   
BEGIN    
      IF UN_CONDICION  THEN
         RETURN (UN_SI);
      ELSE 
         RETURN (UN_NO);   
      END IF;
END FC_IIF;
FUNCTION FC_IIF     
  (
    UN_CONDICION  VARCHAR2,
    UN_SI         VARCHAR2,
    UN_NO         VARCHAR2 DEFAULT NULL
  )
RETURN VARCHAR2 
AS
  MI_CONDICION  NUMBER;
BEGIN
      MI_CONDICION:=FC_EVAL(UN_CONDICION);
      IF MI_CONDICION<>0  THEN
         RETURN (UN_SI);
      ELSE 
         RETURN (UN_NO);
      END IF;
END FC_IIF;
FUNCTION FC_IIF
  (
    UN_CONDICION  Boolean,
    UN_SI         DATE,
    UN_NO         DATE DEFAULT NULL
  )
RETURN DATE 
AS
BEGIN
      IF UN_CONDICION THEN
         RETURN (UN_SI);
      ELSE
         RETURN (UN_NO);
      END IF;
END FC_IIF;
FUNCTION FC_IIF
  (
    UN_CONDICION  Boolean,
    UN_SI         NUMBER,
