--------------------------------------------------------
  CREATE OR REPLACE EDITIONABLE PACKAGE BODY "#ESQUELETO_IRIS#"."PCK_ADMINSISTEMA" AS
/*
Release 2.0.0
*/
--01
PROCEDURE PR_CREAR_MENU
/*
    NAME              : PR_CREAR_MENU
    AUTHORS           : SYSMAN  SAS
    AUTHOR MIGRACION  : NICOLÁS GÓMEZ BARBOSA
    DATE MIGRADOR     : 21/01/2016
    TIME              : 02:00 PM
    SOURCE MODULE     : 
    DESCRIPTION       : Crea una opción de menú en las tablas que ello implica(MENU,MENU_D).
  */
  (
  UN_PADRE            NUMBER:='',
  UN_CODIGO           NUMBER,
  UN_APLICACION       NUMBER,
  UN_NOMBRE           VARCHAR2,
  UN_DESCRIPCION_RUTA VARCHAR2:='',
  UN_TIPO             VARCHAR2 DEFAULT 'M',
  UN_COMANDO          VARCHAR2:='',
  UN_RUTA_ICONO       VARCHAR2:='',
  UN_PARAMETRO        VARCHAR2:='',
  UN_ORDEN            NUMBER:=99
  )
  AS
    MI_ERROR_FUN        NUMBER:= GL_ERROR_NUM + 1;
    MI_CAMPOS           VARCHAR2(32000);
    MI_VALORES          VARCHAR2(32000);
    MI_AUX              VARCHAR2(32000);
    MI_AUXORDEN         NUMBER;
    MI_AUXTIPO          VARCHAR2(1);
  BEGIN
    MI_AUXORDEN:=NVL(UN_ORDEN,99);
    MI_AUXTIPO:=NVL(UN_TIPO,'M');
    MI_CAMPOS:='CODIGO,APLICACION,TIPO,NOMBRE,COMANDO,RUTA_ICONO,PARAMETRO,ORDEN';
    MI_VALORES := ''||UN_CODIGO||','||UN_APLICACION||','''||MI_AUXTIPO||''','''||UPPER(UN_NOMBRE)||''','''||UN_COMANDO||''','''
      ||UN_RUTA_ICONO||''','''||UN_PARAMETRO||''','||MI_AUXORDEN||'';
    PCK_DATOS.GL_RTA := PCK_DATOS.FC_ACME ('MENU', 'I', MI_CAMPOS, MI_VALORES);
    IF UN_PADRE IS NULL THEN
      MI_AUX:='NULL';
    ELSE
      MI_AUX:=UN_PADRE;
    END IF;
    MI_CAMPOS:='APLICACION,MENU,MENUPADRE,DESCRIPCION';
    MI_VALORES := ''||UN_APLICACION||','||UN_CODIGO||','||MI_AUX||','''||UN_DESCRIPCION_RUTA||'''';
    PCK_DATOS.GL_RTA := PCK_DATOS.FC_ACME ('MENU_D', 'I', MI_CAMPOS, MI_VALORES);
  EXCEPTION WHEN OTHERS THEN
    PCK_DATOS.GL_ERROR_MSG := 'Error al crear tabla';
    PCK_DATOS.GL_ERROR_MSG := PCK_SYSMAN_UTL.FC_EVALUAR_ERROR(MI_ERROR_FUN, PCK_DATOS.GL_ERROR_MSG,  'MENU','',SQLERRM );
    RAISE_APPLICATION_ERROR (-20000, PCK_DATOS.GL_ERROR_MSG || CHR(10) || PCK_DATOS.GL_ERROR_MSG ); 
END PR_CREAR_MENU;
--02
PROCEDURE PR_CREAR_FORMULARIO
/*
    NAME              : PR_CREAR_FORMULARIO
    AUTHORS           : SYSMAN  SAS
    AUTHOR MIGRACION  : NICOLÁS GÓMEZ BARBOSA
    DATE MIGRADOR     : 21/01/2016
    TIME              : 04:00 PM
    SOURCE MODULE     : 
    DESCRIPTION       : Crea un formulario en las tablas que ello implica(FORMULARIO,FORMULARIO_APLICACION).
  */
  (
  UN_CODIGO           NUMBER,
  UN_APLICACION       NUMBER,
  UN_NOMBRE           VARCHAR2:='',
  UN_DESCRIPCION      VARCHAR2:='',
  UN_RUTA             VARCHAR2:='',
  UN_RUTA_MENU        VARCHAR2:='',
  UN_MODAL            NUMBER DEFAULT 0,
  UN_ANCHO_MODAL      NUMBER DEFAULT 0,
  UN_ALTO_MODAL       NUMBER DEFAULT 0
  )
  AS
    MI_ERROR_FUN        NUMBER:= GL_ERROR_NUM + 2;
    MI_CAMPOS           VARCHAR2(32000);
    MI_VALORES          VARCHAR2(32000);
    MI_AUXMODAL         NUMBER;
    MI_AUXANCHO         NUMBER;
    MI_AUXALTO          NUMBER;
  BEGIN
    MI_AUXMODAL:=NVL(UN_MODAL,0);
    MI_AUXANCHO:=NVL(UN_ANCHO_MODAL,0);
    MI_AUXALTO:=NVL(UN_ALTO_MODAL,0);
    MI_CAMPOS:='CODIGO_FORMULARIO,NOMBRE_FORMULARIO,DESCRIPCION_FORMULARIO,RUTA,MODAL,ANCHO_MODAL,ALTO_MODAL';
    MI_VALORES := ''||UN_CODIGO||','''||UPPER(UN_NOMBRE)||''','''||UN_DESCRIPCION||''','''||UN_RUTA||''','||MI_AUXMODAL||','||MI_AUXANCHO||','||MI_AUXALTO||'';
    PCK_DATOS.GL_RTA := PCK_DATOS.FC_ACME ('FORMULARIO', 'I', MI_CAMPOS, MI_VALORES);
    MI_CAMPOS:='APLICACION,FORMULARIO,RUTA';
    MI_VALORES := ''||UN_APLICACION||','||UN_CODIGO||','''||UN_RUTA_MENU||'''';
    PCK_DATOS.GL_RTA := PCK_DATOS.FC_ACME ('FORMULARIO_APLICACION', 'I', MI_CAMPOS, MI_VALORES);
  EXCEPTION WHEN OTHERS THEN
    PCK_DATOS.GL_ERROR_MSG := 'Error al crear tabla';
    PCK_DATOS.GL_ERROR_MSG := PCK_SYSMAN_UTL.FC_EVALUAR_ERROR(MI_ERROR_FUN, PCK_DATOS.GL_ERROR_MSG,  'FORMULARIO','',SQLERRM );
    RAISE_APPLICATION_ERROR (-20000, PCK_DATOS.GL_ERROR_MSG || CHR(10) || PCK_DATOS.GL_ERROR_MSG ); 
END PR_CREAR_FORMULARIO;
END PCK_ADMINSISTEMA;
/
