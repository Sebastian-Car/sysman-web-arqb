--INI_7746384_CONTABILIDAD(10/07/2024 bcardenas)
ALTER TABLE RETENCIONES ADD PRORRATEADO  NUMBER(1) DEFAULT 0;
ALTER TABLE RETENCIONES MODIFY PRORRATEADO  NOT NULL;

 CREATE TABLE PRORRATEADOS
   (  "COMPANIA" VARCHAR2(11 CHAR) NOT NULL , 
  "TIPO" VARCHAR2(3 CHAR) NOT NULL , 
  "ANO" NUMBER(4,0) NOT NULL , 
  "CODIGO" VARCHAR2(5 CHAR) NOT NULL , 
  "CUENTA_CREDITO" VARCHAR2(32 CHAR) NOT NULL , 
  "PCT_APLICAR" NUMBER(20,2) DEFAULT 0 NOT NULL , 
  "CREATED_BY" VARCHAR2(32 CHAR), 
  "MODIFIED_BY" VARCHAR2(32 CHAR), 
  "DATE_CREATED" TIMESTAMP (6) WITH LOCAL TIME ZONE, 
  "DATE_MODIFIED" TIMESTAMP (6) WITH LOCAL TIME ZONE
   ) PCTFREE 5 PCTUSED 80
    STORAGE(INITIAL 267K NEXT 10K PCTINCREASE 0 MINEXTENTS 1 MAXEXTENTS 90)
TABLESPACE "#TB_ESQUELETO_UNIST#"
;

ALTER TABLE PRORRATEADOS ADD (
    CONSTRAINT PK_PRORRATEADOS PRIMARY KEY ("COMPANIA", "TIPO", "ANO", "CODIGO", "CUENTA_CREDITO")
        USING INDEX TABLESPACE "#TN_ESQUELETO_UNIST#"
       STORAGE ( INITIAL 6 K NEXT 10 K PCTINCREASE 0 MINEXTENTS 1 MAXEXTENTS 90 ));

--FIN_7746384_CONTABILIDAD(10/07/2024 bcardenas)
commit;
