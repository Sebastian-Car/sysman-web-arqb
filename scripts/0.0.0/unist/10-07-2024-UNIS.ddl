CREATE TABLE PROCESOS_JUDICIALES
  (
COMPANIA            VARCHAR2(11 CHAR) NOT NULL,
CODIGO              VARCHAR2(16 CHAR) NOT NULL,
NUMEROPROCESO       VARCHAR2(23 CHAR) NOT NULL,       
TERCERO             VARCHAR2(18 CHAR),              
SUCURSAL            VARCHAR2(3 CHAR),
VALOR               NUMBER(20,2) DEFAULT 0 NOT NULL,
FECHA_INGRESO       TIMESTAMP(6) WITH LOCAL TIME ZONE,
TIPO_INGRESO        VARCHAR2(3 CHAR),
COMPROBANTE_INGRESO NUMBER(20,0),
MODIFICACIONES      NUMBER(20,2) DEFAULT 0 NOT NULL,
VALOR_ACTUAL        NUMBER(20,2) DEFAULT 0 NOT NULL,
PAGO                NUMBER(1,0) DEFAULT 0 NOT NULL,
CREATED_BY          VARCHAR2(32 CHAR),
MODIFIED_BY         VARCHAR2(32 CHAR),
DATE_CREATED        TIMESTAMP(6) WITH LOCAL TIME ZONE,
DATE_MODIFIED       TIMESTAMP(6) WITH LOCAL TIME ZONE
  )
PCTFREE 10 PCTUSED 80
STORAGE ( INITIAL 267K NEXT 10K
PCTINCREASE 0
MINEXTENTS 1 MAXEXTENTS 90)
TABLESPACE "#TB_ESQUELETO_UNIST#";

ALTER TABLE PROCESOS_JUDICIALES ADD CONSTRAINT PK_PROCESOS_JUDICIALES PRIMARY KEY (COMPANIA,CODIGO,NUMEROPROCESO)
 USING INDEX TABLESPACE "#TN_ESQUELETO_UNIST#"
 STORAGE ( INITIAL 8K NEXT 10K
 PCTINCREASE 0
MINEXTENTS 1 MAXEXTENTS 90);
