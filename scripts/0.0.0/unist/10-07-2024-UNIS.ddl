--INI_7746176 (17/05/2024 bcardenas)
CREATE TABLE VLR_NOTA_CREDITO
(
COMPANIA VARCHAR2(11 CHAR) NOT NULL,
CLASEORDEN VARCHAR2(3 CHAR) NOT NULL,
ORDENDECOMPRA NUMBER(15,0) NOT NULL,
CODIGO NUMBER(11,0) NOT NULL,
FECHA TIMESTAMP(6) WITH LOCAL TIME ZONE,
VALOR NUMBER(20,2),
DESCRIPCION VARCHAR2(4000 CHAR),
USUARIO VARCHAR2(32 CHAR),
CREATED_BY VARCHAR2(32 CHAR),
DATE_CREATED TIMESTAMP(6) WITH LOCAL TIME ZONE,
DATE_MODIFIED TIMESTAMP(6) WITH LOCAL TIME ZONE,
MODIFIED_BY VARCHAR2(32 CHAR)
)
PCTFREE 10 PCTUSED 80
STORAGE ( INITIAL 267K NEXT 10K
PCTINCREASE 0
MINEXTENTS 1 MAXEXTENTS 90)
TABLESPACE "#TB_ESQUELETO_UNIST#"
;

ALTER TABLE VLR_NOTA_CREDITO ADD CONSTRAINT PK_VLR_NOTA_CREDITO PRIMARY KEY (COMPANIA,CLASEORDEN,ORDENDECOMPRA,CODIGO)
 USING INDEX TABLESPACE "#TN_ESQUELETO_UNIST#"
 STORAGE ( INITIAL 8K NEXT 10K
 PCTINCREASE 0
MINEXTENTS 1 MAXEXTENTS 90);
--INI_7746176 (17/05/2024 bcardenas)
commit;

