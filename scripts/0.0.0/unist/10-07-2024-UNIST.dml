INSERT INTO PARAMETRO (
    COMPANIA
    ,NOMBRE
    ,FECHA_INICIAL
    ,VALOR
    ,DESCRIPCION
    ,MODULO
    ,DATE_CREATED
    ,TIPOPARAMETRO)
SELECT
    CODIGO
    ,'MANEJA DIFERENTES FORMATOS DE IMPRESION EN EGRESOS'
    ,TO_DATE('01/01/2000','DD/MM/YYYY')
    ,'NO'
    ,'Permite identificar si el formato de egreso a imprimir es Normal o de Transferencia'
    ,1
    ,SYSDATE
    ,'5'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                     FROM PARAMETRO
                     WHERE NOMBRE = 'MANEJA DIFERENTES FORMATOS DE IMPRESION EN EGRESOS'
                        AND MODULO = 1);

