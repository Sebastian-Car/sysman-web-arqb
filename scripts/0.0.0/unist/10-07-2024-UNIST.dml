INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'CARGO COORDINADOR PARA EL PAGO DE BONIFICACION' 
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'' 
,'Se debe especificar el codigo del/los cargo(s) de coordianador(es) al cual se le calcula la bonificacion, se deben separar por (,) si es mas de uno ej: 09001,09002'  
,6 
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'CARGO COORDINADOR PARA EL PAGO DE BONIFICACION' 
                        AND MODULO = 6); 

