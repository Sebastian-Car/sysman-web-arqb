--INI_7742479 (30/05/2024 cfbarrera)
MERGE INTO error_negocio fin
USING (
          SELECT
              61000351 id_codigo,
              to_clob(q'[El año anterior no se encontró en la tabla AÑO, no se puede continuar con el proceso.]') msg_interfaz,
              to_clob(q'[ALER_ANIO_ANT]') constante_relacionada
          FROM
              dual
      )
ini ON ( ini.id_codigo = fin.id_codigo )
WHEN MATCHED THEN UPDATE
SET fin.constante_relacionada = ini.constante_relacionada,
    fin.msg_interfaz = ini.msg_interfaz
WHEN NOT MATCHED THEN
INSERT (
    id_codigo,
    constante_relacionada,
    msg_interfaz )
VALUES
    ( ini.id_codigo,
      ini.constante_relacionada,
      ini.msg_interfaz );

 --FIN_7742479 (30/05/2024 cfbarrera)
commit;

