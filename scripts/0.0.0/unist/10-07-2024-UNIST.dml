--INI_7747226_NOMINA(19/06/2024 BCARDENAS)
MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000353  ID_CODIGO ,TO_CLOB(q'[El empleado --NOMBRES-- está solicitando un valor mayor de cesantías al acumulado a la fecha. Asigne un valor menor o igual a = --SALDO-- y vuelva a liquidar.]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_ANTICIPO_CESANTIAS]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
--FIN_7747226_NOMINA(19/06/2024 BCARDENAS)

