SELECT
  CODIGO
,'MANEJA ALERTAS EN ANTICIPO'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO' 
,'Este parámetro determina si el sistema debe activar o desactivar las alertas relacionadas con los anticipos.'  
,-1 
,SYSDATE
,'5' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'MANEJA ALERTAS EN ANTICIPO' 
                        AND MODULO = -1);
COMMIT;
