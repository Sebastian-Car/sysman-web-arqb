UPDATE APLICACIONES
SET IDBOT = 'fb964127-3621-4a6a-a8f3-3af587fea457',
    TOKENBOT = '251f790d-36de-4406-b7c3-b76fb96d8d32',
    USABOT = -1
WHERE APLICACION = 1;
COMMIT;
UPDATE APLICACIONES
SET IDBOT = '36995057-50d2-431b-8c21-95799fc41750',
    TOKENBOT = '33494e52-6e2c-4416-a046-538bece93d42',
    USABOT = -1
WHERE APLICACION = 3;
COMMIT;
UPDATE APLICACIONES
SET IDBOT = '07f26cd6-8f62-4c07-965a-ed49d2e629b4',
    TOKENBOT = 'a0ead5c2-8769-4da9-ac28-9bfca79f1cd2',
    USABOT = -1
WHERE APLICACION = 69;
COMMIT;
UPDATE APLICACIONES
SET IDBOT = '',
    TOKENBOT = '',
    USABOT = 0
WHERE APLICACION = 5;
COMMIT;
