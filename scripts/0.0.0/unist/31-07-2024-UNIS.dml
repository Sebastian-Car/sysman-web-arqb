    ,TO_DATE('01/01/2000','DD/MM/YYYY')
    ,'NO'
    ,'Permite configurar el referenciado para el concepto o servicio'
    ,1
    ,SYSDATE
    ,'5'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                     FROM PARAMETRO
                     WHERE NOMBRE = 'MANEJA REFERENCIADO EN CAUSACION AUTOMATICA'
                        AND MODULO = 1);
COMMIT;                       
UPDATE COMPROBANTE_CNTRETENCION SET CONCEPTO = '0' WHERE CONCEPTO IS NULL;
COMMIT;
UPDATE COMPROBANTE_CNTRETENCION SET PROVEEDOR = '0' WHERE PROVEEDOR IS NULL;
COMMIT;
UPDATE COMPROBANTE_CNTRETENCION SET REFERENCIADO = '0' WHERE REFERENCIADO IS NULL;
COMMIT;
UPDATE COMPROBANTE_CNTRETENCION SET CENTROCOSTO = '0' WHERE CENTROCOSTO IS NULL;
COMMIT;
UPDATE CAUSACION_AUTOMATICA SET REFERENCIADO = '0' WHERE REFERENCIADO IS NULL;
COMMIT;
UPDATE CAUSACION_AUTOMATICA SET CENTROCOSTO = '0' WHERE CENTROCOSTO IS NULL;
COMMIT;
