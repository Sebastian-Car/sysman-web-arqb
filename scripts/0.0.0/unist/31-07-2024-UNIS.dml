INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'PORCENTAJE MAXIMO PARA ADICIONES EN CONTRATO ORIGINAL'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,0
,'Porcentaje maximo para adicionar al contrato original. Ejemplo: si el aumento es de un 150%, el valor de este parametro sera 150' 
,9 
,SYSDATE
,'3' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'PORCENTAJE MAXIMO PARA ADICIONES EN CONTRATO ORIGINAL' 
                        AND MODULO = 9);
COMMIT;