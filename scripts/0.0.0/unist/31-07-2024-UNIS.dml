INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'CUERPO DEL CORREO CREACION ANTICIPOS'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'Estimado(a) Señor(a) s$nombreTercero$s, <br><br> Le informamos que ha sido registrado un anticipo por valor de s$valor$s con el comprobante No s$comprobante$s, emitido el s$fecha$s, con fecha de vencimiento el s$fechaVencimiento$s, por el concepto de s$descripcion$s. <br><br> Quedamos a su disposición para cualquier consulta adicional que pueda tener respecto a este anticipo.' 
,'Este parámetro almacena el contenido del mensaje que se incluirá en el cuerpo del correo electrónico de alertas relacionados con la creación de anticipos.'  
,-1 
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'CUERPO DEL CORREO CREACION ANTICIPOS' 
                        AND MODULO = -1);
COMMIT;                                         
INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'CUERPO DEL CORREO VENCIMIENTO ANTICIPOS'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'Estimado(a) Señor(a) s$nombreTercero$s, <br><br> Le informamos que el anticipo por valor de s$valor$s, con el comprobante No. s$comprobante$s, emitido el s$fecha$s y con fecha de vencimiento el s$fechaVencimiento$s, por el concepto de s$descripcion$s, ha vencido. <br><br> Quedamos a su disposición para cualquier consulta adicional que pueda tener respecto a este anticipo.' 
,'Este parámetro almacena el contenido del mensaje que se incluirá en el cuerpo del correo electrónico de alertas relacionados con la fecha de vencimiento de anticipos.'  
,-1 
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'CUERPO DEL CORREO VENCIMIENTO ANTICIPOS' 
                        AND MODULO = -1);
COMMIT;
INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'TIEMPO PARA ALERTAS EN ANTICIPO'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'00:00' 
,'Este parámetro define el tiempo específico en el que se generan las alertas relacionadas con los anticipos. El valor se expresa en el formato HH:MI, donde los primeros dos dígitos representan las horas y los últimos dos dígitos representan los minutos.'  
,-1 
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'TIEMPO PARA ALERTAS EN ANTICIPO' 
                        AND MODULO = -1);
COMMIT;
