MERGE INTO MODELO_TIPO_APLICACION FIN
USING (SELECT
        6 APLICACION, 
        57 TIPO,
        'MPEREZ' CREATED_BY,
        SYSDATE DATE_CREATED
    FROM DUAL)INI 
ON (    INI.APLICACION = FIN.APLICACION
    AND INI.TIPO = FIN.TIPO)
WHEN NOT MATCHED THEN
INSERT (
     APLICACION,TIPO,CREATED_BY,DATE_CREATED)
VALUES
    (INI.APLICACION,INI.TIPO,INI.CREATED_BY,INI.DATE_CREATED);
COMMIT;