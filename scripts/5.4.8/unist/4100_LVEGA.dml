INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'ENVIAR CAMPOS OBLIGATORIOS PQRS'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO'
,'Parametro para no obligar campos desde envio de PQRS'
,35 
,SYSDATE
,'5' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'ENVIAR CAMPOS OBLIGATORIOS PQRS' 
                        AND MODULO = 35); 
COMMIT;