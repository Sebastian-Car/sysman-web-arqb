INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'MANEJA PAC A RUBROS HIJOS'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO'
,'Parámetro para habilitar la opción Maneja PAC para rubros hijos'
,3 
,SYSDATE
,'5'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'MANEJA PAC A RUBROS HIJOS'
                        AND MODULO = 3);
COMMIT;