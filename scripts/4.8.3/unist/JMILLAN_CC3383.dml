MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000367  ID_CODIGO ,TO_CLOB(q'[Error al actualizar la mesada pensional del personal asociado al año: --ANIO--. por favor verifique los limites y procentajes de salud para pensionados]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_N_SALUD_PENSIONADOS]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;