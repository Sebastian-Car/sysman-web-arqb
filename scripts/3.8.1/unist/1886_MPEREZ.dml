INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'MANEJA FONDO PUBLICO PARA CESANTIAS'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO' 
,'Parametro que indica si se maneja fondo publico para cesantias '  
,6 
,SYSDATE
,'5'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'MANEJA FONDO PUBLICO PARA CESANTIAS'
                        AND MODULO = 6);
COMMIT;