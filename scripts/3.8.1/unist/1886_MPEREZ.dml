INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'CTA_DBT_ADMINISTRACION_CESANTIAS_PUBLICA'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'' 
,'Cuenta Debito Fondos Publicos Cesantias grupo contable Administracion'  
,6 
,SYSDATE
,'1'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'CTA_DBT_ADMINISTRACION_CESANTIAS_PUBLICA'
                        AND MODULO = 6);
COMMIT;					

