 INSERT INTO PARAMETRO (COMPANIA ,NOMBRE ,FECHA_INICIAL ,VALOR ,DESCRIPCION ,MODULO ,DATE_CREATED ,TIPOPARAMETRO) SELECT CODIGO ,'VISTO BUENO EN FORMATO DE CONCILIACION' ,TO_DATE('01/01/2000','DD/MM/YYYY') ,'VISTO BUENO EN FORMATO DE CONCILIACION' ,'Se Agrega firma Visto Bueno en formato de Conciliacion' ,1 ,SYSDATE ,'1' FROM COMPANIA WHERE CODIGO NOT IN (SELECT COMPANIA FROM PARAMETRO WHERE NOMBRE = 'VISTO BUENO EN FORMATO DE CONCILIACION' AND MODULO = 1);
 COMMIT;