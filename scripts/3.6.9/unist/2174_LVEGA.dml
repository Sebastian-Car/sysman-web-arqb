MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000361  ID_CODIGO ,TO_CLOB(q'[El empleado --EMPLEADO--, tiene en fondo de Riesgos = Ninguno, No se esta calculando seguridad social en Riesgos, revise la Novedad]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_NO_FONDO_RIESGOS]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;