MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 300000005  ID_CODIGO ,TO_CLOB(q'[No se puede liquidar viaticos en el periodo 01 para el empleado --NOMBRES--. Este periodo esta configurado para calculo de vacaciones.]') MSG_INTERFAZ ,TO_CLOB(q'[ALER_LIQVIATICOS]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;