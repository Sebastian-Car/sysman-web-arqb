INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'NOMBRE COLUMNA COD PPTAL' 
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'PRUEBAS PRUEBAS' 
,'Lleva el valor de la etiqueta NOMBRE COLUMNA COD PPTAL'  
,3
,SYSDATE
,'1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'NOMBRE COLUMNA COD PPTAL'
                        AND MODULO = 3); 
COMMIT;