MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 61000368  ID_CODIGO ,TO_CLOB(q'[El empleado --EMPLEADO--, Nro. de identificación --CEDULA--, presenta ingreso y retiro en el mismo mes. Se revisa calculo de parafiscales]') MSG_INTERFAZ ,TO_CLOB(q'[ALER_REVISION_PARAFISCALES]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;