INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'SF MANEJA FACTURACION DE ESTAMPILLA ELECTRONICA'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,'NO'
,'Si esta en SI Visualiza TIPOCONTRATO y NUMEROCONTRATO en el formulario de facturacion de concpetos'
,69
,SYSDATE
,'5'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'SF MANEJA FACTURACION DE ESTAMPILLA ELECTRONICA'
                        AND MODULO = 69);
COMMIT;                        
