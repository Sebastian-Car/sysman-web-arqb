INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'URL SERVICIO REST GATEWAY SIGEC'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,''
,'Se configura la URL de producción GATEWAY SIGEC'
,1
,SYSDATE
,'1'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'URL SERVICIO REST GATEWAY SIGEC'
                        AND MODULO = 1);
COMMIT;
INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'TOKEN AUTORIZACION SIGEC'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,''
,'Se configura el (Token) de autorización de la entidad en SIGEC.'
,1
,SYSDATE
,'1'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'TOKEN AUTORIZACION SIGEC'
                        AND MODULO = 1);
COMMIT;
