ALTER TABLE ALMACENCONTABILIDADCC DROP CONSTRAINT ALMACENCONTABILIDADCC_PK;
COMMIT;
ALTER TABLE ALMACENCONTABILIDADCC ADD (
    CONSTRAINT PK_ALMACENCONTABILIDADCC PRIMARY KEY (COMPANIA, CODIGOELEMENTO, TIPOMOVIMIENTO, ANO, CENTRO_COSTO, FUENTEDERECURSO)
        USING INDEX TABLESPACE TN_UNIST
       STORAGE ( INITIAL 6 K NEXT 10 K PCTINCREASE 0 MINEXTENTS 1 MAXEXTENTS 90 ));
