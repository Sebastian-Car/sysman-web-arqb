MERGE INTO FORMULARIO_APLICACION FIN USING (SELECT 99 APLICACION, 2495 FORMULARIO ,TO_CLOB(q'[PANEL PRINCIPAL/ENTES DE CONTROL/SIA/CONSOLIDACION INFORMES ENTES]') RUTA, 'LVEGA' CREATED_BY, NULL MODIFIED_BY  FROM DUAL ) INI ON (INI.APLICACION = FIN.APLICACION AND INI.FORMULARIO = FIN.FORMULARIO)  WHEN MATCHED THEN  UPDATE SET FIN.RUTA =  INI.RUTA,  FIN.MODIFIED_BY = INI.MODIFIED_BY, FIN.DATE_MODIFIED = SYSDATE  WHEN NOT MATCHED THEN  INSERT (APLICACION,FORMULARIO,RUTA,CREATED_BY,DATE_CREATED)  VALUES (INI.APLICACION,INI.FORMULARIO,INI.RUTA,INI.CREATED_BY,SYSDATE);
