INSERT INTO CONFIG_CIERRE_PPTAL (COMPANIA, TIPOCIERRE, CLASERESERVA, TIPO_DIS, TIPO_RES, TIPO_REO, DIGITOSCAMBIO, TIPOVIGENCIAINICI, TIPOVIGENCIAFINAL, CREAJERARQUIA, GENERAR, CREATED_BY, DATE_CREATED, MODIFIED_BY, DATE_MODIFIED, TIPO_ADI, RECLASIFICAR) SELECT c.CODIGO AS COMPANIA, 'REG', 'PASAIGUAL', ' ', '  ', NULL, '9', ' ', ' ', 0, 0, 'ADMIN', TIMESTAMP '2025-01-19 10:22:00.000000000', 'PRUEBAS_SS', TIMESTAMP '2025-01-27 06:26:00.000000000', NULL, 0 FROM COMPANIA c WHERE NOT EXISTS (SELECT 1 FROM CONFIG_CIERRE_PPTAL ccp WHERE ccp.COMPANIA = c.CODIGO AND ccp.TIPOCIERRE = 'REG' AND ccp.CLASERESERVA = 'PASAIGUAL');
COMMIT;