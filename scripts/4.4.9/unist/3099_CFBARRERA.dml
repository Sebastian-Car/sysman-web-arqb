MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 9000111  ID_CODIGO ,TO_CLOB(q'[El contrato --CONTRATO--, tipo --TIPO-- se encuentra con valor cero, debe definir un valor antes de aplicar una modificación.]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_CONTRATO_VALORCERO]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;