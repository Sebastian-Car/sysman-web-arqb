MERGE INTO ERROR_NEGOCIO FIN USING (SELECT 84000017  ID_CODIGO ,TO_CLOB(q'[Tabla: --TABLA--. Mensaje: --MENSAJE--]') MSG_INTERFAZ ,TO_CLOB(q'[ERR_CM_DUPLICADO_RIPS]') CONSTANTE_RELACIONADA  FROM DUAL ) INI ON (INI.ID_CODIGO = FIN.ID_CODIGO)  WHEN MATCHED THEN  UPDATE SET FIN.CONSTANTE_RELACIONADA = INI.CONSTANTE_RELACIONADA, FIN.MSG_INTERFAZ = INI.MSG_INTERFAZ WHEN NOT MATCHED THEN  INSERT (ID_CODIGO, CONSTANTE_RELACIONADA, MSG_INTERFAZ)  VALUES (INI.ID_CODIGO, INI.CONSTANTE_RELACIONADA, INI.MSG_INTERFAZ);
COMMIT;