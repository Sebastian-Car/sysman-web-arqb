INSERT INTO PARAMETRO (
  COMPANIA
,NOMBRE
,FECHA_INICIAL
,VALOR
,DESCRIPCION
,MODULO
,DATE_CREATED
,TIPOPARAMETRO)
SELECT
  CODIGO
,'KEY LOGIN APP EXTERNA'
,TO_DATE('01/01/2000','DD/MM/YYYY')
,''
,'Api key para login en app externa'
,-1
,SYSDATE
,'1'
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                       FROM PARAMETRO
                      WHERE NOMBRE = 'KEY LOGIN APP EXTERNA'
                        AND MODULO = -1);
COMMIT;