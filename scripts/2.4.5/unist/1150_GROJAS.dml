    'CARGO PROFESIONAL UNIVERSITARIO GRADO 02',
    'Cargo del profesional universitario grado 02',  
    1, 
    SYSDATE,
    '1' 
FROM COMPANIA
WHERE CODIGO NOT IN (SELECT COMPANIA
                     FROM PARAMETRO
                     WHERE NOMBRE = 'CARGO PROFESIONAL UNIVERSITARIO GRADO 02' 
                        AND MODULO = 1);
COMMIT;