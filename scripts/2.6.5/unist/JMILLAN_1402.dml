INSERT INTO PARAMETRO (COMPANIA ,NOMBRE ,FECHA_INICIAL ,VALOR ,MODULO ,DESCRIPCION ,DATE_CREATED ,TIPOPARAMETRO) SELECT CODIGO ,'CALCULAR RETENCION EN RETROACTIVO',TO_DATE('01/01/2000','DD/MM/YYYY') ,'NO',6 ,'Calcular retención en el mes de cálculo del retroactivo para los empleados con porcentaje fijo',SYSDATE ,'1'FROM COMPANIA WHERE CODIGO NOT IN (SELECT COMPANIA FROM PARAMETRO WHERE NOMBRE = 'CALCULAR RETENCION EN RETROACTIVO'AND MODULO = 1);
COMMIT;