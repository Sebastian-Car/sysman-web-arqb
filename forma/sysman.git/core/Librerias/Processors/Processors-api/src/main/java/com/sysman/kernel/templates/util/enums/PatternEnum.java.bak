package com.sysman.kernel.templates.util.enums;

/**
 * @author Erwin José Tirado Baldovino
 * 
 * @version 1.0
 * 
 * Enumeración que permite clasificar los atributos de búsqueda y reemplazo.
 */ 
public enum PatternEnum {
	
	REPLACEMENT("pattern","replace","param","patternHome","replaceHome","url");
	
	private final String pattern;
	private final String replace;
	private final String patternHome;
	private final String replaceHome;
	private final String param;
	private final String url;
	
	private PatternEnum(String pattern, String replace, String param, String patternHome, String replaceHome , String url) {
		this.pattern     = pattern;
		this.replace     = replace;
		this.param       = param;
		this.patternHome = patternHome;
		this.replaceHome = replaceHome;
		this.url		 = url;
	}

	public String getPattern() {
		return pattern;
	}

	public String getReplace() {
		return replace;
	}

	public String getParam() {
		return param;
	}

	public String getPatternHome() {
		return patternHome;
	}

	public String getReplaceHome() {
		return replaceHome;
	}
	
	public String getUrl () {
		return url;
	}
	 
}
