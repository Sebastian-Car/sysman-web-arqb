package com.sysman.kernel.templates.util.enums;

/**
 * @author Erwin José Tirado Baldovino
 * 
 * @version 1.0
 * 
 * Enumeración que contiene el listado de todos los properties disponibles en la librería.
 */ 
public enum PropertyEnum {
	
	PATTERNS("patterns"),
	PARAMS("parameters");
	
	private final String value;
	
	private PropertyEnum(String value) {
		this.value = value;
	}

	public String getValue() {
		return value;
	}
}
