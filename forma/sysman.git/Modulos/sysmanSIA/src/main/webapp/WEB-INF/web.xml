<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://java.sun.com/xml/ns/javaee"
	xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
	version="3.0">

 <display-name>sysmanSIA</display-name>
<filter>
		<filter-name>SetCharacterEncodingFilter</filter-name>
		<filter-class>com.sysman.conf.SetCharacterEncodingFilter</filter-class>
		<init-param>
			<param-name>encoding</param-name>
			<param-value>UTF-8</param-value>
		</init-param>
	</filter>
	<filter>
		<filter-name>PrimeFaces FileUpload Filter</filter-name>
		<filter-class>org.primefaces.webapp.filter.FileUploadFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>SetCharacterEncodingFilter</filter-name>
		<url-pattern>*.sysman</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>PrimeFaces FileUpload Filter</filter-name>
		<servlet-name>Faces Servlet</servlet-name>
	</filter-mapping>
	<servlet>
		<servlet-name>Faces Servlet</servlet-name>
		<servlet-class>javax.faces.webapp.FacesServlet</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet-mapping>
		<servlet-name>Faces Servlet</servlet-name>
		<url-pattern>*.sysman</url-pattern>
	</servlet-mapping>
	<session-config>
		<session-timeout>30</session-timeout>
	</session-config>
	<login-config>
		<auth-method>BASIC</auth-method>
		<realm-name>DBRealm</realm-name>
	</login-config>
	<security-role>
		<role-name>USER</role-name>
	</security-role>
	<env-entry>
		<description>Ruta de reportes</description>
		<env-entry-name>rutaReportes</env-entry-name>
		<env-entry-type>java.lang.String</env-entry-type>
		<env-entry-value>C:/Sysman/reportesWeb/</env-entry-value>
	</env-entry>
	<env-entry>
		<description>Titulo de todos los mensajes mostrados</description>
		<env-entry-name>tituloMensajes</env-entry-name>
		<env-entry-type>java.lang.String</env-entry-type>
		<env-entry-value>Sysman Software</env-entry-value>
	</env-entry>
</web-app>