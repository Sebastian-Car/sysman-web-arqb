					<textFieldExpression><![CDATA["El inmueble identificado con cédula catastral Nº " + $F{CODIGO} + " ubicado en la  " + RTrim(dirunificada) + "  de la ciudad,  y de su propiedad, adeuda al municipio de " + $P{PR_CIUDADCOMPANIA} + ", la suma de:  " + $P{UTILIDADES_SCRIPTLET}.moneda(TOTALDEUDA,0)  + " ( " +") , liquidado a " +" por concepto de impuesto predial, correspondientes a los años gravables de " + $F{INTERVALO} + ". En consecuencia el Area de impuestos de la Secretaría de Hacienda del Municipio de " + $P{PR_CIUDADCOMPANIA} +]]></textFieldExpression>
					
