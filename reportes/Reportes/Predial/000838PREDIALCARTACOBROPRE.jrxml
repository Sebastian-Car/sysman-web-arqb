					<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
						<font fontName="Arial" size="9" isBold="false" isItalic="false" isUnderline="false"   isStrikeThrough="false"/>
					</textElement>
					<textFieldExpression><![CDATA["Sírvase comparecer a este despacho dentro de los diez(10) siguientes al recibo de la presente, para notificarle las acreencias con la Secretaria de Hacienda Municipal de " + $P{PR_CIUDADCOMPANIA} + ", por concepto del Impuesto predial identificado con el numero catastral Nº  " + $F{CODIGO}]]></textFieldExpression>
					
				</textField>
				<textField  evaluationTime="Now" evaluationGroup="#GRUPO_EVALUACION#" isStretchWithOverflow="false" isBlankWhenNull="true">
					<reportElement key="Texto407" x="0" y="51" width="428" height="22" isRemoveLineWhenBlank="false" isPrintRepeatedValues="true" forecolor="#000000" mode="Transparent" backcolor="#FFFFFF"  positionType="Float" stretchType="NoStretch">
						
					</reportElement>
					<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
						<topPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
						<font fontName="Arial" size="9" isBold="false" isItalic="false" isUnderline="false"   isStrikeThrough="false"/>
					</textElement>
					<textFieldExpression><![CDATA["La administración municipal le invita a que en esta primera etapa de cobro persuasivo y de acercamiento, proceda al respectivo pago.  "]]></textFieldExpression>
					
				</textField>
				<textField  evaluationTime="Now" evaluationGroup="#GRUPO_EVALUACION#" isStretchWithOverflow="false" isBlankWhenNull="true">
					<reportElement key="Texto410" x="0" y="76" width="428" height="25" isRemoveLineWhenBlank="false" isPrintRepeatedValues="true" forecolor="#000000" mode="Transparent" backcolor="#FFFFFF"  positionType="Float" stretchType="NoStretch">
						
					</reportElement>
					<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
						<topPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
						<font fontName="Arial" size="9" isBold="false" isItalic="false" isUnderline="false"   isStrikeThrough="false"/>
					</textElement>
					<textFieldExpression><![CDATA["Le recomendamos que desde el año gravable  " + $F{PAGO_ANO} + " de  el inmueble tiene una deuda por la suma de $" + $F{TOTAL} ]]></textFieldExpression>
					
				</textField>
				<textField  evaluationTime="Now" evaluationGroup="#GRUPO_EVALUACION#" isStretchWithOverflow="false" isBlankWhenNull="true">
					<reportElement key="Texto411" x="0" y="105" width="428" height="37" isRemoveLineWhenBlank="false" isPrintRepeatedValues="true" forecolor="#000000" mode="Transparent" backcolor="#FFFFFF"  positionType="Float" stretchType="NoStretch">
						
					</reportElement>
					<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
						<topPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
						<font fontName="Arial" size="9" isBold="false" isItalic="false" isUnderline="false"   isStrikeThrough="false"/>
					</textElement>
					<textFieldExpression><![CDATA["Si por alguna circustancia ya ha complido con esta obligación oportunamente, le ofrecemos nuestras disculpas y le solicitamos nos infome por escrito, acreditando la documentación que soporte la extinción de la obligación.  "]]></textFieldExpression>
					
