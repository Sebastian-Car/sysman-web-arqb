					<reportElement key="Texto316" x="0" y="10" width="428" height="36" isRemoveLineWhenBlank="false" isPrintRepeatedValues="true" forecolor="#000000" mode="Transparent" backcolor="#FFFFFF"  positionType="Float" stretchType="NoStretch">
						
					</reportElement>
					<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
