				<textField pattern="#,##0.###" isBlankWhenNull="true">
					<reportElement key="Texto18" positionType="Float" mode="Transparent" x="360" y="180" width="155" height="10" forecolor="#000000" backcolor="#FFFFFF" uuid="f7b7ff0b-eeb6-46cc-888e-d33700a6d028"/>
					<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
						<pen lineWidth="0.5"/>
						<leftPen lineWidth="0.0"/>
					</box>
					<textElement textAlignment="Right" verticalAlignment="Middle" rotation="None">
