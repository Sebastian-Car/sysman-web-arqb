					<font fontName="Tahoma" size="10" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["En consideración a lo contemplado en el Plan de Desarrollo " + $P{PR_PLAN_DE_DESARROLLO} + "; cuyo objeto es " + $F{OBJETO_PROYECTO}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
