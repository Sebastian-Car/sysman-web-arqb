					<font fontName="Tahoma" size="10" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Que el proyecto  " + $F{NOMBREPROYECTO} + "  se encuentra registrado con código BPIM del sistema de seguimiento y evaluación de proyectos, SSEPI " + $F{CODIGOBPIM} + ", otorgado por el municipio de " + $P{PR_CIUDADCOMPANIA}]]></textFieldExpression>
