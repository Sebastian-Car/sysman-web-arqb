						<font fontName="Arial" size="9"/>
					</textElement>
					<textFieldExpression><![CDATA["Los recursos solicitados para el proceso contractual propuesto están asociados al Proyecto inscrito en el Banco de Programas y Proyectos de Inversión del municipio de Castilla la Nueva, con apropiación vigente de recursos en el Presupuesto de Inversión de la entidad y el Plan Operativo Anual de Inversiones para la vigencia fiscal 2024, según especificaciones descritas a continuación:"]]></textFieldExpression>
