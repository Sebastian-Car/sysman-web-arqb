	<group name="Group1" keepTogether="true">
		<groupHeader>
			<band height="145">
				<staticText>
					<reportElement x="0" y="14" width="508" height="18" uuid="beefda6b-d30f-4a78-af39-ade02b4d9721"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" isBold="true"/>
					</textElement>
					<text><![CDATA[CERTIFICA QUE:]]></text>
				</staticText>
				<textField>
					<reportElement x="0" y="33" width="508" height="57" uuid="743a56d8-266b-406b-9bb2-1bacccbb00d4"/>
					<textElement textAlignment="Justified" verticalAlignment="Middle">
						<font fontName="Arial"/>
					</textElement>
					<textFieldExpression><![CDATA["El proyecto de inversión con nombre "+ $F{NOMBRE_PROYECTO}.toUpperCase() +", se encuentra debidamente registrado con código BPIM No. "+  $F{CODIGO_BPIM}+" en el Banco de Programas y Proyectos de Inversión del municipio."]]></textFieldExpression>
				</textField>
				<textField>
					<reportElement x="1" y="91" width="508" height="54" uuid="8af76187-d299-45a1-8e51-359a7e201c02"/>
					<textElement textAlignment="Justified" verticalAlignment="Middle">
						<font fontName="Arial"/>
					</textElement>
					<textFieldExpression><![CDATA["El proyecto contribuye al cumplimiento de las metas del Plan de Desarrollo Municipal "+ "\""+$P{PR_PLAN_DE_DESARROLLO}.toUpperCase()+"\"" +", contempladas en el sector de "+ $F{NOMBRE_SECTOR}.toUpperCase()+", en el programa de "+$F{NOMBRE_PROGRAMA}.toUpperCase() +"."]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
	</group>
	<group name="Group2" keepTogether="true" preventOrphanFooter="true">
