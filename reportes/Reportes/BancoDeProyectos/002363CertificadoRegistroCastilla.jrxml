					<textElement verticalAlignment="Middle"/>
					<text><![CDATA[El valor de la ejecución del proyecto será obtenido del siguiente rubro:]]></text>
				</staticText>
				<staticText>
					<reportElement x="0" y="19" width="65" height="24" isPrintWhenDetailOverflows="true" uuid="cce9d103-15ee-4f3f-9754-b789ca6dd69e"/>
