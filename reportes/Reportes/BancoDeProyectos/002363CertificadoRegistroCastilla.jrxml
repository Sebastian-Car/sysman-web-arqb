					<textElement textAlignment="Justified"/>
					<textFieldExpression><![CDATA["La presente se expide a los "+ $F{DIA} +" días del mes de "+ $F{MES}+" de "+ $F{ANIO}+", con base en la solicitud realizada por "+$F{NOMBRE_RESPONSABLE}.toUpperCase() +" en su calidad de "+$F{CARGO_RESPONSABLE}.toUpperCase() +"."]]></textFieldExpression>
				</textField>
				<textField>
					<reportElement x="0" y="8" width="509" height="28" uuid="20dad511-a59f-45b9-ad75-a1e559fca58b"/>
					<textElement textAlignment="Justified" verticalAlignment="Top">
						<font fontName="Arial"/>
					</textElement>
					<textFieldExpression><![CDATA["Nota: La oficina "+$F{NOMBRE_DEPENDENCIA}.toUpperCase() +" realizo el estudio técnico, económico y jurídico de soporte del proyecto aquí certificado."]]></textFieldExpression>
				</textField>
			</band>
