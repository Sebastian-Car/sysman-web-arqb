					</textElement>
					<text><![CDATA[VIGENCIA]]></text>
				</staticText>
				<staticText>
					<reportElement x="65" y="19" width="150" height="24" isPrintWhenDetailOverflows="true" uuid="726eca69-223f-49ce-8e83-c0fe55768d70"/>
