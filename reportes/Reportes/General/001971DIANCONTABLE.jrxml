				<text><![CDATA[C.C. ó Nit. No.]]></text>
			</staticText>
			<staticText>
				<reportElement key="TerceraClausula" positionType="Float" mode="Transparent" x="5" y="724" width="318" height="6" forecolor="#000000" backcolor="#FFFFFF" uuid="48ab1920-3709-4280-b416-852a43af3774"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<text><![CDATA[ 2. No fui responsable del impuesto sobre las ventas]]></text>
			</staticText>
			<textField isBlankWhenNull="true">
				<reportElement key="SegundaClausula" positionType="Float" mode="Transparent" x="5" y="737" width="318" height="6" forecolor="#000000" backcolor="#FFFFFF" uuid="7859a2e5-f116-4167-81a4-a5d725b24c2c"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["4. Mis consumos mediante tarjetas de crédito no excedieron la suma de " + 
$F{CONSUMOTARJETACRE_UVT} + " (" +
new java.text.DecimalFormat("$ #,###").format($F{CONSUMOTARJETACRE_VALOR}) +  
")."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="AvisoDeclaracion" positionType="Float" mode="Transparent" x="5" y="756" width="318" height="6" forecolor="#000000" backcolor="#FFFFFF" uuid="15a2507e-ca88-4c4c-a991-842a37ad9b7c"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Por lo tanto, manifiesto que no estoy obligado a presentar " + 
"declaracion de renta y complementarios por el año gravable " + 
$F{ANO} + "."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="CuartaClausula" positionType="Float" mode="Transparent" x="5" y="730" width="318" height="7" forecolor="#000000" backcolor="#FFFFFF" uuid="b095fc92-f838-4964-9522-3a8ef84c6b47"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["3. Mis Ingresos totales fueron iguales o inferiores a " + 
$F{INGRESOSTOTALES_UVT} + " (" 
+ new java.text.DecimalFormat("$ #,###").format($F{INGRESOSTOTALES_VALOR}) + ")."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="PrimeraClausula" positionType="Float" mode="Transparent" x="5" y="718" width="318" height="6" forecolor="#000000" backcolor="#FFFFFF" uuid="12f11342-5e04-4804-bf9a-c0b9ebf612a3"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["1. Mi patrimonio bruto era igual o inferior a " 
+ $F{PATRIMONIOBRUTO_UVT} + " UVT. " + "($ "
+ new java.text.DecimalFormat("#,###").format($F{PATRIMONIOBRUTO_VALOR}) 
+ ")."]]></textFieldExpression>
			</textField>
			<staticText>
