				<textFieldExpression><![CDATA["6. Que el valor total de mis consignaciones bancarias, " + 
"depósitos o inversiones financieras no excedieron los "  
+ new java.text.DecimalFormat("#,###").format($F{CONSIGNACIONESBANCARIAS_UVT} )+ "(" + 
new java.text.DecimalFormat("$ #,###").format($F{CONSIGNACIONESBANCARIAS_VALOR}) + 
")."]]></textFieldExpression>
			</textField>
