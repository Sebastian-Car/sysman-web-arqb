					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Por lo tanto, manifiesto que no estoy obligado a presentar " + 
"declaracion de renta y complementarios por el año gravable " + 
$F{ANO} + "."]]></textFieldExpression>
