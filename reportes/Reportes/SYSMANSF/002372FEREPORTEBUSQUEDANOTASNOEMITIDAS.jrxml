	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Cajica-Desarrollo"/>
	<parameter name="PR_FECHA" class="java.util.Date"/>
	<parameter name="PR_STRSQL" class="java.lang.String"/>
	<parameter name="PR_IMAGENES" class="java.lang.String"/>
	<parameter name="PR_GETUSER" class="java.lang.String"/>
	<parameter name="PR_NOMBREEMPRESA" class="java.lang.String"/>
	<parameter name="PR_HORA" class="java.util.Date"/>
	<parameter name="PR_IMAGEN_ESPECIAL" class="java.lang.String"/>
	<parameter name="PR_HEADER_ESPECIAL" class="java.lang.Boolean"/>
	<parameter name="compania" class="java.lang.String"/>
	<parameter name="fechaI" class="java.lang.String"/>
	<parameter name="fechaF" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
	COMPROBANTE_CNT.NUMERO,
	TO_CHAR(COMPROBANTE_CNT.FECHA, 'DD/MM/YYYY') FECHA,
	COMPROBANTE_CNT.TERCERO,
	COMPROBANTE_CNT.VLR_DOCUMENTO
FROM
	COMPROBANTE_CNT
INNER JOIN TERCERO ON
	COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA
	AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT
	AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL
WHERE
	COMPROBANTE_CNT.COMPANIA = $P{compania}
	AND COMPROBANTE_CNT.FECHA BETWEEN $P{fechaI} AND $P{fechaF}
	AND COMPROBANTE_CNT.ANULADO != '-1'
	AND COMPROBANTE_CNT.TIPO = 'NCL'
	AND 
	COMPROBANTE_CNT.NUMERO NOT IN (
	SELECT
		NUMFORMATO
	FROM
		ESTADO_NOTAS)
ORDER BY
	COMPROBANTE_CNT.COMPANIA,
	COMPROBANTE_CNT.ANO,
	COMPROBANTE_CNT.TIPO,
	COMPROBANTE_CNT.NUMERO DESC,
	COMPROBANTE_CNT.FECHA DESC]]>
	</queryString>
	<field name="NUMERO" class="java.lang.String"/>
	<field name="FECHA" class="java.lang.String"/>
	<field name="TERCERO" class="java.lang.String"/>
	<field name="VLR_DOCUMENTO" class="java.lang.String"/>
