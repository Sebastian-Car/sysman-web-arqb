	<queryString>
		<![CDATA[SELECT 
ESTADO_NOTAS.CLASE,        
ESTADO_NOTAS.ESTADO,        
ESTADO_NOTAS.FECHA,        
ESTADO_NOTAS.NUMFACTURA,        
ESTADO_NOTAS.NUMFORMATO,
COMPROBANTE_CNT.VLR_DOCUMENTO VALOR,
COMPROBANTE_CNT.TERCERO,
ESTADO_NOTAS.OBSERVACION CUDE
FROM ESTADO_NOTAS,COMPROBANTE_CNT WHERE COMPROBANTE_CNT.NUMERO = ESTADO_NOTAS.NUMFORMATO AND TIPO = 'NCL']]>
	</queryString>
