<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="FEREPORTEBUSQUEDAFACTURA" pageWidth="520" pageHeight="624" orientation="Landscape" whenNoDataType="NoPages" columnWidth="492" leftMargin="14" rightMargin="14" topMargin="14" bottomMargin="14" isTitleNewPage="true" isSummaryWithPageHeaderAndFooter="true" whenResourceMissingType="Error" uuid="c774e22b-837d-4bfe-8042-5720b77745f7">
