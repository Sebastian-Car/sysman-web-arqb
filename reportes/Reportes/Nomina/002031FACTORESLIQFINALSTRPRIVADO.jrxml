			<staticText>
				<reportElement key="Texto120" positionType="Float" mode="Transparent" x="3" y="514" width="499" height="8" forecolor="#000000" backcolor="#FFFFFF" uuid="153d44cd-ed3f-4825-aae4-e0b0bf8f57c0"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
