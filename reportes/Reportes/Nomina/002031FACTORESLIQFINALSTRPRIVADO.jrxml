					<font fontName="Arial" size="6" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<text><![CDATA[reconocimiento ó pago. (Art. 15, C.S.T.). ]]></text>
			</staticText>
