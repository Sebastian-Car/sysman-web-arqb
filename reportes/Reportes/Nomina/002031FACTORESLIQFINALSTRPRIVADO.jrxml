			</textField>
			<textField pattern="#,##0.00" isBlankWhenNull="true">
				<reportElement key="Texto133" positionType="Float" mode="Transparent" x="382" y="305" width="36" height="14" forecolor="#000000" backcolor="#FFFFFF" uuid="bfc558a5-22ed-400f-8216-e9e53b13e27b"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
