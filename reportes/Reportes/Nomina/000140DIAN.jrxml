			<textField pattern="#,##0" isBlankWhenNull="true">
				<reportElement key="Texto53" positionType="Float" mode="Transparent" x="274" y="432" width="17" height="12" forecolor="#000000" backcolor="#FFFFFF" uuid="c74ca0d2-a14a-4c68-b9c6-42901fde2659"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.5" lineStyle="Solid" lineColor="#008B28"/>
					<leftPen lineWidth="0.5" lineStyle="Solid" lineColor="#008B28"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#008B28"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#008B28"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="8" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["53"]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement key="ClausulaSexta" positionType="Float" mode="Transparent" x="0" y="691" width="327" height="12" forecolor="#000000" backcolor="#FFFFFF" uuid="2728ca44-8c7d-4252-b9b7-57a3bcda1702"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<leftPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["6. Que el valor total de mis consignaciones bancarias, " + 
"depósitos o inversiones financieras no excedieron los " + 
$F{CONSIGNACIONESBANCARIAS_UVT} + "(" + 
new java.text.DecimalFormat("$ #,###").format($F{CONSIGNACIONESBANCARIAS_VALOR}) + 
")."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="ClausulaQuinta" positionType="Float" mode="Transparent" x="0" y="680" width="327" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="7be4c29c-5b2e-494f-8729-ac8e0f59d5d4"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<leftPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["5. Que el total de mis compras y consumos no superaron la suma de " + 
$F{COMPRASYCONSUMO_UVT} +  " (" +
new java.text.DecimalFormat("$ #,###").format($F{COMPRASYCONSUMO_VALOR}) +
")."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="ClausulaCuarta" positionType="Float" mode="Transparent" x="0" y="669" width="327" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="d1070ba5-a14e-4321-a677-ed589ae44287"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<leftPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["4. Mis consumos mediante tarjetas de crédito no excedieron la suma de " + 
$F{CONSUMOTARJETACRE_UVT} + " (" +
new java.text.DecimalFormat("$ #,###").format($F{CONSUMOTARJETACRE_VALOR}) +  
")."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="ClausulaTercera" positionType="Float" mode="Transparent" x="0" y="657" width="327" height="12" forecolor="#000000" backcolor="#FFFFFF" uuid="54c296f1-e7cb-4c3f-9bc3-bbab76c04f7a"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<leftPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["3. Mis Ingresos brutos fueron inferiores a " + 
$F{INGRESOSTOTALES_UVT} + " (" 
+ new java.text.DecimalFormat("$ #,###").format($F{INGRESOSTOTALES_VALOR}) + ")."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="AvisoDeclaracionRenta" positionType="Float" mode="Transparent" x="0" y="703" width="327" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="47833043-23c9-4c9a-a8c9-305db4318b45"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<leftPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<bottomPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
					<rightPen lineWidth="0.5" lineStyle="Solid" lineColor="#88CE95"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="5" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Por lo tanto, manifiesto que no estoy obligado a presentar " + 
"declaracion de renta y complementarios por el año gravable " + 
$F{ANO} + "."]]></textFieldExpression>
