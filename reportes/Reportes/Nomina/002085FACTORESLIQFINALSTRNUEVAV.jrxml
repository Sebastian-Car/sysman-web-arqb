				</textElement>
				<textFieldExpression><![CDATA["Diseñadas y Actualizadas según la ley © por " + $P{PR_EMPRESAPARAMETRIZADA}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto51" positionType="Float" mode="Transparent" x="96" y="855" width="463" height="16" forecolor="#000000" backcolor="#FFFFFF" uuid="ea19f607-9e12-4314-9e87-f613669603a3">
					<printWhenExpression><![CDATA[false]]></printWhenExpression>
				</reportElement>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="9" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{PR_CIUDAD_DONDE_SE_EXPIDE_CERTIFICACION_LABORAL} + ", " + new SimpleDateFormat("EEEEE, dd MMMMM yyyy").format($P{PR_FECHA})]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto353" positionType="Float" mode="Transparent" x="2" y="592" width="557" height="10" forecolor="#000000" backcolor="#FFFFFF" uuid="20b8f1fb-0dd3-4c85-b6f3-2cf2a7984252"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="8" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["CONSTANCIA: Se hace constar expresamente lo siguiente:"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto355" positionType="Float" mode="Transparent" x="2" y="602" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="322e428f-2254-44cf-a056-370069926c43"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["1. - Que el empleado ha incorporado en la anterior liquidación, en lo pertinente, la totalidad de los valores correspondientes a salarios, Horas extras, recargos"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto356" positionType="Float" mode="Transparent" x="2" y="613" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="c84d26a0-78c3-46ba-a59c-aa1e80b3ee8f"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      por trabajo nocturno, descansos remunerados, cesantías, vacaciones, auxilios por enfermedad, accidentes de trabajo, primas, calzado y overoles, Auxilio de  "]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto357" positionType="Float" mode="Transparent" x="2" y="624" width="557" height="10" forecolor="#000000" backcolor="#FFFFFF" uuid="00c7a10c-78f8-4755-921c-875b178782f9"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      transporte, y, en general, todo concepto relacionado con salarios prestaciones ó indemnizaciones que tengan por causa del contrato de trabajo que ha "]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto358" positionType="Float" mode="Transparent" x="2" y="634" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="800257bf-c31d-4bfc-9a27-c47fb97e3270"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      quedado extinguido."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto359" positionType="Float" mode="Transparent" x="2" y="645" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="ce3f7370-65e1-46c1-bcd2-488c7839c09c"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["2. - En consideración a que la obtención de los datos contables, elaboración y revisión de la presente liquidación, su aprobación y giros de cheques, ha exigido  "]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto360" positionType="Float" mode="Transparent" x="2" y="656" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="cef42bbc-71b8-430f-8ebf-854172591207"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      varios días, por lo cual ha sido fisicamente imposible pagar en el instante de la terminación del vinculo, el Trabajador conviene expresamente en que el"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto361" positionType="Float" mode="Transparent" x="2" y="667" width="557" height="10" forecolor="#000000" backcolor="#FFFFFF" uuid="70badda0-689a-49f5-8836-976e32bce0fd"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      termino trancurrido entre la terminación del vinculo y la fecha de esta liquidación y pago ha sido el necesario y razonable para estos efectos y"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto362" positionType="Float" mode="Transparent" x="2" y="677" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="55ac5821-335a-4fb0-a43d-1f19af6ec196"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      que, en consecuecia,  no ha habido mora en el pago."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto363" positionType="Float" mode="Transparent" x="2" y="688" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="75859a1f-f00b-4778-8ce1-80e7450633dd"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["3. -  Que no obstante la anterior declaración, se hace constar por las partes que en el pago de la suma de dinero ha que hace referencia la presente liquidación,"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto364" positionType="Float" mode="Transparent" x="2" y="699" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="668c6fe0-c449-4728-a565-623ee9c01f0c"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      queda transada cualquier diferencia relativa al vinculo  que ha quedado terminado  pues ha sido su común ánimo transar definitivamente, como "]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto365" positionType="Float" mode="Transparent" x="2" y="710" width="557" height="10" forecolor="#000000" backcolor="#FFFFFF" uuid="28b7a3fa-7d14-4416-9035-6aa605c0464e"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      en efecto se transa, todo reclamo pasado, presente ó futuro que tenga por causa del mencionado vinculo. Por consiguiente, ésta transacción tiene como  "]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto366" positionType="Float" mode="Transparent" x="2" y="720" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="6b9985c6-9d02-4c3d-b274-22455507f105"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      efecto la extinción de las obligaciones provenientes de la relación laboral que existió entre el Empleador y Empleado, quienes reciprocamente se declaran"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto367" positionType="Float" mode="Transparent" x="2" y="731" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="4ad448db-ff93-47a6-b728-86a749fddddc"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      a paz y salvo por todos los conceptos expresados, exepto en cuanto a derechos ciertos e indiscutibles del Empleado que, por cualquier circunstancia, "]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto368" positionType="Float" mode="Transparent" x="2" y="742" width="557" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="d60b3d80-0aba-49dc-a1af-0d85d5da06ec"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["      estén pendientes de reconocimiento o pago (Art 15, CST)"]]></textFieldExpression>
			</textField>
