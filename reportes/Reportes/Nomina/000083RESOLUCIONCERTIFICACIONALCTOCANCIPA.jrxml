					</textElement>
					<textFieldExpression><![CDATA["Elaborado  por: " + $P{PR_ELABORADO_POR}]]></textFieldExpression>
					
				</textField>
				<textField  evaluationTime="Now" evaluationGroup="#GRUPO_EVALUACION#" isStretchWithOverflow="true" isBlankWhenNull="true">
					<reportElement key="TextoPrincipal" x="0" y="142" width="470" height="31" isRemoveLineWhenBlank="false" isPrintRepeatedValues="true" forecolor="#000000" mode="Transparent" backcolor="#FFFFFF"  positionType="Float" stretchType="RelativeToTallestObject">
						
					</reportElement>
					<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
						<topPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<textElement textAlignment="Justified" verticalAlignment="Middle" rotation="None">
						<font fontName="Tahoma" size="12" isBold="false" isItalic="false" isUnderline="false"   isStrikeThrough="false"/>
					</textElement>
					<textFieldExpression><![CDATA["Que " + ($F{ID_DE_TIPO} == "02" ? " el(la) Dr(a) ":" el(la) señor(a) ")
+ $F{NOMBRECOMPLETO} + " identificado(a) con cédula de ciudadanía Nro. "
+ new java.text.DecimalFormat("#,###").format(Integer.valueOf($F{NUMERO_DCTO}))
+ " expedida en " + $F{CIUDAD} + " (" + $F{DEPARTAMENTO} + ") "
+ ($F{ESTADO_ACTUAL}.equals(new java.lang.Integer(3)) ?" laboró ":" labora ")
+ "para " + $P{PR_NOMBRECOMPANIA} + " desde el "
+ new java.text.SimpleDateFormat("d").format($F{FECHA_DE_INGRESO})
+ " de " + new java.text.SimpleDateFormat("MMMM").format($F{FECHA_DE_INGRESO})
+ " de " + new java.text.SimpleDateFormat("yyyy").format($F{FECHA_DE_INGRESO})
+ ($F{ESTADO_ACTUAL}.equals(new java.lang.Integer(3)) ? " hasta el " 
+ new java.text.SimpleDateFormat("d").format($F{FECHATERCONTRATO}) + " de " 
+ new java.text.SimpleDateFormat("MMMM").format($F{FECHATERCONTRATO}) + " de "
+ new java.text.SimpleDateFormat("yyyy").format($F{FECHATERCONTRATO}) : "") 
+ " en " + $F{NOMBREFORMA} + ($F{ESTADO_ACTUAL}.equals(new java.lang.Integer(3))
? ", que se desempeñó en el cargo de "
: ", y actualmente desempeña en el cargo de ")
+ $F{NOMBRE_DEL_CARGO} + ", con una asignación básica mensual de "
+ $F{MONEDA_SALARIO_BASE} + " ("
+ new java.text.DecimalFormat("$ #,##0.00").format($F{SALARIO_BASE})
+ ") PESOS MONEDA LEGAL COLOMBIANA" + ($F{SUBSALIMENTACION} > 0.0
? " y que percibe por prima de alimentación la suma de "
+ $F{MONEDA_SUBSALIMENTACION} + " ("
+ new java.text.DecimalFormat("$ #,##0.00").format($F{SUBSALIMENTACION}) + "), " : "")
+ ($F{SUBSTRANSPORTE} > 0.0 ? " y  por subsidio de transporte la suma de "
+ $F{MONEDA_SUBSTRANSPORTE} + "("
+ new java.text.DecimalFormat("$ #,##0.00").format($F{SUBSTRANSPORTE}) + ")" : "")
+ ($F{ID_DE_TIPO} == "02" ? " Modalidad Salario Integral" : "") + "."]]></textFieldExpression>
					
				</textField>
				<textField  evaluationTime="Now" evaluationGroup="#GRUPO_EVALUACION#" isStretchWithOverflow="true" isBlankWhenNull="true">
