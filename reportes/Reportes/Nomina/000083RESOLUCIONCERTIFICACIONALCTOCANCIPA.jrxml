						<font fontName="Tahoma" size="12" isBold="false" isItalic="false" isUnderline="false"   isStrikeThrough="false"/>
					</textElement>
					<textFieldExpression><![CDATA["La presente certificación se expide a solicitud de el(la) interesado(a) en "
+ $P{PR_CIUDAD_DE_CERTIFICACION} + " a los "
+ new java.text.SimpleDateFormat("d").format($P{PR_FECHA_EXPEDICION})
+ " días del mes de "
+ new java.text.SimpleDateFormat("MMMM").format($P{PR_FECHA_EXPEDICION})
+ " del " + new java.text.SimpleDateFormat("yyyy").format($P{PR_FECHA_EXPEDICION})
+ "."]]></textFieldExpression>
					
