					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["relacionado con salarios prestaciones o indemnizaciones que tengan por causal el contrato de trabajo que ha quedado extinguido."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto365" positionType="Float" mode="Transparent" x="3" y="567" width="596" height="10" forecolor="#000000" backcolor="#FFFFFF" uuid="676b2b15-d83d-4f65-9353-595757a46808"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["tenga por causa del mensionado contrato."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto367" positionType="Float" mode="Transparent" x="3" y="588" width="596" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="a58df58d-8f6c-403d-8a51-0bf836a79ee9"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["mente se declaran a paz y salvo por los conceptos expresados, excepto en cuanto a derechos ciertos e indiscutibles del trabajador que, por cualquier circunstancia, estén pendientes de"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto353" positionType="Float" mode="Transparent" x="3" y="471" width="596" height="10" forecolor="#000000" backcolor="#FFFFFF" uuid="fdea050a-c9ca-4b82-84b6-0cd8ba946e6a"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="8" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["CONSTANCIA: Se hace constar expresamente lo siguiente"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto364" positionType="Float" mode="Transparent" x="3" y="556" width="596" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="3470697a-f946-4005-a186-8861c393c132"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["relativa al contrato de trabajo que ha quedado terminado, pues ha sido su común ámimo transar definitivamente, como en efecto de transa, todo reclamo pasado, presente o futuro que"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto368" positionType="Float" mode="Transparent" x="3" y="599" width="596" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="7f0603cd-a840-463f-b71e-b66ccae45a00"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Arial" size="7" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["reconocimiento ó pago. (Art. 15, C.S.T.)."]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto360" positionType="Float" mode="Transparent" x="3" y="524" width="596" height="11" forecolor="#000000" backcolor="#FFFFFF" uuid="83bbd2e8-2ec8-4201-85f0-ef12376528d3"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
