					<textFieldExpression><![CDATA["QUE LAS PERSONAS RELACIONADAS EN LA PRESENTE NOMINA TIENEN DERECHO AL PAGO DE " + $P{PR_CONCEPTOPAGO} + " CORREPONDIENTE AL MES DE " +  $P{PR_NOMBREMES} + " DE " + $F{ANO}]]></textFieldExpression>
					
