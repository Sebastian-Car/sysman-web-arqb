					<font fontName="Arial" size="9" isBold="true" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Menos: Renta Exentas (art. 126-1, 126-4 y art.206 numerales 1 a 9 del ET)"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto279" positionType="Float" stretchType="RelativeToTallestObject" mode="Transparent" x="22" y="242" width="371" height="33" forecolor="#000000" backcolor="#FFFFFF" uuid="7da716fd-b5d5-405a-9b16-2ffb686e2f1b"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Tahoma" size="9" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["2) Pagos durante el año anterior (" + ($F{ANO}-1) + ") a medicina prepagada del trabajador, la esposa y hasta dos hijos,y divididos por los meses a que correspondieron (este valor no pude exceder de " + $P{PR_VALOR_UVT_MAXIMOS_DEDUCIBLES_MEDICINA_PREPAGADAS}+ " UVT, osea, " + $P{PR_VALOR_UVT_MAXIMOS_DEDUCIBLES_MEDICINA_PREPAGADAS}+ " x $ " +   java.text.NumberFormat.getCurrencyInstance(new Locale("en","US")).format($F{VALOR_UVT}) + " = " + java.text.NumberFormat.getCurrencyInstance(new Locale("en","US")).format($F{RND_MED}) +  ")"]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00" isBlankWhenNull="true">
				<reportElement key="DED_2_2_MEDICINA" positionType="Float" stretchType="RelativeToTallestObject" mode="Transparent" x="393" y="242" width="69" height="33" forecolor="#000000" backcolor="#FFFFFF" uuid="b8b070c5-e5c2-4793-8fd5-e0acb80569f9"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Right" verticalAlignment="Middle" rotation="None">
					<font fontName="Tahoma" size="9" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{DED_2_2_MEDICINA}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement key="Texto281" positionType="Float" stretchType="RelativeToTallestObject" mode="Transparent" x="22" y="275" width="371" height="23" forecolor="#000000" backcolor="#FFFFFF" uuid="fa6cc648-33ba-462d-b424-9d612bac2a18"/>
				<box topPadding="0" leftPadding="1" bottomPadding="0" rightPadding="1">
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle" rotation="None">
					<font fontName="Tahoma" size="9" isBold="false" isItalic="false" isUnderline="false" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression><![CDATA["3) Deducción por concepto de 'Personas a Cargo' (10% de los ingresos brutos sin exceder de " + $P{PR_VALOR_UVT_MAXIMOS_PERSONAL_A_CARGO}+ " UVT; osea, sin exceder de " + $P{PR_VALOR_UVT_MAXIMOS_PERSONAL_A_CARGO}+ " x  " +   java.text.NumberFormat.getCurrencyInstance(new Locale("en","US")).format($F{VALOR_UVT}) + " = " + java.text.NumberFormat.getCurrencyInstance(new Locale("en","US")).format($F{RND_PER}) + ")"]]></textFieldExpression>
			</textField>
