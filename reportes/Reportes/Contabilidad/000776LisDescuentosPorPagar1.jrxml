				<textElement textAlignment="Center" verticalAlignment="Middle" rotation="None">
					<font fontName="Tahoma" size="14" isBold="true" isItalic="true" isUnderline="true" isStrikeThrough="false"/>
				</textElement>
				<text><![CDATA[No existe información con los parámetros suministrados]]></text>
			</staticText>
		</band>
	</noData>
</jasperReport>
