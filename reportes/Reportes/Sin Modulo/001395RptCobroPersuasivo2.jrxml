					<reportElement key="TextoDelDocumento" x="0" y="221" width="505" height="232" isRemoveLineWhenBlank="false" isPrintRepeatedValues="true" forecolor="#000000" mode="Transparent" backcolor="#FFFFFF"  positionType="Float" stretchType="NoStretch">
						
