<data name="pilares" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPilaresPagBppilaresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COD_PILAR,DESCRIPCION FROM PILARES WHERE COMPANIA = :COMPANIA AND ACUERDO = :ACUERDO) INI WHERE (CASE WHEN COD_PILAR IS NULL THEN ' ' ELSE UPPER(COD_PILAR) END) LIKE UPPER(CONCAT(:COD_PILAR, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_PILAR":"$COD_PILAR(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACUERDO" sqlType="STRING"/>
		<param name="COD_PILAR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="pilares/bppilares/pag">
		<call-query href="getPilaresPagBppilaresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACUERDO" query-param="ACUERDO"/>
			<with-param name="COD_PILAR" query-param="COD_PILAR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPilaresNumBppilaresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COD_PILAR,DESCRIPCION FROM PILARES WHERE COMPANIA = :COMPANIA AND ACUERDO = :ACUERDO) INI WHERE (CASE WHEN COD_PILAR IS NULL THEN ' ' ELSE UPPER(COD_PILAR) END) LIKE UPPER(CONCAT(:COD_PILAR, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACUERDO" sqlType="STRING"/>
		<param name="COD_PILAR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pilares/bppilares/num">
		<call-query href="getPilaresNumBppilaresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACUERDO" query-param="ACUERDO"/>
			<with-param name="COD_PILAR" query-param="COD_PILAR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertPilares" keyColumns="COMPANIA,COD_PILAR,ACUERDO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PILARES (COMPANIA, COD_PILAR, DESCRIPCION, ACTIVO, ACUERDO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :COD_PILAR, :DESCRIPCION, :ACTIVO, :ACUERDO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_PILAR":"$COD_PILAR(type:integer)","KEY_ACUERDO":"$ACUERDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PILAR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="ACTIVO" sqlType="STRING"/>
		<param name="ACUERDO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="pilares">
		<call-query href="insertPilares">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_PILAR" query-param="COD_PILAR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="ACUERDO" query-param="ACUERDO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deletePilares" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PILARES WHERE PILARES.COMPANIA= :KEY_COMPANIA AND PILARES.COD_PILAR= :KEY_COD_PILAR AND PILARES.ACUERDO= :KEY_ACUERDO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_PILAR" sqlType="INTEGER"/>
		<param name="KEY_ACUERDO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="pilares">
		<call-query href="deletePilares">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_PILAR" query-param="KEY_COD_PILAR"/>
			<with-param name="KEY_ACUERDO" query-param="KEY_ACUERDO"/>

		</call-query>
	</resource>
	<query id="getPilaresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA,COD_PILAR,DESCRIPCION,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,ACUERDO FROM PILARES WHERE COMPANIA = :COMPANIA AND ACUERDO = :ACUERDO) INI WHERE (CASE WHEN COD_PILAR IS NULL THEN ' ' ELSE UPPER(COD_PILAR) END) LIKE UPPER(CONCAT(:COD_PILAR, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ACTIVO IS NULL THEN ' ' ELSE UPPER(ACTIVO) END) LIKE UPPER(CONCAT(:ACTIVO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PILAR":"$COD_PILAR(type:integer)","DESCRIPCION":"$DESCRIPCION","ACTIVO":"$ACTIVO(type:boolean)","ACUERDO":"$ACUERDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACUERDO" sqlType="STRING"/>
		<param name="COD_PILAR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="pilares">
		<call-query href="getPilaresPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACUERDO" query-param="ACUERDO"/>
			<with-param name="COD_PILAR" query-param="COD_PILAR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPilaresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA,COD_PILAR,DESCRIPCION,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,ACUERDO FROM PILARES WHERE COMPANIA = :COMPANIA AND ACUERDO = :ACUERDO) INI WHERE (CASE WHEN COD_PILAR IS NULL THEN ' ' ELSE UPPER(COD_PILAR) END) LIKE UPPER(CONCAT(:COD_PILAR, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ACTIVO IS NULL THEN ' ' ELSE UPPER(ACTIVO) END) LIKE UPPER(CONCAT(:ACTIVO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACUERDO" sqlType="STRING"/>
		<param name="COD_PILAR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pilares/numero">
		<call-query href="getPilaresNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACUERDO" query-param="ACUERDO"/>
			<with-param name="COD_PILAR" query-param="COD_PILAR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>

		</call-query>
	</resource>
	<query id="updatePilares" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PILARES SET COMPANIA=:COMPANIA, COD_PILAR=:COD_PILAR, DESCRIPCION=:DESCRIPCION, ACTIVO=:ACTIVO, ACUERDO=:ACUERDO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE PILARES.COMPANIA= :KEY_COMPANIA AND PILARES.COD_PILAR= :KEY_COD_PILAR AND PILARES.ACUERDO= :KEY_ACUERDO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PILAR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="ACUERDO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_PILAR" sqlType="STRING"/>
		<param name="KEY_ACUERDO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="pilares">
		<call-query href="updatePilares">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_PILAR" query-param="COD_PILAR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="ACUERDO" query-param="ACUERDO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_PILAR" query-param="KEY_COD_PILAR"/>
			<with-param name="KEY_ACUERDO" query-param="KEY_ACUERDO"/>

		</call-query>
	</resource>

</data>