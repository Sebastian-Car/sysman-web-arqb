	<query id="getPlanespresupuestalesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT PLAN_PRESUPUESTAL.COMPANIA, PLAN_PRESUPUESTAL.ANO, PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.CODIGO_EQUIV, PLAN_PRESUPUESTAL.CODIGO_EQUIV2, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.NATURALEZA,(CASE PLAN_PRESUPUESTAL.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE PLAN_PRESUPUESTAL.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_PRESUPUESTAL.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE PLAN_PRESUPUESTAL.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE PLAN_PRESUPUESTAL.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE PLAN_PRESUPUESTAL.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE PLAN_PRESUPUESTAL.MAN_PAC WHEN 0 THEN 'false' ELSE 'true' END) MAN_PAC, PLAN_PRESUPUESTAL.VIGENCIA, PLAN_PRESUPUESTAL.DINAMICA, PLAN_PRESUPUESTAL.INDECONOMICO, PLAN_PRESUPUESTAL.DESTINO, PLAN_PRESUPUESTAL.APROPIACIONINICIAL,(CASE PLAN_PRESUPUESTAL.RESERVADECAJA WHEN 0 THEN 'false' ELSE 'true' END) RESERVADECAJA,(CASE PLAN_PRESUPUESTAL.RESERVADEAPROPIACION WHEN 0 THEN 'false' ELSE 'true' END) RESERVADEAPROPIACION, PLAN_PRESUPUESTAL.NIVEL1, PLAN_PRESUPUESTAL.NIVEL2, PLAN_PRESUPUESTAL.NIVEL3, PLAN_PRESUPUESTAL.NIVEL4, PLAN_PRESUPUESTAL.NIVEL5, PLAN_PRESUPUESTAL.NIVEL6, PLAN_PRESUPUESTAL.NIVEL7, PLAN_PRESUPUESTAL.NIVEL8, PLAN_PRESUPUESTAL.TIPOVIGENCIA,(CASE PLAN_PRESUPUESTAL.INDCONTROL WHEN 0 THEN 'false' ELSE 'true' END) INDCONTROL,(CASE PLAN_PRESUPUESTAL.INFORME WHEN 0 THEN 'false' ELSE 'true' END) INFORME, PLAN_PRESUPUESTAL.DEPENDENCIAASOCIADA,(CASE PLAN_PRESUPUESTAL.ENARCHIVOPLANO WHEN 0 THEN 'false' ELSE 'true' END) ENARCHIVOPLANO, PLAN_PRESUPUESTAL.CODCONTABLE5544, PLAN_PRESUPUESTAL.RECURSO5544, PLAN_PRESUPUESTAL.SUBRECURSO5544, PLAN_PRESUPUESTAL.COD_EQUIV5544,(CASE PLAN_PRESUPUESTAL.PERMITECONSOLIDAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITECONSOLIDAR, PLAN_PRESUPUESTAL.COD_SIGUIENTE_VIGENCIA, PLAN_PRESUPUESTAL.COD_ANTERIOR_VIGENCIA, PLAN_PRESUPUESTAL.RECONOCIMIENTO,(CASE PLAN_PRESUPUESTAL.INFORMESHACIENDA WHEN 0 THEN 'false' ELSE 'true' END) INFORMESHACIENDA,(CASE PLAN_PRESUPUESTAL.CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS, PLAN_PRESUPUESTAL.ORIGENESPECIFICACIONINGRESOS,(CASE PLAN_PRESUPUESTAL.MEN WHEN 0 THEN 'false' ELSE 'true' END) MEN, PLAN_PRESUPUESTAL.CODIGO_MEN, PLAN_PRESUPUESTAL.CUENTAAFORO, PLAN_PRESUPUESTAL.CODIGO_EQUIVALENTE2, PLAN_PRESUPUESTAL.CENTRO_EQUIV, PLAN_PRESUPUESTAL.AUXILIAR_EQUIV, PLAN_PRESUPUESTAL.JERARQUIA_GASTO, PLAN_PRESUPUESTAL.DESTINO_RECURSOS, PLAN_PRESUPUESTAL.NOM_CODIGO_EQUIVALENTE,(CASE PLAN_PRESUPUESTAL.MANEJA_PROYECTOS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_PROYECTOS,(CASE PLAN_PRESUPUESTAL.REGALIAS WHEN 0 THEN 'false' ELSE 'true' END) REGALIAS,(CASE PLAN_PRESUPUESTAL.PASAR_SALDOS_APROP WHEN 0 THEN 'false' ELSE 'true' END) PASAR_SALDOS_APROP,(TO_CHAR(PLAN_PRESUPUESTAL.FECHA_ACTIVACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTIVACION, PLAN_PRESUPUESTAL.FUENTE_RECURSOS, FUENTE_RECURSOS.NOMBRE NOMBRE_FUENTE, PLAN_PRESUPUESTAL.CREATED_BY,(TO_CHAR(PLAN_PRESUPUESTAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, PLAN_PRESUPUESTAL.MODIFIED_BY,(TO_CHAR(PLAN_PRESUPUESTAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE PLAN_PRESUPUESTAL.COVID WHEN 0 THEN 'false' ELSE 'true' END) COVID,(CASE PLAN_PRESUPUESTAL.MAN_POLITICA_PUBLICA WHEN 0 THEN 'false' ELSE 'true' END) MAN_POLITICA_PUBLICA, PLAN_PRESUPUESTAL.EQUIV_GASTO, PLAN_PRESUPUESTAL.CUENTAGASTOCNT, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(PLAN_PRESUPUESTAL.TIPOCLASIFICADOR,'-'),TIPOCLASIFICADOR.NOMBRE),' '),PLAN_PRESUPUESTAL.CLASECLASIFICADOR),' - '), CLASECLASIFICADOR.NOMBRE) AS TIPOCLASECLASIFICADOR, PLAN_PRESUPUESTAL.TIPOCLASIFICADOR ,PLAN_PRESUPUESTAL.CLASECLASIFICADOR, PLAN_PRESUPUESTAL.TIPO_RECURSO,(CASE PLAN_PRESUPUESTAL.OBLIGACCPET WHEN 0 THEN 'false' ELSE 'true' END) OBLIGACCPET,(CASE PLAN_PRESUPUESTAL.COFINANCIADO WHEN 0 THEN 'false' ELSE 'true' END) COFINANCIADO,PLAN_PRESUPUESTAL.UNIDAD_EJECUTORA FROM PLAN_PRESUPUESTAL LEFT JOIN FUENTE_RECURSOS ON PLAN_PRESUPUESTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND PLAN_PRESUPUESTAL.ANO = FUENTE_RECURSOS.ANO AND PLAN_PRESUPUESTAL.FUENTE_RECURSOS = FUENTE_RECURSOS.CODIGO LEFT JOIN CLASECLASIFICADOR ON PLAN_PRESUPUESTAL.COMPANIA = CLASECLASIFICADOR.COMPANIA AND PLAN_PRESUPUESTAL.ANO = CLASECLASIFICADOR.ANO AND PLAN_PRESUPUESTAL.CLASECLASIFICADOR = CLASECLASIFICADOR.CODIGO LEFT JOIN TIPOCLASIFICADOR ON PLAN_PRESUPUESTAL.COMPANIA = TIPOCLASIFICADOR.COMPANIA AND PLAN_PRESUPUESTAL.ANO = TIPOCLASIFICADOR.ANO AND PLAN_PRESUPUESTAL.CLASECLASIFICADOR = TIPOCLASIFICADOR.CLASECLASIFICADOR AND PLAN_PRESUPUESTAL.TIPOCLASIFICADOR = TIPOCLASIFICADOR.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA= :KEY_COMPANIA AND PLAN_PRESUPUESTAL.ANO= :KEY_ANO AND PLAN_PRESUPUESTAL.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CODIGO_EQUIV":"$CODIGO_EQUIV","CODIGO_EQUIV2":"$CODIGO_EQUIV2","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_PAC":"$MAN_PAC(type:boolean)","VIGENCIA":"$VIGENCIA(type:integer)","DINAMICA":"$DINAMICA","INDECONOMICO":"$INDECONOMICO","DESTINO":"$DESTINO","APROPIACIONINICIAL":"$APROPIACIONINICIAL","RESERVADECAJA":"$RESERVADECAJA(type:boolean)","RESERVADEAPROPIACION":"$RESERVADEAPROPIACION(type:boolean)","NIVEL1":"$NIVEL1","NIVEL2":"$NIVEL2","NIVEL3":"$NIVEL3","NIVEL4":"$NIVEL4","NIVEL5":"$NIVEL5","NIVEL6":"$NIVEL6","NIVEL7":"$NIVEL7","NIVEL8":"$NIVEL8","TIPOVIGENCIA":"$TIPOVIGENCIA","INDCONTROL":"$INDCONTROL(type:boolean)","INFORME":"$INFORME(type:boolean)","DEPENDENCIAASOCIADA":"$DEPENDENCIAASOCIADA","ENARCHIVOPLANO":"$ENARCHIVOPLANO(type:boolean)","CODCONTABLE5544":"$CODCONTABLE5544","RECURSO5544":"$RECURSO5544","SUBRECURSO5544":"$SUBRECURSO5544","COD_EQUIV5544":"$COD_EQUIV5544","PERMITECONSOLIDAR":"$PERMITECONSOLIDAR(type:boolean)","COD_SIGUIENTE_VIGENCIA":"$COD_SIGUIENTE_VIGENCIA","COD_ANTERIOR_VIGENCIA":"$COD_ANTERIOR_VIGENCIA","RECONOCIMIENTO":"$RECONOCIMIENTO","INFORMESHACIENDA":"$INFORMESHACIENDA(type:boolean)","CONSITUACIONFONDOS":"$CONSITUACIONFONDOS(type:boolean)","ORIGENESPECIFICACIONINGRESOS":"$ORIGENESPECIFICACIONINGRESOS","MEN":"$MEN(type:boolean)","CODIGO_MEN":"$CODIGO_MEN","CUENTAAFORO":"$CUENTAAFORO","CODIGO_EQUIVALENTE2":"$CODIGO_EQUIVALENTE2","CENTRO_EQUIV":"$CENTRO_EQUIV","AUXILIAR_EQUIV":"$AUXILIAR_EQUIV","JERARQUIA_GASTO":"$JERARQUIA_GASTO","DESTINO_RECURSOS":"$DESTINO_RECURSOS","NOM_CODIGO_EQUIVALENTE":"$NOM_CODIGO_EQUIVALENTE","MANEJA_PROYECTOS":"$MANEJA_PROYECTOS(type:boolean)","REGALIAS":"$REGALIAS(type:boolean)","PASAR_SALDOS_APROP":"$PASAR_SALDOS_APROP(type:boolean)","FECHA_ACTIVACION":"$FECHA_ACTIVACION","FUENTE_RECURSOS":"$FUENTE_RECURSOS","NOMBRE_FUENTE":"$NOMBRE_FUENTE","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","COVID":"$COVID(type:boolean)","MAN_POLITICA_PUBLICA":"$MAN_POLITICA_PUBLICA(type:boolean)","EQUIV_GASTO":"$EQUIV_GASTO","CUENTAGASTOCNT":"$CUENTAGASTOCNT","TIPOCLASECLASIFICADOR":"$TIPOCLASECLASIFICADOR","TIPOCLASIFICADOR":"$TIPOCLASIFICADOR","CLASECLASIFICADOR":"$CLASECLASIFICADOR","TIPO_RECURSO":"$TIPO_RECURSO(type:long)","OBLIGACCPET":"$OBLIGACCPET(type:boolean)","COFINANCIADO":"$COFINANCIADO(type:boolean)","UNIDAD_EJECUTORA":"$UNIDAD_EJECUTORA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
