		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE  FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.CODIGO &gt;= :CUENTAINICIAL AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.NATURALEZA = 'C' ORDER BY PLAN_PRESUPUESTAL.COMPANIA, PLAN_PRESUPUESTAL.ANO, PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
