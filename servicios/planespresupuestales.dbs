	<query id="getPlanespresupuestalesPagGetconfiguraplanpresucuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO ,SUBSTR(CODIGO,0,100) CODIGO,SUBSTR(NOMBRE,0,100) NOMBRE ,TIPOVIGENCIA, (SELECT NOMBRE FROM TIPOVIGENCIA WHERE CODIGO = TIPOVIGENCIA) NOMBREVIGENCIA ,SECTOR ,PROGRAMA ,SUBPROGRAMA ,CODIGOPRODUCTO ,CODIGOBPIN ,CODIGOCCPET ,CODIGOCPCDANE ,CODIGOUNIDADEJE ,CODIGOFUENTE ,CODIGOCCPETREGA ,POLITCA_PUBLICA_CUIPO ,DETALLE_SECTORIAL ,TIPO_RECURSO ,(CASE RECAUDO_VA WHEN 0 THEN 'false' ELSE 'true' END) RECAUDO_VA,(CASE CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS,(CASE TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TRANSFERENCIA,(CASE APLICA_DEST_ESPECIFICA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DEST_ESPECIFICA,TIPO_NORMA ,NUMERO_NORMA ,(TO_CHAR(FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_NORMA,NATURALEZA,TERCERO_CHIP,(case WHEN MOVIMIENTO NOT IN(0) or MAN_CEN_CTO NOT IN(0) or MAN_AUX_TER NOT IN(0) or MAN_AUX_GEN NOT IN(0) or MAN_AUX_REF NOT IN(0) or MAN_AUX_FUE NOT IN(0) or MAN_PAC NOT IN(0) THEN 'true' ELSE 'false' END) MOVIMIENTO FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO AND NATURALEZA = :NATURALEZA AND REGALIAS IN(0) ORDER BY CODIGO ASC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOVIGENCIA), '%')) AND (CASE WHEN NOMBREVIGENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREVIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREVIGENCIA), '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SECTOR), '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMA), '%')) AND (CASE WHEN SUBPROGRAMA IS NULL THEN ' ' ELSE UPPER(SUBPROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:SUBPROGRAMA), '%')) AND (CASE WHEN CODIGOPRODUCTO IS NULL THEN ' ' ELSE UPPER(CODIGOPRODUCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPRODUCTO), '%')) AND (CASE WHEN CODIGOBPIN IS NULL THEN ' ' ELSE UPPER(CODIGOBPIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOBPIN), '%')) AND (CASE WHEN CODIGOCCPET IS NULL THEN ' ' ELSE UPPER(CODIGOCCPET) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPET), '%')) AND (CASE WHEN CODIGOCPCDANE IS NULL THEN ' ' ELSE UPPER(CODIGOCPCDANE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCPCDANE), '%')) AND (CASE WHEN CODIGOUNIDADEJE IS NULL THEN ' ' ELSE UPPER(CODIGOUNIDADEJE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOUNIDADEJE), '%')) AND (CASE WHEN CODIGOFUENTE IS NULL THEN ' ' ELSE UPPER(CODIGOFUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOFUENTE), '%')) AND (CASE WHEN CODIGOCCPETREGA IS NULL THEN ' ' ELSE UPPER(CODIGOCCPETREGA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPETREGA), '%')) AND (CASE WHEN POLITCA_PUBLICA_CUIPO IS NULL THEN ' ' ELSE UPPER(POLITCA_PUBLICA_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:POLITCA_PUBLICA_CUIPO), '%')) AND (CASE WHEN DETALLE_SECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLE_SECTORIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DETALLE_SECTORIAL), '%')) AND (CASE WHEN TIPO_RECURSO IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_RECURSO), '%')) AND (CASE WHEN RECAUDO_VA IS NULL THEN ' ' ELSE UPPER(RECAUDO_VA) END) LIKE UPPER(CONCAT(CONCAT('%',:RECAUDO_VA), '%')) AND (CASE WHEN CONSITUACIONFONDOS IS NULL THEN ' ' ELSE UPPER(CONSITUACIONFONDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSITUACIONFONDOS), '%')) AND (CASE WHEN TRANSFERENCIA IS NULL THEN ' ' ELSE UPPER(TRANSFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TRANSFERENCIA), '%')) AND (CASE WHEN APLICA_DEST_ESPECIFICA IS NULL THEN ' ' ELSE UPPER(APLICA_DEST_ESPECIFICA) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICA_DEST_ESPECIFICA), '%')) AND (CASE WHEN TIPO_NORMA IS NULL THEN ' ' ELSE UPPER(TIPO_NORMA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_NORMA), '%')) AND (CASE WHEN NUMERO_NORMA IS NULL THEN ' ' ELSE UPPER(NUMERO_NORMA) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_NORMA), '%')) AND (CASE WHEN FECHA_NORMA IS NULL THEN ' ' ELSE UPPER(FECHA_NORMA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_NORMA), '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(CONCAT('%',:NATURALEZA), '%')) AND (CASE WHEN TERCERO_CHIP IS NULL THEN ' ' ELSE UPPER(TERCERO_CHIP) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO_CHIP), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MOVIMIENTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPOVIGENCIA":"$TIPOVIGENCIA","NOMBREVIGENCIA":"$NOMBREVIGENCIA","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITCA_PUBLICA_CUIPO":"$POLITCA_PUBLICA_CUIPO","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","TIPO_RECURSO":"$TIPO_RECURSO(type:long)","RECAUDO_VA":"$RECAUDO_VA(type:boolean)","CONSITUACIONFONDOS":"$CONSITUACIONFONDOS(type:boolean)","TRANSFERENCIA":"$TRANSFERENCIA(type:boolean)","APLICA_DEST_ESPECIFICA":"$APLICA_DEST_ESPECIFICA(type:boolean)","TIPO_NORMA":"$TIPO_NORMA","NUMERO_NORMA":"$NUMERO_NORMA","FECHA_NORMA":"$FECHA_NORMA","NATURALEZA":"$NATURALEZA","TERCERO_CHIP":"$TERCERO_CHIP","MOVIMIENTO":"$MOVIMIENTO"}]}}		</result>
