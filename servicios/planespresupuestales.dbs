	<query id="updatePlanespresupuestales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PRESUPUESTAL SET COMPANIA=:COMPANIA, ANO=:ANO, CODIGO=:CODIGO, CODIGO_EQUIV=:CODIGO_EQUIV, CODIGO_EQUIV2=:CODIGO_EQUIV2, NOMBRE=:NOMBRE, NATURALEZA=:NATURALEZA, MOVIMIENTO=:MOVIMIENTO, MAN_CEN_CTO=:MAN_CEN_CTO, MAN_AUX_TER=:MAN_AUX_TER, MAN_AUX_GEN=:MAN_AUX_GEN, MAN_AUX_REF=:MAN_AUX_REF, MAN_AUX_FUE=:MAN_AUX_FUE, MAN_PAC=:MAN_PAC, VIGENCIA=:VIGENCIA, DINAMICA=:DINAMICA, INDECONOMICO=:INDECONOMICO, DESTINO=:DESTINO, APROPIACIONINICIAL=:APROPIACIONINICIAL, RESERVADECAJA=:RESERVADECAJA, RESERVADEAPROPIACION=:RESERVADEAPROPIACION, NIVEL1=:NIVEL1, NIVEL2=:NIVEL2, NIVEL3=:NIVEL3, NIVEL4=:NIVEL4, NIVEL5=:NIVEL5, NIVEL6=:NIVEL6, NIVEL7=:NIVEL7, NIVEL8=:NIVEL8, TIPOVIGENCIA=:TIPOVIGENCIA, INDCONTROL=:INDCONTROL, INFORME=:INFORME, DEPENDENCIAASOCIADA=:DEPENDENCIAASOCIADA, ENARCHIVOPLANO=:ENARCHIVOPLANO, CODCONTABLE5544=:CODCONTABLE5544, RECURSO5544=:RECURSO5544, SUBRECURSO5544=:SUBRECURSO5544, COD_EQUIV5544=:COD_EQUIV5544, PERMITECONSOLIDAR=:PERMITECONSOLIDAR, COD_SIGUIENTE_VIGENCIA=:COD_SIGUIENTE_VIGENCIA, COD_ANTERIOR_VIGENCIA=:COD_ANTERIOR_VIGENCIA, RECONOCIMIENTO=:RECONOCIMIENTO, INFORMESHACIENDA=:INFORMESHACIENDA, CONSITUACIONFONDOS=:CONSITUACIONFONDOS, ORIGENESPECIFICACIONINGRESOS=:ORIGENESPECIFICACIONINGRESOS, MEN=:MEN, CODIGO_MEN=:CODIGO_MEN, CUENTAAFORO=:CUENTAAFORO, CODIGO_EQUIVALENTE2=:CODIGO_EQUIVALENTE2, CENTRO_EQUIV=:CENTRO_EQUIV, AUXILIAR_EQUIV=:AUXILIAR_EQUIV, JERARQUIA_GASTO=:JERARQUIA_GASTO, DESTINO_RECURSOS=:DESTINO_RECURSOS, NOM_CODIGO_EQUIVALENTE=:NOM_CODIGO_EQUIVALENTE, MANEJA_PROYECTOS=:MANEJA_PROYECTOS, REGALIAS=:REGALIAS, PASAR_SALDOS_APROP=:PASAR_SALDOS_APROP, FECHA_ACTIVACION=TO_DATE(:FECHA_ACTIVACION,'DD/MM/YYYY HH24:MI:SS'), FUENTE_RECURSOS=:FUENTE_RECURSOS, COVID=:COVID, MAN_POLITICA_PUBLICA=:MAN_POLITICA_PUBLICA, EQUIV_GASTO=:EQUIV_GASTO, CUENTAGASTOCNT=:CUENTAGASTOCNT, TIPOCLASIFICADOR=:TIPOCLASIFICADOR, CLASECLASIFICADOR=:CLASECLASIFICADOR, TIPO_RECURSO=:TIPO_RECURSO, OBLIGACCPET=:OBLIGACCPET, COFINANCIADO=:COFINANCIADO, UNIDAD_EJECUTORA=:UNIDAD_EJECUTORA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PRESUPUESTAL.COMPANIA= :KEY_COMPANIA AND PLAN_PRESUPUESTAL.ANO= :KEY_ANO AND PLAN_PRESUPUESTAL.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

