	<query id="getPlanespresupuestalesPagGettipoclasicicuiponueQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TC.CODIGO, TC.NOMBRE FROM TIPOCLASIFICADOR TC INNER JOIN CLASECLASIFICADOR CC ON TC.COMPANIA = CC.COMPANIA AND TC.ANO = CC.ANO AND TC.CLASECLASIFICADOR = CC.CODIGO WHERE TC.COMPANIA = :COMPANIA AND TC.ANO = :ANO AND TC.CLASECLASIFICADOR= '009') INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
