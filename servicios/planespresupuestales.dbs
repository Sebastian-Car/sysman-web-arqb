	</resource>
	<query id="getPlanespresupuestalesNumGetclaseclasificadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO CODIGOCLASE, NOMBRE FROM CLASECLASIFICADOR WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGOCLASE IS NULL THEN ' ' ELSE UPPER(CODIGOCLASE) END) LIKE UPPER(CONCAT(:CODIGOCLASE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGOCLASE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

