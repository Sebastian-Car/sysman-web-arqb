	<query id="getPlanespresupuestalesPagGetrubroporanioyauxiliaresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE,(CASE PLAN_PRESUPUESTAL.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_PRESUPUESTAL.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE PLAN_PRESUPUESTAL.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE PLAN_PRESUPUESTAL.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN FROM PLAN_PRESUPUESTAL LEFT JOIN DETALLE_COMPROBANTE_PPTAL ON PLAN_PRESUPUESTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND PLAN_PRESUPUESTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND PLAN_PRESUPUESTAL.CODIGO = DETALLE_COMPROBANTE_PPTAL.CUENTA LEFT JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = TIPO_COMPROBPP.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.NATURALEZA = :NATURALEZA AND TIPO_COMPROBPP.CLASE IN ('ING','AIN','DIN','MOI','ICA','AIC','DIC','MIC') AND (PLAN_PRESUPUESTAL.MAN_AUX_GEN &lt;&gt; 0 OR PLAN_PRESUPUESTAL.MAN_CEN_CTO &lt;&gt; 0 OR PLAN_PRESUPUESTAL.MAN_AUX_REF &lt;&gt; 0 OR PLAN_PRESUPUESTAL.MAN_AUX_FUE &lt;&gt; 0) GROUP BY PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.MAN_AUX_GEN, PLAN_PRESUPUESTAL.MAN_CEN_CTO, PLAN_PRESUPUESTAL.MAN_AUX_REF, PLAN_PRESUPUESTAL.MAN_AUX_FUE ORDER BY PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END) LIKE UPPER(CONCAT(:MAN_CEN_CTO, '%')) AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END) LIKE UPPER(CONCAT(:MAN_AUX_REF, '%')) AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END) LIKE UPPER(CONCAT(:MAN_AUX_FUE, '%')) AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END) LIKE UPPER(CONCAT(:MAN_AUX_GEN, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
