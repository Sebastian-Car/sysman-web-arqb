		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="planespresupuestales">
		<call-query href="insertPlanespresupuestales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_EQUIV" query-param="CODIGO_EQUIV"/>
			<with-param name="CODIGO_EQUIV2" query-param="CODIGO_EQUIV2"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="MAN_CEN_CTO" query-param="MAN_CEN_CTO"/>
			<with-param name="MAN_AUX_TER" query-param="MAN_AUX_TER"/>
			<with-param name="MAN_AUX_GEN" query-param="MAN_AUX_GEN"/>
			<with-param name="MAN_AUX_REF" query-param="MAN_AUX_REF"/>
			<with-param name="MAN_AUX_FUE" query-param="MAN_AUX_FUE"/>
			<with-param name="MAN_PAC" query-param="MAN_PAC"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DINAMICA" query-param="DINAMICA"/>
			<with-param name="INDECONOMICO" query-param="INDECONOMICO"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="APROPIACIONINICIAL" query-param="APROPIACIONINICIAL"/>
			<with-param name="RESERVADECAJA" query-param="RESERVADECAJA"/>
			<with-param name="RESERVADEAPROPIACION" query-param="RESERVADEAPROPIACION"/>
			<with-param name="NIVEL1" query-param="NIVEL1"/>
			<with-param name="NIVEL2" query-param="NIVEL2"/>
			<with-param name="NIVEL3" query-param="NIVEL3"/>
			<with-param name="NIVEL4" query-param="NIVEL4"/>
			<with-param name="NIVEL5" query-param="NIVEL5"/>
			<with-param name="NIVEL6" query-param="NIVEL6"/>
			<with-param name="NIVEL7" query-param="NIVEL7"/>
			<with-param name="NIVEL8" query-param="NIVEL8"/>
			<with-param name="TIPOVIGENCIA" query-param="TIPOVIGENCIA"/>
			<with-param name="INDCONTROL" query-param="INDCONTROL"/>
