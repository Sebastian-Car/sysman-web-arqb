		<param name="NUMERO_NORMA" sqlType="STRING"/>
		<param name="FECHA_NORMA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="TERCERO_CHIP" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planespresupuestales/updateplan_preclasificadores">
		<call-query href="updatePlanespresupuestalesUpdateplan_preclasificadores">
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
			<with-param name="SUBPROGRAMA" query-param="SUBPROGRAMA"/>
			<with-param name="CODIGOPRODUCTO" query-param="CODIGOPRODUCTO"/>
			<with-param name="CODIGOBPIN" query-param="CODIGOBPIN"/>
			<with-param name="CODIGOCCPET" query-param="CODIGOCCPET"/>
			<with-param name="CODIGOCPCDANE" query-param="CODIGOCPCDANE"/>
			<with-param name="CODIGOUNIDADEJE" query-param="CODIGOUNIDADEJE"/>
			<with-param name="CODIGOFUENTE" query-param="CODIGOFUENTE"/>
			<with-param name="CODIGOCCPETREGA" query-param="CODIGOCCPETREGA"/>
			<with-param name="POLITCA_PUBLICA_CUIPO" query-param="POLITCA_PUBLICA_CUIPO"/>
			<with-param name="DETALLE_SECTORIAL" query-param="DETALLE_SECTORIAL"/>
			<with-param name="TIPO_RECURSO" query-param="TIPO_RECURSO"/>
			<with-param name="RECAUDO_VA" query-param="RECAUDO_VA"/>
			<with-param name="CONSITUACIONFONDOS" query-param="CONSITUACIONFONDOS"/>
			<with-param name="TRANSFERENCIA" query-param="TRANSFERENCIA"/>
			<with-param name="APLICA_DEST_ESPECIFICA" query-param="APLICA_DEST_ESPECIFICA"/>
			<with-param name="TIPO_NORMA" query-param="TIPO_NORMA"/>
			<with-param name="NUMERO_NORMA" query-param="NUMERO_NORMA"/>
			<with-param name="FECHA_NORMA" query-param="FECHA_NORMA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="TERCERO_CHIP" query-param="TERCERO_CHIP"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesGetplan_preclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA,ANO ,CODIGO ,NOMBRE ,TIPOVIGENCIA ,SECTOR ,PROGRAMA ,SUBPROGRAMA ,CODIGOPRODUCTO ,CODIGOBPIN ,CODIGOCCPET ,CODIGOCPCDANE ,CODIGOUNIDADEJE ,CODIGOFUENTE ,CODIGOCCPETREGA ,POLITCA_PUBLICA_CUIPO ,DETALLE_SECTORIAL ,TIPO_RECURSO ,(CASE RECAUDO_VA WHEN 0 THEN 'false' ELSE 'true' END) RECAUDO_VA,(CASE CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS,(CASE TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TRANSFERENCIA,(CASE APLICA_DEST_ESPECIFICA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DEST_ESPECIFICA,TIPO_NORMA ,NUMERO_NORMA ,(TO_CHAR(FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_NORMA,NATURALEZA FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO AND NATURALEZA = :NATURALEZA AND REGALIAS NOT IN(0) AND CODIGO LIKE UPPER(CONCAT(:CODIGO,'%'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPOVIGENCIA":"$TIPOVIGENCIA","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITCA_PUBLICA_CUIPO":"$POLITCA_PUBLICA_CUIPO","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","TIPO_RECURSO":"$TIPO_RECURSO(type:long)","RECAUDO_VA":"$RECAUDO_VA(type:boolean)","CONSITUACIONFONDOS":"$CONSITUACIONFONDOS(type:boolean)","TRANSFERENCIA":"$TRANSFERENCIA(type:boolean)","APLICA_DEST_ESPECIFICA":"$APLICA_DEST_ESPECIFICA(type:boolean)","TIPO_NORMA":"$TIPO_NORMA","NUMERO_NORMA":"$NUMERO_NORMA","FECHA_NORMA":"$FECHA_NORMA","NATURALEZA":"$NATURALEZA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planespresupuestales/getPlan_preClasificadors">
		<call-query href="getPlanespresupuestalesGetplan_preclasificadoresQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesGetplanclasregaliasnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO ,SUBSTR(CODIGO,0,100) CODIGO,SUBSTR(NOMBRE,0,100) NOMBRE, (SELECT NOMBRE FROM TIPOVIGENCIA WHERE CODIGO = TIPOVIGENCIA) NOMBREVIGENCIA , TIPOVIGENCIA ,SECTOR ,PROGRAMA ,SUBPROGRAMA ,CODIGOPRODUCTO,CODIGOBPIN ,CODIGOCCPET,CODIGOCPCDANE,CODIGOUNIDADEJE ,CODIGOFUENTE ,CODIGOCCPETREGA ,POLITCA_PUBLICA_CUIPO,DETALLE_SECTORIAL ,TIPO_RECURSO ,(CASE RECAUDO_VA WHEN 0 THEN 'false' ELSE 'true' END) RECAUDO_VA,(CASE CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS,(CASE TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TRANSFERENCIA, TERCERO_CHIP,(CASE APLICA_DEST_ESPECIFICA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DEST_ESPECIFICA,TIPO_NORMA ,NUMERO_NORMA ,(TO_CHAR(FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_NORMA,NATURALEZA FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO AND NATURALEZA = :NATURALEZA AND REGALIAS IN(0) AND (case WHEN MOVIMIENTO NOT IN(0) or MAN_CEN_CTO NOT IN(0) or MAN_AUX_TER NOT IN(0) or MAN_AUX_GEN NOT IN(0) or MAN_AUX_REF NOT IN(0) or MAN_AUX_FUE NOT IN(0) or MAN_PAC NOT IN(0) THEN 'true' ELSE 'false' END) = 'true' ORDER BY CODIGO ASC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NOMBREVIGENCIA":"$NOMBREVIGENCIA","TIPOVIGENCIA":"$TIPOVIGENCIA","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITCA_PUBLICA_CUIPO":"$POLITCA_PUBLICA_CUIPO","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","TIPO_RECURSO":"$TIPO_RECURSO(type:long)","RECAUDO_VA":"$RECAUDO_VA(type:boolean)","CONSITUACIONFONDOS":"$CONSITUACIONFONDOS(type:boolean)","TRANSFERENCIA":"$TRANSFERENCIA(type:boolean)","TERCERO_CHIP":"$TERCERO_CHIP","APLICA_DEST_ESPECIFICA":"$APLICA_DEST_ESPECIFICA(type:boolean)","TIPO_NORMA":"$TIPO_NORMA","NUMERO_NORMA":"$NUMERO_NORMA","FECHA_NORMA":"$FECHA_NORMA","NATURALEZA":"$NATURALEZA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>

	</query>
