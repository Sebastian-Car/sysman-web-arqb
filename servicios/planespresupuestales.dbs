		<param name="CODIGOBPIN" sqlType="STRING"/>
		<param name="CODIGOCCPET" sqlType="STRING"/>
		<param name="CODIGOCPCDANE" sqlType="STRING"/>
		<param name="CODIGOUNIDADEJE" sqlType="STRING"/>
		<param name="CODIGOFUENTE" sqlType="STRING"/>
