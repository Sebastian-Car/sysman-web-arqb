	<query id="getPlanespresupuestalesManAuxPorCompaniaAnoCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
