	<query id="getPlanespresupuestalesNumRubroConMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE,(CASE PLAN_PRESUPUESTAL.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE PLAN_PRESUPUESTAL.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_PRESUPUESTAL.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE PLAN_PRESUPUESTAL.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE PLAN_PRESUPUESTAL.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE PLAN_PRESUPUESTAL.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE, PLAN_PRESUPUESTAL.NATURALEZA  FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANO AND (PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_CEN_CTO NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_TER NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_GEN NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_REF NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_FUE NOT IN (0)) ORDER BY PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
