	<query id="getPlanespresupuestalesNumGetplan_preclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE, ( SELECT NOMBRE FROM TIPOVIGENCIA WHERE CODIGO = TIPOVIGENCIA ) NOMBREVIGENCIA, TIPOVIGENCIA, SECTOR, PROGRAMA, SUBPROGRAMA, CODIGOPRODUCTO, CODIGOBPIN, CODIGOCCPET, CODIGOCPCDANE, CODIGOUNIDADEJE, CODIGOFUENTE, CODIGOCCPETREGA, POLITCA_PUBLICA_CUIPO, DETALLE_SECTORIAL, TIPO_RECURSO,(CASE RECAUDO_VA WHEN 0 THEN 'false' ELSE 'true' END) RECAUDO_VA,(CASE CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS,(CASE TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TRANSFERENCIA,(CASE APLICA_DEST_ESPECIFICA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DEST_ESPECIFICA, TIPO_NORMA, NUMERO_NORMA,(TO_CHAR(FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_NORMA, NATURALEZA, TERCERO_CHIP, (CASE WHEN (MOVIMIENTO + MAN_CEN_CTO + MAN_AUX_TER + MAN_AUX_GEN + MAN_AUX_REF + MAN_AUX_FUE) &lt;&gt; 0 THEN 'true' ELSE 'false' END) MOVIMIENTO FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO AND NATURALEZA = :NATURALEZA AND REGALIAS NOT IN (0) ORDER BY CODIGO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREVIGENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREVIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREVIGENCIA), '%')) AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOVIGENCIA), '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SECTOR), '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMA), '%')) AND (CASE WHEN SUBPROGRAMA IS NULL THEN ' ' ELSE UPPER(SUBPROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:SUBPROGRAMA), '%')) AND (CASE WHEN CODIGOPRODUCTO IS NULL THEN ' ' ELSE UPPER(CODIGOPRODUCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPRODUCTO), '%')) AND (CASE WHEN CODIGOBPIN IS NULL THEN ' ' ELSE UPPER(CODIGOBPIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOBPIN), '%')) AND (CASE WHEN CODIGOCCPET IS NULL THEN ' ' ELSE UPPER(CODIGOCCPET) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPET), '%')) AND (CASE WHEN CODIGOCPCDANE IS NULL THEN ' ' ELSE UPPER(CODIGOCPCDANE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCPCDANE), '%')) AND (CASE WHEN CODIGOUNIDADEJE IS NULL THEN ' ' ELSE UPPER(CODIGOUNIDADEJE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOUNIDADEJE), '%')) AND (CASE WHEN CODIGOFUENTE IS NULL THEN ' ' ELSE UPPER(CODIGOFUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOFUENTE), '%')) AND (CASE WHEN CODIGOCCPETREGA IS NULL THEN ' ' ELSE UPPER(CODIGOCCPETREGA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPETREGA), '%')) AND (CASE WHEN POLITCA_PUBLICA_CUIPO IS NULL THEN ' ' ELSE UPPER(POLITCA_PUBLICA_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:POLITCA_PUBLICA_CUIPO), '%')) AND (CASE WHEN DETALLE_SECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLE_SECTORIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DETALLE_SECTORIAL), '%')) AND (CASE WHEN TIPO_RECURSO IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_RECURSO), '%')) AND (CASE WHEN RECAUDO_VA IS NULL THEN ' ' ELSE UPPER(RECAUDO_VA) END) LIKE UPPER(CONCAT(CONCAT('%',:RECAUDO_VA), '%')) AND (CASE WHEN CONSITUACIONFONDOS IS NULL THEN ' ' ELSE UPPER(CONSITUACIONFONDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSITUACIONFONDOS), '%')) AND (CASE WHEN TRANSFERENCIA IS NULL THEN ' ' ELSE UPPER(TRANSFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TRANSFERENCIA), '%')) AND (CASE WHEN APLICA_DEST_ESPECIFICA IS NULL THEN ' ' ELSE UPPER(APLICA_DEST_ESPECIFICA) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICA_DEST_ESPECIFICA), '%')) AND (CASE WHEN TIPO_NORMA IS NULL THEN ' ' ELSE UPPER(TIPO_NORMA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_NORMA), '%')) AND (CASE WHEN NUMERO_NORMA IS NULL THEN ' ' ELSE UPPER(NUMERO_NORMA) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_NORMA), '%')) AND (CASE WHEN FECHA_NORMA IS NULL THEN ' ' ELSE UPPER(FECHA_NORMA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_NORMA), '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(CONCAT('%',:NATURALEZA), '%')) AND (CASE WHEN TERCERO_CHIP IS NULL THEN ' ' ELSE UPPER(TERCERO_CHIP) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO_CHIP), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
