	<query id="getPlanespresupuestalesNumGetrubroporanioyauxiliaresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE,(CASE PLAN_PRESUPUESTAL.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_PRESUPUESTAL.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE PLAN_PRESUPUESTAL.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE PLAN_PRESUPUESTAL.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN FROM PLAN_PRESUPUESTAL LEFT JOIN DETALLE_COMPROBANTE_PPTAL ON PLAN_PRESUPUESTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND PLAN_PRESUPUESTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND PLAN_PRESUPUESTAL.CODIGO = DETALLE_COMPROBANTE_PPTAL.CUENTA LEFT JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = TIPO_COMPROBPP.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.NATURALEZA = :NATURALEZA AND TIPO_COMPROBPP.CLASE IN ('ING','AIN','DIN','MOI','ICA','AIC','DIC','MIC') AND (PLAN_PRESUPUESTAL.MAN_AUX_GEN &lt;&gt; 0 OR PLAN_PRESUPUESTAL.MAN_CEN_CTO &lt;&gt; 0 OR PLAN_PRESUPUESTAL.MAN_AUX_REF &lt;&gt; 0 OR PLAN_PRESUPUESTAL.MAN_AUX_FUE &lt;&gt; 0) GROUP BY PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.MAN_AUX_GEN, PLAN_PRESUPUESTAL.MAN_CEN_CTO, PLAN_PRESUPUESTAL.MAN_AUX_REF, PLAN_PRESUPUESTAL.MAN_AUX_FUE ORDER BY PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END) LIKE UPPER(CONCAT(:MAN_CEN_CTO, '%')) AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END) LIKE UPPER(CONCAT(:MAN_AUX_REF, '%')) AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END) LIKE UPPER(CONCAT(:MAN_AUX_FUE, '%')) AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END) LIKE UPPER(CONCAT(:MAN_AUX_GEN, '%')) ) A) FIN</sql>
