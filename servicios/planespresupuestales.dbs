	<query id="getPlanespresupuestalesConteoCuentasConMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.CODIGO = :CODIGO AND (PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_FUE NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_GEN NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_REF NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_GEN NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_CEN_CTO NOT IN (0) OR PLAN_PRESUPUESTAL.MAN_AUX_TER NOT IN (0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
