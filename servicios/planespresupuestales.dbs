	<query id="getPlanespresupuestalesGetplanclasificadoresregaliasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA,ANO ,SUBSTR(CODIGO,0,100) CODIGO,SUBSTR(NOMBRE,0,100) NOMBRE , (SELECT NOMBRE FROM TIPOVIGENCIA WHERE CODIGO = TIPOVIGENCIA) NOMBREVIGENCIA , TIPOVIGENCIA ,SECTOR ,PROGRAMA ,SUBPROGRAMA ,CODIGOPRODUCTO ,CODIGOBPIN , CODIGOCCPET ,CODIGOCPCDANE ,CODIGOUNIDADEJE ,CODIGOFUENTE ,CODIGOCCPETREGA , POLITCA_PUBLICA_CUIPO ,DETALLE_SECTORIAL ,TIPO_RECURSO ,(CASE RECAUDO_VA WHEN 0 THEN 'false' ELSE 'true' END) RECAUDO_VA,(CASE CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS,(CASE TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TRANSFERENCIA,(CASE APLICA_DEST_ESPECIFICA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DEST_ESPECIFICA,TIPO_NORMA ,NUMERO_NORMA ,(TO_CHAR(FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_NORMA,NATURALEZA FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO AND NATURALEZA = :NATURALEZA AND REGALIAS NOT IN(0) ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NOMBREVIGENCIA":"$NOMBREVIGENCIA","TIPOVIGENCIA":"$TIPOVIGENCIA","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITCA_PUBLICA_CUIPO":"$POLITCA_PUBLICA_CUIPO","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","TIPO_RECURSO":"$TIPO_RECURSO(type:long)","RECAUDO_VA":"$RECAUDO_VA(type:boolean)","CONSITUACIONFONDOS":"$CONSITUACIONFONDOS(type:boolean)","TRANSFERENCIA":"$TRANSFERENCIA(type:boolean)","APLICA_DEST_ESPECIFICA":"$APLICA_DEST_ESPECIFICA(type:boolean)","TIPO_NORMA":"$TIPO_NORMA","NUMERO_NORMA":"$NUMERO_NORMA","FECHA_NORMA":"$FECHA_NORMA","NATURALEZA":"$NATURALEZA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>

	</query>
