	<query id="insertPlanespresupuestalesInsertplanpresupuestalexcel" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PLAN_PRESUPUESTAL (COMPANIA, ANO, CODIGO, NOMBRE, NATURALEZA, MOVIMIENTO, MAN_CEN_CTO, MAN_AUX_GEN, MAN_AUX_FUE, MAN_AUX_REF, VIGENCIA, TIPOVIGENCIA, DESTINO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :NATURALEZA, :MOVIMIENTO, :MAN_CEN_CTO, :MAN_AUX_GEN, :MAN_AUX_FUE, :MAN_AUX_REF, :VIGENCIA, :TIPOVIGENCIA, :DESTINO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_CEN_CTO" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_GEN" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_FUE" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_REF" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="" name="TIPOVIGENCIA" sqlType="STRING"/>
		<param defaultValue="" name="DESTINO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
