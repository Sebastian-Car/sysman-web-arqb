		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)"}]}}		</result>
