		<sql>SELECT ANO ,SUBSTR(CODIGO,0,100) CODIGO,SUBSTR(NOMBRE,0,100) NOMBRE ,(SELECT NOMBRE FROM TIPOVIGENCIA WHERE CODIGO = TIPOVIGENCIA) NOMBREVIGENCIA ,TIPOVIGENCIA, TIPOCLASIFICADOR,CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO AND NATURALEZA = :NATURALEZA AND REGALIAS NOT IN(0) ORDER BY CODIGO ASC</sql>
