	<query id="updatePlanespresupuestalesUpdateplanarbolregalias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PRESUPUESTAL SET TIPOVIGENCIA=:TIPOVIGENCIA, TIPOCLASIFICADOR=:TIPOCLASIFICADOR, CLASECLASIFICADOR=:CLASECLASIFICADOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PRESUPUESTAL.COMPANIA= :KEY_COMPANIA AND PLAN_PRESUPUESTAL.ANO= :KEY_ANO AND PLAN_PRESUPUESTAL.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPOVIGENCIA" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="CLASECLASIFICADOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planespresupuestales/updateplanarbolregalias">
		<call-query href="updatePlanespresupuestalesUpdateplanarbolregalias">
			<with-param name="TIPOVIGENCIA" query-param="TIPOVIGENCIA"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>
			<with-param name="CLASECLASIFICADOR" query-param="CLASECLASIFICADOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesPagGettipoclasificadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TC.CODIGO, TC.NOMBRE NOMBRETIPO, TC.CLASECLASIFICADOR CODIGOCLASE, CC.NOMBRE NOMBRECLASE FROM TIPOCLASIFICADOR TC INNER JOIN CLASECLASIFICADOR CC ON TC.COMPANIA = CC.COMPANIA AND TC.ANO = CC.ANO AND TC.CLASECLASIFICADOR = CC.CODIGO WHERE TC.COMPANIA = :COMPANIA AND TC.ANO = :ANO AND TC.CLASECLASIFICADOR= :CODIGOCLASE) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPO), '%')) AND (CASE WHEN CODIGOCLASE IS NULL THEN ' ' ELSE UPPER(CODIGOCLASE) END) LIKE UPPER(CONCAT(:CODIGOCLASE, '%')) AND (CASE WHEN NOMBRECLASE IS NULL THEN ' ' ELSE UPPER(NOMBRECLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECLASE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRETIPO":"$NOMBRETIPO","CODIGOCLASE":"$CODIGOCLASE","NOMBRECLASE":"$NOMBRECLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOCLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="NOMBRECLASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planespresupuestales/gettipoclasificador/pag">
		<call-query href="getPlanespresupuestalesPagGettipoclasificadorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOCLASE" query-param="CODIGOCLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="NOMBRECLASE" query-param="NOMBRECLASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesNumGettipoclasificadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TC.CODIGO, TC.NOMBRE NOMBRETIPO, TC.CLASECLASIFICADOR CODIGOCLASE, CC.NOMBRE NOMBRECLASE FROM TIPOCLASIFICADOR TC INNER JOIN CLASECLASIFICADOR CC ON TC.COMPANIA = CC.COMPANIA AND TC.ANO = CC.ANO AND TC.CLASECLASIFICADOR = CC.CODIGO WHERE TC.COMPANIA = :COMPANIA AND TC.ANO = :ANO AND TC.CLASECLASIFICADOR= :CODIGOCLASE) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPO), '%')) AND (CASE WHEN CODIGOCLASE IS NULL THEN ' ' ELSE UPPER(CODIGOCLASE) END) LIKE UPPER(CONCAT(:CODIGOCLASE, '%')) AND (CASE WHEN NOMBRECLASE IS NULL THEN ' ' ELSE UPPER(NOMBRECLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECLASE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOCLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="NOMBRECLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planespresupuestales/gettipoclasificador/num">
		<call-query href="getPlanespresupuestalesNumGettipoclasificadorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOCLASE" query-param="CODIGOCLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="NOMBRECLASE" query-param="NOMBRECLASE"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesPagGetclaseclasificadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO CODIGOCLASE, NOMBRE FROM CLASECLASIFICADOR WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGOCLASE IS NULL THEN ' ' ELSE UPPER(CODIGOCLASE) END) LIKE UPPER(CONCAT(:CODIGOCLASE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOCLASE":"$CODIGOCLASE","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGOCLASE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
