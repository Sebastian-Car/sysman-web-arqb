		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (CONCAT(ANO , CODIGO) ) COD, CODIGO, NOMBRE, ANO FROM PLAN_PRESUPUESTAL WHERE COMPANIA =:COMPANIA ORDER BY ANO DESC, CODIGO) INI WHERE (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END) LIKE UPPER(CONCAT(:COD, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD":"$COD","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)"}]}}		</result>
