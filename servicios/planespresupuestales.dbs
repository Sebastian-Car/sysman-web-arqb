		<param defaultValue="" name="COD_SIGUIENTE_VIGENCIA" sqlType="STRING"/>
		<param defaultValue="" name="COD_ANTERIOR_VIGENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="RECONOCIMIENTO" sqlType="STRING"/>
