	<query id="updatePlanespresupuestalesUpdateplan_preclasificadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PRESUPUESTAL SET SECTOR=:SECTOR, PROGRAMA=:PROGRAMA, SUBPROGRAMA=:SUBPROGRAMA, CODIGOPRODUCTO=:CODIGOPRODUCTO, CODIGOBPIN=:CODIGOBPIN, CODIGOCCPET=:CODIGOCCPET, CODIGOCPCDANE=:CODIGOCPCDANE, CODIGOUNIDADEJE=:CODIGOUNIDADEJE, CODIGOFUENTE=:CODIGOFUENTE, CODIGOCCPETREGA=:CODIGOCCPETREGA, POLITCA_PUBLICA_CUIPO=:POLITCA_PUBLICA_CUIPO, DETALLE_SECTORIAL=:DETALLE_SECTORIAL, TIPO_RECURSO=:TIPO_RECURSO, RECAUDO_VA=:RECAUDO_VA, CONSITUACIONFONDOS=:CONSITUACIONFONDOS, TRANSFERENCIA=:TRANSFERENCIA, APLICA_DEST_ESPECIFICA=:APLICA_DEST_ESPECIFICA, TIPO_NORMA=:TIPO_NORMA, NUMERO_NORMA=:NUMERO_NORMA, FECHA_NORMA=TO_DATE(:FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, NATURALEZA=:NATURALEZA, TERCERO_CHIP=:TERCERO_CHIP WHERE PLAN_PRESUPUESTAL.COMPANIA= :KEY_COMPANIA AND PLAN_PRESUPUESTAL.ANO= :KEY_ANO AND PLAN_PRESUPUESTAL.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SECTOR" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="SUBPROGRAMA" sqlType="STRING"/>
		<param name="CODIGOPRODUCTO" sqlType="STRING"/>
		<param name="CODIGOBPIN" sqlType="STRING"/>
		<param name="CODIGOCCPET" sqlType="STRING"/>
		<param name="CODIGOCPCDANE" sqlType="STRING"/>
		<param name="CODIGOUNIDADEJE" sqlType="STRING"/>
		<param name="CODIGOFUENTE" sqlType="STRING"/>
		<param name="CODIGOCCPETREGA" sqlType="STRING"/>
		<param name="POLITCA_PUBLICA_CUIPO" sqlType="STRING"/>
		<param name="DETALLE_SECTORIAL" sqlType="STRING"/>
		<param name="TIPO_RECURSO" sqlType="STRING"/>
		<param name="RECAUDO_VA" sqlType="STRING"/>
