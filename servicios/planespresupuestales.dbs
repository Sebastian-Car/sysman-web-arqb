		<param name="POLITCA_PUBLICA_CUIPO" sqlType="STRING"/>
		<param name="DETALLE_SECTORIAL" sqlType="STRING"/>
		<param name="TIPO_RECURSO" sqlType="STRING"/>
		<param name="RECAUDO_VA" sqlType="STRING"/>
		<param name="CONSITUACIONFONDOS" sqlType="STRING"/>
		<param name="TRANSFERENCIA" sqlType="STRING"/>
		<param name="APLICA_DEST_ESPECIFICA" sqlType="STRING"/>
		<param name="TIPO_NORMA" sqlType="STRING"/>
