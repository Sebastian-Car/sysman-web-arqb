<data name="planespresupuestales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPlanespresupuestalesNombrePorAnioCodigoConMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE  FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CODIGO = :CODIGO AND MOVIMIENTO NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planespresupuestales/nombreporaniocodigoconmovimiento">
		<call-query href="getPlanespresupuestalesNombrePorAnioCodigoConMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesPagTodosPorNaturalezacQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NATURALEZA = 'C' ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planespresupuestales/todospornaturalezac/pag">
		<call-query href="getPlanespresupuestalesPagTodosPorNaturalezacQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesNumTodosPorNaturalezacQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NATURALEZA = 'C' ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planespresupuestales/todospornaturalezac/num">
		<call-query href="getPlanespresupuestalesNumTodosPorNaturalezacQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesPagTodosPorCuentainiYNaturacQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE  FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.CODIGO &gt;= :CUENTAINICIAL AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.NATURALEZA = 'C' ORDER BY PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planespresupuestales/todosporcuentainiynaturac/pag">
		<call-query href="getPlanespresupuestalesPagTodosPorCuentainiYNaturacQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesNumTodosPorCuentainiYNaturacQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE  FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.CODIGO &gt;= :CUENTAINICIAL AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.NATURALEZA = 'C' ORDER BY PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planespresupuestales/todosporcuentainiynaturac/num">
		<call-query href="getPlanespresupuestalesNumTodosPorCuentainiYNaturacQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesPagListaDeRubrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, RECONOCIMIENTO FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA =:COMPANIA AND PLAN_PRESUPUESTAL.ANO =:ANIO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(CONCAT('',CONCAT(:CUENTAS,'') ),' ','') ),CONCAT('''',CONCAT(PLAN_PRESUPUESTAL .CODIGO,'''') ),1) &gt; 0) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN RECONOCIMIENTO IS NULL THEN ' ' ELSE UPPER(RECONOCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:RECONOCIMIENTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","RECONOCIMIENTO":"$RECONOCIMIENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CUENTAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RECONOCIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planespresupuestales/listaderubros/pag">
		<call-query href="getPlanespresupuestalesPagListaDeRubrosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CUENTAS" query-param="CUENTAS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RECONOCIMIENTO" query-param="RECONOCIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesNumListaDeRubrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, RECONOCIMIENTO FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA =:COMPANIA AND PLAN_PRESUPUESTAL.ANO =:ANIO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(CONCAT('',CONCAT(:CUENTAS,'') ),' ','') ),CONCAT('''',CONCAT(PLAN_PRESUPUESTAL .CODIGO,'''') ),1) &gt; 0) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN RECONOCIMIENTO IS NULL THEN ' ' ELSE UPPER(RECONOCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:RECONOCIMIENTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CUENTAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RECONOCIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planespresupuestales/listaderubros/num">
		<call-query href="getPlanespresupuestalesNumListaDeRubrosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CUENTAS" query-param="CUENTAS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RECONOCIMIENTO" query-param="RECONOCIMIENTO"/>

		</call-query>
	</resource>
	<query id="insertPlanespresupuestales" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PLAN_PRESUPUESTAL (COMPANIA, ANO, CODIGO, CODIGO_EQUIV, CODIGO_EQUIV2, NOMBRE, NATURALEZA, MOVIMIENTO, MAN_CEN_CTO, MAN_AUX_TER, MAN_AUX_GEN, MAN_AUX_REF, MAN_AUX_FUE, MAN_PAC, VIGENCIA, DINAMICA, INDECONOMICO, DESTINO, APROPIACIONINICIAL, RESERVADECAJA, RESERVADEAPROPIACION, NIVEL1, NIVEL2, NIVEL3, NIVEL4, NIVEL5, NIVEL6, NIVEL7, NIVEL8, TIPOVIGENCIA, INDCONTROL, INFORME, DEPENDENCIAASOCIADA, ENARCHIVOPLANO, CODCONTABLE5544, RECURSO5544, SUBRECURSO5544, COD_EQUIV5544, PERMITECONSOLIDAR, COD_SIGUIENTE_VIGENCIA, COD_ANTERIOR_VIGENCIA, RECONOCIMIENTO, INFORMESHACIENDA, CONSITUACIONFONDOS, ORIGENESPECIFICACIONINGRESOS, MEN, CODIGO_MEN, CUENTAAFORO, CODIGO_EQUIVALENTE2, CENTRO_EQUIV, AUXILIAR_EQUIV, JERARQUIA_GASTO, DESTINO_RECURSOS, NOM_CODIGO_EQUIVALENTE, MANEJA_PROYECTOS, REGALIAS, PASAR_SALDOS_APROP, FECHA_ACTIVACION, FUENTE_RECURSOS, COVID, MAN_POLITICA_PUBLICA, EQUIV_GASTO, CUENTAGASTOCNT, TIPOCLASIFICADOR, CLASECLASIFICADOR, TIPO_RECURSO, OBLIGACCPET, COFINANCIADO, UNIDAD_EJECUTORA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :CODIGO_EQUIV, :CODIGO_EQUIV2, :NOMBRE, :NATURALEZA, :MOVIMIENTO, :MAN_CEN_CTO, :MAN_AUX_TER, :MAN_AUX_GEN, :MAN_AUX_REF, :MAN_AUX_FUE, :MAN_PAC, :VIGENCIA, :DINAMICA, :INDECONOMICO, :DESTINO, :APROPIACIONINICIAL, :RESERVADECAJA, :RESERVADEAPROPIACION, :NIVEL1, :NIVEL2, :NIVEL3, :NIVEL4, :NIVEL5, :NIVEL6, :NIVEL7, :NIVEL8, :TIPOVIGENCIA, :INDCONTROL, :INFORME, :DEPENDENCIAASOCIADA, :ENARCHIVOPLANO, :CODCONTABLE5544, :RECURSO5544, :SUBRECURSO5544, :COD_EQUIV5544, :PERMITECONSOLIDAR, :COD_SIGUIENTE_VIGENCIA, :COD_ANTERIOR_VIGENCIA, :RECONOCIMIENTO, :INFORMESHACIENDA, :CONSITUACIONFONDOS, :ORIGENESPECIFICACIONINGRESOS, :MEN, :CODIGO_MEN, :CUENTAAFORO, :CODIGO_EQUIVALENTE2, :CENTRO_EQUIV, :AUXILIAR_EQUIV, :JERARQUIA_GASTO, :DESTINO_RECURSOS, :NOM_CODIGO_EQUIVALENTE, :MANEJA_PROYECTOS, :REGALIAS, :PASAR_SALDOS_APROP, TO_DATE(:FECHA_ACTIVACION,'DD/MM/YYYY HH24:MI:SS'), :FUENTE_RECURSOS, :COVID, :MAN_POLITICA_PUBLICA, :EQUIV_GASTO, :CUENTAGASTOCNT, :TIPOCLASIFICADOR, :CLASECLASIFICADOR, :TIPO_RECURSO, :OBLIGACCPET, :COFINANCIADO, :UNIDAD_EJECUTORA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_EQUIV" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_EQUIV2" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_CEN_CTO" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_TER" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_GEN" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_REF" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_FUE" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_PAC" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="" name="DINAMICA" sqlType="STRING"/>
