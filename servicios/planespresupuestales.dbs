	<query id="getPlanespresupuestalesPagGetplanespresupuestalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TC.CODIGO, TC.NOMBRE NOMBRETIPO, TC.CLASECLASIFICADOR CODIGOCLASE, CC.NOMBRE NOMBRECLASE FROM TIPOCLASIFICADOR TC INNER JOIN CLASECLASIFICADOR CC ON TC.COMPANIA = CC.COMPANIA AND TC.ANO = CC.ANO AND TC.CLASECLASIFICADOR = CC.CODIGO WHERE TC.COMPANIA = :COMPANIA AND TC.ANO = :ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPO), '%')) AND (CASE WHEN CODIGOCLASE IS NULL THEN ' ' ELSE UPPER(CODIGOCLASE) END) LIKE UPPER(CONCAT(:CODIGOCLASE, '%')) AND (CASE WHEN NOMBRECLASE IS NULL THEN ' ' ELSE UPPER(NOMBRECLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECLASE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRETIPO":"$NOMBRETIPO","CODIGOCLASE":"$CODIGOCLASE","NOMBRECLASE":"$NOMBRECLASE"}]}}		</result>
