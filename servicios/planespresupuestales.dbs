	<query id="deletePlanespresupuestales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA= :KEY_COMPANIA AND PLAN_PRESUPUESTAL.ANO= :KEY_ANO AND PLAN_PRESUPUESTAL.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="planespresupuestales">
		<call-query href="deletePlanespresupuestales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PP.COMPANIA, PP.ANO, PP.CODIGO, PP.NOMBRE, DESTINO.NOMBRE DESTINO, DECODE(PP.NATURALEZA,'D','Gastos','Ingresos') NATURALEZA,(CASE PP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, TV.NOMBRE TIPO_VIGENCIA  FROM PLAN_PRESUPUESTAL PP INNER JOIN TIPOVIGENCIA TV ON PP.TIPOVIGENCIA = TV.CODIGO LEFT JOIN DESTINO ON PP.COMPANIA = DESTINO.COMPANIA AND PP.DESTINO = DESTINO.CODIGO WHERE PP.COMPANIA = :COMPANIA AND PP.ANO = :ANO ORDER BY PP.COMPANIA, PP.ANO, PP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END)  LIKE UPPER(:DESTINO || '%')  AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END)  LIKE UPPER(:NATURALEZA || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN TIPO_VIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPO_VIGENCIA) END)  LIKE UPPER(:TIPO_VIGENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESTINO":"$DESTINO","NATURALEZA":"$NATURALEZA","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","TIPO_VIGENCIA":"$TIPO_VIGENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="TIPO_VIGENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planespresupuestales">
		<call-query href="getPlanespresupuestalesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="TIPO_VIGENCIA" query-param="TIPO_VIGENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanespresupuestalesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PP.COMPANIA, PP.ANO, PP.CODIGO, PP.NOMBRE, DESTINO.NOMBRE DESTINO, DECODE(PP.NATURALEZA,'D','Gastos','Ingresos') NATURALEZA,(CASE PP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, TV.NOMBRE TIPO_VIGENCIA  FROM PLAN_PRESUPUESTAL PP INNER JOIN TIPOVIGENCIA TV ON PP.TIPOVIGENCIA = TV.CODIGO LEFT JOIN DESTINO ON PP.COMPANIA = DESTINO.COMPANIA AND PP.DESTINO = DESTINO.CODIGO WHERE PP.COMPANIA = :COMPANIA AND PP.ANO = :ANO ORDER BY PP.COMPANIA, PP.ANO, PP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END)  LIKE UPPER(:DESTINO || '%')  AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END)  LIKE UPPER(:NATURALEZA || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN TIPO_VIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPO_VIGENCIA) END)  LIKE UPPER(:TIPO_VIGENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="TIPO_VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planespresupuestales/numero">
		<call-query href="getPlanespresupuestalesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="TIPO_VIGENCIA" query-param="TIPO_VIGENCIA"/>

		</call-query>
