		<param defaultValue="0" name="PASAR_SALDOS_APROP" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ACTIVACION" sqlType="STRING"/>
		<param defaultValue="" name="FUENTE_RECURSOS" sqlType="STRING"/>
		<param defaultValue="0" name="COVID" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_POLITICA_PUBLICA" sqlType="STRING"/>
		<param defaultValue="" name="EQUIV_GASTO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTAGASTOCNT" sqlType="STRING"/>
		<param defaultValue="" name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param defaultValue="" name="CLASECLASIFICADOR" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_RECURSO" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGACCPET" sqlType="STRING"/>
