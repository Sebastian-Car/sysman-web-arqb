<data name="vpproyectos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVpproyectosPagProyectoporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID,CODIGO,DESCRIPCION  FROM VP_PROYECTOS WHERE COMPANIA = :COMPANIA AND CLASE = :CLASE) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpproyectos/proyectoporcompania/pag">
		<call-query href="getVpproyectosPagProyectoporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpproyectosNumProyectoporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID,CODIGO,DESCRIPCION  FROM VP_PROYECTOS WHERE COMPANIA = :COMPANIA AND CLASE = :CLASE) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpproyectos/proyectoporcompania/num">
		<call-query href="getVpproyectosNumProyectoporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getVpproyectosPagLlavesprimariasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID,CODIGO,DESCRIPCION,CLASE  FROM VP_PROYECTOS WHERE COMPANIA = :COMPANIA AND CLASE = :CLASEVP) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","CLASE":"$CLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEVP" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpproyectos/llavesprimarias/pag">
		<call-query href="getVpproyectosPagLlavesprimariasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEVP" query-param="CLASEVP"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpproyectosNumLlavesprimariasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID,CODIGO,DESCRIPCION,CLASE  FROM VP_PROYECTOS WHERE COMPANIA = :COMPANIA AND CLASE = :CLASEVP) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEVP" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpproyectos/llavesprimarias/num">
		<call-query href="getVpproyectosNumLlavesprimariasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEVP" query-param="CLASEVP"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertVpproyectosInsertacuerdo" keyColumns="ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VP_PROYECTOS (COMPANIA, CODIGO, CLASE, MOVIMIENTO, DESCRIPCION, LOCALIZACION, VALOR_PROYECTO, VALOR_DISTRIBUIBLE, FECHA_INICIAL_PROYECTO, VALOR_AREA_PREFERENCIA, FECHA_FINAL_PROYECTO, RUTA_ANEXO, PORCENTAJE_DESCUENTO, CODIGO_EAN, AREA_TOTAL, ANO_BASE, MES_BASE, TIPO_COMPROBANTE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :CLASE, :MOVIMIENTO, :DESCRIPCION, :LOCALIZACION, :VALOR_PROYECTO, :VALOR_DISTRIBUIBLE, TO_DATE(:FECHA_INICIAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS'), :VALOR_AREA_PREFERENCIA, TO_DATE(:FECHA_FINAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS'), :RUTA_ANEXO, :PORCENTAJE_DESCUENTO, :CODIGO_EAN, :AREA_TOTAL, :ANO_BASE, :MES_BASE, :TIPO_COMPROBANTE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ID":"$ID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="LOCALIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_DISTRIBUIBLE" sqlType="STRING"/>
		<param name="FECHA_INICIAL_PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_AREA_PREFERENCIA" sqlType="STRING"/>
		<param name="FECHA_FINAL_PROYECTO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_ANEXO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE_DESCUENTO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_EAN" sqlType="STRING"/>
		<param defaultValue="" name="AREA_TOTAL" sqlType="STRING"/>
		<param defaultValue="" name="ANO_BASE" sqlType="STRING"/>
		<param defaultValue="" name="MES_BASE" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vpproyectos/insertacuerdo">
		<call-query href="insertVpproyectosInsertacuerdo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="LOCALIZACION" query-param="LOCALIZACION"/>
			<with-param name="VALOR_PROYECTO" query-param="VALOR_PROYECTO"/>
			<with-param name="VALOR_DISTRIBUIBLE" query-param="VALOR_DISTRIBUIBLE"/>
			<with-param name="FECHA_INICIAL_PROYECTO" query-param="FECHA_INICIAL_PROYECTO"/>
			<with-param name="VALOR_AREA_PREFERENCIA" query-param="VALOR_AREA_PREFERENCIA"/>
			<with-param name="FECHA_FINAL_PROYECTO" query-param="FECHA_FINAL_PROYECTO"/>
			<with-param name="RUTA_ANEXO" query-param="RUTA_ANEXO"/>
			<with-param name="PORCENTAJE_DESCUENTO" query-param="PORCENTAJE_DESCUENTO"/>
			<with-param name="CODIGO_EAN" query-param="CODIGO_EAN"/>
			<with-param name="AREA_TOTAL" query-param="AREA_TOTAL"/>
			<with-param name="ANO_BASE" query-param="ANO_BASE"/>
			<with-param name="MES_BASE" query-param="MES_BASE"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getVpproyectosSelectacuerdoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID,COMPANIA,CODIGO,DESCRIPCION  FROM VP_PROYECTOS WHERE COMPANIA = :COMPANIA AND CLASE = :CLASEVP</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEVP" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpproyectos/selectacuerdo">
		<call-query href="getVpproyectosSelectacuerdoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEVP" query-param="CLASEVP"/>

		</call-query>
	</resource>
	<query id="getVpproyectosValidartiporecaudoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_RECAUDO  FROM VP_PROYECTOS INNER JOIN TIPO_COMPROBANTE ON VP_PROYECTOS.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND VP_PROYECTOS.TIPO_COMPROBANTE = TIPO_COMPROBANTE.CODIGO WHERE VP_PROYECTOS.COMPANIA = :COMPANIA AND VP_PROYECTOS.ID = :PROYECTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_RECAUDO":"$TIPO_RECAUDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpproyectos/validartiporecaudo">
		<call-query href="getVpproyectosValidartiporecaudoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>

		</call-query>
	</resource>
	<query id="getVpproyectosExistecodigoeanQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO_EAN  FROM VP_PROYECTOS WHERE COMPANIA = :COMPANIA AND ID = :PROYECTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_EAN":"$CODIGO_EAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpproyectos/existecodigoean">
		<call-query href="getVpproyectosExistecodigoeanQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>

		</call-query>
	</resource>
	<query id="insertVpproyectos" keyColumns="ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VP_PROYECTOS (COMPANIA, CODIGO, CLASE, MOVIMIENTO, DESCRIPCION, LOCALIZACION, VALOR_PROYECTO, VALOR_DISTRIBUIBLE, FECHA_INICIAL_PROYECTO, VALOR_AREA_PREFERENCIA, FECHA_FINAL_PROYECTO, RUTA_ANEXO, PORCENTAJE_DESCUENTO, CODIGO_EAN, PI_TIPO, PI_NUMERO, PI_ID_PLAN, PI_VIGENCIA_INICIAL, BP_CODIGO, AREA_TOTAL, TIPO_COMPROBANTE, APLICA_AMNISTIA, FECHA_FINAL_AMNISTIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :CLASE, :MOVIMIENTO, :DESCRIPCION, :LOCALIZACION, :VALOR_PROYECTO, :VALOR_DISTRIBUIBLE, TO_DATE(:FECHA_INICIAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS'), :VALOR_AREA_PREFERENCIA, TO_DATE(:FECHA_FINAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS'), :RUTA_ANEXO, :PORCENTAJE_DESCUENTO, :CODIGO_EAN, :PI_TIPO, :PI_NUMERO, :PI_ID_PLAN, :PI_VIGENCIA_INICIAL, :BP_CODIGO, :AREA_TOTAL, :TIPO_COMPROBANTE, :APLICA_AMNISTIA, TO_DATE(:FECHA_FINAL_AMNISTIA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ID":"$ID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="LOCALIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_DISTRIBUIBLE" sqlType="STRING"/>
		<param name="FECHA_INICIAL_PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_AREA_PREFERENCIA" sqlType="STRING"/>
		<param name="FECHA_FINAL_PROYECTO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_ANEXO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE_DESCUENTO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_EAN" sqlType="STRING"/>
		<param defaultValue="" name="PI_TIPO" sqlType="STRING"/>
		<param defaultValue="" name="PI_NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="PI_ID_PLAN" sqlType="STRING"/>
		<param defaultValue="" name="PI_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param defaultValue="" name="BP_CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="AREA_TOTAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param defaultValue="0" name="APLICA_AMNISTIA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL_AMNISTIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vpproyectos">
		<call-query href="insertVpproyectos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="LOCALIZACION" query-param="LOCALIZACION"/>
			<with-param name="VALOR_PROYECTO" query-param="VALOR_PROYECTO"/>
			<with-param name="VALOR_DISTRIBUIBLE" query-param="VALOR_DISTRIBUIBLE"/>
			<with-param name="FECHA_INICIAL_PROYECTO" query-param="FECHA_INICIAL_PROYECTO"/>
			<with-param name="VALOR_AREA_PREFERENCIA" query-param="VALOR_AREA_PREFERENCIA"/>
			<with-param name="FECHA_FINAL_PROYECTO" query-param="FECHA_FINAL_PROYECTO"/>
			<with-param name="RUTA_ANEXO" query-param="RUTA_ANEXO"/>
			<with-param name="PORCENTAJE_DESCUENTO" query-param="PORCENTAJE_DESCUENTO"/>
			<with-param name="CODIGO_EAN" query-param="CODIGO_EAN"/>
			<with-param name="PI_TIPO" query-param="PI_TIPO"/>
			<with-param name="PI_NUMERO" query-param="PI_NUMERO"/>
			<with-param name="PI_ID_PLAN" query-param="PI_ID_PLAN"/>
			<with-param name="PI_VIGENCIA_INICIAL" query-param="PI_VIGENCIA_INICIAL"/>
			<with-param name="BP_CODIGO" query-param="BP_CODIGO"/>
			<with-param name="AREA_TOTAL" query-param="AREA_TOTAL"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
			<with-param name="APLICA_AMNISTIA" query-param="APLICA_AMNISTIA"/>
			<with-param name="FECHA_FINAL_AMNISTIA" query-param="FECHA_FINAL_AMNISTIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVpproyectos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VP_PROYECTOS WHERE VP_PROYECTOS.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vpproyectos">
		<call-query href="deleteVpproyectos">
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getVpproyectosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VP_PROYECTOS.ID, VP_PROYECTOS.COMPANIA, VP_PROYECTOS.CODIGO, TIPOS.NOMBRE, VP_PROYECTOS.CLASE, VP_PROYECTOS.DESCRIPCION  FROM VP_PROYECTOS LEFT JOIN TIPOS ON VP_PROYECTOS.CLASE = TIPOS.ID WHERE COMPANIA = :COMPANIA AND CLASE = :CLASEVP) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE":"$CLASE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEVP" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpproyectos">
		<call-query href="getVpproyectosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEVP" query-param="CLASEVP"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpproyectosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VP_PROYECTOS.ID, VP_PROYECTOS.COMPANIA, VP_PROYECTOS.CODIGO, TIPOS.NOMBRE, VP_PROYECTOS.CLASE, VP_PROYECTOS.DESCRIPCION  FROM VP_PROYECTOS LEFT JOIN TIPOS ON VP_PROYECTOS.CLASE = TIPOS.ID WHERE COMPANIA = :COMPANIA AND CLASE = :CLASEVP) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEVP" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpproyectos/numero">
		<call-query href="getVpproyectosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEVP" query-param="CLASEVP"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getVpproyectosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VP_PROYECTOS.ID, VP_PROYECTOS.COMPANIA, VP_PROYECTOS.CODIGO, VP_PROYECTOS.CLASE, TIPOS.NOMBRE NOMBRECLASE,(CASE VP_PROYECTOS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, VP_PROYECTOS.DESCRIPCION, VP_PROYECTOS.LOCALIZACION, VP_PROYECTOS.VALOR_PROYECTO, VP_PROYECTOS.VALOR_DISTRIBUIBLE,(TO_CHAR(VP_PROYECTOS.FECHA_INICIAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL_PROYECTO, VP_PROYECTOS.VALOR_AREA_PREFERENCIA,(CASE VP_PROYECTOS.APLICA_AMNISTIA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_AMNISTIA,(TO_CHAR(VP_PROYECTOS.FECHA_FINAL_AMNISTIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_AMNISTIA,(TO_CHAR(VP_PROYECTOS.FECHA_FINAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_PROYECTO, VP_PROYECTOS.TIPO_COMPROBANTE, VP_PROYECTOS.RUTA_ANEXO, VP_PROYECTOS.ANO_BASE, VP_PROYECTOS.MES_BASE, VP_PROYECTOS.PORCENTAJE_DESCUENTO, VP_PROYECTOS.CODIGO_EAN, VP_PROYECTOS.PI_TIPO, VP_PROYECTOS.PI_NUMERO, VP_PROYECTOS.PI_ID_PLAN, VP_PROYECTOS.PI_VIGENCIA_INICIAL, VP_PROYECTOS.BP_CODIGO, VP_PROYECTOS.AREA_TOTAL, BP_ACTIVIDADES.NOMBRE NOMBREACTIVIDAD, VP_PROYECTOS.CREATED_BY,(TO_CHAR(VP_PROYECTOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VP_PROYECTOS.MODIFIED_BY,(TO_CHAR(VP_PROYECTOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM VP_PROYECTOS LEFT JOIN TIPOS ON VP_PROYECTOS.CLASE = TIPOS.ID LEFT JOIN BP_ACTIVIDADES ON VP_PROYECTOS.COMPANIA = BP_ACTIVIDADES.COMPANIA AND VP_PROYECTOS.BP_CODIGO = BP_ACTIVIDADES.CODIGO WHERE VP_PROYECTOS.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CLASE":"$CLASE","NOMBRECLASE":"$NOMBRECLASE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","DESCRIPCION":"$DESCRIPCION","LOCALIZACION":"$LOCALIZACION","VALOR_PROYECTO":"$VALOR_PROYECTO","VALOR_DISTRIBUIBLE":"$VALOR_DISTRIBUIBLE","FECHA_INICIAL_PROYECTO":"$FECHA_INICIAL_PROYECTO","VALOR_AREA_PREFERENCIA":"$VALOR_AREA_PREFERENCIA","APLICA_AMNISTIA":"$APLICA_AMNISTIA(type:boolean)","FECHA_FINAL_AMNISTIA":"$FECHA_FINAL_AMNISTIA","FECHA_FINAL_PROYECTO":"$FECHA_FINAL_PROYECTO","TIPO_COMPROBANTE":"$TIPO_COMPROBANTE","RUTA_ANEXO":"$RUTA_ANEXO","ANO_BASE":"$ANO_BASE(type:integer)","MES_BASE":"$MES_BASE(type:integer)","PORCENTAJE_DESCUENTO":"$PORCENTAJE_DESCUENTO","CODIGO_EAN":"$CODIGO_EAN","PI_TIPO":"$PI_TIPO","PI_NUMERO":"$PI_NUMERO(type:long)","PI_ID_PLAN":"$PI_ID_PLAN","PI_VIGENCIA_INICIAL":"$PI_VIGENCIA_INICIAL(type:integer)","BP_CODIGO":"$BP_CODIGO","AREA_TOTAL":"$AREA_TOTAL","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpproyectos/data">
		<call-query href="getVpproyectosRegistroQuery">
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateVpproyectos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VP_PROYECTOS SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, CLASE=:CLASE, MOVIMIENTO=:MOVIMIENTO, DESCRIPCION=:DESCRIPCION, LOCALIZACION=:LOCALIZACION, VALOR_PROYECTO=:VALOR_PROYECTO, VALOR_DISTRIBUIBLE=:VALOR_DISTRIBUIBLE, FECHA_INICIAL_PROYECTO=TO_DATE(:FECHA_INICIAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS'), VALOR_AREA_PREFERENCIA=:VALOR_AREA_PREFERENCIA, FECHA_FINAL_PROYECTO=TO_DATE(:FECHA_FINAL_PROYECTO,'DD/MM/YYYY HH24:MI:SS'), RUTA_ANEXO=:RUTA_ANEXO, PORCENTAJE_DESCUENTO=:PORCENTAJE_DESCUENTO, CODIGO_EAN=:CODIGO_EAN, PI_TIPO=:PI_TIPO, PI_NUMERO=:PI_NUMERO, PI_ID_PLAN=:PI_ID_PLAN, PI_VIGENCIA_INICIAL=:PI_VIGENCIA_INICIAL, BP_CODIGO=:BP_CODIGO, AREA_TOTAL=:AREA_TOTAL, ANO_BASE=:ANO_BASE, MES_BASE=:MES_BASE, TIPO_COMPROBANTE=:TIPO_COMPROBANTE, APLICA_AMNISTIA=:APLICA_AMNISTIA, FECHA_FINAL_AMNISTIA=TO_DATE(:FECHA_FINAL_AMNISTIA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VP_PROYECTOS.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="LOCALIZACION" sqlType="STRING"/>
		<param name="VALOR_PROYECTO" sqlType="STRING"/>
		<param name="VALOR_DISTRIBUIBLE" sqlType="STRING"/>
		<param name="FECHA_INICIAL_PROYECTO" sqlType="STRING"/>
		<param name="VALOR_AREA_PREFERENCIA" sqlType="STRING"/>
		<param name="FECHA_FINAL_PROYECTO" sqlType="STRING"/>
		<param name="RUTA_ANEXO" sqlType="STRING"/>
		<param name="PORCENTAJE_DESCUENTO" sqlType="STRING"/>
		<param name="CODIGO_EAN" sqlType="STRING"/>
		<param name="PI_TIPO" sqlType="STRING"/>
		<param name="PI_NUMERO" sqlType="STRING"/>
		<param name="PI_ID_PLAN" sqlType="STRING"/>
		<param name="PI_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="BP_CODIGO" sqlType="STRING"/>
		<param name="AREA_TOTAL" sqlType="STRING"/>
		<param name="ANO_BASE" sqlType="STRING"/>
		<param name="MES_BASE" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="APLICA_AMNISTIA" sqlType="STRING"/>
		<param name="FECHA_FINAL_AMNISTIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vpproyectos">
		<call-query href="updateVpproyectos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="LOCALIZACION" query-param="LOCALIZACION"/>
