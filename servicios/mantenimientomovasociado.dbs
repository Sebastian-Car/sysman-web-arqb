			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>

		</call-query>
	</resource>
	<query id="updateMantenimientomovasociado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MANTENIMIENTO_MOV_ASOCIADO SET TIPOCOMPROBANTE=:TIPOCOMPROBANTE, NUM_MANTENIMIENTO=:NUM_MANTENIMIENTO, TIPOMOVIMIENTO=:TIPOMOVIMIENTO, NUM_MOVIMIENTO=:NUM_MOVIMIENTO, CONSECUTIVO=:CONSECUTIVO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE MANTENIMIENTO_MOV_ASOCIADO.COMPANIA= :KEY_COMPANIA AND MANTENIMIENTO_MOV_ASOCIADO.ANO= :KEY_ANO AND MANTENIMIENTO_MOV_ASOCIADO.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MANTENIMIENTO= :KEY_NUM_MANTENIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MOVIMIENTO= :KEY_NUM_MOVIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUM_MANTENIMIENTO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUM_MOVIMIENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_NUM_MANTENIMIENTO" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_NUM_MOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="mantenimientomovasociado">
		<call-query href="updateMantenimientomovasociado">
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="NUM_MANTENIMIENTO" query-param="NUM_MANTENIMIENTO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUM_MOVIMIENTO" query-param="NUM_MOVIMIENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOMPROBANTE" query-param="KEY_TIPOCOMPROBANTE"/>
			<with-param name="KEY_NUM_MANTENIMIENTO" query-param="KEY_NUM_MANTENIMIENTO"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_NUM_MOVIMIENTO" query-param="KEY_NUM_MOVIMIENTO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>