<data name="mantenimientomovasociado" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertMantenimientomovasociado" keyColumns="COMPANIA,ANO,TIPOCOMPROBANTE,NUM_MANTENIMIENTO,TIPOMOVIMIENTO,NUM_MOVIMIENTO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO MANTENIMIENTO_MOV_ASOCIADO (COMPANIA, ANO, TIPOCOMPROBANTE, NUM_MANTENIMIENTO, TIPOMOVIMIENTO, NUM_MOVIMIENTO, CONSECUTIVO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ANO, :TIPOCOMPROBANTE, :NUM_MANTENIMIENTO, :TIPOMOVIMIENTO, :NUM_MOVIMIENTO, :CONSECUTIVO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPOCOMPROBANTE":"$TIPOCOMPROBANTE","KEY_NUM_MANTENIMIENTO":"$NUM_MANTENIMIENTO","KEY_TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","KEY_NUM_MOVIMIENTO":"$NUM_MOVIMIENTO","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param defaultValue="0" name="NUM_MANTENIMIENTO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUM_MOVIMIENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="mantenimientomovasociado">
		<call-query href="insertMantenimientomovasociado">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="NUM_MANTENIMIENTO" query-param="NUM_MANTENIMIENTO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUM_MOVIMIENTO" query-param="NUM_MOVIMIENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteMantenimientomovasociado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM MANTENIMIENTO_MOV_ASOCIADO WHERE MANTENIMIENTO_MOV_ASOCIADO.COMPANIA= :KEY_COMPANIA AND MANTENIMIENTO_MOV_ASOCIADO.ANO= :KEY_ANO AND MANTENIMIENTO_MOV_ASOCIADO.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MANTENIMIENTO= :KEY_NUM_MANTENIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MOVIMIENTO= :KEY_NUM_MOVIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_NUM_MANTENIMIENTO" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_NUM_MOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="mantenimientomovasociado">
		<call-query href="deleteMantenimientomovasociado">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOMPROBANTE" query-param="KEY_TIPOCOMPROBANTE"/>
			<with-param name="KEY_NUM_MANTENIMIENTO" query-param="KEY_NUM_MANTENIMIENTO"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_NUM_MOVIMIENTO" query-param="KEY_NUM_MOVIMIENTO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getMantenimientomovasociadoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MANTENIMIENTO_MOV_ASOCIADO.COMPANIA, MANTENIMIENTO_MOV_ASOCIADO.ANO, MANTENIMIENTO_MOV_ASOCIADO.TIPOCOMPROBANTE, MANTENIMIENTO_MOV_ASOCIADO.NUM_MANTENIMIENTO, MANTENIMIENTO_MOV_ASOCIADO.TIPOMOVIMIENTO, MANTENIMIENTO_MOV_ASOCIADO.NUM_MOVIMIENTO, MANTENIMIENTO_MOV_ASOCIADO.CONSECUTIVO, TO_CHAR(MOVIMIENTO.FECHA, 'DD/MM/YYYY') FECHA, MOVIMIENTO.DESCRIPCION, MANTENIMIENTO_MOV_ASOCIADO.CREATED_BY,(TO_CHAR(MANTENIMIENTO_MOV_ASOCIADO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MANTENIMIENTO_MOV_ASOCIADO.MODIFIED_BY,(TO_CHAR(MANTENIMIENTO_MOV_ASOCIADO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM MANTENIMIENTO_MOV_ASOCIADO INNER JOIN MOVIMIENTO ON MANTENIMIENTO_MOV_ASOCIADO.COMPANIA = MOVIMIENTO.COMPANIA AND MANTENIMIENTO_MOV_ASOCIADO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MOVIMIENTO = MOVIMIENTO.NUMERO WHERE MANTENIMIENTO_MOV_ASOCIADO.COMPANIA = :COMPANIA AND MANTENIMIENTO_MOV_ASOCIADO.ANO = :ANO AND MANTENIMIENTO_MOV_ASOCIADO.TIPOCOMPROBANTE = :TIPOCOMPROBANTE AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MANTENIMIENTO = :NUM_MANTENIMIENTO ORDER BY MANTENIMIENTO_MOV_ASOCIADO.CONSECUTIVO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPOCOMPROBANTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPROBANTE) END)  LIKE UPPER( '%' || :TIPOCOMPROBANTE || '%')  AND (CASE WHEN NUM_MANTENIMIENTO IS NULL THEN ' ' ELSE UPPER(NUM_MANTENIMIENTO) END)  LIKE UPPER(:NUM_MANTENIMIENTO || '%')  AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%')  AND (CASE WHEN NUM_MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(NUM_MOVIMIENTO) END)  LIKE UPPER( '%' || :NUM_MOVIMIENTO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER( '%' || :DATE_MODIFIED || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOMPROBANTE":"$TIPOCOMPROBANTE","NUM_MANTENIMIENTO":"$NUM_MANTENIMIENTO","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","NUM_MOVIMIENTO":"$NUM_MOVIMIENTO","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUM_MANTENIMIENTO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUM_MOVIMIENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="mantenimientomovasociado">
		<call-query href="getMantenimientomovasociadoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="NUM_MANTENIMIENTO" query-param="NUM_MANTENIMIENTO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUM_MOVIMIENTO" query-param="NUM_MOVIMIENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMantenimientomovasociadoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MANTENIMIENTO_MOV_ASOCIADO.COMPANIA, MANTENIMIENTO_MOV_ASOCIADO.ANO, MANTENIMIENTO_MOV_ASOCIADO.TIPOCOMPROBANTE, MANTENIMIENTO_MOV_ASOCIADO.NUM_MANTENIMIENTO, MANTENIMIENTO_MOV_ASOCIADO.TIPOMOVIMIENTO, MANTENIMIENTO_MOV_ASOCIADO.NUM_MOVIMIENTO, MANTENIMIENTO_MOV_ASOCIADO.CONSECUTIVO, TO_CHAR(MOVIMIENTO.FECHA, 'DD/MM/YYYY') FECHA, MOVIMIENTO.DESCRIPCION, MANTENIMIENTO_MOV_ASOCIADO.CREATED_BY,(TO_CHAR(MANTENIMIENTO_MOV_ASOCIADO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MANTENIMIENTO_MOV_ASOCIADO.MODIFIED_BY,(TO_CHAR(MANTENIMIENTO_MOV_ASOCIADO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM MANTENIMIENTO_MOV_ASOCIADO INNER JOIN MOVIMIENTO ON MANTENIMIENTO_MOV_ASOCIADO.COMPANIA = MOVIMIENTO.COMPANIA AND MANTENIMIENTO_MOV_ASOCIADO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MOVIMIENTO = MOVIMIENTO.NUMERO WHERE MANTENIMIENTO_MOV_ASOCIADO.COMPANIA = :COMPANIA AND MANTENIMIENTO_MOV_ASOCIADO.ANO = :ANO AND MANTENIMIENTO_MOV_ASOCIADO.TIPOCOMPROBANTE = :TIPOCOMPROBANTE AND MANTENIMIENTO_MOV_ASOCIADO.NUM_MANTENIMIENTO = :NUM_MANTENIMIENTO ORDER BY MANTENIMIENTO_MOV_ASOCIADO.CONSECUTIVO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPOCOMPROBANTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPROBANTE) END)  LIKE UPPER( '%' || :TIPOCOMPROBANTE || '%')  AND (CASE WHEN NUM_MANTENIMIENTO IS NULL THEN ' ' ELSE UPPER(NUM_MANTENIMIENTO) END)  LIKE UPPER(:NUM_MANTENIMIENTO || '%')  AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%')  AND (CASE WHEN NUM_MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(NUM_MOVIMIENTO) END)  LIKE UPPER( '%' || :NUM_MOVIMIENTO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER( '%' || :DATE_MODIFIED || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUM_MANTENIMIENTO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUM_MOVIMIENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientomovasociado/numero">
		<call-query href="getMantenimientomovasociadoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="NUM_MANTENIMIENTO" query-param="NUM_MANTENIMIENTO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
