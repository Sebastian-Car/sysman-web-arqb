<data name="gnacuerdo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getGnacuerdoPagListadoacuerdosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIT, NOMBRE  FROM GN_ACUERDO GNA INNER JOIN TERCERO T ON GNA.COMPANIA = T.COMPANIA AND GNA.TERCERO = T.NIT AND GNA.SUCURSAL = T.SUCURSAL WHERE GNA.COMPANIA = :COMPANIA AND APLICACION = :APLICACION ORDER BY GNA.ID) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="gnacuerdo/listadoacuerdos/pag">
		<call-query href="getGnacuerdoPagListadoacuerdosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getGnacuerdoNumListadoacuerdosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NIT, NOMBRE  FROM GN_ACUERDO GNA INNER JOIN TERCERO T ON GNA.COMPANIA = T.COMPANIA AND GNA.TERCERO = T.NIT AND GNA.SUCURSAL = T.SUCURSAL WHERE GNA.COMPANIA = :COMPANIA AND APLICACION = :APLICACION ORDER BY GNA.ID) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="gnacuerdo/listadoacuerdos/num">
		<call-query href="getGnacuerdoNumListadoacuerdosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getGnacuerdoPagTercerofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIT, NOMBRE  FROM GN_ACUERDO GNA INNER JOIN TERCERO T ON GNA.COMPANIA = T.COMPANIA AND GNA.TERCERO = T.NIT AND GNA.SUCURSAL = T.SUCURSAL WHERE GNA.COMPANIA = :COMPANIA AND GNA.APLICACION = :APLICACION AND T.NIT &lt;= :TERCEROINICIAL) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="TERCEROINICIAL" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="gnacuerdo/tercerofinal/pag">
		<call-query href="getGnacuerdoPagTercerofinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="TERCEROINICIAL" query-param="TERCEROINICIAL"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getGnacuerdoNumTercerofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NIT, NOMBRE  FROM GN_ACUERDO GNA INNER JOIN TERCERO T ON GNA.COMPANIA = T.COMPANIA AND GNA.TERCERO = T.NIT AND GNA.SUCURSAL = T.SUCURSAL WHERE GNA.COMPANIA = :COMPANIA AND GNA.APLICACION = :APLICACION AND T.NIT &lt;= :TERCEROINICIAL) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="TERCEROINICIAL" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="gnacuerdo/tercerofinal/num">
		<call-query href="getGnacuerdoNumTercerofinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="TERCEROINICIAL" query-param="TERCEROINICIAL"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

</data>