<data name="vehiculopartes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVehiculopartesPartesFuncionalesPorPlacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VEHICULO_PARTES.COMPANIA, VEHICULO_PARTES.PLACA, VEHICULO_PARTES.PARTEFUNCIONAL, VEHICULO_PARTES.ESTADO, PARTEFUNCIONAL.NOMBRE, CASE WHEN VEHICULO_PARTES.ESTADO='B' THEN 'Bueno' ELSE CASE WHEN VEHICULO_PARTES.ESTADO='R' THEN 'Regular' ELSE 'Mal' END END NOMBRESTADO, VEHICULO_PARTES.CANTIDAD  FROM VEHICULO_PARTES INNER JOIN PARTEFUNCIONAL ON VEHICULO_PARTES.PARTEFUNCIONAL=PARTEFUNCIONAL.CODIGO WHERE COMPANIA =:COMPANIA AND PLACA =:PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PLACA":"$PLACA","PARTEFUNCIONAL":"$PARTEFUNCIONAL","ESTADO":"$ESTADO","NOMBRE":"$NOMBRE","NOMBRESTADO":"$NOMBRESTADO","CANTIDAD":"$CANTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vehiculopartes/partesfuncionalesporplaca">
		<call-query href="getVehiculopartesPartesFuncionalesPorPlacaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLACA" query-param="PLACA"/>

		</call-query>
	</resource>
	<query id="insertVehiculopartes" keyColumns="COMPANIA,PLACA,PARTEFUNCIONAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VEHICULO_PARTES (CANTIDAD, ESTADO, PLACA, COMPANIA, PARTEFUNCIONAL, DATE_CREATED, CREATED_BY) VALUES (:CANTIDAD, :ESTADO, :PLACA, :COMPANIA, :PARTEFUNCIONAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PLACA":"$PLACA","KEY_PARTEFUNCIONAL":"$PARTEFUNCIONAL"}]}}		</result>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PARTEFUNCIONAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vehiculopartes">
		<call-query href="insertVehiculopartes">
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PARTEFUNCIONAL" query-param="PARTEFUNCIONAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVehiculopartes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VEHICULO_PARTES WHERE VEHICULO_PARTES.COMPANIA= :KEY_COMPANIA AND VEHICULO_PARTES.PLACA= :KEY_PLACA AND VEHICULO_PARTES.PARTEFUNCIONAL= :KEY_PARTEFUNCIONAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>
		<param name="KEY_PARTEFUNCIONAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vehiculopartes">
		<call-query href="deleteVehiculopartes">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>
			<with-param name="KEY_PARTEFUNCIONAL" query-param="KEY_PARTEFUNCIONAL"/>

		</call-query>
	</resource>
	<query id="updateVehiculopartes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VEHICULO_PARTES SET CANTIDAD=:CANTIDAD, ESTADO=:ESTADO, PARTEFUNCIONAL=:PARTEFUNCIONAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VEHICULO_PARTES.COMPANIA= :KEY_COMPANIA AND VEHICULO_PARTES.PLACA= :KEY_PLACA AND VEHICULO_PARTES.PARTEFUNCIONAL= :KEY_PARTEFUNCIONAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PARTEFUNCIONAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>
		<param name="KEY_PARTEFUNCIONAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vehiculopartes">
		<call-query href="updateVehiculopartes">
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PARTEFUNCIONAL" query-param="PARTEFUNCIONAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>
			<with-param name="KEY_PARTEFUNCIONAL" query-param="KEY_PARTEFUNCIONAL"/>

		</call-query>
	</resource>

</data>