	<query id="getVacumuladosMediosMagConcepto5011rQuery"  useConfig="sysmandsunist">
		<sql>SELECT '5011' CPT, '31' TDOC, V_FONDO_DE_RIESGOS.NIT NID, PCK_SYSMAN_UTL.FC_DCH(V_FONDO_DE_RIESGOS.NIT) DV, '' APELLIDO1, '' APELLIDO2, '' NOMBRES, V_FONDO_DE_RIESGOS.NOMBRE_FONDO_RIESGOS RAZ, V_FONDO_DE_RIESGOS.DIRECCIONFR DIR, FONDO.DEPARTAMENTO DEPARTAMENTO, FONDO.CIUDAD CIUDAD, FONDO.PAIS PAIS, TO_CHAR(SUM(CASE WHEN V_ACUMULADOS.ID_DE_CONCEPTO IN( '111' ) THEN V_ACUMULADOS.VALOR ELSE 0 END),'999,999,999,999.00') PAGO, 0 PNDED, 0 IDEDF, 0 INDEDF, 0 RETPF, 0 RETAF, 0 COMUNF, 0 SIMPF, 0 NDOMF, 0 CREE_PRACTICADA, 0 CREE_ASUMIDA FROM V_ACUMULADOS INNER JOIN PERSONAL ON V_ACUMULADOS.COMPANIA = PERSONAL.COMPANIA AND V_ACUMULADOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN V_FONDO_DE_RIESGOS ON PERSONAL.COMPANIA = V_FONDO_DE_RIESGOS.COMPANIA AND PERSONAL.FONDO_RIESGOS = V_FONDO_DE_RIESGOS.FONDO_RIESGOS INNER JOIN CLASEFONDO ON CLASEFONDO.COMPANIA = V_FONDO_DE_RIESGOS.COMPANIA AND CLASEFONDO.ID = V_FONDO_DE_RIESGOS.FONDO_RIESGOS INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE V_ACUMULADOS.COMPANIA =:COMPANIA AND CONCAT( V_ACUMULADOS.ANO ,CONCAT( V_ACUMULADOS.MES , V_ACUMULADOS.PERIODO)) BETWEEN CONCAT(:ANO1 ,CONCAT(:MES1 ,:PERIODO1)) AND CONCAT(:ANO2 ,CONCAT(:MES2 ,:PERIODO2)) AND V_ACUMULADOS.ID_DE_CONCEPTO IN ('111') GROUP BY V_FONDO_DE_RIESGOS.NIT, V_FONDO_DE_RIESGOS.NOMBRE_FONDO_RIESGOS, V_FONDO_DE_RIESGOS.DIRECCIONFR, V_FONDO_DE_RIESGOS.TELEFONOFR, FONDO.DEPARTAMENTO, FONDO.CIUDAD, FONDO.PAIS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CPT":"$CPT","TDOC":"$TDOC","NID":"$NID","DV":"$DV(type:integer)","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRES":"$NOMBRES","RAZ":"$RAZ","DIR":"$DIR","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","PAIS":"$PAIS","PAGO":"$PAGO","PNDED":"$PNDED(type:double)","IDEDF":"$IDEDF(type:double)","INDEDF":"$INDEDF(type:double)","RETPF":"$RETPF(type:double)","RETAF":"$RETAF(type:double)","COMUNF":"$COMUNF(type:double)","SIMPF":"$SIMPF(type:double)","NDOMF":"$NDOMF(type:double)","CREE_PRACTICADA":"$CREE_PRACTICADA(type:double)","CREE_ASUMIDA":"$CREE_ASUMIDA(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO1" sqlType="STRING"/>
		<param name="MES1" sqlType="STRING"/>
		<param name="PERIODO1" sqlType="STRING"/>
		<param name="ANO2" sqlType="STRING"/>
		<param name="MES2" sqlType="STRING"/>
		<param name="PERIODO2" sqlType="STRING"/>

	</query>
