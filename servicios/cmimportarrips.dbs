<data name="cmimportarrips" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateCmimportarripsActualizarestadomensajesrips" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_IMPORTARRIPS SET MENSAJES =:MENSAJES, ESTADO =:ESTADO, DATE_MODIFIED = SYSDATE, MODIFIED_BY =:USUARIO WHERE CONSECUTIVO =:CONSECUTIVO AND COMPANIA =:COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MENSAJES" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmimportarrips/actualizarestadomensajesrips">
		<call-query href="updateCmimportarripsActualizarestadomensajesrips">
			<with-param name="MENSAJES" query-param="MENSAJES"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getCmimportarripsTraerestadomensajeQuery"  useConfig="sysmandsunist">
		<sql>SELECT CASE ESTADO WHEN 'P' THEN 'POR CARGAR' WHEN 'F' THEN 'FALLIDO' WHEN 'E' THEN 'EN PROCESO' WHEN 'C' THEN 'CARGADO' WHEN 'T' THEN 'FACTURADO' END ESTADO, MENSAJES FROM CM_IMPORTARRIPS WHERE CONSECUTIVO =:CONSECUTIVO AND COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO","MENSAJES":"$MENSAJES"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmimportarrips/traerestadomensaje">
		<call-query href="getCmimportarripsTraerestadomensajeQuery">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getCmimportarripsPagCuentasRadicadasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CM_IMPORTARRIPS.COMPANIA, CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, CM_IMPORTARRIPS.SUCURSAL, CM_ARCHIVO_TRANSACCIONES.NUM_IDENTIF_PRESTADOR COD_PREST_SERV_SALUD, PRESTADOR.NOMBRE1 NOMBRE_RAZON_SOCIAL,(TO_CHAR(CM_IMPORTARRIPS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SUM(NVL( VALOR_NETO_A_PAGAR_ENTI_CONTR, 0 )) VALOR_PAGAR, CM_IMPORTARRIPS.AUDITOR, TERCERO.NOMBRE NOMBRE_AUDITOR,(TO_CHAR(CM_IMPORTARRIPS.FECHA_AUDIT,'DD/MM/YYYY HH24:MI:SS')) FECHA_AUDIT,(TO_CHAR(CM_IMPORTARRIPS.FECHA_CONCILIAC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONCILIAC,(TO_CHAR(CM_IMPORTARRIPS.FECHA_FIN_AUDIT,'DD/MM/YYYY HH24:MI:SS')) FECHA_FIN_AUDIT FROM CM_IMPORTARRIPS INNER JOIN CM_ARCHIVO_TRANSACCIONES ON CM_IMPORTARRIPS.COMPANIA = CM_ARCHIVO_TRANSACCIONES.COMPANIA AND CM_IMPORTARRIPS.CONSECUTIVO = CM_ARCHIVO_TRANSACCIONES.CONSECUTIVO_RIPS INNER JOIN TERCERO PRESTADOR ON CM_ARCHIVO_TRANSACCIONES.COMPANIA = PRESTADOR.COMPANIA AND CM_ARCHIVO_TRANSACCIONES.NUM_IDENTIF_PRESTADOR = PRESTADOR.NIT LEFT JOIN CM_AUDITORES ON CM_IMPORTARRIPS.COMPANIA = CM_AUDITORES.COMPANIA AND CM_IMPORTARRIPS.AUDITOR = CM_AUDITORES.NIT LEFT JOIN TERCERO ON CM_AUDITORES.COMPANIA = TERCERO.COMPANIA AND CM_AUDITORES.NIT = TERCERO.NIT AND CM_AUDITORES.SUCURSAL = TERCERO.SUCURSAL WHERE CM_IMPORTARRIPS.COMPANIA = :COMPANIA AND INSTR( :ESTADO, CONCAT( CONCAT( ',', CM_IMPORTARRIPS.ESTADO ), ',' ) ) &gt; 0 GROUP BY CM_IMPORTARRIPS.COMPANIA, CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, CM_IMPORTARRIPS.SUCURSAL, CM_ARCHIVO_TRANSACCIONES.NUM_IDENTIF_PRESTADOR, PRESTADOR.NOMBRE1, CM_IMPORTARRIPS.FECHA, CM_IMPORTARRIPS.ESTADO, CM_IMPORTARRIPS.AUDITOR, TERCERO.NOMBRE, CM_IMPORTARRIPS.FECHA_AUDIT, CM_IMPORTARRIPS.FECHA_CONCILIAC, CM_IMPORTARRIPS.FECHA_FIN_AUDIT ORDER BY CM_IMPORTARRIPS.CONSECUTIVO DESC) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(CONCAT('%',:RADICADO), '%')) AND (CASE WHEN COD_PREST_SERV_SALUD IS NULL THEN ' ' ELSE UPPER(COD_PREST_SERV_SALUD) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_PREST_SERV_SALUD), '%')) AND (CASE WHEN NOMBRE_RAZON_SOCIAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_RAZON_SOCIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RAZON_SOCIAL), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR_PAGAR IS NULL THEN ' ' ELSE UPPER(VALOR_PAGAR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_PAGAR), '%')) AND (CASE WHEN NOMBRE_AUDITOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUDITOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUDITOR), '%')) AND (CASE WHEN FECHA_AUDIT IS NULL THEN ' ' ELSE UPPER(FECHA_AUDIT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_AUDIT), '%')) AND (CASE WHEN FECHA_CONCILIAC IS NULL THEN ' ' ELSE UPPER(FECHA_CONCILIAC) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_CONCILIAC), '%')) AND (CASE WHEN FECHA_FIN_AUDIT IS NULL THEN ' ' ELSE UPPER(FECHA_FIN_AUDIT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FIN_AUDIT), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","RADICADO":"$RADICADO","NIT":"$NIT","SUCURSAL":"$SUCURSAL","COD_PREST_SERV_SALUD":"$COD_PREST_SERV_SALUD","NOMBRE_RAZON_SOCIAL":"$NOMBRE_RAZON_SOCIAL","FECHA":"$FECHA","VALOR_PAGAR":"$VALOR_PAGAR","AUDITOR":"$AUDITOR","NOMBRE_AUDITOR":"$NOMBRE_AUDITOR","FECHA_AUDIT":"$FECHA_AUDIT","FECHA_CONCILIAC":"$FECHA_CONCILIAC","FECHA_FIN_AUDIT":"$FECHA_FIN_AUDIT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="COD_PREST_SERV_SALUD" sqlType="STRING"/>
		<param name="NOMBRE_RAZON_SOCIAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_PAGAR" sqlType="STRING"/>
		<param name="NOMBRE_AUDITOR" sqlType="STRING"/>
		<param name="FECHA_AUDIT" sqlType="STRING"/>
		<param name="FECHA_CONCILIAC" sqlType="STRING"/>
		<param name="FECHA_FIN_AUDIT" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cmimportarrips/cuentasradicadas/pag">
		<call-query href="getCmimportarripsPagCuentasRadicadasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
