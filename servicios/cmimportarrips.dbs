			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALOR_PAGAR" query-param="VALOR_PAGAR"/>
			<with-param name="NOMBRE_AUDITOR" query-param="NOMBRE_AUDITOR"/>
			<with-param name="FECHA_AUDIT" query-param="FECHA_AUDIT"/>
			<with-param name="FECHA_CONCILIAC" query-param="FECHA_CONCILIAC"/>
			<with-param name="FECHA_FIN_AUDIT" query-param="FECHA_FIN_AUDIT"/>

		</call-query>
	</resource>
	<query id="updateCmimportarripsUpdateauditor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_IMPORTARRIPS SET AUDITOR=:AUDITOR, FECHA_AUDIT=TO_DATE(:FECHA_AUDIT,'DD/MM/YYYY HH24:MI:SS'), FECHA_CONCILIAC=TO_DATE(:FECHA_CONCILIAC,'DD/MM/YYYY HH24:MI:SS'), FECHA_FIN_AUDIT=TO_DATE(:FECHA_FIN_AUDIT,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CM_IMPORTARRIPS.COMPANIA= :KEY_COMPANIA AND CM_IMPORTARRIPS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="AUDITOR" sqlType="STRING"/>
		<param name="FECHA_AUDIT" sqlType="STRING"/>
		<param name="FECHA_CONCILIAC" sqlType="STRING"/>
		<param name="FECHA_FIN_AUDIT" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmimportarrips/updateauditor">
		<call-query href="updateCmimportarripsUpdateauditor">
			<with-param name="AUDITOR" query-param="AUDITOR"/>
			<with-param name="FECHA_AUDIT" query-param="FECHA_AUDIT"/>
			<with-param name="FECHA_CONCILIAC" query-param="FECHA_CONCILIAC"/>
			<with-param name="FECHA_FIN_AUDIT" query-param="FECHA_FIN_AUDIT"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getCmimportarripsPagRadicadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, TERCERO.NOMBRE, TO_CHAR(CM_IMPORTARRIPS.FECHA, 'DD/MM/YYYY') FECHA FROM CM_IMPORTARRIPS INNER JOIN TERCERO ON CM_IMPORTARRIPS.COMPANIA = TERCERO.COMPANIA AND CM_IMPORTARRIPS.NIT = TERCERO.NIT WHERE CM_IMPORTARRIPS.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(:RADICADO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","RADICADO":"$RADICADO","NIT":"$NIT","NOMBRE":"$NOMBRE","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cmimportarrips/radicados/pag">
		<call-query href="getCmimportarripsPagRadicadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="RADICADO" query-param="RADICADO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCmimportarripsNumRadicadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, TERCERO.NOMBRE, TO_CHAR(CM_IMPORTARRIPS.FECHA, 'DD/MM/YYYY') FECHA FROM CM_IMPORTARRIPS INNER JOIN TERCERO ON CM_IMPORTARRIPS.COMPANIA = TERCERO.COMPANIA AND CM_IMPORTARRIPS.NIT = TERCERO.NIT WHERE CM_IMPORTARRIPS.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(:RADICADO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmimportarrips/radicados/num">
		<call-query href="getCmimportarripsNumRadicadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="RADICADO" query-param="RADICADO"/>
			<with-param name="NIT" query-param="NIT"/>
