	</resource>
	<query id="insertCmimportarrips" keyColumns="COMPANIA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CM_IMPORTARRIPS (CONSECUTIVO, COMPANIA, FECHA, RADICADO, NIT, SUCURSAL, ESTADO, ESTADOCUENTA, CLASECUENTA, DESCRIPCION, AUDITOR, RIPS_JSON, NRO_CONTRATO, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:CONSECUTIVO, :COMPANIA, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :RADICADO, :NIT, :SUCURSAL, :ESTADO, :ESTADOCUENTA, :CLASECUENTA, :DESCRIPCION, :AUDITOR, :RIPS_JSON, :NRO_CONTRATO, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="ESTADOCUENTA" sqlType="STRING"/>
		<param defaultValue="" name="CLASECUENTA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="AUDITOR" sqlType="STRING"/>
		<param defaultValue="0" name="RIPS_JSON" sqlType="STRING"/>
		<param defaultValue="" name="NRO_CONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
