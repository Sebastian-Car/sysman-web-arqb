	<query id="getCmimportarripsPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONSECUTIVO, COMPANIA, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA, RADICADO, NIT, SUCURSAL, ARCHIVO, CASE ESTADO WHEN 'P' THEN 'POR CARGAR' WHEN 'E' THEN 'EN PROCESO' WHEN 'F' THEN 'FALLIDO' WHEN 'C' THEN 'CARGADO' WHEN 'T' THEN 'CAUSADO' END ESTADO, MENSAJES, CASE WHEN ESTADO IN ('P','F') THEN 'true' ELSE 'false' END ACCION, AUDITOR FROM CM_IMPORTARRIPS ORDER BY CONSECUTIVO DESC) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(:RADICADO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN AUDITOR IS NULL THEN ' ' ELSE UPPER(AUDITOR) END) LIKE UPPER(CONCAT(:AUDITOR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","COMPANIA":"$COMPANIA","FECHA":"$FECHA","RADICADO":"$RADICADO","NIT":"$NIT","SUCURSAL":"$SUCURSAL","ARCHIVO":"$ARCHIVO","ESTADO":"$ESTADO","MENSAJES":"$MENSAJES","ACCION":"$ACCION","AUDITOR":"$AUDITOR"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="AUDITOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cmimportarrips">
		<call-query href="getCmimportarripsPaginaQuery">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="RADICADO" query-param="RADICADO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="AUDITOR" query-param="AUDITOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCmimportarripsNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONSECUTIVO, COMPANIA, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA, RADICADO, NIT, SUCURSAL, ARCHIVO, CASE ESTADO WHEN 'P' THEN 'POR CARGAR' WHEN 'E' THEN 'EN PROCESO' WHEN 'F' THEN 'FALLIDO' WHEN 'C' THEN 'CARGADO' WHEN 'T' THEN 'CAUSADO' END ESTADO, MENSAJES, CASE WHEN ESTADO IN ('P','F') THEN 'true' ELSE 'false' END ACCION, AUDITOR FROM CM_IMPORTARRIPS ORDER BY CONSECUTIVO DESC) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(:RADICADO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN AUDITOR IS NULL THEN ' ' ELSE UPPER(AUDITOR) END) LIKE UPPER(CONCAT(:AUDITOR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="AUDITOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmimportarrips/numero">
		<call-query href="getCmimportarripsNumeroQuery">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="RADICADO" query-param="RADICADO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="AUDITOR" query-param="AUDITOR"/>

		</call-query>
	</resource>
	<query id="getCmimportarripsRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.COMPANIA, TO_CHAR( CM_IMPORTARRIPS.FECHA, 'DD/MM/YYYY HH24:MI:SS' ) FECHA, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, TERCERO.NOMBRE, CM_IMPORTARRIPS.SUCURSAL, CM_IMPORTARRIPS.ARCHIVO, CM_IMPORTARRIPS.MENSAJES, CM_IMPORTARRIPS.ESTADO, CASE CM_IMPORTARRIPS.ESTADO WHEN 'P' THEN 'POR CARGAR' WHEN 'F' THEN 'FALLIDO' WHEN 'E' THEN 'EN PROCESO' WHEN 'C' THEN 'CARGADO' WHEN 'T' THEN 'CAUSADO' END NOMBRE_ESTADO, CM_IMPORTARRIPS.ESTADOCUENTA, CM_ESTADOCUENTA.NOMBRE NOMBRE_ESTADOCUENTA, CM_IMPORTARRIPS.CLASECUENTA, CM_CLASECUENTA.NOMBRE NOMBRE_CLASECUENTA, CM_IMPORTARRIPS.DESCRIPCION, CM_IMPORTARRIPS.AUDITOR,(CASE CM_IMPORTARRIPS.RIPS_JSON WHEN 0 THEN 'false' ELSE 'true' END) RIPS_JSON, CM_IMPORTARRIPS.NRO_CONTRATO, CM_IMPORTARRIPS.OBSERVACIONES FROM CM_IMPORTARRIPS INNER JOIN TERCERO ON CM_IMPORTARRIPS.COMPANIA = TERCERO.COMPANIA AND CM_IMPORTARRIPS.NIT = TERCERO.NIT LEFT JOIN CM_ESTADOCUENTA ON CM_IMPORTARRIPS.COMPANIA = CM_ESTADOCUENTA.COMPANIA AND CM_IMPORTARRIPS.ESTADOCUENTA = CM_ESTADOCUENTA.CODIGO LEFT JOIN CM_CLASECUENTA ON CM_IMPORTARRIPS.COMPANIA = CM_CLASECUENTA.COMPANIA AND CM_IMPORTARRIPS.CLASECUENTA = CM_CLASECUENTA.CODIGO WHERE CM_IMPORTARRIPS.COMPANIA= :KEY_COMPANIA AND CM_IMPORTARRIPS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","COMPANIA":"$COMPANIA","FECHA":"$FECHA","RADICADO":"$RADICADO","NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","ARCHIVO":"$ARCHIVO","MENSAJES":"$MENSAJES","ESTADO":"$ESTADO","NOMBRE_ESTADO":"$NOMBRE_ESTADO","ESTADOCUENTA":"$ESTADOCUENTA","NOMBRE_ESTADOCUENTA":"$NOMBRE_ESTADOCUENTA","CLASECUENTA":"$CLASECUENTA","NOMBRE_CLASECUENTA":"$NOMBRE_CLASECUENTA","DESCRIPCION":"$DESCRIPCION","AUDITOR":"$AUDITOR","RIPS_JSON":"$RIPS_JSON(type:boolean)","NRO_CONTRATO":"$NRO_CONTRATO","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmimportarrips/data">
		<call-query href="getCmimportarripsRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateCmimportarrips" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_IMPORTARRIPS SET CONSECUTIVO=:CONSECUTIVO, COMPANIA=:COMPANIA, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), RADICADO=:RADICADO, NIT=:NIT, SUCURSAL=:SUCURSAL, ARCHIVO=:ARCHIVO, MENSAJES=:MENSAJES, ESTADO=:ESTADO, ESTADOCUENTA=:ESTADOCUENTA, CLASECUENTA=:CLASECUENTA, DESCRIPCION=:DESCRIPCION, AUDITOR=:AUDITOR, RIPS_JSON=:RIPS_JSON, NRO_CONTRATO=:NRO_CONTRATO, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CM_IMPORTARRIPS.COMPANIA= :KEY_COMPANIA AND CM_IMPORTARRIPS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
