			<with-param name="FECHA_AUDIT" query-param="FECHA_AUDIT"/>
			<with-param name="FECHA_CONCILIAC" query-param="FECHA_CONCILIAC"/>
			<with-param name="FECHA_FIN_AUDIT" query-param="FECHA_FIN_AUDIT"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCmimportarripsNumCuentasRadicadasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CM_IMPORTARRIPS.COMPANIA, CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, CM_IMPORTARRIPS.SUCURSAL, CM_ARCHIVO_TRANSACCIONES.NUM_IDENTIF_PRESTADOR COD_PREST_SERV_SALUD, PRESTADOR.NOMBRE1 NOMBRE_RAZON_SOCIAL,(TO_CHAR(CM_IMPORTARRIPS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SUM(NVL( VALOR_NETO_A_PAGAR_ENTI_CONTR, 0 )) VALOR_PAGAR, CM_IMPORTARRIPS.AUDITOR, TERCERO.NOMBRE NOMBRE_AUDITOR,(TO_CHAR(CM_IMPORTARRIPS.FECHA_AUDIT,'DD/MM/YYYY HH24:MI:SS')) FECHA_AUDIT,(TO_CHAR(CM_IMPORTARRIPS.FECHA_CONCILIAC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONCILIAC,(TO_CHAR(CM_IMPORTARRIPS.FECHA_FIN_AUDIT,'DD/MM/YYYY HH24:MI:SS')) FECHA_FIN_AUDIT FROM CM_IMPORTARRIPS INNER JOIN CM_ARCHIVO_TRANSACCIONES ON CM_IMPORTARRIPS.COMPANIA = CM_ARCHIVO_TRANSACCIONES.COMPANIA AND CM_IMPORTARRIPS.CONSECUTIVO = CM_ARCHIVO_TRANSACCIONES.CONSECUTIVO_RIPS INNER JOIN TERCERO PRESTADOR ON CM_ARCHIVO_TRANSACCIONES.COMPANIA = PRESTADOR.COMPANIA AND CM_ARCHIVO_TRANSACCIONES.NUM_IDENTIF_PRESTADOR = PRESTADOR.NIT LEFT JOIN CM_AUDITORES ON CM_IMPORTARRIPS.COMPANIA = CM_AUDITORES.COMPANIA AND CM_IMPORTARRIPS.AUDITOR = CM_AUDITORES.NIT LEFT JOIN TERCERO ON CM_AUDITORES.COMPANIA = TERCERO.COMPANIA AND CM_AUDITORES.NIT = TERCERO.NIT AND CM_AUDITORES.SUCURSAL = TERCERO.SUCURSAL WHERE CM_IMPORTARRIPS.COMPANIA = :COMPANIA AND INSTR( :ESTADO, CONCAT( CONCAT( ',', CM_IMPORTARRIPS.ESTADO ), ',' ) ) &gt; 0 GROUP BY CM_IMPORTARRIPS.COMPANIA, CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, CM_IMPORTARRIPS.SUCURSAL, CM_ARCHIVO_TRANSACCIONES.NUM_IDENTIF_PRESTADOR, PRESTADOR.NOMBRE1, CM_IMPORTARRIPS.FECHA, CM_IMPORTARRIPS.ESTADO, CM_IMPORTARRIPS.AUDITOR, TERCERO.NOMBRE, CM_IMPORTARRIPS.FECHA_AUDIT, CM_IMPORTARRIPS.FECHA_CONCILIAC, CM_IMPORTARRIPS.FECHA_FIN_AUDIT ORDER BY CM_IMPORTARRIPS.CONSECUTIVO DESC) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(CONCAT('%',:RADICADO), '%')) AND (CASE WHEN COD_PREST_SERV_SALUD IS NULL THEN ' ' ELSE UPPER(COD_PREST_SERV_SALUD) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_PREST_SERV_SALUD), '%')) AND (CASE WHEN NOMBRE_RAZON_SOCIAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_RAZON_SOCIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RAZON_SOCIAL), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR_PAGAR IS NULL THEN ' ' ELSE UPPER(VALOR_PAGAR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_PAGAR), '%')) AND (CASE WHEN NOMBRE_AUDITOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUDITOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUDITOR), '%')) AND (CASE WHEN FECHA_AUDIT IS NULL THEN ' ' ELSE UPPER(FECHA_AUDIT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_AUDIT), '%')) AND (CASE WHEN FECHA_CONCILIAC IS NULL THEN ' ' ELSE UPPER(FECHA_CONCILIAC) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_CONCILIAC), '%')) AND (CASE WHEN FECHA_FIN_AUDIT IS NULL THEN ' ' ELSE UPPER(FECHA_FIN_AUDIT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FIN_AUDIT), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="COD_PREST_SERV_SALUD" sqlType="STRING"/>
		<param name="NOMBRE_RAZON_SOCIAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_PAGAR" sqlType="STRING"/>
		<param name="NOMBRE_AUDITOR" sqlType="STRING"/>
		<param name="FECHA_AUDIT" sqlType="STRING"/>
		<param name="FECHA_CONCILIAC" sqlType="STRING"/>
		<param name="FECHA_FIN_AUDIT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmimportarrips/cuentasradicadas/num">
		<call-query href="getCmimportarripsNumCuentasRadicadasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="RADICADO" query-param="RADICADO"/>
			<with-param name="COD_PREST_SERV_SALUD" query-param="COD_PREST_SERV_SALUD"/>
