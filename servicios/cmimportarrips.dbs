	</resource>
	<query id="getCmimportarripsPagRadicadoscondevolucionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CM_IMPORTARRIPS.CONSECUTIVO, CM_IMPORTARRIPS.RADICADO, CM_IMPORTARRIPS.NIT, TERCERO.NOMBRE, TO_CHAR(CM_IMPORTARRIPS.FECHA, 'DD/MM/YYYY') AS FECHA FROM CM_IMPORTARRIPS INNER JOIN TERCERO ON CM_IMPORTARRIPS.COMPANIA = TERCERO.COMPANIA AND CM_IMPORTARRIPS.NIT = TERCERO.NIT WHERE CM_IMPORTARRIPS.COMPANIA = :COMPANIA AND EXISTS ( SELECT 1 FROM CM_AUDITORIA_GLOSAS WHERE CM_AUDITORIA_GLOSAS.COMPANIA = CM_IMPORTARRIPS.COMPANIA AND CM_AUDITORIA_GLOSAS.CONSECUTIVO_ARCHIVO = CM_IMPORTARRIPS.CONSECUTIVO AND CM_AUDITORIA_GLOSAS.DEVOLUCION_FACTURA &lt;&gt; 0 )) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(:RADICADO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","RADICADO":"$RADICADO","NIT":"$NIT","NOMBRE":"$NOMBRE","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
