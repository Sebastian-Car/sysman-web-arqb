	<query id="deleteCmimportarrips" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CM_IMPORTARRIPS WHERE CM_IMPORTARRIPS.COMPANIA= :KEY_COMPANIA AND CM_IMPORTARRIPS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
