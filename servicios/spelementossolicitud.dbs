<data name="spelementossolicitud" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpelementossolicitudCodNomCantPorCompClaseNumQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_ELEMENTOSSOLICITUD.COMPANIA, SP_ELEMENTOSSOLICITUD.CLASESOLICITUD, SP_ELEMENTOSSOLICITUD.SOLICITUD, SP_ELEMENTOSSOLICITUD.CODIGO , SP_ELEMENTOS.DESCRIPCION, SP_ELEMENTOSSOLICITUD.CANTIDAD , SP_ELEMENTOSSOLICITUD.VALORUNITARIO , SP_ELEMENTOSSOLICITUD.PORCIVA , (SP_ELEMENTOSSOLICITUD.CANTIDAD*SP_ELEMENTOSSOLICITUD.VALORUNITARIO)+((SP_ELEMENTOSSOLICITUD.CANTIDAD*SP_ELEMENTOSSOLICITUD.VALORUNITARIO)*(NVL(SP_ELEMENTOSSOLICITUD.PORCIVA,0)/100)) TEXTOTOTAL, SP_ELEMENTOSSOLICITUD.CREATED_BY , SP_ELEMENTOSSOLICITUD.MODIFIED_BY ,(TO_CHAR(SP_ELEMENTOSSOLICITUD.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(SP_ELEMENTOSSOLICITUD.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_ELEMENTOSSOLICITUD INNER JOIN SP_ELEMENTOS ON SP_ELEMENTOSSOLICITUD.COMPANIA = SP_ELEMENTOS.COMPANIA AND SP_ELEMENTOSSOLICITUD.CODIGO = SP_ELEMENTOS.CODIGO WHERE SP_ELEMENTOSSOLICITUD.COMPANIA = :COMPANIA AND SP_ELEMENTOSSOLICITUD.CLASESOLICITUD=:CLASESOLICITUD AND SP_ELEMENTOSSOLICITUD.SOLICITUD =:NUMEROSOLICITUD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASESOLICITUD":"$CLASESOLICITUD","SOLICITUD":"$SOLICITUD(type:long)","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","CANTIDAD":"$CANTIDAD","VALORUNITARIO":"$VALORUNITARIO","PORCIVA":"$PORCIVA","TEXTOTOTAL":"$TEXTOTOTAL(type:integer)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASESOLICITUD" sqlType="STRING"/>
		<param name="NUMEROSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spelementossolicitud/codnomcantporcompclasenum">
		<call-query href="getSpelementossolicitudCodNomCantPorCompClaseNumQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASESOLICITUD" query-param="CLASESOLICITUD"/>
			<with-param name="NUMEROSOLICITUD" query-param="NUMEROSOLICITUD"/>

		</call-query>
	</resource>
	<query id="deleteSpelementossolicitudCodNomCantPorCompClaseNum" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_ELEMENTOSSOLICITUD WHERE SP_ELEMENTOSSOLICITUD.COMPANIA    = :KEY_COMPANIA AND SP_ELEMENTOSSOLICITUD.CLASESOLICITUD=:KEY_CLASESOLICITUD AND SP_ELEMENTOSSOLICITUD.SOLICITUD     =:KEY_SOLICITUD AND SP_ELEMENTOSSOLICITUD.CODIGO        =:KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASESOLICITUD" sqlType="STRING"/>
		<param name="KEY_SOLICITUD" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spelementossolicitud/codnomcantporcompclasenum">
		<call-query href="deleteSpelementossolicitudCodNomCantPorCompClaseNum">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASESOLICITUD" query-param="KEY_CLASESOLICITUD"/>
			<with-param name="KEY_SOLICITUD" query-param="KEY_SOLICITUD"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateSpelementossolicitudCodNomCantPorCompClaseNum" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_ELEMENTOSSOLICITUD SET CODIGO=:CODIGO, CANTIDAD=:CANTIDAD, PORCIVA=:PORCIVA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_ELEMENTOSSOLICITUD.COMPANIA= :KEY_COMPANIA AND SP_ELEMENTOSSOLICITUD.CLASESOLICITUD= :KEY_CLASESOLICITUD AND SP_ELEMENTOSSOLICITUD.SOLICITUD= :KEY_SOLICITUD AND SP_ELEMENTOSSOLICITUD.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASESOLICITUD" sqlType="STRING"/>
		<param name="KEY_SOLICITUD" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spelementossolicitud/codnomcantporcompclasenum">
		<call-query href="updateSpelementossolicitudCodNomCantPorCompClaseNum">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASESOLICITUD" query-param="KEY_CLASESOLICITUD"/>
			<with-param name="KEY_SOLICITUD" query-param="KEY_SOLICITUD"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="insertSpelementossolicitudCodNomCantPorCompClaseNu" keyColumns="COMPANIA,CLASESOLICITUD,SOLICITUD,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_ELEMENTOSSOLICITUD (COMPANIA, CLASESOLICITUD, SOLICITUD, CODIGO, CANTIDAD, VALORUNITARIO, PORCIVA, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CLASESOLICITUD, :SOLICITUD, :CODIGO, :CANTIDAD, :VALORUNITARIO, :PORCIVA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASESOLICITUD":"$CLASESOLICITUD","KEY_SOLICITUD":"$SOLICITUD(type:long)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASESOLICITUD" sqlType="STRING"/>
		<param name="SOLICITUD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spelementossolicitud/codnomcantporcompclasenu">
		<call-query href="insertSpelementossolicitudCodNomCantPorCompClaseNu">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASESOLICITUD" query-param="CLASESOLICITUD"/>
			<with-param name="SOLICITUD" query-param="SOLICITUD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="getSpelementossolicitudCodVlrPorClaseNumQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, VALORUNITARIO  FROM SP_ELEMENTOSSOLICITUD WHERE COMPANIA =:COMPANIA AND CLASESOLICITUD=:CLASESOLICITUD AND SOLICITUD =:NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","VALORUNITARIO":"$VALORUNITARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASESOLICITUD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spelementossolicitud/codvlrporclasenum">
		<call-query href="getSpelementossolicitudCodVlrPorClaseNumQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASESOLICITUD" query-param="CLASESOLICITUD"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>

</data>