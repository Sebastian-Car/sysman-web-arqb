<data name="requisitosteventos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertRequisitosteventos" keyColumns="COMPANIA,TIPO_EVENTO,REQUISITO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO REQUISITOS_TEVENTO (COMPANIA, TIPO_EVENTO, REQUISITO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO_EVENTO, :REQUISITO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO_EVENTO":"$TIPO_EVENTO(type:integer)","KEY_REQUISITO":"$REQUISITO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_EVENTO" sqlType="STRING"/>
		<param name="REQUISITO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="requisitosteventos">
		<call-query href="insertRequisitosteventos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_EVENTO" query-param="TIPO_EVENTO"/>
			<with-param name="REQUISITO" query-param="REQUISITO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteRequisitosteventos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM REQUISITOS_TEVENTO WHERE REQUISITOS_TEVENTO.COMPANIA= :KEY_COMPANIA AND REQUISITOS_TEVENTO.TIPO_EVENTO= :KEY_TIPO_EVENTO AND REQUISITOS_TEVENTO.REQUISITO= :KEY_REQUISITO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_EVENTO" sqlType="INTEGER"/>
		<param name="KEY_REQUISITO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="requisitosteventos">
		<call-query href="deleteRequisitosteventos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO_EVENTO" query-param="KEY_TIPO_EVENTO"/>
			<with-param name="KEY_REQUISITO" query-param="KEY_REQUISITO"/>

		</call-query>
	</resource>
	<query id="getRequisitosteventosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  REQUISITOS_TEVENTO.COMPANIA, REQUISITOS_TEVENTO.TIPO_EVENTO, TIPO_EVENTO.NOMBRE NOMBRE_EVENTO, REQUISITOS_TEVENTO.REQUISITO, REQUISITOS_PRESTAMO.NOMBRE  FROM REQUISITOS_TEVENTO INNER JOIN REQUISITOS_PRESTAMO ON REQUISITOS_TEVENTO.COMPANIA = REQUISITOS_PRESTAMO.COMPANIA AND REQUISITOS_TEVENTO.REQUISITO = REQUISITOS_PRESTAMO.CODIGO INNER JOIN TIPO_EVENTO ON REQUISITOS_TEVENTO.COMPANIA = TIPO_EVENTO.COMPANIA AND REQUISITOS_TEVENTO.TIPO_EVENTO = TIPO_EVENTO.CODIGO WHERE REQUISITOS_TEVENTO.COMPANIA = :COMPANIA AND REQUISITOS_TEVENTO.TIPO_EVENTO = :TIPOEVENTO ORDER BY REQUISITOS_TEVENTO.COMPANIA, TIPO_EVENTO.NOMBRE, REQUISITOS_TEVENTO.REQUISITO) WHERE (CASE WHEN NOMBRE_EVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_EVENTO) END)  LIKE UPPER( '%' || :NOMBRE_EVENTO || '%')  AND (CASE WHEN REQUISITO IS NULL THEN ' ' ELSE UPPER(REQUISITO) END)  LIKE UPPER( '%' || :REQUISITO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_EVENTO":"$TIPO_EVENTO(type:integer)","NOMBRE_EVENTO":"$NOMBRE_EVENTO","REQUISITO":"$REQUISITO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NOMBRE_EVENTO" sqlType="STRING"/>
		<param name="REQUISITO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="requisitosteventos">
		<call-query href="getRequisitosteventosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NOMBRE_EVENTO" query-param="NOMBRE_EVENTO"/>
			<with-param name="REQUISITO" query-param="REQUISITO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRequisitosteventosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  REQUISITOS_TEVENTO.COMPANIA, REQUISITOS_TEVENTO.TIPO_EVENTO, TIPO_EVENTO.NOMBRE NOMBRE_EVENTO, REQUISITOS_TEVENTO.REQUISITO, REQUISITOS_PRESTAMO.NOMBRE  FROM REQUISITOS_TEVENTO INNER JOIN REQUISITOS_PRESTAMO ON REQUISITOS_TEVENTO.COMPANIA = REQUISITOS_PRESTAMO.COMPANIA AND REQUISITOS_TEVENTO.REQUISITO = REQUISITOS_PRESTAMO.CODIGO INNER JOIN TIPO_EVENTO ON REQUISITOS_TEVENTO.COMPANIA = TIPO_EVENTO.COMPANIA AND REQUISITOS_TEVENTO.TIPO_EVENTO = TIPO_EVENTO.CODIGO WHERE REQUISITOS_TEVENTO.COMPANIA = :COMPANIA AND REQUISITOS_TEVENTO.TIPO_EVENTO = :TIPOEVENTO ORDER BY REQUISITOS_TEVENTO.COMPANIA, TIPO_EVENTO.NOMBRE, REQUISITOS_TEVENTO.REQUISITO) WHERE (CASE WHEN NOMBRE_EVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_EVENTO) END)  LIKE UPPER( '%' || :NOMBRE_EVENTO || '%')  AND (CASE WHEN REQUISITO IS NULL THEN ' ' ELSE UPPER(REQUISITO) END)  LIKE UPPER( '%' || :REQUISITO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NOMBRE_EVENTO" sqlType="STRING"/>
		<param name="REQUISITO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="requisitosteventos/numero">
		<call-query href="getRequisitosteventosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NOMBRE_EVENTO" query-param="NOMBRE_EVENTO"/>
			<with-param name="REQUISITO" query-param="REQUISITO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateRequisitosteventos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE REQUISITOS_TEVENTO SET TIPO_EVENTO=:TIPO_EVENTO, REQUISITO=:REQUISITO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE REQUISITOS_TEVENTO.COMPANIA= :KEY_COMPANIA AND REQUISITOS_TEVENTO.TIPO_EVENTO= :KEY_TIPO_EVENTO AND REQUISITOS_TEVENTO.REQUISITO= :KEY_REQUISITO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO_EVENTO" sqlType="STRING"/>
		<param name="REQUISITO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_EVENTO" sqlType="STRING"/>
		<param name="KEY_REQUISITO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="requisitosteventos">
		<call-query href="updateRequisitosteventos">
			<with-param name="TIPO_EVENTO" query-param="TIPO_EVENTO"/>
			<with-param name="REQUISITO" query-param="REQUISITO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO_EVENTO" query-param="KEY_TIPO_EVENTO"/>
			<with-param name="KEY_REQUISITO" query-param="KEY_REQUISITO"/>

		</call-query>
	</resource>

</data>