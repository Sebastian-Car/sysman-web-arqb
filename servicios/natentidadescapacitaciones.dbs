	<query id="updateNatentidadescapacitaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_ENTIDADESCAPACITACION SET NITESTABLECIMIENTO=:NITESTABLECIMIENTO, SUCURSAL=:SUCURSAL, TIPO=:TIPO, NOMBREESTABLECIMIENTO=:NOMBREESTABLECIMIENTO, DIRECCIONESTABLECIMIENTO=:DIRECCIONESTABLECIMIENTO, TELEFONOESTABLECIMIENTO=:TELEFONOESTABLECIMIENTO, PERSONACONTACTO=:PERSONACONTACTO, DIRECCIONCONTACTO=:DIRECCIONCONTACTO, TELEFONOCONTACTO=:TELEFONOCONTACTO, SUCURSALCONTACTO=:SUCURSALCONTACTO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_ENTIDADESCAPACITACION.COMPANIA= :KEY_COMPANIA AND NAT_ENTIDADESCAPACITACION.NITESTABLECIMIENTO= :KEY_NITESTABLECIMIENTO AND NAT_ENTIDADESCAPACITACION.SUCURSAL= :KEY_SUCURSAL</sql>
