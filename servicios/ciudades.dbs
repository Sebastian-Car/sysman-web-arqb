<data name="ciudades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCiudadesPorDepartamentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO ,NOMBRE  FROM CIUDAD WHERE PAIS = :PAIS AND DEPARTAMENTO = :DEPARTAMENTO ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/pordepartamento">
		<call-query href="getCiudadesPorDepartamentoQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="getCiudadesPorPaisDepartamentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CIUDAD.CODIGO, CIUDAD.NOMBRE, CIUDAD.PAIS, CIUDAD.DEPARTAMENTO  FROM CIUDAD WHERE CIUDAD.PAIS = :PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO ORDER BY CIUDAD.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/porpaisdepartamento">
		<call-query href="getCiudadesPorPaisDepartamentoQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="getCiudadesTodosPorNombreCodigoCiudadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT CIUDAD.CODIGO, CIUDAD.NOMBRE  FROM CIUDAD WHERE CIUDAD.PAIS=:PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO ORDER BY CIUDAD.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/todospornombrecodigociudad">
		<call-query href="getCiudadesTodosPorNombreCodigoCiudadQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="getCiudadesPorNombreDependiendoCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CIU.NOMBRE  FROM CIUDAD CIU INNER JOIN COMPANIA COM ON CIU.PAIS = COM.PAIS AND CIU.DEPARTAMENTO = COM.DEPARTAMENTO AND CIU.CODIGO = COM.CIUDAD WHERE COM.CODIGO = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/pornombredependiendocompania">
		<call-query href="getCiudadesPorNombreDependiendoCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getCiudadesPorPaisDepYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CIUDAD.CODIGO, CIUDAD.NOMBRE  FROM CIUDAD WHERE CIUDAD.PAIS = :PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO AND CIUDAD.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/porpaisdepycodigo">
		<call-query href="getCiudadesPorPaisDepYCodigoQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getCiudadesCodNomDepPorDepPaisQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CIUDAD.CODIGO, CIUDAD.NOMBRE, CIUDAD.DEPARTAMENTO  FROM CIUDAD WHERE CIUDAD.DEPARTAMENTO =:DEPARTAMENTO AND CIUDAD.PAIS =:PAIS ORDER BY CIUDAD.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DEPARTAMENTO":"$DEPARTAMENTO"}]}}		</result>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/codnomdeppordeppais">
		<call-query href="getCiudadesCodNomDepPorDepPaisQuery">
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="getCiudadesPagTodosPorPaisdepQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CIUDAD.CODIGO, CIUDAD.NOMBRE  FROM CIUDAD WHERE CIUDAD.DEPARTAMENTO = :DEPARTAMENTO AND CIUDAD.PAIS = :PAIS ORDER BY CIUDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ciudades/todosporpaisdep/pag">
		<call-query href="getCiudadesPagTodosPorPaisdepQuery">
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCiudadesNumTodosPorPaisdepQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CIUDAD.CODIGO, CIUDAD.NOMBRE  FROM CIUDAD WHERE CIUDAD.DEPARTAMENTO = :DEPARTAMENTO AND CIUDAD.PAIS = :PAIS ORDER BY CIUDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/todosporpaisdep/num">
		<call-query href="getCiudadesNumTodosPorPaisdepQuery">
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCiudadesNombreCiudadOrigenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CIUDAD.CODIGO, CIUDAD.NOMBRE CIUDADORIGENNOMBRE  FROM CIUDAD WHERE CIUDAD.PAIS = :PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO ORDER BY CIUDAD.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CIUDADORIGENNOMBRE":"$CIUDADORIGENNOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/nombreciudadorigen">
		<call-query href="getCiudadesNombreCiudadOrigenQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="insertCiudades" keyColumns="PAIS,DEPARTAMENTO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CIUDAD (PAIS, DEPARTAMENTO, CODIGO, NOMBRE, DATE_CREATED, CREATED_BY) VALUES (:PAIS, :DEPARTAMENTO, :CODIGO, :NOMBRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_PAIS":"$PAIS","KEY_DEPARTAMENTO":"$DEPARTAMENTO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ciudades">
		<call-query href="insertCiudades">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteCiudades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CIUDAD WHERE CIUDAD.PAIS= :KEY_PAIS AND CIUDAD.DEPARTAMENTO= :KEY_DEPARTAMENTO AND CIUDAD.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_DEPARTAMENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ciudades">
		<call-query href="deleteCiudades">
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_DEPARTAMENTO" query-param="KEY_DEPARTAMENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getCiudadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CIUDAD.CODIGO, CIUDAD.DEPARTAMENTO,CIUDAD.PAIS, CIUDAD.NOMBRE  FROM CIUDAD WHERE PAIS=:PAIS AND DEPARTAMENTO=:DEPARTAMENTO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DEPARTAMENTO":"$DEPARTAMENTO","PAIS":"$PAIS","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ciudades">
		<call-query href="getCiudadesPaginaQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCiudadesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CIUDAD.CODIGO, CIUDAD.DEPARTAMENTO,CIUDAD.PAIS, CIUDAD.NOMBRE  FROM CIUDAD WHERE PAIS=:PAIS AND DEPARTAMENTO=:DEPARTAMENTO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/numero">
		<call-query href="getCiudadesNumeroQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateCiudades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CIUDAD SET PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CIUDAD.PAIS= :KEY_PAIS AND CIUDAD.DEPARTAMENTO= :KEY_DEPARTAMENTO AND CIUDAD.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_DEPARTAMENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ciudades">
		<call-query href="updateCiudades">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_DEPARTAMENTO" query-param="KEY_DEPARTAMENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getCiudadesNombreCiudadDestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CIUDAD.CODIGO, CIUDAD.NOMBRE CIUDADDESTINONOMBRE  FROM CIUDAD WHERE CIUDAD.PAIS = :PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO ORDER BY CIUDAD.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CIUDADDESTINONOMBRE":"$CIUDADDESTINONOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/nombreciudaddestino">
		<call-query href="getCiudadesNombreCiudadDestinoQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="getCiudadesMunicpiobasicQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO ,NOMBRE NMBREMUNICIPIO  FROM CIUDAD WHERE PAIS = :PAIS AND DEPARTAMENTO = :DEPARTAMENTO ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NMBREMUNICIPIO":"$NMBREMUNICIPIO"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/municpiobasic">
		<call-query href="getCiudadesMunicpiobasicQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="getCiudadesPagNombreCiudadesMundoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  C.CODIGO, C.NOMBRE, D.CODIGO CODIGOD, D.NOMBRE DEPARTAMENTO, P.PAIS CODIGOP, P.NOMBRE PAIS  FROM CIUDAD C INNER JOIN DEPARTAMENTO D ON C.DEPARTAMENTO = D.CODIGO AND C.PAIS = D.PAIS INNER JOIN PAISES P ON D.PAIS = P.PAIS ORDER BY P.NOMBRE , D.NOMBRE, C.NOMBRE) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(DEPARTAMENTO) END)  LIKE UPPER( '%' || :DEPARTAMENTO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGOD":"$CODIGOD","DEPARTAMENTO":"$DEPARTAMENTO","CODIGOP":"$CODIGOP","PAIS":"$PAIS"}]}}		</result>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ciudades/nombreciudadesmundo/pag">
		<call-query href="getCiudadesPagNombreCiudadesMundoQuery">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCiudadesNumNombreCiudadesMundoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  C.CODIGO, C.NOMBRE, D.CODIGO CODIGOD, D.NOMBRE DEPARTAMENTO, P.PAIS CODIGOP, P.NOMBRE PAIS  FROM CIUDAD C INNER JOIN DEPARTAMENTO D ON C.DEPARTAMENTO = D.CODIGO AND C.PAIS = D.PAIS INNER JOIN PAISES P ON D.PAIS = P.PAIS ORDER BY P.NOMBRE , D.NOMBRE, C.NOMBRE) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(DEPARTAMENTO) END)  LIKE UPPER( '%' || :DEPARTAMENTO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/nombreciudadesmundo/num">
		<call-query href="getCiudadesNumNombreCiudadesMundoQuery">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="getCiudadesConCodigoDepartamentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(CIUDAD.DEPARTAMENTO,CIUDAD.CODIGO) CODIGO, CIUDAD.NOMBRE, CIUDAD.PAIS, CIUDAD.DEPARTAMENTO FROM CIUDAD WHERE CIUDAD.PAIS = :PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO ORDER BY CIUDAD.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciudades/concodigodepartamento">
		<call-query href="getCiudadesConCodigoDepartamentoQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="getCiudadesTodaslasciudadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(CONCAT(CODIGO, ' '), NOMBRE) AS CODIGO, NOMBRE FROM CIUDAD ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="ciudades/todaslasciudades">
		<call-query href="getCiudadesTodaslasciudadesQuery">
 
		</call-query>
	</resource>

</data>