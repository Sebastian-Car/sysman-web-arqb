<data name="evtipodeevaluacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEvtipodeevaluacionPagTodosPorCompaniaYClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE,(CASE SEMESTRAL WHEN 0 THEN 'false' ELSE 'true' END) SEMESTRAL FROM EV_TIPO_DE_EVALUACION WHERE COMPANIA = :COMPANIA AND CLASE_EVALUACION = :CLASE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SEMESTRAL":"$SEMESTRAL(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evtipodeevaluacion/todosporcompaniayclase/pag">
		<call-query href="getEvtipodeevaluacionPagTodosPorCompaniaYClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvtipodeevaluacionNumTodosPorCompaniaYClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE,(CASE SEMESTRAL WHEN 0 THEN 'false' ELSE 'true' END) SEMESTRAL FROM EV_TIPO_DE_EVALUACION WHERE COMPANIA = :COMPANIA AND CLASE_EVALUACION = :CLASE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evtipodeevaluacion/todosporcompaniayclase/num">
		<call-query href="getEvtipodeevaluacionNumTodosPorCompaniaYClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertEvtipodeevaluacion" keyColumns="COMPANIA,CODIGO,CLASE_EVALUACION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_TIPO_DE_EVALUACION (COMPANIA, CLASE_EVALUACION, CODIGO, NOMBRE, SEMESTRAL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CLASE_EVALUACION, :CODIGO, :NOMBRE, :SEMESTRAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="SEMESTRAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evtipodeevaluacion">
		<call-query href="insertEvtipodeevaluacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SEMESTRAL" query-param="SEMESTRAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteEvtipodeevaluacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_TIPO_DE_EVALUACION WHERE EV_TIPO_DE_EVALUACION.COMPANIA= :KEY_COMPANIA AND EV_TIPO_DE_EVALUACION.CODIGO= :KEY_CODIGO AND EV_TIPO_DE_EVALUACION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="evtipodeevaluacion">
		<call-query href="deleteEvtipodeevaluacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>

		</call-query>
	</resource>
	<query id="getEvtipodeevaluacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CLASE_EVALUACION, CODIGO, NOMBRE,(CASE SEMESTRAL WHEN 0 THEN 'false' ELSE 'true' END) SEMESTRAL FROM EV_TIPO_DE_EVALUACION WHERE COMPANIA = :COMPANIA AND CLASE_EVALUACION = :CLASEEVALUACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SEMESTRAL IS NULL THEN ' ' ELSE UPPER(SEMESTRAL) END)  LIKE UPPER(:SEMESTRAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SEMESTRAL":"$SEMESTRAL(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SEMESTRAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evtipodeevaluacion">
		<call-query href="getEvtipodeevaluacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SEMESTRAL" query-param="SEMESTRAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvtipodeevaluacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CLASE_EVALUACION, CODIGO, NOMBRE,(CASE SEMESTRAL WHEN 0 THEN 'false' ELSE 'true' END) SEMESTRAL FROM EV_TIPO_DE_EVALUACION WHERE COMPANIA = :COMPANIA AND CLASE_EVALUACION = :CLASEEVALUACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SEMESTRAL IS NULL THEN ' ' ELSE UPPER(SEMESTRAL) END)  LIKE UPPER(:SEMESTRAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SEMESTRAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evtipodeevaluacion/numero">
		<call-query href="getEvtipodeevaluacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SEMESTRAL" query-param="SEMESTRAL"/>

		</call-query>
	</resource>
	<query id="updateEvtipodeevaluacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_TIPO_DE_EVALUACION SET COMPANIA=:COMPANIA, CLASE_EVALUACION=:CLASE_EVALUACION, CODIGO=:CODIGO, NOMBRE=:NOMBRE, SEMESTRAL=:SEMESTRAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE EV_TIPO_DE_EVALUACION.COMPANIA= :KEY_COMPANIA AND EV_TIPO_DE_EVALUACION.CODIGO= :KEY_CODIGO AND EV_TIPO_DE_EVALUACION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SEMESTRAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evtipodeevaluacion">
		<call-query href="updateEvtipodeevaluacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SEMESTRAL" query-param="SEMESTRAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>

		</call-query>
	</resource>

</data>