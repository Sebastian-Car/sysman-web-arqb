<data name="urlservicio" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getUrlservicioAutenticaciondirectorioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  URL, TIPO_DIRECTORIO  FROM URLSERVICIO WHERE COMPANIA = :COMPANIA AND CODIGO= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"URL":"$URL","TIPO_DIRECTORIO":"$TIPO_DIRECTORIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="urlservicio/autenticaciondirectorio">
		<call-query href="getUrlservicioAutenticaciondirectorioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getUrlservicioPagWorkflowservicioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, ETIQUETA  FROM URLSERVICIO WHERE USA_WORKFLOW NOT IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","ETIQUETA":"$ETIQUETA"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="urlservicio/workflowservicio/pag">
		<call-query href="getUrlservicioPagWorkflowservicioQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getUrlservicioNumWorkflowservicioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, ETIQUETA  FROM URLSERVICIO WHERE USA_WORKFLOW NOT IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="urlservicio/workflowservicio/num">
		<call-query href="getUrlservicioNumWorkflowservicioQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>

		</call-query>
	</resource>
	<query id="getUrlservicioPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,CODIGO, URL  FROM URLSERVICIO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN URL IS NULL THEN ' ' ELSE UPPER(URL) END)  LIKE UPPER( '%' || :URL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO(type:integer)","URL":"$URL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="URL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="urlservicio">
		<call-query href="getUrlservicioPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="URL" query-param="URL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getUrlservicioNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA,CODIGO, URL  FROM URLSERVICIO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN URL IS NULL THEN ' ' ELSE UPPER(URL) END)  LIKE UPPER( '%' || :URL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="URL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="urlservicio/numero">
		<call-query href="getUrlservicioNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="URL" query-param="URL"/>

		</call-query>
	</resource>
	<query id="updateUrlservicio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE URLSERVICIO SET URL=:URL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE URLSERVICIO.COMPANIA= :KEY_COMPANIA AND URLSERVICIO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="URL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="urlservicio">
		<call-query href="updateUrlservicio">
			<with-param name="URL" query-param="URL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>