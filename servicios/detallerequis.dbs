	<query id="deleteDetallerequis" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DETALLEREQUIS WHERE DETALLEREQUIS.COD_REQUISICION= :KEY_COD_REQUISICION AND DETALLEREQUIS.COMPANIA= :KEY_COMPANIA AND DETALLEREQUIS.COD_DETALLE= :KEY_COD_DETALLE</sql>
