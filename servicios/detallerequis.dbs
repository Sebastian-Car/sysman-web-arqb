<data name="detallerequis" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDetallerequisCentralizacionRequisiciones" keyColumns="COD_REQUISICION,COMPANIA,COD_DETALLE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLEREQUIS (COMPANIA, COD_REQUISICION, COD_DETALLE, CODIGOELEMENTO, ESPECIFICACION, CANTIDAD, SALDODETALLE, VALORUNITARIO, VALORTOTAL, ORDENDESUMINISTRO, DEPENDENCIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_REQUISICION, :COD_DETALLE, :CODIGOELEMENTO, :ESPECIFICACION, :CANTIDAD, :SALDODETALLE, :VALORUNITARIO, :VALORTOTAL, :ORDENDESUMINISTRO, :DEPENDENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COD_REQUISICION":"$COD_REQUISICION(type:long)","KEY_COMPANIA":"$COMPANIA","KEY_COD_DETALLE":"$COD_DETALLE(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="COD_DETALLE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param defaultValue="" name="ESPECIFICACION" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="SALDODETALLE" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="ORDENDESUMINISTRO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detallerequis/centralizacionrequisiciones">
		<call-query href="insertDetallerequisCentralizacionRequisiciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="COD_DETALLE" query-param="COD_DETALLE"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="SALDODETALLE" query-param="SALDODETALLE"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="ORDENDESUMINISTRO" query-param="ORDENDESUMINISTRO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getDetallerequisListaSubdetalleQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DETALLEREQUIS.COD_DETALLE, DETALLEREQUIS.CODIGOELEMENTO, DETALLEREQUIS.ESPECIFICACION, DETALLEREQUIS.CANTIDAD, DETALLEREQUIS.VALORUNITARIO, DETALLEREQUIS.VALORTOTAL, DETALLEREQUIS.COD_PROPUESTA, INVENTARIO.NOMBRELARGO, DETALLEREQUIS.DEPENDENCIA SUBDEPENDENCIA, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA  FROM DETALLEREQUIS LEFT JOIN INVENTARIO ON DETALLEREQUIS.COMPANIA = INVENTARIO.COMPANIA AND DETALLEREQUIS.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEPENDENCIA ON DETALLEREQUIS.COMPANIA = DEPENDENCIA.COMPANIA AND DETALLEREQUIS.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE DETALLEREQUIS.COMPANIA =:COMPANIA AND DETALLEREQUIS.COD_REQUISICION= :REQUISICION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_DETALLE":"$COD_DETALLE(type:long)","CODIGOELEMENTO":"$CODIGOELEMENTO","ESPECIFICACION":"$ESPECIFICACION","CANTIDAD":"$CANTIDAD","VALORUNITARIO":"$VALORUNITARIO","VALORTOTAL":"$VALORTOTAL","COD_PROPUESTA":"$COD_PROPUESTA(type:long)","NOMBRELARGO":"$NOMBRELARGO","SUBDEPENDENCIA":"$SUBDEPENDENCIA","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="REQUISICION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallerequis/listasubdetalle">
		<call-query href="getDetallerequisListaSubdetalleQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="REQUISICION" query-param="REQUISICION"/>

		</call-query>
	</resource>
	<query id="insertDetallerequisComprasContratacion" keyColumns="COD_REQUISICION,COMPANIA,COD_DETALLE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLEREQUIS (COD_REQUISICION, COMPANIA, COD_DETALLE, CODIGOELEMENTO, ESPECIFICACION, CANTIDAD, VALORUNITARIO, VALORTOTAL, COD_PROPUESTA, SALDODETALLE, PORCDESCUENTO, PORCIVA, DEPENDENCIA, CREATED_BY, DATE_CREATED) VALUES (:COD_REQUISICION, :COMPANIA, :COD_DETALLE, :CODIGOELEMENTO, :ESPECIFICACION, :CANTIDAD, :VALORUNITARIO, :VALORTOTAL, :COD_PROPUESTA, :SALDODETALLE, :PORCDESCUENTO, :PORCIVA, :DEPENDENCIA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COD_REQUISICION":"$COD_REQUISICION(type:long)","KEY_COMPANIA":"$COMPANIA","KEY_COD_DETALLE":"$COD_DETALLE(type:long)"}]}}		</result>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_DETALLE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param defaultValue="" name="ESPECIFICACION" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="COD_PROPUESTA" sqlType="STRING"/>
		<param defaultValue="0" name="SALDODETALLE" sqlType="STRING"/>
		<param defaultValue="0" name="PORCDESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVA" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detallerequis/comprascontratacion">
		<call-query href="insertDetallerequisComprasContratacion">
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_DETALLE" query-param="COD_DETALLE"/>
