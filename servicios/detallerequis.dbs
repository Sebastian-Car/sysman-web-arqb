 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>
		<param name="KEY_COD_DETALLE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="detallerequis/comprascontratacion">
		<call-query href="deleteDetallerequisComprasContratacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_REQUISICION" query-param="KEY_COD_REQUISICION"/>
			<with-param name="KEY_COD_DETALLE" query-param="KEY_COD_DETALLE"/>

		</call-query>
	</resource>
	<query id="insertDetallerequis" keyColumns="COD_REQUISICION,COMPANIA,COD_DETALLE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLEREQUIS (COD_REQUISICION, COMPANIA, COD_DETALLE, CODIGOELEMENTO, ESPECIFICACION, CANTIDAD, VALORUNITARIO, VALORTOTAL, COD_PROPUESTA, SALDODETALLE, PORCDESCUENTO, PORCIVA, DEPENDENCIA, DATE_CREATED, CREATED_BY) VALUES (:COD_REQUISICION, :COMPANIA, :COD_DETALLE, :CODIGOELEMENTO, :ESPECIFICACION, :CANTIDAD, :VALORUNITARIO, :VALORTOTAL, :COD_PROPUESTA, :SALDODETALLE, :PORCDESCUENTO, :PORCIVA, :DEPENDENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COD_REQUISICION":"$COD_REQUISICION(type:long)","KEY_COMPANIA":"$COMPANIA","KEY_COD_DETALLE":"$COD_DETALLE(type:long)"}]}}		</result>
