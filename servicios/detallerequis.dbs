		</call-query>
	</resource>
	<query id="updateDetallerequisComprasContratacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLEREQUIS SET CODIGOELEMENTO=:CODIGOELEMENTO, ESPECIFICACION=:ESPECIFICACION, CANTIDAD=:CANTIDAD, VALORUNITARIO=:VALORUNITARIO, VALORTOTAL=:VALORTOTAL, COD_PROPUESTA=:COD_PROPUESTA, DEPENDENCIA=:DEPENDENCIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLEREQUIS.COD_REQUISICION= :KEY_COD_REQUISICION AND DETALLEREQUIS.COMPANIA= :KEY_COMPANIA AND DETALLEREQUIS.COD_DETALLE= :KEY_COD_DETALLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="COD_PROPUESTA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_DETALLE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallerequis/comprascontratacion">
		<call-query href="updateDetallerequisComprasContratacion">
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="COD_PROPUESTA" query-param="COD_PROPUESTA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COD_REQUISICION" query-param="KEY_COD_REQUISICION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_DETALLE" query-param="KEY_COD_DETALLE"/>

		</call-query>
	</resource>
	<query id="deleteDetallerequisComprasContratacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DETALLEREQUIS WHERE COMPANIA      = :KEY_COMPANIA AND COD_REQUISICION = :KEY_COD_REQUISICION AND COD_DETALLE     = :KEY_COD_DETALLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
