<data name="esprobabilidadvaloracion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsprobabilidadvaloracionPagCodigonombreprobabilidadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO PROBABILIDAD , CATEGORIA NOMBRE_PROBABILIDAD  FROM ES_PROBABILIDAD_VALORACION WHERE TIPO_OPCION IN (4)) WHERE (CASE WHEN PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(PROBABILIDAD) END)  LIKE UPPER(:PROBABILIDAD || '%')  AND (CASE WHEN NOMBRE_PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROBABILIDAD) END)  LIKE UPPER( '%' || :NOMBRE_PROBABILIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PROBABILIDAD":"$PROBABILIDAD","NOMBRE_PROBABILIDAD":"$NOMBRE_PROBABILIDAD"}]}}		</result>
		<param name="PROBABILIDAD" sqlType="STRING"/>
		<param name="NOMBRE_PROBABILIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esprobabilidadvaloracion/codigonombreprobabilidades/pag">
		<call-query href="getEsprobabilidadvaloracionPagCodigonombreprobabilidadesQuery">
			<with-param name="PROBABILIDAD" query-param="PROBABILIDAD"/>
			<with-param name="NOMBRE_PROBABILIDAD" query-param="NOMBRE_PROBABILIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsprobabilidadvaloracionNumCodigonombreprobabilidadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO PROBABILIDAD , CATEGORIA NOMBRE_PROBABILIDAD  FROM ES_PROBABILIDAD_VALORACION WHERE TIPO_OPCION IN (4)) WHERE (CASE WHEN PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(PROBABILIDAD) END)  LIKE UPPER(:PROBABILIDAD || '%')  AND (CASE WHEN NOMBRE_PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROBABILIDAD) END)  LIKE UPPER( '%' || :NOMBRE_PROBABILIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="PROBABILIDAD" sqlType="STRING"/>
		<param name="NOMBRE_PROBABILIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esprobabilidadvaloracion/codigonombreprobabilidades/num">
		<call-query href="getEsprobabilidadvaloracionNumCodigonombreprobabilidadesQuery">
			<with-param name="PROBABILIDAD" query-param="PROBABILIDAD"/>
			<with-param name="NOMBRE_PROBABILIDAD" query-param="NOMBRE_PROBABILIDAD"/>

		</call-query>
	</resource>
	<query id="getEsprobabilidadvaloracionCategoriaporvaloracionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CATEGORIA  FROM ES_PROBABILIDAD_VALORACION WHERE VALORACION = :VALORACION AND TIPO_OPCION IN (6) AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CATEGORIA":"$CATEGORIA"}]}}		</result>
		<param name="VALORACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esprobabilidadvaloracion/categoriaporvaloracion">
		<call-query href="getEsprobabilidadvaloracionCategoriaporvaloracionQuery">
			<with-param name="VALORACION" query-param="VALORACION"/>

		</call-query>
	</resource>
	<query id="insertEsprobabilidadvaloracion" keyColumns="COMPANIA,CODIGO,TIPO_OPCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_PROBABILIDAD_VALORACION (COMPANIA, CODIGO, CATEGORIA, DESCRIPCION, VALORACION, TIPO_OPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :CATEGORIA, :DESCRIPCION, :VALORACION, :TIPO_OPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_TIPO_OPCION":"$TIPO_OPCION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORACION" sqlType="STRING"/>
		<param name="TIPO_OPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esprobabilidadvaloracion">
		<call-query href="insertEsprobabilidadvaloracion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORACION" query-param="VALORACION"/>
			<with-param name="TIPO_OPCION" query-param="TIPO_OPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsprobabilidadvaloracion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_PROBABILIDAD_VALORACION WHERE ES_PROBABILIDAD_VALORACION.COMPANIA= :KEY_COMPANIA AND ES_PROBABILIDAD_VALORACION.CODIGO= :KEY_CODIGO AND ES_PROBABILIDAD_VALORACION.TIPO_OPCION= :KEY_TIPO_OPCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPO_OPCION" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="esprobabilidadvaloracion">
		<call-query href="deleteEsprobabilidadvaloracion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPO_OPCION" query-param="KEY_TIPO_OPCION"/>

		</call-query>
	</resource>
	<query id="getEsprobabilidadvaloracionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, CATEGORIA, DESCRIPCION, VALORACION, TIPO_OPCION  FROM ES_PROBABILIDAD_VALORACION WHERE COMPANIA = :COMPANIA AND TIPO_OPCION = :TIPO_OPCION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CATEGORIA IS NULL THEN ' ' ELSE UPPER(CATEGORIA) END)  LIKE UPPER( '%' || :CATEGORIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALORACION IS NULL THEN ' ' ELSE UPPER(VALORACION) END)  LIKE UPPER(:VALORACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CATEGORIA":"$CATEGORIA","DESCRIPCION":"$DESCRIPCION","VALORACION":"$VALORACION(type:integer)","TIPO_OPCION":"$TIPO_OPCION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_OPCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esprobabilidadvaloracion">
		<call-query href="getEsprobabilidadvaloracionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_OPCION" query-param="TIPO_OPCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORACION" query-param="VALORACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsprobabilidadvaloracionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, CATEGORIA, DESCRIPCION, VALORACION, TIPO_OPCION  FROM ES_PROBABILIDAD_VALORACION WHERE COMPANIA = :COMPANIA AND TIPO_OPCION = :TIPO_OPCION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CATEGORIA IS NULL THEN ' ' ELSE UPPER(CATEGORIA) END)  LIKE UPPER( '%' || :CATEGORIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALORACION IS NULL THEN ' ' ELSE UPPER(VALORACION) END)  LIKE UPPER(:VALORACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_OPCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esprobabilidadvaloracion/numero">
		<call-query href="getEsprobabilidadvaloracionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_OPCION" query-param="TIPO_OPCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORACION" query-param="VALORACION"/>

		</call-query>
	</resource>
	<query id="updateEsprobabilidadvaloracion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_PROBABILIDAD_VALORACION SET CATEGORIA=:CATEGORIA, DESCRIPCION=:DESCRIPCION, VALORACION=:VALORACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_PROBABILIDAD_VALORACION.COMPANIA= :KEY_COMPANIA AND ES_PROBABILIDAD_VALORACION.CODIGO= :KEY_CODIGO AND ES_PROBABILIDAD_VALORACION.TIPO_OPCION= :KEY_TIPO_OPCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPO_OPCION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esprobabilidadvaloracion">
		<call-query href="updateEsprobabilidadvaloracion">
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORACION" query-param="VALORACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPO_OPCION" query-param="KEY_TIPO_OPCION"/>

		</call-query>
	</resource>

</data>