<data name="ipigacresolucionesdet" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpigacresolucionesdetDetallesCambiosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_IGAC_RESOLUCIONESDET.CONSECUTIVO, IP_IGAC_RESOLUCIONESDET.RADICACION, IP_IGAC_RESOLUCIONESDET.MUTACION, IP_IGAC_RESOLUCIONESDET.CODIGO, IP_IGAC_RESOLUCIONESDET.CANCELAINSCRIBE, IP_IGAC_RESOLUCIONESDET.TIPOREGISTRO, IP_IGAC_RESOLUCIONESDET.NUMEROORDEN, IP_IGAC_RESOLUCIONESDET.TOTALREGISTROS, IP_IGAC_RESOLUCIONESDET.CODIGO_PADRE, IP_IGAC_RESOLUCIONESDET.NOMBRE, IP_IGAC_RESOLUCIONESDET.ANTNOMBRE, IP_IGAC_RESOLUCIONESDET.TIPODOCUMENTO, IP_IGAC_RESOLUCIONESDET.ESTADOCIVIL, IP_IGAC_RESOLUCIONESDET.ANTTIPODOCUMENTO, IP_IGAC_RESOLUCIONESDET.NUMERODOCUMENTO, IP_IGAC_RESOLUCIONESDET.ANTNUMERODOCUMENTO, IP_IGAC_RESOLUCIONESDET.DIRECCION, IP_IGAC_RESOLUCIONESDET.ANTDIRECCION, IP_IGAC_RESOLUCIONESDET.DESTINOECONOMICO, IP_IGAC_RESOLUCIONESDET.ANTDESTINOECONOMICO, IP_IGAC_RESOLUCIONESDET.AREATERRENO, IP_IGAC_RESOLUCIONESDET.ANTAREATERRENO, IP_IGAC_RESOLUCIONESDET.AREACONSTRUIDA, IP_IGAC_RESOLUCIONESDET.ANTCONSTRUIDA, IP_IGAC_RESOLUCIONESDET.AVALUO, IP_IGAC_RESOLUCIONESDET.ANTAVALUO, IP_IGAC_RESOLUCIONESDET.VIGENCIA, IP_IGAC_RESOLUCIONESDET.ANTVIGENCIA, IP_IGAC_RESOLUCIONESDET.CONDICIONTRIS, IP_IGAC_RESOLUCIONESDET.ANTCONDICION, IP_IGAC_RESOLUCIONESDET.AREAHECTARES, IP_IGAC_RESOLUCIONESDET.ANTAREAHECTARES, IP_IGAC_RESOLUCIONESDET.TARIFA, IP_IGAC_RESOLUCIONESDET.ANTTARIFA, IP_IGAC_RESOLUCIONESDET.UBICACION, IP_IGAC_RESOLUCIONESDET.UBICACIONANT, IP_IGAC_RESOLUCIONESDET.ANTRESOLUCION, IP_IGAC_RESOLUCIONESDET.USUARIOCREADOR, IP_IGAC_RESOLUCIONESDET.OBSERVACION  FROM IP_IGAC_RESOLUCIONESDET WHERE IP_IGAC_RESOLUCIONESDET.COMPANIA = :COMPANIA AND IP_IGAC_RESOLUCIONESDET.PAIS = :PAIS AND IP_IGAC_RESOLUCIONESDET.DEPARTAMENTO = :DEPARTAMENTO AND IP_IGAC_RESOLUCIONESDET.MUNICIPIO = :CIUDAD AND IP_IGAC_RESOLUCIONESDET.ANO = :ANO AND IP_IGAC_RESOLUCIONESDET.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:long)","RADICACION":"$RADICACION","MUTACION":"$MUTACION","CODIGO":"$CODIGO","CANCELAINSCRIBE":"$CANCELAINSCRIBE","TIPOREGISTRO":"$TIPOREGISTRO","NUMEROORDEN":"$NUMEROORDEN","TOTALREGISTROS":"$TOTALREGISTROS","CODIGO_PADRE":"$CODIGO_PADRE","NOMBRE":"$NOMBRE","ANTNOMBRE":"$ANTNOMBRE","TIPODOCUMENTO":"$TIPODOCUMENTO","ESTADOCIVIL":"$ESTADOCIVIL","ANTTIPODOCUMENTO":"$ANTTIPODOCUMENTO","NUMERODOCUMENTO":"$NUMERODOCUMENTO","ANTNUMERODOCUMENTO":"$ANTNUMERODOCUMENTO","DIRECCION":"$DIRECCION","ANTDIRECCION":"$ANTDIRECCION","DESTINOECONOMICO":"$DESTINOECONOMICO","ANTDESTINOECONOMICO":"$ANTDESTINOECONOMICO","AREATERRENO":"$AREATERRENO","ANTAREATERRENO":"$ANTAREATERRENO","AREACONSTRUIDA":"$AREACONSTRUIDA","ANTCONSTRUIDA":"$ANTCONSTRUIDA","AVALUO":"$AVALUO","ANTAVALUO":"$ANTAVALUO","VIGENCIA":"$VIGENCIA(type:integer)","ANTVIGENCIA":"$ANTVIGENCIA","CONDICIONTRIS":"$CONDICIONTRIS","ANTCONDICION":"$ANTCONDICION","AREAHECTARES":"$AREAHECTARES","ANTAREAHECTARES":"$ANTAREAHECTARES","TARIFA":"$TARIFA","ANTTARIFA":"$ANTTARIFA","UBICACION":"$UBICACION","UBICACIONANT":"$UBICACIONANT","ANTRESOLUCION":"$ANTRESOLUCION","USUARIOCREADOR":"$USUARIOCREADOR","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
