	<query id="deleteIpigacresolucionesdet" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_IGAC_RESOLUCIONESDET WHERE IP_IGAC_RESOLUCIONESDET.COMPANIA= :KEY_COMPANIA AND IP_IGAC_RESOLUCIONESDET.PAIS= :KEY_PAIS AND IP_IGAC_RESOLUCIONESDET.DEPARTAMENTO= :KEY_DEPARTAMENTO AND IP_IGAC_RESOLUCIONESDET.MUNICIPIO= :KEY_MUNICIPIO AND IP_IGAC_RESOLUCIONESDET.RESOLUCION= :KEY_RESOLUCION AND IP_IGAC_RESOLUCIONESDET.CONSECUTIVO= :KEY_CONSECUTIVO AND IP_IGAC_RESOLUCIONESDET.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_DEPARTAMENTO" sqlType="STRING"/>
		<param name="KEY_MUNICIPIO" sqlType="STRING"/>
		<param name="KEY_RESOLUCION" sqlType="STRING"/>
