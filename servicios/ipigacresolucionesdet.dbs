	<query id="getIpigacresolucionesdetTodosPorElNumeroDePredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMEROORDEN NUMERO  FROM IP_IGAC_RESOLUCIONESDET WHERE COMPANIA =:COMPANIA AND CODIGO =:CODIGO AND NUMEROORDEN =:NUMERO_ORDEN AND RESOLUCION =:RESOLUCION AND CONSECUTIVO!=:CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="RESOLUCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipigacresolucionesdet/todosporelnumerodepredio">
		<call-query href="getIpigacresolucionesdetTodosPorElNumeroDePredioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getIpigacresolucionesdetTodosPorElNumeroDePredioConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LPAD(MAX(TO_NUMBER(NUMEROORDEN)+1),3,'0') NUMERO  FROM IP_IGAC_RESOLUCIONESDET WHERE COMPANIA=:COMPANIA AND CODIGO =:CODIGO AND RESOLUCION=:RESOLUCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="RESOLUCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipigacresolucionesdet/todosporelnumerodepredioconsecutivo">
		<call-query href="getIpigacresolucionesdetTodosPorElNumeroDePredioConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>

