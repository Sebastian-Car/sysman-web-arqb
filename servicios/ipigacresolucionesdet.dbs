	<query id="insertIpigacresolucionesdetCopiarRegistro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_IGAC_RESOLUCIONESDET  (ANO, ANO_CONSTRUCCION, ANTANO_CONSTRUCCION, ANTAREAHECTARES, ANTAREATERRENO,  ANTAVALUO, ANTCONDICION, ANTCONSTRUIDA, ANTDESTINOECONOMICO, ANTDIRECCION, ANTNOMBRE,  ANTNUMERODOCUMENTO, ANTOBSERVACION, ANTRESOLUCION, ANTTARIFA, ANTTIPODOCUMENTO,  ANTULTIMO_ANIO, ANTVIGENCIA, AREACONSTRUIDA, AREAHECTARES, AREATERENOM2, AREATERRENO,  AVALUO, CANCELAINSCRIBE, CODIGO, CODIGO_PADRE, COMPANIA, COMUNA, COMUNA_ANT, CONDICIONTRIS, CONSECUTIVO, CREATED_BY, DATE_CREATED, DATE_MODIFIED ,DEPARTAMENTO, DESTINOECONOMICO, DIRECCION, ESPACIO,  ESPACIO_ANT, ESTADOCIVIL, FECHAINGRESOSISTEMA,MODIFIED_BY, MODIFICA_AVALUOS, MUNICIPIO, MUTACION,  NOMBRE, NUMERODOCUMENTO, NUMEROORDEN, NUMERO_PREDIAL_NUEVO, OBSERVACION, OBS_REGISTRO,  PAIS, RADICACION, REGISTRADO, RESOLUCION, TARIFA, TEMPORAL, TIPODOCUMENTO, TIPOREGISTRO,  TIPO_TRAMITE, TIPO_TRAMITE_ANT, TOTALREGISTROS, TRPRAN, UBICACION, UBICACIONANT,  ULTIMO_ANIO, ULTIMO_PAGO, USUARIOCREADOR, VIGENCIA) VALUES  (:ANO, :ANO_CONSTRUCCION, :ANTANO_CONSTRUCCION, :ANTAREAHECTARES, :ANTAREATERRENO, :ANTAVALUO, :ANTCONDICION, :ANTCONSTRUIDA, :ANTDESTINOECONOMICO, :ANTDIRECCION,  :ANTNOMBRE, :ANTNUMERODOCUMENTO, :ANTOBSERVACION, :ANTRESOLUCION, :ANTTARIFA,  :ANTTIPODOCUMENTO, :ANTULTIMO_ANIO, :ANTVIGENCIA, :AREACONSTRUIDA, :AREAHECTARES,   :AREATERENOM2, :AREATERRENO, :AVALUO, :CANCELAINSCRIBE, :CODIGO, :CODIGO_PADRE,   :COMPANIA, :COMUNA, :COMUNA_ANT, :CONDICIONTRIS, :CONSECUTIVO,   :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),  :DEPARTAMENTO,:DESTINOECONOMICO, :DIRECCION, :ESPACIO, :ESPACIO_ANT, :ESTADOCIVIL,   TO_DATE(:FECHAINGRESOSISTEMA,'DD/MM/YYYY HH24:MI:SS'),:MODIFIED_BY, :MODIFICA_AVALUOS,   :MUNICIPIO, :MUTACION, :NOMBRE, :NUMERODOCUMENTO, :NUMEROORDEN, :NUMERO_PREDIAL_NUEVO,   :OBSERVACION, :OBS_REGISTRO, :PAIS, :RADICACION, :REGISTRADO, :RESOLUCION, :TARIFA,   :TEMPORAL, :TIPODOCUMENTO, :TIPOREGISTRO, :TIPO_TRAMITE, :TIPO_TRAMITE_ANT, :TOTALREGISTROS,   :TRPRAN, :UBICACION, :UBICACIONANT, :ULTIMO_ANIO, :ULTIMO_PAGO, :USUARIOCREADOR, :VIGENCIA)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

