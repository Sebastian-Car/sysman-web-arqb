P_IGAC_RESOLUCIONESDET.RESOLUCION= :KEY_RESOLUCION AND IP_IGAC_RESOLUCIONESDET.CONSECUTIVO= :KEY_CONSECUTIVO AND IP_IGAC_RESOLUCIONESDET.ANO= :KEY_ANO</sql>
