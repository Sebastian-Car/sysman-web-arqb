	<query id="insertIpigacresolucionesdet" keyColumns="COMPANIA,PAIS,DEPARTAMENTO,MUNICIPIO,RESOLUCION,CONSECUTIVO,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_IGAC_RESOLUCIONESDET (COMPANIA, PAIS, DEPARTAMENTO, MUNICIPIO, RESOLUCION, CONSECUTIVO, ANO, RADICACION, MUTACION, CODIGO, NUMEROORDEN, CANCELAINSCRIBE, TIPOREGISTRO, TOTALREGISTROS, NOMBRE, ESTADOCIVIL, TIPODOCUMENTO, NUMERODOCUMENTO, DIRECCION, DESTINOECONOMICO, AREATERRENO, AREACONSTRUIDA, AVALUO, VIGENCIA, CONDICIONTRIS, ANTTIPODOCUMENTO, ANTNUMERODOCUMENTO, ANTDESTINOECONOMICO, ANTAREATERRENO, ANTCONSTRUIDA, ANTAVALUO, ANTCONDICION, USUARIOCREADOR, REGISTRADO, AREATERENOM2, AREAHECTARES, ANTAREAHECTARES, TARIFA, ANTTARIFA, ULTIMO_ANIO, MODIFICA_AVALUOS, CODIGO_PADRE, ULTIMO_PAGO, ANO_CONSTRUCCION, ANTANO_CONSTRUCCION, ANTVIGENCIA, ANTULTIMO_ANIO, OBSERVACION, ANTOBSERVACION, UBICACION, UBICACIONANT, ANTDIRECCION, ANTNOMBRE, ANTRESOLUCION, TEMPORAL, FECHAINGRESOSISTEMA, OBS_REGISTRO, TRPRAN, NUMERO_PREDIAL_NUEVO, TIPO_TRAMITE, TIPO_TRAMITE_ANT, COMUNA, COMUNA_ANT, ESPACIO, ESPACIO_ANT, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :PAIS, :DEPARTAMENTO, :MUNICIPIO, :RESOLUCION, :CONSECUTIVO, :ANO, :RADICACION, :MUTACION, :CODIGO, :NUMEROORDEN, :CANCELAINSCRIBE, :TIPOREGISTRO, :TOTALREGISTROS, :NOMBRE, :ESTADOCIVIL, :TIPODOCUMENTO, :NUMERODOCUMENTO, :DIRECCION, :DESTINOECONOMICO, :AREATERRENO, :AREACONSTRUIDA, :AVALUO, :VIGENCIA, :CONDICIONTRIS, :ANTTIPODOCUMENTO, :ANTNUMERODOCUMENTO, :ANTDESTINOECONOMICO, :ANTAREATERRENO, :ANTCONSTRUIDA, :ANTAVALUO, :ANTCONDICION, :USUARIOCREADOR, :REGISTRADO, :AREATERENOM2, :AREAHECTARES, :ANTAREAHECTARES, :TARIFA, :ANTTARIFA, :ULTIMO_ANIO, :MODIFICA_AVALUOS, :CODIGO_PADRE, :ULTIMO_PAGO, :ANO_CONSTRUCCION, :ANTANO_CONSTRUCCION, :ANTVIGENCIA, :ANTULTIMO_ANIO, :OBSERVACION, :ANTOBSERVACION, :UBICACION, :UBICACIONANT, :ANTDIRECCION, :ANTNOMBRE, :ANTRESOLUCION, :TEMPORAL, TO_DATE(:FECHAINGRESOSISTEMA,'DD/MM/YYYY HH24:MI:SS'), :OBS_REGISTRO, :TRPRAN, :NUMERO_PREDIAL_NUEVO, :TIPO_TRAMITE, :TIPO_TRAMITE_ANT, :COMUNA, :COMUNA_ANT, :ESPACIO, :ESPACIO_ANT, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
