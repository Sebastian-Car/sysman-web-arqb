	<query id="getIpigacresolucionesdetRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, PAIS, DEPARTAMENTO, MUNICIPIO, RESOLUCION, CONSECUTIVO, ANO, RADICACION, MUTACION, CODIGO, NUMEROORDEN, CANCELAINSCRIBE, TIPOREGISTRO, TOTALREGISTROS, NOMBRE, ESTADOCIVIL, TIPODOCUMENTO, NUMERODOCUMENTO, DIRECCION, DESTINOECONOMICO, AREATERRENO, AREACONSTRUIDA, AVALUO, VIGENCIA, CONDICIONTRIS, ANTTIPODOCUMENTO, ANTNUMERODOCUMENTO, ANTDESTINOECONOMICO, ANTAREATERRENO, ANTCONSTRUIDA, ANTAVALUO, ANTCONDICION, USUARIOCREADOR,(CASE REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO, CASE WHEN REGISTRADO IN(0) THEN 'false' ELSE 'true' END REGISTRADOS, AREATERENOM2, AREAHECTARES, ANTAREAHECTARES, TARIFA, ANTTARIFA, ULTIMO_ANIO,(CASE MODIFICA_AVALUOS WHEN 0 THEN 'false' ELSE 'true' END) MODIFICA_AVALUOS, CODIGO_PADRE, ULTIMO_PAGO, ANO_CONSTRUCCION, ANTANO_CONSTRUCCION, ANTVIGENCIA, ANTULTIMO_ANIO, OBSERVACION, ANTOBSERVACION, UBICACION, UBICACIONANT, ANTDIRECCION, ANTNOMBRE, ANTRESOLUCION, TEMPORAL,(TO_CHAR(FECHAINGRESOSISTEMA,'DD/MM/YYYY HH24:MI:SS')) FECHAINGRESOSISTEMA, OBS_REGISTRO, TRPRAN, NUMERO_PREDIAL_NUEVO, TIPO_TRAMITE, TIPO_TRAMITE_ANT, COMUNA, COMUNA_ANT, ESPACIO, ESPACIO_ANT, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM IP_IGAC_RESOLUCIONESDET WHERE IP_IGAC_RESOLUCIONESDET.COMPANIA= :KEY_COMPANIA AND IP_IGAC_RESOLUCIONESDET.PAIS= :KEY_PAIS AND IP_IGAC_RESOLUCIONESDET.DEPARTAMENTO= :KEY_DEPARTAMENTO AND IP_IGAC_RESOLUCIONESDET.MUNICIPIO= :KEY_MUNICIPIO AND IP_IGAC_RESOLUCIONESDET.RESOLUCION= :KEY_RESOLUCION AND IP_IGAC_RESOLUCIONESDET.CONSECUTIVO= :KEY_CONSECUTIVO AND IP_IGAC_RESOLUCIONESDET.ANO= :KEY_ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","MUNICIPIO":"$MUNICIPIO","RESOLUCION":"$RESOLUCION","CONSECUTIVO":"$CONSECUTIVO(type:long)","ANO":"$ANO(type:integer)","RADICACION":"$RADICACION","MUTACION":"$MUTACION","CODIGO":"$CODIGO","NUMEROORDEN":"$NUMEROORDEN","CANCELAINSCRIBE":"$CANCELAINSCRIBE","TIPOREGISTRO":"$TIPOREGISTRO","TOTALREGISTROS":"$TOTALREGISTROS","NOMBRE":"$NOMBRE","ESTADOCIVIL":"$ESTADOCIVIL","TIPODOCUMENTO":"$TIPODOCUMENTO","NUMERODOCUMENTO":"$NUMERODOCUMENTO","DIRECCION":"$DIRECCION","DESTINOECONOMICO":"$DESTINOECONOMICO","AREATERRENO":"$AREATERRENO","AREACONSTRUIDA":"$AREACONSTRUIDA","AVALUO":"$AVALUO","VIGENCIA":"$VIGENCIA(type:integer)","CONDICIONTRIS":"$CONDICIONTRIS","ANTTIPODOCUMENTO":"$ANTTIPODOCUMENTO","ANTNUMERODOCUMENTO":"$ANTNUMERODOCUMENTO","ANTDESTINOECONOMICO":"$ANTDESTINOECONOMICO","ANTAREATERRENO":"$ANTAREATERRENO","ANTCONSTRUIDA":"$ANTCONSTRUIDA","ANTAVALUO":"$ANTAVALUO","ANTCONDICION":"$ANTCONDICION","USUARIOCREADOR":"$USUARIOCREADOR","REGISTRADO":"$REGISTRADO(type:boolean)","REGISTRADOS":"$REGISTRADOS","AREATERENOM2":"$AREATERENOM2","AREAHECTARES":"$AREAHECTARES","ANTAREAHECTARES":"$ANTAREAHECTARES","TARIFA":"$TARIFA","ANTTARIFA":"$ANTTARIFA","ULTIMO_ANIO":"$ULTIMO_ANIO(type:integer)","MODIFICA_AVALUOS":"$MODIFICA_AVALUOS(type:boolean)","CODIGO_PADRE":"$CODIGO_PADRE","ULTIMO_PAGO":"$ULTIMO_PAGO","ANO_CONSTRUCCION":"$ANO_CONSTRUCCION","ANTANO_CONSTRUCCION":"$ANTANO_CONSTRUCCION","ANTVIGENCIA":"$ANTVIGENCIA","ANTULTIMO_ANIO":"$ANTULTIMO_ANIO(type:integer)","OBSERVACION":"$OBSERVACION","ANTOBSERVACION":"$ANTOBSERVACION","UBICACION":"$UBICACION","UBICACIONANT":"$UBICACIONANT","ANTDIRECCION":"$ANTDIRECCION","ANTNOMBRE":"$ANTNOMBRE","ANTRESOLUCION":"$ANTRESOLUCION","TEMPORAL":"$TEMPORAL","FECHAINGRESOSISTEMA":"$FECHAINGRESOSISTEMA","OBS_REGISTRO":"$OBS_REGISTRO","TRPRAN":"$TRPRAN","NUMERO_PREDIAL_NUEVO":"$NUMERO_PREDIAL_NUEVO","TIPO_TRAMITE":"$TIPO_TRAMITE","TIPO_TRAMITE_ANT":"$TIPO_TRAMITE_ANT","COMUNA":"$COMUNA","COMUNA_ANT":"$COMUNA_ANT","ESPACIO":"$ESPACIO","ESPACIO_ANT":"$ESPACIO_ANT","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
