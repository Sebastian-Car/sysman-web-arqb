	<query id="getIpigacresolucionesdetPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, PAIS, DEPARTAMENTO, MUNICIPIO, ANO, RESOLUCION, CONSECUTIVO, CODIGO, NOMBRE, AREATERENOM2 AREATERRENO, AREACONSTRUIDA, AVALUO,(CASE REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO FROM IP_IGAC_RESOLUCIONESDET WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND RESOLUCION = :RESOLUCION AND PAIS = :PAIS AND DEPARTAMENTO = :DEPARTAMENTO AND MUNICIPIO = :MUNICIPIO) WHERE (CASE WHEN RESOLUCION IS NULL THEN ' ' ELSE UPPER(RESOLUCION) END)  LIKE UPPER(:RESOLUCION || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN AREATERRENO IS NULL THEN ' ' ELSE UPPER(AREATERRENO) END)  LIKE UPPER(:AREATERRENO || '%')  AND (CASE WHEN AREACONSTRUIDA IS NULL THEN ' ' ELSE UPPER(AREACONSTRUIDA) END)  LIKE UPPER(:AREACONSTRUIDA || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER(:AVALUO || '%')  AND (CASE WHEN REGISTRADO IS NULL THEN ' ' ELSE UPPER(REGISTRADO) END)  LIKE UPPER( '%' || :REGISTRADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","MUNICIPIO":"$MUNICIPIO","ANO":"$ANO(type:integer)","RESOLUCION":"$RESOLUCION","CONSECUTIVO":"$CONSECUTIVO(type:long)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","AREATERRENO":"$AREATERRENO","AREACONSTRUIDA":"$AREACONSTRUIDA","AVALUO":"$AVALUO","REGISTRADO":"$REGISTRADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="RESOLUCION" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="MUNICIPIO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="AREATERRENO" sqlType="STRING"/>
		<param name="AREACONSTRUIDA" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="REGISTRADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipigacresolucionesdet">
		<call-query href="getIpigacresolucionesdetPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
