<data name="sptarifaintreca" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSptarifaintrecaCargarListaInteresPorUsoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_TARIFA_INT_RECA.COMPANIA, SP_TARIFA_INT_RECA.ANO, SP_TARIFA_INT_RECA.PERIODO, SP_TARIFA_INT_RECA.USO, SP_TARIFA_INT_RECA.ESTRATO, SP_TARIFA_INT_RECA.CONCEPTO, SP_TARIFA_INT_RECA.INTERES, SP_TARIFA_INT_RECA.RECARGO ,SP_CONCEPTOS.NOMBRE  FROM SP_TARIFA_INT_RECA INNER JOIN SP_CONCEPTOS ON (SP_TARIFA_INT_RECA.COMPANIA = SP_CONCEPTOS.COMPANIA) AND (SP_TARIFA_INT_RECA.CONCEPTO = SP_CONCEPTOS.CODIGO) WHERE SP_TARIFA_INT_RECA.COMPANIA = :COMPANIA AND SP_TARIFA_INT_RECA.ANO = :ANO AND SP_TARIFA_INT_RECA.PERIODO = :PERIODO AND SP_TARIFA_INT_RECA.USO = :USO AND SP_TARIFA_INT_RECA.ESTRATO = :ESTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","USO":"$USO","ESTRATO":"$ESTRATO","CONCEPTO":"$CONCEPTO(type:integer)","INTERES":"$INTERES","RECARGO":"$RECARGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptarifaintreca/cargarlistainteresporuso">
		<call-query href="getSptarifaintrecaCargarListaInteresPorUsoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>

		</call-query>
	</resource>
	<query id="insertSptarifaintreca" keyColumns="COMPANIA,ANO,PERIODO,USO,ESTRATO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_TARIFA_INT_RECA (COMPANIA, ANO, PERIODO, USO, ESTRATO, CONCEPTO, INTERES, RECARGO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :PERIODO, :USO, :ESTRATO, :CONCEPTO, :INTERES, :RECARGO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_USO":"$USO","KEY_ESTRATO":"$ESTRATO","KEY_CONCEPTO":"$CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="INTERES" sqlType="STRING"/>
		<param defaultValue="0" name="RECARGO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sptarifaintreca">
		<call-query href="insertSptarifaintreca">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="RECARGO" query-param="RECARGO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSptarifaintreca" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_TARIFA_INT_RECA WHERE SP_TARIFA_INT_RECA.COMPANIA= :KEY_COMPANIA AND SP_TARIFA_INT_RECA.ANO= :KEY_ANO AND SP_TARIFA_INT_RECA.PERIODO= :KEY_PERIODO AND SP_TARIFA_INT_RECA.USO= :KEY_USO AND SP_TARIFA_INT_RECA.ESTRATO= :KEY_ESTRATO AND SP_TARIFA_INT_RECA.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_USO" sqlType="STRING"/>
		<param name="KEY_ESTRATO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="sptarifaintreca">
		<call-query href="deleteSptarifaintreca">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_USO" query-param="KEY_USO"/>
			<with-param name="KEY_ESTRATO" query-param="KEY_ESTRATO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateSptarifaintreca" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_TARIFA_INT_RECA SET ANO=:ANO, PERIODO=:PERIODO, USO=:USO, ESTRATO=:ESTRATO, CONCEPTO=:CONCEPTO, INTERES=:INTERES, RECARGO=:RECARGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_TARIFA_INT_RECA.COMPANIA= :KEY_COMPANIA AND SP_TARIFA_INT_RECA.ANO= :KEY_ANO AND SP_TARIFA_INT_RECA.PERIODO= :KEY_PERIODO AND SP_TARIFA_INT_RECA.USO= :KEY_USO AND SP_TARIFA_INT_RECA.ESTRATO= :KEY_ESTRATO AND SP_TARIFA_INT_RECA.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>
		<param name="RECARGO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_USO" sqlType="STRING"/>
		<param name="KEY_ESTRATO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sptarifaintreca">
		<call-query href="updateSptarifaintreca">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="RECARGO" query-param="RECARGO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_USO" query-param="KEY_USO"/>
			<with-param name="KEY_ESTRATO" query-param="KEY_ESTRATO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>

</data>