			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosCodOrdPorPredQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOS.COMPANIA, IP_FACTURADOS.CODIGO, IP_FACTURADOS.NUMERO_ORDEN  FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :PREDIO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/codordporpred">
		<call-query href="getIpfacturadosCodOrdPorPredQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosPagSubavaluosDosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NUMERO_ORDEN, PREANO, TRPCOD, TRPRAN,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, AVALUO, TRPPOR, NUMRESOLUCION, AVALUOANT, TARIFAANT, PREIND,(CASE NOCOBRADO WHEN 0 THEN 'false' ELSE 'true' END) NOCOBRADO FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO_ORDEN AND CODIGO = :CODIGO AND PAGADO IN (0) AND NOCOBRADO IN (0)) WHERE (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%')  AND (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER(:TRPCOD || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","TRPCOD":"$TRPCOD","TRPRAN":"$TRPRAN","PREFEC":"$PREFEC","AVALUO":"$AVALUO","TRPPOR":"$TRPPOR","NUMRESOLUCION":"$NUMRESOLUCION","AVALUOANT":"$AVALUOANT","TARIFAANT":"$TARIFAANT","PREIND":"$PREIND","NOCOBRADO":"$NOCOBRADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipfacturados/subavaluosdosporcodigo/pag">
		<call-query href="getIpfacturadosPagSubavaluosDosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="TRPCOD" query-param="TRPCOD"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosNumSubavaluosDosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NUMERO_ORDEN, PREANO, TRPCOD, TRPRAN,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, AVALUO, TRPPOR, NUMRESOLUCION, AVALUOANT, TARIFAANT, PREIND,(CASE NOCOBRADO WHEN 0 THEN 'false' ELSE 'true' END) NOCOBRADO FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO_ORDEN AND CODIGO = :CODIGO AND PAGADO IN (0) AND NOCOBRADO IN (0)) WHERE (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%')  AND (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER( '%' || :TRPCOD || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/subavaluosdosporcodigo/num">
		<call-query href="getIpfacturadosNumSubavaluosDosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="TRPCOD" query-param="TRPCOD"/>
			<with-param name="AVALUO" query-param="AVALUO"/>

		</call-query>
	</resource>
	<query id="updateIpfacturadosSubavaluosDosPorCodigo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_FACTURADOS SET TRPCOD=:TRPCOD, TRPRAN=:TRPRAN, PREFEC=TO_DATE(:PREFEC,'DD/MM/YYYY HH24:MI:SS'), AVALUO=:AVALUO, TRPPOR=:TRPPOR, NUMRESOLUCION=:NUMRESOLUCION, AVALUOANT=:AVALUOANT, TARIFAANT=:TARIFAANT, PREIND=:PREIND, NOCOBRADO=:NOCOBRADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_FACTURADOS.COMPANIA= :KEY_COMPANIA AND IP_FACTURADOS.CODIGO= :KEY_CODIGO AND IP_FACTURADOS.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_FACTURADOS.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TRPCOD" sqlType="STRING"/>
		<param name="TRPRAN" sqlType="STRING"/>
		<param name="PREFEC" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="TRPPOR" sqlType="STRING"/>
		<param name="NUMRESOLUCION" sqlType="STRING"/>
		<param name="AVALUOANT" sqlType="STRING"/>
		<param name="TARIFAANT" sqlType="STRING"/>
		<param name="PREIND" sqlType="STRING"/>
		<param name="NOCOBRADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="KEY_PREANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipfacturados/subavaluosdosporcodigo">
		<call-query href="updateIpfacturadosSubavaluosDosPorCodigo">
			<with-param name="TRPCOD" query-param="TRPCOD"/>
			<with-param name="TRPRAN" query-param="TRPRAN"/>
			<with-param name="PREFEC" query-param="PREFEC"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="TRPPOR" query-param="TRPPOR"/>
			<with-param name="NUMRESOLUCION" query-param="NUMRESOLUCION"/>
