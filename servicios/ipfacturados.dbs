	<query id="getIpfacturadosPreanoPagPorPredioAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOS.PREANO  FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :PREDIO AND IP_FACTURADOS.PREANO &gt; :ANO AND IP_FACTURADOS.PAGADO IN(0) AND IP_FACTURADOS.NOCOBRADO IN(0) ORDER BY IP_FACTURADOS.PREANO ASC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/preanopagporpredioano">
		<call-query href="getIpfacturadosPreanoPagPorPredioAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosTotalesPrefusaPorCodNumQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(SUM(C1), '99,999,999,999,999,990.90') TIMPUESTO, TO_CHAR(SUM(C2), '99,999,999,999,999,990.90') TINTERES, TO_CHAR(SUM(C3), '99,999,999,999,999,990.90') TCAR, TO_CHAR(SUM(C4), '99,999,999,999,999,990.90') TCARINT, TO_CHAR(SUM(C13), '99,999,999,999,999,990.90') TDESC, TO_CHAR(SUM(C14), '99,999,999,999,999,990.90') TC14, CASE WHEN :INDOTROS =1 THEN TO_CHAR(SUM(C15+C16+C17+C20), '99,999,999,999,999,990.90') WHEN :INDOTROS =2 THEN TO_CHAR(SUM(C15+C16+C17+C18), '99,999,999,999,999,990.90') ELSE TO_CHAR(SUM(C15+C16+C17+C18+C19+C20), '99,999,999,999,999,990.90') END TOTROS, TO_CHAR(SUM(TOTAL), '99,999,999,999,999,990.90') TDEUDA  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :PREDIO AND NUMERO_ORDEN = :NUMERO AND PAGADO IN (0) AND NOCOBRADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIMPUESTO":"$TIMPUESTO","TINTERES":"$TINTERES","TCAR":"$TCAR","TCARINT":"$TCARINT","TDESC":"$TDESC","TC14":"$TC14","TOTROS":"$TOTROS","TDEUDA":"$TDEUDA"}]}}		</result>
		<param name="INDOTROS" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
