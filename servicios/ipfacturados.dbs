	<query id="getIpfacturadosTodosPorCompaniaPredioNumeroOrdenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOS.PREANO  FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA =:COMPANIA AND IP_FACTURADOS.CODIGO = :CODIGOPREDIO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORDEN_PREDIAL AND IP_FACTURADOS.PREANO &gt; :ANOPAGO AND IP_FACTURADOS.PAGADO IN (0) AND IP_FACTURADOS.INDEXE IN (0) AND IP_FACTURADOS.NOCOBRADO IN(0) AND IP_FACTURADOS.INDPAGO_ACPAG IN(0) ORDER BY IP_FACTURADOS.PREANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPREDIO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN_PREDIAL" sqlType="STRING"/>
		<param name="ANOPAGO" sqlType="STRING"/>

	</query>
