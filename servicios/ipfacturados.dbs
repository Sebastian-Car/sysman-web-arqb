			<with-param name="IND_PROCESOJUD" query-param="IND_PROCESOJUD"/>
			<with-param name="AREAM2" query-param="AREAM2"/>
			<with-param name="AREA_CONSTRUIDA" query-param="AREA_CONSTRUIDA"/>
			<with-param name="TOTAL" query-param="TOTAL"/>

		</call-query>
	</resource>
	<query id="updateIpfacturados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_FACTURADOS SET PREANO=:PREANO, AVALUO=:AVALUO, PREIND=:PREIND, TRPCOD=:TRPCOD, TRPPOR=:TRPPOR, TRPRAN=:TRPRAN, INDCAR=:INDCAR, INDEXE=:INDEXE, INDEXEOTROS=:INDEXEOTROS, ANTERIOR_RURAL=:ANTERIOR_RURAL, NOCOBRADO=:NOCOBRADO, FECHAPRESCRIPCION=TO_DATE(:FECHAPRESCRIPCION,'DD/MM/YYYY HH24:MI:SS'), PAGADO=:PAGADO, INDPAGO_ACPAG=:INDPAGO_ACPAG, INDPAGO_CUOTAS=:INDPAGO_CUOTAS, IND_PROCESOJUD=:IND_PROCESOJUD, FECHAPAGO=TO_DATE(:FECHAPAGO,'DD/MM/YYYY HH24:MI:SS'), PAG_BAN=:PAG_BAN, PREVAL=:PREVAL, DOCNUM=:DOCNUM, TOTAL=:TOTAL, OBSERVACIONES=:OBSERVACIONES, TOTALABONADO=:TOTALABONADO, VALORULTIMOABONO=:VALORULTIMOABONO, FECHAULTIMOABONO=TO_DATE(:FECHAULTIMOABONO,'DD/MM/YYYY HH24:MI:SS'), AREA_CONSTRUIDA=:AREA_CONSTRUIDA, AREAM2=:AREAM2, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE IP_FACTURADOS.COMPANIA= :KEY_COMPANIA AND IP_FACTURADOS.CODIGO= :KEY_CODIGO AND IP_FACTURADOS.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_FACTURADOS.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PREANO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="PREIND" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="TRPPOR" sqlType="STRING"/>
		<param name="TRPRAN" sqlType="STRING"/>
		<param name="INDCAR" sqlType="STRING"/>
		<param name="INDEXE" sqlType="STRING"/>
		<param name="INDEXEOTROS" sqlType="STRING"/>
		<param name="ANTERIOR_RURAL" sqlType="STRING"/>
		<param name="NOCOBRADO" sqlType="STRING"/>
		<param name="FECHAPRESCRIPCION" sqlType="STRING"/>
		<param name="PAGADO" sqlType="STRING"/>
		<param name="INDPAGO_ACPAG" sqlType="STRING"/>
		<param name="INDPAGO_CUOTAS" sqlType="STRING"/>
		<param name="IND_PROCESOJUD" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>
		<param name="PREVAL" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="TOTALABONADO" sqlType="STRING"/>
		<param name="VALORULTIMOABONO" sqlType="STRING"/>
		<param name="FECHAULTIMOABONO" sqlType="STRING"/>
		<param name="AREA_CONSTRUIDA" sqlType="STRING"/>
		<param name="AREAM2" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="KEY_PREANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipfacturados">
		<call-query href="updateIpfacturados">
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
