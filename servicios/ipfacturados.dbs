	<query id="getIpfacturadosNumTodosPorConceptoFacturacionGQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_FACTURADOS.COMPANIA, IP_FACTURADOS.CODIGO, IP_FACTURADOS.NUMERO_ORDEN, IP_FACTURADOS.C1, IP_FACTURADOS.C2, IP_FACTURADOS.C3, IP_FACTURADOS.C4, IP_FACTURADOS.C5, IP_FACTURADOS.C6, IP_FACTURADOS.C7, IP_FACTURADOS.C8, IP_FACTURADOS.C9, IP_FACTURADOS.C10, IP_FACTURADOS.C11, IP_FACTURADOS.C12, IP_FACTURADOS.C13, IP_FACTURADOS.C14, IP_FACTURADOS.C15, IP_FACTURADOS.C16, IP_FACTURADOS.C17, IP_FACTURADOS.C18, IP_FACTURADOS.C19, IP_FACTURADOS.C20, IP_FACTURADOS.PREANO, IP_FACTURADOS.TOTAL, IP_FACTURADOS.C1_CPY, IP_FACTURADOS.C3_CPY, IP_FACTURADOS.AVALUO,(CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :CODIGOPREDIO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_FACTURADOS.PREANO DESC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NUMERO_ORDEN IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDEN) END)  LIKE UPPER( '%' || :NUMERO_ORDEN || '%')  AND (CASE WHEN C1 IS NULL THEN ' ' ELSE UPPER(C1) END)  LIKE UPPER( '%' || :C1 || '%')  AND (CASE WHEN C2 IS NULL THEN ' ' ELSE UPPER(C2) END)  LIKE UPPER( '%' || :C2 || '%')  AND (CASE WHEN C3 IS NULL THEN ' ' ELSE UPPER(C3) END)  LIKE UPPER( '%' || :C3 || '%')  AND (CASE WHEN C4 IS NULL THEN ' ' ELSE UPPER(C4) END)  LIKE UPPER( '%' || :C4 || '%')  AND (CASE WHEN C5 IS NULL THEN ' ' ELSE UPPER(C5) END)  LIKE UPPER( '%' || :C5 || '%')  AND (CASE WHEN C6 IS NULL THEN ' ' ELSE UPPER(C6) END)  LIKE UPPER( '%' || :C6 || '%')  AND (CASE WHEN C7 IS NULL THEN ' ' ELSE UPPER(C7) END)  LIKE UPPER( '%' || :C7 || '%')  AND (CASE WHEN C8 IS NULL THEN ' ' ELSE UPPER(C8) END)  LIKE UPPER( '%' || :C8 || '%')  AND (CASE WHEN C9 IS NULL THEN ' ' ELSE UPPER(C9) END)  LIKE UPPER( '%' || :C9 || '%')  AND (CASE WHEN C10 IS NULL THEN ' ' ELSE UPPER(C10) END)  LIKE UPPER( '%' || :C10 || '%')  AND (CASE WHEN C11 IS NULL THEN ' ' ELSE UPPER(C11) END)  LIKE UPPER( '%' || :C11 || '%')  AND (CASE WHEN C12 IS NULL THEN ' ' ELSE UPPER(C12) END)  LIKE UPPER( '%' || :C12 || '%')  AND (CASE WHEN C13 IS NULL THEN ' ' ELSE UPPER(C13) END)  LIKE UPPER( '%' || :C13 || '%')  AND (CASE WHEN C14 IS NULL THEN ' ' ELSE UPPER(C14) END)  LIKE UPPER( '%' || :C14 || '%')  AND (CASE WHEN C15 IS NULL THEN ' ' ELSE UPPER(C15) END)  LIKE UPPER( '%' || :C15 || '%')  AND (CASE WHEN C16 IS NULL THEN ' ' ELSE UPPER(C16) END)  LIKE UPPER( '%' || :C16 || '%')  AND (CASE WHEN C17 IS NULL THEN ' ' ELSE UPPER(C17) END)  LIKE UPPER( '%' || :C17 || '%')  AND (CASE WHEN C18 IS NULL THEN ' ' ELSE UPPER(C18) END)  LIKE UPPER( '%' || :C18 || '%')  AND (CASE WHEN C19 IS NULL THEN ' ' ELSE UPPER(C19) END)  LIKE UPPER( '%' || :C19 || '%')  AND (CASE WHEN C20 IS NULL THEN ' ' ELSE UPPER(C20) END)  LIKE UPPER( '%' || :C20 || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%')  AND (CASE WHEN C1_CPY IS NULL THEN ' ' ELSE UPPER(C1_CPY) END)  LIKE UPPER( '%' || :C1_CPY || '%')  AND (CASE WHEN C3_CPY IS NULL THEN ' ' ELSE UPPER(C3_CPY) END)  LIKE UPPER( '%' || :C3_CPY || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPREDIO" sqlType="STRING"/>
