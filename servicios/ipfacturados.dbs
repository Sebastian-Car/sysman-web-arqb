		<param name="C7" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="C9" sqlType="STRING"/>
		<param name="C4" sqlType="STRING"/>
		<param name="C3" sqlType="STRING"/>
		<param name="C6" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="C5" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="C20" sqlType="STRING"/>
