			<with-param name="C2" query-param="C2"/>
			<with-param name="C3" query-param="C3"/>
			<with-param name="C4" query-param="C4"/>
			<with-param name="C13" query-param="C13"/>
			<with-param name="OTROS" query-param="OTROS"/>
			<with-param name="TOTAL" query-param="TOTAL"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosTotalesdetalledeudaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(SUM(C1), '99,999,999,999,999,990.90') TIMPUESTO, TO_CHAR(SUM(C2), '99,999,999,999,999,990.90') TINTERES, TO_CHAR(SUM(C3), '99,999,999,999,999,990.90') TCAR, TO_CHAR(SUM(C4), '99,999,999,999,999,990.90') TCARINT, TO_CHAR(SUM(C13), '99,999,999,999,999,990.90') TDESC, TO_CHAR(SUM((IP_FACTURADOS.TOTAL - (IP_FACTURADOS.C1 + IP_FACTURADOS.C2 + IP_FACTURADOS.C3 + IP_FACTURADOS.C4 + IP_FACTURADOS.C13))), '99,999,999,999,999,990.90') TOTROS, TO_CHAR(SUM(TOTAL), '99,999,999,999,999,990.90') TDEUDA  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND NUMERO_ORDEN = :NUMERO_ORDEN AND PAGADO IN (0) AND INDPAGO_ACPAG IN (0) AND NOCOBRADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIMPUESTO":"$TIMPUESTO","TINTERES":"$TINTERES","TCAR":"$TCAR","TCARINT":"$TCARINT","TDESC":"$TDESC","TOTROS":"$TOTROS","TDEUDA":"$TDEUDA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/totalesdetalledeuda">
