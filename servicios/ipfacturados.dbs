	<query id="getIpfacturadosNumListadodetalledeudaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_FACTURADOS.COMPANIA, IP_FACTURADOS.CODIGO, IP_FACTURADOS.NUMERO_ORDEN, IP_FACTURADOS.PREANO, TRPPOR * 1000 TARIFA, IP_FACTURADOS.AVALUO, IP_FACTURADOS.C1, IP_FACTURADOS.C2, IP_FACTURADOS.C3, IP_FACTURADOS.C4, IP_FACTURADOS.C13, (IP_FACTURADOS.TOTAL - (IP_FACTURADOS.C1 + IP_FACTURADOS.C2 + IP_FACTURADOS.C3 + IP_FACTURADOS.C4 + IP_FACTURADOS.C13)) OTROS, IP_FACTURADOS.TOTAL,(CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :CODIGO_PREDIO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORD AND IP_FACTURADOS.PAGADO IN(0) AND IP_FACTURADOS.NOCOBRADO IN(0) AND IP_FACTURADOS.INDPAGO_ACPAG IN(0) ORDER BY IP_FACTURADOS.PREANO) WHERE (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%')  AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END)  LIKE UPPER( '%' || :TARIFA || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN C1 IS NULL THEN ' ' ELSE UPPER(C1) END)  LIKE UPPER( '%' || :C1 || '%')  AND (CASE WHEN C2 IS NULL THEN ' ' ELSE UPPER(C2) END)  LIKE UPPER( '%' || :C2 || '%')  AND (CASE WHEN C3 IS NULL THEN ' ' ELSE UPPER(C3) END)  LIKE UPPER( '%' || :C3 || '%')  AND (CASE WHEN C4 IS NULL THEN ' ' ELSE UPPER(C4) END)  LIKE UPPER( '%' || :C4 || '%')  AND (CASE WHEN C13 IS NULL THEN ' ' ELSE UPPER(C13) END)  LIKE UPPER( '%' || :C13 || '%')  AND (CASE WHEN OTROS IS NULL THEN ' ' ELSE UPPER(OTROS) END)  LIKE UPPER( '%' || :OTROS || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PREDIO" sqlType="STRING"/>
		<param name="NUMERO_ORD" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="C1" sqlType="STRING"/>
		<param name="C2" sqlType="STRING"/>
		<param name="C3" sqlType="STRING"/>
		<param name="C4" sqlType="STRING"/>
		<param name="C13" sqlType="STRING"/>
		<param name="OTROS" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/listadodetalledeuda/num">
		<call-query href="getIpfacturadosNumListadodetalledeudaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PREDIO" query-param="CODIGO_PREDIO"/>
			<with-param name="NUMERO_ORD" query-param="NUMERO_ORD"/>
			<with-param name="PREANO" query-param="PREANO"/>
