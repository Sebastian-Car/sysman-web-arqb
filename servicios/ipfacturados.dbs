	<query id="getIpfacturadosUsuariosFactPorPredionumQuery"  useConfig="sysmandsunist">
		<sql>SELECT  C8, C9, C10, C11, C12, C13, C14, C15, C16, C17, C18, C19, C20,(CASE PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, TRPPOR,(CASE NOCOBRADO WHEN 0 THEN 'false' ELSE 'true' END) NOCOBRADO, OBSERVACIONES, NUMRESOLUCION, AVALUOANT, TARIFAANT, AREAHE, AREAM2, USUARIO,(TO_CHAR(FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO,(TO_CHAR(FECHAPRESCRIPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAPRESCRIPCION, TOTALABONADO, VALORULTIMOABONO,(TO_CHAR(FECHAULTIMOABONO,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMOABONO,(TO_CHAR(ALDIAINTERES,'DD/MM/YYYY HH24:MI:SS')) ALDIAINTERES,(CASE INDPAGO_ACPAG WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_ACPAG,(CASE FINANCIAR WHEN 0 THEN 'false' ELSE 'true' END) FINANCIAR,(CASE CNT WHEN 0 THEN 'false' ELSE 'true' END) CNT, C1_CNT, TOTALABONADO1, VALORULTIMOABONO1,(TO_CHAR(FECHAULTIMOABONO1,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMOABONO1,(TO_CHAR(ALDIAINTERES1,'DD/MM/YYYY HH24:MI:SS')) ALDIAINTERES1, TOTALABONADO2, VALORULTIMOABONO2,(TO_CHAR(FECHAULTIMOABONO2,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMOABONO2,(TO_CHAR(ALDIAINTERES2,'DD/MM/YYYY HH24:MI:SS')) ALDIAINTERES2, DOCNUMABONO, DOCNUMABONO1, DOCNUMABONO2,(CASE INDPAGO_CUOTAS WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_CUOTAS, TOTALCUOTA,(TO_CHAR(PAGFECCUOTA,'DD/MM/YYYY HH24:MI:SS')) PAGFECCUOTA, PAGNCUOTA, DOCNUMCUOTA, TOTALCUOTA1,(TO_CHAR(PAGFECCUOTA1,'DD/MM/YYYY HH24:MI:SS')) PAGFECCUOTA1, PAGNCUOTA1, DOCNUMCUOTA1, TOTALCUOTA2,(TO_CHAR(PAGFECCUOTA2,'DD/MM/YYYY HH24:MI:SS')) PAGFECCUOTA2, PAGNCUOTA2, DOCNUMCUOTA2, C18_CNT, TOTALABONO1, TOTALABONO2,(CASE PREANO_EXONERADO WHEN 0 THEN 'false' ELSE 'true' END) PREANO_EXONERADO, C1_CPY,(CASE IND_C1CPY WHEN 0 THEN 'false' ELSE 'true' END) IND_C1CPY,(TO_CHAR(ALDIAINTERESCAR,'DD/MM/YYYY HH24:MI:SS')) ALDIAINTERESCAR,(TO_CHAR(ALDIAINTERES1CAR,'DD/MM/YYYY HH24:MI:SS')) ALDIAINTERES1CAR,(TO_CHAR(ALDIAINTERES2CAR,'DD/MM/YYYY HH24:MI:SS')) ALDIAINTERES2CAR, C3_CPY,(CASE IND_C3CPY WHEN 0 THEN 'false' ELSE 'true' END) IND_C3CPY,(CASE SINDESCUENTOS WHEN 0 THEN 'false' ELSE 'true' END) SINDESCUENTOS, AUDITADESC, DESC_INTERES, C1_EXE, C2_EXE, C3_EXE, C4_EXE,(CASE INDEXEOTROS WHEN 0 THEN 'false' ELSE 'true' END) INDEXEOTROS, C13_EXE, C14_EXE, C15_EXE, C16_EXE, C17_EXE, C18_EXE, C19_EXE, C20_EXE, DESESPC13, DESESPC2, DESESPC4, DESESPC14, DESESPC15, DESESPC16, DESESPC17, DESESPC18, DESESPC19, DESESPC20,(CASE IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD, AREA_CONSTRUIDA, FECHA_CAMBIO_AVALUO, CAMBIO_AVALUO, TRP_POR,(CASE ES_AUTOAVALUO WHEN 0 THEN 'false' ELSE 'true' END) ES_AUTOAVALUO, CONSECUTIVO, PORCENTAJE_RESERVA, RESOLUCION_RESERVA, RESOLUCION_DESRESERVA, TEMPORAL,(CASE IND_EXEINT_DUP WHEN 0 THEN 'false' ELSE 'true' END) IND_EXEINT_DUP,(CASE APROBADOFISC WHEN 0 THEN 'false' ELSE 'true' END) APROBADOFISC,(CASE INCR_AUTOAVALUO WHEN 0 THEN 'false' ELSE 'true' END) INCR_AUTOAVALUO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, COMPANIA, CODIGO, NUMERO_ORDEN, PREANO, TRPCOD, TRPRAN,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, DOCNUM, PAG_BAN, PREVAL, USUARIO_CREADOR_REGISTRO,(TO_CHAR(FECHA_CREACION_REGISTRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CREACION_REGISTRO, USUARIO_MODIFICO_REGISTRO,(TO_CHAR(FECHA_MODIFICACION_REGISTRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_MODIFICACION_REGISTRO, AVALUO, TRPFOR, PREIND, SALDOCREDITO, ABONOS,(CASE INDHIP WHEN 0 THEN 'false' ELSE 'true' END) INDHIP,(CASE INDCAR WHEN 0 THEN 'false' ELSE 'true' END) INDCAR,(CASE INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE,(CASE ANTERIOR_RURAL WHEN 0 THEN 'false' ELSE 'true' END) ANTERIOR_RURAL, TOTAL, C1, C2, C3, C4, C5, C6, C7, CASE WHEN :INDOTROS =1 THEN C15+C16+C17+C20 WHEN :INDOTROS =2 THEN C15 +C16+C17+C18 ELSE C15 +C16+C17+C18+C19+C20 END OTROS  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :PREDIO AND NUMERO_ORDEN = :NUMERO AND PAGADO IN (0) AND NOCOBRADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"C8":"$C8","C9":"$C9","C10":"$C10","C11":"$C11","C12":"$C12","C13":"$C13","C14":"$C14","C15":"$C15","C16":"$C16","C17":"$C17","C18":"$C18","C19":"$C19","C20":"$C20","PAGADO":"$PAGADO(type:boolean)","TRPPOR":"$TRPPOR","NOCOBRADO":"$NOCOBRADO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","NUMRESOLUCION":"$NUMRESOLUCION","AVALUOANT":"$AVALUOANT","TARIFAANT":"$TARIFAANT","AREAHE":"$AREAHE","AREAM2":"$AREAM2","USUARIO":"$USUARIO","FECHAPAGO":"$FECHAPAGO","FECHAPRESCRIPCION":"$FECHAPRESCRIPCION","TOTALABONADO":"$TOTALABONADO","VALORULTIMOABONO":"$VALORULTIMOABONO","FECHAULTIMOABONO":"$FECHAULTIMOABONO","ALDIAINTERES":"$ALDIAINTERES","INDPAGO_ACPAG":"$INDPAGO_ACPAG(type:boolean)","FINANCIAR":"$FINANCIAR(type:boolean)","CNT":"$CNT(type:boolean)","C1_CNT":"$C1_CNT","TOTALABONADO1":"$TOTALABONADO1","VALORULTIMOABONO1":"$VALORULTIMOABONO1","FECHAULTIMOABONO1":"$FECHAULTIMOABONO1","ALDIAINTERES1":"$ALDIAINTERES1","TOTALABONADO2":"$TOTALABONADO2","VALORULTIMOABONO2":"$VALORULTIMOABONO2","FECHAULTIMOABONO2":"$FECHAULTIMOABONO2","ALDIAINTERES2":"$ALDIAINTERES2","DOCNUMABONO":"$DOCNUMABONO","DOCNUMABONO1":"$DOCNUMABONO1","DOCNUMABONO2":"$DOCNUMABONO2","INDPAGO_CUOTAS":"$INDPAGO_CUOTAS(type:boolean)","TOTALCUOTA":"$TOTALCUOTA","PAGFECCUOTA":"$PAGFECCUOTA","PAGNCUOTA":"$PAGNCUOTA","DOCNUMCUOTA":"$DOCNUMCUOTA","TOTALCUOTA1":"$TOTALCUOTA1","PAGFECCUOTA1":"$PAGFECCUOTA1","PAGNCUOTA1":"$PAGNCUOTA1","DOCNUMCUOTA1":"$DOCNUMCUOTA1","TOTALCUOTA2":"$TOTALCUOTA2","PAGFECCUOTA2":"$PAGFECCUOTA2","PAGNCUOTA2":"$PAGNCUOTA2","DOCNUMCUOTA2":"$DOCNUMCUOTA2","C18_CNT":"$C18_CNT","TOTALABONO1":"$TOTALABONO1","TOTALABONO2":"$TOTALABONO2","PREANO_EXONERADO":"$PREANO_EXONERADO(type:boolean)","C1_CPY":"$C1_CPY","IND_C1CPY":"$IND_C1CPY(type:boolean)","ALDIAINTERESCAR":"$ALDIAINTERESCAR","ALDIAINTERES1CAR":"$ALDIAINTERES1CAR","ALDIAINTERES2CAR":"$ALDIAINTERES2CAR","C3_CPY":"$C3_CPY","IND_C3CPY":"$IND_C3CPY(type:boolean)","SINDESCUENTOS":"$SINDESCUENTOS(type:boolean)","AUDITADESC":"$AUDITADESC","DESC_INTERES":"$DESC_INTERES","C1_EXE":"$C1_EXE","C2_EXE":"$C2_EXE","C3_EXE":"$C3_EXE","C4_EXE":"$C4_EXE","INDEXEOTROS":"$INDEXEOTROS(type:boolean)","C13_EXE":"$C13_EXE","C14_EXE":"$C14_EXE","C15_EXE":"$C15_EXE","C16_EXE":"$C16_EXE","C17_EXE":"$C17_EXE","C18_EXE":"$C18_EXE","C19_EXE":"$C19_EXE","C20_EXE":"$C20_EXE","DESESPC13":"$DESESPC13","DESESPC2":"$DESESPC2","DESESPC4":"$DESESPC4","DESESPC14":"$DESESPC14","DESESPC15":"$DESESPC15","DESESPC16":"$DESESPC16","DESESPC17":"$DESESPC17","DESESPC18":"$DESESPC18","DESESPC19":"$DESESPC19","DESESPC20":"$DESESPC20","IND_PROCESOJUD":"$IND_PROCESOJUD(type:boolean)","AREA_CONSTRUIDA":"$AREA_CONSTRUIDA","FECHA_CAMBIO_AVALUO":"$FECHA_CAMBIO_AVALUO","CAMBIO_AVALUO":"$CAMBIO_AVALUO","TRP_POR":"$TRP_POR","ES_AUTOAVALUO":"$ES_AUTOAVALUO(type:boolean)","CONSECUTIVO":"$CONSECUTIVO","PORCENTAJE_RESERVA":"$PORCENTAJE_RESERVA","RESOLUCION_RESERVA":"$RESOLUCION_RESERVA","RESOLUCION_DESRESERVA":"$RESOLUCION_DESRESERVA","TEMPORAL":"$TEMPORAL","IND_EXEINT_DUP":"$IND_EXEINT_DUP(type:boolean)","APROBADOFISC":"$APROBADOFISC(type:boolean)","INCR_AUTOAVALUO":"$INCR_AUTOAVALUO(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","TRPCOD":"$TRPCOD","TRPRAN":"$TRPRAN","PREFEC":"$PREFEC","DOCNUM":"$DOCNUM","PAG_BAN":"$PAG_BAN","PREVAL":"$PREVAL","USUARIO_CREADOR_REGISTRO":"$USUARIO_CREADOR_REGISTRO","FECHA_CREACION_REGISTRO":"$FECHA_CREACION_REGISTRO","USUARIO_MODIFICO_REGISTRO":"$USUARIO_MODIFICO_REGISTRO","FECHA_MODIFICACION_REGISTRO":"$FECHA_MODIFICACION_REGISTRO","AVALUO":"$AVALUO","TRPFOR":"$TRPFOR","PREIND":"$PREIND","SALDOCREDITO":"$SALDOCREDITO","ABONOS":"$ABONOS","INDHIP":"$INDHIP(type:boolean)","INDCAR":"$INDCAR(type:boolean)","INDEXE":"$INDEXE(type:boolean)","ANTERIOR_RURAL":"$ANTERIOR_RURAL(type:boolean)","TOTAL":"$TOTAL","C1":"$C1","C2":"$C2","C3":"$C3","C4":"$C4","C5":"$C5","C6":"$C6","C7":"$C7","OTROS":"$OTROS(type:integer)"}]}}		</result>
		<param name="INDOTROS" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
