			<with-param name="ANOPAGO" query-param="ANOPAGO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosExisteAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TRPANO  FROM IP_FACTURADOS INNER JOIN IP_TARIFAS ON IP_FACTURADOS.COMPANIA = IP_TARIFAS.COMPANIA AND IP_FACTURADOS.TRPCOD = IP_TARIFAS.TRPCOD AND IP_FACTURADOS.PREANO = IP_TARIFAS.TRPANO AND IP_FACTURADOS.TRPRAN = IP_TARIFAS.TRPRAN WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_TARIFAS.TRPANO = :TRPANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TRPANO":"$TRPANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TRPANO" sqlType="STRING"/>

	</query>
