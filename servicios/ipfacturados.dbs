			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosPagDetalleDeclaracionAutoavaluoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, IP_FACTURADOS.PREANO, IP_FACTURADOS.AVALUO, IP_FACTURADOS.TRPCOD, IP_TARIFAS.TRPDES FROM IP_FACTURADOS INNER JOIN IP_TARIFAS ON IP_FACTURADOS.TRPRAN = IP_TARIFAS.TRPRAN AND IP_FACTURADOS.TRPCOD = IP_TARIFAS.TRPCOD AND IP_FACTURADOS.PREANO = IP_TARIFAS.TRPANO WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.NUMERO_ORDEN = :NUMEROORDEN AND IP_FACTURADOS.CODIGO = :CODIGO AND IP_FACTURADOS.NOCOBRADO = 0 AND IP_FACTURADOS.INDPAGO_ACPAG = 0 AND IP_FACTURADOS.PAGADO = 0 ORDER BY IP_FACTURADOS.PREANO) INI WHERE (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END) LIKE UPPER(CONCAT(:PAGADO, '%')) AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END) LIKE UPPER(CONCAT(:PREANO, '%')) AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END) LIKE UPPER(CONCAT(:AVALUO, '%')) AND (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END) LIKE UPPER(CONCAT(:TRPCOD, '%')) AND (CASE WHEN TRPDES IS NULL THEN ' ' ELSE UPPER(TRPDES) END) LIKE UPPER(CONCAT(CONCAT('%',:TRPDES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAGADO":"$PAGADO(type:boolean)","PREANO":"$PREANO(type:integer)","AVALUO":"$AVALUO","TRPCOD":"$TRPCOD","TRPDES":"$TRPDES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAGADO" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="TRPDES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipfacturados/detalledeclaracionautoavaluo/pag">
		<call-query href="getIpfacturadosPagDetalleDeclaracionAutoavaluoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAGADO" query-param="PAGADO"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="TRPCOD" query-param="TRPCOD"/>
			<with-param name="TRPDES" query-param="TRPDES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosNumDetalleDeclaracionAutoavaluoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, IP_FACTURADOS.PREANO, IP_FACTURADOS.AVALUO, IP_FACTURADOS.TRPCOD, IP_TARIFAS.TRPDES FROM IP_FACTURADOS INNER JOIN IP_TARIFAS ON IP_FACTURADOS.TRPRAN = IP_TARIFAS.TRPRAN AND IP_FACTURADOS.TRPCOD = IP_TARIFAS.TRPCOD AND IP_FACTURADOS.PREANO = IP_TARIFAS.TRPANO WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.NUMERO_ORDEN = :NUMEROORDEN AND IP_FACTURADOS.CODIGO = :CODIGO AND IP_FACTURADOS.NOCOBRADO = 0 AND IP_FACTURADOS.INDPAGO_ACPAG = 0 AND IP_FACTURADOS.PAGADO = 0 ORDER BY IP_FACTURADOS.PREANO) INI WHERE (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END) LIKE UPPER(CONCAT(:PAGADO, '%')) AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END) LIKE UPPER(CONCAT(:PREANO, '%')) AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END) LIKE UPPER(CONCAT(:AVALUO, '%')) AND (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END) LIKE UPPER(CONCAT(:TRPCOD, '%')) AND (CASE WHEN TRPDES IS NULL THEN ' ' ELSE UPPER(TRPDES) END) LIKE UPPER(CONCAT(CONCAT('%',:TRPDES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAGADO" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="TRPDES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/detalledeclaracionautoavaluo/num">
		<call-query href="getIpfacturadosNumDetalleDeclaracionAutoavaluoQuery">
