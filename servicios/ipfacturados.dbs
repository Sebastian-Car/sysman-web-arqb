	<query id="updateIpfacturadosConceptosFacturacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_FACTURADOS SET C8=:C8, C7=:C7, CODIGO=:CODIGO, C9=:C9, C4=:C4, C3=:C3, C6=:C6, PREANO=:PREANO, C5=:C5, NUMERO_ORDEN=:NUMERO_ORDEN, TOTAL=:TOTAL, C20=:C20, C3_CPY=:C3_CPY, C1=:C1, C2=:C2, C16=:C16, C17=:C17, C18=:C18, C19=:C19, PAGADO=:PAGADO, C10=:C10, C11=:C11, C12=:C12, C13=:C13, C14=:C14, C15=:C15, COMPANIA=:COMPANIA, AVALUO=:AVALUO, C1_CPY=:C1_CPY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_FACTURADOS.COMPANIA= :KEY_COMPANIA AND IP_FACTURADOS.CODIGO= :KEY_CODIGO AND IP_FACTURADOS.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_FACTURADOS.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

