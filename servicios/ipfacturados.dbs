<data name="ipfacturados" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpfacturadosAnosFacturadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(0) ANOSFACT  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND NUMERO_ORDEN = :NUMERO_ORDEN AND PAGADO IN (0) AND NOCOBRADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANOSFACT":"$ANOSFACT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/anosfacturados">
		<call-query href="getIpfacturadosAnosFacturadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosTodosFacturadosPagadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' FACTURADOS  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND NUMERO_ORDEN = :NUMERO_ORDEN AND PAGADO NOT IN (0) HAVING SUM(DESESPC2 + DESESPC4 + DESESPC13 + DESESPC14 + DESESPC15 + DESESPC16 + DESESPC17 + DESESPC18 + DESESPC19 + DESESPC20) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FACTURADOS":"$FACTURADOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/todosfacturadospagados">
		<call-query href="getIpfacturadosTodosFacturadosPagadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosAcuerdosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOS.COMPANIA, IP_FACTURADOS.CODIGO, IP_FACTURADOS.NUMERO_ORDEN, IP_FACTURADOS.PREANO, (C1 + C3 ) IMPUESTO, (C2 + C4 ) INTERESES, (C13 + C14 + C15 + C16 + C17 + C18 + C19 + C20 ) OTROS, IP_FACTURADOS.TOTAL,(CASE IP_FACTURADOS.FINANCIAR WHEN 0 THEN 'false' ELSE 'true' END) FINANCIAR FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :CODIGO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_FACTURADOS.PAGADO IN(0) AND IP_FACTURADOS.INDPAGO_ACPAG IN (0) AND IP_FACTURADOS.IND_PROCESOJUD IN(0) ORDER BY IP_FACTURADOS.PREANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","IMPUESTO":"$IMPUESTO(type:integer)","INTERESES":"$INTERESES(type:integer)","OTROS":"$OTROS(type:integer)","TOTAL":"$TOTAL","FINANCIAR":"$FINANCIAR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/acuerdosporcodigo">
		<call-query href="getIpfacturadosAcuerdosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosCargarTotalesFinanciamientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(SUM(TOTAL), '99,999,999,999,999,990.90') TOTALDEUDA, SUM(TOTAL) TOTALDEUDASF, TO_CHAR(SUM(CASE WHEN FINANCIAR &lt;&gt; 0 THEN TOTAL ELSE 0 END), '99,999,999,999,999,990.90') TOTALFINANCIAR, SUM(CASE WHEN FINANCIAR &lt;&gt; 0 THEN TOTAL ELSE 0 END) TOTALFINANCIARSF  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND NUMERO_ORDEN = :NUMERO_ORDEN AND PAGADO IN (0) AND NOCOBRADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTALDEUDA":"$TOTALDEUDA","TOTALDEUDASF":"$TOTALDEUDASF(type:integer)","TOTALFINANCIAR":"$TOTALFINANCIAR","TOTALFINANCIARSF":"$TOTALFINANCIARSF(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/cargartotalesfinanciamiento">
		<call-query href="getIpfacturadosCargarTotalesFinanciamientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="updateIpfacturadosActualizarFinanciamiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_FACTURADOS SET CODIGO=:CODIGO, COMPANIA=:COMPANIA, NUMERO_ORDEN=:NUMERO_ORDEN, FINANCIAR=:FINANCIAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_FACTURADOS.COMPANIA= :KEY_COMPANIA AND IP_FACTURADOS.CODIGO= :KEY_CODIGO AND IP_FACTURADOS.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_FACTURADOS.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="FINANCIAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="KEY_PREANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipfacturados/actualizarfinanciamiento">
		<call-query href="updateIpfacturadosActualizarFinanciamiento">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="FINANCIAR" query-param="FINANCIAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_NUMERO_ORDEN" query-param="KEY_NUMERO_ORDEN"/>
			<with-param name="KEY_PREANO" query-param="KEY_PREANO"/>

		</call-query>
	</resource>
	<query id="updateIpfacturadosNegarFinanciamientosPorCodigo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_FACTURADOS SET FINANCIAR = 0,DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY  WHERE COMPANIA = :COMPANIA    AND CODIGO = :CODIGO   AND NUMERO_ORDEN = :NUMERO_ORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipfacturados/negarfinanciamientosporcodigo">
		<call-query href="updateIpfacturadosNegarFinanciamientosPorCodigo">
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosCantidadVigenciasAFinanciarQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(PREANO) PREANOMAX, COUNT(FINANCIAR) VIGENCIAS  FROM IP_FACTURADOS WHERE FINANCIAR &lt;&gt; 0 GROUP BY CODIGO HAVING CODIGO= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANOMAX":"$PREANOMAX(type:integer)","VIGENCIAS":"$VIGENCIAS(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/cantidadvigenciasafinanciar">
		<call-query href="getIpfacturadosCantidadVigenciasAFinanciarQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosPagListadodetalledeudaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_FACTURADOS.COMPANIA, IP_FACTURADOS.CODIGO, IP_FACTURADOS.NUMERO_ORDEN, IP_FACTURADOS.PREANO, TRPPOR * 1000 TARIFA, IP_FACTURADOS.AVALUO, IP_FACTURADOS.C1, IP_FACTURADOS.C2, IP_FACTURADOS.C3, IP_FACTURADOS.C4, IP_FACTURADOS.C13, (IP_FACTURADOS.TOTAL - (IP_FACTURADOS.C1 + IP_FACTURADOS.C2 + IP_FACTURADOS.C3 + IP_FACTURADOS.C4 + IP_FACTURADOS.C13)) OTROS, IP_FACTURADOS.TOTAL,(CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :CODIGO_PREDIO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORD AND IP_FACTURADOS.PAGADO IN(0) AND IP_FACTURADOS.NOCOBRADO IN(0) AND IP_FACTURADOS.INDPAGO_ACPAG IN(0) ORDER BY IP_FACTURADOS.PREANO) WHERE (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%')  AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END)  LIKE UPPER(:TARIFA || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER(:AVALUO || '%')  AND (CASE WHEN C1 IS NULL THEN ' ' ELSE UPPER(C1) END)  LIKE UPPER(:C1 || '%')  AND (CASE WHEN C2 IS NULL THEN ' ' ELSE UPPER(C2) END)  LIKE UPPER(:C2 || '%')  AND (CASE WHEN C3 IS NULL THEN ' ' ELSE UPPER(C3) END)  LIKE UPPER(:C3 || '%')  AND (CASE WHEN C4 IS NULL THEN ' ' ELSE UPPER(C4) END)  LIKE UPPER(:C4 || '%')  AND (CASE WHEN C13 IS NULL THEN ' ' ELSE UPPER(C13) END)  LIKE UPPER(:C13 || '%')  AND (CASE WHEN OTROS IS NULL THEN ' ' ELSE UPPER(OTROS) END)  LIKE UPPER(:OTROS || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER(:TOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","TARIFA":"$TARIFA(type:integer)","AVALUO":"$AVALUO","C1":"$C1","C2":"$C2","C3":"$C3","C4":"$C4","C13":"$C13","OTROS":"$OTROS(type:integer)","TOTAL":"$TOTAL","PAGADO":"$PAGADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PREDIO" sqlType="STRING"/>
		<param name="NUMERO_ORD" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="C1" sqlType="STRING"/>
		<param name="C2" sqlType="STRING"/>
		<param name="C3" sqlType="STRING"/>
		<param name="C4" sqlType="STRING"/>
		<param name="C13" sqlType="STRING"/>
		<param name="OTROS" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipfacturados/listadodetalledeuda/pag">
		<call-query href="getIpfacturadosPagListadodetalledeudaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PREDIO" query-param="CODIGO_PREDIO"/>
			<with-param name="NUMERO_ORD" query-param="NUMERO_ORD"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="C1" query-param="C1"/>
			<with-param name="C2" query-param="C2"/>
			<with-param name="C3" query-param="C3"/>
			<with-param name="C4" query-param="C4"/>
			<with-param name="C13" query-param="C13"/>
			<with-param name="OTROS" query-param="OTROS"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertIpfacturados" keyColumns="COMPANIA,CODIGO,NUMERO_ORDEN,PREANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_FACTURADOS (COMPANIA, CODIGO, NUMERO_ORDEN, PREANO, AVALUO, TRPCOD, TRPPOR, TRPRAN, PREIND, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NUMERO_ORDEN, :PREANO, :AVALUO, :TRPCOD, :TRPPOR, :TRPRAN, :PREIND, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_NUMERO_ORDEN":"$NUMERO_ORDEN","KEY_PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param defaultValue="0" name="AVALUO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param defaultValue="0" name="TRPPOR" sqlType="STRING"/>
		<param name="TRPRAN" sqlType="STRING"/>
		<param defaultValue="" name="PREIND" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ipfacturados">
		<call-query href="insertIpfacturados">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="TRPCOD" query-param="TRPCOD"/>
			<with-param name="TRPPOR" query-param="TRPPOR"/>
			<with-param name="TRPRAN" query-param="TRPRAN"/>
			<with-param name="PREIND" query-param="PREIND"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteIpfacturados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA= :KEY_COMPANIA AND IP_FACTURADOS.CODIGO= :KEY_CODIGO AND IP_FACTURADOS.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_FACTURADOS.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="KEY_PREANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="ipfacturados">
		<call-query href="deleteIpfacturados">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_NUMERO_ORDEN" query-param="KEY_NUMERO_ORDEN"/>
			<with-param name="KEY_PREANO" query-param="KEY_PREANO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_FACTURADOS.COMPANIA, IP_FACTURADOS.CODIGO, IP_FACTURADOS.PREANO, IP_FACTURADOS.NUMERO_ORDEN, IP_FACTURADOS.AVALUO, IP_FACTURADOS.PREIND, CASE WHEN IP_FACTURADOS.PREIND = 'M' THEN 'Manual' ELSE 'Retroactivo' END PREINDT, IP_FACTURADOS.TRPRAN, IP_FACTURADOS.TRPCOD,(CASE IP_FACTURADOS.INDHIP WHEN 0 THEN 'false' ELSE 'true' END) INDHIP,(CASE IP_FACTURADOS.INDCAR WHEN 0 THEN 'false' ELSE 'true' END) INDCAR,(CASE IP_FACTURADOS.INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE,(CASE IP_FACTURADOS.ANTERIOR_RURAL WHEN 0 THEN 'false' ELSE 'true' END) ANTERIOR_RURAL,(CASE IP_FACTURADOS.NOCOBRADO WHEN 0 THEN 'false' ELSE 'true' END) NOCOBRADO, IP_FACTURADOS.OBSERVACIONES,(TO_CHAR(IP_FACTURADOS.PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, IP_FACTURADOS.DOCNUM, IP_FACTURADOS.PAG_BAN, IP_FACTURADOS.PREVAL, IP_FACTURADOS.TRPPOR,(CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, TO_CHAR(IP_FACTURADOS.FECHAPAGO,'DD/MM/YYYY') FECHAPAGO, TO_CHAR(IP_FACTURADOS.FECHAPRESCRIPCION,'DD/MM/YYYY') FECHAPRESCRIPCION, IP_FACTURADOS.TOTALABONADO, IP_FACTURADOS.VALORULTIMOABONO, TO_CHAR(IP_FACTURADOS.FECHAULTIMOABONO,'DD/MM/YYYY') FECHAULTIMOABONO,(CASE IP_FACTURADOS.INDPAGO_ACPAG WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_ACPAG,(CASE IP_FACTURADOS.INDEXEOTROS WHEN 0 THEN 'false' ELSE 'true' END) INDEXEOTROS,(CASE IP_FACTURADOS.INDPAGO_CUOTAS WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_CUOTAS,(CASE IP_FACTURADOS.IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD, IP_FACTURADOS.AREAM2, IP_FACTURADOS.AREA_CONSTRUIDA, IP_FACTURADOS.TOTAL  FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :CODIGOPREDIO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_FACTURADOS.PREANO DESC, IP_FACTURADOS.CODIGO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%')  AND (CASE WHEN NUMERO_ORDEN IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDEN) END)  LIKE UPPER(:NUMERO_ORDEN || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER(:AVALUO || '%')  AND (CASE WHEN PREIND IS NULL THEN ' ' ELSE UPPER(PREIND) END)  LIKE UPPER(:PREIND || '%')  AND (CASE WHEN PREINDT IS NULL THEN ' ' ELSE UPPER(PREINDT) END)  LIKE UPPER(:PREINDT || '%')  AND (CASE WHEN TRPRAN IS NULL THEN ' ' ELSE UPPER(TRPRAN) END)  LIKE UPPER(:TRPRAN || '%')  AND (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER(:TRPCOD || '%')  AND (CASE WHEN INDHIP IS NULL THEN ' ' ELSE UPPER(INDHIP) END)  LIKE UPPER(:INDHIP || '%')  AND (CASE WHEN INDCAR IS NULL THEN ' ' ELSE UPPER(INDCAR) END)  LIKE UPPER(:INDCAR || '%')  AND (CASE WHEN INDEXE IS NULL THEN ' ' ELSE UPPER(INDEXE) END)  LIKE UPPER(:INDEXE || '%')  AND (CASE WHEN ANTERIOR_RURAL IS NULL THEN ' ' ELSE UPPER(ANTERIOR_RURAL) END)  LIKE UPPER(:ANTERIOR_RURAL || '%')  AND (CASE WHEN NOCOBRADO IS NULL THEN ' ' ELSE UPPER(NOCOBRADO) END)  LIKE UPPER(:NOCOBRADO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER(:OBSERVACIONES || '%')  AND (CASE WHEN PREFEC IS NULL THEN ' ' ELSE UPPER(PREFEC) END)  LIKE UPPER(:PREFEC || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER(:PAG_BAN || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER(:PREVAL || '%')  AND (CASE WHEN TRPPOR IS NULL THEN ' ' ELSE UPPER(TRPPOR) END)  LIKE UPPER(:TRPPOR || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER(:PAGADO || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER(:FECHAPAGO || '%')  AND (CASE WHEN FECHAPRESCRIPCION IS NULL THEN ' ' ELSE UPPER(FECHAPRESCRIPCION) END)  LIKE UPPER(:FECHAPRESCRIPCION || '%')  AND (CASE WHEN TOTALABONADO IS NULL THEN ' ' ELSE UPPER(TOTALABONADO) END)  LIKE UPPER(:TOTALABONADO || '%')  AND (CASE WHEN VALORULTIMOABONO IS NULL THEN ' ' ELSE UPPER(VALORULTIMOABONO) END)  LIKE UPPER(:VALORULTIMOABONO || '%')  AND (CASE WHEN FECHAULTIMOABONO IS NULL THEN ' ' ELSE UPPER(FECHAULTIMOABONO) END)  LIKE UPPER(:FECHAULTIMOABONO || '%')  AND (CASE WHEN INDPAGO_ACPAG IS NULL THEN ' ' ELSE UPPER(INDPAGO_ACPAG) END)  LIKE UPPER(:INDPAGO_ACPAG || '%')  AND (CASE WHEN INDEXEOTROS IS NULL THEN ' ' ELSE UPPER(INDEXEOTROS) END)  LIKE UPPER(:INDEXEOTROS || '%')  AND (CASE WHEN INDPAGO_CUOTAS IS NULL THEN ' ' ELSE UPPER(INDPAGO_CUOTAS) END)  LIKE UPPER(:INDPAGO_CUOTAS || '%')  AND (CASE WHEN IND_PROCESOJUD IS NULL THEN ' ' ELSE UPPER(IND_PROCESOJUD) END)  LIKE UPPER(:IND_PROCESOJUD || '%')  AND (CASE WHEN AREAM2 IS NULL THEN ' ' ELSE UPPER(AREAM2) END)  LIKE UPPER(:AREAM2 || '%')  AND (CASE WHEN AREA_CONSTRUIDA IS NULL THEN ' ' ELSE UPPER(AREA_CONSTRUIDA) END)  LIKE UPPER(:AREA_CONSTRUIDA || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","PREANO":"$PREANO(type:integer)","NUMERO_ORDEN":"$NUMERO_ORDEN","AVALUO":"$AVALUO","PREIND":"$PREIND","PREINDT":"$PREINDT","TRPRAN":"$TRPRAN","TRPCOD":"$TRPCOD","INDHIP":"$INDHIP(type:boolean)","INDCAR":"$INDCAR(type:boolean)","INDEXE":"$INDEXE(type:boolean)","ANTERIOR_RURAL":"$ANTERIOR_RURAL(type:boolean)","NOCOBRADO":"$NOCOBRADO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","PREFEC":"$PREFEC","DOCNUM":"$DOCNUM","PAG_BAN":"$PAG_BAN","PREVAL":"$PREVAL","TRPPOR":"$TRPPOR","PAGADO":"$PAGADO(type:boolean)","FECHAPAGO":"$FECHAPAGO","FECHAPRESCRIPCION":"$FECHAPRESCRIPCION","TOTALABONADO":"$TOTALABONADO","VALORULTIMOABONO":"$VALORULTIMOABONO","FECHAULTIMOABONO":"$FECHAULTIMOABONO","INDPAGO_ACPAG":"$INDPAGO_ACPAG(type:boolean)","INDEXEOTROS":"$INDEXEOTROS(type:boolean)","INDPAGO_CUOTAS":"$INDPAGO_CUOTAS(type:boolean)","IND_PROCESOJUD":"$IND_PROCESOJUD(type:boolean)","AREAM2":"$AREAM2","AREA_CONSTRUIDA":"$AREA_CONSTRUIDA","TOTAL":"$TOTAL"}]}}		</result>
