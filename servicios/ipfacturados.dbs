	<query id="getIpfacturadosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_FACTURADOS.COMPANIA, IP_FACTURADOS.CODIGO, IP_FACTURADOS.PREANO, IP_FACTURADOS.NUMERO_ORDEN, IP_FACTURADOS.AVALUO, IP_FACTURADOS.PREIND, CASE WHEN IP_FACTURADOS.PREIND = 'M' THEN 'Manual' ELSE 'Retroactivo' END PREINDT, IP_FACTURADOS.TRPRAN, IP_FACTURADOS.TRPCOD,(CASE IP_FACTURADOS.INDHIP WHEN 0 THEN 'false' ELSE 'true' END) INDHIP,(CASE IP_FACTURADOS.INDCAR WHEN 0 THEN 'false' ELSE 'true' END) INDCAR,(CASE IP_FACTURADOS.INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE,(CASE IP_FACTURADOS.ANTERIOR_RURAL WHEN 0 THEN 'false' ELSE 'true' END) ANTERIOR_RURAL,(CASE IP_FACTURADOS.NOCOBRADO WHEN 0 THEN 'false' ELSE 'true' END) NOCOBRADO, IP_FACTURADOS.OBSERVACIONES,(TO_CHAR(IP_FACTURADOS.PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, IP_FACTURADOS.DOCNUM, IP_FACTURADOS.PAG_BAN, IP_FACTURADOS.PREVAL, IP_FACTURADOS.TRPPOR,(CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, TO_CHAR(IP_FACTURADOS.FECHAPAGO,'DD/MM/YYYY') FECHAPAGO, TO_CHAR(IP_FACTURADOS.FECHAPRESCRIPCION,'DD/MM/YYYY') FECHAPRESCRIPCION, IP_FACTURADOS.TOTALABONADO, IP_FACTURADOS.VALORULTIMOABONO, TO_CHAR(IP_FACTURADOS.FECHAULTIMOABONO,'DD/MM/YYYY') FECHAULTIMOABONO,(CASE IP_FACTURADOS.INDPAGO_ACPAG WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_ACPAG,(CASE IP_FACTURADOS.INDEXEOTROS WHEN 0 THEN 'false' ELSE 'true' END) INDEXEOTROS,(CASE IP_FACTURADOS.INDPAGO_CUOTAS WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_CUOTAS,(CASE IP_FACTURADOS.IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD, IP_FACTURADOS.AREAM2, IP_FACTURADOS.AREA_CONSTRUIDA, IP_FACTURADOS.TOTAL  FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.CODIGO = :CODIGOPREDIO AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_FACTURADOS.PREANO DESC, IP_FACTURADOS.CODIGO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN NUMERO_ORDEN IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDEN) END)  LIKE UPPER( '%' || :NUMERO_ORDEN || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN PREIND IS NULL THEN ' ' ELSE UPPER(PREIND) END)  LIKE UPPER( '%' || :PREIND || '%')  AND (CASE WHEN PREINDT IS NULL THEN ' ' ELSE UPPER(PREINDT) END)  LIKE UPPER( '%' || :PREINDT || '%')  AND (CASE WHEN TRPRAN IS NULL THEN ' ' ELSE UPPER(TRPRAN) END)  LIKE UPPER( '%' || :TRPRAN || '%')  AND (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER( '%' || :TRPCOD || '%')  AND (CASE WHEN INDHIP IS NULL THEN ' ' ELSE UPPER(INDHIP) END)  LIKE UPPER( '%' || :INDHIP || '%')  AND (CASE WHEN INDCAR IS NULL THEN ' ' ELSE UPPER(INDCAR) END)  LIKE UPPER( '%' || :INDCAR || '%')  AND (CASE WHEN INDEXE IS NULL THEN ' ' ELSE UPPER(INDEXE) END)  LIKE UPPER( '%' || :INDEXE || '%')  AND (CASE WHEN ANTERIOR_RURAL IS NULL THEN ' ' ELSE UPPER(ANTERIOR_RURAL) END)  LIKE UPPER( '%' || :ANTERIOR_RURAL || '%')  AND (CASE WHEN NOCOBRADO IS NULL THEN ' ' ELSE UPPER(NOCOBRADO) END)  LIKE UPPER( '%' || :NOCOBRADO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN PREFEC IS NULL THEN ' ' ELSE UPPER(PREFEC) END)  LIKE UPPER( '%' || :PREFEC || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER( '%' || :PAG_BAN || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER( '%' || :PREVAL || '%')  AND (CASE WHEN TRPPOR IS NULL THEN ' ' ELSE UPPER(TRPPOR) END)  LIKE UPPER( '%' || :TRPPOR || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%')  AND (CASE WHEN FECHAPRESCRIPCION IS NULL THEN ' ' ELSE UPPER(FECHAPRESCRIPCION) END)  LIKE UPPER( '%' || :FECHAPRESCRIPCION || '%')  AND (CASE WHEN TOTALABONADO IS NULL THEN ' ' ELSE UPPER(TOTALABONADO) END)  LIKE UPPER( '%' || :TOTALABONADO || '%')  AND (CASE WHEN VALORULTIMOABONO IS NULL THEN ' ' ELSE UPPER(VALORULTIMOABONO) END)  LIKE UPPER( '%' || :VALORULTIMOABONO || '%')  AND (CASE WHEN FECHAULTIMOABONO IS NULL THEN ' ' ELSE UPPER(FECHAULTIMOABONO) END)  LIKE UPPER( '%' || :FECHAULTIMOABONO || '%')  AND (CASE WHEN INDPAGO_ACPAG IS NULL THEN ' ' ELSE UPPER(INDPAGO_ACPAG) END)  LIKE UPPER( '%' || :INDPAGO_ACPAG || '%')  AND (CASE WHEN INDEXEOTROS IS NULL THEN ' ' ELSE UPPER(INDEXEOTROS) END)  LIKE UPPER( '%' || :INDEXEOTROS || '%')  AND (CASE WHEN INDPAGO_CUOTAS IS NULL THEN ' ' ELSE UPPER(INDPAGO_CUOTAS) END)  LIKE UPPER( '%' || :INDPAGO_CUOTAS || '%')  AND (CASE WHEN IND_PROCESOJUD IS NULL THEN ' ' ELSE UPPER(IND_PROCESOJUD) END)  LIKE UPPER( '%' || :IND_PROCESOJUD || '%')  AND (CASE WHEN AREAM2 IS NULL THEN ' ' ELSE UPPER(AREAM2) END)  LIKE UPPER( '%' || :AREAM2 || '%')  AND (CASE WHEN AREA_CONSTRUIDA IS NULL THEN ' ' ELSE UPPER(AREA_CONSTRUIDA) END)  LIKE UPPER( '%' || :AREA_CONSTRUIDA || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
