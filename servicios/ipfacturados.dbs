		<param defaultValue="0" name="AVALUOANT" sqlType="STRING"/>
		<param defaultValue="" name="TARIFAANT" sqlType="STRING"/>
		<param defaultValue="" name="PREIND" sqlType="STRING"/>
		<param defaultValue="0" name="NOCOBRADO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
