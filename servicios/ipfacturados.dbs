	<query id="insertIpfacturadosSubavaluosDosPorCodigo" keyColumns="COMPANIA,CODIGO,NUMERO_ORDEN,PREANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_FACTURADOS (COMPANIA, CODIGO, NUMERO_ORDEN, PREANO, TRPCOD, TRPRAN, PREFEC, AVALUO, TRPPOR, NUMRESOLUCION, AVALUOANT, TARIFAANT, PREIND, NOCOBRADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NUMERO_ORDEN, :PREANO, :TRPCOD, :TRPRAN, TO_DATE(:PREFEC,'DD/MM/YYYY HH24:MI:SS'), :AVALUO, :TRPPOR, :NUMRESOLUCION, :AVALUOANT, :TARIFAANT, :PREIND, :NOCOBRADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_NUMERO_ORDEN":"$NUMERO_ORDEN","KEY_PREANO":"$PREANO(type:integer)"}]}}		</result>
