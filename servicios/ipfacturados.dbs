	<query id="getIpfacturadosVerificarPagoPorCodigoYPreanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOS.TRPCOD, IP_FACTURADOS.PREANO,(CASE IP_FACTURADOS.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO FROM IP_FACTURADOS WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_FACTURADOS.CODIGO = :CODIGO AND IP_FACTURADOS.PREANO = :PREANO AND IP_FACTURADOS.PAGADO IN (0) AND IP_FACTURADOS.NOCOBRADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TRPCOD":"$TRPCOD","PREANO":"$PREANO(type:integer)","PAGADO":"$PAGADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/verificarpagoporcodigoypreano">
		<call-query href="getIpfacturadosVerificarPagoPorCodigoYPreanoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PREANO" query-param="PREANO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosSubavaluosPorResolucionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, PREANO, AVALUO, TRPCOD, NUMRESOLUCION, AVALUOANT, TARIFAANT  FROM IP_FACTURADOS WHERE COMPANIA= :COMPANIA AND NUMRESOLUCION= :RESOLUCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PREANO":"$PREANO(type:integer)","AVALUO":"$AVALUO","TRPCOD":"$TRPCOD","NUMRESOLUCION":"$NUMRESOLUCION","AVALUOANT":"$AVALUOANT","TARIFAANT":"$TARIFAANT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESOLUCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/subavaluosporresolucion">
		<call-query href="getIpfacturadosSubavaluosPorResolucionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosMaximoAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(PREANO) KEEP (DENSE_RANK LAST ORDER BY ROWNUM) PREANO  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :PREDIO AND PAGADO NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/maximoano">
		<call-query href="getIpfacturadosMaximoAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosAnosFacturadosPagadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) ANOS_FACTURADOS FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND NUMERO_ORDEN = :NUMERO_ORDEN AND PAGADO NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANOS_FACTURADOS":"$ANOS_FACTURADOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturados/anosfacturadospagados">
