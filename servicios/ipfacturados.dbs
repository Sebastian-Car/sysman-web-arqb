	<query id="updateIpfacturadosAvaluoTarifaEIndPagado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_FACTURADOS SET PAGADO = :PAGADO , AVALUO = :AVALUO , TRPCOD = :TRPCOD , USUARIO_MODIFICO_REGISTRO = :MODIFIED_BY , MODIFIED_BY = :MODIFIED_BY , DATE_MODIFIED = :DATE_MODIFIED WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMEROORDEN AND CODIGO = :CODIGO AND PREANO = :PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAGADO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>

	</query>
