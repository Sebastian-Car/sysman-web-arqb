	<query id="getIpfacturadosTodosPorPreanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT IP_FACTURADOS.PREANO  FROM IP_FACTURADOS INNER JOIN IP_USUARIOS_PREDIAL ON IP_FACTURADOS.COMPANIA = IP_USUARIOS_PREDIAL.COMPANIA AND IP_FACTURADOS.CODIGO = IP_USUARIOS_PREDIAL.CODIGO WHERE IP_FACTURADOS.COMPANIA = :COMPANIA AND IP_FACTURADOS.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_FACTURADOS.INDEXE IN(0) AND IP_FACTURADOS.NOCOBRADO IN(0) AND IP_FACTURADOS.PAGADO IN(0) ORDER BY IP_FACTURADOS.PREANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
