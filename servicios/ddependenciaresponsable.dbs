<data name="ddependenciaresponsable" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDdependenciaresponsableMaximoempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(NVL(ORDENDESUMINISTRO.VALORESTIMADO,0)),0) VLR_ACUMULADO  FROM D_DEPENDENCIA_RESPONSABLE INNER JOIN ORDENDESUMINISTRO ON D_DEPENDENCIA_RESPONSABLE.COMPANIA = ORDENDESUMINISTRO.COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA = ORDENDESUMINISTRO.DEPENDENCIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE = ORDENDESUMINISTRO.TERCERO AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL = ORDENDESUMINISTRO.SUCURSAL AND D_DEPENDENCIA_RESPONSABLE.ANO = TO_NUMBER(TO_CHAR(ORDENDESUMINISTRO.FECHA,'YYYY')) WHERE D_DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE = :RESPONSABLE AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL = :SUCURSAL AND D_DEPENDENCIA_RESPONSABLE.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLR_ACUMULADO":"$VLR_ACUMULADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ddependenciaresponsable/maximoempleado">
		<call-query href="getDdependenciaresponsableMaximoempleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDdependenciaresponsableMaximarequisicionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(NVL(D_DEPENDENCIA_RESPONSABLE.VLR_MAX_REQUISICIONES,0)),0) VLR_MAX  FROM D_DEPENDENCIA_RESPONSABLE WHERE D_DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE = :RESPONSABLE AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL = :SUCURSAL AND D_DEPENDENCIA_RESPONSABLE.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLR_MAX":"$VLR_MAX(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ddependenciaresponsable/maximarequisicion">
		<call-query href="getDdependenciaresponsableMaximarequisicionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertDdependenciaresponsable" keyColumns="COMPANIA,DEPENDENCIA,RESPONSABLE,SUCURSAL,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_DEPENDENCIA_RESPONSABLE (COMPANIA, DEPENDENCIA, RESPONSABLE, SUCURSAL, ANO, VLR_MAX_REQUISICIONES, VLR_REQUISICIONES_ACUM, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DEPENDENCIA, :RESPONSABLE, :SUCURSAL, :ANO, :VLR_MAX_REQUISICIONES, :VLR_REQUISICIONES_ACUM, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DEPENDENCIA":"$DEPENDENCIA","KEY_RESPONSABLE":"$RESPONSABLE","KEY_SUCURSAL":"$SUCURSAL","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="VLR_MAX_REQUISICIONES" sqlType="STRING"/>
		<param name="VLR_REQUISICIONES_ACUM" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ddependenciaresponsable">
		<call-query href="insertDdependenciaresponsable">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="VLR_MAX_REQUISICIONES" query-param="VLR_MAX_REQUISICIONES"/>
			<with-param name="VLR_REQUISICIONES_ACUM" query-param="VLR_REQUISICIONES_ACUM"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDdependenciaresponsable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_DEPENDENCIA_RESPONSABLE WHERE D_DEPENDENCIA_RESPONSABLE.COMPANIA= :KEY_COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA= :KEY_DEPENDENCIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE= :KEY_RESPONSABLE AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL= :KEY_SUCURSAL AND D_DEPENDENCIA_RESPONSABLE.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="ddependenciaresponsable">
		<call-query href="deleteDdependenciaresponsable">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_RESPONSABLE" query-param="KEY_RESPONSABLE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getDdependenciaresponsablePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_DEPENDENCIA_RESPONSABLE.COMPANIA, D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA, D_DEPENDENCIA_RESPONSABLE.RESPONSABLE, RESPONSABLES.NOMBRE NOMBRE_RESPONSABLE, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, D_DEPENDENCIA_RESPONSABLE.SUCURSAL, D_DEPENDENCIA_RESPONSABLE.ANO, D_DEPENDENCIA_RESPONSABLE.VLR_MAX_REQUISICIONES  FROM D_DEPENDENCIA_RESPONSABLE INNER JOIN DEPENDENCIA ON D_DEPENDENCIA_RESPONSABLE.COMPANIA = DEPENDENCIA.COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO RESPONSABLES ON D_DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLES.COMPANIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLES.NIT AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLES.SUCURSAL WHERE D_DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESPONSABLE) END)  LIKE UPPER( '%' || :NOMBRE_RESPONSABLE || '%')  AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBRE_DEPENDENCIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN VLR_MAX_REQUISICIONES IS NULL THEN ' ' ELSE UPPER(VLR_MAX_REQUISICIONES) END)  LIKE UPPER(:VLR_MAX_REQUISICIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","SUCURSAL":"$SUCURSAL","ANO":"$ANO(type:integer)","VLR_MAX_REQUISICIONES":"$VLR_MAX_REQUISICIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE_RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="VLR_MAX_REQUISICIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ddependenciaresponsable">
		<call-query href="getDdependenciaresponsablePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE_RESPONSABLE" query-param="NOMBRE_RESPONSABLE"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="VLR_MAX_REQUISICIONES" query-param="VLR_MAX_REQUISICIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDdependenciaresponsableNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_DEPENDENCIA_RESPONSABLE.COMPANIA, D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA, D_DEPENDENCIA_RESPONSABLE.RESPONSABLE, RESPONSABLES.NOMBRE NOMBRE_RESPONSABLE, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, D_DEPENDENCIA_RESPONSABLE.SUCURSAL, D_DEPENDENCIA_RESPONSABLE.ANO, D_DEPENDENCIA_RESPONSABLE.VLR_MAX_REQUISICIONES  FROM D_DEPENDENCIA_RESPONSABLE INNER JOIN DEPENDENCIA ON D_DEPENDENCIA_RESPONSABLE.COMPANIA = DEPENDENCIA.COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO RESPONSABLES ON D_DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLES.COMPANIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLES.NIT AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLES.SUCURSAL WHERE D_DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESPONSABLE) END)  LIKE UPPER( '%' || :NOMBRE_RESPONSABLE || '%')  AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBRE_DEPENDENCIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN VLR_MAX_REQUISICIONES IS NULL THEN ' ' ELSE UPPER(VLR_MAX_REQUISICIONES) END)  LIKE UPPER(:VLR_MAX_REQUISICIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE_RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="VLR_MAX_REQUISICIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ddependenciaresponsable/numero">
		<call-query href="getDdependenciaresponsableNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE_RESPONSABLE" query-param="NOMBRE_RESPONSABLE"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="VLR_MAX_REQUISICIONES" query-param="VLR_MAX_REQUISICIONES"/>

		</call-query>
	</resource>
	<query id="getDdependenciaresponsableRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  D_DEPENDENCIA_RESPONSABLE.COMPANIA, D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA, D_DEPENDENCIA_RESPONSABLE.RESPONSABLE, RESPONSABLES.NOMBRE NOMBRE_RESPONSABLE, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, D_DEPENDENCIA_RESPONSABLE.SUCURSAL, D_DEPENDENCIA_RESPONSABLE.ANO, D_DEPENDENCIA_RESPONSABLE.VLR_MAX_REQUISICIONES, D_DEPENDENCIA_RESPONSABLE.CREATED_BY, D_DEPENDENCIA_RESPONSABLE.MODIFIED_BY,(TO_CHAR(D_DEPENDENCIA_RESPONSABLE.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(D_DEPENDENCIA_RESPONSABLE.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED FROM D_DEPENDENCIA_RESPONSABLE INNER JOIN DEPENDENCIA ON D_DEPENDENCIA_RESPONSABLE.COMPANIA = DEPENDENCIA.COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO RESPONSABLES ON D_DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLES.COMPANIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLES.NIT AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLES.SUCURSAL WHERE D_DEPENDENCIA_RESPONSABLE.COMPANIA= :KEY_COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA= :KEY_DEPENDENCIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE= :KEY_RESPONSABLE AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL= :KEY_SUCURSAL AND D_DEPENDENCIA_RESPONSABLE.ANO= :KEY_ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","SUCURSAL":"$SUCURSAL","ANO":"$ANO(type:integer)","VLR_MAX_REQUISICIONES":"$VLR_MAX_REQUISICIONES","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ddependenciaresponsable/data">
		<call-query href="getDdependenciaresponsableRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_RESPONSABLE" query-param="KEY_RESPONSABLE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="updateDdependenciaresponsable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_DEPENDENCIA_RESPONSABLE SET COMPANIA=:COMPANIA, DEPENDENCIA=:DEPENDENCIA, RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, ANO=:ANO, VLR_MAX_REQUISICIONES=:VLR_MAX_REQUISICIONES, VLR_REQUISICIONES_ACUM=:VLR_REQUISICIONES_ACUM, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_DEPENDENCIA_RESPONSABLE.COMPANIA= :KEY_COMPANIA AND D_DEPENDENCIA_RESPONSABLE.DEPENDENCIA= :KEY_DEPENDENCIA AND D_DEPENDENCIA_RESPONSABLE.RESPONSABLE= :KEY_RESPONSABLE AND D_DEPENDENCIA_RESPONSABLE.SUCURSAL= :KEY_SUCURSAL AND D_DEPENDENCIA_RESPONSABLE.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="VLR_MAX_REQUISICIONES" sqlType="STRING"/>
		<param name="VLR_REQUISICIONES_ACUM" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ddependenciaresponsable">
		<call-query href="updateDdependenciaresponsable">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="VLR_MAX_REQUISICIONES" query-param="VLR_MAX_REQUISICIONES"/>
			<with-param name="VLR_REQUISICIONES_ACUM" query-param="VLR_REQUISICIONES_ACUM"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_RESPONSABLE" query-param="KEY_RESPONSABLE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>

</data>