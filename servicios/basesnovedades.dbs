<data name="basesnovedades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBasesnovedadesTotalesbasesQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(NVL(SUM(BASE),0), '99,999,999,999,999,990.90') BASE ,SUM(DIAS) DIAS , TO_CHAR(NVL(SUM(BASEPROPORCIONAL),0), '99,999,999,999,999,990.90') BASEPROPORCIONAL , TO_CHAR(NVL(SUM(APORTEPATRONALPENSION),0), '99,999,999,999,999,990.90') APORTEPATRONALPENSION , TO_CHAR(NVL(SUM(CASE WHEN NVL(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA_AUX,'REDONDEAR SEGURIDAD SOCIAL',6,SYSDATE),'SI') = 'SI' THEN APORTEEMPLEADOPENSION ELSE ROUND(APORTEEMPLEADOPENSION + 49,-2) END),0), '99,999,999,999,999,990.90') APORTEEMPLEADOPENSION , TO_CHAR(NVL(SUM(FSP),0), '99,999,999,999,999,990.90') FSP , TO_CHAR(NVL(SUM(FSPSUBSISTENCIA),0), '99,999,999,999,999,990.90') FSPSUBSISTENCIA , TO_CHAR(NVL(SUM(FSPADICIONAL),0), '99,999,999,999,999,990.90') FSPADICIONAL ,TO_CHAR(NVL(SUM(APORTEPATRONALSALUD),0), '99,999,999,999,999,990.90') APORTEPATRONALSALUD , TO_CHAR(NVL(SUM(CASE WHEN NVL(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA_AUX,'REDONDEAR SEGURIDAD SOCIAL',6,SYSDATE),'SI') = 'SI' THEN APORTEEMPLEADOSALUD ELSE ROUND(APORTEEMPLEADOSALUD + 49,-2) END),0), '99,999,999,999,999,990.90') APORTEEMPLEADOSALUD FROM BASESNOVEDADES WHERE COMPANIA = :COMPANIA_AUX AND ID_DE_EMPLEADO = :ID_DE_EMPLEADO_AUX AND ANO = :ANO_AUX AND MES = :MES_AUX GROUP BY ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BASE":"$BASE","DIAS":"$DIAS(type:integer)","BASEPROPORCIONAL":"$BASEPROPORCIONAL","APORTEPATRONALPENSION":"$APORTEPATRONALPENSION","APORTEEMPLEADOPENSION":"$APORTEEMPLEADOPENSION","FSP":"$FSP","FSPSUBSISTENCIA":"$FSPSUBSISTENCIA","FSPADICIONAL":"$FSPADICIONAL","APORTEPATRONALSALUD":"$APORTEPATRONALSALUD","APORTEEMPLEADOSALUD":"$APORTEEMPLEADOSALUD"}]}}		</result>
		<param name="COMPANIA_AUX" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO_AUX" sqlType="STRING"/>
		<param name="ANO_AUX" sqlType="STRING"/>
		<param name="MES_AUX" sqlType="STRING"/>

	</query>
	<resource method="GET" path="basesnovedades/totalesbases">
		<call-query href="getBasesnovedadesTotalesbasesQuery">
			<with-param name="COMPANIA_AUX" query-param="COMPANIA_AUX"/>
			<with-param name="ID_DE_EMPLEADO_AUX" query-param="ID_DE_EMPLEADO_AUX"/>
			<with-param name="ANO_AUX" query-param="ANO_AUX"/>
			<with-param name="MES_AUX" query-param="MES_AUX"/>

		</call-query>
	</resource>
	<query id="deleteBasesnovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BASESNOVEDADES WHERE BASESNOVEDADES.COMPANIA= :KEY_COMPANIA AND BASESNOVEDADES.LLAVENOVEDAD= :KEY_LLAVENOVEDAD AND BASESNOVEDADES.TIPONOVEDAD= :KEY_TIPONOVEDAD AND BASESNOVEDADES.CONSECUTIVO= :KEY_CONSECUTIVO AND BASESNOVEDADES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND BASESNOVEDADES.ANO= :KEY_ANO AND BASESNOVEDADES.MES= :KEY_MES</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_LLAVENOVEDAD" sqlType="STRING"/>
		<param name="KEY_TIPONOVEDAD" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="basesnovedades">
		<call-query href="deleteBasesnovedades">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_LLAVENOVEDAD" query-param="KEY_LLAVENOVEDAD"/>
			<with-param name="KEY_TIPONOVEDAD" query-param="KEY_TIPONOVEDAD"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>

		</call-query>
	</resource>
	<query id="getBasesnovedadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BASESNOVEDADES.COMPANIA, BASESNOVEDADES.LLAVENOVEDAD, BASESNOVEDADES.TIPONOVEDAD, BASESNOVEDADES.CONSECUTIVO, BASESNOVEDADES.ID_DE_EMPLEADO, BASESNOVEDADES.ANO, BASESNOVEDADES.MES, BASESNOVEDADES.PERIODO,(TO_CHAR(BASESNOVEDADES.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(BASESNOVEDADES.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, BASESNOVEDADES.BASE, BASESNOVEDADES.DIAS, BASESNOVEDADES.BASEPROPORCIONAL,(CASE BASESNOVEDADES.MANUAL WHEN 0 THEN 'false' ELSE 'true' END) MANUAL,(TO_CHAR(BASESNOVEDADES.FECHACAMBIOMANUAL,'DD/MM/YYYY HH24:MI:SS')) FECHACAMBIOMANUAL, CONCAT(CASE WHEN ID_DE_PROCESO = 10 THEN 'RETROACTIVO ' END , TIPOSBASESNOVEDADES.DESCRIPCION) DESCRIPCION, BASESNOVEDADES.APORTEPATRONALSALUD, CASE WHEN NVL(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA_AUX,'REDONDEAR SEGURIDAD SOCIAL',6,SYSDATE),'SI') = 'SI' THEN BASESNOVEDADES.APORTEEMPLEADOSALUD ELSE ROUND(BASESNOVEDADES.APORTEEMPLEADOSALUD + 49,-2) END AS APORTEEMPLEADOSALUD, BASESNOVEDADES.APORTEPATRONALPENSION, CASE WHEN NVL(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA_AUX,'REDONDEAR SEGURIDAD SOCIAL',6,SYSDATE),'SI') = 'SI' THEN BASESNOVEDADES.APORTEEMPLEADOPENSION ELSE ROUND(BASESNOVEDADES.APORTEEMPLEADOPENSION + 49,-2) END AS APORTEEMPLEADOPENSION, BASESNOVEDADES.FSP, BASESNOVEDADES.FSPSUBSISTENCIA, BASESNOVEDADES.FSPADICIONAL FROM BASESNOVEDADES INNER JOIN TIPOSBASESNOVEDADES ON BASESNOVEDADES.TIPONOVEDAD = TIPOSBASESNOVEDADES.CODIGO WHERE BASESNOVEDADES.COMPANIA =:COMPANIA_AUX AND BASESNOVEDADES.ID_DE_EMPLEADO =:ID_DE_EMPLEADO_AUX AND BASESNOVEDADES.ANO =:ANO_AUX AND BASESNOVEDADES.MES =:MES_AUX ORDER BY TIPONOVEDAD, PERIODO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN BASE IS NULL THEN ' ' ELSE UPPER(BASE) END) LIKE UPPER(CONCAT(:BASE, '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(:DIAS, '%')) AND (CASE WHEN BASEPROPORCIONAL IS NULL THEN ' ' ELSE UPPER(BASEPROPORCIONAL) END) LIKE UPPER(CONCAT(:BASEPROPORCIONAL, '%')) AND (CASE WHEN MANUAL IS NULL THEN ' ' ELSE UPPER(MANUAL) END) LIKE UPPER(CONCAT(:MANUAL, '%')) AND (CASE WHEN FECHACAMBIOMANUAL IS NULL THEN ' ' ELSE UPPER(FECHACAMBIOMANUAL) END) LIKE UPPER(CONCAT(:FECHACAMBIOMANUAL, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN APORTEPATRONALSALUD IS NULL THEN ' ' ELSE UPPER(APORTEPATRONALSALUD) END) LIKE UPPER(CONCAT(:APORTEPATRONALSALUD, '%')) AND (CASE WHEN APORTEEMPLEADOSALUD IS NULL THEN ' ' ELSE UPPER(APORTEEMPLEADOSALUD) END) LIKE UPPER(CONCAT(:APORTEEMPLEADOSALUD, '%')) AND (CASE WHEN APORTEPATRONALPENSION IS NULL THEN ' ' ELSE UPPER(APORTEPATRONALPENSION) END) LIKE UPPER(CONCAT(:APORTEPATRONALPENSION, '%')) AND (CASE WHEN APORTEEMPLEADOPENSION IS NULL THEN ' ' ELSE UPPER(APORTEEMPLEADOPENSION) END) LIKE UPPER(CONCAT(:APORTEEMPLEADOPENSION, '%')) AND (CASE WHEN FSP IS NULL THEN ' ' ELSE UPPER(FSP) END) LIKE UPPER(CONCAT(:FSP, '%')) AND (CASE WHEN FSPSUBSISTENCIA IS NULL THEN ' ' ELSE UPPER(FSPSUBSISTENCIA) END) LIKE UPPER(CONCAT(:FSPSUBSISTENCIA, '%')) AND (CASE WHEN FSPADICIONAL IS NULL THEN ' ' ELSE UPPER(FSPADICIONAL) END) LIKE UPPER(CONCAT(:FSPADICIONAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","LLAVENOVEDAD":"$LLAVENOVEDAD","TIPONOVEDAD":"$TIPONOVEDAD(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","BASE":"$BASE","DIAS":"$DIAS","BASEPROPORCIONAL":"$BASEPROPORCIONAL","MANUAL":"$MANUAL(type:boolean)","FECHACAMBIOMANUAL":"$FECHACAMBIOMANUAL","DESCRIPCION":"$DESCRIPCION","APORTEPATRONALSALUD":"$APORTEPATRONALSALUD","APORTEEMPLEADOSALUD":"$APORTEEMPLEADOSALUD","APORTEPATRONALPENSION":"$APORTEPATRONALPENSION","APORTEEMPLEADOPENSION":"$APORTEEMPLEADOPENSION","FSP":"$FSP","FSPSUBSISTENCIA":"$FSPSUBSISTENCIA","FSPADICIONAL":"$FSPADICIONAL"}]}}		</result>
		<param name="COMPANIA_AUX" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO_AUX" sqlType="STRING"/>
		<param name="ANO_AUX" sqlType="STRING"/>
		<param name="MES_AUX" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="BASE" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="BASEPROPORCIONAL" sqlType="STRING"/>
		<param name="MANUAL" sqlType="STRING"/>
		<param name="FECHACAMBIOMANUAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="APORTEPATRONALSALUD" sqlType="STRING"/>
		<param name="APORTEEMPLEADOSALUD" sqlType="STRING"/>
		<param name="APORTEPATRONALPENSION" sqlType="STRING"/>
		<param name="APORTEEMPLEADOPENSION" sqlType="STRING"/>
		<param name="FSP" sqlType="STRING"/>
		<param name="FSPSUBSISTENCIA" sqlType="STRING"/>
		<param name="FSPADICIONAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="basesnovedades">
		<call-query href="getBasesnovedadesPaginaQuery">
			<with-param name="COMPANIA_AUX" query-param="COMPANIA_AUX"/>
			<with-param name="ID_DE_EMPLEADO_AUX" query-param="ID_DE_EMPLEADO_AUX"/>
			<with-param name="ANO_AUX" query-param="ANO_AUX"/>
			<with-param name="MES_AUX" query-param="MES_AUX"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="BASE" query-param="BASE"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="BASEPROPORCIONAL" query-param="BASEPROPORCIONAL"/>
			<with-param name="MANUAL" query-param="MANUAL"/>
			<with-param name="FECHACAMBIOMANUAL" query-param="FECHACAMBIOMANUAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="APORTEPATRONALSALUD" query-param="APORTEPATRONALSALUD"/>
			<with-param name="APORTEEMPLEADOSALUD" query-param="APORTEEMPLEADOSALUD"/>
			<with-param name="APORTEPATRONALPENSION" query-param="APORTEPATRONALPENSION"/>
			<with-param name="APORTEEMPLEADOPENSION" query-param="APORTEEMPLEADOPENSION"/>
			<with-param name="FSP" query-param="FSP"/>
			<with-param name="FSPSUBSISTENCIA" query-param="FSPSUBSISTENCIA"/>
			<with-param name="FSPADICIONAL" query-param="FSPADICIONAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBasesnovedadesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BASESNOVEDADES.COMPANIA, BASESNOVEDADES.LLAVENOVEDAD, BASESNOVEDADES.TIPONOVEDAD, BASESNOVEDADES.CONSECUTIVO, BASESNOVEDADES.ID_DE_EMPLEADO, BASESNOVEDADES.ANO, BASESNOVEDADES.MES, BASESNOVEDADES.PERIODO,(TO_CHAR(BASESNOVEDADES.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(BASESNOVEDADES.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, BASESNOVEDADES.BASE, BASESNOVEDADES.DIAS, BASESNOVEDADES.BASEPROPORCIONAL,(CASE BASESNOVEDADES.MANUAL WHEN 0 THEN 'false' ELSE 'true' END) MANUAL,(TO_CHAR(BASESNOVEDADES.FECHACAMBIOMANUAL,'DD/MM/YYYY HH24:MI:SS')) FECHACAMBIOMANUAL, CONCAT(CASE WHEN ID_DE_PROCESO = 10 THEN 'RETROACTIVO ' END , TIPOSBASESNOVEDADES.DESCRIPCION) DESCRIPCION, BASESNOVEDADES.APORTEPATRONALSALUD, BASESNOVEDADES.APORTEEMPLEADOSALUD, BASESNOVEDADES.APORTEPATRONALPENSION, BASESNOVEDADES.APORTEEMPLEADOPENSION, BASESNOVEDADES.FSP, BASESNOVEDADES.FSPSUBSISTENCIA, BASESNOVEDADES.FSPADICIONAL FROM BASESNOVEDADES INNER JOIN TIPOSBASESNOVEDADES ON BASESNOVEDADES.TIPONOVEDAD = TIPOSBASESNOVEDADES.CODIGO WHERE BASESNOVEDADES.COMPANIA =:COMPANIA_AUX AND BASESNOVEDADES.ID_DE_EMPLEADO =:ID_DE_EMPLEADO_AUX AND BASESNOVEDADES.ANO =:ANO_AUX AND BASESNOVEDADES.MES =:MES_AUX ORDER BY TIPONOVEDAD, PERIODO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN BASE IS NULL THEN ' ' ELSE UPPER(BASE) END) LIKE UPPER(CONCAT(:BASE, '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(:DIAS, '%')) AND (CASE WHEN BASEPROPORCIONAL IS NULL THEN ' ' ELSE UPPER(BASEPROPORCIONAL) END) LIKE UPPER(CONCAT(:BASEPROPORCIONAL, '%')) AND (CASE WHEN MANUAL IS NULL THEN ' ' ELSE UPPER(MANUAL) END) LIKE UPPER(CONCAT(:MANUAL, '%')) AND (CASE WHEN FECHACAMBIOMANUAL IS NULL THEN ' ' ELSE UPPER(FECHACAMBIOMANUAL) END) LIKE UPPER(CONCAT(:FECHACAMBIOMANUAL, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN APORTEPATRONALSALUD IS NULL THEN ' ' ELSE UPPER(APORTEPATRONALSALUD) END) LIKE UPPER(CONCAT(:APORTEPATRONALSALUD, '%')) AND (CASE WHEN APORTEEMPLEADOSALUD IS NULL THEN ' ' ELSE UPPER(APORTEEMPLEADOSALUD) END) LIKE UPPER(CONCAT(:APORTEEMPLEADOSALUD, '%')) AND (CASE WHEN APORTEPATRONALPENSION IS NULL THEN ' ' ELSE UPPER(APORTEPATRONALPENSION) END) LIKE UPPER(CONCAT(:APORTEPATRONALPENSION, '%')) AND (CASE WHEN APORTEEMPLEADOPENSION IS NULL THEN ' ' ELSE UPPER(APORTEEMPLEADOPENSION) END) LIKE UPPER(CONCAT(:APORTEEMPLEADOPENSION, '%')) AND (CASE WHEN FSP IS NULL THEN ' ' ELSE UPPER(FSP) END) LIKE UPPER(CONCAT(:FSP, '%')) AND (CASE WHEN FSPSUBSISTENCIA IS NULL THEN ' ' ELSE UPPER(FSPSUBSISTENCIA) END) LIKE UPPER(CONCAT(:FSPSUBSISTENCIA, '%')) AND (CASE WHEN FSPADICIONAL IS NULL THEN ' ' ELSE UPPER(FSPADICIONAL) END) LIKE UPPER(CONCAT(:FSPADICIONAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA_AUX" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO_AUX" sqlType="STRING"/>
		<param name="ANO_AUX" sqlType="STRING"/>
		<param name="MES_AUX" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="BASE" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="BASEPROPORCIONAL" sqlType="STRING"/>
		<param name="MANUAL" sqlType="STRING"/>
		<param name="FECHACAMBIOMANUAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="APORTEPATRONALSALUD" sqlType="STRING"/>
		<param name="APORTEEMPLEADOSALUD" sqlType="STRING"/>
		<param name="APORTEPATRONALPENSION" sqlType="STRING"/>
		<param name="APORTEEMPLEADOPENSION" sqlType="STRING"/>
		<param name="FSP" sqlType="STRING"/>
		<param name="FSPSUBSISTENCIA" sqlType="STRING"/>
		<param name="FSPADICIONAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="basesnovedades/numero">
		<call-query href="getBasesnovedadesNumeroQuery">
			<with-param name="COMPANIA_AUX" query-param="COMPANIA_AUX"/>
			<with-param name="ID_DE_EMPLEADO_AUX" query-param="ID_DE_EMPLEADO_AUX"/>
			<with-param name="ANO_AUX" query-param="ANO_AUX"/>
			<with-param name="MES_AUX" query-param="MES_AUX"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="BASE" query-param="BASE"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="BASEPROPORCIONAL" query-param="BASEPROPORCIONAL"/>
			<with-param name="MANUAL" query-param="MANUAL"/>
			<with-param name="FECHACAMBIOMANUAL" query-param="FECHACAMBIOMANUAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="APORTEPATRONALSALUD" query-param="APORTEPATRONALSALUD"/>
			<with-param name="APORTEEMPLEADOSALUD" query-param="APORTEEMPLEADOSALUD"/>
			<with-param name="APORTEPATRONALPENSION" query-param="APORTEPATRONALPENSION"/>
			<with-param name="APORTEEMPLEADOPENSION" query-param="APORTEEMPLEADOPENSION"/>
			<with-param name="FSP" query-param="FSP"/>
			<with-param name="FSPSUBSISTENCIA" query-param="FSPSUBSISTENCIA"/>
			<with-param name="FSPADICIONAL" query-param="FSPADICIONAL"/>

		</call-query>
	</resource>
	<query id="updateBasesnovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BASESNOVEDADES SET CONSECUTIVO=:CONSECUTIVO, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), BASE=:BASE, DIAS=:DIAS, BASEPROPORCIONAL=:BASEPROPORCIONAL, MANUAL=:MANUAL, FECHACAMBIOMANUAL=TO_DATE(:FECHACAMBIOMANUAL,'DD/MM/YYYY HH24:MI:SS'), APORTEPATRONALSALUD=:APORTEPATRONALSALUD, APORTEEMPLEADOSALUD=:APORTEEMPLEADOSALUD, APORTEPATRONALPENSION=:APORTEPATRONALPENSION, APORTEEMPLEADOPENSION=:APORTEEMPLEADOPENSION, FSP=:FSP, FSPSUBSISTENCIA=:FSPSUBSISTENCIA, FSPADICIONAL=:FSPADICIONAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BASESNOVEDADES.COMPANIA= :KEY_COMPANIA AND BASESNOVEDADES.LLAVENOVEDAD= :KEY_LLAVENOVEDAD AND BASESNOVEDADES.TIPONOVEDAD= :KEY_TIPONOVEDAD AND BASESNOVEDADES.CONSECUTIVO= :KEY_CONSECUTIVO AND BASESNOVEDADES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND BASESNOVEDADES.ANO= :KEY_ANO AND BASESNOVEDADES.MES= :KEY_MES AND BASESNOVEDADES.PERIODO= :KEY_PERIODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="BASE" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="BASEPROPORCIONAL" sqlType="STRING"/>
		<param name="MANUAL" sqlType="STRING"/>
		<param name="FECHACAMBIOMANUAL" sqlType="STRING"/>
		<param name="APORTEPATRONALSALUD" sqlType="STRING"/>
		<param name="APORTEEMPLEADOSALUD" sqlType="STRING"/>
		<param name="APORTEPATRONALPENSION" sqlType="STRING"/>
		<param name="APORTEEMPLEADOPENSION" sqlType="STRING"/>
		<param name="FSP" sqlType="STRING"/>
		<param name="FSPSUBSISTENCIA" sqlType="STRING"/>
		<param name="FSPADICIONAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
