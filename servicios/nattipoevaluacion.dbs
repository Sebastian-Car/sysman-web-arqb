<data name="nattipoevaluacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNattipoevaluacionPagCodigoYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_TIPO_EVALUACION.CE_CODIGO, NAT_TIPO_EVALUACION.CE_NOMBRE  FROM NAT_TIPO_EVALUACION ORDER BY NAT_TIPO_EVALUACION.CE_CODIGO) WHERE (CASE WHEN CE_CODIGO IS NULL THEN ' ' ELSE UPPER(CE_CODIGO) END)  LIKE UPPER(:CE_CODIGO || '%')  AND (CASE WHEN CE_NOMBRE IS NULL THEN ' ' ELSE UPPER(CE_NOMBRE) END)  LIKE UPPER( '%' || :CE_NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CE_CODIGO":"$CE_CODIGO(type:integer)","CE_NOMBRE":"$CE_NOMBRE"}]}}		</result>
		<param name="CE_CODIGO" sqlType="STRING"/>
		<param name="CE_NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nattipoevaluacion/codigoynombre/pag">
		<call-query href="getNattipoevaluacionPagCodigoYNombreQuery">
			<with-param name="CE_CODIGO" query-param="CE_CODIGO"/>
			<with-param name="CE_NOMBRE" query-param="CE_NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNattipoevaluacionNumCodigoYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_TIPO_EVALUACION.CE_CODIGO, NAT_TIPO_EVALUACION.CE_NOMBRE  FROM NAT_TIPO_EVALUACION ORDER BY NAT_TIPO_EVALUACION.CE_CODIGO) WHERE (CASE WHEN CE_CODIGO IS NULL THEN ' ' ELSE UPPER(CE_CODIGO) END)  LIKE UPPER(:CE_CODIGO || '%')  AND (CASE WHEN CE_NOMBRE IS NULL THEN ' ' ELSE UPPER(CE_NOMBRE) END)  LIKE UPPER( '%' || :CE_NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CE_CODIGO" sqlType="STRING"/>
		<param name="CE_NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nattipoevaluacion/codigoynombre/num">
		<call-query href="getNattipoevaluacionNumCodigoYNombreQuery">
			<with-param name="CE_CODIGO" query-param="CE_CODIGO"/>
			<with-param name="CE_NOMBRE" query-param="CE_NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertNattipoevaluacion" keyColumns="CE_CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_TIPO_EVALUACION (CE_CODIGO, CE_NOMBRE, DATE_CREATED, CREATED_BY) VALUES (:CE_CODIGO, :CE_NOMBRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CE_CODIGO":"$CE_CODIGO(type:integer)"}]}}		</result>
		<param defaultValue="99" name="CE_CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="CE_NOMBRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="nattipoevaluacion">
		<call-query href="insertNattipoevaluacion">
			<with-param name="CE_CODIGO" query-param="CE_CODIGO"/>
			<with-param name="CE_NOMBRE" query-param="CE_NOMBRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNattipoevaluacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_TIPO_EVALUACION WHERE NAT_TIPO_EVALUACION.CE_CODIGO= :KEY_CE_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CE_CODIGO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="nattipoevaluacion">
		<call-query href="deleteNattipoevaluacion">
			<with-param name="KEY_CE_CODIGO" query-param="KEY_CE_CODIGO"/>

		</call-query>
	</resource>
	<query id="getNattipoevaluacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CE_CODIGO, CE_NOMBRE  FROM NAT_TIPO_EVALUACION ORDER BY CE_CODIGO) WHERE (CASE WHEN CE_CODIGO IS NULL THEN ' ' ELSE UPPER(CE_CODIGO) END)  LIKE UPPER(:CE_CODIGO || '%')  AND (CASE WHEN CE_NOMBRE IS NULL THEN ' ' ELSE UPPER(CE_NOMBRE) END)  LIKE UPPER( '%' || :CE_NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CE_CODIGO":"$CE_CODIGO(type:integer)","CE_NOMBRE":"$CE_NOMBRE"}]}}		</result>
		<param name="CE_CODIGO" sqlType="STRING"/>
		<param name="CE_NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nattipoevaluacion">
		<call-query href="getNattipoevaluacionPaginaQuery">
			<with-param name="CE_CODIGO" query-param="CE_CODIGO"/>
			<with-param name="CE_NOMBRE" query-param="CE_NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNattipoevaluacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CE_CODIGO, CE_NOMBRE  FROM NAT_TIPO_EVALUACION ORDER BY CE_CODIGO) WHERE (CASE WHEN CE_CODIGO IS NULL THEN ' ' ELSE UPPER(CE_CODIGO) END)  LIKE UPPER(:CE_CODIGO || '%')  AND (CASE WHEN CE_NOMBRE IS NULL THEN ' ' ELSE UPPER(CE_NOMBRE) END)  LIKE UPPER( '%' || :CE_NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CE_CODIGO" sqlType="STRING"/>
		<param name="CE_NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nattipoevaluacion/numero">
		<call-query href="getNattipoevaluacionNumeroQuery">
			<with-param name="CE_CODIGO" query-param="CE_CODIGO"/>
			<with-param name="CE_NOMBRE" query-param="CE_NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateNattipoevaluacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_TIPO_EVALUACION SET CE_CODIGO=:CE_CODIGO, CE_NOMBRE=:CE_NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_TIPO_EVALUACION.CE_CODIGO= :KEY_CE_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CE_CODIGO" sqlType="STRING"/>
		<param name="CE_NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CE_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="nattipoevaluacion">
		<call-query href="updateNattipoevaluacion">
			<with-param name="CE_CODIGO" query-param="CE_CODIGO"/>
			<with-param name="CE_NOMBRE" query-param="CE_NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CE_CODIGO" query-param="KEY_CE_CODIGO"/>

		</call-query>
	</resource>

</data>