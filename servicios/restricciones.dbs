<data name="restricciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getRestriccionesListaSubrestriccionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  RESTRICCIONES.COMPANIA, RESTRICCIONES.DOCUMENTO_IDENTIDAD, RESTRICCIONES.RESTRICCION,(TO_CHAR(RESTRICCIONES.FECHARESTRICCION,'DD/MM/YYYY HH24:MI:SS')) FECHARESTRICCION, TO_CHAR(RESTRICCIONES.FECHARESTRICCION,'dd/MM/YYYY') FECHARESTRICCIONAUX, RESTRICCIONES.SUCURSAL, RESTRICCIONESPASE.DESCRIPCION  FROM RESTRICCIONES INNER JOIN RESTRICCIONESPASE ON RESTRICCIONES.RESTRICCION=RESTRICCIONESPASE.RESTRICCION WHERE COMPANIA = :COMPANIA AND DOCUMENTO_IDENTIDAD = :NIT AND SUCURSAL =:SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DOCUMENTO_IDENTIDAD":"$DOCUMENTO_IDENTIDAD","RESTRICCION":"$RESTRICCION","FECHARESTRICCION":"$FECHARESTRICCION","FECHARESTRICCIONAUX":"$FECHARESTRICCIONAUX","SUCURSAL":"$SUCURSAL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="restricciones/listasubrestricciones">
		<call-query href="getRestriccionesListaSubrestriccionesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="insertRestriccionesInsertarSubRestricciones" keyColumns="COMPANIA,DOCUMENTO_IDENTIDAD,SUCURSAL,RESTRICCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO RESTRICCIONES (COMPANIA, DOCUMENTO_IDENTIDAD, RESTRICCION, FECHARESTRICCION, SUCURSAL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :DOCUMENTO_IDENTIDAD, :RESTRICCION, TO_DATE(:FECHARESTRICCION,'DD/MM/YYYY HH24:MI:SS'), :SUCURSAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DOCUMENTO_IDENTIDAD":"$DOCUMENTO_IDENTIDAD","KEY_SUCURSAL":"$SUCURSAL","KEY_RESTRICCION":"$RESTRICCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="DOCUMENTO_IDENTIDAD" sqlType="STRING"/>
		<param name="RESTRICCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHARESTRICCION" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="restricciones/insertarsubrestricciones">
		<call-query href="insertRestriccionesInsertarSubRestricciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCUMENTO_IDENTIDAD" query-param="DOCUMENTO_IDENTIDAD"/>
			<with-param name="RESTRICCION" query-param="RESTRICCION"/>
			<with-param name="FECHARESTRICCION" query-param="FECHARESTRICCION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="updateRestriccionesEditarSubRestricciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RESTRICCIONES SET DOCUMENTO_IDENTIDAD=:DOCUMENTO_IDENTIDAD, RESTRICCION=:RESTRICCION, FECHARESTRICCION=TO_DATE(:FECHARESTRICCION,'DD/MM/YYYY HH24:MI:SS'), SUCURSAL=:SUCURSAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE RESTRICCIONES.COMPANIA= :KEY_COMPANIA AND RESTRICCIONES.DOCUMENTO_IDENTIDAD= :KEY_DOCUMENTO_IDENTIDAD AND RESTRICCIONES.SUCURSAL= :KEY_SUCURSAL AND RESTRICCIONES.RESTRICCION= :KEY_RESTRICCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DOCUMENTO_IDENTIDAD" sqlType="STRING"/>
		<param name="RESTRICCION" sqlType="STRING"/>
		<param name="FECHARESTRICCION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DOCUMENTO_IDENTIDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_RESTRICCION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="restricciones/editarsubrestricciones">
		<call-query href="updateRestriccionesEditarSubRestricciones">
			<with-param name="DOCUMENTO_IDENTIDAD" query-param="DOCUMENTO_IDENTIDAD"/>
			<with-param name="RESTRICCION" query-param="RESTRICCION"/>
			<with-param name="FECHARESTRICCION" query-param="FECHARESTRICCION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DOCUMENTO_IDENTIDAD" query-param="KEY_DOCUMENTO_IDENTIDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_RESTRICCION" query-param="KEY_RESTRICCION"/>

		</call-query>
	</resource>
	<query id="deleteRestricciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM RESTRICCIONES WHERE RESTRICCIONES.COMPANIA= :KEY_COMPANIA AND RESTRICCIONES.DOCUMENTO_IDENTIDAD= :KEY_DOCUMENTO_IDENTIDAD AND RESTRICCIONES.SUCURSAL= :KEY_SUCURSAL AND RESTRICCIONES.RESTRICCION= :KEY_RESTRICCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DOCUMENTO_IDENTIDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_RESTRICCION" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="restricciones">
		<call-query href="deleteRestricciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DOCUMENTO_IDENTIDAD" query-param="KEY_DOCUMENTO_IDENTIDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_RESTRICCION" query-param="KEY_RESTRICCION"/>

		</call-query>
	</resource>

</data>