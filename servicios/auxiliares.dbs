	</resource>
	<query id="getAuxiliaresNumGetauxiliarcompaniaaniorubroqueryQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.AUXILIAR CODIGO, AUXILIAR.nombre NOMBRE FROM DETALLE_COMPROBANTE_PPTAL LEFT JOIN AUXILIAR ON AUXILIAR.COMPANIA = DETALLE_COMPROBANTE_PPTAL.compania AND AUXILIAR.ANO = DETALLE_COMPROBANTE_PPTAL.ano AND AUXILIAR.CODIGO = DETALLE_COMPROBANTE_PPTAL.AUXILIAR WHERE DETALLE_COMPROBANTE_PPTAL.compania = :COMPANIA and DETALLE_COMPROBANTE_PPTAL.ano = :ANO and DETALLE_COMPROBANTE_PPTAL.CUENTA = :RUBRO group by DETALLE_COMPROBANTE_PPTAL.AUXILIAR, AUXILIAR.nombre) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="auxiliares/getauxiliarcompaniaaniorubroquery/num">
		<call-query href="getAuxiliaresNumGetauxiliarcompaniaaniorubroqueryQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getAuxiliaresCodigonombreporanocompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, NOMBRE FROM AUXILIAR WHERE COMPANIA = :COMPANIA AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="auxiliares/codigonombreporanocompania">
		<call-query href="getAuxiliaresCodigonombreporanocompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
		<query id="getAuxiliaresAuxiliarequivalentesiganoQuery"  useConfig="sysmandsunist">
		<sql>SELECT AUXILIAR.CODIGO FROM AUXILIAR WHERE AUXILIAR.COMPANIA = :COMPANIA AND AUXILIAR.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="auxiliares/auxiliarequivalentesigano">
		<call-query href="getAuxiliaresAuxiliarequivalentesiganoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAuxiliaresAuxiliaresxpaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT T.*, ROWNUM RN FROM ( SELECT COMPANIA, ANO, CODIGO, NOMBRE FROM AUXILIAR WHERE COMPANIA = :COMPANIA AND ANO = :ANIO ORDER BY CODIGO ) T WHERE ROWNUM &lt;= :PAGINICIO + :PAGTAMANIO ) WHERE RN &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","RN":"$RN(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="auxiliares/auxiliaresxpagina">
		<call-query href="getAuxiliaresAuxiliaresxpaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>

</data>