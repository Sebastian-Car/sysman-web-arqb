		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT AUXILIAR.CODIGO, AUXILIAR.NOMBRE  FROM AUXILIAR INNER JOIN V_PLAN_PRESUPUESTAL ON AUXILIAR.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND AUXILIAR.CODIGO = V_PLAN_PRESUPUESTAL.AUXILIAR AND AUXILIAR.ANO = V_PLAN_PRESUPUESTAL.ANO WHERE AUXILIAR.COMPANIA = :COMPANIA AND AUXILIAR.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO = :CODCUENTA AND AUXILIAR.MOVIMIENTO &lt;&gt; 0 ORDER BY AUXILIAR.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
