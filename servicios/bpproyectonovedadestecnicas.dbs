<data name="bpproyectonovedadestecnicas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBpproyectonovedadestecnicas" keyColumns="COMPANIA,CODIGOPROYECTO,TIPO,CODIGONOVEDAD,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BPPROYECTONOVEDADESTECNICAS (COMPANIA, CODIGOPROYECTO, TIPO, CODIGONOVEDAD, CONSECUTIVO, ESTADO, FECHAAPROBACION, AUTOR, ENTIDAD, UBICACIONFISICA, NUMEROCONTRATO, FECHACONTRATO, INTERVENTOR, NOMBRENOVEDAD, SUCURSAL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGOPROYECTO, :TIPO, :CODIGONOVEDAD, :CONSECUTIVO, :ESTADO, TO_DATE(:FECHAAPROBACION,'DD/MM/YYYY HH24:MI:SS'), :AUTOR, :ENTIDAD, :UBICACIONFISICA, :NUMEROCONTRATO, TO_DATE(:FECHACONTRATO,'DD/MM/YYYY HH24:MI:SS'), :INTERVENTOR, :NOMBRENOVEDAD, :SUCURSAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOPROYECTO":"$CODIGOPROYECTO","KEY_TIPO":"$TIPO","KEY_CODIGONOVEDAD":"$CODIGONOVEDAD","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGONOVEDAD" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAAPROBACION" sqlType="STRING"/>
		<param defaultValue="" name="AUTOR" sqlType="STRING"/>
		<param defaultValue="" name="ENTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="UBICACIONFISICA" sqlType="STRING"/>
		<param defaultValue="0" name="NUMEROCONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="FECHACONTRATO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="INTERVENTOR" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRENOVEDAD" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpproyectonovedadestecnicas">
		<call-query href="insertBpproyectonovedadestecnicas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGONOVEDAD" query-param="CODIGONOVEDAD"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHAAPROBACION" query-param="FECHAAPROBACION"/>
			<with-param name="AUTOR" query-param="AUTOR"/>
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="UBICACIONFISICA" query-param="UBICACIONFISICA"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>
			<with-param name="FECHACONTRATO" query-param="FECHACONTRATO"/>
			<with-param name="INTERVENTOR" query-param="INTERVENTOR"/>
			<with-param name="NOMBRENOVEDAD" query-param="NOMBRENOVEDAD"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteBpproyectonovedadestecnicas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BPPROYECTONOVEDADESTECNICAS WHERE BPPROYECTONOVEDADESTECNICAS.COMPANIA= :KEY_COMPANIA AND BPPROYECTONOVEDADESTECNICAS.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND BPPROYECTONOVEDADESTECNICAS.TIPO= :KEY_TIPO AND BPPROYECTONOVEDADESTECNICAS.CODIGONOVEDAD= :KEY_CODIGONOVEDAD AND BPPROYECTONOVEDADESTECNICAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPROYECTO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_CODIGONOVEDAD" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="bpproyectonovedadestecnicas">
		<call-query href="deleteBpproyectonovedadestecnicas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPROYECTO" query-param="KEY_CODIGOPROYECTO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_CODIGONOVEDAD" query-param="KEY_CODIGONOVEDAD"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getBpproyectonovedadestecnicasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  P.COMPANIA, P.CODIGOPROYECTO, P.TIPO, (CASE P.TIPO WHEN 'EST' THEN 'Estudio' WHEN 'LIC' THEN 'Licencia' WHEN 'DIS' THEN 'Diseño' WHEN 'OTR' THEN 'Otros' END) NOMBRETIPO, P.CODIGONOVEDAD, TN.NOMBRE NOMBRENOVEDAD, P.CONSECUTIVO, P.ESTADO, (CASE P.ESTADO WHEN 'A' THEN 'Aprobado' WHEN 'T' THEN 'Trámite' WHEN 'EN' THEN 'En Ejecución' WHEN 'E' THEN 'Ejecutado' WHEN 'SE' THEN 'Sin Ejecutar' ELSE P.ESTADO END) NOMBREESTADO,(TO_CHAR(P.FECHAAPROBACION,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACION, TO_CHAR(P.FECHAAPROBACION, 'DD/MM/YYYY') FECHA, P.AUTOR, P.ENTIDAD, P.UBICACIONFISICA, P.NUMEROCONTRATO,(TO_CHAR(P.FECHACONTRATO,'DD/MM/YYYY HH24:MI:SS')) FECHACONTRATO, P.INTERVENTOR, T.NOMBRE NOMBREINTERVENTOR, P.SUCURSAL  FROM BPPROYECTONOVEDADESTECNICAS P LEFT JOIN BPTIPOSNOVEDADTECNICA TN ON P.COMPANIA = TN.COMPANIA AND P.TIPO = TN.TIPO AND P.CODIGONOVEDAD = TN.CODIGO LEFT JOIN TERCERO T ON P.COMPANIA = T.COMPANIA AND P.INTERVENTOR = T.NIT AND P.SUCURSAL = T.SUCURSAL WHERE P.COMPANIA = :COMPANIA AND P.CODIGOPROYECTO = :CODIGOPROYECTO ORDER BY P.CODIGOPROYECTO, P.TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOPROYECTO":"$CODIGOPROYECTO","TIPO":"$TIPO","NOMBRETIPO":"$NOMBRETIPO","CODIGONOVEDAD":"$CODIGONOVEDAD","NOMBRENOVEDAD":"$NOMBRENOVEDAD","CONSECUTIVO":"$CONSECUTIVO(type:integer)","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO","FECHAAPROBACION":"$FECHAAPROBACION","FECHA":"$FECHA","AUTOR":"$AUTOR","ENTIDAD":"$ENTIDAD","UBICACIONFISICA":"$UBICACIONFISICA","NUMEROCONTRATO":"$NUMEROCONTRATO","FECHACONTRATO":"$FECHACONTRATO","INTERVENTOR":"$INTERVENTOR","NOMBREINTERVENTOR":"$NOMBREINTERVENTOR","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectonovedadestecnicas">
		<call-query href="getBpproyectonovedadestecnicasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>

		</call-query>
	</resource>
	<query id="updateBpproyectonovedadestecnicas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPPROYECTONOVEDADESTECNICAS SET ESTADO=:ESTADO, FECHAAPROBACION=TO_DATE(:FECHAAPROBACION,'DD/MM/YYYY HH24:MI:SS'), AUTOR=:AUTOR, ENTIDAD=:ENTIDAD, UBICACIONFISICA=:UBICACIONFISICA, NUMEROCONTRATO=:NUMEROCONTRATO, FECHACONTRATO=TO_DATE(:FECHACONTRATO,'DD/MM/YYYY HH24:MI:SS'), INTERVENTOR=:INTERVENTOR, SUCURSAL=:SUCURSAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE BPPROYECTONOVEDADESTECNICAS.COMPANIA= :KEY_COMPANIA AND BPPROYECTONOVEDADESTECNICAS.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND BPPROYECTONOVEDADESTECNICAS.TIPO= :KEY_TIPO AND BPPROYECTONOVEDADESTECNICAS.CODIGONOVEDAD= :KEY_CODIGONOVEDAD AND BPPROYECTONOVEDADESTECNICAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHAAPROBACION" sqlType="STRING"/>
		<param name="AUTOR" sqlType="STRING"/>
		<param name="ENTIDAD" sqlType="STRING"/>
		<param name="UBICACIONFISICA" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>
		<param name="FECHACONTRATO" sqlType="STRING"/>
		<param name="INTERVENTOR" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPROYECTO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_CODIGONOVEDAD" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpproyectonovedadestecnicas">
		<call-query href="updateBpproyectonovedadestecnicas">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHAAPROBACION" query-param="FECHAAPROBACION"/>
			<with-param name="AUTOR" query-param="AUTOR"/>
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="UBICACIONFISICA" query-param="UBICACIONFISICA"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>
			<with-param name="FECHACONTRATO" query-param="FECHACONTRATO"/>
			<with-param name="INTERVENTOR" query-param="INTERVENTOR"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPROYECTO" query-param="KEY_CODIGOPROYECTO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_CODIGONOVEDAD" query-param="KEY_CODIGONOVEDAD"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>