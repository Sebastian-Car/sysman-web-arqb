			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CRITERIO" query-param="CRITERIO"/>

		</call-query>
	</resource>
	<query id="insertEvsubdetalleevaluacionCriteriosEvaluados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_SUBDETALLE_EVALUACION   (     COMPANIA,     EVALUACION,     CARGO_EVALUADOR,     CARGO_EVALUADO,     CRITERIO_EVALUADO,     CLASE_EVALUACION,     TIPO_EVALUACION,     VALOR_ASIGNADO,     CEDULA_EVALUADO,     SUCURSAL_EVALUADO,     CEDULA_EVALUADOR,     SUCURSAL_EVALUADOR,     GRUPO,     MOVIMIENTO,     PUNTAJE,     IND_TEXTO,     TEXTO,     CREATED_BY,     DATE_CREATED,     ESCALAFON_EVALUADOR,     ESCALAFON_EVALUADO,     FECHA,     HORA ) SELECT DISTINCT EV_CRITERIO_GRUPO.COMPANIA,   :EVALUACION ,   :CARGO_EVALUADOR ,   :CARGO_EVALUADO ,   EV_CRITERIOS_EVALUACION.CODIGO,   EV_CRITERIO_GRUPO.CLASE_EVALUACION ,   :TIPO TIPO_EVALUACION,   0 VALOR_ASIGNADO,   :CEDULA_EVALUADO ,   :SUCURSAL_EVALUADO ,   :CEDULA_EVALUADOR ,   :SUCURSAL_EVALUADOR ,   EV_CRITERIO_GRUPO.GRUPO,   EV_CRITERIOS_EVALUACION.MOVIMIENTO,   EV_CRITERIOS_EVALUACION.PUNTAJE,   EV_CRITERIOS_EVALUACION.IND_TEXTO,   '' TEXTO,   :USUARIO,   SYSDATE,   :ESCALAFON_EVALUADOR,   :ESCALAFON_EVALUADO,    SYSDATE,   :HORA FROM EV_CRITERIOS_EVALUACION INNER JOIN EV_CRITERIO_GRUPO ON EV_CRITERIOS_EVALUACION.COMPANIA                                                    = EV_CRITERIO_GRUPO.COMPANIA AND SUBSTR(EV_CRITERIOS_EVALUACION.CODIGO,1,LENGTH(EV_CRITERIO_GRUPO.CODIGO_CRITERIO)) = EV_CRITERIO_GRUPO.CODIGO_CRITERIO AND EV_CRITERIOS_EVALUACION.CLASE_EVALUACION                                           = EV_CRITERIO_GRUPO.CLASE_EVALUACION INNER JOIN EV_EVALUACIONES ON EV_CRITERIO_GRUPO.GRUPO                                     = EV_EVALUACIONES.GRUPO_APLICAR AND EV_CRITERIO_GRUPO.COMPANIA                                 = EV_EVALUACIONES.COMPANIA AND EV_CRITERIO_GRUPO.CLASE_EVALUACION                         = EV_EVALUACIONES.CLASE_EVALUACION WHERE EV_CRITERIO_GRUPO.COMPANIA                               = :COMPANIA AND EV_CRITERIO_GRUPO.CLASE_EVALUACION                         = :CLASE AND EV_EVALUACIONES.CONSECUTIVO                                = :EVALUACION AND SUBSTR(EV_CRITERIOS_EVALUACION.CODIGO,1,LENGTH(:CRITERIO)) = :CRITERIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CARGO_EVALUADOR" sqlType="STRING"/>
		<param name="CARGO_EVALUADO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="ESCALAFON_EVALUADOR" sqlType="STRING"/>
		<param name="ESCALAFON_EVALUADO" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CRITERIO" sqlType="STRING"/>

	</query>
