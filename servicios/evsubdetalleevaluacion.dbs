<data name="evsubdetalleevaluacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEvsubdetalleevaluacionPagCriteriosPrincipalesEvaluadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO, EV_CRITERIOS_EVALUACION.NOMBRE NOMBRECRITERIO,(TO_CHAR(EV_SUBDETALLE_EVALUACION.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(EV_SUBDETALLE_EVALUACION.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, EV_SUBDETALLE_EVALUACION.PUNTAJE,(CASE EV_CRITERIOS_EVALUACION.IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO,(CASE EV_CRITERIOS_EVALUACION.ESCOMPROMISO WHEN 0 THEN 'false' ELSE 'true' END) ESCOMPROMISO, EV_CRITERIOS_EVALUACION.TEXTO  FROM EV_SUBDETALLE_EVALUACION INNER JOIN EV_CRITERIOS_EVALUACION ON EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO = EV_CRITERIOS_EVALUACION.CODIGO AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = EV_CRITERIOS_EVALUACION.CLASE_EVALUACION AND EV_SUBDETALLE_EVALUACION.COMPANIA = EV_CRITERIOS_EVALUACION.COMPANIA WHERE EV_SUBDETALLE_EVALUACION.COMPANIA = :COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION = :EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR = :CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = :CLASE AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION = :TIPO AND EV_SUBDETALLE_EVALUACION.MOVIMIENTO = 0) WHERE (CASE WHEN CRITERIO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CRITERIO_EVALUADO) END)  LIKE UPPER(:CRITERIO_EVALUADO || '%')  AND (CASE WHEN NOMBRECRITERIO IS NULL THEN ' ' ELSE UPPER(NOMBRECRITERIO) END)  LIKE UPPER( '%' || :NOMBRECRITERIO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END)  LIKE UPPER( '%' || :HORA || '%')  AND (CASE WHEN PUNTAJE IS NULL THEN ' ' ELSE UPPER(PUNTAJE) END)  LIKE UPPER(:PUNTAJE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CRITERIO_EVALUADO":"$CRITERIO_EVALUADO","NOMBRECRITERIO":"$NOMBRECRITERIO","FECHA":"$FECHA","HORA":"$HORA","PUNTAJE":"$PUNTAJE(type:integer)","IND_GRUPO":"$IND_GRUPO(type:boolean)","ESCOMPROMISO":"$ESCOMPROMISO(type:boolean)","TEXTO":"$TEXTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="NOMBRECRITERIO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="PUNTAJE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evsubdetalleevaluacion/criteriosprincipalesevaluados/pag">
		<call-query href="getEvsubdetalleevaluacionPagCriteriosPrincipalesEvaluadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CRITERIO_EVALUADO" query-param="CRITERIO_EVALUADO"/>
			<with-param name="NOMBRECRITERIO" query-param="NOMBRECRITERIO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="PUNTAJE" query-param="PUNTAJE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvsubdetalleevaluacionNumCriteriosPrincipalesEvaluadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO, EV_CRITERIOS_EVALUACION.NOMBRE NOMBRECRITERIO,(TO_CHAR(EV_SUBDETALLE_EVALUACION.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(EV_SUBDETALLE_EVALUACION.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, EV_SUBDETALLE_EVALUACION.PUNTAJE,(CASE EV_CRITERIOS_EVALUACION.IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO,(CASE EV_CRITERIOS_EVALUACION.ESCOMPROMISO WHEN 0 THEN 'false' ELSE 'true' END) ESCOMPROMISO, EV_CRITERIOS_EVALUACION.TEXTO  FROM EV_SUBDETALLE_EVALUACION INNER JOIN EV_CRITERIOS_EVALUACION ON EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO = EV_CRITERIOS_EVALUACION.CODIGO AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = EV_CRITERIOS_EVALUACION.CLASE_EVALUACION AND EV_SUBDETALLE_EVALUACION.COMPANIA = EV_CRITERIOS_EVALUACION.COMPANIA WHERE EV_SUBDETALLE_EVALUACION.COMPANIA = :COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION = :EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR = :CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = :CLASE AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION = :TIPO AND EV_SUBDETALLE_EVALUACION.MOVIMIENTO = 0) WHERE (CASE WHEN CRITERIO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CRITERIO_EVALUADO) END)  LIKE UPPER(:CRITERIO_EVALUADO || '%')  AND (CASE WHEN NOMBRECRITERIO IS NULL THEN ' ' ELSE UPPER(NOMBRECRITERIO) END)  LIKE UPPER( '%' || :NOMBRECRITERIO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END)  LIKE UPPER( '%' || :HORA || '%')  AND (CASE WHEN PUNTAJE IS NULL THEN ' ' ELSE UPPER(PUNTAJE) END)  LIKE UPPER(:PUNTAJE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="NOMBRECRITERIO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="PUNTAJE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evsubdetalleevaluacion/criteriosprincipalesevaluados/num">
		<call-query href="getEvsubdetalleevaluacionNumCriteriosPrincipalesEvaluadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CRITERIO_EVALUADO" query-param="CRITERIO_EVALUADO"/>
			<with-param name="NOMBRECRITERIO" query-param="NOMBRECRITERIO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="PUNTAJE" query-param="PUNTAJE"/>

		</call-query>
	</resource>
	<query id="getEvsubdetalleevaluacionPagCriteriosHijosEvaluadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_SUBDETALLE_EVALUACION.COMPANIA, EV_SUBDETALLE_EVALUACION.EVALUACION, EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO, EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR, EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION, EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADO, EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADOR, EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO, EV_CRITERIOS_EVALUACION.NOMBRE NOMBRECRITERIO,(CASE EV_SUBDETALLE_EVALUACION.VALOR_ASIGNADO WHEN 0 THEN 'false' ELSE 'true' END) VALOR_ASIGNADO, EV_SUBDETALLE_EVALUACION.TEXTO, EV_SUBDETALLE_EVALUACION.PUNTAJE,(CASE EV_SUBDETALLE_EVALUACION.IND_TEXTO WHEN 0 THEN 'false' ELSE 'true' END) IND_TEXTO FROM EV_SUBDETALLE_EVALUACION LEFT JOIN EV_CRITERIOS_EVALUACION ON EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO = EV_CRITERIOS_EVALUACION.CODIGO AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = EV_CRITERIOS_EVALUACION.CLASE_EVALUACION AND EV_SUBDETALLE_EVALUACION.COMPANIA = EV_CRITERIOS_EVALUACION.COMPANIA WHERE EV_SUBDETALLE_EVALUACION.COMPANIA = :COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION = :EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR = :CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = :CLASE AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION = :TIPO AND SUBSTR(EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO,1,LENGTH(:CRITERIO)) = :CRITERIO AND EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO NOT IN :CRITERIO) WHERE (CASE WHEN CRITERIO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CRITERIO_EVALUADO) END)  LIKE UPPER(:CRITERIO_EVALUADO || '%')  AND (CASE WHEN NOMBRECRITERIO IS NULL THEN ' ' ELSE UPPER(NOMBRECRITERIO) END)  LIKE UPPER( '%' || :NOMBRECRITERIO || '%')  AND (CASE WHEN VALOR_ASIGNADO IS NULL THEN ' ' ELSE UPPER(VALOR_ASIGNADO) END)  LIKE UPPER(:VALOR_ASIGNADO || '%')  AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END)  LIKE UPPER( '%' || :TEXTO || '%')  AND (CASE WHEN PUNTAJE IS NULL THEN ' ' ELSE UPPER(PUNTAJE) END)  LIKE UPPER(:PUNTAJE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","EVALUACION":"$EVALUACION(type:long)","CEDULA_EVALUADO":"$CEDULA_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR","CRITERIO_EVALUADO":"$CRITERIO_EVALUADO","NOMBRECRITERIO":"$NOMBRECRITERIO","VALOR_ASIGNADO":"$VALOR_ASIGNADO(type:boolean)","TEXTO":"$TEXTO","PUNTAJE":"$PUNTAJE(type:integer)","IND_TEXTO":"$IND_TEXTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CRITERIO" sqlType="STRING"/>
		<param name="CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="NOMBRECRITERIO" sqlType="STRING"/>
		<param name="VALOR_ASIGNADO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="PUNTAJE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evsubdetalleevaluacion/criterioshijosevaluados/pag">
		<call-query href="getEvsubdetalleevaluacionPagCriteriosHijosEvaluadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
