	<query id="deleteEvsubdetalleevaluacionCriterioPadreEHijos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_SUBDETALLE_EVALUACION  WHERE EV_SUBDETALLE_EVALUACION.COMPANIA                                    = :COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION                                    = :EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO                               = :CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR                              = :CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION                              = :CLASE AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION                               = :TIPO AND SUBSTR(EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO,1,LENGTH(:CRITERIO)) = :CRITERIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CRITERIO" sqlType="STRING"/>

	</query>
