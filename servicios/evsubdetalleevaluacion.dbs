	<query id="deleteEvsubdetalleevaluacionEliminarTodas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_SUBDETALLE_EVALUACION  WHERE EV_SUBDETALLE_EVALUACION.COMPANIA      = :COMPANIA   AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO = :CEDULA_EVALUADO</sql>
