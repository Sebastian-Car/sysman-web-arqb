			<with-param name="CRITERIO_EVALUADO" query-param="CRITERIO_EVALUADO"/>
			<with-param name="NOMBRECRITERIO" query-param="NOMBRECRITERIO"/>
			<with-param name="VALOR_ASIGNADO" query-param="VALOR_ASIGNADO"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="PUNTAJE" query-param="PUNTAJE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvsubdetalleevaluacionNumCriteriosHijosEvaluadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_SUBDETALLE_EVALUACION.COMPANIA, EV_SUBDETALLE_EVALUACION.EVALUACION, EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO, EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR, EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION, EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADO, EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADOR, EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO, EV_CRITERIOS_EVALUACION.NOMBRE NOMBRECRITERIO,(CASE EV_SUBDETALLE_EVALUACION.VALOR_ASIGNADO WHEN 0 THEN 'false' ELSE 'true' END) VALOR_ASIGNADO, EV_SUBDETALLE_EVALUACION.TEXTO, EV_SUBDETALLE_EVALUACION.PUNTAJE,(CASE EV_SUBDETALLE_EVALUACION.IND_TEXTO WHEN 0 THEN 'false' ELSE 'true' END) IND_TEXTO FROM EV_SUBDETALLE_EVALUACION LEFT JOIN EV_CRITERIOS_EVALUACION ON EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO = EV_CRITERIOS_EVALUACION.CODIGO AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = EV_CRITERIOS_EVALUACION.CLASE_EVALUACION AND EV_SUBDETALLE_EVALUACION.COMPANIA = EV_CRITERIOS_EVALUACION.COMPANIA WHERE EV_SUBDETALLE_EVALUACION.COMPANIA = :COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION = :EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR = :CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = :CLASE AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION = :TIPO AND SUBSTR(EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO,1,LENGTH(:CRITERIO)) = :CRITERIO AND EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO NOT IN :CRITERIO) WHERE (CASE WHEN CRITERIO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CRITERIO_EVALUADO) END)  LIKE UPPER(:CRITERIO_EVALUADO || '%')  AND (CASE WHEN NOMBRECRITERIO IS NULL THEN ' ' ELSE UPPER(NOMBRECRITERIO) END)  LIKE UPPER( '%' || :NOMBRECRITERIO || '%')  AND (CASE WHEN VALOR_ASIGNADO IS NULL THEN ' ' ELSE UPPER(VALOR_ASIGNADO) END)  LIKE UPPER(:VALOR_ASIGNADO || '%')  AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END)  LIKE UPPER( '%' || :TEXTO || '%')  AND (CASE WHEN PUNTAJE IS NULL THEN ' ' ELSE UPPER(PUNTAJE) END)  LIKE UPPER(:PUNTAJE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CRITERIO" sqlType="STRING"/>
		<param name="CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="NOMBRECRITERIO" sqlType="STRING"/>
		<param name="VALOR_ASIGNADO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="PUNTAJE" sqlType="STRING"/>

	</query>
