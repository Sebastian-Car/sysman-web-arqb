		</call-query>
	</resource>
	<query id="updateEvsubdetalleevaluacionValorAsignado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_SUBDETALLE_EVALUACION  SET    VALOR_ASIGNADO=0, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_SUBDETALLE_EVALUACION.COMPANIA                                                    = :KEY_COMPANIA    AND EV_SUBDETALLE_EVALUACION.EVALUACION                                                 = :KEY_EVALUACION    AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO                                            = :KEY_CEDULA_EVALUADO    AND EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADO                                          = :KEY_SUCURSAL_EVALUADO    AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR                                           = :KEY_CEDULA_EVALUADOR    AND EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADOR                                         = :KEY_SUCURSAL_EVALUADOR    AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION                                           = :KEY_CLASE_EVALUACION    AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION                                            = :KEY_TIPO_EVALUACION    AND SUBSTR(EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO,1,LENGTH(:KEY_CRITERIO_EVALUADO)) = :KEY_CRITERIO_EVALUADO    AND EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO NOT                                     IN :KEY_CRITERIO_EVALUADO    AND EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO NOT                                     IN :KEY_CRITERIO_SELECCIONADO    AND :KEY_CRITERIO_EVALUADO IN     (SELECT  CODIGO      FROM   EV_CRITERIOS_EVALUACION      WHERE  EV_CRITERIOS_EVALUACION.COMPANIA                                                   = :KEY_COMPANIA         AND EV_CRITERIOS_EVALUACION.CLASE_EVALUACION                                           = :KEY_CLASE_EVALUACION         AND EV_CRITERIOS_EVALUACION.CODIGO                                                     = :KEY_CRITERIO_EVALUADO         AND EV_CRITERIOS_EVALUACION.IND_SELECCION_MULTIPLE                                     IN (0)     )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CRITERIO_SELECCIONADO" sqlType="STRING"/>

	</query>
