			<with-param name="PUNTAJE" query-param="PUNTAJE"/>

		</call-query>
	</resource>
	<query id="updateEvsubdetalleevaluacionCriteriosHijosEvaluados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_SUBDETALLE_EVALUACION SET VALOR_ASIGNADO=:VALOR_ASIGNADO, TEXTO=:TEXTO, PUNTAJE=:PUNTAJE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_SUBDETALLE_EVALUACION.COMPANIA= :KEY_COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION= :KEY_EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADOR= :KEY_SUCURSAL_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO= :KEY_CRITERIO_EVALUADO AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR_ASIGNADO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="PUNTAJE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evsubdetalleevaluacion/criterioshijosevaluados">
		<call-query href="updateEvsubdetalleevaluacionCriteriosHijosEvaluados">
			<with-param name="VALOR_ASIGNADO" query-param="VALOR_ASIGNADO"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="PUNTAJE" query-param="PUNTAJE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_EVALUACION" query-param="KEY_EVALUACION"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_CEDULA_EVALUADOR" query-param="KEY_CEDULA_EVALUADOR"/>
			<with-param name="KEY_SUCURSAL_EVALUADOR" query-param="KEY_SUCURSAL_EVALUADOR"/>
			<with-param name="KEY_CRITERIO_EVALUADO" query-param="KEY_CRITERIO_EVALUADO"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>

		</call-query>
	</resource>
	<query id="updateEvsubdetalleevaluacionPuntajeTotal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_SUBDETALLE_EVALUACION PADRE SET PUNTAJE =                (SELECT SUM(EV_SUBDETALLE_EVALUACION.PUNTAJE)         FROM EV_SUBDETALLE_EVALUACION         WHERE EV_SUBDETALLE_EVALUACION.COMPANIA                                                 = :KEY_COMPANIA         AND EV_SUBDETALLE_EVALUACION.EVALUACION                                                 = :KEY_EVALUACION         AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO                                            = :KEY_CEDULA_EVALUADO         AND EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADO                                          = :KEY_SUCURSAL_EVALUADO         AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR                                           = :KEY_CEDULA_EVALUADOR         AND EV_SUBDETALLE_EVALUACION.SUCURSAL_EVALUADOR                                         = :KEY_SUCURSAL_EVALUADOR         AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION                                           = :KEY_CLASE_EVALUACION         AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION                                            = :KEY_TIPO_EVALUACION         AND SUBSTR(PADRE.CRITERIO_EVALUADO,1,LENGTH(PADRE.CRITERIO_EVALUADO))                   =PADRE.CRITERIO_EVALUADO         AND EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO NOT                                     IN PADRE.CRITERIO_EVALUADO         AND NVL(EV_SUBDETALLE_EVALUACION.VALOR_ASIGNADO,0) NOT                                 IN (0)         ),   DATE_MODIFIED                                 =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY                                   =:MODIFIED_BY WHERE PADRE.COMPANIA           = :KEY_COMPANIA   AND PADRE.EVALUACION         = :KEY_EVALUACION   AND PADRE.CEDULA_EVALUADO    = :KEY_CEDULA_EVALUADO   AND PADRE.SUCURSAL_EVALUADO  = :KEY_SUCURSAL_EVALUADO   AND PADRE.CEDULA_EVALUADOR   = :KEY_CEDULA_EVALUADOR   AND PADRE.SUCURSAL_EVALUADOR = :KEY_SUCURSAL_EVALUADOR   AND PADRE.CLASE_EVALUACION   = :KEY_CLASE_EVALUACION   AND PADRE.TIPO_EVALUACION    = :KEY_TIPO_EVALUACION   AND PADRE.CRITERIO_EVALUADO  = SUBSTR(:KEY_CRITERIO_EVALUADO,1,LENGTH(PADRE.CRITERIO_EVALUADO))</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CRITERIO_EVALUADO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evsubdetalleevaluacion/puntajetotal">
