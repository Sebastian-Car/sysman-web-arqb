		<call-query href="getEvsubdetalleevaluacionNumCriteriosHijosEvaluadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
