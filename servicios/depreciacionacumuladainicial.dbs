			<with-param name="VALOR_DEPRECIAR" query-param="VALOR_DEPRECIAR"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="updateDepreciacionacumuladainicial" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEPRECIACION_ACUMULADA_INICIAL SET COMPANIA=:COMPANIA, ELEMENTO=:ELEMENTO, SERIE=:SERIE, VALOR_HISTORICO=:VALOR_HISTORICO, VIDA_UTIL=:VIDA_UTIL, FECHA_ADQUISICION=TO_DATE(:FECHA_ADQUISICION,'DD/MM/YYYY HH24:MI:SS'), PERIODO_AFECTAR=TO_DATE(:PERIODO_AFECTAR,'DD/MM/YYYY HH24:MI:SS'), VALOR_PERIODO=:VALOR_PERIODO, VALOR_ACUMULADO=:VALOR_ACUMULADO, VALOR_DEPRECIAR=:VALOR_DEPRECIAR, OBSERVACIONES=:OBSERVACIONES, NIIF_VLRLIBROS=:NIIF_VLRLIBROS, NIIF_VIDA_UTIL=:NIIF_VIDA_UTIL, NIIF_VLRDEPRECIACION=:NIIF_VLRDEPRECIACION, NIIF_VLRACUMULADO=:NIIF_VLRACUMULADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEPRECIACION_ACUMULADA_INICIAL.COMPANIA= :KEY_COMPANIA AND DEPRECIACION_ACUMULADA_INICIAL.ELEMENTO= :KEY_ELEMENTO AND DEPRECIACION_ACUMULADA_INICIAL.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR_HISTORICO" sqlType="STRING"/>
		<param name="VIDA_UTIL" sqlType="STRING"/>
		<param name="FECHA_ADQUISICION" sqlType="STRING"/>
		<param name="PERIODO_AFECTAR" sqlType="STRING"/>
		<param name="VALOR_PERIODO" sqlType="STRING"/>
		<param name="VALOR_ACUMULADO" sqlType="STRING"/>
		<param name="VALOR_DEPRECIAR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="NIIF_VIDA_UTIL" sqlType="STRING"/>
		<param name="NIIF_VLRDEPRECIACION" sqlType="STRING"/>
		<param name="NIIF_VLRACUMULADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
