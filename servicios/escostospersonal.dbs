			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="REQUISITOS" query-param="REQUISITOS"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>

		</call-query>
	</resource>
	<query id="updateEscostospersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_COSTO_PER SET COMPANIA=:COMPANIA, ID_COSTO=:ID_COSTO, COD_ESTUDIO=:COD_ESTUDIO, FORMACION=:FORMACION, EXPERIENCIA=:EXPERIENCIA, DESCRIPCION=:DESCRIPCION, CANTIDAD=:CANTIDAD, SUELDOBASICO=:SUELDOBASICO, TIEMPO=:TIEMPO, DEDICACION=:DEDICACION, FM=:FM, VALORPARCIAL=:VALORPARCIAL, SUBTOTALVALOR=:SUBTOTALVALOR, SUBTOTALCANT=:SUBTOTALCANT, SUBTOTALSUELDO=:SUBTOTALSUELDO, SUBTOTALTIEMPO=:SUBTOTALTIEMPO, CONTRATO=:CONTRATO, REQUISITOS=:REQUISITOS, GRUPO=:GRUPO, CATEGORIA=:CATEGORIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_COSTO_PER.COMPANIA= :KEY_COMPANIA AND ES_COSTO_PER.ID_COSTO= :KEY_ID_COSTO AND ES_COSTO_PER.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_COSTO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="FORMACION" sqlType="STRING"/>
		<param name="EXPERIENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="SUELDOBASICO" sqlType="STRING"/>
		<param name="TIEMPO" sqlType="STRING"/>
		<param name="DEDICACION" sqlType="STRING"/>
		<param name="FM" sqlType="STRING"/>
		<param name="VALORPARCIAL" sqlType="STRING"/>
		<param name="SUBTOTALVALOR" sqlType="STRING"/>
		<param name="SUBTOTALCANT" sqlType="STRING"/>
		<param name="SUBTOTALSUELDO" sqlType="STRING"/>
		<param name="SUBTOTALTIEMPO" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="REQUISITOS" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_COSTO" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
