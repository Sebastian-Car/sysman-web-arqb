			<with-param name="SUBTOTALCANT" query-param="SUBTOTALCANT"/>
			<with-param name="SUBTOTALSUELDO" query-param="SUBTOTALSUELDO"/>
			<with-param name="SUBTOTALTIEMPO" query-param="SUBTOTALTIEMPO"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
