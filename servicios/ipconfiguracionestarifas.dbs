			<with-param name="IND_CLASEPREDIO" query-param="IND_CLASEPREDIO"/>
			<with-param name="CLASE_INICIAL" query-param="CLASE_INICIAL"/>
			<with-param name="CLASE_FINAL" query-param="CLASE_FINAL"/>
			<with-param name="IND_ESTRATO" query-param="IND_ESTRATO"/>
			<with-param name="ESTRATO_INICIAL" query-param="ESTRATO_INICIAL"/>
			<with-param name="ESTRATO_FINAL" query-param="ESTRATO_FINAL"/>
			<with-param name="PORCINICIAL" query-param="PORCINICIAL"/>
			<with-param name="PORCFINAL" query-param="PORCFINAL"/>
			<with-param name="TRPANO" query-param="TRPANO"/>
			<with-param name="TRPRAN" query-param="TRPRAN"/>
			<with-param name="NUMERO_ORDENI" query-param="NUMERO_ORDENI"/>
