<data name="ipconfiguracionestarifas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertIpconfiguracionestarifas" keyColumns="COMPANIA,ID,CODTARIFA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_CONFIGURACIONTARIFAS (COMPANIA, ID, CODTARIFA, PREDIO_INICIAL, PREDIO_FINAL, AVALUO_INICIAL, AVALUO_FINAL, AREAM2_INICIAL, AREAM2_FINAL, AREACONST_INICIAL, AREACONST_FINAL, AREAHA_INICIAL, AREAHA_FINAL, IND_TIPOESTRATO, TIPO_FINAL, TIPO_INICIAL, IND_CLASEPREDIO, CLASE_INICIAL, CLASE_FINAL, IND_ESTRATO, ESTRATO_INICIAL, ESTRATO_FINAL, PORCINICIAL, PORCFINAL, TRPANO, TRPRAN, NUMERO_ORDENI, NUMERO_ORDENF, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID, :CODTARIFA, :PREDIO_INICIAL, :PREDIO_FINAL, :AVALUO_INICIAL, :AVALUO_FINAL, :AREAM2_INICIAL, :AREAM2_FINAL, :AREACONST_INICIAL, :AREACONST_FINAL, :AREAHA_INICIAL, :AREAHA_FINAL, :IND_TIPOESTRATO, :TIPO_FINAL, :TIPO_INICIAL, :IND_CLASEPREDIO, :CLASE_INICIAL, :CLASE_FINAL, :IND_ESTRATO, :ESTRATO_INICIAL, :ESTRATO_FINAL, :PORCINICIAL, :PORCFINAL, :TRPANO, :TRPRAN, :NUMERO_ORDENI, :NUMERO_ORDENF, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID":"$ID(type:long)","KEY_CODTARIFA":"$CODTARIFA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODTARIFA" sqlType="STRING"/>
		<param name="PREDIO_INICIAL" sqlType="STRING"/>
		<param name="PREDIO_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="AVALUO_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="AVALUO_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="AREAM2_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="AREAM2_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="AREACONST_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="AREACONST_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="AREAHA_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="AREAHA_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="IND_TIPOESTRATO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="IND_CLASEPREDIO" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_INICIAL" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="IND_ESTRATO" sqlType="STRING"/>
		<param defaultValue="" name="ESTRATO_INICIAL" sqlType="STRING"/>
		<param defaultValue="" name="ESTRATO_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="PORCINICIAL" sqlType="STRING"/>
		<param defaultValue="100" name="PORCFINAL" sqlType="STRING"/>
		<param name="TRPANO" sqlType="STRING"/>
		<param name="TRPRAN" sqlType="STRING"/>
		<param name="NUMERO_ORDENI" sqlType="STRING"/>
		<param name="NUMERO_ORDENF" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ipconfiguracionestarifas">
		<call-query href="insertIpconfiguracionestarifas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODTARIFA" query-param="CODTARIFA"/>
			<with-param name="PREDIO_INICIAL" query-param="PREDIO_INICIAL"/>
			<with-param name="PREDIO_FINAL" query-param="PREDIO_FINAL"/>
			<with-param name="AVALUO_INICIAL" query-param="AVALUO_INICIAL"/>
			<with-param name="AVALUO_FINAL" query-param="AVALUO_FINAL"/>
			<with-param name="AREAM2_INICIAL" query-param="AREAM2_INICIAL"/>
			<with-param name="AREAM2_FINAL" query-param="AREAM2_FINAL"/>
			<with-param name="AREACONST_INICIAL" query-param="AREACONST_INICIAL"/>
			<with-param name="AREACONST_FINAL" query-param="AREACONST_FINAL"/>
