	<query id="updateIpconfiguracionestarifas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_CONFIGURACIONTARIFAS SET ID=:ID, CODTARIFA=:CODTARIFA, PREDIO_INICIAL=:PREDIO_INICIAL, PREDIO_FINAL=:PREDIO_FINAL, AVALUO_INICIAL=:AVALUO_INICIAL, AVALUO_FINAL=:AVALUO_FINAL, AREAM2_INICIAL=:AREAM2_INICIAL, AREAM2_FINAL=:AREAM2_FINAL, AREACONST_INICIAL=:AREACONST_INICIAL, AREACONST_FINAL=:AREACONST_FINAL, AREAHA_INICIAL=:AREAHA_INICIAL, AREAHA_FINAL=:AREAHA_FINAL, IND_TIPOESTRATO=:IND_TIPOESTRATO, TIPO_FINAL=:TIPO_FINAL, TIPO_INICIAL=:TIPO_INICIAL, IND_CLASEPREDIO=:IND_CLASEPREDIO, CLASE_INICIAL=:CLASE_INICIAL, CLASE_FINAL=:CLASE_FINAL, IND_ESTRATO=:IND_ESTRATO, ESTRATO_INICIAL=:ESTRATO_INICIAL, ESTRATO_FINAL=:ESTRATO_FINAL, PORCINICIAL=:PORCINICIAL, PORCFINAL=:PORCFINAL, TRPANO=:TRPANO, TRPRAN=:TRPRAN, NUMERO_ORDENI=:NUMERO_ORDENI, NUMERO_ORDENF=:NUMERO_ORDENF, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_CONFIGURACIONTARIFAS.COMPANIA= :KEY_COMPANIA AND IP_CONFIGURACIONTARIFAS.ID= :KEY_ID AND IP_CONFIGURACIONTARIFAS.CODTARIFA= :KEY_CODTARIFA</sql>
