<data name="sptarifas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSptarifasAniosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO  FROM SP_TARIFAS WHERE COMPANIA = :COMPANIA ORDER BY ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptarifas/aniosporcompania">
		<call-query href="getSptarifasAniosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSptarifasPeriodosPorCompaniaYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODO  FROM SP_TARIFAS WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptarifas/periodosporcompaniayanio">
		<call-query href="getSptarifasPeriodosPorCompaniaYAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateSptarifasPorcindexa" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_TARIFAS SET  SP_TARIFAS.PORCINDEXAALCANTA =:INDALCAN,  SP_TARIFAS.PORCINDEXAACUEDU = :INDACUEDUCTO,  SP_TARIFAS.PORCINDEXAASEO = :INDASEO,  SP_TARIFAS.PORCINDEXAALUM = :INDALUM, SP_TARIFAS.DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), SP_TARIFAS.MODIFIED_BY = :MODIFIED_BY WHERE SP_TARIFAS.COMPANIA =:COMPANIA AND SP_TARIFAS.ANO = :ANO AND SP_TARIFAS.PERIODO = :PERIODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="INDALCAN" sqlType="STRING"/>
		<param name="INDACUEDUCTO" sqlType="STRING"/>
		<param name="INDASEO" sqlType="STRING"/>
		<param name="INDALUM" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sptarifas/porcindexa">
		<call-query href="updateSptarifasPorcindexa">
			<with-param name="INDALCAN" query-param="INDALCAN"/>
			<with-param name="INDACUEDUCTO" query-param="INDACUEDUCTO"/>
			<with-param name="INDASEO" query-param="INDASEO"/>
			<with-param name="INDALUM" query-param="INDALUM"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSptarifasPorcompaniaanoyperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'X' EXISTE_TARIFA  FROM SP_TARIFAS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND PERIODO = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE_TARIFA":"$EXISTE_TARIFA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptarifas/porcompaniaanoyperiodo">
		<call-query href="getSptarifasPorcompaniaanoyperiodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="insertSptarifas" keyColumns="COMPANIA,ANO,PERIODO,USO,ESTRATO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_TARIFAS (CLOROGASEOSO, FECHA_ANALISIS, TURBIEDAD, COLOR, RESULTADO_ANALISIS, DESCRIPCION, SUBCOMPLEMENTARIOENT, SINMEDICIONALCENT, SUBALCBASICOENT, SUB_TASAAMBIENTALALC, SOBREASEODOMICILIARIOENT, SOBREASEOBARRIDOENT, SOBREASEOCONSUMOENT, SUBALCSUNTUARIOENT, PORC_CONTRIBUCION_ALC, SUBASEO_DESHABITADO, SUBFIJOENT, PORC_SUBSIDIO_AC, ASEODESHABITADOS, SUBSUNTUARIOENT, PORC_SUBSIDIO_ALC, SUBBASICOENT, PRECIO_METROS_NO_COBRADOS, SUB_TASAAMBIENTALAC, METROS_NO_COBRADOS, SUBALCCOMPLEMENTARIOENT, SUBALCFIJOENT, POR_RECARGO668, SOBREASEO_DESHABITADO, SUBASEOUNICOENT, SINMEDICIONENT, PORC_CONTRIBUCION_AC, PORCENTAJEFECHA2, SUBASEODOMICILIARIO, SOBRE_TASAAMBIENTALAC, SOBRE_TASAAMBIENTALALC, RECARGOFIJO, DES_SUBTRAMOEXCEDENTE, SOBREALCFIJO, SOBREALCSUNTUARIO, DES_SUBASEOUNICO, COSTOFIJOAL, SUBALCSUNTUARIO, SOBREASEOUNICO, SUBASEOCONSUMO, SOBRECOMPLEMENTARIO, COSTOFIJOAC, SUBASEOBARRIDO, FIJOALCANTARILLADO, DES_ASEOCONSUMO, DES_ASEOUNICO, ASEOUNICO, COSTOM3REC, ASEOBARRIDO, SOBREFREC8, DES_SOBREASEOUNICO, CONSUMOBASICO, SOBREFREC7, SINMEDICION, SOBREFREC9, SOBREFREC4, SOBREFREC3, CONSUMOSUNTUARIO, SOBREASEODOMICILIARIO, SOBREFREC6, SOBREFREC5, VALORTASAAMBIENTALAC, RECONEXION, DES_SUBASEBARRIDO, SUBALCBASICO, SOBREFREC1, SOBREFREC2, DATE_CREATED, DES_TRAMOEXCEDENTE, PERMITE_HOGAR, PORC_CONTRIBUCION, TARIFAALUMBRADO, DES_SOBREASEBARRIDO, SUBSINMEDICION, DESCSEPARACIONENFUENTE, CONSUMOPROM_USOS_ESTRATOS, SUBTRAMOEX, SOBRESUNTUARIO, VALORTASAAMBIENTALALC, USO, SOBREASEOBARRIDO, PESOASEO3, SUBASEOUNICO, PESOASEO1, PESOASEO2, SUBALCCOMPLEMENTARIO, SOBREASEOCONSUMO, COMPANIA, ALCBASICO, TDI, DESCNOPUERTAPUERTA, TARIFACOMPLEMENTARIO, DISPFINALBARRIDOLIMP, SUBBASICO, SOBREASEOTARIFA2, SOBREASEOTARIFA3, ASEOCONSUMO, PERIODO, SOBREASEOTARIFA1, TASACAR, SUBFREC1, SOBRETRAMOEX, TARIFABASICO, SUBFREC9, DES_SOBREASEOCONSUMO, SUBFREC8, SUBFREC7, SUBFREC6, SUBFREC5, SUBFREC4, SUBCOMPLEMENTARIO, SUBFREC3, SUBFREC2, SOBREFIJO, COSTOM3AS, FACTOR_DESHABITADO, SUBSUNTUARIO, DES_ASEBARRIDO, PORCINDEXAACUEDU, SUBALCFIJO, COSTOM3AL, PORCINDEXAASEO, SINMEDICIONALC, ASEODOMICILIARIO, VALORFREC1, COSTOM3AC, VALORFREC4, PORC_SUBSIDIO, VALORFREC5, TARIFAASEO3, VALORFREC2, VALORFREC3, PORCALCANTARILLADO, VALORFREC8, VALORFREC9, M3SINMEDICION, VALORFREC6, TARIFAASEO2, PORCINDEXAALCANTA, VALORFREC7, TARIFAASEO1, CARGOFIJO, PORCINDEXAALUM, SUBASEOTARIFA3, CONSUMOCOMPLEMENTARIO, RECARGOFIJOMORA, DERCONEXIONALCAN, SOBRESINMEDICION, DES_SUBASEDOMICILIARIO, SUBASEOTARIFA1, SOBREALCSINMEDICION, SUBASEOTARIFA2, CREATED_BY, DES_SOBREASEDOMICILIARIO, PORCINTMORA, DES_ASEDOMICILIARIO, USOSUPERSERVICIOS, SUBFIJO, DES_SOBRETRAMOEXCEDENTE, SOBREBASICO, ALCSUNTUARIO, SOBREALCCOMPLEMENTARIO, ESTRATO, ANO, TARIFASUNTUARIO, DES_SUBASEOCONSUMO, ALCCOMPLEMENTARIO, TRAMOEXCEDENTE, SOBREALCBASICO, SUBALCSINMEDICION, COSTOM3PN, DERCONEXIONACUE, RECTRANSBARRIDOLIMP) VALUES (:CLOROGASEOSO, TO_DATE(:FECHA_ANALISIS,'DD/MM/YYYY HH24:MI:SS'), :TURBIEDAD, :COLOR, :RESULTADO_ANALISIS, :DESCRIPCION, :SUBCOMPLEMENTARIOENT, :SINMEDICIONALCENT, :SUBALCBASICOENT, :SUB_TASAAMBIENTALALC, :SOBREASEODOMICILIARIOENT, :SOBREASEOBARRIDOENT, :SOBREASEOCONSUMOENT, :SUBALCSUNTUARIOENT, :PORC_CONTRIBUCION_ALC, :SUBASEO_DESHABITADO, :SUBFIJOENT, :PORC_SUBSIDIO_AC, :ASEODESHABITADOS, :SUBSUNTUARIOENT, :PORC_SUBSIDIO_ALC, :SUBBASICOENT, :PRECIO_METROS_NO_COBRADOS, :SUB_TASAAMBIENTALAC, :METROS_NO_COBRADOS, :SUBALCCOMPLEMENTARIOENT, :SUBALCFIJOENT, :POR_RECARGO668, :SOBREASEO_DESHABITADO, :SUBASEOUNICOENT, :SINMEDICIONENT, :PORC_CONTRIBUCION_AC, :PORCENTAJEFECHA2, :SUBASEODOMICILIARIO, :SOBRE_TASAAMBIENTALAC, :SOBRE_TASAAMBIENTALALC, :RECARGOFIJO, :DES_SUBTRAMOEXCEDENTE, :SOBREALCFIJO, :SOBREALCSUNTUARIO, :DES_SUBASEOUNICO, :COSTOFIJOAL, :SUBALCSUNTUARIO, :SOBREASEOUNICO, :SUBASEOCONSUMO, :SOBRECOMPLEMENTARIO, :COSTOFIJOAC, :SUBASEOBARRIDO, :FIJOALCANTARILLADO, :DES_ASEOCONSUMO, :DES_ASEOUNICO, :ASEOUNICO, :COSTOM3REC, :ASEOBARRIDO, :SOBREFREC8, :DES_SOBREASEOUNICO, :CONSUMOBASICO, :SOBREFREC7, :SINMEDICION, :SOBREFREC9, :SOBREFREC4, :SOBREFREC3, :CONSUMOSUNTUARIO, :SOBREASEODOMICILIARIO, :SOBREFREC6, :SOBREFREC5, :VALORTASAAMBIENTALAC, :RECONEXION, :DES_SUBASEBARRIDO, :SUBALCBASICO, :SOBREFREC1, :SOBREFREC2, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :DES_TRAMOEXCEDENTE, :PERMITE_HOGAR, :PORC_CONTRIBUCION, :TARIFAALUMBRADO, :DES_SOBREASEBARRIDO, :SUBSINMEDICION, :DESCSEPARACIONENFUENTE, :CONSUMOPROM_USOS_ESTRATOS, :SUBTRAMOEX, :SOBRESUNTUARIO, :VALORTASAAMBIENTALALC, :USO, :SOBREASEOBARRIDO, :PESOASEO3, :SUBASEOUNICO, :PESOASEO1, :PESOASEO2, :SUBALCCOMPLEMENTARIO, :SOBREASEOCONSUMO, :COMPANIA, :ALCBASICO, :TDI, :DESCNOPUERTAPUERTA, :TARIFACOMPLEMENTARIO, :DISPFINALBARRIDOLIMP, :SUBBASICO, :SOBREASEOTARIFA2, :SOBREASEOTARIFA3, :ASEOCONSUMO, :PERIODO, :SOBREASEOTARIFA1, :TASACAR, :SUBFREC1, :SOBRETRAMOEX, :TARIFABASICO, :SUBFREC9, :DES_SOBREASEOCONSUMO, :SUBFREC8, :SUBFREC7, :SUBFREC6, :SUBFREC5, :SUBFREC4, :SUBCOMPLEMENTARIO, :SUBFREC3, :SUBFREC2, :SOBREFIJO, :COSTOM3AS, :FACTOR_DESHABITADO, :SUBSUNTUARIO, :DES_ASEBARRIDO, :PORCINDEXAACUEDU, :SUBALCFIJO, :COSTOM3AL, :PORCINDEXAASEO, :SINMEDICIONALC, :ASEODOMICILIARIO, :VALORFREC1, :COSTOM3AC, :VALORFREC4, :PORC_SUBSIDIO, :VALORFREC5, :TARIFAASEO3, :VALORFREC2, :VALORFREC3, :PORCALCANTARILLADO, :VALORFREC8, :VALORFREC9, :M3SINMEDICION, :VALORFREC6, :TARIFAASEO2, :PORCINDEXAALCANTA, :VALORFREC7, :TARIFAASEO1, :CARGOFIJO, :PORCINDEXAALUM, :SUBASEOTARIFA3, :CONSUMOCOMPLEMENTARIO, :RECARGOFIJOMORA, :DERCONEXIONALCAN, :SOBRESINMEDICION, :DES_SUBASEDOMICILIARIO, :SUBASEOTARIFA1, :SOBREALCSINMEDICION, :SUBASEOTARIFA2, :CREATED_BY, :DES_SOBREASEDOMICILIARIO, :PORCINTMORA, :DES_ASEDOMICILIARIO, :USOSUPERSERVICIOS, :SUBFIJO, :DES_SOBRETRAMOEXCEDENTE, :SOBREBASICO, :ALCSUNTUARIO, :SOBREALCCOMPLEMENTARIO, :ESTRATO, :ANO, :TARIFASUNTUARIO, :DES_SUBASEOCONSUMO, :ALCCOMPLEMENTARIO, :TRAMOEXCEDENTE, :SOBREALCBASICO, :SUBALCSINMEDICION, :COSTOM3PN, :DERCONEXIONACUE, :RECTRANSBARRIDOLIMP)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_USO":"$USO","KEY_ESTRATO":"$ESTRATO"}]}}		</result>
