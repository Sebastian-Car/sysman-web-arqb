	<query id="deleteSptarifas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_TARIFAS WHERE SP_TARIFAS.COMPANIA= :KEY_COMPANIA AND SP_TARIFAS.ANO= :KEY_ANO AND SP_TARIFAS.PERIODO= :KEY_PERIODO AND SP_TARIFAS.USO= :KEY_USO AND SP_TARIFAS.ESTRATO= :KEY_ESTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_USO" sqlType="STRING"/>
		<param name="KEY_ESTRATO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sptarifas">
		<call-query href="deleteSptarifas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_USO" query-param="KEY_USO"/>
			<with-param name="KEY_ESTRATO" query-param="KEY_ESTRATO"/>

		</call-query>
	</resource>
	<query id="getSptarifasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_TARIFAS.COMPANIA, SP_TARIFAS.ANO, SP_TARIFAS.PERIODO, SP_TARIFAS.USO, SP_TARIFAS.ESTRATO, SP_ESTRATOS.NOMBRE ESTRATONOMBRE, SP_USOS.NOMBRE NOMBREUSO  FROM SP_TARIFAS INNER JOIN SP_ESTRATOS ON (SP_TARIFAS.COMPANIA = SP_ESTRATOS.COMPANIA) AND (SP_TARIFAS.USO = SP_ESTRATOS.USO) AND (SP_TARIFAS.ESTRATO = SP_ESTRATOS.CODIGO) INNER JOIN SP_USOS ON (SP_TARIFAS.COMPANIA = SP_USOS.COMPANIA) AND (SP_TARIFAS.USO = SP_USOS.CODIGO) WHERE SP_TARIFAS.COMPANIA = :COMPANIA AND SP_TARIFAS.ANO = :ANO AND SP_TARIFAS.PERIODO = :PERIODO) WHERE (CASE WHEN ESTRATONOMBRE IS NULL THEN ' ' ELSE UPPER(ESTRATONOMBRE) END)  LIKE UPPER( '%' || :ESTRATONOMBRE || '%')  AND (CASE WHEN NOMBREUSO IS NULL THEN ' ' ELSE UPPER(NOMBREUSO) END)  LIKE UPPER( '%' || :NOMBREUSO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","USO":"$USO","ESTRATO":"$ESTRATO","ESTRATONOMBRE":"$ESTRATONOMBRE","NOMBREUSO":"$NOMBREUSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ESTRATONOMBRE" sqlType="STRING"/>
		<param name="NOMBREUSO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sptarifas">
		<call-query href="getSptarifasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ESTRATONOMBRE" query-param="ESTRATONOMBRE"/>
			<with-param name="NOMBREUSO" query-param="NOMBREUSO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSptarifasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_TARIFAS.COMPANIA, SP_TARIFAS.ANO, SP_TARIFAS.PERIODO, SP_TARIFAS.USO, SP_TARIFAS.ESTRATO, SP_ESTRATOS.NOMBRE ESTRATONOMBRE, SP_USOS.NOMBRE NOMBREUSO  FROM SP_TARIFAS INNER JOIN SP_ESTRATOS ON (SP_TARIFAS.COMPANIA = SP_ESTRATOS.COMPANIA) AND (SP_TARIFAS.USO = SP_ESTRATOS.USO) AND (SP_TARIFAS.ESTRATO = SP_ESTRATOS.CODIGO) INNER JOIN SP_USOS ON (SP_TARIFAS.COMPANIA = SP_USOS.COMPANIA) AND (SP_TARIFAS.USO = SP_USOS.CODIGO) WHERE SP_TARIFAS.COMPANIA = :COMPANIA AND SP_TARIFAS.ANO = :ANO AND SP_TARIFAS.PERIODO = :PERIODO) WHERE (CASE WHEN ESTRATONOMBRE IS NULL THEN ' ' ELSE UPPER(ESTRATONOMBRE) END)  LIKE UPPER( '%' || :ESTRATONOMBRE || '%')  AND (CASE WHEN NOMBREUSO IS NULL THEN ' ' ELSE UPPER(NOMBREUSO) END)  LIKE UPPER( '%' || :NOMBREUSO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ESTRATONOMBRE" sqlType="STRING"/>
		<param name="NOMBREUSO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptarifas/numero">
		<call-query href="getSptarifasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ESTRATONOMBRE" query-param="ESTRATONOMBRE"/>
			<with-param name="NOMBREUSO" query-param="NOMBREUSO"/>

		</call-query>
	</resource>
	<query id="getSptarifasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLOROGASEOSO,(TO_CHAR(FECHA_ANALISIS,'DD/MM/YYYY HH24:MI:SS')) FECHA_ANALISIS, TURBIEDAD, COLOR, RESULTADO_ANALISIS, DESCRIPCION, SUBCOMPLEMENTARIOENT, SINMEDICIONALCENT, SUBALCBASICOENT, SUB_TASAAMBIENTALALC, SOBREASEODOMICILIARIOENT, SOBREASEOBARRIDOENT, SOBREASEOCONSUMOENT, SUBALCSUNTUARIOENT, PORC_CONTRIBUCION_ALC, SUBASEO_DESHABITADO, SUBFIJOENT, PORC_SUBSIDIO_AC, ASEODESHABITADOS, SUBSUNTUARIOENT, PORC_SUBSIDIO_ALC, SUBBASICOENT, PRECIO_METROS_NO_COBRADOS, SUB_TASAAMBIENTALAC, METROS_NO_COBRADOS, SUBALCCOMPLEMENTARIOENT, SUBALCFIJOENT, POR_RECARGO668, SOBREASEO_DESHABITADO, SUBASEOUNICOENT, SINMEDICIONENT, PORC_CONTRIBUCION_AC, PORCENTAJEFECHA2, SUBASEODOMICILIARIO, SOBRE_TASAAMBIENTALAC, SOBRE_TASAAMBIENTALALC, RECARGOFIJO, DES_SUBTRAMOEXCEDENTE, SOBREALCFIJO, SOBREALCSUNTUARIO, DES_SUBASEOUNICO, COSTOFIJOAL, SUBALCSUNTUARIO, SOBREASEOUNICO, SUBASEOCONSUMO, SOBRECOMPLEMENTARIO, COSTOFIJOAC, SUBASEOBARRIDO, FIJOALCANTARILLADO, DES_ASEOCONSUMO, DES_ASEOUNICO, ASEOUNICO, COSTOM3REC, ASEOBARRIDO, SOBREFREC8, DES_SOBREASEOUNICO, CONSUMOBASICO, SOBREFREC7, SINMEDICION, SOBREFREC9, SOBREFREC4, SOBREFREC3, CONSUMOSUNTUARIO, SOBREASEODOMICILIARIO, SOBREFREC6, SOBREFREC5, VALORTASAAMBIENTALAC, RECONEXION, DES_SUBASEBARRIDO, SUBALCBASICO, SOBREFREC1, SOBREFREC2,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, DES_TRAMOEXCEDENTE,(CASE PERMITE_HOGAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_HOGAR, PORC_CONTRIBUCION, TARIFAALUMBRADO, DES_SOBREASEBARRIDO, SUBSINMEDICION, DESCSEPARACIONENFUENTE, CONSUMOPROM_USOS_ESTRATOS, SUBTRAMOEX, SOBRESUNTUARIO, VALORTASAAMBIENTALALC, USO, SOBREASEOBARRIDO, PESOASEO3, SUBASEOUNICO, PESOASEO1, PESOASEO2, SUBALCCOMPLEMENTARIO, SOBREASEOCONSUMO, COMPANIA, ALCBASICO, TDI, DESCNOPUERTAPUERTA, TARIFACOMPLEMENTARIO, DISPFINALBARRIDOLIMP, SUBBASICO, SOBREASEOTARIFA2, SOBREASEOTARIFA3, ASEOCONSUMO, PERIODO, SOBREASEOTARIFA1, TASACAR, SUBFREC1, SOBRETRAMOEX, TARIFABASICO, SUBFREC9, DES_SOBREASEOCONSUMO, SUBFREC8, SUBFREC7, SUBFREC6, SUBFREC5, SUBFREC4, SUBCOMPLEMENTARIO, SUBFREC3, SUBFREC2, SOBREFIJO, COSTOM3AS, FACTOR_DESHABITADO, SUBSUNTUARIO, DES_ASEBARRIDO, PORCINDEXAACUEDU, SUBALCFIJO, COSTOM3AL, PORCINDEXAASEO, SINMEDICIONALC, ASEODOMICILIARIO, VALORFREC1, COSTOM3AC, VALORFREC4, PORC_SUBSIDIO, VALORFREC5, TARIFAASEO3, VALORFREC2, VALORFREC3, PORCALCANTARILLADO, VALORFREC8, VALORFREC9, M3SINMEDICION, VALORFREC6, TARIFAASEO2, PORCINDEXAALCANTA, VALORFREC7, TARIFAASEO1, CARGOFIJO, PORCINDEXAALUM, SUBASEOTARIFA3, CONSUMOCOMPLEMENTARIO, RECARGOFIJOMORA, DERCONEXIONALCAN, SOBRESINMEDICION, DES_SUBASEDOMICILIARIO, SUBASEOTARIFA1, SOBREALCSINMEDICION, SUBASEOTARIFA2, CREATED_BY, MODIFIED_BY, DES_SOBREASEDOMICILIARIO, PORCINTMORA, DES_ASEDOMICILIARIO, USOSUPERSERVICIOS, SUBFIJO, DES_SOBRETRAMOEXCEDENTE, SOBREBASICO, ALCSUNTUARIO, SOBREALCCOMPLEMENTARIO, ESTRATO, ANO, TARIFASUNTUARIO, DES_SUBASEOCONSUMO, ALCCOMPLEMENTARIO, TRAMOEXCEDENTE, SOBREALCBASICO, SUBALCSINMEDICION, COSTOM3PN, DERCONEXIONACUE, RECTRANSBARRIDOLIMP  FROM SP_TARIFAS WHERE SP_TARIFAS.COMPANIA= :KEY_COMPANIA AND SP_TARIFAS.ANO= :KEY_ANO AND SP_TARIFAS.PERIODO= :KEY_PERIODO AND SP_TARIFAS.USO= :KEY_USO AND SP_TARIFAS.ESTRATO= :KEY_ESTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLOROGASEOSO":"$CLOROGASEOSO","FECHA_ANALISIS":"$FECHA_ANALISIS","TURBIEDAD":"$TURBIEDAD","COLOR":"$COLOR","RESULTADO_ANALISIS":"$RESULTADO_ANALISIS","DESCRIPCION":"$DESCRIPCION","SUBCOMPLEMENTARIOENT":"$SUBCOMPLEMENTARIOENT","SINMEDICIONALCENT":"$SINMEDICIONALCENT","SUBALCBASICOENT":"$SUBALCBASICOENT","SUB_TASAAMBIENTALALC":"$SUB_TASAAMBIENTALALC","SOBREASEODOMICILIARIOENT":"$SOBREASEODOMICILIARIOENT","SOBREASEOBARRIDOENT":"$SOBREASEOBARRIDOENT","SOBREASEOCONSUMOENT":"$SOBREASEOCONSUMOENT","SUBALCSUNTUARIOENT":"$SUBALCSUNTUARIOENT","PORC_CONTRIBUCION_ALC":"$PORC_CONTRIBUCION_ALC","SUBASEO_DESHABITADO":"$SUBASEO_DESHABITADO","SUBFIJOENT":"$SUBFIJOENT","PORC_SUBSIDIO_AC":"$PORC_SUBSIDIO_AC","ASEODESHABITADOS":"$ASEODESHABITADOS","SUBSUNTUARIOENT":"$SUBSUNTUARIOENT","PORC_SUBSIDIO_ALC":"$PORC_SUBSIDIO_ALC","SUBBASICOENT":"$SUBBASICOENT","PRECIO_METROS_NO_COBRADOS":"$PRECIO_METROS_NO_COBRADOS","SUB_TASAAMBIENTALAC":"$SUB_TASAAMBIENTALAC","METROS_NO_COBRADOS":"$METROS_NO_COBRADOS","SUBALCCOMPLEMENTARIOENT":"$SUBALCCOMPLEMENTARIOENT","SUBALCFIJOENT":"$SUBALCFIJOENT","POR_RECARGO668":"$POR_RECARGO668","SOBREASEO_DESHABITADO":"$SOBREASEO_DESHABITADO","SUBASEOUNICOENT":"$SUBASEOUNICOENT","SINMEDICIONENT":"$SINMEDICIONENT","PORC_CONTRIBUCION_AC":"$PORC_CONTRIBUCION_AC","PORCENTAJEFECHA2":"$PORCENTAJEFECHA2","SUBASEODOMICILIARIO":"$SUBASEODOMICILIARIO","SOBRE_TASAAMBIENTALAC":"$SOBRE_TASAAMBIENTALAC","SOBRE_TASAAMBIENTALALC":"$SOBRE_TASAAMBIENTALALC","RECARGOFIJO":"$RECARGOFIJO","DES_SUBTRAMOEXCEDENTE":"$DES_SUBTRAMOEXCEDENTE","SOBREALCFIJO":"$SOBREALCFIJO","SOBREALCSUNTUARIO":"$SOBREALCSUNTUARIO","DES_SUBASEOUNICO":"$DES_SUBASEOUNICO","COSTOFIJOAL":"$COSTOFIJOAL","SUBALCSUNTUARIO":"$SUBALCSUNTUARIO","SOBREASEOUNICO":"$SOBREASEOUNICO","SUBASEOCONSUMO":"$SUBASEOCONSUMO","SOBRECOMPLEMENTARIO":"$SOBRECOMPLEMENTARIO","COSTOFIJOAC":"$COSTOFIJOAC","SUBASEOBARRIDO":"$SUBASEOBARRIDO","FIJOALCANTARILLADO":"$FIJOALCANTARILLADO","DES_ASEOCONSUMO":"$DES_ASEOCONSUMO","DES_ASEOUNICO":"$DES_ASEOUNICO","ASEOUNICO":"$ASEOUNICO","COSTOM3REC":"$COSTOM3REC","ASEOBARRIDO":"$ASEOBARRIDO","SOBREFREC8":"$SOBREFREC8","DES_SOBREASEOUNICO":"$DES_SOBREASEOUNICO","CONSUMOBASICO":"$CONSUMOBASICO","SOBREFREC7":"$SOBREFREC7","SINMEDICION":"$SINMEDICION","SOBREFREC9":"$SOBREFREC9","SOBREFREC4":"$SOBREFREC4","SOBREFREC3":"$SOBREFREC3","CONSUMOSUNTUARIO":"$CONSUMOSUNTUARIO","SOBREASEODOMICILIARIO":"$SOBREASEODOMICILIARIO","SOBREFREC6":"$SOBREFREC6","SOBREFREC5":"$SOBREFREC5","VALORTASAAMBIENTALAC":"$VALORTASAAMBIENTALAC","RECONEXION":"$RECONEXION","DES_SUBASEBARRIDO":"$DES_SUBASEBARRIDO","SUBALCBASICO":"$SUBALCBASICO","SOBREFREC1":"$SOBREFREC1","SOBREFREC2":"$SOBREFREC2","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","DES_TRAMOEXCEDENTE":"$DES_TRAMOEXCEDENTE","PERMITE_HOGAR":"$PERMITE_HOGAR(type:boolean)","PORC_CONTRIBUCION":"$PORC_CONTRIBUCION","TARIFAALUMBRADO":"$TARIFAALUMBRADO","DES_SOBREASEBARRIDO":"$DES_SOBREASEBARRIDO","SUBSINMEDICION":"$SUBSINMEDICION","DESCSEPARACIONENFUENTE":"$DESCSEPARACIONENFUENTE","CONSUMOPROM_USOS_ESTRATOS":"$CONSUMOPROM_USOS_ESTRATOS","SUBTRAMOEX":"$SUBTRAMOEX","SOBRESUNTUARIO":"$SOBRESUNTUARIO","VALORTASAAMBIENTALALC":"$VALORTASAAMBIENTALALC","USO":"$USO","SOBREASEOBARRIDO":"$SOBREASEOBARRIDO","PESOASEO3":"$PESOASEO3","SUBASEOUNICO":"$SUBASEOUNICO","PESOASEO1":"$PESOASEO1","PESOASEO2":"$PESOASEO2","SUBALCCOMPLEMENTARIO":"$SUBALCCOMPLEMENTARIO","SOBREASEOCONSUMO":"$SOBREASEOCONSUMO","COMPANIA":"$COMPANIA","ALCBASICO":"$ALCBASICO","TDI":"$TDI","DESCNOPUERTAPUERTA":"$DESCNOPUERTAPUERTA","TARIFACOMPLEMENTARIO":"$TARIFACOMPLEMENTARIO","DISPFINALBARRIDOLIMP":"$DISPFINALBARRIDOLIMP","SUBBASICO":"$SUBBASICO","SOBREASEOTARIFA2":"$SOBREASEOTARIFA2","SOBREASEOTARIFA3":"$SOBREASEOTARIFA3","ASEOCONSUMO":"$ASEOCONSUMO","PERIODO":"$PERIODO","SOBREASEOTARIFA1":"$SOBREASEOTARIFA1","TASACAR":"$TASACAR","SUBFREC1":"$SUBFREC1","SOBRETRAMOEX":"$SOBRETRAMOEX","TARIFABASICO":"$TARIFABASICO","SUBFREC9":"$SUBFREC9","DES_SOBREASEOCONSUMO":"$DES_SOBREASEOCONSUMO","SUBFREC8":"$SUBFREC8","SUBFREC7":"$SUBFREC7","SUBFREC6":"$SUBFREC6","SUBFREC5":"$SUBFREC5","SUBFREC4":"$SUBFREC4","SUBCOMPLEMENTARIO":"$SUBCOMPLEMENTARIO","SUBFREC3":"$SUBFREC3","SUBFREC2":"$SUBFREC2","SOBREFIJO":"$SOBREFIJO","COSTOM3AS":"$COSTOM3AS","FACTOR_DESHABITADO":"$FACTOR_DESHABITADO","SUBSUNTUARIO":"$SUBSUNTUARIO","DES_ASEBARRIDO":"$DES_ASEBARRIDO","PORCINDEXAACUEDU":"$PORCINDEXAACUEDU","SUBALCFIJO":"$SUBALCFIJO","COSTOM3AL":"$COSTOM3AL","PORCINDEXAASEO":"$PORCINDEXAASEO","SINMEDICIONALC":"$SINMEDICIONALC","ASEODOMICILIARIO":"$ASEODOMICILIARIO","VALORFREC1":"$VALORFREC1","COSTOM3AC":"$COSTOM3AC","VALORFREC4":"$VALORFREC4","PORC_SUBSIDIO":"$PORC_SUBSIDIO","VALORFREC5":"$VALORFREC5","TARIFAASEO3":"$TARIFAASEO3","VALORFREC2":"$VALORFREC2","VALORFREC3":"$VALORFREC3","PORCALCANTARILLADO":"$PORCALCANTARILLADO","VALORFREC8":"$VALORFREC8","VALORFREC9":"$VALORFREC9","M3SINMEDICION":"$M3SINMEDICION","VALORFREC6":"$VALORFREC6","TARIFAASEO2":"$TARIFAASEO2","PORCINDEXAALCANTA":"$PORCINDEXAALCANTA","VALORFREC7":"$VALORFREC7","TARIFAASEO1":"$TARIFAASEO1","CARGOFIJO":"$CARGOFIJO","PORCINDEXAALUM":"$PORCINDEXAALUM","SUBASEOTARIFA3":"$SUBASEOTARIFA3","CONSUMOCOMPLEMENTARIO":"$CONSUMOCOMPLEMENTARIO","RECARGOFIJOMORA":"$RECARGOFIJOMORA","DERCONEXIONALCAN":"$DERCONEXIONALCAN","SOBRESINMEDICION":"$SOBRESINMEDICION","DES_SUBASEDOMICILIARIO":"$DES_SUBASEDOMICILIARIO","SUBASEOTARIFA1":"$SUBASEOTARIFA1","SOBREALCSINMEDICION":"$SOBREALCSINMEDICION","SUBASEOTARIFA2":"$SUBASEOTARIFA2","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DES_SOBREASEDOMICILIARIO":"$DES_SOBREASEDOMICILIARIO","PORCINTMORA":"$PORCINTMORA","DES_ASEDOMICILIARIO":"$DES_ASEDOMICILIARIO","USOSUPERSERVICIOS":"$USOSUPERSERVICIOS","SUBFIJO":"$SUBFIJO","DES_SOBRETRAMOEXCEDENTE":"$DES_SOBRETRAMOEXCEDENTE","SOBREBASICO":"$SOBREBASICO","ALCSUNTUARIO":"$ALCSUNTUARIO","SOBREALCCOMPLEMENTARIO":"$SOBREALCCOMPLEMENTARIO","ESTRATO":"$ESTRATO","ANO"