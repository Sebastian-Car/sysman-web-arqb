		<param name="NOMBRE_PROYECTO" sqlType="STRING"/>
		<param name="VIG_INICIO" sqlType="STRING"/>
		<param name="VIG_FINAL" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO" sqlType="STRING"/>
		<param name="VALOR_SOLICITADO" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO" sqlType="STRING"/>
		<param name="VALOR_DISMINUIDO" sqlType="STRING"/>
		<param name="AVANCE" sqlType="STRING"/>
