	<query id="getProyectosDatosBasicosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBREPROYECTO, CODIGOBPIM, VALOREJECUTADO, VALORPROGRAMADO, (CASE PERIOCIDAD WHEN '01' THEN 'ANUAL' WHEN '02' THEN 'SEMESTRAL' WHEN '03' THEN 'CUATRO MESES' WHEN '04' THEN 'TRIMESTRAL' WHEN '06' THEN 'BIMESTRAL' WHEN '12' THEN 'MENSUAL' END) AS PERIODICIDAD, VALORTOTAL  FROM PROYECTOS WHERE PROYECTOS.COMPANIA = :COMPANIA AND PROYECTOS.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO","CODIGOBPIM":"$CODIGOBPIM","VALOREJECUTADO":"$VALOREJECUTADO","VALORPROGRAMADO":"$VALORPROGRAMADO","PERIODICIDAD":"$PERIODICIDAD","VALORTOTAL":"$VALORTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/datosbasicos">
		<call-query href="getProyectosDatosBasicosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getProyectosPagProyectoProgFinancieraQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SUBSTR(PROYECTOS.CODIGOBPIM,-4,4) BPIM, PROYECTOS.CODIGO, PROYECTOS.CODIGOBPIM, PROYECTOS.NOMBREPROYECTO, SUBSTR(PROYECTOS.CODIGOBPIM,-4,4) EXPR1, PROYECTOS.DEPENDENCIA, PROYECTOS.VIGENCIAINICIO, PROYECTOS.VIGENCIAFIN, PROYECTOS.PERIOCIDAD, PROYECTOS.VALORTOTAL, PROYECTOS.VALOREJECUTADO, PROYECTOS.VALORPROGRAMADO, DEPENDENCIA.NOMBRE  FROM PROYECTOS LEFT JOIN DEPENDENCIA ON PROYECTOS.COMPANIA = DEPENDENCIA.COMPANIA AND PROYECTOS.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE PROYECTOS.COMPANIA = :COMPANIA AND PROYECTOS.DEPENDENCIA = CASE WHEN :DEPENDENCIA IS NOT NULL THEN :DEPENDENCIA ELSE DEPENDENCIA END ORDER BY PROYECTOS.CODIGO, SUBSTR(PROYECTOS.CODIGOBPIM,-4,4)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER(:CODIGOBPIM || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BPIM":"$BPIM","CODIGO":"$CODIGO","CODIGOBPIM":"$CODIGOBPIM","NOMBREPROYECTO":"$NOMBREPROYECTO","EXPR1":"$EXPR1","DEPENDENCIA":"$DEPENDENCIA","VIGENCIAINICIO":"$VIGENCIAINICIO(type:integer)","VIGENCIAFIN":"$VIGENCIAFIN(type:integer)","PERIOCIDAD":"$PERIOCIDAD","VALORTOTAL":"$VALORTOTAL","VALOREJECUTADO":"$VALOREJECUTADO","VALORPROGRAMADO":"$VALORPROGRAMADO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proyectos/proyectoprogfinanciera/pag">
		<call-query href="getProyectosPagProyectoProgFinancieraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectosNumProyectoProgFinancieraQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SUBSTR(PROYECTOS.CODIGOBPIM,-4,4) BPIM, PROYECTOS.CODIGO, PROYECTOS.CODIGOBPIM, PROYECTOS.NOMBREPROYECTO, SUBSTR(PROYECTOS.CODIGOBPIM,-4,4) EXPR1, PROYECTOS.DEPENDENCIA, PROYECTOS.VIGENCIAINICIO, PROYECTOS.VIGENCIAFIN, PROYECTOS.PERIOCIDAD, PROYECTOS.VALORTOTAL, PROYECTOS.VALOREJECUTADO, PROYECTOS.VALORPROGRAMADO, DEPENDENCIA.NOMBRE  FROM PROYECTOS LEFT JOIN DEPENDENCIA ON PROYECTOS.COMPANIA = DEPENDENCIA.COMPANIA AND PROYECTOS.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE PROYECTOS.COMPANIA = :COMPANIA AND PROYECTOS.DEPENDENCIA = CASE WHEN :DEPENDENCIA IS NOT NULL THEN :DEPENDENCIA ELSE DEPENDENCIA END ORDER BY PROYECTOS.CODIGO, SUBSTR(PROYECTOS.CODIGOBPIM,-4,4)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER(:CODIGOBPIM || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/proyectoprogfinanciera/num">
