	<query id="deleteProyectos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PROYECTOS WHERE PROYECTOS.COMPANIA= :KEY_COMPANIA AND PROYECTOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="proyectos">
		<call-query href="deleteProyectos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getProyectosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, CODIGOBPIM, NOMBREPROYECTO  FROM PROYECTOS WHERE COMPANIA = :COMPANIA AND (VIGENCIAINICIO BETWEEN :ANOINICIAL AND :ANOFINAL OR VIGENCIAFIN BETWEEN :ANOINICIAL AND :ANOFINAL) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER(:CODIGOBPIM || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CODIGOBPIM":"$CODIGOBPIM","NOMBREPROYECTO":"$NOMBREPROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proyectos">
		<call-query href="getProyectosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, CODIGOBPIM, NOMBREPROYECTO  FROM PROYECTOS WHERE COMPANIA = :COMPANIA AND (VIGENCIAINICIO BETWEEN :ANOINICIAL AND :ANOFINAL OR VIGENCIAFIN BETWEEN :ANOINICIAL AND :ANOFINAL) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER(:CODIGOBPIM || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/numero">
		<call-query href="getProyectosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>

		</call-query>
	</resource>
	<query id="getProyectosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CODIGO, DESC_POBLACION, DESTINO_SIRECI,(CASE IND_CIUDADANIA WHEN 0 THEN 'false' ELSE 'true' END) IND_CIUDADANIA,(CASE IND_DESARROLLO WHEN 0 THEN 'false' ELSE 'true' END) IND_DESARROLLO,(CASE IND_EXISTENCIA WHEN 0 THEN 'false' ELSE 'true' END) IND_EXISTENCIA,(CASE IND_PDA WHEN 0 THEN 'false' ELSE 'true' END) IND_PDA,(CASE IND_PROTECCION WHEN 0 THEN 'false' ELSE 'true' END) IND_PROTECCION, N_POBLACION, N_POBLACION_OBJ, TIPOPROYECTO, CODIGOBPIM, NOMBREPROYECTO, PROCESO, ENTIDADPROPONENTE, DEPENDENCIA, RESPONSABLE, SUCURSAL, CARGORESPONSABLE, VIGENCIAINICIO, VIGENCIAFIN, PRODUCTO, CANTIDAD, UNIDAD, ESTADOACTUAL, PORCEJECUCION, ETAPA, INTERVENTOR, VALORSOLICITADO, VALORMUNICIPIO, VALORDEPARTAMENTO, VALORFONDONAL, VALORCOMUNIDAD, VALOROTROS, RUBROPPTAL,(TO_CHAR(FECHAENVIODPTO,'DD/MM/YYYY HH24:MI:SS')) FECHAENVIODPTO,(TO_CHAR(FECHAENVIONACION,'DD/MM/YYYY HH24:MI:SS')) FECHAENVIONACION, ANOSVIDA, PLAZO, SECTORDNP, SUBSECTORDNP, PERIOCIDAD, RESPONSABLERELACIONADO, SUCURSALRELACIONADO, VALOREJECUTADO, VALORPROGRAMADO,(TO_CHAR(FECHAREGISTRO,'DD/MM/YYYY HH24:MI:SS')) FECHAREGISTRO, VALORNACION, VALORDPTO, ESTADONACION, ESTADODPTO, RESPONSABLENACION, SUCURSALNACION, RESPONSABLEDPTO, SUCURSALDPTO, CODIGONACION, CODIGODPTO, VALORANNO1, VALORANNO2, VALORANNO3, VALORANNO4, TIPODEGASTO, VALOROTRAENTIDAD, ESTADOOTRAENTIDAD, RESPONSABLEOTRAENTIDAD, SUCURSALOTRAENTIDAD, CODIGOOTRAENTIDAD,(TO_CHAR(FECHAENVIOOTRAENTIDAD,'DD/MM/YYYY HH24:MI:SS')) FECHAENVIOOTRAENTIDAD,(CASE CONPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) CONPROGRAMACION, CONTRATONACION, CONTRATODPTO, CONTRATOOTRAENTIDAD, OTRAENTIDAD, CONTRATOPROYECTO,(CASE ENVIADONACION WHEN 0 THEN 'false' ELSE 'true' END) ENVIADONACION,(CASE ENVIADODPTO WHEN 0 THEN 'false' ELSE 'true' END) ENVIADODPTO,(CASE ENVIADOOTRAENTIDAD WHEN 0 THEN 'false' ELSE 'true' END) ENVIADOOTRAENTIDAD, TIPOREGISTRO,(TO_CHAR(FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, RUTAARCHIVOFISICO, RUTAARCHIVOFISICO1, RUTAARCHIVOFISICO3, OBJETO, VALORTOTAL_AUX,(CASE FINANCIADO_REGALIAS WHEN 0 THEN 'false' ELSE 'true' END) FINANCIADO_REGALIAS, PERIOCIDAD_ANTERIOR, CDP, REGCDP, NUMERO_REGISTRO, PROGRAMA,(CASE PROCESOFINANCIERO WHEN 0 THEN 'false' ELSE 'true' END) PROCESOFINANCIERO, VALORTOTAL,(CASE IREGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) IREGISTRADO, TEMP_VALORTOTAL, CONCEPTO_OBSERV, RESPONSABLE_RADIC, SUCURSAL_RADIC, CARGO_RESPONS_RADIC, DEPENDENCIA_RESPONS_RADIC, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PROYECTOS WHERE PROYECTOS.COMPANIA= :KEY_COMPANIA AND PROYECTOS.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","DESC_POBLACION":"$DESC_POBLACION","DESTINO_SIRECI":"$DESTINO_SIRECI","IND_CIUDADANIA":"$IND_CIUDADANIA(type:boolean)","IND_DESARROLLO":"$IND_DESARROLLO(type:boolean)","IND_EXISTENCIA":"$IND_EXISTENCIA(type:boolean)","IND_PDA":"$IND_PDA(type:boolean)","IND_PROTECCION":"$IND_PROTECCION(type:boolean)","N_POBLACION":"$N_POBLACION","N_POBLACION_OBJ":"$N_POBLACION_OBJ","TIPOPROYECTO":"$TIPOPROYECTO","CODIGOBPIM":"$CODIGOBPIM","NOMBREPROYECTO":"$NOMBREPROYECTO","PROCESO":"$PROCESO","ENTIDADPROPONENTE":"$ENTIDADPROPONENTE","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","CARGORESPONSABLE":"$CARGORESPONSABLE","VIGENCIAINICIO":"$VIGENCIAINICIO(type:integer)","VIGENCIAFIN":"$VIGENCIAFIN(type:integer)","PRODUCTO":"$PRODUCTO","CANTIDAD":"$CANTIDAD","UNIDAD":"$UNIDAD","ESTADOACTUAL":"$ESTADOACTUAL","PORCEJECUCION":"$PORCEJECUCION","ETAPA":"$ETAPA","INTERVENTOR":"$INTERVENTOR","VALORSOLICITADO":"$VALORSOLICITADO","VALORMUNICIPIO":"$VALORMUNICIPIO","VALORDEPARTAMENTO":"$VALORDEPARTAMENTO","VALORFONDONAL":"$VALORFONDONAL","VALORCOMUNIDAD":"$VALORCOMUNIDAD","VALOROTROS":"$VALOROTROS","RUBROPPTAL":"$RUBROPPTAL","FECHAENVIODPTO":"$FECHAENVIODPTO","FECHAENVIONACION":"$FECHAENVIONACION","ANOSVIDA":"$ANOSVIDA","PLAZO":"$PLAZO","SECTORDNP":"$SECTORDNP","SUBSECTORDNP":"$SUBSECTORDNP","PERIOCIDAD":"$PERIOCIDAD","RESPONSABLERELACIONADO":"$RESPONSABLERELACIONADO","SUCURSALRELACIONADO":"$SUCURSALRELACIONADO","VALOREJECUTADO":"$VALOREJECUTADO","VALORPROGRAMADO":"$VALORPROGRAMADO","FECHAREGISTRO":"$FECHAREGISTRO","VALORNACION":"$VALORNACION","VALORDPTO":"$VALORDPTO","ESTADONACION":"$ESTADONACION","ESTADODPTO":"$ESTADODPTO","RESPONSABLENACION":"$RESPONSABLENACION","SUCURSALNACION":"$SUCURSALNACION","RESPONSABLEDPTO":"$RESPONSABLEDPTO","SUCURSALDPTO":"$SUCURSALDPTO","CODIGONACION":"$CODIGONACION","CODIGODPTO":"$CODIGODPTO","VALORANNO1":"$VALORANNO1","VALORANNO2":"$VALOR