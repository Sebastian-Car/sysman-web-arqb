D, CODIGOOTRAENTIDAD=:CODIGOOTRAENTIDAD, FECHAENVIOOTRAENTIDAD=TO_DATE(:FECHAENVIOOTRAENTIDAD,'DD/MM/YYYY HH24:MI:SS'), CONPROGRAMACION=:CONPROGRAMACION, CONTRATONACION=:CONTRATONACION, CONTRATODPTO=:CONTRATODPTO, CONTRATOOTRAENTIDAD=:CONTRATOOTRAENTIDAD, OTRAENTIDAD=:OTRAENTIDAD, CONTRATOPROYECTO=:CONTRATOPROYECTO, ENVIADONACION=:ENVIADONACION, ENVIADODPTO=:ENVIADODPTO, ENVIADOOTRAENTIDAD=:ENVIADOOTRAENTIDAD, TIPOREGISTRO=:TIPOREGISTRO, FECHA_ACTUALIZACION=TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), RUTAARCHIVOFISICO=:RUTAARCHIVOFISICO, RUTAARCHIVOFISICO1=:RUTAARCHIVOFISICO1, RUTAARCHIVOFISICO3=:RUTAARCHIVOFISICO3, OBJETO=:OBJETO, VALORTOTAL_AUX=:VALORTOTAL_AUX, FINANCIADO_REGALIAS=:FINANCIADO_REGALIAS, PERIOCIDAD_ANTERIOR=:PERIOCIDAD_ANTERIOR, CDP=:CDP, REGCDP=:REGCDP, NUMERO_REGISTRO=:NUMERO_REGISTRO, PROGRAMA=:PROGRAMA, PROCESOFINANCIERO=:PROCESOFINANCIERO, VALORTOTAL=:VALORTOTAL, IREGISTRADO=:IREGISTRADO, TEMP_VALORTOTAL=:TEMP_VALORTOTAL, CONCEPTO_OBSERV=:CONCEPTO_OBSERV, RESPONSABLE_RADIC=:RESPONSABLE_RADIC, SUCURSAL_RADIC=:SUCURSAL_RADIC, CARGO_RESPONS_RADIC=:CARGO_RESPONS_RADIC, DEPENDENCIA_RESPONS_RADIC=:DEPENDENCIA_RESPONS_RADIC, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE PROYECTOS.COMPANIA= :KEY_COMPANIA AND PROYECTOS.CODIGO= :KEY_CODIGO</sql>
