	<query id="getProyectosPagPeriodicidadpordependenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.CODIGOBPIM, PROYECTOS.PERIOCIDAD, PROYECTOS.PROGRAMA, PROYECTOS.NOMBREPROYECTO  FROM PROYECTOS WHERE PROYECTOS.COMPANIA= :COMPANIA AND DEPENDENCIA = CASE WHEN :DEPENDENCIA = 'T' AND :DEPENDENCIA_SEC = 'T' THEN DEPENDENCIA ELSE CASE WHEN :DEPENDENCIA IS NULL AND :DEPENDENCIA_SEC IS NULL THEN DEPENDENCIA ELSE TO_CHAR( CASE DEPENDENCIA WHEN :DEPENDENCIA THEN DEPENDENCIA WHEN :DEPENDENCIA_SEC THEN DEPENDENCIA END) END END ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER(:CODIGOBPIM || '%')  AND (CASE WHEN PERIOCIDAD IS NULL THEN ' ' ELSE UPPER(PERIOCIDAD) END)  LIKE UPPER(:PERIOCIDAD || '%')  AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END)  LIKE UPPER( '%' || :PROGRAMA || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER(:NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CODIGOBPIM":"$CODIGOBPIM","PERIOCIDAD":"$PERIOCIDAD","PROGRAMA":"$PROGRAMA","NOMBREPROYECTO":"$NOMBREPROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DEPENDENCIA_SEC" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="PERIOCIDAD" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
