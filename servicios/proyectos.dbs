		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="ENTIDAD_PROPONENTE" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHAREGISTRO" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="TIPOREGISTRO" sqlType="STRING"/>
		<param name="ESTADOACTUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
