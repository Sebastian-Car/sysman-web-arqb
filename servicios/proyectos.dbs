	<query id="getProyectosPagMonitorDeProyectosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT P.COMPANIA, P.CODIGO, P.CODIGOBPIM CODIGO_BPIM, P.NOMBREPROYECTO NOMBRE_PROYECTO, P.VIGENCIAINICIO VIG_INICIO, P.VIGENCIAFIN VIG_FINAL, P.VALORTOTAL VALOR_TOTAL, P.VALORPROGRAMADO VALOR_PROGRAMADO, P.VALORSOLICITADO VALOR_SOLICITADO, P.VALOREJECUTADO VALOR_EJECUTADO, P.VALOR_DISMINUIDO VALOR_DISMINUIDO, CASE WHEN NVL(P.VALOREJECUTADO,0) = 0 OR NVL(P.VALORPROGRAMADO,0) = 0 THEN 0 ELSE P.VALOREJECUTADO / P.VALORPROGRAMADO END AVANCE, D.NOMBRE DEPENDENCIA, CONCAT(T.NOMBRE1 ,CONCAT(' ' ,CONCAT(T.NOMBRE2 ,CONCAT(' ' ,CONCAT(T.APELLIDO1 ,CONCAT( ' ' , T.APELLIDO2)))))) RESPONSABLE, E.NOMBRE ENTIDAD_PROPONENTE, OBJETO,(TO_CHAR(FECHAREGISTRO,'DD/MM/YYYY HH24:MI:SS')) FECHAREGISTRO,(TO_CHAR(FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, TIPOREGISTRO, CASE ESTADOACTUAL WHEN 'E' THEN 'Ejecución' WHEN 'S' THEN 'Sin ejecutar' WHEN 'P' THEN 'Ejecutado parcialmente' WHEN 'T' THEN 'Ejecutado' END ESTADOACTUAL FROM PROYECTOS P LEFT JOIN DEPENDENCIA D ON P.COMPANIA = D.COMPANIA AND P.DEPENDENCIA = D.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE DR ON P.COMPANIA = DR.COMPANIA AND P.DEPENDENCIA = DR.DEPENDENCIA AND P.RESPONSABLE = DR.RESPONSABLE LEFT JOIN RESPONSABLE R ON DR.COMPANIA = R.COMPANIA AND DR.RESPONSABLE = R.CEDULA LEFT JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL LEFT JOIN BP_ENTIDADES E ON P.COMPANIA = E.COMPANIA AND P.ENTIDADPROPONENTE = E.CODIGO WHERE P.COMPANIA =:COMPANIA AND P.CODIGO = CASE WHEN (:PROYECTO ) = 'TODOS' THEN P.CODIGO ELSE :PROYECTO END AND D.CODIGO = CASE WHEN (:DEPENDENCIAINI ) = 'T' THEN D.CODIGO ELSE :DEPENDENCIAINI END AND P.VIGENCIAINICIO &lt;= CASE WHEN (:VIGENCIAINICIO ) = 'TODAS' THEN P.VIGENCIAINICIO ELSE TO_NUMBER(:VIGENCIAINICIO) END AND P.VIGENCIAFIN &gt;= CASE WHEN (:VIGENCIAFIN ) = 'TODAS' THEN P.VIGENCIAFIN ELSE TO_NUMBER(:VIGENCIAFIN) END AND P.ESTADOACTUAL = CASE WHEN (:ESTADO ) = 'X' THEN P.ESTADOACTUAL ELSE :ESTADO END) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN CODIGO_BPIM IS NULL THEN ' ' ELSE UPPER(CODIGO_BPIM) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_BPIM), '%')) AND (CASE WHEN NOMBRE_PROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROYECTO), '%')) AND (CASE WHEN VIG_INICIO IS NULL THEN ' ' ELSE UPPER(VIG_INICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:VIG_INICIO), '%')) AND (CASE WHEN VIG_FINAL IS NULL THEN ' ' ELSE UPPER(VIG_FINAL) END) LIKE UPPER(CONCAT(:VIG_FINAL, '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN VALOR_PROGRAMADO IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO) END) LIKE UPPER(CONCAT(:VALOR_PROGRAMADO, '%')) AND (CASE WHEN VALOR_SOLICITADO IS NULL THEN ' ' ELSE UPPER(VALOR_SOLICITADO) END) LIKE UPPER(CONCAT(:VALOR_SOLICITADO, '%')) AND (CASE WHEN VALOR_EJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO) END) LIKE UPPER(CONCAT(:VALOR_EJECUTADO, '%')) AND (CASE WHEN VALOR_DISMINUIDO IS NULL THEN ' ' ELSE UPPER(VALOR_DISMINUIDO) END) LIKE UPPER(CONCAT(:VALOR_DISMINUIDO, '%')) AND (CASE WHEN AVANCE IS NULL THEN ' ' ELSE UPPER(AVANCE) END) LIKE UPPER(CONCAT(:AVANCE, '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DEPENDENCIA), '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE), '%')) AND (CASE WHEN ENTIDAD_PROPONENTE IS NULL THEN ' ' ELSE UPPER(ENTIDAD_PROPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:ENTIDAD_PROPONENTE), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN FECHAREGISTRO IS NULL THEN ' ' ELSE UPPER(FECHAREGISTRO) END) LIKE UPPER(CONCAT(:FECHAREGISTRO, '%')) AND (CASE WHEN FECHA_ACTUALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_ACTUALIZACION) END) LIKE UPPER(CONCAT(:FECHA_ACTUALIZACION, '%')) AND (CASE WHEN TIPOREGISTRO IS NULL THEN ' ' ELSE UPPER(TIPOREGISTRO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOREGISTRO), '%')) AND (CASE WHEN ESTADOACTUAL IS NULL THEN ' ' ELSE UPPER(ESTADOACTUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADOACTUAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CODIGO_BPIM":"$CODIGO_BPIM","NOMBRE_PROYECTO":"$NOMBRE_PROYECTO","VIG_INICIO":"$VIG_INICIO(type:integer)","VIG_FINAL":"$VIG_FINAL(type:integer)","VALOR_TOTAL":"$VALOR_TOTAL","VALOR_PROGRAMADO":"$VALOR_PROGRAMADO","VALOR_SOLICITADO":"$VALOR_SOLICITADO","VALOR_EJECUTADO":"$VALOR_EJECUTADO","VALOR_DISMINUIDO":"$VALOR_DISMINUIDO","AVANCE":"$AVANCE(type:double)","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","ENTIDAD_PROPONENTE":"$ENTIDAD_PROPONENTE","OBJETO":"$OBJETO","FECHAREGISTRO":"$FECHAREGISTRO","FECHA_ACTUALIZACION":"$FECHA_ACTUALIZACION","TIPOREGISTRO":"$TIPOREGISTRO","ESTADOACTUAL":"$ESTADOACTUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="DEPENDENCIAINI" sqlType="STRING"/>
		<param name="VIGENCIAINICIO" sqlType="STRING"/>
		<param name="VIGENCIAFIN" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
