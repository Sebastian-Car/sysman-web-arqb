		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CODIGOBPIM":"$CODIGOBPIM","NOMBREPROYECTO":"$NOMBREPROYECTO"}]}}		</result>
