	<query id="getProyectosPagTodosPorCodigoNombreProyectoFCompaniaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.VIGENCIAINICIO, PROYECTOS.VIGENCIAFIN, (MAX(BP_PROYECTOSRUBROS.DIMENSION) KEEP (DENSE_RANK LAST ORDER BY ROWNUM) ) ID_DIMENSION, (MAX(BP_PROYECTOSRUBROS.SECTOR) KEEP (DENSE_RANK LAST ORDER BY ROWNUM) ) ID_SECTOR, (MAX(BP_PROYECTOSRUBROS.PROGRAMA) KEEP (DENSE_RANK LAST ORDER BY ROWNUM)) ID_PROGRAMA, (MAX(BP_PROYECTOSRUBROS.SUBPROGRAMA) KEEP (DENSE_RANK LAST ORDER BY ROWNUM) ) ID_SUBPROGRAMA  FROM PROYECTOS INNER JOIN BP_PROYECTOSRUBROS ON PROYECTOS.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND PROYECTOS.CODIGO = BP_PROYECTOSRUBROS.PROYECTO WHERE PROYECTOS.COMPANIA = :COMPANIA AND PROYECTOS.CODIGO &gt;=:CODIGO_INCIIAL GROUP BY PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.VIGENCIAINICIO, PROYECTOS.VIGENCIAFIN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%')  AND (CASE WHEN VIGENCIAINICIO IS NULL THEN ' ' ELSE UPPER(VIGENCIAINICIO) END)  LIKE UPPER(:VIGENCIAINICIO || '%')  AND (CASE WHEN VIGENCIAFIN IS NULL THEN ' ' ELSE UPPER(VIGENCIAFIN) END)  LIKE UPPER(:VIGENCIAFIN || '%')  AND (CASE WHEN ID_DIMENSION IS NULL THEN ' ' ELSE UPPER(ID_DIMENSION) END)  LIKE UPPER(:ID_DIMENSION || '%')  AND (CASE WHEN ID_SECTOR IS NULL THEN ' ' ELSE UPPER(ID_SECTOR) END)  LIKE UPPER(:ID_SECTOR || '%')  AND (CASE WHEN ID_PROGRAMA IS NULL THEN ' ' ELSE UPPER(ID_PROGRAMA) END)  LIKE UPPER(:ID_PROGRAMA || '%')  AND (CASE WHEN ID_SUBPROGRAMA IS NULL THEN ' ' ELSE UPPER(ID_SUBPROGRAMA) END)  LIKE UPPER(:ID_SUBPROGRAMA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO","VIGENCIAINICIO":"$VIGENCIAINICIO(type:integer)","VIGENCIAFIN":"$VIGENCIAFIN(type:integer)","ID_DIMENSION":"$ID_DIMENSION","ID_SECTOR":"$ID_SECTOR","ID_PROGRAMA":"$ID_PROGRAMA","ID_SUBPROGRAMA":"$ID_SUBPROGRAMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_INCIIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIAINICIO" sqlType="STRING"/>
		<param name="VIGENCIAFIN" sqlType="STRING"/>
		<param name="ID_DIMENSION" sqlType="STRING"/>
		<param name="ID_SECTOR" sqlType="STRING"/>
		<param name="ID_PROGRAMA" sqlType="STRING"/>
		<param name="ID_SUBPROGRAMA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
