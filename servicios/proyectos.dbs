	<query id="updateProyectosIndicadorDeRegistrado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROYECTOS SET IREGISTRADO = :IREGISTRADO ,   NUMERO_REGISTRO = :NUMEROREGISTRO,   DATE_MODIFIED = SYSDATE ,   MODIFIED_BY   = :MODIFIED_BY WHERE COMPANIA  = :COMPANIA AND CODIGO      = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IREGISTRADO" sqlType="STRING"/>
		<param name="NUMEROREGISTRO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="proyectos/indicadorderegistrado">
		<call-query href="updateProyectosIndicadorDeRegistrado">
			<with-param name="IREGISTRADO" query-param="IREGISTRADO"/>
			<with-param name="NUMEROREGISTRO" query-param="NUMEROREGISTRO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getProyectosPagTodosPorCodigoNombreProyectoFCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.VIGENCIAINICIO, PROYECTOS.VIGENCIAFIN  FROM PROYECTOS INNER JOIN BP_PROYECTOSRUBROS ON PROYECTOS.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND PROYECTOS.CODIGO = BP_PROYECTOSRUBROS.PROYECTO WHERE PROYECTOS.COMPANIA = :COMPANIA GROUP BY PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.VIGENCIAINICIO, PROYECTOS.VIGENCIAFIN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%')  AND (CASE WHEN VIGENCIAINICIO IS NULL THEN ' ' ELSE UPPER(VIGENCIAINICIO) END)  LIKE UPPER(:VIGENCIAINICIO || '%')  AND (CASE WHEN VIGENCIAFIN IS NULL THEN ' ' ELSE UPPER(VIGENCIAFIN) END)  LIKE UPPER(:VIGENCIAFIN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO","VIGENCIAINICIO":"$VIGENCIAINICIO(type:integer)","VIGENCIAFIN":"$VIGENCIAFIN(type:integer)"}]}}		</result>
