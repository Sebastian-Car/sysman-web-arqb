<data name="proyectos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getProyectosPagTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO CODIGOBP, NOMBREPROYECTO, VIGENCIAINICIO, VIGENCIAFIN, DEPENDENCIA  FROM PROYECTOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOBP IS NULL THEN ' ' ELSE UPPER(CODIGOBP) END)  LIKE UPPER(:CODIGOBP || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%')  AND (CASE WHEN VIGENCIAINICIO IS NULL THEN ' ' ELSE UPPER(VIGENCIAINICIO) END)  LIKE UPPER(:VIGENCIAINICIO || '%')  AND (CASE WHEN VIGENCIAFIN IS NULL THEN ' ' ELSE UPPER(VIGENCIAFIN) END)  LIKE UPPER( '%' || :VIGENCIAFIN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBP":"$CODIGOBP","NOMBREPROYECTO":"$NOMBREPROYECTO","VIGENCIAINICIO":"$VIGENCIAINICIO(type:integer)","VIGENCIAFIN":"$VIGENCIAFIN(type:integer)","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBP" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIAINICIO" sqlType="STRING"/>
		<param name="VIGENCIAFIN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proyectos/todos/pag">
		<call-query href="getProyectosPagTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBP" query-param="CODIGOBP"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="VIGENCIAINICIO" query-param="VIGENCIAINICIO"/>
			<with-param name="VIGENCIAFIN" query-param="VIGENCIAFIN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectosNumTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO CODIGOBP, NOMBREPROYECTO, VIGENCIAINICIO, VIGENCIAFIN, DEPENDENCIA  FROM PROYECTOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOBP IS NULL THEN ' ' ELSE UPPER(CODIGOBP) END)  LIKE UPPER(:CODIGOBP || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%')  AND (CASE WHEN VIGENCIAINICIO IS NULL THEN ' ' ELSE UPPER(VIGENCIAINICIO) END)  LIKE UPPER( '%' || :VIGENCIAINICIO || '%')  AND (CASE WHEN VIGENCIAFIN IS NULL THEN ' ' ELSE UPPER(VIGENCIAFIN) END)  LIKE UPPER( '%' || :VIGENCIAFIN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBP" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIAINICIO" sqlType="STRING"/>
		<param name="VIGENCIAFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/todos/num">
		<call-query href="getProyectosNumTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBP" query-param="CODIGOBP"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="VIGENCIAINICIO" query-param="VIGENCIAINICIO"/>
			<with-param name="VIGENCIAFIN" query-param="VIGENCIAFIN"/>

		</call-query>
	</resource>
	<query id="getProyectosPagTodosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO  FROM PROYECTOS WHERE PROYECTOS.COMPANIA = :COMPANIA ORDER BY PROYECTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proyectos/todosporcodigo/pag">
		<call-query href="getProyectosPagTodosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectosNumTodosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO  FROM PROYECTOS WHERE PROYECTOS.COMPANIA = :COMPANIA ORDER BY PROYECTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/todosporcodigo/num">
		<call-query href="getProyectosNumTodosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>

		</call-query>
	</resource>
	<query id="getProyectosPagTodosPorCodigoYNombreProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.PERIOCIDAD,(CASE PROYECTOS.CONPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) CONPROGRAMACION FROM PROYECTOS WHERE PROYECTOS.COMPANIA = :COMPANIA ORDER BY PROYECTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO","PERIOCIDAD":"$PERIOCIDAD","CONPROGRAMACION":"$CONPROGRAMACION(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proyectos/todosporcodigoynombreproyecto/pag">
		<call-query href="getProyectosPagTodosPorCodigoYNombreProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectosNumTodosPorCodigoYNombreProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.PERIOCIDAD,(CASE PROYECTOS.CONPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) CONPROGRAMACION FROM PROYECTOS WHERE PROYECTOS.COMPANIA = :COMPANIA ORDER BY PROYECTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/todosporcodigoynombreproyecto/num">
		<call-query href="getProyectosNumTodosPorCodigoYNombreProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>

		</call-query>
	</resource>
	<query id="getProyectosPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.CODIGOBPIM  FROM PROYECTOS WHERE PROYECTOS.COMPANIA =:COMPANIA ORDER BY PROYECTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO","CODIGOBPIM":"$CODIGOBPIM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proyectos/todosporcompania/pag">
		<call-query href="getProyectosPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectosNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROYECTOS.CODIGO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.CODIGOBPIM  FROM PROYECTOS WHERE PROYECTOS.COMPANIA =:COMPANIA ORDER BY PROYECTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/todosporcompania/num">
		<call-query href="getProyectosNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>

		</call-query>
	</resource>
	<query id="insertProyectos" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PROYECTOS (COMPANIA, CODIGO, DESC_POBLACION, DESTINO_SIRECI, IND_CIUDADANIA, IND_DESARROLLO, IND_EXISTENCIA, IND_PDA, IND_PROTECCION, N_POBLACION, N_POBLACION_OBJ, TIPOPROYECTO, CODIGOBPIM, NOMBREPROYECTO, PROCESO, ENTIDADPROPONENTE, DEPENDENCIA, RESPONSABLE, SUCURSAL, CARGORESPONSABLE, VIGENCIAINICIO, VIGENCIAFIN, PRODUCTO, CANTIDAD, UNIDAD, ESTADOACTUAL, PORCEJECUCION, ETAPA, INTERVENTOR, VALORSOLICITADO, VALORMUNICIPIO, VALORDEPARTAMENTO, VALORFONDONAL, VALORCOMUNIDAD, VALOROTROS, RUBROPPTAL, FECHAENVIODPTO, FECHAENVIONACION, ANOSVIDA, PLAZO, SECTORDNP, SUBSECTORDNP, PERIOCIDAD, RESPONSABLERELACIONADO, SUCURSALRELACIONADO, VALOREJECUTADO, VALORPROGRAMADO, FECHAREGISTRO, VALORNACION, VALORDPTO, ESTADONACION, ESTADODPTO, RESPONSABLENACION, SUCURSALNACION, RESPONSABLEDPTO, SUCURSALDPTO, CODIGONACION, CODIGODPTO, VALORANNO1, VALORANNO2, VALORANNO3, VALORANNO4, TIPODEGASTO, VALOROTRAENTIDAD, ESTADOOTRAENTIDAD, RESPONSABLEOTRAENTIDAD, SUCURSALOTRAENTIDAD, CODIGOOTRAENTIDAD, FECHAENVIOOTRAENTIDAD, CONPROGRAMACION, CONTRATONACION, CONTRATODPTO, CONTRATOOTRAENTIDAD, OTRAENTIDAD, CONTRATOPROYECTO, ENVIADONACION, ENVIADODPTO, ENVIADOOTRAENTIDAD, TIPOREGISTRO, FECHA_ACTUALIZACION, RUTAARCHIVOFISICO, RUTAARCHIVOFISICO1, RUTAARCHIVOFISICO3, OBJETO, VALORTOTAL_AUX, FINANCIADO_REGALIAS, PERIOCIDAD_ANTERIOR, CDP, REGCDP, NUMERO_REGISTRO, PROGRAMA, PROCESOFINANCIERO, VALORTOTAL, IREGISTRADO, TEMP_VALORTOTAL, CONCEPTO_OBSERV, RESPONSABLE_RADIC, SUCURSAL_RADIC, CARGO_RESPONS_RADIC, DEPENDENCIA_RESPONS_RADIC, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO, :DESC_POBLACION, :DESTINO_SIRECI, :IND_CIUDADANIA, :IND_DESARROLLO, :IND_EXISTENCIA, :IND_PDA, :IND_PROTECCION, :N_POBLACION, :N_POBLACION_OBJ, :TIPOPROYECTO, :CODIGOBPIM, :NOMBREPROYECTO, :PROCESO, :ENTIDADPROPONENTE, :DEPENDENCIA, :RESPONSABLE, :SUCURSAL, :CARGORESPONSABLE, :VIGENCIAINICIO, :VIGENCIAFIN, :PRODUCTO, :CANTIDAD, :UNIDAD, :ESTADOACTUAL, :PORCEJECUCION, :ETAPA, :INTERVENTOR, :VALORSOLICITADO, :VALORMUNICIPIO, :VALORDEPARTAMENTO, :VALORFONDONAL, :VALORCOMUNIDAD, :VALOROTROS, :RUBROPPTAL, TO_DATE(:FECHAENVIODPTO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAENVIONACION,'DD/MM/YYYY HH24:MI:SS'), :ANOSVIDA, :PLAZO, :SECTORDNP, :SUBSECTORDNP, :PERIOCIDAD, :RESPONSABLERELACIONADO, :SUCURSALRELACIONADO, :VALOREJECUTADO, :VALORPROGRAMADO, TO_DATE(:FECHAREGISTRO,'DD/MM/YYYY HH24:MI:SS'), :VALORNACION, :VALORDPTO, :ESTADONACION, :ESTADODPTO, :RESPONSABLENACION, :SUCURSALNACION, :RESPONSABLEDPTO, :SUCURSALDPTO, :CODIGONACION, :CODIGODPTO, :VALORANNO1, :VALORANNO2, :VALORANNO3, :VALORANNO4, :TIPODEGASTO, :VALOROTRAENTIDAD, :ESTADOOTRAENTIDAD, :RESPONSABLEOTRAENTIDAD, :SUCURSALOTRAENTIDAD, :CODIGOOTRAENTIDAD, TO_DATE(:FECHAENVIOOTRAENTIDAD,'DD/MM/YYYY HH24:MI:SS'), :CONPROGRAMACION, :CONTRATONACION, :CONTRATODPTO, :CONTRATOOTRAENTIDAD, :OTRAENTIDAD, :CONTRATOPROYECTO, :ENVIADONACION, :ENVIADODPTO, :ENVIADOOTRAENTIDAD, :TIPOREGISTRO, TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), :RUTAARCHIVOFISICO, :RUTAARCHIVOFISICO1, :RUTAARCHIVOFISICO3, :OBJETO, :VALORTOTAL_AUX, :FINANCIADO_REGALIAS, :PERIOCIDAD_ANTERIOR, :CDP, :REGCDP, :NUMERO_REGISTRO, :PROGRAMA, :PROCESOFINANCIERO, :VALORTOTAL, :IREGISTRADO, :TEMP_VALORTOTAL, :CONCEPTO_OBSERV, :RESPONSABLE_RADIC, :SUCURSAL_RADIC, :CARGO_RESPONS_RADIC, :DEPENDENCIA_RESPONS_RADIC, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="DESC_POBLACION" sqlType="STRING"/>
		<param defaultValue="" name="DESTINO_SIRECI" sqlType="STRING"/>
		<param defaultValue="0" name="IND_CIUDADANIA" sqlType="STRING"/>
		<param defaultValue="0" name="IND_DESARROLLO" sqlType="STRING"/>
		<param defaultValue="0" name="IND_EXISTENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="IND_PDA" sqlType="STRING"/>
		<param defaultValue="0" name="IND_PROTECCION" sqlType="STRING"/>
		<param defaultValue="0" name="N_POBLACION" sqlType="STRING"/>
		<param defaultValue="0" name="N_POBLACION_OBJ" sqlType="STRING"/>
		<param defaultValue="" name="TIPOPROYECTO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param defaultValue="" name="NOMBREPROYECTO" sqlType="STRING"/>
		<param defaultValue="" name="PROCESO" sqlType="STRING"/>
		<param defaultValue="" name="ENTIDADPROPONENTE" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="CARGORESPONSABLE" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIAINICIO" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIAFIN" sqlType="STRING"/>
		<param defaultValue="" name="PRODUCTO" sqlType="STRING"/>
		<param defaultValue="" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD" sqlType="STRING"/>
		<param defaultValue="" name="ESTADOACTUAL" sqlType="STRING"/>
		<param defaultValue="0" name="PORCEJECUCION" sqlType="STRING"/>
		<param defaultValue="" name="ETAPA" sqlType="STRING"/>
		<param defaultValue="" name="INTERVENTOR" sqlType="STRING"/>
		<param defaultValue="0" name="VALORSOLICITADO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORMUNICIPIO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORDEPARTAMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORFONDONAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORCOMUNIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOROTROS" sqlType="STRING"/>
		<param defaultValue="" name="RUBROPPTAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHAENVIODPTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAENVIONACION" sqlType="STRING"/>
		<param defaultValue="0" name="ANOSVIDA" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZO" sqlType="STRING"/>
		<param defaultValue="" name="SECTORDNP" sqlType="STRING"/>
		<param defaultValue="" name="SUBSECTORDNP" sqlType="STRING"/>
		<param defaultValue="" name="PERIOCIDAD" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLERELACIONADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSALRELACIONADO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOREJECUTADO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORPROGRAMADO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAREGISTRO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORNACION" sqlType="STRING"/>
		<param defaultValue="0" name="VALORDPTO" sqlType="STRING"/>
		<param defaultValue="" name="ESTADONACION" sqlType="STRING"/>
		<param defaultValue="" name="ESTADODPTO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLENACION" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSALNACION" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLEDPTO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSALDPTO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGONACION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGODPTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORANNO1" sqlType="STRING"/>
		<param defaultValue="0" name="VALORANNO2" sqlType="STRING"/>
		<param defaultValue="0" name="VALORANNO3" sqlType="STRING"/>
		<param defaultValue="0" name="VALORANNO4" sqlType="STRING"/>
		<param defaultValue="" name="TIPODEGASTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOROTRAENTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="ESTADOOTRAENTIDAD" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLEOTRAENTIDAD" sqlType="STRING"/>
