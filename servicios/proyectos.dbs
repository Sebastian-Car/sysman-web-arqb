			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectosNumProyectoscontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBREPROYECTO NOMBRE FROM PROYECTOS WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectos/proyectoscontrato/num">
		<call-query href="getProyectosNumProyectoscontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateProyectosUpdateproyectosdesdereferencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROYECTOS SET CODIGO = :CODIGO , CODIGOBPIM = :CODIGOBPIM, NOMBREPROYECTO = :NOMBREPROYECTO, VIGENCIAINICIO = :VIGENCIAINICIO, VIGENCIAFIN = :VIGENCIAFIN, DATE_MODIFIED = SYSDATE , MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :KEY_COMPANIA AND CODIGO = :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIAINICIO" sqlType="STRING"/>
		<param name="VIGENCIAFIN" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="proyectos/updateproyectosdesdereferencia">
		<call-query href="updateProyectosUpdateproyectosdesdereferencia">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="VIGENCIAINICIO" query-param="VIGENCIAINICIO"/>
			<with-param name="VIGENCIAFIN" query-param="VIGENCIAFIN"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>