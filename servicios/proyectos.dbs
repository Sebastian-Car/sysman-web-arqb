	<query id="getProyectosPagCodnombreporproyectoinicialydependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBREPROYECTO, VIGENCIAINICIO, VIGENCIAFIN, DEPENDENCIA  FROM PROYECTOS WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :PROYECTOINI AND DEPENDENCIA = NVL(:DEPENDENCIA,DEPENDENCIA) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%')  AND (CASE WHEN VIGENCIAINICIO IS NULL THEN ' ' ELSE UPPER(VIGENCIAINICIO) END)  LIKE UPPER(:VIGENCIAINICIO || '%')  AND (CASE WHEN VIGENCIAFIN IS NULL THEN ' ' ELSE UPPER(VIGENCIAFIN) END)  LIKE UPPER(:VIGENCIAFIN || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO","VIGENCIAINICIO":"$VIGENCIAINICIO(type:integer)","VIGENCIAFIN":"$VIGENCIAFIN(type:integer)","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
