			<with-param name="VIG_FINAL" query-param="VIG_FINAL"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="VALOR_PROGRAMADO" query-param="VALOR_PROGRAMADO"/>
			<with-param name="VALOR_SOLICITADO" query-param="VALOR_SOLICITADO"/>
			<with-param name="VALOR_EJECUTADO" query-param="VALOR_EJECUTADO"/>
			<with-param name="VALOR_DISMINUIDO" query-param="VALOR_DISMINUIDO"/>
			<with-param name="AVANCE" query-param="AVANCE"/>
