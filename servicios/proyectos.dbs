	<query id="getProyectosValoresTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NVL(SUM(P.VALORTOTAL),0), '99,999,999,999,999,990.90') VALOR_TOTAL, TO_CHAR(NVL(SUM(P.VALORPROGRAMADO),0), '99,999,999,999,999,990.90') VALOR_PROGRAMADO, TO_CHAR(NVL(SUM(P.VALORSOLICITADO),0), '99,999,999,999,999,990.90') VALOR_SOLICITADO, TO_CHAR(NVL(SUM(P.VALOREJECUTADO),0), '99,999,999,999,999,990.90') VALOR_EJECUTADO, TO_CHAR(NVL(SUM(P.VALOR_DISMINUIDO),0), '99,999,999,999,999,990.90') VALOR_DISMINUIDO  FROM PROYECTOS P LEFT JOIN DEPENDENCIA D ON P.COMPANIA = D.COMPANIA AND P.DEPENDENCIA = D.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE DR ON P.COMPANIA = DR.COMPANIA AND P.DEPENDENCIA = DR.DEPENDENCIA AND P.RESPONSABLE = DR.RESPONSABLE LEFT JOIN RESPONSABLE R ON DR.COMPANIA = R.COMPANIA AND DR.RESPONSABLE = R.CEDULA LEFT JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL LEFT JOIN BP_ENTIDADES E ON P.COMPANIA = E.COMPANIA AND P.ENTIDADPROPONENTE = E.CODIGO WHERE P.COMPANIA = :COMPANIA AND P.CODIGO = CASE WHEN (:PROYECTO)='TODOS' THEN P.CODIGO ELSE :PROYECTO END AND D.CODIGO = CASE WHEN (:DEPENDENCIA)='T' THEN D.CODIGO ELSE :DEPENDENCIA END AND P.VIGENCIAINICIO &lt;= CASE WHEN (:VIGENCIAINICIO)='TODAS' THEN P.VIGENCIAINICIO ELSE TO_NUMBER(:VIGENCIAINICIO) END AND P.VIGENCIAFIN &gt;= CASE WHEN (:VIGENCIAFIN)='TODAS' THEN P.VIGENCIAFIN ELSE TO_NUMBER(:VIGENCIAFIN) END AND P.ESTADOACTUAL = CASE WHEN (:ESTADO)='X' THEN P.ESTADOACTUAL ELSE :ESTADO END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_TOTAL":"$VALOR_TOTAL","VALOR_PROGRAMADO":"$VALOR_PROGRAMADO","VALOR_SOLICITADO":"$VALOR_SOLICITADO","VALOR_EJECUTADO":"$VALOR_EJECUTADO","VALOR_DISMINUIDO":"$VALOR_DISMINUIDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="VIGENCIAINICIO" sqlType="STRING"/>
		<param name="VIGENCIAFIN" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
