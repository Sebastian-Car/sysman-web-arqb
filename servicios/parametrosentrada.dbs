	<query id="deleteParametrosentrada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PARAMETROS_DE_ENTRADA WHERE PARAMETROS_DE_ENTRADA.COMPANIA= :KEY_COMPANIA AND PARAMETROS_DE_ENTRADA.NIT= :KEY_NIT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="parametrosentrada">
		<call-query href="deleteParametrosentrada">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>

		</call-query>
	</resource>
	<query id="getParametrosentradaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PARAMETROS_DE_ENTRADA.COMPANIA, PARAMETROS_DE_ENTRADA.NIT, PARAMETROS_DE_ENTRADA.TELEFONO, PARAMETROS_DE_ENTRADA.DIRECCION, CIUDAD.NOMBRE CIUDAD, DEPARTAMENTO.NOMBRE DEPARTAMENTO, COMPANIA.NOMBRE NOMBRECOMPANIA  FROM PARAMETROS_DE_ENTRADA INNER JOIN DEPARTAMENTO ON PARAMETROS_DE_ENTRADA.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND PARAMETROS_DE_ENTRADA.PAIS = DEPARTAMENTO.PAIS INNER JOIN CIUDAD ON PARAMETROS_DE_ENTRADA.CIUDAD = CIUDAD.CODIGO AND PARAMETROS_DE_ENTRADA.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND PARAMETROS_DE_ENTRADA.PAIS = CIUDAD.PAIS INNER JOIN COMPANIA ON PARAMETROS_DE_ENTRADA.COMPANIA = COMPANIA.CODIGO ORDER BY PARAMETROS_DE_ENTRADA.COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END)  LIKE UPPER( '%' || :TELEFONO || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN CIUDAD IS NULL THEN ' ' ELSE UPPER(CIUDAD) END)  LIKE UPPER( '%' || :CIUDAD || '%')  AND (CASE WHEN DEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(DEPARTAMENTO) END)  LIKE UPPER( '%' || :DEPARTAMENTO || '%')  AND (CASE WHEN NOMBRECOMPANIA IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPANIA) END)  LIKE UPPER( '%' || :NOMBRECOMPANIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","TELEFONO":"$TELEFONO","DIRECCION":"$DIRECCION","CIUDAD":"$CIUDAD","DEPARTAMENTO":"$DEPARTAMENTO","NOMBRECOMPANIA":"$NOMBRECOMPANIA"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECOMPANIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="parametrosentrada">
		<call-query href="getParametrosentradaPaginaQuery">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="CIUDAD" query-param="CIUDAD"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="NOMBRECOMPANIA" query-param="NOMBRECOMPANIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getParametrosentradaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PARAMETROS_DE_ENTRADA.COMPANIA, PARAMETROS_DE_ENTRADA.NIT, PARAMETROS_DE_ENTRADA.TELEFONO, PARAMETROS_DE_ENTRADA.DIRECCION, CIUDAD.NOMBRE CIUDAD, DEPARTAMENTO.NOMBRE DEPARTAMENTO, COMPANIA.NOMBRE NOMBRECOMPANIA  FROM PARAMETROS_DE_ENTRADA INNER JOIN DEPARTAMENTO ON PARAMETROS_DE_ENTRADA.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND PARAMETROS_DE_ENTRADA.PAIS = DEPARTAMENTO.PAIS INNER JOIN CIUDAD ON PARAMETROS_DE_ENTRADA.CIUDAD = CIUDAD.CODIGO AND PARAMETROS_DE_ENTRADA.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND PARAMETROS_DE_ENTRADA.PAIS = CIUDAD.PAIS INNER JOIN COMPANIA ON PARAMETROS_DE_ENTRADA.COMPANIA = COMPANIA.CODIGO ORDER BY PARAMETROS_DE_ENTRADA.COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END)  LIKE UPPER( '%' || :TELEFONO || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN CIUDAD IS NULL THEN ' ' ELSE UPPER(CIUDAD) END)  LIKE UPPER( '%' || :CIUDAD || '%')  AND (CASE WHEN DEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(DEPARTAMENTO) END)  LIKE UPPER( '%' || :DEPARTAMENTO || '%')  AND (CASE WHEN NOMBRECOMPANIA IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPANIA) END)  LIKE UPPER( '%' || :NOMBRECOMPANIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECOMPANIA" sqlType="STRING"/>

	</query>
