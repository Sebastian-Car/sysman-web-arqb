<data name="parametrosentrada" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getParametrosentradaTodosporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,NIT,RAZONSOCIAL,TELEFONO,FAX,TIPONIT,TIPOVINCULADOS,DIRECCION,CUPOSALUD,SALARIOMINIMO,PAIS,DEPARTAMENTO,CIUDAD,TIPOAPORTANTE,PRESENTACION,CODIGO_SUCURSALPAGADORA,PORC_PATRON_AFP,PORC_EMPLEADO_AFP,PORC_FSP_AFP,SALARIOSMINIMOS_FSP,PORC_TOTAL_AFP,PORC_PATRON_EPS,PORC_EMPLEADO_EPS,PORC_GARANTIAS_EPS,PORC_TOTAL_EPS,PORC_FONDO_ARP,PORC_ICBF,PORC_SENA,PORC_CAJA,PORC_ESAP,PORC_INST,SALARIOS_MAXIMOS_AFP,SALARIOS_MAXIMOS_EPS,SALARIOS_MAXIMOS_ARP,PORC_SALARIO_INTEGRAL,CORREOELECTRONICO,NOMBRESUCURSAL,EXONERADO_1607,ACOGE_1429,PORC_PATRON_EPS_EXO,PORC_CAJA_EXO,PORC_ICBF_EXO,PORC_SENA_EXO,PORC_ESAP_EXO,PORC_INST_EXO,PORC_TOTAL_EPS_EXO,(CASE ES_DECLARANTE WHEN 0 THEN 'false' ELSE 'true' END) ES_DECLARANTE,(CASE APLICA_ART_5_1429 WHEN 0 THEN 'false' ELSE 'true' END) APLICA_ART_5_1429,CREATED_BY,MODIFIED_BY,INDICADORVACACIONES,DIASLABORADOS,DIASDISFRUTE,DIASPAGARVACACIONES,VACACIONESDINERO,DIASENCARGO,DIASREEMPLAZO,SALARIOENCARGO,SALARIOREEMPLAZO,DEDUCIBLE,DIASHABILES,IBL,CESANTIAPARCIAL,CESANTIACONSOLIDADA,INTERESCESANTIA,LABSIGPERIODO,PERIODOVACACIONES,PORCRETENCION,PORCGASTOS,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PARAMETROS_DE_ENTRADA WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","RAZONSOCIAL":"$RAZONSOCIAL","TELEFONO":"$TELEFONO","FAX":"$FAX","TIPONIT":"$TIPONIT","TIPOVINCULADOS":"$TIPOVINCULADOS","DIRECCION":"$DIRECCION","CUPOSALUD":"$CUPOSALUD","SALARIOMINIMO":"$SALARIOMINIMO","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","TIPOAPORTANTE":"$TIPOAPORTANTE","PRESENTACION":"$PRESENTACION","CODIGO_SUCURSALPAGADORA":"$CODIGO_SUCURSALPAGADORA","PORC_PATRON_AFP":"$PORC_PATRON_AFP","PORC_EMPLEADO_AFP":"$PORC_EMPLEADO_AFP","PORC_FSP_AFP":"$PORC_FSP_AFP","SALARIOSMINIMOS_FSP":"$SALARIOSMINIMOS_FSP","PORC_TOTAL_AFP":"$PORC_TOTAL_AFP","PORC_PATRON_EPS":"$PORC_PATRON_EPS","PORC_EMPLEADO_EPS":"$PORC_EMPLEADO_EPS","PORC_GARANTIAS_EPS":"$PORC_GARANTIAS_EPS","PORC_TOTAL_EPS":"$PORC_TOTAL_EPS","PORC_FONDO_ARP":"$PORC_FONDO_ARP","PORC_ICBF":"$PORC_ICBF","PORC_SENA":"$PORC_SENA","PORC_CAJA":"$PORC_CAJA","PORC_ESAP":"$PORC_ESAP","PORC_INST":"$PORC_INST","SALARIOS_MAXIMOS_AFP":"$SALARIOS_MAXIMOS_AFP","SALARIOS_MAXIMOS_EPS":"$SALARIOS_MAXIMOS_EPS","SALARIOS_MAXIMOS_ARP":"$SALARIOS_MAXIMOS_ARP","PORC_SALARIO_INTEGRAL":"$PORC_SALARIO_INTEGRAL","CORREOELECTRONICO":"$CORREOELECTRONICO","NOMBRESUCURSAL":"$NOMBRESUCURSAL","EXONERADO_1607":"$EXONERADO_1607","ACOGE_1429":"$ACOGE_1429","PORC_PATRON_EPS_EXO":"$PORC_PATRON_EPS_EXO","PORC_CAJA_EXO":"$PORC_CAJA_EXO","PORC_ICBF_EXO":"$PORC_ICBF_EXO","PORC_SENA_EXO":"$PORC_SENA_EXO","PORC_ESAP_EXO":"$PORC_ESAP_EXO","PORC_INST_EXO":"$PORC_INST_EXO","PORC_TOTAL_EPS_EXO":"$PORC_TOTAL_EPS_EXO","ES_DECLARANTE":"$ES_DECLARANTE(type:boolean)","APLICA_ART_5_1429":"$APLICA_ART_5_1429(type:boolean)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","INDICADORVACACIONES":"$INDICADORVACACIONES(type:integer)","DIASLABORADOS":"$DIASLABORADOS(type:integer)","DIASDISFRUTE":"$DIASDISFRUTE(type:integer)","DIASPAGARVACACIONES":"$DIASPAGARVACACIONES(type:integer)","VACACIONESDINERO":"$VACACIONESDINERO(type:integer)","DIASENCARGO":"$DIASENCARGO(type:integer)","DIASREEMPLAZO":"$DIASREEMPLAZO(type:integer)","SALARIOENCARGO":"$SALARIOENCARGO(type:integer)","SALARIOREEMPLAZO":"$SALARIOREEMPLAZO(type:integer)","DEDUCIBLE":"$DEDUCIBLE(type:integer)","DIASHABILES":"$DIASHABILES(type:integer)","IBL":"$IBL(type:integer)","CESANTIAPARCIAL":"$CESANTIAPARCIAL(type:integer)","CESANTIACONSOLIDADA":"$CESANTIACONSOLIDADA(type:integer)","INTERESCESANTIA":"$INTERESCESANTIA(type:integer)","LABSIGPERIODO":"$LABSIGPERIODO(type:integer)","PERIODOVACACIONES":"$PERIODOVACACIONES(type:integer)","PORCRETENCION":"$PORCRETENCION(type:integer)","PORCGASTOS":"$PORCGASTOS(type:integer)","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="parametrosentrada/todosporcompania">
		<call-query href="getParametrosentradaTodosporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getParametrosentradaParametrosEnAutoliquidacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,RAZONSOCIAL, NIT, TELEFONO, DIRECCION, TIPOAPORTANTE, PRESENTACION, CODIGO_SUCURSALPAGADORA, FAX  FROM PARAMETROS_DE_ENTRADA WHERE COMPANIA = :KEY_COMPANIA AND NIT = :KEY_NIT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","RAZONSOCIAL":"$RAZONSOCIAL","NIT":"$NIT","TELEFONO":"$TELEFONO","DIRECCION":"$DIRECCION","TIPOAPORTANTE":"$TIPOAPORTANTE","PRESENTACION":"$PRESENTACION","CODIGO_SUCURSALPAGADORA":"$CODIGO_SUCURSALPAGADORA","FAX":"$FAX"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="parametrosentrada/parametrosenautoliquidacion">
		<call-query href="getParametrosentradaParametrosEnAutoliquidacionQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>

		</call-query>
	</resource>
	<query id="updateParametrosentradaAutoliquidacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PARAMETROS_DE_ENTRADA SET RAZONSOCIAL=:RAZONSOCIAL, TELEFONO=:TELEFONO, DIRECCION=:DIRECCION, TIPOAPORTANTE=:TIPOAPORTANTE, PRESENTACION=:PRESENTACION, CODIGO_SUCURSALPAGADORA=:CODIGO_SUCURSALPAGADORA, FAX=:FAX, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PARAMETROS_DE_ENTRADA.COMPANIA= :KEY_COMPANIA AND PARAMETROS_DE_ENTRADA.NIT= :KEY_NIT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="RAZONSOCIAL" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TIPOAPORTANTE" sqlType="STRING"/>
		<param name="PRESENTACION" sqlType="STRING"/>
		<param name="CODIGO_SUCURSALPAGADORA" sqlType="STRING"/>
		<param name="FAX" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="parametrosentrada/autoliquidacion">
		<call-query href="updateParametrosentradaAutoliquidacion">
			<with-param name="RAZONSOCIAL" query-param="RAZONSOCIAL"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TIPOAPORTANTE" query-param="TIPOAPORTANTE"/>
			<with-param name="PRESENTACION" query-param="PRESENTACION"/>
			<with-param name="CODIGO_SUCURSALPAGADORA" query-param="CODIGO_SUCURSALPAGADORA"/>
			<with-param name="FAX" query-param="FAX"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>

		</call-query>
	</resource>
	<query id="getParametrosentradaValidarNitQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NIT  FROM PARAMETROS_DE_ENTRADA WHERE COMPANIA = :COMPANIA AND NIT = :NIT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="parametrosentrada/validarnit">
		<call-query href="getParametrosentradaValidarNitQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>

		</call-query>
	</resource>
	<query id="getParametrosentradaPornit31Query"  useConfig="sysmandsunist">
		<sql>SELECT NIT FROM PARAMETROS_DE_ENTRADA WHERE COMPANIA = :UN_COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT"}]}}		</result>
		<param name="UN_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="parametrosentrada/pornit31">
		<call-query href="getParametrosentradaPornit31Query">
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertParametrosentrada" keyColumns="COMPANIA,NIT" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PARAMETROS_DE_ENTRADA (EXONERADO_1607, ACOGE_1429, PRESENTACION, CODIGO_SUCURSALPAGADORA, NOMBRESUCURSAL, CORREOELECTRONICO, NIT, RAZONSOCIAL, TELEFONO, FAX, TIPONIT, TIPOVINCULADOS, TIPOAPORTANTE, DIRECCION, INDICADORVACACIONES, DIASLABORADOS, DIASDISFRUTE, DIASPAGARVACACIONES, VACACIONESDINERO, DIASENCARGO, DIASREEMPLAZO, SALARIOENCARGO, SALARIOREEMPLAZO, CUPOSALUD, DEDUCIBLE, DIASHABILES, IBL, CESANTIAPARCIAL, CESANTIACONSOLIDADA, INTERESCESANTIA, LABSIGPERIODO, PERIODOVACACIONES, SALARIOMINIMO, PORCRETENCION, CIUDAD, PAIS, DEPARTAMENTO, PORCGASTOS, COMPANIA, PORC_PATRON_EPS, PORC_EMPLEADO_EPS, PORC_CAJA, PORC_ICBF, PORC_SENA, PORC_INST, PORC_ESAP, PORC_PATRON_AFP, PORC_EMPLEADO_AFP, SALARIOSMINIMOS_FSP, PORC_FSP_AFP, PORC_FONDO_ARP, SALARIOS_MAXIMOS_AFP, SALARIOS_MAXIMOS_EPS, SALARIOS_MAXIMOS_ARP, PORC_SALARIO_INTEGRAL, PORC_TOTAL_AFP, PORC_GARANTIAS_EPS, DATE_CREATED, CREATED_BY) VALUES (:EXONERADO_1607, :ACOGE_1429, :PRESENTACION, :CODIGO_SUCURSALPAGADORA, :NOMBRESUCURSAL, :CORREOELECTRONICO, :NIT, :RAZONSOCIAL, :TELEFONO, :FAX, :TIPONIT, :TIPOVINCULADOS, :TIPOAPORTANTE, :DIRECCION, :INDICADORVACACIONES, :DIASLABORADOS, :DIASDISFRUTE, :DIASPAGARVACACIONES, :VACACIONESDINERO, :DIASENCARGO, :DIASREEMPLAZO, :SALARIOENCARGO, :SALARIOREEMPLAZO, :CUPOSALUD, :DEDUCIBLE, :DIASHABILES, :IBL, :CESANTIAPARCIAL, :CESANTIACONSOLIDADA, :INTERESCESANTIA, :LABSIGPERIODO, :PERIODOVACACIONES, :SALARIOMINIMO, :PORCRETENCION, :CIUDAD, :PAIS, :DEPARTAMENTO, :PORCGASTOS, :COMPANIA, :PORC_PATRON_EPS, :PORC_EMPLEADO_EPS, :PORC_CAJA, :PORC_ICBF, :PORC_SENA, :PORC_INST, :PORC_ESAP, :PORC_PATRON_AFP, :PORC_EMPLEADO_AFP, :SALARIOSMINIMOS_FSP, :PORC_FSP_AFP, :PORC_FONDO_ARP, :SALARIOS_MAXIMOS_AFP, :SALARIOS_MAXIMOS_EPS, :SALARIOS_MAXIMOS_ARP, :PORC_SALARIO_INTEGRAL, :PORC_TOTAL_AFP, :PORC_GARANTIAS_EPS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT"}]}}		</result>
		<param defaultValue="N" name="EXONERADO_1607" sqlType="STRING"/>
		<param defaultValue="N" name="ACOGE_1429" sqlType="STRING"/>
		<param defaultValue="" name="PRESENTACION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_SUCURSALPAGADORA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRESUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="CORREOELECTRONICO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="RAZONSOCIAL" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO" sqlType="STRING"/>
		<param defaultValue="" name="FAX" sqlType="STRING"/>
		<param defaultValue="" name="TIPONIT" sqlType="STRING"/>
		<param defaultValue="0" name="TIPOVINCULADOS" sqlType="STRING"/>
		<param defaultValue="" name="TIPOAPORTANTE" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="403" name="INDICADORVACACIONES" sqlType="STRING"/>
		<param defaultValue="9" name="DIASLABORADOS" sqlType="STRING"/>
		<param defaultValue="35" name="DIASDISFRUTE" sqlType="STRING"/>
		<param defaultValue="94" name="DIASPAGARVACACIONES" sqlType="STRING"/>
		<param defaultValue="419" name="VACACIONESDINERO" sqlType="STRING"/>
		<param defaultValue="11" name="DIASENCARGO" sqlType="STRING"/>
		<param defaultValue="11" name="DIASREEMPLAZO" sqlType="STRING"/>
		<param defaultValue="10" name="SALARIOENCARGO" sqlType="STRING"/>
		<param defaultValue="10" name="SALARIOREEMPLAZO" sqlType="STRING"/>
		<param defaultValue="0" name="CUPOSALUD" sqlType="STRING"/>
		<param defaultValue="300" name="DEDUCIBLE" sqlType="STRING"/>
		<param defaultValue="162" name="DIASHABILES" sqlType="STRING"/>
		<param defaultValue="112" name="IBL" sqlType="STRING"/>
		<param defaultValue="" name="CESANTIAPARCIAL" sqlType="STRING"/>
		<param defaultValue="" name="CESANTIACONSOLIDADA" sqlType="STRING"/>
		<param defaultValue="" name="INTERESCESANTIA" sqlType="STRING"/>
		<param defaultValue="35" name="LABSIGPERIODO" sqlType="STRING"/>
		<param defaultValue="164" name="PERIODOVACACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIOMINIMO" sqlType="STRING"/>
		<param defaultValue="" name="PORCRETENCION" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param defaultValue="" name="PORCGASTOS" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_PATRON_EPS" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_EMPLEADO_EPS" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_CAJA" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_ICBF" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_SENA" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_INST" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_ESAP" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_PATRON_AFP" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_EMPLEADO_AFP" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIOSMINIMOS_FSP" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_FSP_AFP" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_FONDO_ARP" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIOS_MAXIMOS_AFP" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIOS_MAXIMOS_EPS" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIOS_MAXIMOS_ARP" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_SALARIO_INTEGRAL" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_TOTAL_AFP" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_GARANTIAS_EPS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="parametrosentrada">
		<call-query href="insertParametrosentrada">
			<with-param name="EXONERADO_1607" query-param="EXONERADO_1607"/>
			<with-param name="ACOGE_1429" query-param="ACOGE_1429"/>
			<with-param name="PRESENTACION" query-param="PRESENTACION"/>
