	<query id="updateParametrosentrada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PARAMETROS_DE_ENTRADA SET EXONERADO_1607=:EXONERADO_1607, ACOGE_1429=:ACOGE_1429, PRESENTACION=:PRESENTACION, CODIGO_SUCURSALPAGADORA=:CODIGO_SUCURSALPAGADORA, NOMBRESUCURSAL=:NOMBRESUCURSAL, CORREOELECTRONICO=:CORREOELECTRONICO, NIT=:NIT, RAZONSOCIAL=:RAZONSOCIAL, TELEFONO=:TELEFONO, FAX=:FAX, TIPONIT=:TIPONIT, TIPOVINCULADOS=:TIPOVINCULADOS, TIPOAPORTANTE=:TIPOAPORTANTE, DIRECCION=:DIRECCION, INDICADORVACACIONES=:INDICADORVACACIONES, DIASLABORADOS=:DIASLABORADOS, DIASDISFRUTE=:DIASDISFRUTE, DIASPAGARVACACIONES=:DIASPAGARVACACIONES, VACACIONESDINERO=:VACACIONESDINERO, DIASENCARGO=:DIASENCARGO, DIASREEMPLAZO=:DIASREEMPLAZO, SALARIOENCARGO=:SALARIOENCARGO, SALARIOREEMPLAZO=:SALARIOREEMPLAZO, CUPOSALUD=:CUPOSALUD, DEDUCIBLE=:DEDUCIBLE, DIASHABILES=:DIASHABILES, IBL=:IBL, CESANTIAPARCIAL=:CESANTIAPARCIAL, CESANTIACONSOLIDADA=:CESANTIACONSOLIDADA, INTERESCESANTIA=:INTERESCESANTIA, LABSIGPERIODO=:LABSIGPERIODO, PERIODOVACACIONES=:PERIODOVACACIONES, SALARIOMINIMO=:SALARIOMINIMO, PORCRETENCION=:PORCRETENCION, CIUDAD=:CIUDAD, PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, PORCGASTOS=:PORCGASTOS, PORC_PATRON_EPS=:PORC_PATRON_EPS, PORC_EMPLEADO_EPS=:PORC_EMPLEADO_EPS, PORC_CAJA=:PORC_CAJA, PORC_ICBF=:PORC_ICBF, PORC_SENA=:PORC_SENA, PORC_INST=:PORC_INST, PORC_ESAP=:PORC_ESAP, PORC_PATRON_AFP=:PORC_PATRON_AFP, PORC_EMPLEADO_AFP=:PORC_EMPLEADO_AFP, SALARIOSMINIMOS_FSP=:SALARIOSMINIMOS_FSP, PORC_FSP_AFP=:PORC_FSP_AFP, PORC_FONDO_ARP=:PORC_FONDO_ARP, SALARIOS_MAXIMOS_AFP=:SALARIOS_MAXIMOS_AFP, SALARIOS_MAXIMOS_EPS=:SALARIOS_MAXIMOS_EPS, SALARIOS_MAXIMOS_ARP=:SALARIOS_MAXIMOS_ARP, PORC_SALARIO_INTEGRAL=:PORC_SALARIO_INTEGRAL, PORC_TOTAL_AFP=:PORC_TOTAL_AFP, PORC_GARANTIAS_EPS=:PORC_GARANTIAS_EPS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PARAMETROS_DE_ENTRADA.COMPANIA= :KEY_COMPANIA AND PARAMETROS_DE_ENTRADA.NIT= :KEY_NIT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
