	<query id="getParametrosentradaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PARAMETROS_DE_ENTRADA.EXONERADO_1607 , PARAMETROS_DE_ENTRADA.ACOGE_1429 , PARAMETROS_DE_ENTRADA.PRESENTACION , PARAMETROS_DE_ENTRADA.CODIGO_SUCURSALPAGADORA , PARAMETROS_DE_ENTRADA.NOMBRESUCURSAL , PARAMETROS_DE_ENTRADA.CORREOELECTRONICO , PARAMETROS_DE_ENTRADA.NIT, PARAMETROS_DE_ENTRADA.RAZONSOCIAL, PARAMETROS_DE_ENTRADA.TELEFONO, PARAMETROS_DE_ENTRADA.FAX, PARAMETROS_DE_ENTRADA.TIPONIT, PARAMETROS_DE_ENTRADA.TIPOVINCULADOS, PARAMETROS_DE_ENTRADA.TIPOAPORTANTE, PARAMETROS_DE_ENTRADA.DIRECCION, PARAMETROS_DE_ENTRADA.INDICADORVACACIONES, PARAMETROS_DE_ENTRADA.DIASLABORADOS, PARAMETROS_DE_ENTRADA.DIASDISFRUTE, PARAMETROS_DE_ENTRADA.DIASPAGARVACACIONES, PARAMETROS_DE_ENTRADA.VACACIONESDINERO, PARAMETROS_DE_ENTRADA.DIASENCARGO, PARAMETROS_DE_ENTRADA.DIASREEMPLAZO, PARAMETROS_DE_ENTRADA.SALARIOENCARGO, PARAMETROS_DE_ENTRADA.SALARIOREEMPLAZO, PARAMETROS_DE_ENTRADA.CUPOSALUD, PARAMETROS_DE_ENTRADA.DEDUCIBLE, PARAMETROS_DE_ENTRADA.DIASHABILES, PARAMETROS_DE_ENTRADA.IBL, PARAMETROS_DE_ENTRADA.CESANTIAPARCIAL, PARAMETROS_DE_ENTRADA.CESANTIACONSOLIDADA, PARAMETROS_DE_ENTRADA.INTERESCESANTIA, PARAMETROS_DE_ENTRADA.LABSIGPERIODO, PARAMETROS_DE_ENTRADA.PERIODOVACACIONES, PARAMETROS_DE_ENTRADA.SALARIOMINIMO, PARAMETROS_DE_ENTRADA.PORCRETENCION, PARAMETROS_DE_ENTRADA.CIUDAD, PARAMETROS_DE_ENTRADA.PAIS , PARAMETROS_DE_ENTRADA.DEPARTAMENTO, PARAMETROS_DE_ENTRADA.PORCGASTOS, PARAMETROS_DE_ENTRADA.COMPANIA , PARAMETROS_DE_ENTRADA.PORC_PATRON_EPS, PARAMETROS_DE_ENTRADA.PORC_EMPLEADO_EPS, PARAMETROS_DE_ENTRADA.PORC_CAJA, PARAMETROS_DE_ENTRADA.PORC_ICBF, PARAMETROS_DE_ENTRADA.PORC_SENA, PARAMETROS_DE_ENTRADA.PORC_INST, PARAMETROS_DE_ENTRADA.PORC_ESAP, PARAMETROS_DE_ENTRADA.PORC_CAJA + PARAMETROS_DE_ENTRADA.PORC_ESAP + PARAMETROS_DE_ENTRADA.PORC_SENA + PARAMETROS_DE_ENTRADA.PORC_ICBF + PARAMETROS_DE_ENTRADA.PORC_INST TOTAL_APORTE_AFP , PARAMETROS_DE_ENTRADA.PORC_PATRON_AFP, PARAMETROS_DE_ENTRADA.PORC_EMPLEADO_AFP, PARAMETROS_DE_ENTRADA.SALARIOSMINIMOS_FSP, PARAMETROS_DE_ENTRADA.PORC_FSP_AFP, PARAMETROS_DE_ENTRADA.PORC_FONDO_ARP, PARAMETROS_DE_ENTRADA.SALARIOS_MAXIMOS_AFP, PARAMETROS_DE_ENTRADA.SALARIOS_MAXIMOS_EPS, PARAMETROS_DE_ENTRADA.SALARIOS_MAXIMOS_ARP, PARAMETROS_DE_ENTRADA.PORC_SALARIO_INTEGRAL, PARAMETROS_DE_ENTRADA.PORC_TOTAL_AFP, PARAMETROS_DE_ENTRADA.PORC_GARANTIAS_EPS, PARAMETROS_DE_ENTRADA.CREATED_BY,(TO_CHAR(PARAMETROS_DE_ENTRADA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, PARAMETROS_DE_ENTRADA.MODIFIED_BY,(TO_CHAR(PARAMETROS_DE_ENTRADA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PARAMETROS_DE_ENTRADA WHERE PARAMETROS_DE_ENTRADA.COMPANIA= :KEY_COMPANIA AND PARAMETROS_DE_ENTRADA.NIT= :KEY_NIT</sql>
