OS_AFP","SALARIOS_MAXIMOS_EPS":"$SALARIOS_MAXIMOS_EPS","SALARIOS_MAXIMOS_ARP":"$SALARIOS_MAXIMOS_ARP","PORC_SALARIO_INTEGRAL":"$PORC_SALARIO_INTEGRAL","PORC_TOTAL_AFP":"$PORC_TOTAL_AFP","PORC_GARANTIAS_EPS":"$PORC_GARANTIAS_EPS","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
