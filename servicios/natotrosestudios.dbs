		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>
		<param name="GRADUADO" sqlType="STRING"/>
		<param name="PATROCINADO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHATERMINACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
