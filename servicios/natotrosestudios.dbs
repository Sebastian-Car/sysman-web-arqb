<data name="natotrosestudios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatotrosestudios" keyColumns="COMPANIA,NUMERO_DCTO,SUCURSAL,NUMERO,NOE_CODIGOPERSONA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_OTROS_ESTUDIOS (COMPANIA, NUMERO_DCTO, SUCURSAL, NUMERO, NOE_CODIGOPERSONA, MODALIDAD, ESTABLECIMIENTO, HORAS, TITULOOBTENIDO, PAIS, DEPTO, MUNICIPIO, DIAINICIO, MESINICIO, ANOINICIO, DIATERMINACION, MESTERMINACION, ANOTERMINACION, GRADUADO, PATROCINADO, FECHAINICIO, FECHATERMINACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_DCTO, :SUCURSAL, :NUMERO, :NOE_CODIGOPERSONA, :MODALIDAD, :ESTABLECIMIENTO, :HORAS, :TITULOOBTENIDO, :PAIS, :DEPTO, :MUNICIPIO, :DIAINICIO, :MESINICIO, :ANOINICIO, :DIATERMINACION, :MESTERMINACION, :ANOTERMINACION, :GRADUADO, :PATROCINADO, TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_NUMERO":"$NUMERO","KEY_NOE_CODIGOPERSONA":"$NOE_CODIGOPERSONA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOE_CODIGOPERSONA" sqlType="STRING"/>
		<param defaultValue="" name="MODALIDAD" sqlType="STRING"/>
		<param defaultValue="" name="ESTABLECIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="HORAS" sqlType="STRING"/>
		<param defaultValue="" name="TITULOOBTENIDO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPTO" sqlType="STRING"/>
		<param name="MUNICIPIO" sqlType="STRING"/>
		<param defaultValue="" name="DIAINICIO" sqlType="STRING"/>
		<param defaultValue="" name="MESINICIO" sqlType="STRING"/>
		<param defaultValue="" name="ANOINICIO" sqlType="STRING"/>
		<param defaultValue="" name="DIATERMINACION" sqlType="STRING"/>
		<param defaultValue="" name="MESTERMINACION" sqlType="STRING"/>
		<param defaultValue="" name="ANOTERMINACION" sqlType="STRING"/>
		<param defaultValue="0" name="GRADUADO" sqlType="STRING"/>
		<param defaultValue="0" name="PATROCINADO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHATERMINACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natotrosestudios">
		<call-query href="insertNatotrosestudios">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
