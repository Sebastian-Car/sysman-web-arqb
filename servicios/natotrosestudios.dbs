	<query id="getNatotrosestudiosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_OTROS_ESTUDIOS.COMPANIA, NAT_OTROS_ESTUDIOS.NUMERO_DCTO, NAT_OTROS_ESTUDIOS.SUCURSAL, NAT_OTROS_ESTUDIOS.NUMERO, NAT_OTROS_ESTUDIOS.NOE_CODIGOPERSONA, NAT_OTROS_ESTUDIOS.MODALIDAD, NAT_MODALIDAD_ESTUDIOS.NOMBRE, NAT_OTROS_ESTUDIOS.ESTABLECIMIENTO, INSTITUCIONES_EDUCATIVAS.NOMBRE NOMBRE_ESTABLECIMIENTO, NAT_OTROS_ESTUDIOS.HORAS, NAT_OTROS_ESTUDIOS.TITULOOBTENIDO, NAT_OTROS_ESTUDIOS.PAIS , UPPER(PAISES.NOMBRE) NOMBREPAIS, NAT_OTROS_ESTUDIOS.DEPTO , DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, NAT_OTROS_ESTUDIOS.MUNICIPIO, CIUDAD.NOMBRE NOMBRECIUDAD, NAT_OTROS_ESTUDIOS.DIAINICIO, NAT_OTROS_ESTUDIOS.MESINICIO, NAT_OTROS_ESTUDIOS.ANOINICIO, NAT_OTROS_ESTUDIOS.DIATERMINACION, NAT_OTROS_ESTUDIOS.MESTERMINACION, NAT_OTROS_ESTUDIOS.ANOTERMINACION,(CASE NAT_OTROS_ESTUDIOS.GRADUADO WHEN 0 THEN 'false' ELSE 'true' END) GRADUADO,(CASE NAT_OTROS_ESTUDIOS.PATROCINADO WHEN 0 THEN 'false' ELSE 'true' END) PATROCINADO,(TO_CHAR(NAT_OTROS_ESTUDIOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(NAT_OTROS_ESTUDIOS.FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS')) FECHATERMINACION FROM NAT_OTROS_ESTUDIOS LEFT JOIN PAISES ON NAT_OTROS_ESTUDIOS.PAIS = PAISES.PAIS LEFT JOIN DEPARTAMENTO ON NAT_OTROS_ESTUDIOS.PAIS = DEPARTAMENTO.PAIS AND NAT_OTROS_ESTUDIOS.DEPTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON NAT_OTROS_ESTUDIOS.PAIS = CIUDAD.PAIS AND NAT_OTROS_ESTUDIOS.DEPTO = CIUDAD.DEPARTAMENTO AND NAT_OTROS_ESTUDIOS.MUNICIPIO = CIUDAD.CODIGO LEFT JOIN NAT_MODALIDAD_ESTUDIOS ON NAT_OTROS_ESTUDIOS.MODALIDAD = NAT_MODALIDAD_ESTUDIOS.CODIGO LEFT JOIN INSTITUCIONES_EDUCATIVAS ON NAT_OTROS_ESTUDIOS.ESTABLECIMIENTO = INSTITUCIONES_EDUCATIVAS.NIT WHERE NAT_OTROS_ESTUDIOS.COMPANIA = :COMPANIA AND NAT_OTROS_ESTUDIOS.NUMERO_DCTO = :NUMERO_DCTO AND NAT_OTROS_ESTUDIOS.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRE_ESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTABLECIMIENTO) END)  LIKE UPPER( '%' || :NOMBRE_ESTABLECIMIENTO || '%')  AND (CASE WHEN HORAS IS NULL THEN ' ' ELSE UPPER(HORAS) END)  LIKE UPPER(:HORAS || '%')  AND (CASE WHEN TITULOOBTENIDO IS NULL THEN ' ' ELSE UPPER(TITULOOBTENIDO) END)  LIKE UPPER( '%' || :TITULOOBTENIDO || '%')  AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END)  LIKE UPPER( '%' || :NOMBREPAIS || '%')  AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END)  LIKE UPPER( '%' || :NOMBREDEPARTAMENTO || '%')  AND (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END)  LIKE UPPER( '%' || :NOMBRECIUDAD || '%')  AND (CASE WHEN GRADUADO IS NULL THEN ' ' ELSE UPPER(GRADUADO) END)  LIKE UPPER( '%' || :GRADUADO || '%')  AND (CASE WHEN PATROCINADO IS NULL THEN ' ' ELSE UPPER(PATROCINADO) END)  LIKE UPPER( '%' || :PATROCINADO || '%')  AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END)  LIKE UPPER( '%' || :FECHAINICIO || '%')  AND (CASE WHEN FECHATERMINACION IS NULL THEN ' ' ELSE UPPER(FECHATERMINACION) END)  LIKE UPPER( '%' || :FECHATERMINACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_ESTABLECIMIENTO" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="TITULOOBTENIDO" sqlType="STRING"/>
