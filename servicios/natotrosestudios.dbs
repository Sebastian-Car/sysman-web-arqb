	<query id="updateNatotrosestudios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_OTROS_ESTUDIOS SET MODALIDAD=:MODALIDAD, ESTABLECIMIENTO=:ESTABLECIMIENTO, HORAS=:HORAS, TITULOOBTENIDO=:TITULOOBTENIDO, PAIS=:PAIS, DEPTO=:DEPTO, MUNICIPIO=:MUNICIPIO, DIAINICIO=:DIAINICIO, MESINICIO=:MESINICIO, ANOINICIO=:ANOINICIO, DIATERMINACION=:DIATERMINACION, MESTERMINACION=:MESTERMINACION, ANOTERMINACION=:ANOTERMINACION, GRADUADO=:GRADUADO, PATROCINADO=:PATROCINADO, FECHAINICIO=TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), FECHATERMINACION=TO_DATE(:FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_OTROS_ESTUDIOS.COMPANIA= :KEY_COMPANIA AND NAT_OTROS_ESTUDIOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_OTROS_ESTUDIOS.SUCURSAL= :KEY_SUCURSAL AND NAT_OTROS_ESTUDIOS.NUMERO= :KEY_NUMERO AND NAT_OTROS_ESTUDIOS.NOE_CODIGOPERSONA= :KEY_NOE_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="ESTABLECIMIENTO" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="TITULOOBTENIDO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPTO" sqlType="STRING"/>
		<param name="MUNICIPIO" sqlType="STRING"/>
		<param name="DIAINICIO" sqlType="STRING"/>
		<param name="MESINICIO" sqlType="STRING"/>
		<param name="ANOINICIO" sqlType="STRING"/>
		<param name="DIATERMINACION" sqlType="STRING"/>
		<param name="MESTERMINACION" sqlType="STRING"/>
		<param name="ANOTERMINACION" sqlType="STRING"/>
		<param name="GRADUADO" sqlType="STRING"/>
		<param name="PATROCINADO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHATERMINACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
