<data name="bpplanindicativofuentes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpplanindicativofuentesVigenciaplanymetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT VIGENCIA_META  FROM BP_PLAN_INDICATIVO_FUENTES WHERE COMPANIA = :COMPANIA ORDER BY VIGENCIA_META</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA_META":"$VIGENCIA_META(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativofuentes/vigenciaplanymeta">
		<call-query href="getBpplanindicativofuentesVigenciaplanymetaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativofuentesUltimavigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MIN(VIGENCIA_META) MIN_VIGENCIA  FROM BP_PLAN_INDICATIVO_FUENTES WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MIN_VIGENCIA":"$MIN_VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativofuentes/ultimavigencia">
		<call-query href="getBpplanindicativofuentesUltimavigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertBpplanindicativofuentes" keyColumns="COMPANIA,ID_PLAN,VIGENCIA_PLAN,VIGENCIA_META,FUENTE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_PLAN_INDICATIVO_FUENTES (COMPANIA, ID_PLAN, VIGENCIA_PLAN, VIGENCIA_META, FUENTE, VALOR_POR_FUENTES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_PLAN, :VIGENCIA_PLAN, :VIGENCIA_META, :FUENTE, :VALOR_POR_FUENTES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_PLAN":"$ID_PLAN","KEY_VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","KEY_VIGENCIA_META":"$VIGENCIA_META(type:integer)","KEY_FUENTE":"$FUENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_META" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_POR_FUENTES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpplanindicativofuentes">
		<call-query href="insertBpplanindicativofuentes">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_PLAN" query-param="VIGENCIA_PLAN"/>
			<with-param name="VIGENCIA_META" query-param="VIGENCIA_META"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="VALOR_POR_FUENTES" query-param="VALOR_POR_FUENTES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpplanindicativofuentes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_PLAN_INDICATIVO_FUENTES WHERE BP_PLAN_INDICATIVO_FUENTES.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO_FUENTES.ID_PLAN= :KEY_ID_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN= :KEY_VIGENCIA_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META= :KEY_VIGENCIA_META AND BP_PLAN_INDICATIVO_FUENTES.FUENTE= :KEY_FUENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_PLAN" sqlType="INTEGER"/>
		<param name="KEY_VIGENCIA_META" sqlType="INTEGER"/>
		<param name="KEY_FUENTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpplanindicativofuentes">
		<call-query href="deleteBpplanindicativofuentes">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_VIGENCIA_PLAN" query-param="KEY_VIGENCIA_PLAN"/>
			<with-param name="KEY_VIGENCIA_META" query-param="KEY_VIGENCIA_META"/>
			<with-param name="KEY_FUENTE" query-param="KEY_FUENTE"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativofuentesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_FUENTES.COMPANIA, BP_PLAN_INDICATIVO_FUENTES.ID_PLAN, BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN, BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META, BP_PLAN_INDICATIVO_FUENTES.FUENTE, FUENTE_RECURSOS.NOMBRE, BP_PLAN_INDICATIVO_FUENTES.VALOR_POR_FUENTES  FROM BP_PLAN_INDICATIVO_FUENTES LEFT JOIN FUENTE_RECURSOS ON BP_PLAN_INDICATIVO_FUENTES.FUENTE = FUENTE_RECURSOS.CODIGO AND BP_PLAN_INDICATIVO_FUENTES.COMPANIA = FUENTE_RECURSOS.COMPANIA AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META = FUENTE_RECURSOS.ANO WHERE BP_PLAN_INDICATIVO_FUENTES.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO_FUENTES.ID_PLAN = :ID_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN = :VIGENCIA_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META = :VIGENCIA_META) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR_POR_FUENTES IS NULL THEN ' ' ELSE UPPER(VALOR_POR_FUENTES) END)  LIKE UPPER( '%' || :VALOR_POR_FUENTES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_PLAN":"$ID_PLAN","VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","VIGENCIA_META":"$VIGENCIA_META(type:integer)","FUENTE":"$FUENTE","NOMBRE":"$NOMBRE","VALOR_POR_FUENTES":"$VALOR_POR_FUENTES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR_POR_FUENTES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativofuentes">
		<call-query href="getBpplanindicativofuentesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_PLAN" query-param="VIGENCIA_PLAN"/>
			<with-param name="VIGENCIA_META" query-param="VIGENCIA_META"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR_POR_FUENTES" query-param="VALOR_POR_FUENTES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativofuentesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_FUENTES.COMPANIA, BP_PLAN_INDICATIVO_FUENTES.ID_PLAN, BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN, BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META, BP_PLAN_INDICATIVO_FUENTES.FUENTE, FUENTE_RECURSOS.NOMBRE, BP_PLAN_INDICATIVO_FUENTES.VALOR_POR_FUENTES  FROM BP_PLAN_INDICATIVO_FUENTES LEFT JOIN FUENTE_RECURSOS ON BP_PLAN_INDICATIVO_FUENTES.FUENTE = FUENTE_RECURSOS.CODIGO AND BP_PLAN_INDICATIVO_FUENTES.COMPANIA = FUENTE_RECURSOS.COMPANIA AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META = FUENTE_RECURSOS.ANO WHERE BP_PLAN_INDICATIVO_FUENTES.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO_FUENTES.ID_PLAN = :ID_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN = :VIGENCIA_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META = :VIGENCIA_META) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR_POR_FUENTES IS NULL THEN ' ' ELSE UPPER(VALOR_POR_FUENTES) END)  LIKE UPPER( '%' || :VALOR_POR_FUENTES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR_POR_FUENTES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativofuentes/numero">
		<call-query href="getBpplanindicativofuentesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_PLAN" query-param="VIGENCIA_PLAN"/>
			<with-param name="VIGENCIA_META" query-param="VIGENCIA_META"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR_POR_FUENTES" query-param="VALOR_POR_FUENTES"/>

		</call-query>
	</resource>
	<query id="updateBpplanindicativofuentes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PLAN_INDICATIVO_FUENTES SET VALOR_POR_FUENTES=:VALOR_POR_FUENTES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_PLAN_INDICATIVO_FUENTES.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO_FUENTES.ID_PLAN= :KEY_ID_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN= :KEY_VIGENCIA_PLAN AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META= :KEY_VIGENCIA_META AND BP_PLAN_INDICATIVO_FUENTES.FUENTE= :KEY_FUENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR_POR_FUENTES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_META" sqlType="STRING"/>
		<param name="KEY_FUENTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpplanindicativofuentes">
		<call-query href="updateBpplanindicativofuentes">
			<with-param name="VALOR_POR_FUENTES" query-param="VALOR_POR_FUENTES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_VIGENCIA_PLAN" query-param="KEY_VIGENCIA_PLAN"/>
			<with-param name="KEY_VIGENCIA_META" query-param="KEY_VIGENCIA_META"/>
			<with-param name="KEY_FUENTE" query-param="KEY_FUENTE"/>

		</call-query>
	</resource>

</data>