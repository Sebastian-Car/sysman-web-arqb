<data name="spdabonos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpdabonosConsultarTotalesAbonadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(SP_D_ABONOS.VALORANT) VALORANT, SUM(SP_D_ABONOS.VALORACT) VALORACT, SUM(VALORACT + VALORANT ) TOTALAB  FROM SP_D_ABONOS WHERE SP_D_ABONOS.COMPANIA = :COMPANIA AND SP_D_ABONOS.CICLO = :CICLO AND SP_D_ABONOS.CODIGORUTA = :CODIGORUTA AND SP_D_ABONOS.CONSECUTIVO = :CONSECUTIVO AND SP_D_ABONOS.ANO = :ANO AND SP_D_ABONOS.PERIODO = :PERIODO AND VALORACT + VALORANT NOT IN (0) ORDER BY SP_D_ABONOS.CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORANT":"$VALORANT(type:integer)","VALORACT":"$VALORACT(type:integer)","TOTALAB":"$TOTALAB(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdabonos/consultartotalesabonados">
		<call-query href="getSpdabonosConsultarTotalesAbonadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpdabonosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_D_ABONOS.COMPANIA, SP_D_ABONOS.CICLO, SP_D_ABONOS.CODIGORUTA, SP_D_ABONOS.ANO, SP_D_ABONOS.PERIODO, SP_D_ABONOS.CONSECUTIVO, SP_D_ABONOS.CONCEPTO, SP_D_ABONOS.VALOR VALORABONADO, SP_D_ABONOS.VALORACT, SP_D_ABONOS.VALORANT, (VALORACT + VALORANT ) TOTALAB , SP_CONCEPTOS.NOMBRE  FROM SP_D_ABONOS LEFT JOIN SP_CONCEPTOS ON SP_D_ABONOS.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_D_ABONOS.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_D_ABONOS.COMPANIA = :COMPANIA AND SP_D_ABONOS.CICLO = :CICLO AND SP_D_ABONOS.CONSECUTIVO = :CONSECUTIVO AND SP_D_ABONOS.CODIGORUTA = :CODIGORUTA AND SP_D_ABONOS.ANO = :ANO AND SP_D_ABONOS.PERIODO = :PERIODO AND VALORACT + VALORANT NOT IN (0) ORDER BY SP_D_ABONOS.CONCEPTO) WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN VALORACT IS NULL THEN ' ' ELSE UPPER(VALORACT) END)  LIKE UPPER( '%' || :VALORACT || '%')  AND (CASE WHEN VALORANT IS NULL THEN ' ' ELSE UPPER(VALORANT) END)  LIKE UPPER( '%' || :VALORANT || '%')  AND (CASE WHEN TOTALAB IS NULL THEN ' ' ELSE UPPER(TOTALAB) END)  LIKE UPPER( '%' || :TOTALAB || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CONSECUTIVO":"$CONSECUTIVO","CONCEPTO":"$CONCEPTO(type:integer)","VALORABONADO":"$VALORABONADO","VALORACT":"$VALORACT","VALORANT":"$VALORANT","TOTALAB":"$TOTALAB(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="VALORACT" sqlType="STRING"/>
		<param name="VALORANT" sqlType="STRING"/>
		<param name="TOTALAB" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spdabonos">
		<call-query href="getSpdabonosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="VALORACT" query-param="VALORACT"/>
			<with-param name="VALORANT" query-param="VALORANT"/>
			<with-param name="TOTALAB" query-param="TOTALAB"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpdabonosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_D_ABONOS.COMPANIA, SP_D_ABONOS.CICLO, SP_D_ABONOS.CODIGORUTA, SP_D_ABONOS.ANO, SP_D_ABONOS.PERIODO, SP_D_ABONOS.CONSECUTIVO, SP_D_ABONOS.CONCEPTO, SP_D_ABONOS.VALOR VALORABONADO, SP_D_ABONOS.VALORACT, SP_D_ABONOS.VALORANT, (VALORACT + VALORANT ) TOTALAB , SP_CONCEPTOS.NOMBRE  FROM SP_D_ABONOS LEFT JOIN SP_CONCEPTOS ON SP_D_ABONOS.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_D_ABONOS.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_D_ABONOS.COMPANIA = :COMPANIA AND SP_D_ABONOS.CICLO = :CICLO AND SP_D_ABONOS.CONSECUTIVO = :CONSECUTIVO AND SP_D_ABONOS.CODIGORUTA = :CODIGORUTA AND SP_D_ABONOS.ANO = :ANO AND SP_D_ABONOS.PERIODO = :PERIODO AND VALORACT + VALORANT NOT IN (0) ORDER BY SP_D_ABONOS.CONCEPTO) WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN VALORACT IS NULL THEN ' ' ELSE UPPER(VALORACT) END)  LIKE UPPER( '%' || :VALORACT || '%')  AND (CASE WHEN VALORANT IS NULL THEN ' ' ELSE UPPER(VALORANT) END)  LIKE UPPER( '%' || :VALORANT || '%')  AND (CASE WHEN TOTALAB IS NULL THEN ' ' ELSE UPPER(TOTALAB) END)  LIKE UPPER( '%' || :TOTALAB || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="VALORACT" sqlType="STRING"/>
		<param name="VALORANT" sqlType="STRING"/>
		<param name="TOTALAB" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdabonos/numero">
		<call-query href="getSpdabonosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="VALORACT" query-param="VALORACT"/>
			<with-param name="VALORANT" query-param="VALORANT"/>
			<with-param name="TOTALAB" query-param="TOTALAB"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

</data>