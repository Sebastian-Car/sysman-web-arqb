			<with-param name="PIDE_VENCIMIENTO" query-param="PIDE_VENCIMIENTO"/>

		</call-query>
	</resource>
	<query id="getInventariofisico_consumoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM INVENTARIO_FISICO_CONSUMO WHERE INVENTARIO_FISICO_CONSUMO.COMPANIA= :KEY_COMPANIA AND INVENTARIO_FISICO_CONSUMO.ANO= :KEY_ANO AND INVENTARIO_FISICO_CONSUMO.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND INVENTARIO_FISICO_CONSUMO.FECHA_CORTE= TO_DATE(:KEY_FECHA_CORTE,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBREELEMENTO":"$NOMBREELEMENTO","LOTE":"$LOTE","FUENTE":"$FUENTE","SALDO":"$SALDO","CONTEO1":"$CONTEO1","CONTEO2":"$CONTEO2","CONTEO3":"$CONTEO3","DEBITO":"$DEBITO","CREDITO":"$CREDITO","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","BODEGA":"$BODEGA","CONTEO":"$CONTEO(type:integer)","FECHA_CORTE":"$FECHA_CORTE","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_FECHA_CORTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventariofisico_consumo/data">
		<call-query href="getInventariofisico_consumoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>
			<with-param name="KEY_FECHA_CORTE" query-param="KEY_FECHA_CORTE"/>

