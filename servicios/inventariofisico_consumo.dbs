	<query id="updateInventariofisico_consumo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVENTARIO_FISICO_CONSUMO SET COMPANIA=:COMPANIA, ANO=:ANO, CODIGOELEMENTO=:CODIGOELEMENTO, NOMBREELEMENTO=:NOMBREELEMENTO, LOTE=:LOTE, FUENTE=:FUENTE, SALDO=:SALDO, CONTEO1=:CONTEO1, CONTEO2=:CONTEO2, CONTEO3=:CONTEO3, DEBITO=:DEBITO, CREDITO=:CREDITO, MODIFIED_BY=:MODIFIED_BY, BODEGA=:BODEGA, CONTEO=:CONTEO, FECHA_CORTE=TO_DATE(:FECHA_CORTE,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE INVENTARIO_FISICO_CONSUMO.COMPANIA= :KEY_COMPANIA AND INVENTARIO_FISICO_CONSUMO.ANO= :KEY_ANO AND INVENTARIO_FISICO_CONSUMO.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND INVENTARIO_FISICO_CONSUMO.FECHA_CORTE= TO_DATE(:KEY_FECHA_CORTE,'DD/MM/YYYY HH24:MI:SS') AND INVENTARIO_FISICO_CONSUMO.LOTE= :KEY_LOTE AND INVENTARIO_FISICO_CONSUMO.FUENTE= :KEY_FUENTE AND INVENTARIO_FISICO_CONSUMO.BODEGA= :KEY_BODEGA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBREELEMENTO" sqlType="STRING"/>
		<param name="LOTE" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="CONTEO1" sqlType="STRING"/>
		<param name="CONTEO2" sqlType="STRING"/>
		<param name="CONTEO3" sqlType="STRING"/>
		<param name="DEBITO" sqlType="STRING"/>
		<param name="CREDITO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>
		<param name="CONTEO" sqlType="STRING"/>
		<param name="FECHA_CORTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_FECHA_CORTE" sqlType="STRING"/>
