	<query id="getBpplanadquisicionesIndicadorpaaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(PAA,-1) INDICADOR_PAA  FROM BP_PLAN_ADQUISICIONES WHERE COMPANIA = :COMPANIA AND VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND ID_PLAN = :ID_PLAN AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"INDICADOR_PAA":"$INDICADOR_PAA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanadquisiciones/indicadorpaa">
		<call-query href="getBpplanadquisicionesIndicadorpaaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpplanadquisicionesPagPlanporvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL, BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN, BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO, BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA, BP_PLAN_ADQUISICIONES.DESCRIPCION, BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO  FROM BP_PLAN_ADQUISICIONES INNER JOIN BP_PLAN_ADQUISICIONES_VIGENCIA ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN AND BP_PLAN_ADQUISICIONES.CODIGO = BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO WHERE BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA = :COMPANIA AND BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA = :VIGENCIA) WHERE (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END)  LIKE UPPER(:VIGENCIA_INICIAL || '%')  AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALOR_ESTIMADO IS NULL THEN ' ' ELSE UPPER(VALOR_ESTIMADO) END)  LIKE UPPER(:VALOR_ESTIMADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","ID_PLAN":"$ID_PLAN","CODIGO":"$CODIGO(type:integer)","VIGENCIA":"$VIGENCIA(type:integer)","DESCRIPCION":"$DESCRIPCION","VALOR_ESTIMADO":"$VALOR_ESTIMADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanadquisiciones/planporvigencia/pag">
		<call-query href="getBpplanadquisicionesPagPlanporvigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR_ESTIMADO" query-param="VALOR_ESTIMADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanadquisicionesNumPlanporvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL, BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN, BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO, BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA, BP_PLAN_ADQUISICIONES.DESCRIPCION, BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO  FROM BP_PLAN_ADQUISICIONES INNER JOIN BP_PLAN_ADQUISICIONES_VIGENCIA ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN AND BP_PLAN_ADQUISICIONES.CODIGO = BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO WHERE BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA = :COMPANIA AND BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA = :VIGENCIA) WHERE (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END)  LIKE UPPER(:VIGENCIA_INICIAL || '%')  AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALOR_ESTIMADO IS NULL THEN ' ' ELSE UPPER(VALOR_ESTIMADO) END)  LIKE UPPER(:VALOR_ESTIMADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanadquisiciones/planporvigencia/num">
		<call-query href="getBpplanadquisicionesNumPlanporvigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR_ESTIMADO" query-param="VALOR_ESTIMADO"/>

		</call-query>
	</resource>
	<query id="getBpplanadquisicionesPagItemsPorResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_ADQUISICIONES.ID_PLAN, BP_PLAN_ADQUISICIONES.DESCRIPCION, BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO, BP_PLAN_ADQUISICIONES.CODIGO, BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL, ((BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO)- (SELECT NVL(SUM(NVL(D_SOLICITUDDISPONIBILIDAD.VALOR,0)),0) FROM D_SOLICITUDDISPONIBILIDAD INNER JOIN SOLICITUDDISPONIBILIDAD ON SOLICITUDDISPONIBILIDAD.COMPANIA = D_SOLICITUDDISPONIBILIDAD.COMPANIA AND SOLICITUDDISPONIBILIDAD.NUMERO = D_SOLICITUDDISPONIBILIDAD.NUMERO AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = D_SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD WHERE D_SOLICITUDDISPONIBILIDAD.COMPANIA = BP_PLAN_ADQUISICIONES.COMPANIA AND D_SOLICITUDDISPONIBILIDAD.ID_PLAN = BP_PLAN_ADQUISICIONES.ID_PLAN AND D_SOLICITUDDISPONIBILIDAD.ANO = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA AND D_SOLICITUDDISPONIBILIDAD.CODIGO = BP_PLAN_ADQUISICIONES.CODIGO AND D_SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD IN (1,2) AND SOLICITUDDISPONIBILIDAD.APROBACION IN (-1,2) )) SALDO  FROM BP_PLAN_ADQUISICIONES INNER JOIN BP_PLAN_INDICATIVO ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_PLAN_INDICATIVO.ID INNER JOIN BP_PLAN_ADQUISICIONES_VIGENCIA ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN AND BP_PLAN_ADQUISICIONES.CODIGO = BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO INNER JOIN BP_EQUIVALENCIAS ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_EQUIVALENCIAS.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_EQUIVALENCIAS.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_EQUIVALENCIAS.SUBPROYECTO AND BP_PLAN_ADQUISICIONES.CODIGO = BP_EQUIVALENCIAS.CODIGO WHERE BP_PLAN_ADQUISICIONES.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.RESPONSABLE = :RESPONSABLE) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALOR_ESTIMADO IS NULL THEN ' ' ELSE UPPER(VALOR_ESTIMADO) END)  LIKE UPPER(:VALOR_ESTIMADO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER(:SALDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN":"$ID_PLAN","DESCRIPCION":"$DESCRIPCION","VALOR_ESTIMADO":"$VALOR_ESTIMADO","CODIGO":"$CODIGO(type:long)","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","SALDO":"$SALDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
