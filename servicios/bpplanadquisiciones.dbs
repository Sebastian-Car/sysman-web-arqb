	<query id="getBpplanadquisicionesNumItemsPorResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_ADQUISICIONES.ID_PLAN, BP_PLAN_ADQUISICIONES.DESCRIPCION, BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO, BP_PLAN_ADQUISICIONES.CODIGO, BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL, ((BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO)- (SELECT NVL(SUM(NVL(D_SOLICITUDDISPONIBILIDAD.VALOR,0)),0) FROM D_SOLICITUDDISPONIBILIDAD INNER JOIN SOLICITUDDISPONIBILIDAD ON SOLICITUDDISPONIBILIDAD.COMPANIA = D_SOLICITUDDISPONIBILIDAD.COMPANIA AND SOLICITUDDISPONIBILIDAD.NUMERO = D_SOLICITUDDISPONIBILIDAD.NUMERO AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = D_SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD WHERE D_SOLICITUDDISPONIBILIDAD.COMPANIA = BP_PLAN_ADQUISICIONES.COMPANIA AND D_SOLICITUDDISPONIBILIDAD.ID_PLAN = BP_PLAN_ADQUISICIONES.ID_PLAN AND D_SOLICITUDDISPONIBILIDAD.ANO = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA AND D_SOLICITUDDISPONIBILIDAD.CODIGO = BP_PLAN_ADQUISICIONES.CODIGO AND D_SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD IN (1,2) AND SOLICITUDDISPONIBILIDAD.APROBACION IN (-1,2) )) SALDO  FROM BP_PLAN_ADQUISICIONES INNER JOIN BP_PLAN_INDICATIVO ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_PLAN_INDICATIVO.ID INNER JOIN BP_PLAN_ADQUISICIONES_VIGENCIA ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN AND BP_PLAN_ADQUISICIONES.CODIGO = BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO INNER JOIN BP_EQUIVALENCIAS ON BP_PLAN_ADQUISICIONES.COMPANIA = BP_EQUIVALENCIAS.COMPANIA AND BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL = BP_EQUIVALENCIAS.VIGENCIA_INICIAL AND BP_PLAN_ADQUISICIONES.ID_PLAN = BP_EQUIVALENCIAS.SUBPROYECTO AND BP_PLAN_ADQUISICIONES.CODIGO = BP_EQUIVALENCIAS.CODIGO WHERE BP_PLAN_ADQUISICIONES.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.RESPONSABLE = :RESPONSABLE) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALOR_ESTIMADO IS NULL THEN ' ' ELSE UPPER(VALOR_ESTIMADO) END)  LIKE UPPER(:VALOR_ESTIMADO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER(:SALDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>

	</query>
