<data name="seguridadsocialnov" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSeguridadsocialnov" keyColumns="COMPANIA,CLASEORDEN,ORDENDECOMPRA,NOVEDAD,CODIGOPLANI" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SEGURIDADSOCIALNOV (COMPANIA, CLASEORDEN, ORDENDECOMPRA, NOVEDAD, CODIGOPLANI, PERIODO, IBC, SALUD, PENSION, ARL, CAJACOMPEN, SENA, ICBF, TOTALAPORTES, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CLASEORDEN, :ORDENDECOMPRA, :NOVEDAD, :CODIGOPLANI, :PERIODO, :IBC, :SALUD, :PENSION, :ARL, :CAJACOMPEN, :SENA, :ICBF, :TOTALAPORTES, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_ORDENDECOMPRA":"$ORDENDECOMPRA","KEY_NOVEDAD":"$NOVEDAD","KEY_CODIGOPLANI":"$CODIGOPLANI"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="CODIGOPLANI" sqlType="STRING"/>
		<param defaultValue="" name="PERIODO" sqlType="STRING"/>
		<param defaultValue="" name="IBC" sqlType="STRING"/>
		<param defaultValue="" name="SALUD" sqlType="STRING"/>
		<param defaultValue="" name="PENSION" sqlType="STRING"/>
		<param defaultValue="" name="ARL" sqlType="STRING"/>
		<param defaultValue="" name="CAJACOMPEN" sqlType="STRING"/>
		<param defaultValue="" name="SENA" sqlType="STRING"/>
		<param defaultValue="" name="ICBF" sqlType="STRING"/>
		<param defaultValue="" name="TOTALAPORTES" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="seguridadsocialnov">
		<call-query href="insertSeguridadsocialnov">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="CODIGOPLANI" query-param="CODIGOPLANI"/>
