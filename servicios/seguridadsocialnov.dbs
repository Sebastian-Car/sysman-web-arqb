			<with-param name="ICBF" query-param="ICBF"/>
			<with-param name="TOTALAPORTES" query-param="TOTALAPORTES"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteSeguridadsocialnov" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SEGURIDADSOCIALNOV WHERE SEGURIDADSOCIALNOV.COMPANIA= :KEY_COMPANIA AND SEGURIDADSOCIALNOV.CLASEORDEN= :KEY_CLASEORDEN AND SEGURIDADSOCIALNOV.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND SEGURIDADSOCIALNOV.NOVEDAD= :KEY_NOVEDAD AND SEGURIDADSOCIALNOV.CODIGOPLANI= :KEY_CODIGOPLANI</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_CODIGOPLANI" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="seguridadsocialnov">
		<call-query href="deleteSeguridadsocialnov">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_ORDENDECOMPRA" query-param="KEY_ORDENDECOMPRA"/>
			<with-param name="KEY_NOVEDAD" query-param="KEY_NOVEDAD"/>
			<with-param name="KEY_CODIGOPLANI" query-param="KEY_CODIGOPLANI"/>

		</call-query>
	</resource>
	<query id="getSeguridadsocialnovPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CLASEORDEN, ORDENDECOMPRA, NOVEDAD, CODIGOPLANI, PERIODO, IBC, SALUD, PENSION, ARL, CAJACOMPEN, SENA, ICBF, TOTALAPORTES FROM SEGURIDADSOCIALNOV) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASEORDEN), '%')) AND (CASE WHEN ORDENDECOMPRA IS NULL THEN ' ' ELSE UPPER(ORDENDECOMPRA) END) LIKE UPPER(CONCAT(CONCAT('%',:ORDENDECOMPRA), '%')) AND (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOVEDAD), '%')) AND (CASE WHEN CODIGOPLANI IS NULL THEN ' ' ELSE UPPER(CODIGOPLANI) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPLANI), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN IBC IS NULL THEN ' ' ELSE UPPER(IBC) END) LIKE UPPER(CONCAT(CONCAT('%',:IBC), '%')) AND (CASE WHEN SALUD IS NULL THEN ' ' ELSE UPPER(SALUD) END) LIKE UPPER(CONCAT(CONCAT('%',:SALUD), '%')) AND (CASE WHEN PENSION IS NULL THEN ' ' ELSE UPPER(PENSION) END) LIKE UPPER(CONCAT(CONCAT('%',:PENSION), '%')) AND (CASE WHEN ARL IS NULL THEN ' ' ELSE UPPER(ARL) END) LIKE UPPER(CONCAT(CONCAT('%',:ARL), '%')) AND (CASE WHEN CAJACOMPEN IS NULL THEN ' ' ELSE UPPER(CAJACOMPEN) END) LIKE UPPER(CONCAT(CONCAT('%',:CAJACOMPEN), '%')) AND (CASE WHEN SENA IS NULL THEN ' ' ELSE UPPER(SENA) END) LIKE UPPER(CONCAT(CONCAT('%',:SENA), '%')) AND (CASE WHEN ICBF IS NULL THEN ' ' ELSE UPPER(ICBF) END) LIKE UPPER(CONCAT(CONCAT('%',:ICBF), '%')) AND (CASE WHEN TOTALAPORTES IS NULL THEN ' ' ELSE UPPER(TOTALAPORTES) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTALAPORTES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","NOVEDAD":"$NOVEDAD","CODIGOPLANI":"$CODIGOPLANI","PERIODO":"$PERIODO","IBC":"$IBC","SALUD":"$SALUD","PENSION":"$PENSION","ARL":"$ARL","CAJACOMPEN":"$CAJACOMPEN","SENA":"$SENA","ICBF":"$ICBF","TOTALAPORTES":"$TOTALAPORTES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="CODIGOPLANI" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="SALUD" sqlType="STRING"/>
		<param name="PENSION" sqlType="STRING"/>
		<param name="ARL" sqlType="STRING"/>
		<param name="CAJACOMPEN" sqlType="STRING"/>
		<param name="SENA" sqlType="STRING"/>
		<param name="ICBF" sqlType="STRING"/>
		<param name="TOTALAPORTES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="seguridadsocialnov">
		<call-query href="getSeguridadsocialnovPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
