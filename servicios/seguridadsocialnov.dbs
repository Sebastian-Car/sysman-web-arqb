	<query id="updateSeguridadsocialnov" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SEGURIDADSOCIALNOV SET COMPANIA=:COMPANIA, CLASEORDEN=:CLASEORDEN, ORDENDECOMPRA=:ORDENDECOMPRA, NOVEDAD=:NOVEDAD, CODIGOPLANI=:CODIGOPLANI, PERIODO=:PERIODO, IBC=:IBC, SALUD=:SALUD, PENSION=:PENSION, ARL=:ARL, CAJACOMPEN=:CAJACOMPEN, SENA=:SENA, ICBF=:ICBF, TOTALAPORTES=:TOTALAPORTES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SEGURIDADSOCIALNOV.COMPANIA= :KEY_COMPANIA AND SEGURIDADSOCIALNOV.CLASEORDEN= :KEY_CLASEORDEN AND SEGURIDADSOCIALNOV.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND SEGURIDADSOCIALNOV.NOVEDAD= :KEY_NOVEDAD AND SEGURIDADSOCIALNOV.CODIGOPLANI= :KEY_CODIGOPLANI</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

