			<with-param name="PENSION" query-param="PENSION"/>
			<with-param name="ARL" query-param="ARL"/>
			<with-param name="CAJACOMPEN" query-param="CAJACOMPEN"/>
			<with-param name="SENA" query-param="SENA"/>
			<with-param name="ICBF" query-param="ICBF"/>
			<with-param name="TOTALAPORTES" query-param="TOTALAPORTES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSeguridadsocialnovNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CLASEORDEN, ORDENDECOMPRA, NOVEDAD, CODIGOPLANI, PERIODO, IBC, SALUD, PENSION, ARL, CAJACOMPEN, SENA, ICBF, TOTALAPORTES FROM SEGURIDADSOCIALNOV) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASEORDEN), '%')) AND (CASE WHEN ORDENDECOMPRA IS NULL THEN ' ' ELSE UPPER(ORDENDECOMPRA) END) LIKE UPPER(CONCAT(CONCAT('%',:ORDENDECOMPRA), '%')) AND (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOVEDAD), '%')) AND (CASE WHEN CODIGOPLANI IS NULL THEN ' ' ELSE UPPER(CODIGOPLANI) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPLANI), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN IBC IS NULL THEN ' ' ELSE UPPER(IBC) END) LIKE UPPER(CONCAT(CONCAT('%',:IBC), '%')) AND (CASE WHEN SALUD IS NULL THEN ' ' ELSE UPPER(SALUD) END) LIKE UPPER(CONCAT(CONCAT('%',:SALUD), '%')) AND (CASE WHEN PENSION IS NULL THEN ' ' ELSE UPPER(PENSION) END) LIKE UPPER(CONCAT(CONCAT('%',:PENSION), '%')) AND (CASE WHEN ARL IS NULL THEN ' ' ELSE UPPER(ARL) END) LIKE UPPER(CONCAT(CONCAT('%',:ARL), '%')) AND (CASE WHEN CAJACOMPEN IS NULL THEN ' ' ELSE UPPER(CAJACOMPEN) END) LIKE UPPER(CONCAT(CONCAT('%',:CAJACOMPEN), '%')) AND (CASE WHEN SENA IS NULL THEN ' ' ELSE UPPER(SENA) END) LIKE UPPER(CONCAT(CONCAT('%',:SENA), '%')) AND (CASE WHEN ICBF IS NULL THEN ' ' ELSE UPPER(ICBF) END) LIKE UPPER(CONCAT(CONCAT('%',:ICBF), '%')) AND (CASE WHEN TOTALAPORTES IS NULL THEN ' ' ELSE UPPER(TOTALAPORTES) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTALAPORTES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="CODIGOPLANI" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="SALUD" sqlType="STRING"/>
		<param name="PENSION" sqlType="STRING"/>
		<param name="ARL" sqlType="STRING"/>
		<param name="CAJACOMPEN" sqlType="STRING"/>
		<param name="SENA" sqlType="STRING"/>
		<param name="ICBF" sqlType="STRING"/>
		<param name="TOTALAPORTES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="seguridadsocialnov/numero">
		<call-query href="getSeguridadsocialnovNumeroQuery">
