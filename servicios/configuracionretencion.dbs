<data name="configuracionretencion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertConfiguracionretencion" keyColumns="COMPANIA,ANO,REGIMEN_COMPRADOR,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONFIGURACION_RETENCION (COMPANIA, ANO, REGIMEN_COMPRADOR, REGIMEN_VENDEDOR, TIPO_RETENCION, CONSECUTIVO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ANO, :REGIMEN_COMPRADOR, :REGIMEN_VENDEDOR, :TIPO_RETENCION, :CONSECUTIVO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO","KEY_REGIMEN_COMPRADOR":"$REGIMEN_COMPRADOR","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="REGIMEN_COMPRADOR" sqlType="STRING"/>
		<param name="REGIMEN_VENDEDOR" sqlType="STRING"/>
		<param name="TIPO_RETENCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="configuracionretencion">
		<call-query href="insertConfiguracionretencion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="REGIMEN_COMPRADOR" query-param="REGIMEN_COMPRADOR"/>
			<with-param name="REGIMEN_VENDEDOR" query-param="REGIMEN_VENDEDOR"/>
			<with-param name="TIPO_RETENCION" query-param="TIPO_RETENCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteConfiguracionretencion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONFIGURACION_RETENCION WHERE CONFIGURACION_RETENCION.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_RETENCION.ANO= :KEY_ANO AND CONFIGURACION_RETENCION.REGIMEN_COMPRADOR= :KEY_REGIMEN_COMPRADOR AND CONFIGURACION_RETENCION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_REGIMEN_COMPRADOR" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="configuracionretencion">
		<call-query href="deleteConfiguracionretencion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_REGIMEN_COMPRADOR" query-param="KEY_REGIMEN_COMPRADOR"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getConfiguracionretencionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CR.COMPANIA,CR.ANO,CR.CONSECUTIVO,CR.REGIMEN_COMPRADOR,CR.REGIMEN_VENDEDOR,CR.TIPO_RETENCION, TIPOREGIMEN_C.NOMBRE NOMBRE_COMPRADOR, TIPOREGIMEN_V.NOMBRE NOMBRE_VENDEDOR,TIPORETENCION.NOMBRE NOMBRE_RETENCION FROM CONFIGURACION_RETENCION CR INNER JOIN TIPOREGIMEN TIPOREGIMEN_C ON TIPOREGIMEN_C.CODIGO = CR.REGIMEN_COMPRADOR INNER JOIN TIPOREGIMEN TIPOREGIMEN_V ON TIPOREGIMEN_V.CODIGO = CR.REGIMEN_VENDEDOR INNER JOIN TIPORETENCION ON TIPORETENCION.CODIGO = CR.TIPO_RETENCION WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND REGIMEN_COMPRADOR = :REGIMEN) INI WHERE (CASE WHEN REGIMEN_COMPRADOR IS NULL THEN ' ' ELSE UPPER(REGIMEN_COMPRADOR) END) LIKE UPPER(CONCAT(:REGIMEN_COMPRADOR, '%')) AND (CASE WHEN REGIMEN_VENDEDOR IS NULL THEN ' ' ELSE UPPER(REGIMEN_VENDEDOR) END) LIKE UPPER(CONCAT(:REGIMEN_VENDEDOR, '%')) AND (CASE WHEN TIPO_RETENCION IS NULL THEN ' ' ELSE UPPER(TIPO_RETENCION) END) LIKE UPPER(CONCAT(:TIPO_RETENCION, '%')) AND (CASE WHEN NOMBRE_COMPRADOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_COMPRADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_COMPRADOR), '%')) AND (CASE WHEN NOMBRE_VENDEDOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_VENDEDOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_VENDEDOR), '%')) AND (CASE WHEN NOMBRE_RETENCION IS NULL THEN ' ' ELSE UPPER(NOMBRE_RETENCION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RETENCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO","CONSECUTIVO":"$CONSECUTIVO(type:integer)","REGIMEN_COMPRADOR":"$REGIMEN_COMPRADOR","REGIMEN_VENDEDOR":"$REGIMEN_VENDEDOR","TIPO_RETENCION":"$TIPO_RETENCION","NOMBRE_COMPRADOR":"$NOMBRE_COMPRADOR","NOMBRE_VENDEDOR":"$NOMBRE_VENDEDOR","NOMBRE_RETENCION":"$NOMBRE_RETENCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="REGIMEN_COMPRADOR" sqlType="STRING"/>
		<param name="REGIMEN_VENDEDOR" sqlType="STRING"/>
		<param name="TIPO_RETENCION" sqlType="STRING"/>
		<param name="NOMBRE_COMPRADOR" sqlType="STRING"/>
		<param name="NOMBRE_VENDEDOR" sqlType="STRING"/>
		<param name="NOMBRE_RETENCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="configuracionretencion">
		<call-query href="getConfiguracionretencionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="REGIMEN" query-param="REGIMEN"/>
			<with-param name="REGIMEN_COMPRADOR" query-param="REGIMEN_COMPRADOR"/>
			<with-param name="REGIMEN_VENDEDOR" query-param="REGIMEN_VENDEDOR"/>
			<with-param name="TIPO_RETENCION" query-param="TIPO_RETENCION"/>
			<with-param name="NOMBRE_COMPRADOR" query-param="NOMBRE_COMPRADOR"/>
			<with-param name="NOMBRE_VENDEDOR" query-param="NOMBRE_VENDEDOR"/>
			<with-param name="NOMBRE_RETENCION" query-param="NOMBRE_RETENCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConfiguracionretencionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CR.COMPANIA,CR.ANO,CR.CONSECUTIVO,CR.REGIMEN_COMPRADOR,CR.REGIMEN_VENDEDOR,CR.TIPO_RETENCION, TIPOREGIMEN_C.NOMBRE NOMBRE_COMPRADOR, TIPOREGIMEN_V.NOMBRE NOMBRE_VENDEDOR,TIPORETENCION.NOMBRE NOMBRE_RETENCION FROM CONFIGURACION_RETENCION CR INNER JOIN TIPOREGIMEN TIPOREGIMEN_C ON TIPOREGIMEN_C.CODIGO = CR.REGIMEN_COMPRADOR INNER JOIN TIPOREGIMEN TIPOREGIMEN_V ON TIPOREGIMEN_V.CODIGO = CR.REGIMEN_VENDEDOR INNER JOIN TIPORETENCION ON TIPORETENCION.CODIGO = CR.TIPO_RETENCION WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND REGIMEN_COMPRADOR = :REGIMEN) INI WHERE (CASE WHEN REGIMEN_COMPRADOR IS NULL THEN ' ' ELSE UPPER(REGIMEN_COMPRADOR) END) LIKE UPPER(CONCAT(:REGIMEN_COMPRADOR, '%')) AND (CASE WHEN REGIMEN_VENDEDOR IS NULL THEN ' ' ELSE UPPER(REGIMEN_VENDEDOR) END) LIKE UPPER(CONCAT(:REGIMEN_VENDEDOR, '%')) AND (CASE WHEN TIPO_RETENCION IS NULL THEN ' ' ELSE UPPER(TIPO_RETENCION) END) LIKE UPPER(CONCAT(:TIPO_RETENCION, '%')) AND (CASE WHEN NOMBRE_COMPRADOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_COMPRADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_COMPRADOR), '%')) AND (CASE WHEN NOMBRE_VENDEDOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_VENDEDOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_VENDEDOR), '%')) AND (CASE WHEN NOMBRE_RETENCION IS NULL THEN ' ' ELSE UPPER(NOMBRE_RETENCION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RETENCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="REGIMEN_COMPRADOR" sqlType="STRING"/>
		<param name="REGIMEN_VENDEDOR" sqlType="STRING"/>
		<param name="TIPO_RETENCION" sqlType="STRING"/>
		<param name="NOMBRE_COMPRADOR" sqlType="STRING"/>
		<param name="NOMBRE_VENDEDOR" sqlType="STRING"/>
		<param name="NOMBRE_RETENCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionretencion/numero">
		<call-query href="getConfiguracionretencionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="REGIMEN" query-param="REGIMEN"/>
			<with-param name="REGIMEN_COMPRADOR" query-param="REGIMEN_COMPRADOR"/>
			<with-param name="REGIMEN_VENDEDOR" query-param="REGIMEN_VENDEDOR"/>
			<with-param name="TIPO_RETENCION" query-param="TIPO_RETENCION"/>
			<with-param name="NOMBRE_COMPRADOR" query-param="NOMBRE_COMPRADOR"/>
			<with-param name="NOMBRE_VENDEDOR" query-param="NOMBRE_VENDEDOR"/>
			<with-param name="NOMBRE_RETENCION" query-param="NOMBRE_RETENCION"/>

		</call-query>
	</resource>
	<query id="getConfiguracionretencionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM CONFIGURACION_RETENCION WHERE CONFIGURACION_RETENCION.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_RETENCION.ANO= :KEY_ANO AND CONFIGURACION_RETENCION.REGIMEN_COMPRADOR= :KEY_REGIMEN_COMPRADOR AND CONFIGURACION_RETENCION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO","REGIMEN_COMPRADOR":"$REGIMEN_COMPRADOR","REGIMEN_VENDEDOR":"$REGIMEN_VENDEDOR","TIPO_RETENCION":"$TIPO_RETENCION","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_REGIMEN_COMPRADOR" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionretencion/data">
		<call-query href="getConfiguracionretencionRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_REGIMEN_COMPRADOR" query-param="KEY_REGIMEN_COMPRADOR"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateConfiguracionretencion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONFIGURACION_RETENCION SET COMPANIA=:COMPANIA, ANO=:ANO, REGIMEN_COMPRADOR=:REGIMEN_COMPRADOR, REGIMEN_VENDEDOR=:REGIMEN_VENDEDOR, TIPO_RETENCION=:TIPO_RETENCION, CONSECUTIVO=:CONSECUTIVO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE CONFIGURACION_RETENCION.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_RETENCION.ANO= :KEY_ANO AND CONFIGURACION_RETENCION.REGIMEN_COMPRADOR= :KEY_REGIMEN_COMPRADOR AND CONFIGURACION_RETENCION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="REGIMEN_COMPRADOR" sqlType="STRING"/>
		<param name="REGIMEN_VENDEDOR" sqlType="STRING"/>
		<param name="TIPO_RETENCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_REGIMEN_COMPRADOR" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="configuracionretencion">
		<call-query href="updateConfiguracionretencion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="REGIMEN_COMPRADOR" query-param="REGIMEN_COMPRADOR"/>
			<with-param name="REGIMEN_VENDEDOR" query-param="REGIMEN_VENDEDOR"/>
			<with-param name="TIPO_RETENCION" query-param="TIPO_RETENCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_REGIMEN_COMPRADOR" query-param="KEY_REGIMEN_COMPRADOR"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>