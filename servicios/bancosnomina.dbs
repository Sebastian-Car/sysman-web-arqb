	<query id="getBancosnominaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, BANCO, NOMBRE, CUENTA, TIPO_CUENTA, CASE TIPO_CUENTA WHEN 'A' THEN 'Ahorros' WHEN 'C' THEN 'Corriente' WHEN 'R' THEN 'Crédito Rotativo' END  TIPOCUENTA_LB, TELEFONO, FAX, DIRECCION, SUCURSAL, CODIGO_ENTIDAD,(CASE PAGOBANCOLOMBIA WHEN 0 THEN 'false' ELSE 'true' END) PAGOBANCOLOMBIA,(CASE PAGOBANCOBOGOTA WHEN 0 THEN 'false' ELSE 'true' END) PAGOBANCOBOGOTA, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, DOC_SIIF_BANCO, NIT_SIIF,(CASE IND_CODCIUDADCTA WHEN 0 THEN 'false' ELSE 'true' END) IND_CODCIUDADCTA, CODIGO_NACHAM FROM BANCOS_NOMINA WHERE COMPANIA = :COMPANIA ORDER BY TO_NUMBER(BANCO) ASC) INI WHERE (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END) LIKE UPPER(CONCAT(:BANCO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN TIPOCUENTA_LB IS NULL THEN ' ' ELSE UPPER(TIPOCUENTA_LB) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCUENTA_LB), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="TIPOCUENTA_LB" sqlType="STRING"/>

