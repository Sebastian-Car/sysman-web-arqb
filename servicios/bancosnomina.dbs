	<query id="getBancosnominaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, BANCO, NOMBRE, CUENTA, TIPO_CUENTA, TELEFONO, FAX, DIRECCION, SUCURSAL, CODIGO_ENTIDAD,(CASE PAGOBANCOLOMBIA WHEN 0 THEN 'false' ELSE 'true' END) PAGOBANCOLOMBIA,(CASE PAGOBANPOULAR WHEN 0 THEN 'false' ELSE 'true' END) PAGOBANPOULAR, DIGITO_VERIFICACION,(CASE PAGOBANCOBOGOTA WHEN 0 THEN 'false' ELSE 'true' END) PAGOBANCOBOGOTA, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, DOC_SIIF_BANCO, NIT_SIIF,(CASE IND_CODCIUDADCTA WHEN 0 THEN 'false' ELSE 'true' END) IND_CODCIUDADCTA, CODIGO_NACHAM FROM BANCOS_NOMINA WHERE BANCOS_NOMINA.COMPANIA= :KEY_COMPANIA AND BANCOS_NOMINA.BANCO= :KEY_BANCO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","BANCO":"$BANCO","NOMBRE":"$NOMBRE","CUENTA":"$CUENTA","TIPO_CUENTA":"$TIPO_CUENTA","TELEFONO":"$TELEFONO","FAX":"$FAX","DIRECCION":"$DIRECCION","SUCURSAL":"$SUCURSAL","CODIGO_ENTIDAD":"$CODIGO_ENTIDAD","PAGOBANCOLOMBIA":"$PAGOBANCOLOMBIA(type:boolean)","PAGOBANPOULAR":"$PAGOBANPOULAR(type:boolean)","DIGITO_VERIFICACION":"$DIGITO_VERIFICACION","PAGOBANCOBOGOTA":"$PAGOBANCOBOGOTA(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DOC_SIIF_BANCO":"$DOC_SIIF_BANCO","NIT_SIIF":"$NIT_SIIF","IND_CODCIUDADCTA":"$IND_CODCIUDADCTA(type:boolean)","CODIGO_NACHAM":"$CODIGO_NACHAM"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_BANCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bancosnomina/data">
		<call-query href="getBancosnominaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_BANCO" query-param="KEY_BANCO"/>

		</call-query>
	</resource>

	<query id="getBancosnominaPagBancopopularpagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BANCOS_NOMINA.BANCO, BANCOS_NOMINA.NOMBRE, BANCOS_NOMINA.TIPO_CUENTA, BANCOS_NOMINA.CUENTA FROM BANCOS_NOMINA WHERE (BANCOS_NOMINA.BANCO &lt;&gt; '00' AND BANCOS_NOMINA.BANCO &lt;&gt; '99') AND BANCOS_NOMINA.PAGOBANPOULAR &lt;&gt; 0 AND BANCOS_NOMINA.COMPANIA=:COMPANIA ORDER BY BANCOS_NOMINA.NOMBRE) INI WHERE (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END) LIKE UPPER(CONCAT(:BANCO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPO_CUENTA IS NULL THEN ' ' ELSE UPPER(TIPO_CUENTA) END) LIKE UPPER(CONCAT(:TIPO_CUENTA, '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BANCO":"$BANCO","NOMBRE":"$NOMBRE","TIPO_CUENTA":"$TIPO_CUENTA","CUENTA":"$CUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_CUENTA" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bancosnomina/bancopopularpago/pag">
		<call-query href="getBancosnominaPagBancopopularpagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_CUENTA" query-param="TIPO_CUENTA"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBancosnominaNumBancopopularpagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BANCOS_NOMINA.BANCO, BANCOS_NOMINA.NOMBRE, BANCOS_NOMINA.TIPO_CUENTA, BANCOS_NOMINA.CUENTA FROM BANCOS_NOMINA WHERE (BANCOS_NOMINA.BANCO &lt;&gt; '00' AND BANCOS_NOMINA.BANCO &lt;&gt; '99') AND BANCOS_NOMINA.PAGOBANPOULAR &lt;&gt; 0 AND BANCOS_NOMINA.COMPANIA=:COMPANIA ORDER BY BANCOS_NOMINA.NOMBRE) INI WHERE (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END) LIKE UPPER(CONCAT(:BANCO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPO_CUENTA IS NULL THEN ' ' ELSE UPPER(TIPO_CUENTA) END) LIKE UPPER(CONCAT(:TIPO_CUENTA, '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_CUENTA" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bancosnomina/bancopopularpago/num">
