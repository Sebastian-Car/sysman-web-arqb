			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_CUENTA" query-param="TIPO_CUENTA"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="getBancosnominaBancosudamerisQuery"  useConfig="sysmandsunist">
		<sql>SELECT BANCOS_NOMINA.CODIGO_NACHAM, BANCOS_NOMINA.CUENTA, CASE BANCOS_NOMINA.TIPO_CUENTA WHEN 'A' THEN '2' WHEN 'C' THEN '1' ELSE '' END TIPO_CUENTA FROM BANCOS_NOMINA WHERE BANCOS_NOMINA.COMPANIA = :COMPANIA AND BANCOS_NOMINA.NOMBRE LIKE '%SUDAMERIS%'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_NACHAM":"$CODIGO_NACHAM","CUENTA":"$CUENTA","TIPO_CUENTA":"$TIPO_CUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bancosnomina/bancosudameris">
		<call-query href="getBancosnominaBancosudamerisQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	
