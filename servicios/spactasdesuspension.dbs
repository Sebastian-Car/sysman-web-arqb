<data name="spactasdesuspension" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpactasdesuspensionConsecutivoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_NUMBER(MAX(IDACTA))+1 MAXI1  FROM SP_ACTASDESUSPENSION WHERE SP_ACTASDESUSPENSION.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MAXI1":"$MAXI1(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spactasdesuspension/consecutivoporcompania">
		<call-query href="getSpactasdesuspensionConsecutivoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpactasdesuspensionPeriodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT SP_ACTASDESUSPENSION.PERIODO  FROM SP_ACTASDESUSPENSION WHERE SP_ACTASDESUSPENSION.COMPANIA = :COMPANIA ORDER BY SP_ACTASDESUSPENSION.PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spactasdesuspension/periodosporcompania">
		<call-query href="getSpactasdesuspensionPeriodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpactasdesuspensionAniosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT SP_ACTASDESUSPENSION.ANO  FROM SP_ACTASDESUSPENSION WHERE SP_ACTASDESUSPENSION.COMPANIA = :COMPANIA ORDER BY SP_ACTASDESUSPENSION.ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spactasdesuspension/aniosporcompania">
		<call-query href="getSpactasdesuspensionAniosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>