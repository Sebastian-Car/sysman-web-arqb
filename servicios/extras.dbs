<data name="extras" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertExtras" keyColumns="COMPANIA,ID_DE_EMPLEADO,ID_DE_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EXTRAS (COMPANIA, ID_DE_EMPLEADO, ID_DE_CONCEPTO, FECHAINICIO, FECHAFINAL, CANTIDAD, EXTRA_ACTO, EXTRA_FECHA, PAGADA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_EMPLEADO, :ID_DE_CONCEPTO, TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), :CANTIDAD, :EXTRA_ACTO, TO_DATE(:EXTRA_FECHA,'DD/MM/YYYY HH24:MI:SS'), :PAGADA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","KEY_FECHAINICIO":"$FECHAINICIO","KEY_FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="EXTRA_ACTO" sqlType="STRING"/>
		<param defaultValue="" name="EXTRA_FECHA" sqlType="STRING"/>
		<param defaultValue="0" name="PAGADA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="extras">
		<call-query href="insertExtras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="EXTRA_ACTO" query-param="EXTRA_ACTO"/>
			<with-param name="EXTRA_FECHA" query-param="EXTRA_FECHA"/>
			<with-param name="PAGADA" query-param="PAGADA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteExtras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EXTRAS WHERE EXTRAS.COMPANIA= :KEY_COMPANIA AND EXTRAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND EXTRAS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO AND EXTRAS.FECHAINICIO= TO_DATE(:KEY_FECHAINICIO,'DD/MM/YYYY HH24:MI:SS') AND EXTRAS.FECHAFINAL= TO_DATE(:KEY_FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="INTEGER"/>
		<param name="KEY_FECHAINICIO" sqlType="STRING"/>
		<param name="KEY_FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="extras">
		<call-query href="deleteExtras">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>
			<with-param name="KEY_FECHAINICIO" query-param="KEY_FECHAINICIO"/>
			<with-param name="KEY_FECHAFINAL" query-param="KEY_FECHAFINAL"/>

		</call-query>
	</resource>
	<query id="getExtrasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT EXTRAS.COMPANIA, EXTRAS.ID_DE_EMPLEADO, EXTRAS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO,(TO_CHAR(EXTRAS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(EXTRAS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, EXTRAS.CANTIDAD, EXTRAS.EXTRA_ACTO,(TO_CHAR(EXTRAS.EXTRA_FECHA,'DD/MM/YYYY HH24:MI:SS')) EXTRA_FECHA, CASE WHEN EXTRAS.PAGADA NOT IN 0 THEN 'true' ELSE 'false' END PAGADA FROM EXTRAS LEFT JOIN CONCEPTOS ON EXTRAS.COMPANIA = CONCEPTOS.COMPANIA AND EXTRAS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO WHERE EXTRAS.COMPANIA = :COMPANIA AND EXTRAS.ID_DE_EMPLEADO = :ID_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL","CANTIDAD":"$CANTIDAD","EXTRA_ACTO":"$EXTRA_ACTO","EXTRA_FECHA":"$EXTRA_FECHA","PAGADA":"$PAGADA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="extras">
		<call-query href="getExtrasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="updateExtras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EXTRAS SET COMPANIA=:COMPANIA, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, FECHAINICIO=TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), CANTIDAD=:CANTIDAD, EXTRA_ACTO=:EXTRA_ACTO, EXTRA_FECHA=TO_DATE(:EXTRA_FECHA,'DD/MM/YYYY HH24:MI:SS'), PAGADA=:PAGADA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EXTRAS.COMPANIA= :KEY_COMPANIA AND EXTRAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND EXTRAS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO AND EXTRAS.FECHAINICIO= TO_DATE(:KEY_FECHAINICIO,'DD/MM/YYYY HH24:MI:SS') AND EXTRAS.FECHAFINAL= TO_DATE(:KEY_FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="EXTRA_ACTO" sqlType="STRING"/>
		<param name="EXTRA_FECHA" sqlType="STRING"/>
		<param name="PAGADA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_FECHAINICIO" sqlType="STRING"/>
		<param name="KEY_FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="extras">
		<call-query href="updateExtras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="EXTRA_ACTO" query-param="EXTRA_ACTO"/>
			<with-param name="EXTRA_FECHA" query-param="EXTRA_FECHA"/>
			<with-param name="PAGADA" query-param="PAGADA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>
			<with-param name="KEY_FECHAINICIO" query-param="KEY_FECHAINICIO"/>
			<with-param name="KEY_FECHAFINAL" query-param="KEY_FECHAFINAL"/>

		</call-query>
	</resource>

</data>