<data name="retencionesventacnt" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertRetencionesventacnt" keyColumns="COMPANIA,CONSECUTIVO,ANIO,TIPOCOMP,NUMEROCOMP,CUENTA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO RETENCIONESVENTACNT (COMPANIA, CONSECUTIVO, ANIO, TIPOCOMP, NUMEROCOMP, CUENTA, VALOR_RETENIDO, BASEGRAVABLE, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CONSECUTIVO, :ANIO, :TIPOCOMP, :NUMEROCOMP, :CUENTA, :VALOR_RETENIDO, :BASEGRAVABLE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)","KEY_ANIO":"$ANIO(type:integer)","KEY_TIPOCOMP":"$TIPOCOMP","KEY_NUMEROCOMP":"$NUMEROCOMP(type:long)","KEY_CUENTA":"$CUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_RETENIDO" sqlType="STRING"/>
		<param defaultValue="0" name="BASEGRAVABLE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="retencionesventacnt">
		<call-query href="insertRetencionesventacnt">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="VALOR_RETENIDO" query-param="VALOR_RETENIDO"/>
			<with-param name="BASEGRAVABLE" query-param="BASEGRAVABLE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteRetencionesventacnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM RETENCIONESVENTACNT WHERE RETENCIONESVENTACNT.COMPANIA= :KEY_COMPANIA AND RETENCIONESVENTACNT.CONSECUTIVO= :KEY_CONSECUTIVO AND RETENCIONESVENTACNT.ANIO= :KEY_ANIO AND RETENCIONESVENTACNT.TIPOCOMP= :KEY_TIPOCOMP AND RETENCIONESVENTACNT.NUMEROCOMP= :KEY_NUMEROCOMP AND RETENCIONESVENTACNT.CUENTA= :KEY_CUENTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_ANIO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOMP" sqlType="STRING"/>
		<param name="KEY_NUMEROCOMP" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="retencionesventacnt">
		<call-query href="deleteRetencionesventacnt">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_ANIO" query-param="KEY_ANIO"/>
			<with-param name="KEY_TIPOCOMP" query-param="KEY_TIPOCOMP"/>
			<with-param name="KEY_NUMEROCOMP" query-param="KEY_NUMEROCOMP"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>

		</call-query>
	</resource>
	<query id="getRetencionesventacntPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CONSECUTIVO, ANIO, TIPOCOMP, NUMEROCOMP, CUENTA, VALOR_RETENIDO, BASEGRAVABLE FROM RETENCIONESVENTACNT WHERE COMPANIA = :COMPANIA AND ANIO = :ANIO AND TIPOCOMP = :TIPOCOMP AND NUMEROCOMP = :NUMEROCOMP) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN ANIO IS NULL THEN ' ' ELSE UPPER(ANIO) END) LIKE UPPER(CONCAT(:ANIO, '%')) AND (CASE WHEN TIPOCOMP IS NULL THEN ' ' ELSE UPPER(TIPOCOMP) END) LIKE UPPER(CONCAT(:TIPOCOMP, '%')) AND (CASE WHEN NUMEROCOMP IS NULL THEN ' ' ELSE UPPER(NUMEROCOMP) END) LIKE UPPER(CONCAT(:NUMEROCOMP, '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN VALOR_RETENIDO IS NULL THEN ' ' ELSE UPPER(VALOR_RETENIDO) END) LIKE UPPER(CONCAT(:VALOR_RETENIDO, '%')) AND (CASE WHEN BASEGRAVABLE IS NULL THEN ' ' ELSE UPPER(BASEGRAVABLE) END) LIKE UPPER(CONCAT(:BASEGRAVABLE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","ANIO":"$ANIO(type:integer)","TIPOCOMP":"$TIPOCOMP","NUMEROCOMP":"$NUMEROCOMP(type:long)","CUENTA":"$CUENTA","VALOR_RETENIDO":"$VALOR_RETENIDO","BASEGRAVABLE":"$BASEGRAVABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="VALOR_RETENIDO" sqlType="STRING"/>
		<param name="BASEGRAVABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="retencionesventacnt">
		<call-query href="getRetencionesventacntPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="VALOR_RETENIDO" query-param="VALOR_RETENIDO"/>
			<with-param name="BASEGRAVABLE" query-param="BASEGRAVABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRetencionesventacntNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CONSECUTIVO, ANIO, TIPOCOMP, NUMEROCOMP, CUENTA, VALOR_RETENIDO, BASEGRAVABLE FROM RETENCIONESVENTACNT WHERE COMPANIA = :COMPANIA AND ANIO = :ANIO AND TIPOCOMP = :TIPOCOMP AND NUMEROCOMP = :NUMEROCOMP) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN ANIO IS NULL THEN ' ' ELSE UPPER(ANIO) END) LIKE UPPER(CONCAT(:ANIO, '%')) AND (CASE WHEN TIPOCOMP IS NULL THEN ' ' ELSE UPPER(TIPOCOMP) END) LIKE UPPER(CONCAT(:TIPOCOMP, '%')) AND (CASE WHEN NUMEROCOMP IS NULL THEN ' ' ELSE UPPER(NUMEROCOMP) END) LIKE UPPER(CONCAT(:NUMEROCOMP, '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN VALOR_RETENIDO IS NULL THEN ' ' ELSE UPPER(VALOR_RETENIDO) END) LIKE UPPER(CONCAT(:VALOR_RETENIDO, '%')) AND (CASE WHEN BASEGRAVABLE IS NULL THEN ' ' ELSE UPPER(BASEGRAVABLE) END) LIKE UPPER(CONCAT(:BASEGRAVABLE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="VALOR_RETENIDO" sqlType="STRING"/>
		<param name="BASEGRAVABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="retencionesventacnt/numero">
		<call-query href="getRetencionesventacntNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="VALOR_RETENIDO" query-param="VALOR_RETENIDO"/>
			<with-param name="BASEGRAVABLE" query-param="BASEGRAVABLE"/>

		</call-query>
	</resource>
	<query id="updateRetencionesventacnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RETENCIONESVENTACNT SET COMPANIA=:COMPANIA, CONSECUTIVO=:CONSECUTIVO, ANIO=:ANIO, TIPOCOMP=:TIPOCOMP, NUMEROCOMP=:NUMEROCOMP, CUENTA=:CUENTA, VALOR_RETENIDO=:VALOR_RETENIDO, BASEGRAVABLE=:BASEGRAVABLE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE RETENCIONESVENTACNT.COMPANIA= :KEY_COMPANIA AND RETENCIONESVENTACNT.CONSECUTIVO= :KEY_CONSECUTIVO AND RETENCIONESVENTACNT.ANIO= :KEY_ANIO AND RETENCIONESVENTACNT.TIPOCOMP= :KEY_TIPOCOMP AND RETENCIONESVENTACNT.NUMEROCOMP= :KEY_NUMEROCOMP AND RETENCIONESVENTACNT.CUENTA= :KEY_CUENTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="VALOR_RETENIDO" sqlType="STRING"/>
		<param name="BASEGRAVABLE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_ANIO" sqlType="STRING"/>
		<param name="KEY_TIPOCOMP" sqlType="STRING"/>
		<param name="KEY_NUMEROCOMP" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="retencionesventacnt">
		<call-query href="updateRetencionesventacnt">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="VALOR_RETENIDO" query-param="VALOR_RETENIDO"/>
			<with-param name="BASEGRAVABLE" query-param="BASEGRAVABLE"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_ANIO" query-param="KEY_ANIO"/>
			<with-param name="KEY_TIPOCOMP" query-param="KEY_TIPOCOMP"/>
			<with-param name="KEY_NUMEROCOMP" query-param="KEY_NUMEROCOMP"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>

		</call-query>
	</resource>

</data>