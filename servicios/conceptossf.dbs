	</resource>
	<query id="getConceptossfRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CONCEPTOS_SF.COMPANIA, CONCEPTOS_SF.ANO, CONCEPTOS_SF.TIPOCOBRO, CONCEPTOS_SF.CODIGO, CONCEPTOS_SF.NOMBRE, CONCEPTOS_SF.VALOR_COMPRA, CONCEPTOS_SF.VALOR_BASE, CONCEPTOS_SF.UNIDAD,(CASE CONCEPTOS_SF.APLICAIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICAIVA, CONCEPTOS_SF.PORCENTAJEIVA,(CASE CONCEPTOS_SF.APLICARETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEFUENTE, CONCEPTOS_SF.PORCENTAJERETEFUENTE,(CASE CONCEPTOS_SF.APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, CONCEPTOS_SF.PORCENTAJEDESCUENTO,(CASE CONCEPTOS_SF.APLICAICA WHEN 0 THEN 'false' ELSE 'true' END) APLICAICA, CONCEPTOS_SF.PORCENTAJEICA,(CASE CONCEPTOS_SF.APLICAFORMULA WHEN 0 THEN 'false' ELSE 'true' END) APLICAFORMULA, CONCEPTOS_SF.FORMULA, CONCEPTOS_SF.TIPODECONCEPTO,(CASE CONCEPTOS_SF.PERMITEMODIFICARVALOR WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARVALOR,(CASE CONCEPTOS_SF.AFECTAINVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAINVENTARIO, CONCEPTOS_SF.CODIGOINVENTARIO,(CASE CONCEPTOS_SF.PERMITEMODIFICARCANTIDAD WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARCANTIDAD, CONCEPTOS_SF.CUENTADEBITOBASE, CONCEPTOS_SF.CUENTACREDITOBASE, CONCEPTOS_SF.CUENTADEBITOIVA, CONCEPTOS_SF.CUENTACREDITOIVA, CONCEPTOS_SF.CUENTADEBITORETE, CONCEPTOS_SF.CUENTACREDITORETE, CONCEPTOS_SF.CUENTADEBITODESCUENTO, CONCEPTOS_SF.CUENTADEBITOICA, CONCEPTOS_SF.CUENTACREDITOICA, CONCEPTOS_SF.CUENTADEBITOUTILIDAD, CONCEPTOS_SF.CUENTACREDITOUTILIDAD, CONCEPTOS_SF.CUENTADEBITOBASE_AV, CONCEPTOS_SF.CUENTACREDITOBASE_AV, CONCEPTOS_SF.CUENTADEBITOIVA_AV, CONCEPTOS_SF.CUENTACREDITOIVA_AV, CONCEPTOS_SF.CUENTADEBITORETE_AV, CONCEPTOS_SF.CUENTACREDITORETE_AV, CONCEPTOS_SF.CUENTADEBITODESCUENTO_AV, CONCEPTOS_SF.CUENTACREDITODESCUENTO_AV, CONCEPTOS_SF.CUENTADEBITOICA_AV, CONCEPTOS_SF.CUENTACREDITOICA_AV, CONCEPTOS_SF.CUENTADEBITOUTILIDAD_AV, CONCEPTOS_SF.CUENTACREDITOUTILIDAD_AV, CONCEPTOS_SF.AUXILIAR, CONCEPTOS_SF.CENTRO_COSTO,(CASE CONCEPTOS_SF.MANEJA_RANGOTIEMPO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RANGOTIEMPO, CONCEPTOS_SF.PORCETAJE_UTILIDAD, CONCEPTOS_SF.EXISTENCIA, CONCEPTOS_SF.CUENTA_RECAUDO, CONCEPTOS_SF.DIGITOS_REDONDEO,(CASE CONCEPTOS_SF.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO, CONCEPTOS_SF.CLASE_CONCEPTO, CONCEPTOS_SF.CTADEBACOMETIDA, CONCEPTOS_SF.CTACREDACOMETIDA, CONCEPTOS_SF.CTADEBACOMETIDA_AV, CONCEPTOS_SF.CTACREDACOMETIDA_AV, CONCEPTOS_SF.CTADEBAIU, CONCEPTOS_SF.CTACREDAIU, CONCEPTOS_SF.CTADEBAIU_AV, CONCEPTOS_SF.CTACREDAIU_AV, CONCEPTOS_SF.CTADEBADMONIMP, CONCEPTOS_SF.CTACREDADMONIMP, CONCEPTOS_SF.CTADEBADMONIMP_AV, CONCEPTOS_SF.CTACREDADMONIMP_AV, CONCEPTOS_SF.CTADEBUTILIDADAIU, CONCEPTOS_SF.CTACREDUTILIDADAIU, CONCEPTOS_SF.CTADEBUTILIDADAIU_AV, CONCEPTOS_SF.CTACREDUTILIDADAIU_AV, CONCEPTOS_SF.CTADEBIVAUTILIDAD, CONCEPTOS_SF.CTACREDIVAUTILIDAD, CONCEPTOS_SF.CTADEBIVAUTILIDAD_AV, CONCEPTOS_SF.CTACREDIVAUTILIDAD_AV, CONCEPTOS_SF.FORMULAR_ACOMETIDA, CONCEPTOS_SF.FORMULAR_AIU, CONCEPTOS_SF.FORMULAR_ADMONIMP, CONCEPTOS_SF.FORMULAR_UTILIDADAIU, CONCEPTOS_SF.FORMULAR_IVAUTILIDAD, CONCEPTOS_SF.AGRUPAR_COMO, CONCEPTOS_SF.CTAORDENDEUDORA_DEBITO, CONCEPTOS_SF.CTAORDENDEUDORA_CREDITO, CONCEPTOS_SF.CANTIDAD_PORDEFECTO,(CASE CONCEPTOS_SF.UNICO_BASEGRAVABLE WHEN 0 THEN 'false' ELSE 'true' END) UNICO_BASEGRAVABLE, CONCEPTOS_SF.FILTROREGIMEN, CONCEPTOS_SF.CREATED_BY, CONCEPTOS_SF.MODIFIED_BY,(TO_CHAR(CONCEPTOS_SF.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(CONCEPTOS_SF.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM CONCEPTOS_SF WHERE CONCEPTOS_SF.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_SF.ANO= :KEY_ANO AND CONCEPTOS_SF.TIPOCOBRO= :KEY_TIPOCOBRO AND CONCEPTOS_SF.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_BASE":"$VALOR_BASE","UNIDAD":"$UNIDAD","APLICAIVA":"$APLICAIVA(type:boolean)","PORCENTAJEIVA":"$PORCENTAJEIVA","APLICARETEFUENTE":"$APLICARETEFUENTE(type:boolean)","PORCENTAJERETEFUENTE":"$PORCENTAJERETEFUENTE","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO","APLICAICA":"$APLICAICA(type:boolean)","PORCENTAJEICA":"$PORCENTAJEICA","APLICAFORMULA":"$APLICAFORMULA(type:boolean)","FORMULA":"$FORMULA","TIPODECONCEPTO":"$TIPODECONCEPTO","PERMITEMODIFICARVALOR":"$PERMITEMODIFICARVALOR(type:boolean)","AFECTAINVENTARIO":"$AFECTAINVENTARIO(type:boolean)","CODIGOINVENTARIO":"$CODIGOINVENTARIO","PERMITEMODIFICARCANTIDAD":"$PERMITEMODIFICARCANTIDAD(type:boolean)","CUENTADEBITOBASE":"$CUENTADEBITOBASE","CUENTACREDITOBASE":"$CUENTACREDITOBASE","CUENTADEBITOIVA":"$CUENTADEBITOIVA","CUENTACREDITOIVA":"$CUENTACREDITOIVA","CUENTADEBITORETE":"$CUENTADEBITORETE","CUENTACREDITORETE":"$CUENTACREDITORETE","CUENTADEBITODESCUENTO":"$CUENTADEBITODESCUENTO","CUENTADEBITOICA":"$CUENTADEBITOICA","CUENTACREDITOICA":"$CUENTACREDITOICA","CUENTADEBITOUTILIDAD":"$CUENTADEBITOUTILIDAD","CUENTACREDITOUTILIDAD":"$CUENTACREDITOUTILIDAD","CUENTADEBITOBASE_AV":"$CUENTADEBITOBASE_AV","CUENTACREDITOBASE_AV":"$CUENTACREDITOBASE_AV","CUENTADEBITOIVA_AV":"$CUENTADEBITOIVA_AV","CUENTACREDITOIVA_AV":"$CUENTACREDITOIVA_AV","CUENTADEBITORETE_AV":"$CUENTADEBITORETE_AV","CUENTACREDITORETE_AV":"$CUENTACREDITORETE_AV","CUENTADEBITODESCUENTO_AV":"$CUENTADEBITODESCUENTO_AV","CUENTACREDITODESCUENTO_AV":"$CUENTACREDITODESCUENTO_AV","CUENTADEBITOICA_AV":"$CUENTADEBITOICA_AV","CUENTACREDITOICA_AV":"$CUENTACREDITOICA_AV","CUENTADEBITOUTILIDAD_AV":"$CUENTADEBITOUTILIDAD_AV","CUENTACREDITOUTILIDAD_AV":"$CUENTACREDITOUTILIDAD_AV","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COST