		<param defaultValue="" name="CUENTADEBITODESCUENTO_AV" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACREDITODESCUENTO_AV" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADEBITOICA_AV" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACREDITOICA_AV" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADEBITOUTILIDAD_AV" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACREDITOUTILIDAD_AV" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_RANGOTIEMPO" sqlType="STRING"/>
