<data name="conceptossf" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConceptossfPagAnoTipocobroRegimenQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS_SF.CODIGO, CONCEPTOS_SF.NOMBRE, CONCEPTOS_SF.TIPOCOBRO  FROM CONCEPTOS_SF WHERE CONCEPTOS_SF.COMPANIA = :COMPANIA AND CONCEPTOS_SF.ANO = :ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:TIPOCOBRO), CONCEPTOS_SF.TIPOCOBRO, 1) &gt; 0 AND CONCEPTOS_SF.FILTROREGIMEN = :REGIMEN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPOCOBRO":"$TIPOCOBRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptossf/anotipocobroregimen/pag">
		<call-query href="getConceptossfPagAnoTipocobroRegimenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="REGIMEN" query-param="REGIMEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptossfNumAnoTipocobroRegimenQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONCEPTOS_SF.CODIGO, CONCEPTOS_SF.NOMBRE, CONCEPTOS_SF.TIPOCOBRO  FROM CONCEPTOS_SF WHERE CONCEPTOS_SF.COMPANIA = :COMPANIA AND CONCEPTOS_SF.ANO = :ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:TIPOCOBRO), CONCEPTOS_SF.TIPOCOBRO, 1) &gt; 0 AND CONCEPTOS_SF.FILTROREGIMEN = :REGIMEN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptossf/anotipocobroregimen/num">
		<call-query href="getConceptossfNumAnoTipocobroRegimenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="REGIMEN" query-param="REGIMEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getConceptossfPagConsultaconceptoslistaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_CONCEPTOS WHERE TIPODECONCEPTO = 'C' AND COMPANIA = :COMPANIA AND ANO = :ANO_ACTUAL AND TIPOCOBRO = :TIPO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO_ACTUAL" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptossf/consultaconceptoslista/pag">
		<call-query href="getConceptossfPagConsultaconceptoslistaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO_ACTUAL" query-param="ANO_ACTUAL"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptossfNumConsultaconceptoslistaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_CONCEPTOS WHERE TIPODECONCEPTO = 'C' AND COMPANIA = :COMPANIA AND ANO = :ANO_ACTUAL AND TIPOCOBRO = :TIPO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO_ACTUAL" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptossf/consultaconceptoslista/num">
		<call-query href="getConceptossfNumConsultaconceptoslistaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO_ACTUAL" query-param="ANO_ACTUAL"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertConceptossf" keyColumns="COMPANIA,ANO,TIPOCOBRO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONCEPTOS_SF (COMPANIA, ANO, TIPOCOBRO, CODIGO, NOMBRE, VALOR_COMPRA, VALOR_BASE, UNIDAD, APLICAIVA, PORCENTAJEIVA, APLICARETEFUENTE, PORCENTAJERETEFUENTE, APLICADESCUENTO, PORCENTAJEDESCUENTO, APLICAICA, PORCENTAJEICA, APLICAFORMULA, FORMULA, TIPODECONCEPTO, PERMITEMODIFICARVALOR, AFECTAINVENTARIO, CODIGOINVENTARIO, PERMITEMODIFICARCANTIDAD, CUENTADEBITOBASE, CUENTACREDITOBASE, CUENTADEBITOIVA, CUENTACREDITOIVA, CUENTADEBITORETE, CUENTACREDITORETE, CUENTADEBITODESCUENTO, CUENTADEBITOICA, CUENTACREDITOICA, CUENTADEBITOUTILIDAD, CUENTACREDITOUTILIDAD, CUENTADEBITOBASE_AV, CUENTACREDITOBASE_AV, CUENTADEBITOIVA_AV, CUENTACREDITOIVA_AV, CUENTADEBITORETE_AV, CUENTACREDITORETE_AV, CUENTADEBITODESCUENTO_AV, CUENTACREDITODESCUENTO_AV, CUENTADEBITOICA_AV, CUENTACREDITOICA_AV, CUENTADEBITOUTILIDAD_AV, CUENTACREDITOUTILIDAD_AV, AUXILIAR, CENTRO_COSTO, MANEJA_RANGOTIEMPO, PORCETAJE_UTILIDAD, EXISTENCIA, CUENTA_RECAUDO, DIGITOS_REDONDEO, ESTADO, CLASE_CONCEPTO, CTADEBACOMETIDA, CTACREDACOMETIDA, CTADEBACOMETIDA_AV, CTACREDACOMETIDA_AV, CTADEBAIU, CTACREDAIU, CTADEBAIU_AV, CTACREDAIU_AV, CTADEBADMONIMP, CTACREDADMONIMP, CTADEBADMONIMP_AV, CTACREDADMONIMP_AV, CTADEBUTILIDADAIU, CTACREDUTILIDADAIU, CTADEBUTILIDADAIU_AV, CTACREDUTILIDADAIU_AV, CTADEBIVAUTILIDAD, CTACREDIVAUTILIDAD, CTADEBIVAUTILIDAD_AV, CTACREDIVAUTILIDAD_AV, FORMULAR_ACOMETIDA, FORMULAR_AIU, FORMULAR_ADMONIMP, FORMULAR_UTILIDADAIU, FORMULAR_IVAUTILIDAD, AGRUPAR_COMO, CTAORDENDEUDORA_DEBITO, CTAORDENDEUDORA_CREDITO, CANTIDAD_PORDEFECTO, UNICO_BASEGRAVABLE, FILTROREGIMEN, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPOCOBRO, :CODIGO, :NOMBRE, :VALOR_COMPRA, :VALOR_BASE, :UNIDAD, :APLICAIVA, :PORCENTAJEIVA, :APLICARETEFUENTE, :PORCENTAJERETEFUENTE, :APLICADESCUENTO, :PORCENTAJEDESCUENTO, :APLICAICA, :PORCENTAJEICA, :APLICAFORMULA, :FORMULA, :TIPODECONCEPTO, :PERMITEMODIFICARVALOR, :AFECTAINVENTARIO, :CODIGOINVENTARIO, :PERMITEMODIFICARCANTIDAD, :CUENTADEBITOBASE, :CUENTACREDITOBASE, :CUENTADEBITOIVA, :CUENTACREDITOIVA, :CUENTADEBITORETE, :CUENTACREDITORETE, :CUENTADEBITODESCUENTO, :CUENTADEBITOICA, :CUENTACREDITOICA, :CUENTADEBITOUTILIDAD, :CUENTACREDITOUTILIDAD, :CUENTADEBITOBASE_AV, :CUENTACREDITOBASE_AV, :CUENTADEBITOIVA_AV, :CUENTACREDITOIVA_AV, :CUENTADEBITORETE_AV, :CUENTACREDITORETE_AV, :CUENTADEBITODESCUENTO_AV, :CUENTACREDITODESCUENTO_AV, :CUENTADEBITOICA_AV, :CUENTACREDITOICA_AV, :CUENTADEBITOUTILIDAD_AV, :CUENTACREDITOUTILIDAD_AV, :AUXILIAR, :CENTRO_COSTO, :MANEJA_RANGOTIEMPO, :PORCETAJE_UTILIDAD, :EXISTENCIA, :CUENTA_RECAUDO, :DIGITOS_REDONDEO, :ESTADO, :CLASE_CONCEPTO, :CTADEBACOMETIDA, :CTACREDACOMETIDA, :CTADEBACOMETIDA_AV, :CTACREDACOMETIDA_AV, :CTADEBAIU, :CTACREDAIU, :CTADEBAIU_AV, :CTACREDAIU_AV, :CTADEBADMONIMP, :CTACREDADMONIMP, :CTADEBADMONIMP_AV, :CTACREDADMONIMP_AV, :CTADEBUTILIDADAIU, :CTACREDUTILIDADAIU, :CTADEBUTILIDADAIU_AV, :CTACREDUTILIDADAIU_AV, :CTADEBIVAUTILIDAD, :CTACREDIVAUTILIDAD, :CTADEBIVAUTILIDAD_AV, :CTACREDIVAUTILIDAD_AV, :FORMULAR_ACOMETIDA, :FORMULAR_AIU, :FORMULAR_ADMONIMP, :FORMULAR_UTILIDADAIU, :FORMULAR_IVAUTILIDAD, :AGRUPAR_COMO, :CTAORDENDEUDORA_DEBITO, :CTAORDENDEUDORA_CREDITO, :CANTIDAD_PORDEFECTO, :UNICO_BASEGRAVABLE, :FILTROREGIMEN, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_COMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_BASE" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="APLICAIVA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJEIVA" sqlType="STRING"/>
		<param defaultValue="0" name="APLICARETEFUENTE" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJERETEFUENTE" sqlType="STRING"/>
		<param defaultValue="0" name="APLICADESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJEDESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="APLICAICA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJEICA" sqlType="STRING"/>
