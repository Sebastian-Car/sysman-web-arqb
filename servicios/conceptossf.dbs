	<query id="deleteConceptossf" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONCEPTOS_SF WHERE CONCEPTOS_SF.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_SF.ANO= :KEY_ANO AND CONCEPTOS_SF.TIPOCOBRO= :KEY_TIPOCOBRO AND CONCEPTOS_SF.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="conceptossf">
		<call-query href="deleteConceptossf">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getConceptossfPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS_SF.COMPANIA, CONCEPTOS_SF.ANO, CONCEPTOS_SF.TIPOCOBRO, CONCEPTOS_SF.CODIGO, TIPO_COBRO_SF.NOMBRE NOMBRETIPOCOBRO, CONCEPTOS_SF.NOMBRE  FROM CONCEPTOS_SF INNER JOIN TIPO_COBRO_SF ON CONCEPTOS_SF.COMPANIA = TIPO_COBRO_SF.COMPANIA AND CONCEPTOS_SF.TIPOCOBRO = TIPO_COBRO_SF.CODIGO AND CONCEPTOS_SF.ANO = TIPO_COBRO_SF.ANO WHERE CONCEPTOS_SF.COMPANIA = :COMPANIA AND CONCEPTOS_SF.ANO = :ANOCONCEPTO AND CONCEPTOS_SF.TIPOCOBRO = :TIPOCOBRO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPOCOBRO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO) END)  LIKE UPPER( '%' || :TIPOCOBRO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRETIPOCOBRO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOCOBRO) END)  LIKE UPPER( '%' || :NOMBRETIPOCOBRO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CODIGO":"$CODIGO","NOMBRETIPOCOBRO":"$NOMBRETIPOCOBRO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOCONCEPTO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRETIPOCOBRO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptossf">
		<call-query href="getConceptossfPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOCONCEPTO" query-param="ANOCONCEPTO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRETIPOCOBRO" query-param="NOMBRETIPOCOBRO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptossfNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONCEPTOS_SF.COMPANIA, CONCEPTOS_SF.ANO, CONCEPTOS_SF.TIPOCOBRO, CONCEPTOS_SF.CODIGO, TIPO_COBRO_SF.NOMBRE NOMBRETIPOCOBRO, CONCEPTOS_SF.NOMBRE  FROM CONCEPTOS_SF INNER JOIN TIPO_COBRO_SF ON CONCEPTOS_SF.COMPANIA = TIPO_COBRO_SF.COMPANIA AND CONCEPTOS_SF.TIPOCOBRO = TIPO_COBRO_SF.CODIGO AND CONCEPTOS_SF.ANO = TIPO_COBRO_SF.ANO WHERE CONCEPTOS_SF.COMPANIA = :COMPANIA AND CONCEPTOS_SF.ANO = :ANOCONCEPTO AND CONCEPTOS_SF.TIPOCOBRO = :TIPOCOBRO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPOCOBRO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO) END)  LIKE UPPER( '%' || :TIPOCOBRO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRETIPOCOBRO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOCOBRO) END)  LIKE UPPER( '%' || :NOMBRETIPOCOBRO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOCONCEPTO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRETIPOCOBRO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptossf/numero">
		<call-query href="getConceptossfNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOCONCEPTO" query-param="ANOCONCEPTO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
