<data name="llavesprimariasiris" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getCamposLlave"  useConfig="sysmanirisst">
		<sql>SELECT LISTAGG(UCC.COLUMN_NAME ,',') WITHIN GROUP (ORDER BY POSITION) LLAVE FROM USER_CONSTRAINTS UC INNER JOIN USER_CONS_COLUMNS UCC  ON(UC.CONSTRAINT_NAME=UCC.CONSTRAINT_NAME) WHERE CONSTRAINT_TYPE='P' AND UC.TABLE_NAME=:TABLA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LLAVE":"$LLAVE"}]}}		</result>
		<param name="TABLA" sqlType="STRING"/>
	</query>
	<resource method="GET" path="llavesprimarias/portabla">
		<call-query href="getCamposLlave">
			<with-param name="TABLA" query-param="TABLA"/>
		</call-query>
	</resource>

</data>