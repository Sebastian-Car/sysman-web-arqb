	<query id="getRetencionesPagTodosPorIcaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  RETENCIONES.CODIGO, RETENCIONES.NOMBRE, RETENCIONES.TIPO, TIPORETENCION.NOMBRE TIPONOMBRE  FROM RETENCIONES INNER JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO WHERE RETENCIONES.COMPANIA = :COMPANIA AND RETENCIONES.ANO = :ANO AND RETENCIONES.TIPO IN ('ICA') ORDER BY RETENCIONES.TIPO, RETENCIONES.NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN TIPONOMBRE IS NULL THEN ' ' ELSE UPPER(TIPONOMBRE) END)  LIKE UPPER( '%' || :TIPONOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO":"$TIPO","TIPONOMBRE":"$TIPONOMBRE"}]}}		</result>
