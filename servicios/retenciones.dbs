	<query id="getRetencionesPorcentajeaplicarQuery"  useConfig="sysmandsunist">
		<sql>SELECT PCT_APLICAR, PCT_BASE, FACTORREDONDEO FROM RETENCIONES WHERE ANO = :ANO AND CUENTA_CREDITO = :CUENTA GROUP BY PCT_APLICAR,PCT_BASE, FACTORREDONDEO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PCT_APLICAR":"$PCT_APLICAR","PCT_BASE":"$PCT_BASE","FACTORREDONDEO":"$FACTORREDONDEO(type:integer)"}]}}		</result>
