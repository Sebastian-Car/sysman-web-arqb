<data name="evclaseevaluacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEvclaseevaluacionCodigoynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM EV_CLASE_EVALUACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="evclaseevaluacion/codigoynombre">
		<call-query href="getEvclaseevaluacionCodigoynombreQuery">
 
		</call-query>
	</resource>
	<query id="getEvclaseevaluacionClaseevaluacionporcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE  FROM EV_CLASE_EVALUACION WHERE CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evclaseevaluacion/claseevaluacionporcodigo">
		<call-query href="getEvclaseevaluacionClaseevaluacionporcodigoQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>

</data>