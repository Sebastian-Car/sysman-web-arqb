<data name="indicadores" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIndicadoresJerarquiasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT (1) PADRE  FROM IG_INDICADORES_BASICOS WHERE CODIGO NOT IN(:CODIGO) AND ((CODIGO BETWEEN SUBSTR(:CODIGO, 1,1) AND :CODIGO AND CODIGO = SUBSTR(:CODIGO,1,LENGTH(CODIGO)) ) OR ( CODIGO BETWEEN SUBSTR(:CODIGO, 1,1) AND :CODIGO AND :CODIGO = SUBSTR(CODIGO,1,LENGTH(:CODIGO)) )) AND MOVIMIENTO NOT IN 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PADRE":"$PADRE(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="indicadores/jerarquias">
		<call-query href="getIndicadoresJerarquiasQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertIndicadores" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IG_INDICADORES_BASICOS (COMPANIA, CODIGO, DESCRIPCION, MOVIMIENTO, PERIODICIDAD, FECHA_ACTUALIZACION, TIPO, CONSULTA_SQL, HORAS, DIAS, MINUTOS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :DESCRIPCION, :MOVIMIENTO, :PERIODICIDAD, TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), :TIPO, :CONSULTA_SQL, :HORAS, :DIAS, :MINUTOS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PERIODICIDAD" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="EMPTY_CLOB()" name="CONSULTA_SQL" sqlType="STRING"/>
		<param defaultValue="0" name="HORAS" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="0" name="MINUTOS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="indicadores">
		<call-query href="insertIndicadores">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONSULTA_SQL" query-param="CONSULTA_SQL"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteIndicadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IG_INDICADORES_BASICOS WHERE IG_INDICADORES_BASICOS.COMPANIA= :KEY_COMPANIA AND IG_INDICADORES_BASICOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="indicadores">
		<call-query href="deleteIndicadores">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getIndicadoresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IG_INDICADORES_BASICOS.COMPANIA, IG_INDICADORES_BASICOS.CODIGO, IG_INDICADORES_BASICOS.DESCRIPCION,(CASE IG_INDICADORES_BASICOS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, IG_INDICADORES_BASICOS.PERIODICIDAD,(TO_CHAR(IG_INDICADORES_BASICOS.FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, IG_INDICADORES_BASICOS.TIPO, TO_CHAR(IG_INDICADORES_BASICOS.CONSULTA_SQL) CONSULTA_SQL, IG_INDICADORES_BASICOS.HORAS, IG_INDICADORES_BASICOS.DIAS, IG_INDICADORES_BASICOS.MINUTOS  FROM IG_INDICADORES_BASICOS ORDER BY IG_INDICADORES_BASICOS.CODIGO ASC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN PERIODICIDAD IS NULL THEN ' ' ELSE UPPER(PERIODICIDAD) END)  LIKE UPPER(:PERIODICIDAD || '%')  AND (CASE WHEN FECHA_ACTUALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_ACTUALIZACION) END)  LIKE UPPER(:FECHA_ACTUALIZACION || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN CONSULTA_SQL IS NULL THEN ' ' ELSE UPPER(CONSULTA_SQL) END)  LIKE UPPER(:CONSULTA_SQL || '%')  AND (CASE WHEN HORAS IS NULL THEN ' ' ELSE UPPER(HORAS) END)  LIKE UPPER(:HORAS || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN MINUTOS IS NULL THEN ' ' ELSE UPPER(MINUTOS) END)  LIKE UPPER(:MINUTOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","PERIODICIDAD":"$PERIODICIDAD","FECHA_ACTUALIZACION":"$FECHA_ACTUALIZACION","TIPO":"$TIPO","CONSULTA_SQL":"$CONSULTA_SQL","HORAS":"$HORAS(type:integer)","DIAS":"$DIAS(type:integer)","MINUTOS":"$MINUTOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PERIODICIDAD" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CONSULTA_SQL" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="MINUTOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="indicadores">
		<call-query href="getIndicadoresPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONSULTA_SQL" query-param="CONSULTA_SQL"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIndicadoresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IG_INDICADORES_BASICOS.COMPANIA, IG_INDICADORES_BASICOS.CODIGO, IG_INDICADORES_BASICOS.DESCRIPCION,(CASE IG_INDICADORES_BASICOS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, IG_INDICADORES_BASICOS.PERIODICIDAD,(TO_CHAR(IG_INDICADORES_BASICOS.FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, IG_INDICADORES_BASICOS.TIPO, TO_CHAR(IG_INDICADORES_BASICOS.CONSULTA_SQL) CONSULTA_SQL, IG_INDICADORES_BASICOS.HORAS, IG_INDICADORES_BASICOS.DIAS, IG_INDICADORES_BASICOS.MINUTOS  FROM IG_INDICADORES_BASICOS ORDER BY IG_INDICADORES_BASICOS.CODIGO ASC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN PERIODICIDAD IS NULL THEN ' ' ELSE UPPER(PERIODICIDAD) END)  LIKE UPPER(:PERIODICIDAD || '%')  AND (CASE WHEN FECHA_ACTUALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_ACTUALIZACION) END)  LIKE UPPER(:FECHA_ACTUALIZACION || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN CONSULTA_SQL IS NULL THEN ' ' ELSE UPPER(CONSULTA_SQL) END)  LIKE UPPER(:CONSULTA_SQL || '%')  AND (CASE WHEN HORAS IS NULL THEN ' ' ELSE UPPER(HORAS) END)  LIKE UPPER(:HORAS || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN MINUTOS IS NULL THEN ' ' ELSE UPPER(MINUTOS) END)  LIKE UPPER(:MINUTOS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PERIODICIDAD" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CONSULTA_SQL" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="MINUTOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="indicadores/numero">
		<call-query href="getIndicadoresNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONSULTA_SQL" query-param="CONSULTA_SQL"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>

		</call-query>
	</resource>
	<query id="getIndicadoresRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IG_INDICADORES_BASICOS.COMPANIA, IG_INDICADORES_BASICOS.CODIGO, IG_INDICADORES_BASICOS.DESCRIPCION,(CASE IG_INDICADORES_BASICOS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, IG_INDICADORES_BASICOS.PERIODICIDAD,(TO_CHAR(IG_INDICADORES_BASICOS.FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, IG_INDICADORES_BASICOS.TIPO, IG_INDICADORES_BASICOS.CONSULTA_SQL, IG_INDICADORES_BASICOS.HORAS, IG_INDICADORES_BASICOS.DIAS, IG_INDICADORES_BASICOS.MINUTOS  FROM IG_INDICADORES_BASICOS WHERE IG_INDICADORES_BASICOS.COMPANIA= :KEY_COMPANIA AND IG_INDICADORES_BASICOS.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","PERIODICIDAD":"$PERIODICIDAD","FECHA_ACTUALIZACION":"$FECHA_ACTUALIZACION","TIPO":"$TIPO","CONSULTA_SQL":"$CONSULTA_SQL","HORAS":"$HORAS(type:integer)","DIAS":"$DIAS(type:integer)","MINUTOS":"$MINUTOS(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="indicadores/data">
		<call-query href="getIndicadoresRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateIndicadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IG_INDICADORES_BASICOS SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, DESCRIPCION=:DESCRIPCION, MOVIMIENTO=:MOVIMIENTO, PERIODICIDAD=:PERIODICIDAD, FECHA_ACTUALIZACION=TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), TIPO=:TIPO, CONSULTA_SQL=:CONSULTA_SQL, HORAS=:HORAS, DIAS=:DIAS, MINUTOS=:MINUTOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IG_INDICADORES_BASICOS.COMPANIA= :KEY_COMPANIA AND IG_INDICADORES_BASICOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PERIODICIDAD" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CONSULTA_SQL" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="MINUTOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="indicadores">
		<call-query href="updateIndicadores">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONSULTA_SQL" query-param="CONSULTA_SQL"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>