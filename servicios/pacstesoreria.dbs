<data name="pacstesoreria" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPacstesoreriaConteoPorAnoTipomovNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT('X') CONTEO  FROM PACTESORERIA WHERE COMPANIA = :COMPANIA AND ANO = + ano AND TIPO = :TIPOMOVIMIENTO AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pacstesoreria/conteoporanotipomovnumero">
		<call-query href="getPacstesoreriaConteoPorAnoTipomovNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="insertPacstesoreria" keyColumns="COMPANIA,ANO,TIPO,NUMERO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PACTESORERIA (COMPANIA, ANO, TIPO, NUMERO, CONSECUTIVO, CUENTA, FECHA, VALOR_DEBITO, VALOR_CREDITO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO, :NUMERO, :CONSECUTIVO, :CUENTA, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :VALOR_DEBITO, :VALOR_CREDITO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_DEBITO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="pacstesoreria">
		<call-query href="insertPacstesoreria">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALOR_DEBITO" query-param="VALOR_DEBITO"/>
			<with-param name="VALOR_CREDITO" query-param="VALOR_CREDITO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePacstesoreria" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PACTESORERIA WHERE PACTESORERIA.COMPANIA= :KEY_COMPANIA AND PACTESORERIA.ANO= :KEY_ANO AND PACTESORERIA.TIPO= :KEY_TIPO AND PACTESORERIA.NUMERO= :KEY_NUMERO AND PACTESORERIA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="pacstesoreria">
		<call-query href="deletePacstesoreria">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getPacstesoreriaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PACTESORERIA.COMPANIA,PACTESORERIA.ANO,PACTESORERIA.TIPO,PACTESORERIA.NUMERO,PACTESORERIA.CONSECUTIVO,PACTESORERIA.CUENTA,(TO_CHAR(PACTESORERIA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,PACTESORERIA.VALOR_DEBITO,PACTESORERIA.VALOR_CREDITO,(VALOR_DEBITO - VALOR_CREDITO) SALDONETO  FROM PACTESORERIA LEFT JOIN PLAN_PRESUPUESTAL ON PACTESORERIA.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PACTESORERIA.ANO = PLAN_PRESUPUESTAL.ANO AND PACTESORERIA.CUENTA = PLAN_PRESUPUESTAL.CODIGO WHERE PACTESORERIA.COMPANIA = :COMPANIA AND PACTESORERIA.ANO = :ANO AND PACTESORERIA.TIPO = :TIPO_CPTE AND PACTESORERIA.NUMERO = :NUMERO ORDER BY PACTESORERIA.NUMERO) WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END)  LIKE UPPER(:CUENTA || '%')  AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END)  LIKE UPPER(:VALOR_DEBITO || '%')  AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END)  LIKE UPPER(:VALOR_CREDITO || '%')  AND (CASE WHEN SALDONETO IS NULL THEN ' ' ELSE UPPER(SALDONETO) END)  LIKE UPPER(:SALDONETO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","FECHA":"$FECHA","VALOR_DEBITO":"$VALOR_DEBITO(type:double)","VALOR_CREDITO":"$VALOR_CREDITO(type:double)","SALDONETO":"$SALDONETO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="SALDONETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="pacstesoreria">
		<call-query href="getPacstesoreriaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="VALOR_DEBITO" query-param="VALOR_DEBITO"/>
			<with-param name="VALOR_CREDITO" query-param="VALOR_CREDITO"/>
			<with-param name="SALDONETO" query-param="SALDONETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPacstesoreriaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PACTESORERIA.COMPANIA,PACTESORERIA.ANO,PACTESORERIA.TIPO,PACTESORERIA.NUMERO,PACTESORERIA.CONSECUTIVO,PACTESORERIA.CUENTA,(TO_CHAR(PACTESORERIA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,PACTESORERIA.VALOR_DEBITO,PACTESORERIA.VALOR_CREDITO,(VALOR_DEBITO - VALOR_CREDITO) SALDONETO  FROM PACTESORERIA LEFT JOIN PLAN_PRESUPUESTAL ON PACTESORERIA.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PACTESORERIA.ANO = PLAN_PRESUPUESTAL.ANO AND PACTESORERIA.CUENTA = PLAN_PRESUPUESTAL.CODIGO WHERE PACTESORERIA.COMPANIA = :COMPANIA AND PACTESORERIA.ANO = :ANO AND PACTESORERIA.TIPO = :TIPO_CPTE AND PACTESORERIA.NUMERO = :NUMERO ORDER BY PACTESORERIA.NUMERO) WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END)  LIKE UPPER(:CUENTA || '%')  AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END)  LIKE UPPER( '%' || :VALOR_DEBITO || '%')  AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END)  LIKE UPPER( '%' || :VALOR_CREDITO || '%')  AND (CASE WHEN SALDONETO IS NULL THEN ' ' ELSE UPPER(SALDONETO) END)  LIKE UPPER( '%' || :SALDONETO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="SALDONETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pacstesoreria/numero">
		<call-query href="getPacstesoreriaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="VALOR_DEBITO" query-param="VALOR_DEBITO"/>
			<with-param name="VALOR_CREDITO" query-param="VALOR_CREDITO"/>
			<with-param name="SALDONETO" query-param="SALDONETO"/>

		</call-query>
	</resource>
	<query id="updatePacstesoreria" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PACTESORERIA SET CONSECUTIVO=:CONSECUTIVO, CUENTA=:CUENTA, VALOR_DEBITO=:VALOR_DEBITO, VALOR_CREDITO=:VALOR_CREDITO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PACTESORERIA.COMPANIA= :KEY_COMPANIA AND PACTESORERIA.ANO= :KEY_ANO AND PACTESORERIA.TIPO= :KEY_TIPO AND PACTESORERIA.NUMERO= :KEY_NUMERO AND PACTESORERIA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="pacstesoreria">
		<call-query href="updatePacstesoreria">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="VALOR_DEBITO" query-param="VALOR_DEBITO"/>
			<with-param name="VALOR_CREDITO" query-param="VALOR_CREDITO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>