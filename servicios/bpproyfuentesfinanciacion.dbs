<data name="bpproyfuentesfinanciacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBpproyfuentesfinanciacion" keyColumns="COMPANIA,PROYECTO,CODIGOFUENTE,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_PROYFUENTESFINANCIACION (COMPANIA, PROYECTO, CODIGOFUENTE, CODIGOSUBFUENTE, VALOR, PANTALLA, CONSECUTIVO, VIGENCIAFUENTE, CODIGOCOMPONENTE, TIPOCOMPONENTE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :PROYECTO, :CODIGOFUENTE, :CODIGOSUBFUENTE, :VALOR, :PANTALLA, :CONSECUTIVO, :VIGENCIAFUENTE, :CODIGOCOMPONENTE, :TIPOCOMPONENTE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROYECTO":"$PROYECTO","KEY_CODIGOFUENTE":"$CODIGOFUENTE","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CODIGOFUENTE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOSUBFUENTE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="PANTALLA" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIAFUENTE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCOMPONENTE" sqlType="STRING"/>
		<param defaultValue="" name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpproyfuentesfinanciacion">
		<call-query href="insertBpproyfuentesfinanciacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CODIGOFUENTE" query-param="CODIGOFUENTE"/>
			<with-param name="CODIGOSUBFUENTE" query-param="CODIGOSUBFUENTE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PANTALLA" query-param="PANTALLA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="VIGENCIAFUENTE" query-param="VIGENCIAFUENTE"/>
			<with-param name="CODIGOCOMPONENTE" query-param="CODIGOCOMPONENTE"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpproyfuentesfinanciacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_PROYFUENTESFINANCIACION WHERE BP_PROYFUENTESFINANCIACION.COMPANIA= :KEY_COMPANIA AND BP_PROYFUENTESFINANCIACION.PROYECTO= :KEY_PROYECTO AND BP_PROYFUENTESFINANCIACION.CODIGOFUENTE= :KEY_CODIGOFUENTE AND BP_PROYFUENTESFINANCIACION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_CODIGOFUENTE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="bpproyfuentesfinanciacion">
		<call-query href="deleteBpproyfuentesfinanciacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_CODIGOFUENTE" query-param="KEY_CODIGOFUENTE"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getBpproyfuentesfinanciacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PF.COMPANIA, PF.PROYECTO, PF.CODIGOFUENTE, CONCAT(PF.CODIGOFUENTE,CONCAT(' - ',NVL(FF.NOMBRE,' ') ) ) NOMBREFUENTE, PF.CODIGOSUBFUENTE, PF.VALOR, PF.PANTALLA, PF.CONSECUTIVO, PF.VIGENCIAFUENTE, PF.CODIGOCOMPONENTE, PF.TIPOCOMPONENTE FROM BP_PROYFUENTESFINANCIACION PF INNER JOIN FUENTESFINANCIACION FF ON PF.COMPANIA = FF.COMPANIA AND PF.CODIGOFUENTE = FF.CODIGOFUENTE WHERE PF.COMPANIA =:COMPANIA AND PF.PROYECTO =:PROYECTO ORDER BY PF.CODIGOFUENTE, PF.CONSECUTIVO) INI WHERE (CASE WHEN NOMBREFUENTE IS NULL THEN ' ' ELSE UPPER(NOMBREFUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFUENTE), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN VIGENCIAFUENTE IS NULL THEN ' ' ELSE UPPER(VIGENCIAFUENTE) END) LIKE UPPER(CONCAT(:VIGENCIAFUENTE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROYECTO":"$PROYECTO","CODIGOFUENTE":"$CODIGOFUENTE","NOMBREFUENTE":"$NOMBREFUENTE","CODIGOSUBFUENTE":"$CODIGOSUBFUENTE","VALOR":"$VALOR","PANTALLA":"$PANTALLA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","VIGENCIAFUENTE":"$VIGENCIAFUENTE(type:integer)","CODIGOCOMPONENTE":"$CODIGOCOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOMBREFUENTE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="VIGENCIAFUENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpproyfuentesfinanciacion">
		<call-query href="getBpproyfuentesfinanciacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="NOMBREFUENTE" query-param="NOMBREFUENTE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="VIGENCIAFUENTE" query-param="VIGENCIAFUENTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpproyfuentesfinanciacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PF.COMPANIA, PF.PROYECTO, PF.CODIGOFUENTE, CONCAT(PF.CODIGOFUENTE,CONCAT(' - ',NVL(FF.NOMBRE,' ') ) ) NOMBREFUENTE, PF.CODIGOSUBFUENTE, PF.VALOR, PF.PANTALLA, PF.CONSECUTIVO, PF.VIGENCIAFUENTE, PF.CODIGOCOMPONENTE, PF.TIPOCOMPONENTE FROM BP_PROYFUENTESFINANCIACION PF INNER JOIN FUENTESFINANCIACION FF ON PF.COMPANIA = FF.COMPANIA AND PF.CODIGOFUENTE = FF.CODIGOFUENTE WHERE PF.COMPANIA =:COMPANIA AND PF.PROYECTO =:PROYECTO ORDER BY PF.CODIGOFUENTE, PF.CONSECUTIVO) INI WHERE (CASE WHEN NOMBREFUENTE IS NULL THEN ' ' ELSE UPPER(NOMBREFUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFUENTE), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN VIGENCIAFUENTE IS NULL THEN ' ' ELSE UPPER(VIGENCIAFUENTE) END) LIKE UPPER(CONCAT(:VIGENCIAFUENTE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOMBREFUENTE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="VIGENCIAFUENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyfuentesfinanciacion/numero">
		<call-query href="getBpproyfuentesfinanciacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="NOMBREFUENTE" query-param="NOMBREFUENTE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="VIGENCIAFUENTE" query-param="VIGENCIAFUENTE"/>

		</call-query>
	</resource>
	<query id="updateBpproyfuentesfinanciacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PROYFUENTESFINANCIACION SET VALOR=:VALOR, CONSECUTIVO=:CONSECUTIVO, VIGENCIAFUENTE=:VIGENCIAFUENTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_PROYFUENTESFINANCIACION.COMPANIA= :KEY_COMPANIA AND BP_PROYFUENTESFINANCIACION.PROYECTO= :KEY_PROYECTO AND BP_PROYFUENTESFINANCIACION.CODIGOFUENTE= :KEY_CODIGOFUENTE AND BP_PROYFUENTESFINANCIACION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="VIGENCIAFUENTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_CODIGOFUENTE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpproyfuentesfinanciacion">
		<call-query href="updateBpproyfuentesfinanciacion">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="VIGENCIAFUENTE" query-param="VIGENCIAFUENTE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_CODIGOFUENTE" query-param="KEY_CODIGOFUENTE"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>