	<query id="deleteSifascodigoscum" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SIFAS_CODIGOS_CUMS WHERE SIFAS_CODIGOS_CUMS.EXPEDIENTE= :KEY_EXPEDIENTE AND SIFAS_CODIGOS_CUMS.CONSECUTIVOCUM= :KEY_CONSECUTIVOCUM AND SIFAS_CODIGOS_CUMS.NOMBREROL= :KEY_NOMBREROL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_EXPEDIENTE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVOCUM" sqlType="INTEGER"/>
		<param name="KEY_NOMBREROL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sifascodigoscum">
		<call-query href="deleteSifascodigoscum">
			<with-param name="KEY_EXPEDIENTE" query-param="KEY_EXPEDIENTE"/>
			<with-param name="KEY_CONSECUTIVOCUM" query-param="KEY_CONSECUTIVOCUM"/>
			<with-param name="KEY_NOMBREROL" query-param="KEY_NOMBREROL"/>

		</call-query>
	</resource>
	<query id="getSifascodigoscumPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CUMS.EXPEDIENTE, CUMS.PRODUCTO, CUMS.CONSECUTIVOCUM, CUMS.DESCRIPCIONCOMERCIAL, CUMS.CANTIDADCUM, CUMS_FABR.TITULAR, FABR.NOMBRE_ROL FROM SIFAS_CUMS_FABR CUMS_FABR INNER JOIN SIFAS_CODIGOS_CUMS CUMS ON CUMS.EXPEDIENTE = CUMS_FABR.EXPEDIENTE AND CUMS.CONSECUTIVOCUM=CUMS_FABR.CONSECUTIVOCUM INNER JOIN SIFAS_FABRICANTES_CUMS FABR ON FABR.ID = CUMS_FABR.ID_FABR_CUMS ORDER BY CUMS.EXPEDIENTE, CUMS.CONSECUTIVOCUM) INI WHERE (CASE WHEN EXPEDIENTE IS NULL THEN ' ' ELSE UPPER(EXPEDIENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:EXPEDIENTE), '%')) AND (CASE WHEN PRODUCTO IS NULL THEN ' ' ELSE UPPER(PRODUCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:PRODUCTO), '%')) AND (CASE WHEN CONSECUTIVOCUM IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOCUM) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVOCUM), '%')) AND (CASE WHEN DESCRIPCIONCOMERCIAL IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONCOMERCIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCIONCOMERCIAL), '%')) AND (CASE WHEN CANTIDADCUM IS NULL THEN ' ' ELSE UPPER(CANTIDADCUM) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDADCUM), '%')) AND (CASE WHEN TITULAR IS NULL THEN ' ' ELSE UPPER(TITULAR) END) LIKE UPPER(CONCAT(CONCAT('%',:TITULAR), '%')) AND (CASE WHEN NOMBRE_ROL IS NULL THEN ' ' ELSE UPPER(NOMBRE_ROL) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ROL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXPEDIENTE":"$EXPEDIENTE(type:long)","PRODUCTO":"$PRODUCTO","CONSECUTIVOCUM":"$CONSECUTIVOCUM(type:integer)","DESCRIPCIONCOMERCIAL":"$DESCRIPCIONCOMERCIAL","CANTIDADCUM":"$CANTIDADCUM","TITULAR":"$TITULAR","NOMBRE_ROL":"$NOMBRE_ROL"}]}}		</result>
		<param name="EXPEDIENTE" sqlType="STRING"/>
		<param name="PRODUCTO" sqlType="STRING"/>
		<param name="CONSECUTIVOCUM" sqlType="STRING"/>
		<param name="DESCRIPCIONCOMERCIAL" sqlType="STRING"/>
		<param name="CANTIDADCUM" sqlType="STRING"/>
		<param name="TITULAR" sqlType="STRING"/>
		<param name="NOMBRE_ROL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sifascodigoscum">
		<call-query href="getSifascodigoscumPaginaQuery">
			<with-param name="EXPEDIENTE" query-param="EXPEDIENTE"/>
			<with-param name="PRODUCTO" query-param="PRODUCTO"/>
			<with-param name="CONSECUTIVOCUM" query-param="CONSECUTIVOCUM"/>
			<with-param name="DESCRIPCIONCOMERCIAL" query-param="DESCRIPCIONCOMERCIAL"/>
			<with-param name="CANTIDADCUM" query-param="CANTIDADCUM"/>
			<with-param name="TITULAR" query-param="TITULAR"/>
			<with-param name="NOMBRE_ROL" query-param="NOMBRE_ROL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSifascodigoscumNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CUMS.EXPEDIENTE, CUMS.PRODUCTO, CUMS.CONSECUTIVOCUM, CUMS.DESCRIPCIONCOMERCIAL, CUMS.CANTIDADCUM, CUMS_FABR.TITULAR, FABR.NOMBRE_ROL FROM SIFAS_CUMS_FABR CUMS_FABR INNER JOIN SIFAS_CODIGOS_CUMS CUMS ON CUMS.EXPEDIENTE = CUMS_FABR.EXPEDIENTE AND CUMS.CONSECUTIVOCUM=CUMS_FABR.CONSECUTIVOCUM INNER JOIN SIFAS_FABRICANTES_CUMS FABR ON FABR.ID = CUMS_FABR.ID_FABR_CUMS ORDER BY CUMS.EXPEDIENTE, CUMS.CONSECUTIVOCUM) INI WHERE (CASE WHEN EXPEDIENTE IS NULL THEN ' ' ELSE UPPER(EXPEDIENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:EXPEDIENTE), '%')) AND (CASE WHEN PRODUCTO IS NULL THEN ' ' ELSE UPPER(PRODUCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:PRODUCTO), '%')) AND (CASE WHEN CONSECUTIVOCUM IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOCUM) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVOCUM), '%')) AND (CASE WHEN DESCRIPCIONCOMERCIAL IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONCOMERCIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCIONCOMERCIAL), '%')) AND (CASE WHEN CANTIDADCUM IS NULL THEN ' ' ELSE UPPER(CANTIDADCUM) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDADCUM), '%')) AND (CASE WHEN TITULAR IS NULL THEN ' ' ELSE UPPER(TITULAR) END) LIKE UPPER(CONCAT(CONCAT('%',:TITULAR), '%')) AND (CASE WHEN NOMBRE_ROL IS NULL THEN ' ' ELSE UPPER(NOMBRE_ROL) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ROL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="EXPEDIENTE" sqlType="STRING"/>
		<param name="PRODUCTO" sqlType="STRING"/>
		<param name="CONSECUTIVOCUM" sqlType="STRING"/>
		<param name="DESCRIPCIONCOMERCIAL" sqlType="STRING"/>
		<param name="CANTIDADCUM" sqlType="STRING"/>
		<param name="TITULAR" sqlType="STRING"/>
		<param name="NOMBRE_ROL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sifascodigoscum/numero">
		<call-query href="getSifascodigoscumNumeroQuery">
			<with-param name="EXPEDIENTE" query-param="EXPEDIENTE"/>
			<with-param name="PRODUCTO" query-param="PRODUCTO"/>
			<with-param name="CONSECUTIVOCUM" query-param="CONSECUTIVOCUM"/>
			<with-param name="DESCRIPCIONCOMERCIAL" query-param="DESCRIPCIONCOMERCIAL"/>
