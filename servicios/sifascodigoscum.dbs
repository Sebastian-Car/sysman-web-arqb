		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sifascodigoscum">
		<call-query href="insertSifascodigoscum">
