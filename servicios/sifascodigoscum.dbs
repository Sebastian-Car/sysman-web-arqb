		<param name="UNIDADREFERENCIA" sqlType="STRING"/>
		<param name="FORMAFARMACEUTICA" sqlType="STRING"/>
		<param name="NOMBREROL" sqlType="STRING"/>
		<param name="TIPOROL" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
