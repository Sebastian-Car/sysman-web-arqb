	<query id="updateSifascodigoscum" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SIFAS_CODIGOS_CUMS SET EXPEDIENTE=:EXPEDIENTE, PRODUCTO=:PRODUCTO, TITULAR=:TITULAR, REGISTROSANITARIO=:REGISTROSANITARIO, FECHAEXPEDICION=TO_DATE(:FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS'), FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), ESTADOREGISTRO=:ESTADOREGISTRO, EXPEDIENTECUM=:EXPEDIENTECUM, CONSECUTIVOCUM=:CONSECUTIVOCUM, CANTIDADCUM=:CANTIDADCUM, DESCRIPCIONCOMERCIAL=:DESCRIPCIONCOMERCIAL, ESTADOCUM=:ESTADOCUM, FECHAACTIVO=TO_DATE(:FECHAACTIVO,'DD/MM/YYYY HH24:MI:SS'), FECHAINACTIVO=TO_DATE(:FECHAINACTIVO,'DD/MM/YYYY HH24:MI:SS'), MUESTRAMEDICA=:MUESTRAMEDICA, UNIDAD=:UNIDAD, ATC=:ATC, DESCRIPCIONATC=:DESCRIPCIONATC, VIAADMINISTRACION=:VIAADMINISTRACION, CONCENTRACION=:CONCENTRACION, PRINCIPIOACTIVO=:PRINCIPIOACTIVO, UNIDADMEDIDA=:UNIDADMEDIDA, CANTIDAD=:CANTIDAD, UNIDADREFERENCIA=:UNIDADREFERENCIA, FORMAFARMACEUTICA=:FORMAFARMACEUTICA, NOMBREROL=:NOMBREROL, TIPOROL=:TIPOROL, MODALIDAD=:MODALIDAD, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SIFAS_CODIGOS_CUMS.EXPEDIENTE= :KEY_EXPEDIENTE AND SIFAS_CODIGOS_CUMS.CONSECUTIVOCUM= :KEY_CONSECUTIVOCUM AND SIFAS_CODIGOS_CUMS.NOMBREROL= :KEY_NOMBREROL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="EXPEDIENTE" sqlType="STRING"/>
		<param name="PRODUCTO" sqlType="STRING"/>
		<param name="TITULAR" sqlType="STRING"/>
		<param name="REGISTROSANITARIO" sqlType="STRING"/>
		<param name="FECHAEXPEDICION" sqlType="STRING"/>
