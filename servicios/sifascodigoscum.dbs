			<with-param name="TITULAR" query-param="TITULAR"/>
			<with-param name="NOMBRE_ROL" query-param="NOMBRE_ROL"/>

		</call-query>
	</resource>
	<query id="getSifascodigoscumRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SIFAS_CODIGOS_CUMS.EXPEDIENTE, SIFAS_CODIGOS_CUMS.PRODUCTO, SIFAS_CUMS_FABR.TITULAR, SIFAS_CODIGOS_CUMS.REGISTROSANITARIO,(TO_CHAR(SIFAS_CODIGOS_CUMS.FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAEXPEDICION,(TO_CHAR(SIFAS_CODIGOS_CUMS.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO, SIFAS_CODIGOS_CUMS.ESTADOREGISTRO, SIFAS_CODIGOS_CUMS.EXPEDIENTECUM, SIFAS_CODIGOS_CUMS.CONSECUTIVOCUM, SIFAS_CODIGOS_CUMS.CANTIDADCUM, SIFAS_CODIGOS_CUMS.DESCRIPCIONCOMERCIAL, SIFAS_CODIGOS_CUMS.ESTADOCUM,(TO_CHAR(SIFAS_CODIGOS_CUMS.FECHAACTIVO,'DD/MM/YYYY HH24:MI:SS')) FECHAACTIVO,(TO_CHAR(SIFAS_CODIGOS_CUMS.FECHAINACTIVO,'DD/MM/YYYY HH24:MI:SS')) FECHAINACTIVO, SIFAS_CODIGOS_CUMS.MUESTRAMEDICA, SIFAS_CODIGOS_CUMS.UNIDAD, SIFAS_CUMS_FABR.ATC, SIFAS_CUMS_FABR.DESCRIPCIONATC, SIFAS_CUMS_FABR.VIAADMINISTRACION, SIFAS_CODIGOS_CUMS.CONCENTRACION, SIFAS_CUMS_FABR.PRINCIPIOACTIVO, SIFAS_CUMS_FABR.UNIDADMEDIDA, SIFAS_CUMS_FABR.CANTIDAD, SIFAS_CUMS_FABR.UNIDADREFERENCIA, SIFAS_CODIGOS_CUMS.FORMAFARMACEUTICA, SIFAS_FABRICANTES_CUMS.NOMBRE_FABRICANTE NOMBREROL, SIFAS_FABRICANTES_CUMS.NOMBRE_ROL TIPOROL, SIFAS_CODIGOS_CUMS.MODALIDAD , SIFAS_CODIGOS_CUMS.CREATED_BY, SIFAS_CODIGOS_CUMS.MODIFIED_BY,(TO_CHAR(SIFAS_CODIGOS_CUMS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(SIFAS_CODIGOS_CUMS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SIFAS_CUMS_FABR INNER JOIN SIFAS_CODIGOS_CUMS ON SIFAS_CODIGOS_CUMS.EXPEDIENTE = SIFAS_CUMS_FABR.EXPEDIENTE AND SIFAS_CODIGOS_CUMS.CONSECUTIVOCUM=SIFAS_CUMS_FABR.CONSECUTIVOCUM INNER JOIN SIFAS_FABRICANTES_CUMS ON SIFAS_FABRICANTES_CUMS.ID = SIFAS_CUMS_FABR.ID_FABR_CUMS WHERE SIFAS_CODIGOS_CUMS.CONSECUTIVOCUM= :KEY_CONSECUTIVOCUM AND SIFAS_CODIGOS_CUMS.EXPEDIENTE= :KEY_EXPEDIENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXPEDIENTE":"$EXPEDIENTE(type:long)","PRODUCTO":"$PRODUCTO","TITULAR":"$TITULAR","REGISTROSANITARIO":"$REGISTROSANITARIO","FECHAEXPEDICION":"$FECHAEXPEDICION","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","ESTADOREGISTRO":"$ESTADOREGISTRO","EXPEDIENTECUM":"$EXPEDIENTECUM","CONSECUTIVOCUM":"$CONSECUTIVOCUM(type:integer)","CANTIDADCUM":"$CANTIDADCUM","DESCRIPCIONCOMERCIAL":"$DESCRIPCIONCOMERCIAL","ESTADOCUM":"$ESTADOCUM","FECHAACTIVO":"$FECHAACTIVO","FECHAINACTIVO":"$FECHAINACTIVO","MUESTRAMEDICA":"$MUESTRAMEDICA","UNIDAD":"$UNIDAD","ATC":"$ATC","DESCRIPCIONATC":"$DESCRIPCIONATC","VIAADMINISTRACION":"$VIAADMINISTRACION","CONCENTRACION":"$CONCENTRACION","PRINCIPIOACTIVO":"$PRINCIPIOACTIVO","UNIDADMEDIDA":"$UNIDADMEDIDA","CANTIDAD":"$CANTIDAD","UNIDADREFERENCIA":"$UNIDADREFERENCIA","FORMAFARMACEUTICA":"$FORMAFARMACEUTICA","NOMBREROL":"$NOMBREROL","TIPOROL":"$TIPOROL","MODALIDAD":"$MODALIDAD","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_CONSECUTIVOCUM" sqlType="STRING"/>
		<param name="KEY_EXPEDIENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sifascodigoscum/data">
