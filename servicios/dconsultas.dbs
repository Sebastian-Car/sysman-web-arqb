<data name="dconsultas" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getDconsultasCodigoDetallePorConsultaQuery"  useConfig="sysmanirisst">
		<sql>SELECT  D_CONSULTAS.CODIGO_DETALLE  FROM D_CONSULTAS WHERE D_CONSULTAS.COMPANIA = :COMPANIA AND D_CONSULTAS.CODIGO = :CODIGO_CONSULTA AND D_CONSULTAS.CODIGO_REPORTE = :CODIGO_REPORTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_DETALLE":"$CODIGO_DETALLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dconsultas/codigodetalleporconsulta">
		<call-query href="getDconsultasCodigoDetallePorConsultaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>

		</call-query>
	</resource>
	<query id="deleteDconsultasDetallesPorConsulta" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM D_CONSULTAS WHERE D_CONSULTAS.COMPANIA    = :COMPANIA AND D_CONSULTAS.CODIGO        = :CODIGO_CONSULTA AND D_CONSULTAS.CODIGO_REPORTE = :CODIGO_REPORTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dconsultas/detallesporconsulta">
		<call-query href="deleteDconsultasDetallesPorConsulta">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>

		</call-query>
	</resource>
	<query id="updateDconsultasSeleccionarTodos" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE D_CONSULTAS SET VISIBLE = (:VISIBLE),  ORDEN = CASE WHEN (:VISIBLE)=0 THEN 0 ELSE ROWNUM END, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND D_CONSULTAS.CODIGO_REPORTE = :CODIGO_REPORTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VISIBLE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dconsultas/seleccionartodos">
		<call-query href="updateDconsultasSeleccionarTodos">
			<with-param name="VISIBLE" query-param="VISIBLE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>

		</call-query>
	</resource>
	<query id="getDconsultasPagListaMultipleQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_CONSULTAS.COMPANIA, D_CONSULTAS.CODIGO_DETALLE, D_CONSULTAS.CODIGO, D_CONSULTAS.CAMPO, D_CONSULTAS.TIPO, D_CONSULTAS.ETIQUETA  FROM D_CONSULTAS WHERE D_CONSULTAS.COMPANIA = :COMPANIAINI AND D_CONSULTAS.CODIGO = :CODIGO_CONSULTA AND D_CONSULTAS.CODIGO_REPORTE = :CODIGO_REPORTE) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN CODIGO_DETALLE IS NULL THEN ' ' ELSE UPPER(CODIGO_DETALLE) END)  LIKE UPPER( '%' || :CODIGO_DETALLE || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN CAMPO IS NULL THEN ' ' ELSE UPPER(CAMPO) END)  LIKE UPPER( '%' || :CAMPO || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_DETALLE":"$CODIGO_DETALLE","CODIGO":"$CODIGO","CAMPO":"$CAMPO","TIPO":"$TIPO","ETIQUETA":"$ETIQUETA"}]}}		</result>
		<param name="COMPANIAINI" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_DETALLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CAMPO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dconsultas/listamultiple/pag">
		<call-query href="getDconsultasPagListaMultipleQuery">
			<with-param name="COMPANIAINI" query-param="COMPANIAINI"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_DETALLE" query-param="CODIGO_DETALLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CAMPO" query-param="CAMPO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDconsultasNumListaMultipleQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_CONSULTAS.COMPANIA, D_CONSULTAS.CODIGO_DETALLE, D_CONSULTAS.CODIGO, D_CONSULTAS.CAMPO, D_CONSULTAS.TIPO, D_CONSULTAS.ETIQUETA  FROM D_CONSULTAS WHERE D_CONSULTAS.COMPANIA = :COMPANIAINI AND D_CONSULTAS.CODIGO = :CODIGO_CONSULTA AND D_CONSULTAS.CODIGO_REPORTE = :CODIGO_REPORTE) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN CODIGO_DETALLE IS NULL THEN ' ' ELSE UPPER(CODIGO_DETALLE) END)  LIKE UPPER( '%' || :CODIGO_DETALLE || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN CAMPO IS NULL THEN ' ' ELSE UPPER(CAMPO) END)  LIKE UPPER( '%' || :CAMPO || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIAINI" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_DETALLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CAMPO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dconsultas/listamultiple/num">
		<call-query href="getDconsultasNumListaMultipleQuery">
			<with-param name="COMPANIAINI" query-param="COMPANIAINI"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_DETALLE" query-param="CODIGO_DETALLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CAMPO" query-param="CAMPO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>

		</call-query>
	</resource>
	<query id="getDconsultasDetallesOriginalConsultaQuery"  useConfig="sysmanirisst">
		<sql>SELECT  CAMPO, ETIQUETA, TIPO  FROM D_CONSULTAS WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND CODIGO_REPORTE IN ('0') ORDER BY TO_NUMBER(CODIGO_DETALLE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CAMPO":"$CAMPO","ETIQUETA":"$ETIQUETA","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dconsultas/detallesoriginalconsulta">
		<call-query href="getDconsultasDetallesOriginalConsultaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertDconsultas" keyColumns="COMPANIA,CODIGO_DETALLE,CODIGO,CODIGO_REPORTE" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO D_CONSULTAS (COMPANIA, CODIGO_DETALLE, CODIGO, CAMPO, TIPO, ETIQUETA, VISIBLE, ORDEN, CODIGO_REPORTE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_DETALLE, :CODIGO, :CAMPO, :TIPO, :ETIQUETA, :VISIBLE, :ORDEN, :CODIGO_REPORTE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_DETALLE":"$CODIGO_DETALLE","KEY_CODIGO":"$CODIGO","KEY_CODIGO_REPORTE":"$CODIGO_REPORTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_DETALLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CAMPO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param defaultValue="0" name="VISIBLE" sqlType="STRING"/>
		<param defaultValue="0" name="ORDEN" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dconsultas">
		<call-query href="insertDconsultas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_DETALLE" query-param="CODIGO_DETALLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CAMPO" query-param="CAMPO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="VISIBLE" query-param="VISIBLE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDconsultas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM D_CONSULTAS WHERE D_CONSULTAS.COMPANIA= :KEY_COMPANIA AND D_CONSULTAS.CODIGO_DETALLE= :KEY_CODIGO_DETALLE AND D_CONSULTAS.CODIGO= :KEY_CODIGO AND D_CONSULTAS.CODIGO_REPORTE= :KEY_CODIGO_REPORTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_DETALLE" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CODIGO_REPORTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dconsultas">
		<call-query href="deleteDconsultas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_DETALLE" query-param="KEY_CODIGO_DETALLE"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CODIGO_REPORTE" query-param="KEY_CODIGO_REPORTE"/>

		</call-query>
	</resource>
	<query id="getDconsultasPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_CONSULTAS.COMPANIA, D_CONSULTAS.CODIGO_DETALLE, D_CONSULTAS.CODIGO, D_CONSULTAS.CAMPO, D_CONSULTAS.TIPO, CASE WHEN D_CONSULTAS.TIPO IN ('D') THEN 'Date' ELSE CASE WHEN D_CONSULTAS.TIPO IN ('N') THEN 'Numeric' ELSE CASE WHEN D_CONSULTAS.TIPO IN ('S') THEN 'String' ELSE CASE WHEN D_CONSULTAS.TIPO IN ('C') THEN 'Clob' END END END END NOMBRE_TIPO, D_CONSULTAS.ETIQUETA,(CASE D_CONSULTAS.VISIBLE WHEN 0 THEN 'false' ELSE 'true' END) VISIBLE,D_CONSULTAS.ORDEN, D_CONSULTAS.CODIGO_REPORTE  FROM D_CONSULTAS WHERE D_CONSULTAS.COMPANIA = :COMPANIA AND D_CONSULTAS.CODIGO = :CODIGO_CONSULTA AND D_CONSULTAS.CODIGO_REPORTE = :CODIGO_REPORTE ORDER BY TO_NUMBER(CODIGO_DETALLE)) WHERE (CASE WHEN CAMPO IS NULL THEN ' ' ELSE UPPER(CAMPO) END)  LIKE UPPER( '%' || :CAMPO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN VISIBLE IS NULL THEN ' ' ELSE UPPER(VISIBLE) END)  LIKE UPPER( '%' || :VISIBLE || '%')  AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END)  LIKE UPPER( '%' || :ORDEN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_DETALLE":"$CODIGO_DETALLE","CODIGO":"$CODIGO","CAMPO":"$CAMPO","TIPO":"$TIPO","NOMBRE_TIPO":"$NOMBRE_TIPO","ETIQUETA":"$ETIQUETA","VISIBLE":"$VISIBLE(type:boolean)","ORDEN":"$ORDEN(type:long)","CODIGO_REPORTE":"$CODIGO_REPORTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="CAMPO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="VISIBLE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dconsultas">
		<call-query href="getDconsultasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="CAMPO" query-param="CAMPO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="VISIBLE" query-param="VISIBLE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDconsultasNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_CONSULTAS.COMPANIA, D_CONSULTAS.CODIGO_DETALLE, D_CONSULTAS.CODIGO, D_CONSULTAS.CAMPO, D_CONSULTAS.TIPO, CASE WHEN D_CONSULTAS.TIPO IN ('D') THEN 'Date' ELSE CASE WHEN D_CONSULTAS.TIPO IN ('N') THEN 'Numeric' ELSE CASE WHEN D_CONSULTAS.TIPO IN ('S') THEN 'String' ELSE CASE WHEN D_CONSULTAS.TIPO IN ('C') THEN 'Clob' END END END END NOMBRE_TIPO, D_CONSULTAS.ETIQUETA,(CASE D_CONSULTAS.VISIBLE WHEN 0 THEN 'false' ELSE 'true' END) VISIBLE,D_CONSULTAS.ORDEN, D_CONSULTAS.CODIGO_REPORTE  FROM D_CONSULTAS WHERE D_CONSULTAS.COMPANIA = :COMPANIA AND D_CONSULTAS.CODIGO = :CODIGO_CONSULTA AND D_CONSULTAS.CODIGO_REPORTE = :CODIGO_REPORTE ORDER BY TO_NUMBER(CODIGO_DETALLE)) WHERE (CASE WHEN CAMPO IS NULL THEN ' ' ELSE UPPER(CAMPO) END)  LIKE UPPER( '%' || :CAMPO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN VISIBLE IS NULL THEN ' ' ELSE UPPER(VISIBLE) END)  LIKE UPPER( '%' || :VISIBLE || '%')  AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END)  LIKE UPPER( '%' || :ORDEN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="CAMPO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="VISIBLE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dconsultas/numero">
		<call-query href="getDconsultasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="CAMPO" query-param="CAMPO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="VISIBLE" query-param="VISIBLE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>

		</call-query>
	</resource>
	<query id="updateDconsultas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE D_CONSULTAS SET CODIGO_DETALLE=:CODIGO_DETALLE, CODIGO=:CODIGO, CAMPO=:CAMPO, TIPO=:TIPO, ETIQUETA=:ETIQUETA, VISIBLE=:VISIBLE, ORDEN=:ORDEN, CODIGO_REPORTE=:CODIGO_REPORTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_CONSULTAS.COMPANIA= :KEY_COMPANIA AND D_CONSULTAS.CODIGO_DETALLE= :KEY_CODIGO_DETALLE AND D_CONSULTAS.CODIGO= :KEY_CODIGO AND D_CONSULTAS.CODIGO_REPORTE= :KEY_CODIGO_REPORTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO_DETALLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CAMPO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="VISIBLE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_DETALLE" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CODIGO_REPORTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dconsultas">
		<call-query href="updateDconsultas">
			<with-param name="CODIGO_DETALLE" query-param="CODIGO_DETALLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
