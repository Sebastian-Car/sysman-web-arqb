<data name="ipmodificacionespagos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpmodificacionespagosCantidadPorBancoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(MODIFICACION) MODIFICACION  FROM IP_MODIFICACIONES_PAGOS WHERE COMPANIA = :COMPANIA AND MODIFICACION = :MODIFICACION AND TIPO_MODIFICACION = :TIPO_MODIFICACION AND CODIGO = :CODIGO AND BANCO = :BANCO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MODIFICACION":"$MODIFICACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="TIPO_MODIFICACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipmodificacionespagos/cantidadporbanco">
		<call-query href="getIpmodificacionespagosCantidadPorBancoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODIFICACION" query-param="MODIFICACION"/>
			<with-param name="TIPO_MODIFICACION" query-param="TIPO_MODIFICACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="BANCO" query-param="BANCO"/>

		</call-query>
	</resource>
	<query id="getIpmodificacionespagosCantidadPorFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(MODIFICACION) MODIFICACION  FROM IP_MODIFICACIONES_PAGOS WHERE COMPANIA = :COMPANIA AND MODIFICACION = :MODIFICACION AND TIPO_MODIFICACION = :TIPO_MODIFICACION AND CODIGO = :CODIGO AND FECHA = TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MODIFICACION":"$MODIFICACION(type:integer)"}]}}		</result>
