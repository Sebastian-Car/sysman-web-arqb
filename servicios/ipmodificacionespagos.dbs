	</resource>
	<query id="insertIpmodificacionespagos" keyColumns="COMPANIA,MODIFICACION,TIPO_MODIFICACION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_MODIFICACIONES_PAGOS (COMPANIA, MODIFICACION, FECHA_MODIFICACION, TIPO_MODIFICACION, CODIGO, FACTURA, BANCO, FECHA, USUARIO_MODIFICACION, PAQUETE, VALOR, ANULAR_PAGO, ANULAR_RECIBO, ACTIVAR_RECIBO, OBSERVACIONES, ANT_BANCO, ANT_PAQUETE, ANT_VALOR, ANT_FECHA, NUMERO_ORDEN, REGISTRADO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :MODIFICACION, TO_DATE(:FECHA_MODIFICACION,'DD/MM/YYYY HH24:MI:SS'), :TIPO_MODIFICACION, :CODIGO, :FACTURA, :BANCO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :USUARIO_MODIFICACION, :PAQUETE, :VALOR, :ANULAR_PAGO, :ANULAR_RECIBO, :ACTIVAR_RECIBO, :OBSERVACIONES, :ANT_BANCO, :ANT_PAQUETE, :ANT_VALOR, TO_DATE(:ANT_FECHA,'DD/MM/YYYY HH24:MI:SS'), :NUMERO_ORDEN, :REGISTRADO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_MODIFICACION":"$MODIFICACION","KEY_TIPO_MODIFICACION":"$TIPO_MODIFICACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_MODIFICACION" sqlType="STRING"/>
		<param name="TIPO_MODIFICACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="FACTURA" sqlType="STRING"/>
		<param defaultValue="" name="BANCO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="USUARIO_MODIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="PAQUETE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="0" name="ANULAR_PAGO" sqlType="STRING"/>
		<param defaultValue="0" name="ANULAR_RECIBO" sqlType="STRING"/>
		<param defaultValue="0" name="ACTIVAR_RECIBO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="" name="ANT_BANCO" sqlType="STRING"/>
		<param defaultValue="" name="ANT_PAQUETE" sqlType="STRING"/>
		<param defaultValue="0" name="ANT_VALOR" sqlType="STRING"/>
		<param defaultValue="" name="ANT_FECHA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param defaultValue="0" name="REGISTRADO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ipmodificacionespagos">
		<call-query href="insertIpmodificacionespagos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODIFICACION" query-param="MODIFICACION"/>
			<with-param name="FECHA_MODIFICACION" query-param="FECHA_MODIFICACION"/>
			<with-param name="TIPO_MODIFICACION" query-param="TIPO_MODIFICACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="USUARIO_MODIFICACION" query-param="USUARIO_MODIFICACION"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ANULAR_PAGO" query-param="ANULAR_PAGO"/>
			<with-param name="ANULAR_RECIBO" query-param="ANULAR_RECIBO"/>
			<with-param name="ACTIVAR_RECIBO" query-param="ACTIVAR_RECIBO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="ANT_BANCO" query-param="ANT_BANCO"/>
			<with-param name="ANT_PAQUETE" query-param="ANT_PAQUETE"/>
			<with-param name="ANT_VALOR" query-param="ANT_VALOR"/>
			<with-param name="ANT_FECHA" query-param="ANT_FECHA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="REGISTRADO" query-param="REGISTRADO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteIpmodificacionespagos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_MODIFICACIONES_PAGOS WHERE IP_MODIFICACIONES_PAGOS.COMPANIA= :KEY_COMPANIA AND IP_MODIFICACIONES_PAGOS.MODIFICACION= :KEY_MODIFICACION AND IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION= :KEY_TIPO_MODIFICACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODIFICACION" sqlType="STRING"/>
		<param name="KEY_TIPO_MODIFICACION" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ipmodificacionespagos">
		<call-query href="deleteIpmodificacionespagos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MODIFICACION" query-param="KEY_MODIFICACION"/>
			<with-param name="KEY_TIPO_MODIFICACION" query-param="KEY_TIPO_MODIFICACION"/>

		</call-query>
	</resource>
	<query id="getIpmodificacionespagosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_MODIFICACIONES_PAGOS.COMPANIA, IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION,(CASE IP_MODIFICACIONES_PAGOS.REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO, IP_MODIFICACIONES_PAGOS.USUARIO_MODIFICACION, IP_MODIFICACIONES_PAGOS.MODIFICACION, TO_CHAR(CASE IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION WHEN '01' THEN 'Modificar Banco' WHEN '02' THEN 'Modificar Fecha De Pago' WHEN '03' THEN 'Modificar Paquete' WHEN '04' THEN 'Modificar Valor Pagado' WHEN '05' THEN 'Anular Recibo' WHEN '06' THEN 'Activar Recibo' END) TIPO_MODIFICACIONLB, IP_MODIFICACIONES_PAGOS.CODIGO, IP_MODIFICACIONES_PAGOS.FACTURA, BANCO.NOMBREBANCO, TO_CHAR(IP_MODIFICACIONES_PAGOS.FECHA, 'DD/MM/YYYY') FECHA  FROM IP_MODIFICACIONES_PAGOS LEFT JOIN IP_BANCOS BANCO ON IP_MODIFICACIONES_PAGOS.COMPANIA = BANCO.COMPANIA AND IP_MODIFICACIONES_PAGOS.BANCO = BANCO.CODIGOBANCO WHERE IP_MODIFICACIONES_PAGOS.COMPANIA = :COMPANIA ORDER BY IP_MODIFICACIONES_PAGOS.COMPANIA, TO_NUMBER(IP_MODIFICACIONES_PAGOS.MODIFICACION)) WHERE (CASE WHEN MODIFICACION IS NULL THEN ' ' ELSE UPPER(MODIFICACION) END)  LIKE UPPER( '%' || :MODIFICACION || '%')  AND (CASE WHEN TIPO_MODIFICACIONLB IS NULL THEN ' ' ELSE UPPER(TIPO_MODIFICACIONLB) END)  LIKE UPPER( '%' || :TIPO_MODIFICACIONLB || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FACTURA IS NULL THEN ' ' ELSE UPPER(FACTURA) END)  LIKE UPPER(:FACTURA || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_MODIFICACION":"$TIPO_MODIFICACION","REGISTRADO":"$REGISTRADO(type:boolean)","USUARIO_MODIFICACION":"$USUARIO_MODIFICACION","MODIFICACION":"$MODIFICACION","TIPO_MODIFICACIONLB":"$TIPO_MODIFICACIONLB","CODIGO":"$CODIGO","FACTURA":"$FACTURA","NOMBREBANCO":"$NOMBREBANCO","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="TIPO_MODIFICACIONLB" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipmodificacionespagos">
		<call-query href="getIpmodificacionespagosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODIFICACION" query-param="MODIFICACION"/>
			<with-param name="TIPO_MODIFICACIONLB" query-param="TIPO_MODIFICACIONLB"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpmodificacionespagosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_MODIFICACIONES_PAGOS.COMPANIA, IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION,(CASE IP_MODIFICACIONES_PAGOS.REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO, IP_MODIFICACIONES_PAGOS.USUARIO_MODIFICACION, IP_MODIFICACIONES_PAGOS.MODIFICACION, TO_CHAR(CASE IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION WHEN '01' THEN 'Modificar Banco' WHEN '02' THEN 'Modificar Fecha De Pago' WHEN '03' THEN 'Modificar Paquete' WHEN '04' THEN 'Modificar Valor Pagado' WHEN '05' THEN 'Anular Recibo' WHEN '06' THEN 'Activar Recibo' END) TIPO_MODIFICACIONLB, IP_MODIFICACIONES_PAGOS.CODIGO, IP_MODIFICACIONES_PAGOS.FACTURA, BANCO.NOMBREBANCO, TO_CHAR(IP_MODIFICACIONES_PAGOS.FECHA, 'DD/MM/YYYY') FECHA  FROM IP_MODIFICACIONES_PAGOS LEFT JOIN IP_BANCOS BANCO ON IP_MODIFICACIONES_PAGOS.COMPANIA = BANCO.COMPANIA AND IP_MODIFICACIONES_PAGOS.BANCO = BANCO.CODIGOBANCO WHERE IP_MODIFICACIONES_PAGOS.COMPANIA = :COMPANIA ORDER BY IP_MODIFICACIONES_PAGOS.COMPANIA, TO_NUMBER(IP_MODIFICACIONES_PAGOS.MODIFICACION)) WHERE (CASE WHEN MODIFICACION IS NULL THEN ' ' ELSE UPPER(MODIFICACION) END)  LIKE UPPER( '%' || :MODIFICACION || '%')  AND (CASE WHEN TIPO_MODIFICACIONLB IS NULL THEN ' ' ELSE UPPER(TIPO_MODIFICACIONLB) END)  LIKE UPPER( '%' || :TIPO_MODIFICACIONLB || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN FACTURA IS NULL THEN ' ' ELSE UPPER(FACTURA) END)  LIKE UPPER( '%' || :FACTURA || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="TIPO_MODIFICACIONLB" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipmodificacionespagos/numero">
		<call-query href="getIpmodificacionespagosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODIFICACION" query-param="MODIFICACION"/>
			<with-param name="TIPO_MODIFICACIONLB" query-param="TIPO_MODIFICACIONLB"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getIpmodificacionespagosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_MODIFICACIONES_PAGOS.COMPANIA, IP_MODIFICACIONES_PAGOS.MODIFICACION,(TO_CHAR(IP_MODIFICACIONES_PAGOS.FECHA_MODIFICACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_MODIFICACION, IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION, TO_CHAR(CASE IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION WHEN '01' THEN 'Modificar Banco' WHEN '02' THEN 'Modificar Fecha De Pago' WHEN '03' THEN 'Modificar Paquete' WHEN '04' THEN 'Modificar Valor Pagado' WHEN '05' THEN 'Anular Recibo' WHEN '06' THEN 'Activar Recibo' END) TIPO_MODIFICACIONLB, IP_MODIFICACIONES_PAGOS.CODIGO, IP_MODIFICACIONES_PAGOS.FACTURA, IP_MODIFICACIONES_PAGOS.BANCO, BANCO.NOMBREBANCO, IP_USUARIOS_PREDIAL.NOMBRE, IP_USUARIOS_PREDIAL.NIT, IP_PAGO_BANCOSDET.PAG_BAN, IP_PAGO_BANCOSDET.NUMFACTURA, IP_PAGO_BANCOSDET.PAQUETE PAQUETEBANCDET,(TO_CHAR(IP_PAGO_BANCOSDET.PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, IP_PAGO_BANCOSDET.PREVAL,(TO_CHAR(IP_MODIFICACIONES_PAGOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(IP_MODIFICACIONES_PAGOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHAANT, IP_MODIFICACIONES_PAGOS.USUARIO_MODIFICACION, IP_MODIFICACIONES_PAGOS.PAQUETE, IP_MODIFICACIONES_PAGOS.PAQUETE PAQANT, IP_MODIFICACIONES_PAGOS.VALOR,(CASE IP_MODIFICACIONES_PAGOS.ANULAR_PAGO WHEN 0 THEN 'false' ELSE 'true' END) ANULAR_PAGO,(CASE IP_MODIFICACIONES_PAGOS.ANULAR_RECIBO WHEN 0 THEN 'false' ELSE 'true' END) ANULAR_RECIBO,(CASE IP_MODIFICACIONES_PAGOS.ACTIVAR_RECIBO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVAR_RECIBO, IP_MODIFICACIONES_PAGOS.OBSERVACIONES, IP_MODIFICACIONES_PAGOS.ANT_BANCO, IP_MODIFICACIONES_PAGOS.ANT_PAQUETE, IP_MODIFICACIONES_PAGOS.ANT_VALOR,(TO_CHAR(IP_MODIFICACIONES_PAGOS.ANT_FECHA,'DD/MM/YYYY HH24:MI:SS')) ANT_FECHA, IP_MODIFICACIONES_PAGOS.NUMERO_ORDEN,(CASE IP_MODIFICACIONES_PAGOS.REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO, IP_MODIFICACIONES_PAGOS.CREATED_BY,(TO_CHAR(IP_MODIFICACIONES_PAGOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, IP_MODIFICACIONES_PAGOS.MODIFIED_BY,(TO_CHAR(IP_MODIFICACIONES_PAGOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM IP_MODIFICACIONES_PAGOS LEFT JOIN IP_BANCOS BANCO ON IP_MODIFICACIONES_PAGOS.COMPANIA = BANCO.COMPANIA AND IP_MODIFICACIONES_PAGOS.BANCO = BANCO.CODIGOBANCO INNER JOIN IP_USUARIOS_PREDIAL ON IP_MODIFICACIONES_PAGOS.COMPANIA = IP_USUARIOS_PREDIAL.COMPANIA AND IP_MODIFICACIONES_PAGOS.CODIGO = IP_USUARIOS_PREDIAL.CODIGO AND IP_MODIFICACIONES_PAGOS.NUMERO_ORDEN = IP_USUARIOS_PREDIAL.NUMERO_ORDEN LEFT JOIN IP_PAGO_BANCOSDET ON IP_MODIFICACIONES_PAGOS.COMPANIA = IP_PAGO_BANCOSDET.COMPANIA AND IP_MODIFICACIONES_PAGOS.CODIGO = IP_PAGO_BANCOSDET.PRECOD AND IP_MODIFICACIONES_PAGOS.FACTURA = IP_PAGO_BANCOSDET.NUMFACTURA AND IP_MODIFICACIONES_PAGOS.NUMERO_ORDEN = IP_PAGO_BANCOSDET.NUMERO_ORDEN WHERE IP_MODIFICACIONES_PAGOS.COMPANIA= :KEY_COMPANIA AND IP_MODIFICACIONES_PAGOS.MODIFICACION= :KEY_MODIFICACION AND IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION= :KEY_TIPO_MODIFICACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","MODIFICACION":"$MODIFICACION","FECHA_MODIFICACION":"$FECHA_MODIFICACION","TIPO_MODIFICACION":"$TIPO_MODIFICACION","TIPO_MODIFICACIONLB":"$TIPO_MODIFICACIONLB","CODIGO":"$CODIGO","FACTURA":"$FACTURA","BANCO":"$BANCO","NOMBREBANCO":"$NOMBREBANCO","NOMBRE":"$NOMBRE","NIT":"$NIT","PAG_BAN":"$PAG_BAN","NUMFACTURA":"$NUMFACTURA","PAQUETEBANCDET":"$PAQUETEBANCDET","PREFEC":"$PREFEC","PREVAL":"$PREVAL","FECHA":"$FECHA","FECHAANT":"$FECHAANT","USUARIO_MODIFICACION":"$USUARIO_MODIFICACION","PAQUETE":"$PAQUETE","PAQANT":"$PAQANT","VALOR":"$VALOR","ANULAR_PAGO":"$ANULAR_PAGO(type:boolean)","ANULAR_RECIBO":"$ANULAR_RECIBO(type:boolean)","ACTIVAR_RECIBO":"$ACTIVAR_RECIBO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","ANT_BANCO":"$ANT_BANCO","ANT_PAQUETE":"$ANT_PAQUETE","ANT_VALOR":"$ANT_VALOR","ANT_FECHA":"$ANT_FECHA","NUMERO_ORDEN":"$NUMERO_ORDEN","REGISTRADO":"$REGISTRADO(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODIFICACION" sqlType="STRING"/>
		<param name="KEY_TIPO_MODIFICACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipmodificacionespagos/data">
		<call-query href="getIpmodificacionespagosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MODIFICACION" query-param="KEY_MODIFICACION"/>
			<with-param name="KEY_TIPO_MODIFICACION" query-param="KEY_TIPO_MODIFICACION"/>

		</call-query>
	</resource>
	<query id="updateIpmodificacionespagos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_MODIFICACIONES_PAGOS SET MODIFICACION=:MODIFICACION, FECHA_MODIFICACION=TO_DATE(:FECHA_MODIFICACION,'DD/MM/YYYY HH24:MI:SS'), TIPO_MODIFICACION=:TIPO_MODIFICACION, CODIGO=:CODIGO, FACTURA=:FACTURA, BANCO=:BANCO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), USUARIO_MODIFICACION=:USUARIO_MODIFICACION, PAQUETE=:PAQUETE, VALOR=:VALOR, ANULAR_PAGO=:ANULAR_PAGO, ANULAR_RECIBO=:ANULAR_RECIBO, ACTIVAR_RECIBO=:ACTIVAR_RECIBO, OBSERVACIONES=:OBSERVACIONES, ANT_BANCO=:ANT_BANCO, ANT_PAQUETE=:ANT_PAQUETE, ANT_VALOR=:ANT_VALOR, ANT_FECHA=TO_DATE(:ANT_FECHA,'DD/MM/YYYY HH24:MI:SS'), NUMERO_ORDEN=:NUMERO_ORDEN, REGISTRADO=:REGISTRADO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE IP_MODIFICACIONES_PAGOS.COMPANIA= :KEY_COMPANIA AND IP_MODIFICACIONES_PAGOS.MODIFICACION= :KEY_MODIFICACION AND IP_MODIFICACIONES_PAGOS.TIPO_MODIFICACION= :KEY_TIPO_MODIFICACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="FECHA_MODIFICACION" sqlType="STRING"/>
		<param name="TIPO_MODIFICACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="USUARIO_MODIFICACION" sqlType="STRING"/>
		<param name="PAQUETE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ANULAR_PAGO" sqlType="STRING"/>
		<param name="ANULAR_RECIBO" sqlType="STRING"/>
		<param name="ACTIVAR_RECIBO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="ANT_BANCO" sqlType="STRING"/>
		<param name="ANT_PAQUETE" sqlType="STRING"/>
		<param name="ANT_VALOR" sqlType="STRING"/>
		<param name="ANT_FECHA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="REGISTRADO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODIFICACION" sqlType="STRING"/>
		<param name="KEY_TIPO_MODIFICACION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipmodificacionespagos">
		<call-query href="updateIpmodificacionespagos">
			<with-param name="MODIFICACION" query-param="MODIFICACION"/>
			<with-param name="FECHA_MODIFICACION" query-param="FECHA_MODIFICACION"/>
			<with-param name="TIPO_MODIFICACION" query-param="TIPO_MODIFICACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="USUARIO_MODIFICACION" query-param="USUARIO_MODIFICACION"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ANULAR_PAGO" query-param="ANULAR_PAGO"/>
			<with-param name="ANULAR_RECIBO" query-param="ANULAR_RECIBO"/>
			<with-param name="ACTIVAR_RECIBO" query-param="ACTIVAR_RECIBO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="ANT_BANCO" query-param="ANT_BANCO"/>
			<with-param name="ANT_PAQUETE" query-param="ANT_PAQUETE"/>
			<with-param name="ANT_VALOR" query-param="ANT_VALOR"/>
