	</resource>
	<query id="updateSstdtransaccionesParticipantesExternos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_D_TRANSACCIONES SET TIPO_TRANSACCION=:TIPO_TRANSACCION, CONSECUTIVO=:CONSECUTIVO, ID_EMPLEADO=:ID_EMPLEADO, CEDULA=:CEDULA, SUCURSAL=:SUCURSAL, DESCRIPCION=:DESCRIPCION, IND_ASISTIO=:IND_ASISTIO, CALIFICACION=:CALIFICACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_D_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND SST_D_TRANSACCIONES.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_D_TRANSACCIONES.CONSECUTIVO= :KEY_CONSECUTIVO AND SST_D_TRANSACCIONES.ID_EMPLEADO= :KEY_ID_EMPLEADO AND SST_D_TRANSACCIONES.CEDULA= :KEY_CEDULA AND SST_D_TRANSACCIONES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="IND_ASISTIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_ID_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_CEDULA" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstdtransacciones/participantesexternos">
		<call-query href="updateSstdtransaccionesParticipantesExternos">
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="IND_ASISTIO" query-param="IND_ASISTIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_ID_EMPLEADO" query-param="KEY_ID_EMPLEADO"/>
			<with-param name="KEY_CEDULA" query-param="KEY_CEDULA"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

