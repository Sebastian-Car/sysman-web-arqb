	</resource>
	<query id="insertSstdtransacciones" keyColumns="COMPANIA,TIPO_TRANSACCION,CONSECUTIVO,ID_EMPLEADO,CEDULA,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_D_TRANSACCIONES (COMPANIA, TIPO_TRANSACCION, CONSECUTIVO, ID_EMPLEADO, CEDULA, SUCURSAL, DESCRIPCION, IND_ASISTIO, CALIFICACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO_TRANSACCION, :CONSECUTIVO, :ID_EMPLEADO, :CEDULA, :SUCURSAL, :DESCRIPCION, :IND_ASISTIO, :CALIFICACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)","KEY_ID_EMPLEADO":"$ID_EMPLEADO(type:integer)","KEY_CEDULA":"$CEDULA","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="IND_ASISTIO" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFICACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstdtransacciones">
		<call-query href="insertSstdtransacciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
