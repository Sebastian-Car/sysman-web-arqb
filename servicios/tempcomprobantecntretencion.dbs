<data name="tempcomprobantecntretencion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="deleteTempcomprobantecntretencionDeleteretenciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TEMP_COMPROBANTE_CNTRETENCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

 
	</query>
	<resource method="DELETE" path="tempcomprobantecntretencion/deleteretenciones">
		<call-query href="deleteTempcomprobantecntretencionDeleteretenciones">
 
		</call-query>
	</resource>
	<query id="insertTempcomprobantecntretencion" keyColumns="COMPANIA,ANO,TIPO,NUMERO,TIPORETENCION,CODIGORETENCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TEMP_COMPROBANTE_CNTRETENCION (COMPANIA, ANO, TIPO, NUMERO, TIPORETENCION, CODIGORETENCION, VALOR, VALORBASE, PORCIVA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO, :NUMERO, :TIPORETENCION, :CODIGORETENCION, :VALOR, :VALORBASE, :PORCIVA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_TIPORETENCION":"$TIPORETENCION","KEY_CODIGORETENCION":"$CODIGORETENCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPORETENCION" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="0" name="VALORBASE" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tempcomprobantecntretencion">
		<call-query href="insertTempcomprobantecntretencion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTempcomprobantecntretencion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TEMP_COMPROBANTE_CNTRETENCION WHERE TEMP_COMPROBANTE_CNTRETENCION.COMPANIA= :KEY_COMPANIA AND TEMP_COMPROBANTE_CNTRETENCION.ANO= :KEY_ANO AND TEMP_COMPROBANTE_CNTRETENCION.TIPO= :KEY_TIPO AND TEMP_COMPROBANTE_CNTRETENCION.NUMERO= :KEY_NUMERO AND TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION= :KEY_TIPORETENCION AND TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION= :KEY_CODIGORETENCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPORETENCION" sqlType="STRING"/>
		<param name="KEY_CODIGORETENCION" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tempcomprobantecntretencion">
		<call-query href="deleteTempcomprobantecntretencion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPORETENCION" query-param="KEY_TIPORETENCION"/>
			<with-param name="KEY_CODIGORETENCION" query-param="KEY_CODIGORETENCION"/>

		</call-query>
	</resource>
	<query id="getTempcomprobantecntretencionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TEMP_COMPROBANTE_CNTRETENCION.COMPANIA, TEMP_COMPROBANTE_CNTRETENCION.ANO, TEMP_COMPROBANTE_CNTRETENCION.TIPO, TEMP_COMPROBANTE_CNTRETENCION.NUMERO, TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION, TIPORETENCION.NOMBRE NOMBRERETENCIONES, TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION, TEMP_COMPROBANTE_CNTRETENCION.VALOR, TEMP_COMPROBANTE_CNTRETENCION.VALORBASE, RETENCIONES.NOMBRE, TEMP_COMPROBANTE_CNTRETENCION.PORCIVA  FROM TEMP_COMPROBANTE_CNTRETENCION LEFT JOIN RETENCIONES ON TEMP_COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA AND TEMP_COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO AND TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO AND TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO LEFT JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO WHERE TEMP_COMPROBANTE_CNTRETENCION.COMPANIA = :COMPANIA AND TEMP_COMPROBANTE_CNTRETENCION.ANO = :ANO AND TEMP_COMPROBANTE_CNTRETENCION.TIPO = :TIPO AND TEMP_COMPROBANTE_CNTRETENCION.NUMERO = :NUMERO ORDER BY TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION, TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION) WHERE (CASE WHEN NOMBRERETENCIONES IS NULL THEN ' ' ELSE UPPER(NOMBRERETENCIONES) END)  LIKE UPPER( '%' || :NOMBRERETENCIONES || '%')  AND (CASE WHEN CODIGORETENCION IS NULL THEN ' ' ELSE UPPER(CODIGORETENCION) END)  LIKE UPPER( '%' || :CODIGORETENCION || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN VALORBASE IS NULL THEN ' ' ELSE UPPER(VALORBASE) END)  LIKE UPPER( '%' || :VALORBASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TIPORETENCION":"$TIPORETENCION","NOMBRERETENCIONES":"$NOMBRERETENCIONES","CODIGORETENCION":"$CODIGORETENCION","VALOR":"$VALOR","VALORBASE":"$VALORBASE","NOMBRE":"$NOMBRE","PORCIVA":"$PORCIVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRERETENCIONES" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tempcomprobantecntretencion">
		<call-query href="getTempcomprobantecntretencionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NOMBRERETENCIONES" query-param="NOMBRERETENCIONES"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTempcomprobantecntretencionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TEMP_COMPROBANTE_CNTRETENCION.COMPANIA, TEMP_COMPROBANTE_CNTRETENCION.ANO, TEMP_COMPROBANTE_CNTRETENCION.TIPO, TEMP_COMPROBANTE_CNTRETENCION.NUMERO, TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION, TIPORETENCION.NOMBRE NOMBRERETENCIONES, TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION, TEMP_COMPROBANTE_CNTRETENCION.VALOR, TEMP_COMPROBANTE_CNTRETENCION.VALORBASE, RETENCIONES.NOMBRE, TEMP_COMPROBANTE_CNTRETENCION.PORCIVA  FROM TEMP_COMPROBANTE_CNTRETENCION LEFT JOIN RETENCIONES ON TEMP_COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA AND TEMP_COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO AND TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO AND TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO LEFT JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO WHERE TEMP_COMPROBANTE_CNTRETENCION.COMPANIA = :COMPANIA AND TEMP_COMPROBANTE_CNTRETENCION.ANO = :ANO AND TEMP_COMPROBANTE_CNTRETENCION.TIPO = :TIPO AND TEMP_COMPROBANTE_CNTRETENCION.NUMERO = :NUMERO ORDER BY TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION, TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION) WHERE (CASE WHEN NOMBRERETENCIONES IS NULL THEN ' ' ELSE UPPER(NOMBRERETENCIONES) END)  LIKE UPPER( '%' || :NOMBRERETENCIONES || '%')  AND (CASE WHEN CODIGORETENCION IS NULL THEN ' ' ELSE UPPER(CODIGORETENCION) END)  LIKE UPPER( '%' || :CODIGORETENCION || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN VALORBASE IS NULL THEN ' ' ELSE UPPER(VALORBASE) END)  LIKE UPPER( '%' || :VALORBASE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRERETENCIONES" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tempcomprobantecntretencion/numero">
		<call-query href="getTempcomprobantecntretencionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NOMBRERETENCIONES" query-param="NOMBRERETENCIONES"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>

		</call-query>
	</resource>
	<query id="updateTempcomprobantecntretencion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TEMP_COMPROBANTE_CNTRETENCION SET TIPORETENCION=:TIPORETENCION, CODIGORETENCION=:CODIGORETENCION, VALOR=:VALOR, VALORBASE=:VALORBASE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TEMP_COMPROBANTE_CNTRETENCION.COMPANIA= :KEY_COMPANIA AND TEMP_COMPROBANTE_CNTRETENCION.ANO= :KEY_ANO AND TEMP_COMPROBANTE_CNTRETENCION.TIPO= :KEY_TIPO AND TEMP_COMPROBANTE_CNTRETENCION.NUMERO= :KEY_NUMERO AND TEMP_COMPROBANTE_CNTRETENCION.TIPORETENCION= :KEY_TIPORETENCION AND TEMP_COMPROBANTE_CNTRETENCION.CODIGORETENCION= :KEY_CODIGORETENCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPORETENCION" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPORETENCION" sqlType="STRING"/>
		<param name="KEY_CODIGORETENCION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tempcomprobantecntretencion">
		<call-query href="updateTempcomprobantecntretencion">
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPORETENCION" query-param="KEY_TIPORETENCION"/>
			<with-param name="KEY_CODIGORETENCION" query-param="KEY_CODIGORETENCION"/>

		</call-query>
	</resource>

</data>