<data name="observacioneseta" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertObservacioneseta" keyColumns="COMPANIA,TIPOCONTRATO,TRANSACCION,CONSECUTIVODETALLE,ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO OBSERVACIONES_ETA (COMPANIA, TIPOCONTRATO, TRANSACCION, CONSECUTIVODETALLE, ID, OBSERVADOR, DESCRIPCION, RESPUESTA, SUCURSAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOCONTRATO, :TRANSACCION, :CONSECUTIVODETALLE, :ID, :OBSERVADOR, :DESCRIPCION, :RESPUESTA, :SUCURSAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCONTRATO":"$TIPOCONTRATO","KEY_TRANSACCION":"$TRANSACCION","KEY_CONSECUTIVODETALLE":"$CONSECUTIVODETALLE(type:integer)","KEY_ID":"$ID(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="OBSERVADOR" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="RESPUESTA" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="observacioneseta">
		<call-query href="insertObservacioneseta">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVODETALLE" query-param="CONSECUTIVODETALLE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="OBSERVADOR" query-param="OBSERVADOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteObservacioneseta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM OBSERVACIONES_ETA WHERE OBSERVACIONES_ETA.COMPANIA= :KEY_COMPANIA AND OBSERVACIONES_ETA.TIPOCONTRATO= :KEY_TIPOCONTRATO AND OBSERVACIONES_ETA.TRANSACCION= :KEY_TRANSACCION AND OBSERVACIONES_ETA.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND OBSERVACIONES_ETA.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVODETALLE" sqlType="INTEGER"/>
		<param name="KEY_ID" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="observacioneseta">
		<call-query href="deleteObservacioneseta">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_TRANSACCION" query-param="KEY_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVODETALLE" query-param="KEY_CONSECUTIVODETALLE"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getObservacionesetaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  OBSERVACIONES_ETA.COMPANIA, OBSERVACIONES_ETA.TIPOCONTRATO, OBSERVACIONES_ETA.TRANSACCION, OBSERVACIONES_ETA.CONSECUTIVODETALLE, OBSERVACIONES_ETA.ID, TERCERO.NOMBRE, OBSERVACIONES_ETA.DESCRIPCION, OBSERVACIONES_ETA.RESPUESTA  FROM OBSERVACIONES_ETA INNER JOIN TERCERO ON OBSERVACIONES_ETA.COMPANIA = TERCERO.COMPANIA AND OBSERVACIONES_ETA.OBSERVADOR = TERCERO.NIT AND OBSERVACIONES_ETA.SUCURSAL = TERCERO.SUCURSAL WHERE OBSERVACIONES_ETA.COMPANIA = :COMPANIA AND OBSERVACIONES_ETA.TIPOCONTRATO = :TIPO_CONTRATO AND OBSERVACIONES_ETA.TRANSACCION = :CONSECUTIVOTX AND OBSERVACIONES_ETA.CONSECUTIVODETALLE = :CONSECUTIVODET ORDER BY OBSERVACIONES_ETA.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN RESPUESTA IS NULL THEN ' ' ELSE UPPER(RESPUESTA) END)  LIKE UPPER( '%' || :RESPUESTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCONTRATO":"$TIPOCONTRATO","TRANSACCION":"$TRANSACCION","CONSECUTIVODETALLE":"$CONSECUTIVODETALLE(type:integer)","ID":"$ID(type:integer)","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","RESPUESTA":"$RESPUESTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="CONSECUTIVOTX" sqlType="STRING"/>
		<param name="CONSECUTIVODET" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="observacioneseta">
		<call-query href="getObservacionesetaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="CONSECUTIVOTX" query-param="CONSECUTIVOTX"/>
			<with-param name="CONSECUTIVODET" query-param="CONSECUTIVODET"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getObservacionesetaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  OBSERVACIONES_ETA.COMPANIA, OBSERVACIONES_ETA.TIPOCONTRATO, OBSERVACIONES_ETA.TRANSACCION, OBSERVACIONES_ETA.CONSECUTIVODETALLE, OBSERVACIONES_ETA.ID, TERCERO.NOMBRE, OBSERVACIONES_ETA.DESCRIPCION, OBSERVACIONES_ETA.RESPUESTA  FROM OBSERVACIONES_ETA INNER JOIN TERCERO ON OBSERVACIONES_ETA.COMPANIA = TERCERO.COMPANIA AND OBSERVACIONES_ETA.OBSERVADOR = TERCERO.NIT AND OBSERVACIONES_ETA.SUCURSAL = TERCERO.SUCURSAL WHERE OBSERVACIONES_ETA.COMPANIA = :COMPANIA AND OBSERVACIONES_ETA.TIPOCONTRATO = :TIPO_CONTRATO AND OBSERVACIONES_ETA.TRANSACCION = :CONSECUTIVOTX AND OBSERVACIONES_ETA.CONSECUTIVODETALLE = :CONSECUTIVODET ORDER BY OBSERVACIONES_ETA.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN RESPUESTA IS NULL THEN ' ' ELSE UPPER(RESPUESTA) END)  LIKE UPPER( '%' || :RESPUESTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="CONSECUTIVOTX" sqlType="STRING"/>
		<param name="CONSECUTIVODET" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="observacioneseta/numero">
		<call-query href="getObservacionesetaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="CONSECUTIVOTX" query-param="CONSECUTIVOTX"/>
			<with-param name="CONSECUTIVODET" query-param="CONSECUTIVODET"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>

		</call-query>
	</resource>
	<query id="getObservacionesetaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  OBSERVACIONES_ETA.COMPANIA, OBSERVACIONES_ETA.TIPOCONTRATO, OBSERVACIONES_ETA.TRANSACCION, OBSERVACIONES_ETA.CONSECUTIVODETALLE, OBSERVACIONES_ETA.ID, OBSERVACIONES_ETA.OBSERVADOR, OBSERVACIONES_ETA.DESCRIPCION, OBSERVACIONES_ETA.RESPUESTA, OBSERVACIONES_ETA.SUCURSAL,(TO_CHAR(OBSERVACIONES_ETA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, OBSERVACIONES_ETA.CREATED_BY,(TO_CHAR(OBSERVACIONES_ETA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, OBSERVACIONES_ETA.MODIFIED_BY, TERCERO.NIT, TERCERO.NOMBRE  FROM OBSERVACIONES_ETA INNER JOIN TERCERO ON OBSERVACIONES_ETA.COMPANIA = TERCERO.COMPANIA AND OBSERVACIONES_ETA.OBSERVADOR = TERCERO.NIT AND OBSERVACIONES_ETA.SUCURSAL = TERCERO.SUCURSAL WHERE OBSERVACIONES_ETA.COMPANIA= :KEY_COMPANIA AND OBSERVACIONES_ETA.TIPOCONTRATO= :KEY_TIPOCONTRATO AND OBSERVACIONES_ETA.TRANSACCION= :KEY_TRANSACCION AND OBSERVACIONES_ETA.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND OBSERVACIONES_ETA.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCONTRATO":"$TIPOCONTRATO","TRANSACCION":"$TRANSACCION","CONSECUTIVODETALLE":"$CONSECUTIVODETALLE(type:integer)","ID":"$ID(type:integer)","OBSERVADOR":"$OBSERVADOR","DESCRIPCION":"$DESCRIPCION","RESPUESTA":"$RESPUESTA","SUCURSAL":"$SUCURSAL","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="observacioneseta/data">
		<call-query href="getObservacionesetaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_TRANSACCION" query-param="KEY_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVODETALLE" query-param="KEY_CONSECUTIVODETALLE"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateObservacioneseta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE OBSERVACIONES_ETA SET COMPANIA=:COMPANIA, TIPOCONTRATO=:TIPOCONTRATO, TRANSACCION=:TRANSACCION, CONSECUTIVODETALLE=:CONSECUTIVODETALLE, ID=:ID, OBSERVADOR=:OBSERVADOR, DESCRIPCION=:DESCRIPCION, RESPUESTA=:RESPUESTA, SUCURSAL=:SUCURSAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE OBSERVACIONES_ETA.COMPANIA= :KEY_COMPANIA AND OBSERVACIONES_ETA.TIPOCONTRATO= :KEY_TIPOCONTRATO AND OBSERVACIONES_ETA.TRANSACCION= :KEY_TRANSACCION AND OBSERVACIONES_ETA.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND OBSERVACIONES_ETA.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="OBSERVADOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="observacioneseta">
		<call-query href="updateObservacioneseta">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVODETALLE" query-param="CONSECUTIVODETALLE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="OBSERVADOR" query-param="OBSERVADOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_TRANSACCION" query-param="KEY_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVODETALLE" query-param="KEY_CONSECUTIVODETALLE"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>

</data>