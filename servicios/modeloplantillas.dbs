	<query id="getModeloplantillasDatosdeplantillaQuery"  useConfig="sysmanirisst">
		<sql>SELECT MP.VERSION,(TO_CHAR(MP.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,MP.TIPO_VARIABLES_CONSULTA,MP.CONSULTA, MT.MODO_CREACION, CASE WHEN MT.NOMBRE IS NOT NULL THEN CONCAT(SUBSTR(MT.NOMBRE, 1, LENGTH(MT.NOMBRE) - 5), '#&gt;')ELSE '' END AS NOMBRESUB, MT.CONSULTA CONSULTASUB, MT.ENLACE_PRINCIPAL, MT.ENLACE_SECUNDARIO, MT.CONDICION FROM MODELO_PLANTILLA MP LEFT JOIN MODELO_TABLA MT ON MP.CODIGO = MT.PLANTILLA WHERE MP.CODIGO = :PLANTILLA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VERSION":"$VERSION","FECHA":"$FECHA","TIPO_VARIABLES_CONSULTA":"$TIPO_VARIABLES_CONSULTA","CONSULTA":"$CONSULTA","MODO_CREACION":"$MODO_CREACION","NOMBRESUB":"$NOMBRESUB","CONSULTASUB":"$CONSULTASUB","ENLACE_PRINCIPAL":"$ENLACE_PRINCIPAL","ENLACE_SECUNDARIO":"$ENLACE_SECUNDARIO","CONDICION":"$CONDICION"}]}}		</result>
		<param name="PLANTILLA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="modeloplantillas/datosdeplantilla">
		<call-query href="getModeloplantillasDatosdeplantillaQuery">
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>

		</call-query>
	</resource>
	<query id="getModeloplantillasGeneraconsecutivoporanioQuery"  useConfig="sysmanirisst">
		<sql>SELECT CONCAT(:APLICACION, NVL(MAX(TO_NUMBER(SUBSTR(CODIGO, LENGTH(:APLICACION) + 1))) + 1, 1)) AS CODIGO FROM MODELO_PLANTILLA WHERE REGEXP_LIKE(CODIGO, CONCAT(CONCAT('^', :APLICACION), '[0-9]+$')) AND TIPO IN ( SELECT MODELO_TIPO.CODIGO FROM MODELO_TIPO INNER JOIN MODELO_TIPO_APLICACION ON MODELO_TIPO.CODIGO = MODELO_TIPO_APLICACION.TIPO WHERE MODELO_TIPO_APLICACION.APLICACION = :APLICACION )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="APLICACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="modeloplantillas/generaconsecutivoporanio">
		<call-query href="getModeloplantillasGeneraconsecutivoporanioQuery">
			<with-param name="APLICACION" query-param="APLICACION"/>

		</call-query>
	</resource>
