		</call-query>
	</resource>
	<query id="insertModeloplantillas" keyColumns="CODIGO" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO MODELO_PLANTILLA (CODIGO, NOMBRE, PLANTILLA, TIPO_VARIABLES_CONSULTA, TIPO, VERSION, FECHA, CONSULTA, DATE_CREATED, CREATED_BY) VALUES (:CODIGO, :NOMBRE, :PLANTILLA, :TIPO_VARIABLES_CONSULTA, :TIPO, :VERSION, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :CONSULTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGO":"$CODIGO","KEY_FECHA":"$FECHA"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="PLANTILLA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_VARIABLES_CONSULTA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="VERSION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CONSULTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="modeloplantillas">
		<call-query href="insertModeloplantillas">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="TIPO_VARIABLES_CONSULTA" query-param="TIPO_VARIABLES_CONSULTA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CONSULTA" query-param="CONSULTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteModeloplantillas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM MODELO_PLANTILLA WHERE MODELO_PLANTILLA.CODIGO= :KEY_CODIGO AND MODELO_PLANTILLA.FECHA= TO_DATE(:KEY_FECHA,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_FECHA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="modeloplantillas">
		<call-query href="deleteModeloplantillas">
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_FECHA" query-param="KEY_FECHA"/>

		</call-query>
	</resource>
	<query id="getModeloplantillasPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (SELECT NOMBRE FROM MODELO_TIPO WHERE CODIGO = MODELO_PLANTILLA.TIPO ) TIPOMOD, MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, MODELO_PLANTILLA.PLANTILLA, MODELO_PLANTILLA.VERSION, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHALABEL,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MODELO_PLANTILLA INNER JOIN MODELO_TIPO_APLICACION ON MODELO_PLANTILLA.TIPO = MODELO_TIPO_APLICACION.TIPO WHERE MODELO_TIPO_APLICACION.APLICACION = :MODULO ORDER BY MODELO_PLANTILLA.CODIGO DESC,MODELO_PLANTILLA.TIPO) INI WHERE (CASE WHEN TIPOMOD IS NULL THEN ' ' ELSE UPPER(TIPOMOD) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOMOD), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PLANTILLA IS NULL THEN ' ' ELSE UPPER(PLANTILLA) END) LIKE UPPER(CONCAT(CONCAT('%',:PLANTILLA), '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN FECHALABEL IS NULL THEN ' ' ELSE UPPER(FECHALABEL) END) LIKE UPPER(CONCAT(:FECHALABEL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOMOD":"$TIPOMOD","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PLANTILLA":"$PLANTILLA","VERSION":"$VERSION","FECHALABEL":"$FECHALABEL","FECHA":"$FECHA"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="TIPOMOD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHALABEL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="modeloplantillas">
		<call-query href="getModeloplantillasPaginaQuery">
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="TIPOMOD" query-param="TIPOMOD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHALABEL" query-param="FECHALABEL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getModeloplantillasNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (SELECT NOMBRE FROM MODELO_TIPO WHERE CODIGO = MODELO_PLANTILLA.TIPO ) TIPOMOD, MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, MODELO_PLANTILLA.PLANTILLA, MODELO_PLANTILLA.VERSION, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHALABEL,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MODELO_PLANTILLA INNER JOIN MODELO_TIPO_APLICACION ON MODELO_PLANTILLA.TIPO = MODELO_TIPO_APLICACION.TIPO WHERE MODELO_TIPO_APLICACION.APLICACION = :MODULO ORDER BY MODELO_PLANTILLA.CODIGO DESC,MODELO_PLANTILLA.TIPO) INI WHERE (CASE WHEN TIPOMOD IS NULL THEN ' ' ELSE UPPER(TIPOMOD) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOMOD), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PLANTILLA IS NULL THEN ' ' ELSE UPPER(PLANTILLA) END) LIKE UPPER(CONCAT(CONCAT('%',:PLANTILLA), '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN FECHALABEL IS NULL THEN ' ' ELSE UPPER(FECHALABEL) END) LIKE UPPER(CONCAT(:FECHALABEL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="TIPOMOD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHALABEL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="modeloplantillas/numero">
		<call-query href="getModeloplantillasNumeroQuery">
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="TIPOMOD" query-param="TIPOMOD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHALABEL" query-param="FECHALABEL"/>

		</call-query>
	</resource>
	<query id="getModeloplantillasRegistroQuery"  useConfig="sysmanirisst">
		<sql>SELECT  MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, MODELO_PLANTILLA.PLANTILLA, MODELO_PLANTILLA.TIPO_VARIABLES_CONSULTA, MODELO_PLANTILLA.TIPO, MODELO_TIPO.NOMBRE NOMBRETIPO, MODELO_PLANTILLA.VERSION,(TO_CHAR(MODELO_PLANTILLA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, MODELO_PLANTILLA.CONSULTA, MODELO_PLANTILLA.CREATED_BY,(TO_CHAR(MODELO_PLANTILLA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODELO_PLANTILLA.MODIFIED_BY,(TO_CHAR(MODELO_PLANTILLA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM MODELO_PLANTILLA INNER JOIN MODELO_TIPO ON MODELO_PLANTILLA.TIPO = MODELO_TIPO.CODIGO WHERE MODELO_PLANTILLA.CODIGO= :KEY_CODIGO AND MODELO_PLANTILLA.FECHA= TO_DATE(:KEY_FECHA,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PLANTILLA":"$PLANTILLA","TIPO_VARIABLES_CONSULTA":"$TIPO_VARIABLES_CONSULTA","TIPO":"$TIPO(type:integer)","NOMBRETIPO":"$NOMBRETIPO","VERSION":"$VERSION","FECHA":"$FECHA","CONSULTA":"$CONSULTA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="modeloplantillas/data">
		<call-query href="getModeloplantillasRegistroQuery">
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_FECHA" query-param="KEY_FECHA"/>

		</call-query>
	</resource>
	<query id="updateModeloplantillas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE MODELO_PLANTILLA SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, PLANTILLA=:PLANTILLA, TIPO_VARIABLES_CONSULTA=:TIPO_VARIABLES_CONSULTA, TIPO=:TIPO, VERSION=:VERSION, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), CONSULTA=:CONSULTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE MODELO_PLANTILLA.CODIGO= :KEY_CODIGO AND MODELO_PLANTILLA.FECHA= TO_DATE(:KEY_FECHA,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="TIPO_VARIABLES_CONSULTA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CONSULTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_FECHA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="modeloplantillas">
		<call-query href="updateModeloplantillas">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="TIPO_VARIABLES_CONSULTA" query-param="TIPO_VARIABLES_CONSULTA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CONSULTA" query-param="CONSULTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_FECHA" query-param="KEY_FECHA"/>

		</call-query>
	</resource>
	<query id="getModeloplantillasCartasPorDesviacionesQuery"  useConfig="sysmanirisst">
		<sql>SELECT  NOMBRE  FROM ( SELECT * FROM MODELO_PLANTILLA WHERE TIPO = '31' AND CODIGO = :CODIGO AND FECHA &lt;= :FECHA ORDER BY FECHA DESC ) WHERE ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
