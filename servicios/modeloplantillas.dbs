	<query id="getModeloplantillasCodnombrefechainnermodelotipoaplicacionQuery"  useConfig="sysmanirisst">
		<sql>SELECT  MP.CODIGO, MP.NOMBRE,(TO_CHAR(MP.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MODELO_PLANTILLA MP INNER JOIN MODELO_TIPO_APLICACION MPA ON MP.TIPO = MPA.TIPO WHERE MPA.APLICACION = :MODULO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(NVL(:TIPO,MP.TIPO)), MP.TIPO, 1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FECHA":"$FECHA"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
