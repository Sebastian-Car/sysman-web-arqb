	<query id="getModeloplantillasPagCodnomfechasQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE, TO_CHAR(FECHA,'DD/MM/YYYY') FECHAVISIBLE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CONCAT(CODIGO , TO_CHAR(FECHA,'DD/MM/YYYY')) ID FROM MODELO_PLANTILLA WHERE TIPO =:TIPO ORDER BY FECHA DESC) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHAVISIBLE IS NULL THEN ' ' ELSE UPPER(FECHAVISIBLE) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAVISIBLE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FECHAVISIBLE":"$FECHAVISIBLE","FECHA":"$FECHA","ID":"$ID"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAVISIBLE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
