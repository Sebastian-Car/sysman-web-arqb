	<query id="getModeloplantillasPagCodigoYNombrePorModelosQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA FROM MODELO_PLANTILLA INNER JOIN MODELO_TIPO_APLICACION ON MODELO_PLANTILLA.TIPO = MODELO_TIPO_APLICACION.TIPO WHERE APLICACION =:MODULO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:LISTAMODELOS),CONCAT('''',CONCAT(CODIGO,'''') ),1) &gt; 0) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FECHA":"$FECHA"}]}}		</result>
