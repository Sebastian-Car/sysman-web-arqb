		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHALB,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MODELO_PLANTILLA WHERE TIPO = '37') WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHALB IS NULL THEN ' ' ELSE UPPER(FECHALB) END)  LIKE UPPER( '%' || :FECHALB || '%') ))</sql>
