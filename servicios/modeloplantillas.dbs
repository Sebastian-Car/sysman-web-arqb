	<query id="getModeloplantillasPagSegunTipoHojaDeVidaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ( SELECT NOMBRE FROM MODELO_TIPO WHERE CODIGO = MODELO_PLANTILLA.TIPO ) TIPOMOD, MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, MODELO_PLANTILLA.PLANTILLA, MODELO_PLANTILLA.VERSION, TO_CHAR(FECHA,'DD/MM/YYYY') FECHALABEL,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MODELO_PLANTILLA INNER JOIN MODELO_TIPO_APLICACION ON MODELO_PLANTILLA.TIPO = MODELO_TIPO_APLICACION.TIPO WHERE MODELO_TIPO_APLICACION.APLICACION =:MODULO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPO,' ','') ),CONCAT( '', CONCAT( PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(MODELO_TIPO_APLICACION.TIPO,' ','') ), '')),1) &gt; 0 ORDER BY MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.TIPO) INI WHERE (CASE WHEN TIPOMOD IS NULL THEN ' ' ELSE UPPER(TIPOMOD) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOMOD), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PLANTILLA IS NULL THEN ' ' ELSE UPPER(PLANTILLA) END) LIKE UPPER(CONCAT(CONCAT('%',:PLANTILLA), '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN FECHALABEL IS NULL THEN ' ' ELSE UPPER(FECHALABEL) END) LIKE UPPER(CONCAT(:FECHALABEL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOMOD":"$TIPOMOD","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PLANTILLA":"$PLANTILLA","VERSION":"$VERSION","FECHALABEL":"$FECHALABEL","FECHA":"$FECHA"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TIPOMOD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHALABEL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
