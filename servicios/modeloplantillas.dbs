	<query id="getModeloplantillasTodosLosDatosQuery"  useConfig="sysmanirisst">
		<sql>SELECT MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, MODELO_PLANTILLA.PLANTILLA, MODELO_PLANTILLA.TIPO, MODELO_TIPO.NOMBRE AS NOMBRETIPO, MODELO_PLANTILLA.VERSION,(TO_CHAR(MODELO_PLANTILLA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, MODELO_PLANTILLA.CONSULTA, MODELO_PLANTILLA.CREATED_BY,(TO_CHAR(MODELO_PLANTILLA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODELO_PLANTILLA.MODIFIED_BY,(TO_CHAR(MODELO_PLANTILLA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, MODELO_PLANTILLA.TIPO_VARIABLES_CONSULTA FROM MODELO_PLANTILLA INNER JOIN MODELO_TIPO ON MODELO_PLANTILLA.TIPO = MODELO_TIPO.CODIGO WHERE MODELO_PLANTILLA.CODIGO = :CODIGO AND TRUNC(MODELO_PLANTILLA.FECHA) = TO_DATE(:FECHA,'DD/MM/YYYY')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PLANTILLA":"$PLANTILLA","TIPO":"$TIPO(type:integer)","NOMBRETIPO":"$NOMBRETIPO","VERSION":"$VERSION","FECHA":"$FECHA","CONSULTA":"$CONSULTA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","TIPO_VARIABLES_CONSULTA":"$TIPO_VARIABLES_CONSULTA"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="modeloplantillas/todoslosdatos">
		<call-query href="getModeloplantillasTodosLosDatosQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getModeloplantillasPagFormatoContratosQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, TO_CHAR(MODELO_PLANTILLA.FECHA,'DD/MM/YYYY') FECHA  FROM MODELO_PLANTILLA WHERE TIPO = :TIPO AND CODIGO IN (SELECT TRIM(REGEXP_SUBSTR(TIPOFORMATO, '[^,]+', 1, LEVEL)) STR FROM (SELECT TIPOFORMATO FROM TIPOORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CODIGO = :CLASE ) DATA CONNECT BY INSTR(TIPOFORMATO, ',', 1, LEVEL - 1) &gt; 0 )) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FECHA":"$FECHA"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="modeloplantillas/formatocontratos/pag">
