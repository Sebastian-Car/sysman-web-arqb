			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getModeloplantillasPagFormatoworkflowQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE,(TO_CHAR(MODELO_PLANTILLA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MODELO_PLANTILLA WHERE TIPO = :TIPO AND CODIGO IN ( SELECT TRIM(REGEXP_SUBSTR(FORMATO, '[^,]+', 1, LEVEL)) STR FROM ( SELECT FORMATO FROM NODOS WHERE COMPANIA =:COMPANIA AND CODIGO_PROCESO =:PROCESO AND CODIGO =:NODO ) DATA CONNECT BY INSTR(FORMATO, ',', 1, LEVEL - 1) &gt; 0 )ORDER BY MODELO_PLANTILLA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FECHA":"$FECHA"}]}}		</result>
