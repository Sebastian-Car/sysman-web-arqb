	<query id="getModeloplantillasNumFormatoContratosQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, TO_CHAR(MODELO_PLANTILLA.FECHA,'DD/MM/YYYY') FECHA  FROM MODELO_PLANTILLA WHERE TIPO = :TIPO AND CODIGO IN (SELECT TRIM(REGEXP_SUBSTR(TIPOFORMATO, '[^,]+', 1, LEVEL)) STR FROM (SELECT TIPOFORMATO FROM TIPOORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CODIGO = :CLASE ) DATA CONNECT BY INSTR(TIPOFORMATO, ',', 1, LEVEL - 1) &gt; 0 )) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
