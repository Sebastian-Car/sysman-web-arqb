	<query id="getModeloplantillasTodosPorCodigoQuery"  useConfig="sysmanirisst">
		<sql>SELECT  CODIGO, NOMBRE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MODELO_PLANTILLA WHERE CODIGO = :CODIGO</sql>
