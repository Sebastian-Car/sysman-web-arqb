	<query id="getModeloplantillasPagCod_nombre_fecha_tipopormodulo_tipoQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MP.CODIGO, MP.NOMBRE, TO_CHAR(MP.FECHA, 'DD/MM/YYYY') FECHAET,(TO_CHAR(MP.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, MP.TIPO  FROM MODELO_PLANTILLA MP INNER JOIN MODELO_TIPO_APLICACION MPA ON MP.TIPO = MPA.TIPO WHERE MPA.APLICACION = :MODULO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(NVL(:MI_TIPOS,MP.TIPO)), MP.TIPO, 1) &gt; 0) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHAET IS NULL THEN ' ' ELSE UPPER(FECHAET) END)  LIKE UPPER( '%' || :FECHAET || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FECHAET":"$FECHAET","FECHA":"$FECHA","TIPO":"$TIPO(type:integer)"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="MI_TIPOS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAET" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="modeloplantillas/cod_nombre_fecha_tipopormodulo_tipo/pag">
		<call-query href="getModeloplantillasPagCod_nombre_fecha_tipopormodulo_tipoQuery">
