	<query id="getModeloplantillasPagTodosPorTipoSegQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE, TO_CHAR(MODELO_PLANTILLA.FECHA, 'DD/MM/YYYY') FECHA  FROM MODELO_PLANTILLA WHERE MODELO_PLANTILLA.TIPO = CASE TO_CHAR(:TIPO) WHEN 'CC' THEN '39' WHEN 'A' THEN '42' WHEN 'I' THEN '43' WHEN 'L' THEN '44' WHEN 'E' THEN '45' WHEN 'CL' THEN '46' WHEN 'B' THEN '47' WHEN 'IR' THEN '48' WHEN 'CF' THEN '49' WHEN 'CI' THEN '50' END) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FECHA":"$FECHA"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
