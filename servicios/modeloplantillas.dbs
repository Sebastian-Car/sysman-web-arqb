	<query id="getModeloplantillasPagCopiardeaplicacionQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT P.CODIGO, P.NOMBRE, P.PLANTILLA, T.NOMBRE TIPO FROM MODELO_PLANTILLA P INNER JOIN MODELO_TIPO T ON P.TIPO = T.CODIGO INNER JOIN MODELO_TIPO_APLICACION MA ON MA.TIPO = T.CODIGO WHERE MA.APLICACION = :APLICACION) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PLANTILLA IS NULL THEN ' ' ELSE UPPER(PLANTILLA) END) LIKE UPPER(CONCAT(CONCAT('%',:PLANTILLA), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PLANTILLA":"$PLANTILLA","TIPO":"$TIPO"}]}}		</result>
