<data name="festivos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFestivosDiaFestivoPorMesYAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  EXTRACT(DAY FROM ID_DE_FESTIVO) FESTIVO  FROM FESTIVOS WHERE COMPANIA = :COMPANIA AND EXTRACT (YEAR FROM ID_DE_FESTIVO)= :ANO AND EXTRACT (MONTH FROM ID_DE_FESTIVO)= :MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FESTIVO":"$FESTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="festivos/diafestivopormesyano">
		<call-query href="getFestivosDiaFestivoPorMesYAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="insertFestivos" keyColumns="COMPANIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FESTIVOS (COMPANIA, ID_DE_FESTIVO, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, TO_DATE(:ID_DE_FESTIVO,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_FESTIVO":"$ID_DE_FESTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_FESTIVO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="festivos">
		<call-query href="insertFestivos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_FESTIVO" query-param="ID_DE_FESTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteFestivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FESTIVOS WHERE FESTIVOS.COMPANIA= :KEY_COMPANIA AND TRUNC(FESTIVOS.ID_DE_FESTIVO)= TO_DATE(:KEY_ID_DE_FESTIVO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_FESTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="festivos">
		<call-query href="deleteFestivos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_FESTIVO" query-param="KEY_ID_DE_FESTIVO"/>

		</call-query>
	</resource>
	<query id="getFestivosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FESTIVOS.COMPANIA,(TO_CHAR(FESTIVOS.ID_DE_FESTIVO,'DD/MM/YYYY HH24:MI:SS')) ID_DE_FESTIVO, TO_CHAR(ID_DE_FESTIVO, 'DD/MM/YYYY') ID_FESTIVO_LB, REPLACE(REPLACE(REPLACE(TO_CHAR(ID_DE_FESTIVO,'day_DD * month * YYYY','nls_date_language=spanish'), ' ', ''), '*', ' de '), '_',' ') FECHALARGA, FESTIVOS.DESCRIPCION  FROM FESTIVOS WHERE FESTIVOS.COMPANIA = :COMPANIA ORDER BY FESTIVOS.ID_DE_FESTIVO DESC) WHERE (CASE WHEN ID_FESTIVO_LB IS NULL THEN ' ' ELSE UPPER(ID_FESTIVO_LB) END)  LIKE UPPER( '%' || :ID_FESTIVO_LB || '%')  AND (CASE WHEN FECHALARGA IS NULL THEN ' ' ELSE UPPER(FECHALARGA) END)  LIKE UPPER( '%' || :FECHALARGA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_FESTIVO":"$ID_DE_FESTIVO","ID_FESTIVO_LB":"$ID_FESTIVO_LB","FECHALARGA":"$FECHALARGA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_FESTIVO_LB" sqlType="STRING"/>
		<param name="FECHALARGA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="festivos">
		<call-query href="getFestivosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_FESTIVO_LB" query-param="ID_FESTIVO_LB"/>
			<with-param name="FECHALARGA" query-param="FECHALARGA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFestivosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FESTIVOS.COMPANIA,(TO_CHAR(FESTIVOS.ID_DE_FESTIVO,'DD/MM/YYYY HH24:MI:SS')) ID_DE_FESTIVO, TO_CHAR(ID_DE_FESTIVO, 'DD/MM/YYYY') ID_FESTIVO_LB, REPLACE(REPLACE(REPLACE(TO_CHAR(ID_DE_FESTIVO,'day_DD * month * YYYY','nls_date_language=spanish'), ' ', ''), '*', ' de '), '_',' ') FECHALARGA, FESTIVOS.DESCRIPCION  FROM FESTIVOS WHERE FESTIVOS.COMPANIA = :COMPANIA ORDER BY FESTIVOS.ID_DE_FESTIVO DESC) WHERE (CASE WHEN ID_FESTIVO_LB IS NULL THEN ' ' ELSE UPPER(ID_FESTIVO_LB) END)  LIKE UPPER( '%' || :ID_FESTIVO_LB || '%')  AND (CASE WHEN FECHALARGA IS NULL THEN ' ' ELSE UPPER(FECHALARGA) END)  LIKE UPPER( '%' || :FECHALARGA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_FESTIVO_LB" sqlType="STRING"/>
		<param name="FECHALARGA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="festivos/numero">
		<call-query href="getFestivosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_FESTIVO_LB" query-param="ID_FESTIVO_LB"/>
			<with-param name="FECHALARGA" query-param="FECHALARGA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateFestivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FESTIVOS SET COMPANIA=:COMPANIA, ID_DE_FESTIVO=TO_DATE(:ID_DE_FESTIVO,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FESTIVOS.COMPANIA= :KEY_COMPANIA AND FESTIVOS.ID_DE_FESTIVO= TO_DATE(:KEY_ID_DE_FESTIVO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_FESTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_FESTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="festivos">
		<call-query href="updateFestivos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_FESTIVO" query-param="ID_DE_FESTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_FESTIVO" query-param="KEY_ID_DE_FESTIVO"/>

		</call-query>
	</resource>

</data>