<data name="sphistoriaexterna" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSphistoriaexternaActivosPorCodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, ID_EMPRESA, VALORASEOANT, VALORASEO, BANCO_PAGO, TO_CHAR(FECHA_PAGO,'DD/MM/YYYY') FECHA_PAGO, PAQUETE_PAGO  FROM SP_HISTORIA_EXTERNA WHERE COMPANIA = :COMPANIA AND CODIGORUTA = :CODIGORUTA ORDER BY ANO DESC, PERIODO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","ID_EMPRESA":"$ID_EMPRESA","VALORASEOANT":"$VALORASEOANT","VALORASEO":"$VALORASEO","BANCO_PAGO":"$BANCO_PAGO","FECHA_PAGO":"$FECHA_PAGO","PAQUETE_PAGO":"$PAQUETE_PAGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoriaexterna/activosporcodruta">
		<call-query href="getSphistoriaexternaActivosPorCodrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSphistoriaexternaValoraseoantPorCicloAnoPeriodoYCodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VALORASEOANT  FROM SP_HISTORIA_EXTERNA WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND ANO = :ANO AND PERIODO = :PERIODO AND CODIGORUTA = :CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORASEOANT":"$VALORASEOANT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoriaexterna/valoraseoantporcicloanoperiodoycodruta">
		<call-query href="getSphistoriaexternaValoraseoantPorCicloAnoPeriodoYCodrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="updateSphistoriaexternaVlraseoporcicloanoperiodo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_HISTORIA_EXTERNA SET VALORASEOANT = VALORASEO ,   VALORASEO      = :VALORASEO,   USUARIOMOD     = :MODIFIED_BY ,   FECHAMOD       = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') ,   MODIFIED_BY    = :MODIFIED_BY ,   DATE_MODIFIED  = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPANIA   = :COMPANIA AND CICLO        = :CICLO AND ANO          = :ANO AND PERIODO      = :PERIODO AND CODIGORUTA   = :CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORASEO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sphistoriaexterna/vlraseoporcicloanoperiodo">
		<call-query href="updateSphistoriaexternaVlraseoporcicloanoperiodo">
			<with-param name="VALORASEO" query-param="VALORASEO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSphistoriaexternaTodasPorNitQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FACTURA  FROM SP_HISTORIA_EXTERNA WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND ANO = :ANO AND PERIODO = :PERIODO AND ID_EMPRESA = :NIT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FACTURA":"$FACTURA(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoriaexterna/todaspornit">
		<call-query href="getSphistoriaexternaTodasPorNitQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NIT" query-param="NIT"/>

		</call-query>
	</resource>
	<query id="insertSphistoriaexternaNovedadesExternas" keyColumns="COMPANIA,CICLO,CODIGORUTA,ANO,PERIODO,ID_EMPRESA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_HISTORIA_EXTERNA (COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, ID_EMPRESA, CODIGO, FECHA_INICIO, FECHA_FIN, FECHA_GENERA, TARIFA, ESTRATO, CATEGORIA, VALORDEU, MESESMORA, INTMORA, FRECUENCIA_ASEO, FRECUENCIA_BARRIDO, VALORASEO_SINSUBOSOBRE, SUBOSOBRE, SUBOSOBRE_DES, VALORASEO, HISTORICO1, HISTORICO2, HISTORICO3, HISTORICO4, HISTORICO5, HISTORICO6, VALOR_FINAN, CUOTA_FINAN, UNIDADES_RESID, TDI_ASEO, BARRIDO_TBL, RECOLECCION_TRT, TRAMOEXCE_TTE, DISPOFINAL_TDT, MANEJOREC_TFR, REF01, TEX01, REF02, TEX02, REF03, TEX03, REF04, TEX04, REF05, TEX05, VALOR_COB, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CICLO, :CODIGORUTA, :ANO, :PERIODO, :ID_EMPRESA, :CODIGO, TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_GENERA,'DD/MM/YYYY HH24:MI:SS'), :TARIFA, :ESTRATO, :CATEGORIA, :VALORDEU, :MESESMORA, :INTMORA, :FRECUENCIA_ASEO, :FRECUENCIA_BARRIDO, :VALORASEO_SINSUBOSOBRE, :SUBOSOBRE, :SUBOSOBRE_DES, :VALORASEO, :HISTORICO1, :HISTORICO2, :HISTORICO3, :HISTORICO4, :HISTORICO5, :HISTORICO6, :VALOR_FINAN, :CUOTA_FINAN, :UNIDADES_RESID, :TDI_ASEO, :BARRIDO_TBL, :RECOLECCION_TRT, :TRAMOEXCE_TTE, :DISPOFINAL_TDT, :MANEJOREC_TFR, :REF01, :TEX01, :REF02, :TEX02, :REF03, :TEX03, :REF04, :TEX04, :REF05, :TEX05, :VALOR_COB, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_ID_EMPRESA":"$ID_EMPRESA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_EMPRESA" sqlType="STRING"/>
