<data name="sfdetalleacuerdo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfdetalleacuerdoDetallesacuerdopagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, TIPO_AP, CODIGO_AP, CUOTA,(TO_CHAR(FECHACUOTA,'DD/MM/YYYY HH24:MI:SS')) FECHACUOTA, CAPITAL, INTERES, INT_FINANCIACION, INT_RECARGO, TOTAL_CUOTA, ESTADO, TIPOFACTURA, FACTURA_PAGO,(TO_CHAR(FECHA_PAGO,'DD/MM/YYYY HH24:MI:SS')) FECHA_PAGO, BANCO_PAGO  FROM SF_DETALLE_ACUERDO WHERE SF_DETALLE_ACUERDO.COMPANIA = :COMPANIA AND SF_DETALLE_ACUERDO.TIPO_AP = :TIPOACUERDO AND SF_DETALLE_ACUERDO.CODIGO_AP = :CODACUERDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_AP":"$TIPO_AP","CODIGO_AP":"$CODIGO_AP(type:long)","CUOTA":"$CUOTA(type:integer)","FECHACUOTA":"$FECHACUOTA","CAPITAL":"$CAPITAL","INTERES":"$INTERES","INT_FINANCIACION":"$INT_FINANCIACION","INT_RECARGO":"$INT_RECARGO","TOTAL_CUOTA":"$TOTAL_CUOTA","ESTADO":"$ESTADO","TIPOFACTURA":"$TIPOFACTURA","FACTURA_PAGO":"$FACTURA_PAGO(type:long)","FECHA_PAGO":"$FECHA_PAGO","BANCO_PAGO":"$BANCO_PAGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOACUERDO" sqlType="STRING"/>
		<param name="CODACUERDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetalleacuerdo/detallesacuerdopago">
		<call-query href="getSfdetalleacuerdoDetallesacuerdopagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOACUERDO" query-param="TIPOACUERDO"/>
			<with-param name="CODACUERDO" query-param="CODACUERDO"/>

		</call-query>
	</resource>
	<query id="getSfdetalleacuerdoTotalesdetallesapQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(CAPITAL),0) CAPITAL, NVL(SUM(INTERES),0) INTERES, NVL(SUM(INT_FINANCIACION),0) INT_FINANCIACION, NVL(SUM(INT_RECARGO),0) INT_RECARGO, NVL(SUM(TOTAL_CUOTA),0) TOTAL_CUOTA  FROM SF_DETALLE_ACUERDO WHERE SF_DETALLE_ACUERDO.COMPANIA = :COMPANIA AND SF_DETALLE_ACUERDO.TIPO_AP = :TIPOACUERDO AND SF_DETALLE_ACUERDO.CODIGO_AP = :CODACUERDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CAPITAL":"$CAPITAL(type:integer)","INTERES":"$INTERES(type:integer)","INT_FINANCIACION":"$INT_FINANCIACION(type:integer)","INT_RECARGO":"$INT_RECARGO(type:integer)","TOTAL_CUOTA":"$TOTAL_CUOTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOACUERDO" sqlType="STRING"/>
		<param name="CODACUERDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetalleacuerdo/totalesdetallesap">
		<call-query href="getSfdetalleacuerdoTotalesdetallesapQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOACUERDO" query-param="TIPOACUERDO"/>
			<with-param name="CODACUERDO" query-param="CODACUERDO"/>

		</call-query>
	</resource>
	<query id="getSfdetalleacuerdoEstadosAcuerdoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_DETALLE_ACUERDO.ESTADO, SF_DETALLE_ACUERDO.FACTURA_PAGO, SF_TIPO_COBRO.CODIGOEAN FROM SF_DETALLE_ACUERDO INNER JOIN SF_ACUERDO_PAGO ON SF_DETALLE_ACUERDO.COMPANIA = SF_ACUERDO_PAGO.COMPANIA AND SF_DETALLE_ACUERDO.TIPO_AP = SF_ACUERDO_PAGO.TIPO AND SF_DETALLE_ACUERDO.CODIGO_AP = SF_ACUERDO_PAGO.CODIGO LEFT JOIN SF_TIPO_COBRO ON SF_DETALLE_ACUERDO.COMPANIA = SF_TIPO_COBRO.COMPANIA AND SF_DETALLE_ACUERDO.TIPOFACTURA = SF_TIPO_COBRO.CODIGO WHERE SF_DETALLE_ACUERDO.COMPANIA = :COMPANIA AND SF_DETALLE_ACUERDO.TIPO_AP = :TIPO AND SF_DETALLE_ACUERDO.CODIGO_AP = :CODIGO AND SF_DETALLE_ACUERDO.CUOTA = :CUOTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO","FACTURA_PAGO":"$FACTURA_PAGO(type:long)","CODIGOEAN":"$CODIGOEAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetalleacuerdo/estadosacuerdo">
		<call-query href="getSfdetalleacuerdoEstadosAcuerdoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>

		</call-query>
	</resource>

</data>