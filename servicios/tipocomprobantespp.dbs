	<query id="getTipocomprobantesppTodosPorTipoCompQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE, TIPO_COMPROBPP.CLASE, TIPO_COMPROBPP.FORMATO,(CASE TIPO_COMPROBPP.TECEROIGUAL WHEN 0 THEN 'false' ELSE 'true' END) TECEROIGUAL,(CASE TIPO_COMPROBPP.TIPOVIGENCIAFUTURA WHEN 0 THEN 'false' ELSE 'true' END) TIPOVIGENCIAFUTURA FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CODIGO = :TIPOCOMP ORDER BY TIPO_COMPROBPP.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE":"$CLASE","FORMATO":"$FORMATO","TECEROIGUAL":"$TECEROIGUAL(type:boolean)","TIPOVIGENCIAFUTURA":"$TIPOVIGENCIAFUTURA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>

	</query>
