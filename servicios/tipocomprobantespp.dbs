	<query id="getTipocomprobantesppFormatoporclasecodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO ,FORMATO  FROM TIPO_COMPROBPP WHERE COMPANIA =:COMPANIA AND CLASE = 'RES' AND CODIGO = :CODIGO ORDER BY COMPANIA,CODIGO DESC</sql>
