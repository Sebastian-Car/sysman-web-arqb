	<query id="getTipocomprobantesppPagTodoUnionAllQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  'TODOS' CODIGO, 'TODOS' NOMBRE, 'A' ORDEN  FROM DUAL UNION ALL SELECT CODIGO, NOMBRE, NOMBRE FROM TIPO_COMPROBPP WHERE COMPANIA = :COMPANIA ORDER BY 3) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END)  LIKE UPPER( '%' || :ORDEN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ORDEN":"$ORDEN"}]}}		</result>
