	<query id="getTipocomprobantesppPagPoranioytipoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.TIPO, TO_CHAR(COMPROBANTE_PPTAL.FECHA ,'DD/MM/YYYY') FECHA, COMPROBANTE_PPTAL.DESCRIPCION  FROM TIPO_COMPROBPP INNER JOIN COMPROBANTE_PPTAL ON TIPO_COMPROBPP.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND TIPO_COMPROBPP.CODIGO = COMPROBANTE_PPTAL.TIPO WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND COMPROBANTE_PPTAL.ANO BETWEEN :ANOINICIAL AND :ANOFINAL ORDER BY COMPROBANTE_PPTAL.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
