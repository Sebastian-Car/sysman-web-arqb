		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CLASE = :CLASE AND TIPO_COMPROBPP.CODIGO &gt;= :CODIGOINICIAL ORDER BY TIPO_COMPROBPP.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
