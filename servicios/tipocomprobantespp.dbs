	<query id="getTipocomprobantesppPagGettipocomprobbmovimientoaccesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE, CASE WHEN ( NVL(MOVIMIENTOS_ACCESOS.VER, - 1) = -1 ) THEN 'true' ELSE 'false' END VER FROM TIPO_COMPROBPP LEFT JOIN MOVIMIENTOS_ACCESOS ON ( TIPO_COMPROBPP.COMPANIA = MOVIMIENTOS_ACCESOS.COMPANIA AND TIPO_COMPROBPP.CODIGO = MOVIMIENTOS_ACCESOS.TIPO AND MOVIMIENTOS_ACCESOS.USUARIO = :USUARIO) WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND MOVIMIENTOS_ACCESOS.APLICACION = :MODULO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VER IS NULL THEN ' ' ELSE UPPER(VER) END) LIKE UPPER(CONCAT(CONCAT('%',:VER), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VER":"$VER"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VER" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
