	<query id="getTipocomprobantesppCantidadCuentasPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA, TIPO_COMPROBPP_1.CLASE  FROM TIPO_COMPROBPP LEFT JOIN CLASECNTPRES ON TIPO_COMPROBPP.CLASE = CLASECNTPRES.CODIGO LEFT JOIN TIPO_COMPROBPP TIPO_COMPROBPP_1 ON CLASECNTPRES.CLASEAFECTAR = TIPO_COMPROBPP_1.CLASE WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CODIGO = :TIPOCOMP GROUP BY TIPO_COMPROBPP_1.CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)","CLASE":"$CLASE"}]}}		</result>
