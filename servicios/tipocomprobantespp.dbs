	<query id="getTipocomprobantesppPagEntreTiposYFechasDelComprobanteFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.TIPO  FROM TIPO_COMPROBPP INNER JOIN COMPROBANTE_PPTAL ON TIPO_COMPROBPP.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND TIPO_COMPROBPP.CODIGO = COMPROBANTE_PPTAL.TIPO WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.NUMERO &gt;= :COMPROBANTE AND TIPO_COMPROBPP.CODIGO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND COMPROBANTE_PPTAL.FECHA BETWEEN TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS') AND TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') ORDER BY COMPROBANTE_PPTAL.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","TIPO":"$TIPO"}]}}		</result>
