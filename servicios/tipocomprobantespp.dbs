	<query id="getTipocomprobantesppPagTodosPorMovimientosContablesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPO_COMPROBPP.CODIGO,TIPO_COMPROBPP.NOMBRE,TIPO_COMPROBPP.CLASE, TIPO_COMPROBPP.FORMATO,(CASE TIPO_COMPROBPP.TECEROIGUAL WHEN 0 THEN 'false' ELSE 'true' END) TECEROIGUAL,(CASE TIPO_COMPROBPP.TIPOVIGENCIAFUTURA WHEN 0 THEN 'false' ELSE 'true' END) TIPOVIGENCIAFUTURA FROM TIPO_COMPROBPP FULL JOIN MOVIMIENTOS_ACCESOS ON ( TIPO_COMPROBPP.COMPANIA = MOVIMIENTOS_ACCESOS.COMPANIA AND TIPO_COMPROBPP.CODIGO = MOVIMIENTOS_ACCESOS.TIPO AND MOVIMIENTOS_ACCESOS.USUARIO = :USUARIO ) WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CLASE = :OPCIONMENU AND (MOVIMIENTOS_ACCESOS.VER IS NULL OR MOVIMIENTOS_ACCESOS.VER = -1 AND MOVIMIENTOS_ACCESOS.APLICACION = :MODULO) ORDER BY TIPO_COMPROBPP.NOMBRE) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE":"$CLASE","FORMATO":"$FORMATO","TECEROIGUAL":"$TECEROIGUAL(type:boolean)","TIPOVIGENCIAFUTURA":"$TIPOVIGENCIAFUTURA(type:boolean)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="OPCIONMENU" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todospormovimientoscontables/pag">
