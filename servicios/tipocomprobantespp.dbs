	<query id="getTipocomprobantesppCodynombreporclasesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM TIPO_COMPROBPP WHERE COMPANIA = :COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(NVL(:CLASES,CLASE)), CLASE, 1) &gt; 0 ORDER BY NOMBRE</sql>
