	<query id="getTipocomprobantesppClasesPresupuestalesAfectarQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOS_AFECTAR.CODIGO, TIPOS_AFECTAR.NOMBRE, TIPOS_AFECTAR.CLASE  FROM TIPO_COMPROBPP INNER JOIN CLASECNTPRES ON TIPO_COMPROBPP.CLASE = CLASECNTPRES.CODIGO INNER JOIN TIPO_COMPROBPP TIPOS_AFECTAR ON CLASECNTPRES.CLASEAFECTAR = TIPOS_AFECTAR.CLASE WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CODIGO = :TIPO GROUP BY TIPOS_AFECTAR.CODIGO, TIPOS_AFECTAR.NOMBRE, TIPOS_AFECTAR.CLASE ORDER BY TIPOS_AFECTAR.CODIGO</sql>
