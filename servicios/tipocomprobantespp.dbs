<data name="tipocomprobantespp" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipocomprobantesppPagTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, FORMATO  FROM TIPO_COMPROBPP WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FORMATO":"$FORMATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todos/pag">
		<call-query href="getTipocomprobantesppPagTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppNumTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, FORMATO  FROM TIPO_COMPROBPP WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todos/num">
		<call-query href="getTipocomprobantesppNumTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppTodosResQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE  FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CLASE IN ('RES') ORDER BY TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todosres">
		<call-query href="getTipocomprobantesppTodosResQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppTodosDisQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE  FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CLASE IN ('DIS') ORDER BY TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todosdis">
		<call-query href="getTipocomprobantesppTodosDisQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppPagTodosDisResQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE, TIPO_COMPROBPP.CLASE  FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CLASE IN ('DIS' , 'RES' ) ORDER BY TIPO_COMPROBPP.COMPANIA, TIPO_COMPROBPP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE":"$CLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todosdisres/pag">
		<call-query href="getTipocomprobantesppPagTodosDisResQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppNumTodosDisResQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE, TIPO_COMPROBPP.CLASE  FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CLASE IN ('DIS' , 'RES' ) ORDER BY TIPO_COMPROBPP.COMPANIA, TIPO_COMPROBPP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todosdisres/num">
		<call-query href="getTipocomprobantesppNumTodosDisResQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_COMPROBPP.CODIGO, TIPO_COMPROBPP.NOMBRE  FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/todosporcompania">
		<call-query href="getTipocomprobantesppTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppPagCodigonombreordcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM TIPO_COMPROBPP WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/codigonombreordcodigo/pag">
		<call-query href="getTipocomprobantesppPagCodigonombreordcodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppNumCodigonombreordcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM TIPO_COMPROBPP WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/codigonombreordcodigo/num">
		<call-query href="getTipocomprobantesppNumCodigonombreordcodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertTipocomprobantespp" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPO_COMPROBPP (COMPANIA, CODIGO, NOMBRE, CLASE, OBLIGAAFECTACION, TECEROIGUAL, AUTOMATICO, TIPOVIGENCIAFUTURA, FORMATO, SOLO_AFECT_PPTAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :CLASE, :OBLIGAAFECTACION, :TECEROIGUAL, :AUTOMATICO, :TIPOVIGENCIAFUTURA, :FORMATO, :SOLO_AFECT_PPTAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CLASE" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGAAFECTACION" sqlType="STRING"/>
		<param defaultValue="0" name="TECEROIGUAL" sqlType="STRING"/>
		<param defaultValue="0" name="AUTOMATICO" sqlType="STRING"/>
		<param defaultValue="0" name="TIPOVIGENCIAFUTURA" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO" sqlType="STRING"/>
		<param defaultValue="0" name="SOLO_AFECT_PPTAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tipocomprobantespp">
		<call-query href="insertTipocomprobantespp">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="OBLIGAAFECTACION" query-param="OBLIGAAFECTACION"/>
			<with-param name="TECEROIGUAL" query-param="TECEROIGUAL"/>
			<with-param name="AUTOMATICO" query-param="AUTOMATICO"/>
			<with-param name="TIPOVIGENCIAFUTURA" query-param="TIPOVIGENCIAFUTURA"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="SOLO_AFECT_PPTAL" query-param="SOLO_AFECT_PPTAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTipocomprobantespp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA= :KEY_COMPANIA AND TIPO_COMPROBPP.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tipocomprobantespp">
		<call-query href="deleteTipocomprobantespp">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,CODIGO,NOMBRE,CLASE,(CASE OBLIGAAFECTACION WHEN 0 THEN 'false' ELSE 'true' END) OBLIGAAFECTACION,(CASE TECEROIGUAL WHEN 0 THEN 'false' ELSE 'true' END) TECEROIGUAL,(CASE AUTOMATICO WHEN 0 THEN 'false' ELSE 'true' END) AUTOMATICO,(CASE TIPOVIGENCIAFUTURA WHEN 0 THEN 'false' ELSE 'true' END) TIPOVIGENCIAFUTURA,FORMATO  FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%')  AND (CASE WHEN FORMATO IS NULL THEN ' ' ELSE UPPER(FORMATO) END)  LIKE UPPER( '%' || :FORMATO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE":"$CLASE","OBLIGAAFECTACION":"$OBLIGAAFECTACION(type:boolean)","TECEROIGUAL":"$TECEROIGUAL(type:boolean)","AUTOMATICO":"$AUTOMATICO(type:boolean)","TIPOVIGENCIAFUTURA":"$TIPOVIGENCIAFUTURA(type:boolean)","FORMATO":"$FORMATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantespp">
		<call-query href="getTipocomprobantesppPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA,CODIGO,NOMBRE,CLASE,(CASE OBLIGAAFECTACION WHEN 0 THEN 'false' ELSE 'true' END) OBLIGAAFECTACION,(CASE TECEROIGUAL WHEN 0 THEN 'false' ELSE 'true' END) TECEROIGUAL,(CASE AUTOMATICO WHEN 0 THEN 'false' ELSE 'true' END) AUTOMATICO,(CASE TIPOVIGENCIAFUTURA WHEN 0 THEN 'false' ELSE 'true' END) TIPOVIGENCIAFUTURA,FORMATO  FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN FORMATO IS NULL THEN ' ' ELSE UPPER(FORMATO) END)  LIKE UPPER( '%' || :FORMATO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/numero">
		<call-query href="getTipocomprobantesppNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="FORMATO" query-param="FORMATO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesppRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA,CODIGO,NOMBRE,CLASE,(CASE OBLIGAAFECTACION WHEN 0 THEN 'false' ELSE 'true' END) OBLIGAAFECTACION,(CASE TECEROIGUAL WHEN 0 THEN 'false' ELSE 'true' END) TECEROIGUAL,(CASE AUTOMATICO WHEN 0 THEN 'false' ELSE 'true' END) AUTOMATICO,(CASE TIPOVIGENCIAFUTURA WHEN 0 THEN 'false' ELSE 'true' END) TIPOVIGENCIAFUTURA,FORMATO,(CASE SOLO_AFECT_PPTAL WHEN 0 THEN 'false' ELSE 'true' END) SOLO_AFECT_PPTAL,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,CREATED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,MODIFIED_BY FROM TIPO_COMPROBPP WHERE TIPO_COMPROBPP.COMPANIA= :KEY_COMPANIA AND TIPO_COMPROBPP.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE":"$CLASE","OBLIGAAFECTACION":"$OBLIGAAFECTACION(type:boolean)","TECEROIGUAL":"$TECEROIGUAL(type:boolean)","AUTOMATICO":"$AUTOMATICO(type:boolean)","TIPOVIGENCIAFUTURA":"$TIPOVIGENCIAFUTURA(type:boolean)","FORMATO":"$FORMATO","SOLO_AFECT_PPTAL":"$SOLO_AFECT_PPTAL(type:boolean)","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantespp/data">
		<call-query href="getTipocomprobantesppRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateTipocomprobantespp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPO_COMPROBPP SET NOMBRE=:NOMBRE, CLASE=:CLASE, OBLIGAAFECTACION=:OBLIGAAFECTACION, TECEROIGUAL=:TECEROIGUAL, AUTOMATICO=:AUTOMATICO, TIPOVIGENCIAFUTURA=:TIPOVIGENCIAFUTURA, FORMATO=:FORMATO, SOLO_AFECT_PPTAL=:SOLO_AFECT_PPTAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPO_COMPROBPP.COMPANIA= :KEY_COMPANIA AND TIPO_COMPROBPP.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="OBLIGAAFECTACION" sqlType="STRING"/>
		<param name="TECEROIGUAL" sqlType="STRING"/>
		<param name="AUTOMATICO" sqlType="STRING"/>
		<param name="TIPOVIGENCIAFUTURA" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="SOLO_AFECT_PPTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipocomprobantespp">
		<call-query href="updateTipocomprobantespp">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="OBLIGAAFECTACION" query-param="OBLIGAAFECTACION"/>
			<with-param name="TECEROIGUAL" query-param="TECEROIGUAL"/>
			<with-param name="AUTOMATICO" query-param="AUTOMATICO"/>
			<with-param name="TIPOVIGENCIAFUTURA" query-param="TIPOVIGENCIAFUTURA"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="SOLO_AFECT_PPTAL" query-param="SOLO_AFECT_PPTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
