	<query id="getNatdatospersonalesPagMedicinaPrepagadaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO2,CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRE,(TO_CHAR(PERSONAL.FECHAMEDICINA,'DD/MM/YYYY HH24:MI:SS')) FECHAMEDICINA, NAT_DATOS_PERSONALES.MEDICINA_PREPAGADA, NAT_DATOS_PERSONALES.COMPANIA, NAT_DATOS_PERSONALES.NUMERO_DCTO, NAT_DATOS_PERSONALES.SUCURSAL, V_MEDICINA_PREPAGADA.NOMBRE_MEDICINA NOMBREFONDO FROM NAT_DATOS_PERSONALES INNER JOIN PERSONAL ON NAT_DATOS_PERSONALES.COMPANIA = PERSONAL.COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO = PERSONAL.NUMERO_DCTO AND NAT_DATOS_PERSONALES.CODIGO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN V_MEDICINA_PREPAGADA ON NAT_DATOS_PERSONALES.COMPANIA = V_MEDICINA_PREPAGADA.COMPANIA AND NAT_DATOS_PERSONALES.MEDICINA_PREPAGADA = V_MEDICINA_PREPAGADA.MEDICINA_PREPAGADA WHERE NAT_DATOS_PERSONALES.COMPANIA =:COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO =:NUMERO_DCTO AND NAT_DATOS_PERSONALES.SUCURSAL =:SUCURSAL) INI WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHAMEDICINA IS NULL THEN ' ' ELSE UPPER(FECHAMEDICINA) END) LIKE UPPER(CONCAT(:FECHAMEDICINA, '%')) AND (CASE WHEN NOMBREFONDO IS NULL THEN ' ' ELSE UPPER(NOMBREFONDO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFONDO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","FECHAMEDICINA":"$FECHAMEDICINA","MEDICINA_PREPAGADA":"$MEDICINA_PREPAGADA","COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NOMBREFONDO":"$NOMBREFONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAMEDICINA" sqlType="STRING"/>
		<param name="NOMBREFONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natdatospersonales/medicinaprepagada/pag">
		<call-query href="getNatdatospersonalesPagMedicinaPrepagadaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHAMEDICINA" query-param="FECHAMEDICINA"/>
			<with-param name="NOMBREFONDO" query-param="NOMBREFONDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatdatospersonalesNumMedicinaPrepagadaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO2,CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRE,(TO_CHAR(PERSONAL.FECHAMEDICINA,'DD/MM/YYYY HH24:MI:SS')) FECHAMEDICINA, NAT_DATOS_PERSONALES.MEDICINA_PREPAGADA, NAT_DATOS_PERSONALES.COMPANIA, NAT_DATOS_PERSONALES.NUMERO_DCTO, NAT_DATOS_PERSONALES.SUCURSAL, V_MEDICINA_PREPAGADA.NOMBRE_MEDICINA NOMBREFONDO FROM NAT_DATOS_PERSONALES INNER JOIN PERSONAL ON NAT_DATOS_PERSONALES.COMPANIA = PERSONAL.COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO = PERSONAL.NUMERO_DCTO AND NAT_DATOS_PERSONALES.CODIGO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN V_MEDICINA_PREPAGADA ON NAT_DATOS_PERSONALES.COMPANIA = V_MEDICINA_PREPAGADA.COMPANIA AND NAT_DATOS_PERSONALES.MEDICINA_PREPAGADA = V_MEDICINA_PREPAGADA.MEDICINA_PREPAGADA WHERE NAT_DATOS_PERSONALES.COMPANIA =:COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO =:NUMERO_DCTO AND NAT_DATOS_PERSONALES.SUCURSAL =:SUCURSAL) INI WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHAMEDICINA IS NULL THEN ' ' ELSE UPPER(FECHAMEDICINA) END) LIKE UPPER(CONCAT(:FECHAMEDICINA, '%')) AND (CASE WHEN NOMBREFONDO IS NULL THEN ' ' ELSE UPPER(NOMBREFONDO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFONDO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAMEDICINA" sqlType="STRING"/>
		<param name="NOMBREFONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natdatospersonales/medicinaprepagada/num">
		<call-query href="getNatdatospersonalesNumMedicinaPrepagadaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHAMEDICINA" query-param="FECHAMEDICINA"/>
			<with-param name="NOMBREFONDO" query-param="NOMBREFONDO"/>

		</call-query>
	</resource>
	<query id="updateNatdatospersonalesMedicinaPrepagada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_DATOS_PERSONALES SET FECHA_MEDICINA=TO_DATE(:FECHA_MEDICINA,'DD/MM/YYYY HH24:MI:SS'), MEDICINA_PREPAGADA=:MEDICINA_PREPAGADA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_DATOS_PERSONALES.COMPANIA= :KEY_COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_DATOS_PERSONALES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_MEDICINA" sqlType="STRING"/>
		<param name="MEDICINA_PREPAGADA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natdatospersonales/medicinaprepagada">
		<call-query href="updateNatdatospersonalesMedicinaPrepagada">
			<with-param name="FECHA_MEDICINA" query-param="FECHA_MEDICINA"/>
			<with-param name="MEDICINA_PREPAGADA" query-param="MEDICINA_PREPAGADA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatdatospersonalesPagNumerocarpetadctonombresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMEROCARPETA, NUMERO_DCTO, UPPER(CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRECOMPLETO, SUCURSAL, COMPANIA FROM NAT_DATOS_PERSONALES WHERE NUMEROCARPETA IS NOT NULL AND COMPANIA =:COMPANIA ORDER BY NUMEROCARPETA, UPPER(CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) )) INI WHERE (CASE WHEN NUMEROCARPETA IS NULL THEN ' ' ELSE UPPER(NUMEROCARPETA) END) LIKE UPPER(CONCAT(:NUMEROCARPETA, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMEROCARPETA":"$NUMEROCARPETA","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","SUCURSAL":"$SUCURSAL","COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROCARPETA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
