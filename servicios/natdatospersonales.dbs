	<query id="deleteNatdatospersonales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_DATOS_PERSONALES WHERE NAT_DATOS_PERSONALES.COMPANIA= :KEY_COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_DATOS_PERSONALES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natdatospersonales">
		<call-query href="deleteNatdatospersonales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatdatospersonalesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, SUCURSAL, NUMERO_DCTO, CODIGO, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO, CASE WHEN SEXO = 'M' THEN 'MASCULINO' ELSE 'FEMENINO' END SEXO, DIRECCION, TELEFONOS FROM NAT_DATOS_PERSONALES WHERE COMPANIA =:COMPANIA ORDER BY NUMERO_DCTO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN SEXO IS NULL THEN ' ' ELSE UPPER(SEXO) END) LIKE UPPER(CONCAT(CONCAT('%',:SEXO), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN TELEFONOS IS NULL THEN ' ' ELSE UPPER(TELEFONOS) END) LIKE UPPER(CONCAT(CONCAT('%',:TELEFONOS), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NUMERO_DCTO":"$NUMERO_DCTO","CODIGO":"$CODIGO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","SEXO":"$SEXO","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="SEXO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TELEFONOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natdatospersonales">
		<call-query href="getNatdatospersonalesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="SEXO" query-param="SEXO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TELEFONOS" query-param="TELEFONOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatdatospersonalesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, SUCURSAL, NUMERO_DCTO, CODIGO, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO, CASE WHEN SEXO = 'M' THEN 'MASCULINO' ELSE 'FEMENINO' END SEXO, DIRECCION, TELEFONOS FROM NAT_DATOS_PERSONALES WHERE COMPANIA =:COMPANIA ORDER BY NUMERO_DCTO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN SEXO IS NULL THEN ' ' ELSE UPPER(SEXO) END) LIKE UPPER(CONCAT(CONCAT('%',:SEXO), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN TELEFONOS IS NULL THEN ' ' ELSE UPPER(TELEFONOS) END) LIKE UPPER(CONCAT(CONCAT('%',:TELEFONOS), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="SEXO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TELEFONOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natdatospersonales/numero">
		<call-query href="getNatdatospersonalesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="SEXO" query-param="SEXO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TELEFONOS" query-param="TELEFONOS"/>

		</call-query>
	</resource>
	<query id="getNatdatospersonalesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_DATOS_PERSONALES.COMPANIA , NAT_DATOS_PERSONALES.NUMERO_DCTO , NAT_DATOS_PERSONALES.SUCURSAL , NAT_DATOS_PERSONALES.CODIGO , NAT_DATOS_PERSONALES.APELLIDO1 , NAT_DATOS_PERSONALES.APELLIDO2 , NAT_DATOS_PERSONALES.NOMBRES , NAT_DATOS_PERSONALES.DCTO_IDENTIDAD , NAT_DATOS_PERSONALES.EXPEDIDA , NAT_DATOS_PERSONALES.PAISEXTRANJERO , NAT_DATOS_PERSONALES.SEXO , NAT_DATOS_PERSONALES.ANO , NAT_DATOS_PERSONALES.CLASELIBMILITAR , NAT_DATOS_PERSONALES.NUMLIBMILITAR , NAT_DATOS_PERSONALES.DISTRITOMILITAR , NAT_DATOS_PERSONALES.PAISNCTO , NAT_DATOS_PERSONALES.DEPTONCTO , NAT_DATOS_PERSONALES.MUNICIPIONCTO , NAT_DATOS_PERSONALES.PAISRESIDE , NAT_DATOS_PERSONALES.DEPTORESIDE , NAT_DATOS_PERSONALES.MUNICIPIORESIDE , NAT_DATOS_PERSONALES.DIRECCION , NAT_DATOS_PERSONALES.TELEFONOS , NAT_DATOS_PERSONALES.ESTADO_CIVIL , NAT_DATOS_PERSONALES.PERSONAS , NAT_DATOS_PERSONALES.PUBLICACIONES ,(CASE NAT_DATOS_PERSONALES.INHABILIDADES WHEN 0 THEN 'false' ELSE 'true' END) INHABILIDADES, NAT_DATOS_PERSONALES.FOTO , NAT_DATOS_PERSONALES.OBSERVACIONES , NAT_DATOS_PERSONALES.JEFEPERSONAL ,(CASE NAT_DATOS_PERSONALES.FIRMAJEFEPER WHEN 0 THEN 'false' ELSE 'true' END) FIRMAJEFEPER, NAT_DATOS_PERSONALES.GRUPOSANGUINEO , NAT_DATOS_PERSONALES.RH , NAT_DATOS_PERSONALES.CERTIFICADOJUDICIAL , NAT_DATOS_PERSONALES.FORMAVINCULACION , NAT_DATOS_PERSONALES.LICENCIACONDUCCION , NAT_DATOS_PERSONALES.ALERGIAS , NAT_DATOS_PERSONALES.BARRIO , NAT_DATOS_PERSONALES.MEDICOTRATANTE , NAT_DATOS_PERSONALES.ESTRATO , NAT_DATOS_PERSONALES.AC_ANOS , NAT_DATOS_PERSONALES.DIRECCIONRESIDENCIA ,(CASE NAT_DATOS_PERSONALES.PROPIETARIO WHEN 0 THEN 'false' ELSE 'true' END) PROPIETARIO, NAT_DATOS_PERSONALES.EMAIL , NAT_DATOS_PERSONALES.TELEFONORESIDENCIA , NAT_DATOS_PERSONALES.DPTOEXPCEDULA , NAT_DATOS_PERSONALES.NUMEROCARPETA , NAT_DATOS_PERSONALES.CUENTA , NAT_DATOS_PERSONALES.BANCO , NAT_DATOS_PERSONALES.TIPOCUENTA , NAT_DATOS_PERSONALES.ANOPB , NAT_DATOS_PERSONALES.MESPB , NAT_DATOS_PERSONALES.DIASPB , NAT_DATOS_PERSONALES.ANOPV , NAT_DATOS_PERSONALES.MESPV , NAT_DATOS_PERSONALES.DIASPV , NAT_DATOS_PERSONALES.ANOTI , NAT_DATOS_PERSONALES.MESTI , NAT_DATOS_PERSONALES.DIASTI , NAT_DATOS_PERSONALES.ID_CENTROS_DE_COSTO , NAT_DATOS_PERSONALES.MEDICINA_PREPAGADA , NAT_DATOS_PERSONALES.FONDO_SINDICATO ,(CASE NAT_DATOS_PERSONALES.SINDICATO WHEN 0 THEN 'false' ELSE 'true' END) SINDICATO, NAT_DATOS_PERSONALES.NIT_ESTABLECIMIENTO_DOCENTES , NAT_DATOS_PERSONALES.REGIMEN , NAT_DATOS_PERSONALES.GRUPO_SANGUINEO , NAT_DATOS_PERSONALES.CIUDAD_CUENTA , NAT_DATOS_PERSONALES.GRUPOCONTABLE , NAT_DATOS_PERSONALES.PROCESORETENCION , NAT_DATOS_PERSONALES.ID_DE_TIPO , NAT_DATOS_PERSONALES.TIPO_SALARIO , NAT_DATOS_PERSONALES.AREAMISOADM , NAT_DATOS_PERSONALES.TIPOACTIVIDAD , NAT_DATOS_PERSONALES.SEDE , NAT_DATOS_PERSONALES.NIVELSIIF ,(CASE NAT_DATOS_PERSONALES.DEPENDIENTES384 WHEN 0 THEN 'false' ELSE 'true' END) DEPENDIENTES384,(CASE NAT_DATOS_PERSONALES.DECLARANTES384 WHEN 0 THEN 'false' ELSE 'true' END) DECLARANTES384,(CASE NAT_DATOS_PERSONALES.RETE_MINIMA WHEN 0 THEN 'false' ELSE 'true' END) RETE_MINIMA,(CASE NAT_DATOS_PERSONALES.ASALARIADO_NOEMPLEADOS WHEN 0 THEN 'false' ELSE 'true' END) ASALARIADO_NOEMPLEADOS, NAT_DATOS_PERSONALES.NUMEROPATRONAL , NAT_DATOS_PERSONALES.CREATED_BY , NAT_DATOS_PERSONALES.MODIFIED_BY ,(TO_CHAR(NAT_DATOS_PERSONALES.FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHAINGRESO,(TO_CHAR(NAT_DATOS_PERSONALES.FECHARETIRO,'DD/MM/YYYY HH24:MI:SS')) FECHARETIRO,(TO_CHAR(NAT_DATOS_PERSONALES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(NAT_DATOS_PERSONALES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NAT_DATOS_PERSONALES.FECHA_RETE_MINIMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_RETE_MINIMA,(TO_CHAR(NAT_DATOS_PERSONALES.FECHA_DECLARANTES384,'DD/MM/YYYY HH24:MI:SS')) FECHA_DECLARANTES384,(TO_CHAR(NAT_DATOS_PERSONALES.FECHANCTO,'DD/MM/YYYY HH24:MI:SS')) FECHANCTO,(TO_CHAR(NAT_DATOS_PERSONALES.FECHA_MEDICINA,'DD/MM/YYYY HH24:MI:SS')) FECHA_MEDICINA,(TO_CHAR(NAT_DATOS_PERSONALES.FECHATERCONTRATO,'DD/MM/YYYY HH24:MI:SS')) FECHATERCONTRATO,(TO_CHAR(NAT_DATOS_PERSONALES.FECHA_DEPENDIENTES384,'DD/MM/YYYY HH24:MI:SS')) FECHA_DEPENDIENTES384, NAT_DATOS_PERSONALES.NACIONALIDAD, NAT_DATOS_PERSONALES.PAIS_LABORA, NAT_DATOS_PERSONALES.DEPARAMENTO_LABORA, NAT_DATOS_PERSONALES.CIUDAD_LABORA, NAT_DATOS_PERSONALES.CORREOCORPORATIVO  FROM NAT_DATOS_PERSONALES WHERE NAT_DATOS_PERSONALES.COMPANIA= :KEY_COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_DATOS_PERSONALES.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","CODIGO":"$CODIGO","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRES":"$NOMBRES","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","EXPEDIDA":"$EXPEDIDA","PAISEXTRANJERO":"$PAISEXTRANJERO","SEXO":"$SEXO","ANO":"$ANO(type:integer)","CLASELIBMILITAR":"$CLASELIBMILITAR","NUMLIBMILITAR":"$NUMLIBMILITAR","DISTRITOMILITAR":"$DISTRITOMILITAR","PAISNCTO":"$PAISNCTO","DEPTONCTO":"$DEPTONCTO","MUNICIPIONCTO":"$MUNICIPIONCTO","PAISRESIDE":"$PAISRESIDE","DEPTORESIDE":"$DEPTORESIDE","MUNICIPIORESIDE":"$MUNICIPIORESIDE","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","ESTADO_CIVIL":"$ESTADO_CIVIL","PERSONAS":"$PERSONAS(type:integer)","PUBLICACIONES":"$PUBLICACIONES","INHABILIDADES":"$INHABILIDADES(type:boolean)","FOTO":"$FOTO","OBSERVACIONES":"$OBSERVACIONES","JEFEPERSONAL":"$JEFEPERSONAL","FIRMAJEFEPER":"$FIRMAJEFEPER(type:boolean)","GRUPOSANGUINEO":"$GRUPOSANGUINEO","RH":"$RH","CERTIFICADOJUDICIAL":"$CERTIFICADOJUDICIAL","FORMAVINCULACION":"$FORMAVINCULACION","LICENCIACONDUCCION":"$LICENCIACONDUCCION","ALERGIAS":"$ALERGIAS","BARRIO":"$BARRIO","MEDICOTRATANTE":"$MEDICOTRATANTE","ESTRATO":"$ESTRATO","AC_ANOS":"$AC_ANOS(type:integer)","DIRECCIONRESIDENCIA":"$DIRECCIONRESIDENCIA","PROPIETARIO":"$PROPIETARIO(type:boolean)","EMAIL":"$EMAIL","TELEFONORESIDENCIA":"$TELEFONORESIDENCIA","DPTOEXPCEDULA":"$DPTOEXPCEDULA","NUMEROCARPETA":"$NUMEROCARPETA","CUENTA":"$CUENTA","BANCO":"$BANCO","TIPOCUENTA":"$TIPOCUENTA","ANOPB":"$ANOPB(type:integer)","MESPB":"$MESPB(type:integer)","DIASPB":"$DIASPB(type:integer)","ANOPV":"$ANOPV(type:integer)","MESPV":"$MESPV(type:integer)","DIASPV":"$DIASPV(type:integer)","ANOTI":"$ANOTI(type:integer)","MESTI":"$MESTI(type:integer)","DIASTI":"$DIASTI(type:integer)","ID_CENTROS_DE_COSTO":"$ID_CENTROS_DE_COSTO","MEDICINA_PREPAGADA":"$MEDICINA_PREPAGADA","FONDO_SINDICATO":"$FONDO_SINDICATO","SINDICATO":"$SINDICATO(type:boolean)","NIT_ESTABLECIMIENTO_DOCENTES":"$NIT_ESTABLECIMIENTO_DOCENTES","REGIMEN":"$REGIMEN","GRUPO_SANGUINEO":"$GRUPO_SANGUINEO","CIUDAD_CUENTA":"$CIUDAD_CUENTA","GRUPOCONTABLE":"$GRUPOCONTABLE","PROCESORETENCION":"$PROCESORETENCION","ID_DE_TIPO":"$ID_DE_TIPO","TIPO_SALARIO":"$TIPO_SALARIO","AREAMISOADM":"$AREAMISOADM","TIPOACTIVIDAD":"$TIPOACTIVIDAD","SEDE":"$SEDE","NIVELSIIF":"$NIVELSIIF","DEPENDIENTES384":"$DEPENDIENTES384(type:boolean)","DECLARANTES384":"$DECLARANTES384(type:boolean)","RETE_MINIMA":"$RETE_MINIMA(type:boolean)","ASALARIADO_NOEMPLEADOS":"$ASALARIADO_NOEMPLEADOS(type:boolean)","NUMEROPATRONAL":"$NUMEROPATRONAL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","FECHAINGRESO":"$FECHAINGRESO","FECHARETIRO":"$FECHARETIRO","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","FECHA_RETE_MINIMA":"$FECHA_RETE_MINIMA","FECHA_DECLARANTES384":"$FECHA_DECLARANTES384","FECHANCTO":"$FECHANCTO","FECHA_MEDICINA":"$FECHA_MEDICINA","FECHATERCONTRATO":"$FECHATERCONTRATO","FECHA_DEPENDIENTES384":"$FECHA_DEPENDIENTES384","NACIONALIDAD":"$NACIONALIDAD","PAIS_LABORA":"$PAIS_LABORA","DEPARAMENTO_LABORA":"$DEPARAMENTO_LABORA","CIUDAD_LABORA":"$CIUDAD_LABORA","CORREOCORPORATIVO":"$CORREOCORPORATIVO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
