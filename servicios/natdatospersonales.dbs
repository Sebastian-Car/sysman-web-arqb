	<query id="getNatdatospersonalesPagPorCarpetaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NAT_DATOS_PERSONALES.NUMEROCARPETA, NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO FROM NAT_DATOS_PERSONALES WHERE NAT_DATOS_PERSONALES.COMPANIA =:COMPANIA AND NAT_DATOS_PERSONALES.NUMEROCARPETA IS NOT NULL ORDER BY NUMERO_DCTO) INI WHERE (CASE WHEN NUMEROCARPETA IS NULL THEN ' ' ELSE UPPER(NUMEROCARPETA) END) LIKE UPPER(CONCAT(:NUMEROCARPETA, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMEROCARPETA":"$NUMEROCARPETA","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROCARPETA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natdatospersonales/porcarpetainicial/pag">
