	<query id="updateNatdatospersonales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_DATOS_PERSONALES SET NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, CODIGO=:CODIGO, APELLIDO1=:APELLIDO1, APELLIDO2=:APELLIDO2, NOMBRES=:NOMBRES, DCTO_IDENTIDAD=:DCTO_IDENTIDAD, EXPEDIDA=:EXPEDIDA, PAISEXTRANJERO=:PAISEXTRANJERO, SEXO=:SEXO, ANO=:ANO, CLASELIBMILITAR=:CLASELIBMILITAR, NUMLIBMILITAR=:NUMLIBMILITAR, DISTRITOMILITAR=:DISTRITOMILITAR, PAISNCTO=:PAISNCTO, DEPTONCTO=:DEPTONCTO, MUNICIPIONCTO=:MUNICIPIONCTO, PAISRESIDE=:PAISRESIDE, DEPTORESIDE=:DEPTORESIDE, MUNICIPIORESIDE=:MUNICIPIORESIDE, DIRECCION=:DIRECCION, TELEFONOS=:TELEFONOS, ESTADO_CIVIL=:ESTADO_CIVIL, PERSONAS=:PERSONAS, PUBLICACIONES=:PUBLICACIONES, INHABILIDADES=:INHABILIDADES, FOTO=:FOTO, OBSERVACIONES=:OBSERVACIONES, JEFEPERSONAL=:JEFEPERSONAL, FIRMAJEFEPER=:FIRMAJEFEPER, GRUPOSANGUINEO=:GRUPOSANGUINEO, RH=:RH, CERTIFICADOJUDICIAL=:CERTIFICADOJUDICIAL, FORMAVINCULACION=:FORMAVINCULACION, LICENCIACONDUCCION=:LICENCIACONDUCCION, ALERGIAS=:ALERGIAS, BARRIO=:BARRIO, MEDICOTRATANTE=:MEDICOTRATANTE, ESTRATO=:ESTRATO, AC_ANOS=:AC_ANOS, DIRECCIONRESIDENCIA=:DIRECCIONRESIDENCIA, PROPIETARIO=:PROPIETARIO, EMAIL=:EMAIL, TELEFONORESIDENCIA=:TELEFONORESIDENCIA, DPTOEXPCEDULA=:DPTOEXPCEDULA, NUMEROCARPETA=:NUMEROCARPETA, CUENTA=:CUENTA, BANCO=:BANCO, TIPOCUENTA=:TIPOCUENTA, ANOPB=:ANOPB, MESPB=:MESPB, DIASPB=:DIASPB, ANOPV=:ANOPV, MESPV=:MESPV, DIASPV=:DIASPV, ANOTI=:ANOTI, MESTI=:MESTI, DIASTI=:DIASTI, ID_CENTROS_DE_COSTO=:ID_CENTROS_DE_COSTO, MEDICINA_PREPAGADA=:MEDICINA_PREPAGADA, FONDO_SINDICATO=:FONDO_SINDICATO, SINDICATO=:SINDICATO, NIT_ESTABLECIMIENTO_DOCENTES=:NIT_ESTABLECIMIENTO_DOCENTES, REGIMEN=:REGIMEN, GRUPO_SANGUINEO=:GRUPO_SANGUINEO, CIUDAD_CUENTA=:CIUDAD_CUENTA, GRUPOCONTABLE=:GRUPOCONTABLE, PROCESORETENCION=:PROCESORETENCION, ID_DE_TIPO=:ID_DE_TIPO, TIPO_SALARIO=:TIPO_SALARIO, AREAMISOADM=:AREAMISOADM, TIPOACTIVIDAD=:TIPOACTIVIDAD, SEDE=:SEDE, NIVELSIIF=:NIVELSIIF, DEPENDIENTES384=:DEPENDIENTES384, DECLARANTES384=:DECLARANTES384, RETE_MINIMA=:RETE_MINIMA, ASALARIADO_NOEMPLEADOS=:ASALARIADO_NOEMPLEADOS, NUMEROPATRONAL=:NUMEROPATRONAL, MODIFIED_BY=:MODIFIED_BY, FECHAINGRESO=TO_DATE(:FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS'), FECHARETIRO=TO_DATE(:FECHARETIRO,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHA_RETE_MINIMA=TO_DATE(:FECHA_RETE_MINIMA,'DD/MM/YYYY HH24:MI:SS'), FECHA_DECLARANTES384=TO_DATE(:FECHA_DECLARANTES384,'DD/MM/YYYY HH24:MI:SS'), FECHANCTO=TO_DATE(:FECHANCTO,'DD/MM/YYYY HH24:MI:SS'), FECHA_MEDICINA=TO_DATE(:FECHA_MEDICINA,'DD/MM/YYYY HH24:MI:SS'), FECHATERCONTRATO=TO_DATE(:FECHATERCONTRATO,'DD/MM/YYYY HH24:MI:SS'), FECHA_DEPENDIENTES384=TO_DATE(:FECHA_DEPENDIENTES384,'DD/MM/YYYY HH24:MI:SS'), NACIONALIDAD=:NACIONALIDAD, PAIS_LABORA=:PAIS_LABORA, DEPARAMENTO_LABORA=:DEPARAMENTO_LABORA, CIUDAD_LABORA=:CIUDAD_LABORA, CORREOCORPORATIVO=:CORREOCORPORATIVO WHERE NAT_DATOS_PERSONALES.COMPANIA= :KEY_COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_DATOS_PERSONALES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

