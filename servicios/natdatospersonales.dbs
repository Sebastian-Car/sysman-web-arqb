		<param defaultValue="" name="NUMLIBMILITAR" sqlType="STRING"/>
		<param defaultValue="" name="DISTRITOMILITAR" sqlType="STRING"/>
		<param defaultValue="" name="PAISNCTO" sqlType="STRING"/>
		<param defaultValue="" name="DEPTONCTO" sqlType="STRING"/>
		<param defaultValue="" name="MUNICIPIONCTO" sqlType="STRING"/>
		<param defaultValue="" name="PAISRESIDE" sqlType="STRING"/>
		<param defaultValue="" name="DEPTORESIDE" sqlType="STRING"/>
		<param defaultValue="" name="MUNICIPIORESIDE" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONOS" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO_CIVIL" sqlType="STRING"/>
		<param defaultValue="0" name="PERSONAS" sqlType="STRING"/>
		<param defaultValue="" name="PUBLICACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="INHABILIDADES" sqlType="STRING"/>
