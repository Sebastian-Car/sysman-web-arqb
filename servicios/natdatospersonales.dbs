			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROCARPETA" query-param="NUMEROCARPETA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertNatdatospersonales" keyColumns="COMPANIA,NUMERO_DCTO,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_DATOS_PERSONALES (COMPANIA, NUMERO_DCTO, SUCURSAL, CODIGO, APELLIDO1, APELLIDO2, NOMBRES, DCTO_IDENTIDAD, EXPEDIDA, PAISEXTRANJERO, SEXO, ANO, CLASELIBMILITAR, NUMLIBMILITAR, DISTRITOMILITAR, PAISNCTO, DEPTONCTO, MUNICIPIONCTO, PAISRESIDE, DEPTORESIDE, MUNICIPIORESIDE, DIRECCION, TELEFONOS, ESTADO_CIVIL, PERSONAS, PUBLICACIONES, INHABILIDADES, FOTO, OBSERVACIONES, JEFEPERSONAL, FIRMAJEFEPER, GRUPOSANGUINEO, RH, CERTIFICADOJUDICIAL, FORMAVINCULACION, LICENCIACONDUCCION, ALERGIAS, BARRIO, MEDICOTRATANTE, ESTRATO, AC_ANOS, DIRECCIONRESIDENCIA, PROPIETARIO, EMAIL, TELEFONORESIDENCIA, DPTOEXPCEDULA, NUMEROCARPETA, CUENTA, BANCO, TIPOCUENTA, ANOPB, MESPB, DIASPB, ANOPV, MESPV, DIASPV, ANOTI, MESTI, DIASTI, ID_CENTROS_DE_COSTO, MEDICINA_PREPAGADA, FONDO_SINDICATO, SINDICATO, NIT_ESTABLECIMIENTO_DOCENTES, REGIMEN, GRUPO_SANGUINEO, CIUDAD_CUENTA, GRUPOCONTABLE, PROCESORETENCION, ID_DE_TIPO, TIPO_SALARIO, AREAMISOADM, TIPOACTIVIDAD, SEDE, NIVELSIIF, DEPENDIENTES384, DECLARANTES384, RETE_MINIMA, ASALARIADO_NOEMPLEADOS, NUMEROPATRONAL, CREATED_BY, FECHAINGRESO, FECHARETIRO, DATE_CREATED, FECHA_RETE_MINIMA, FECHA_DECLARANTES384, FECHANCTO, FECHA_MEDICINA, FECHATERCONTRATO, FECHA_DEPENDIENTES384, PAIS_LABORA, DEPARAMENTO_LABORA, CIUDAD_LABORA, NACIONALIDAD, CORREOCORPORATIVO) VALUES (:COMPANIA, :NUMERO_DCTO, :SUCURSAL, :CODIGO, :APELLIDO1, :APELLIDO2, :NOMBRES, :DCTO_IDENTIDAD, :EXPEDIDA, :PAISEXTRANJERO, :SEXO, :ANO, :CLASELIBMILITAR, :NUMLIBMILITAR, :DISTRITOMILITAR, :PAISNCTO, :DEPTONCTO, :MUNICIPIONCTO, :PAISRESIDE, :DEPTORESIDE, :MUNICIPIORESIDE, :DIRECCION, :TELEFONOS, :ESTADO_CIVIL, :PERSONAS, :PUBLICACIONES, :INHABILIDADES, :FOTO, :OBSERVACIONES, :JEFEPERSONAL, :FIRMAJEFEPER, :GRUPOSANGUINEO, :RH, :CERTIFICADOJUDICIAL, :FORMAVINCULACION, :LICENCIACONDUCCION, :ALERGIAS, :BARRIO, :MEDICOTRATANTE, :ESTRATO, :AC_ANOS, :DIRECCIONRESIDENCIA, :PROPIETARIO, :EMAIL, :TELEFONORESIDENCIA, :DPTOEXPCEDULA, :NUMEROCARPETA, :CUENTA, :BANCO, :TIPOCUENTA, :ANOPB, :MESPB, :DIASPB, :ANOPV, :MESPV, :DIASPV, :ANOTI, :MESTI, :DIASTI, :ID_CENTROS_DE_COSTO, :MEDICINA_PREPAGADA, :FONDO_SINDICATO, :SINDICATO, :NIT_ESTABLECIMIENTO_DOCENTES, :REGIMEN, :GRUPO_SANGUINEO, :CIUDAD_CUENTA, :GRUPOCONTABLE, :PROCESORETENCION, :ID_DE_TIPO, :TIPO_SALARIO, :AREAMISOADM, :TIPOACTIVIDAD, :SEDE, :NIVELSIIF, :DEPENDIENTES384, :DECLARANTES384, :RETE_MINIMA, :ASALARIADO_NOEMPLEADOS, :NUMEROPATRONAL, :CREATED_BY, TO_DATE(:FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHARETIRO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_RETE_MINIMA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_DECLARANTES384,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHANCTO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_MEDICINA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHATERCONTRATO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_DEPENDIENTES384,'DD/MM/YYYY HH24:MI:SS'), :PAIS_LABORA, :DEPARAMENTO_LABORA, :CIUDAD_LABORA, :NACIONALIDAD, :CORREOCORPORATIVO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO1" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO2" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRES" sqlType="STRING"/>
		<param defaultValue="" name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="EXPEDIDA" sqlType="STRING"/>
		<param defaultValue="" name="PAISEXTRANJERO" sqlType="STRING"/>
		<param defaultValue="" name="SEXO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
