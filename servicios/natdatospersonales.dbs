	<query id="getNatdatospersonalesPagTodosPorPersonalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1, CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO2, CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRES, NAT_DATOS_PERSONALES.SUCURSAL, NAT_DATOS_PERSONALES.CODIGO  FROM NAT_DATOS_PERSONALES WHERE NAT_DATOS_PERSONALES.COMPANIA = :COMPANIA ORDER BY TO_NUMBER(CODIGO)) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRES":"$NOMBRES","SUCURSAL":"$SUCURSAL","CODIGO":"$CODIGO"}]}}		</result>
