	<query id="getNatdatospersonalesPagNumdctonombrecarpetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO_DCTO, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) FULLNAME, NUMEROCARPETA FROM NAT_DATOS_PERSONALES WHERE COMPANIA =:COMPANIA AND NUMEROCARPETA IS NOT NULL ORDER BY NUMERO_DCTO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN FULLNAME IS NULL THEN ' ' ELSE UPPER(FULLNAME) END) LIKE UPPER(CONCAT(CONCAT('%',:FULLNAME), '%')) AND (CASE WHEN NUMEROCARPETA IS NULL THEN ' ' ELSE UPPER(NUMEROCARPETA) END) LIKE UPPER(CONCAT(:NUMEROCARPETA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","FULLNAME":"$FULLNAME","NUMEROCARPETA":"$NUMEROCARPETA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="FULLNAME" sqlType="STRING"/>
		<param name="NUMEROCARPETA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
