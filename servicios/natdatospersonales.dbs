	<query id="getNatdatospersonalesNumPorCarpetaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NAT_DATOS_PERSONALES.NUMEROCARPETA, NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO FROM NAT_DATOS_PERSONALES WHERE NAT_DATOS_PERSONALES.COMPANIA =:COMPANIA AND NAT_DATOS_PERSONALES.NUMEROCARPETA IS NOT NULL ORDER BY NUMERO_DCTO) INI WHERE (CASE WHEN NUMEROCARPETA IS NULL THEN ' ' ELSE UPPER(NUMEROCARPETA) END) LIKE UPPER(CONCAT(:NUMEROCARPETA, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROCARPETA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natdatospersonales/porcarpetainicial/num">
		<call-query href="getNatdatospersonalesNumPorCarpetaInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROCARPETA" query-param="NUMEROCARPETA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>

		</call-query>
	</resource>
	<query id="getNatdatospersonalesPagPorCarpetaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NAT_DATOS_PERSONALES.NUMEROCARPETA, NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO FROM NAT_DATOS_PERSONALES WHERE NAT_DATOS_PERSONALES.COMPANIA =:COMPANIA AND NAT_DATOS_PERSONALES.NUMEROCARPETA IS NOT NULL AND NAT_DATOS_PERSONALES.NUMERO_DCTO &gt;=:NUMERO ORDER BY NUMERO_DCTO) INI WHERE (CASE WHEN NUMEROCARPETA IS NULL THEN ' ' ELSE UPPER(NUMEROCARPETA) END) LIKE UPPER(CONCAT(:NUMEROCARPETA, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMEROCARPETA":"$NUMEROCARPETA","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NUMEROCARPETA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
