	<query id="getNatdatospersonalesPagTodosPorUltimoCargoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NAT_NOMBRAMIENTO.DP_NUMEDOCU, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRES, NAT_DATOS_PERSONALES.SUCURSAL, MIN(NAT_NOMBRAMIENTO.NO_FECHRESODECR) AS PRIMERODENO_FECHRESODECR, MIN(NAT_NOMBRAMIENTO.NO_CODIGOCARGO) AS PRIMERODENO_CODIGOCARGO, MIN(NAT_NOMBRAMIENTO.NO_GRADOCARGO) AS PRIMERODENO_GRADOCARGO, MIN(NAT_NOMBRAMIENTO.NO_TIPO) AS PRIMERODENO_TIPO, MIN(NAT_NOMBRAMIENTO.NO_CARGON) AS PRIMERODENO_CARGON, MIN(NAT_NOMBRAMIENTO.NO_DEPENUEV) AS NO_DEPENUEV, MIN(NAT_NOMBRAMIENTO.NO_FECHAEFECTIVIDAD) AS PRIMERODENO_FECHAEFECTIVIDAD, NAT_DATOS_PERSONALES.CODIGO FROM NAT_DATOS_PERSONALES INNER JOIN NAT_NOMBRAMIENTO ON NAT_DATOS_PERSONALES.COMPANIA = NAT_NOMBRAMIENTO.COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO = NAT_NOMBRAMIENTO.DP_NUMEDOCU AND NAT_DATOS_PERSONALES.SUCURSAL = NAT_NOMBRAMIENTO.SUCURSAL INNER JOIN FORMANOMBRAMIENTO ON NAT_NOMBRAMIENTO.NO_TIPO = FORMANOMBRAMIENTO.IDFORMA WHERE NAT_DATOS_PERSONALES.COMPANIA =:COMPANIA GROUP BY NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_DATOS_PERSONALES.SUCURSAL, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ), NAT_DATOS_PERSONALES.CODIGO ORDER BY MIN(NAT_NOMBRAMIENTO.NO_FECHRESODECR) DESC) INI WHERE (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END) LIKE UPPER(CONCAT(:DP_NUMEDOCU, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DP_NUMEDOCU":"$DP_NUMEDOCU","NOMBRES":"$NOMBRES","SUCURSAL":"$SUCURSAL","PRIMERODENO_FECHRESODECR":"$PRIMERODENO_FECHRESODECR","PRIMERODENO_CODIGOCARGO":"$PRIMERODENO_CODIGOCARGO","PRIMERODENO_GRADOCARGO":"$PRIMERODENO_GRADOCARGO","PRIMERODENO_TIPO":"$PRIMERODENO_TIPO","PRIMERODENO_CARGON":"$PRIMERODENO_CARGON","NO_DEPENUEV":"$NO_DEPENUEV","PRIMERODENO_FECHAEFECTIVIDAD":"$PRIMERODENO_FECHAEFECTIVIDAD","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natdatospersonales/todosporultimocargo/pag">
