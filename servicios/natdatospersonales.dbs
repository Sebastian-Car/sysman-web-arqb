	<resource method="GET" path="natdatospersonales/datosempleadofinal/num">
		<call-query href="getNatdatospersonalesNumDatosEmpleadoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPLEADOINICIAL" query-param="EMPLEADOINICIAL"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
