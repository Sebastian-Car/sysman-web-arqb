	<query id="getNatdatospersonalesPagCargoPersonalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRE, V_PERSONAL.NOMBRE_DE_CARGO, NAT_DATOS_PERSONALES.DCTO_IDENTIDAD FROM NAT_DATOS_PERSONALES LEFT JOIN V_PERSONAL ON NAT_DATOS_PERSONALES.COMPANIA = V_PERSONAL.COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO = V_PERSONAL.NUMERO_DCTO AND NAT_DATOS_PERSONALES.SUCURSAL = V_PERSONAL.SUCURSAL WHERE V_PERSONAL.COMPANIA =:COMPANIA ORDER BY NAT_DATOS_PERSONALES.NUMERO_DCTO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBRE_DE_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DE_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DE_CARGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","NOMBRE_DE_CARGO":"$NOMBRE_DE_CARGO","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_DE_CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
