	<query id="getNatdatospersonalesPagCentrosDeCostoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM NAT_DATOS_PERSONALES INNER JOIN CENTRO_COSTO ON NAT_DATOS_PERSONALES.COMPANIA = CENTRO_COSTO.COMPANIA and NAT_DATOS_PERSONALES.ANO = CENTRO_COSTO.ANO AND NAT_DATOS_PERSONALES.ID_CENTROS_DE_COSTO = CENTRO_COSTO.CODIGO WHERE NAT_DATOS_PERSONALES.COMPANIA = :COMPANIA ORDER BY CENTRO_COSTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
