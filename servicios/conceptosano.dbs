<data name="conceptosano" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConceptosanoPagPoranioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CA.COMPANIA,CA.ANO,CA.ID_DE_CONCEPTO, CN.NOMBRE_CONCEPTO,CA.CODDIAN ,CD.DESCRIPCION  FROM CONCEPTOS_ANO CA INNER JOIN CONCEPTOS CN ON CA.COMPANIA = CN.COMPANIA AND CA.ID_DE_CONCEPTO = CN.ID_DE_CONCEPTO INNER JOIN CODIGOCN_CERTIFICADODIAN CD ON CA.CODDIAN = CD.CODIGO WHERE CA.COMPANIA = :COMPANIA AND CA.ANO = :ANIO ORDER BY CA.ID_DE_CONCEPTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER( '%' || :ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%')  AND (CASE WHEN CODDIAN IS NULL THEN ' ' ELSE UPPER(CODDIAN) END)  LIKE UPPER( '%' || :CODDIAN || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CODDIAN":"$CODDIAN","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CODDIAN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptosano/poranio/pag">
		<call-query href="getConceptosanoPagPoranioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODDIAN" query-param="CODDIAN"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosanoNumPoranioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CA.COMPANIA,CA.ANO,CA.ID_DE_CONCEPTO, CN.NOMBRE_CONCEPTO,CA.CODDIAN ,CD.DESCRIPCION  FROM CONCEPTOS_ANO CA INNER JOIN CONCEPTOS CN ON CA.COMPANIA = CN.COMPANIA AND CA.ID_DE_CONCEPTO = CN.ID_DE_CONCEPTO INNER JOIN CODIGOCN_CERTIFICADODIAN CD ON CA.CODDIAN = CD.CODIGO WHERE CA.COMPANIA = :COMPANIA AND CA.ANO = :ANIO ORDER BY CA.ID_DE_CONCEPTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER( '%' || :ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%')  AND (CASE WHEN CODDIAN IS NULL THEN ' ' ELSE UPPER(CODDIAN) END)  LIKE UPPER( '%' || :CODDIAN || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CODDIAN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptosano/poranio/num">
		<call-query href="getConceptosanoNumPoranioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODDIAN" query-param="CODDIAN"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertConceptosano" keyColumns="COMPANIA,ID_DE_CONCEPTO,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONCEPTOS_ANO (COMPANIA, ID_DE_CONCEPTO, ANO, CODDIAN, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_CONCEPTO, :ANO, :CODDIAN, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODDIAN" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="conceptosano">
		<call-query href="insertConceptosano">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODDIAN" query-param="CODDIAN"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConceptosano" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONCEPTOS_ANO WHERE CONCEPTOS_ANO.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_ANO.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO AND CONCEPTOS_ANO.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="conceptosano">
		<call-query href="deleteConceptosano">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getConceptosanoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,ID_DE_CONCEPTO,ANO,CODDIAN  FROM CONCEPTOS_ANO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER( '%' || :ID_DE_CONCEPTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODDIAN IS NULL THEN ' ' ELSE UPPER(CODDIAN) END)  LIKE UPPER( '%' || :CODDIAN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","ANO":"$ANO(type:integer)","CODDIAN":"$CODDIAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODDIAN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptosano">
		<call-query href="getConceptosanoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODDIAN" query-param="CODDIAN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosanoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA,ID_DE_CONCEPTO,ANO,CODDIAN  FROM CONCEPTOS_ANO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER( '%' || :ID_DE_CONCEPTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODDIAN IS NULL THEN ' ' ELSE UPPER(CODDIAN) END)  LIKE UPPER( '%' || :CODDIAN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODDIAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptosano/numero">
		<call-query href="getConceptosanoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODDIAN" query-param="CODDIAN"/>

		</call-query>
	</resource>
	<query id="getConceptosanoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,ID_DE_CONCEPTO,ANO,CODDIAN  FROM CONCEPTOS_ANO WHERE CONCEPTOS_ANO.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_ANO.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO AND CONCEPTOS_ANO.ANO= :KEY_ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","ANO":"$ANO(type:integer)","CODDIAN":"$CODDIAN"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptosano/data">
		<call-query href="getConceptosanoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="updateConceptosano" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONCEPTOS_ANO SET CODDIAN=:CODDIAN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONCEPTOS_ANO.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_ANO.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO AND CONCEPTOS_ANO.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODDIAN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="conceptosano">
		<call-query href="updateConceptosano">
			<with-param name="CODDIAN" query-param="CODDIAN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>

</data>