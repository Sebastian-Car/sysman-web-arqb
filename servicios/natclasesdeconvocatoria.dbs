<data name="natclasesdeconvocatoria" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatclasesdeconvocatoriaTodasLasClasesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CONVOCATORIA,NOMBRE  FROM NAT_CLASES_DE_CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONVOCATORIA":"$CONVOCATORIA","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="natclasesdeconvocatoria/todaslasclases">
		<call-query href="getNatclasesdeconvocatoriaTodasLasClasesQuery">
 
		</call-query>
	</resource>
	<query id="getNatclasesdeconvocatoriaClaseconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_CLASES_DE_CONVOCATORIA.NOMBRE NOMBRE_CLASE  FROM NAT_CLASES_DE_CONVOCATORIA INNER JOIN NAT_APERTURA ON NAT_CLASES_DE_CONVOCATORIA.CONVOCATORIA = NAT_APERTURA.CLASE WHERE NAT_APERTURA.COMPANIA = :COMPANIA AND NAT_APERTURA.NRO_CONVOCATORIA = :NRO_CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_CLASE":"$NOMBRE_CLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natclasesdeconvocatoria/claseconvocatoria">
		<call-query href="getNatclasesdeconvocatoriaClaseconvocatoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="insertNatclasesdeconvocatoria" keyColumns="CONVOCATORIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_CLASES_DE_CONVOCATORIA (CONVOCATORIA, NOMBRE, CREATED_BY, DATE_CREATED) VALUES (:CONVOCATORIA, :NOMBRE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CONVOCATORIA":"$CONVOCATORIA"}]}}		</result>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natclasesdeconvocatoria">
		<call-query href="insertNatclasesdeconvocatoria">
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteNatclasesdeconvocatoria" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_CLASES_DE_CONVOCATORIA WHERE NAT_CLASES_DE_CONVOCATORIA.CONVOCATORIA= :KEY_CONVOCATORIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natclasesdeconvocatoria">
		<call-query href="deleteNatclasesdeconvocatoria">
			<with-param name="KEY_CONVOCATORIA" query-param="KEY_CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="getNatclasesdeconvocatoriaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONVOCATORIA, NOMBRE  FROM NAT_CLASES_DE_CONVOCATORIA ORDER BY CONVOCATORIA) WHERE (CASE WHEN CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(CONVOCATORIA) END)  LIKE UPPER( '%' || :CONVOCATORIA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONVOCATORIA":"$CONVOCATORIA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natclasesdeconvocatoria">
		<call-query href="getNatclasesdeconvocatoriaPaginaQuery">
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatclasesdeconvocatoriaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONVOCATORIA, NOMBRE  FROM NAT_CLASES_DE_CONVOCATORIA ORDER BY CONVOCATORIA) WHERE (CASE WHEN CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(CONVOCATORIA) END)  LIKE UPPER( '%' || :CONVOCATORIA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natclasesdeconvocatoria/numero">
		<call-query href="getNatclasesdeconvocatoriaNumeroQuery">
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateNatclasesdeconvocatoria" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_CLASES_DE_CONVOCATORIA SET CONVOCATORIA=:CONVOCATORIA, NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_CLASES_DE_CONVOCATORIA.CONVOCATORIA= :KEY_CONVOCATORIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natclasesdeconvocatoria">
		<call-query href="updateNatclasesdeconvocatoria">
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CONVOCATORIA" query-param="KEY_CONVOCATORIA"/>

		</call-query>
	</resource>

</data>