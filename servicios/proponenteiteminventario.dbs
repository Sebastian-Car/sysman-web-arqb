<data name="proponenteiteminventario" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateProponenteiteminventarioProponenteItemInventario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROPONENTE_ITEMINVENTARIO SET CANTIDAD=:CANTIDAD, VALORUNITARIO=:VALORUNITARIO, VALORUNITARIODI=:VALORUNITARIODI, PORCIVA=:PORCIVA, PORCDESC=:PORCDESC, VLRIVA=:VLRIVA, VLRDESCUENTO=:VLRDESCUENTO, VLRTOTAL=:VLRTOTAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PROPONENTE_ITEMINVENTARIO.COMPANIA= :KEY_COMPANIA AND PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO= :KEY_TIPOCONTRATO AND PROPONENTE_ITEMINVENTARIO.TRANSACCION= :KEY_TRANSACCION AND PROPONENTE_ITEMINVENTARIO.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND PROPONENTE_ITEMINVENTARIO.PROPONENTE= :KEY_PROPONENTE AND PROPONENTE_ITEMINVENTARIO.SUCURSAL= :KEY_SUCURSAL AND PROPONENTE_ITEMINVENTARIO.IDELEMENTO= :KEY_IDELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORUNITARIODI" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="PORCDESC" sqlType="STRING"/>
		<param name="VLRIVA" sqlType="STRING"/>
		<param name="VLRDESCUENTO" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="KEY_PROPONENTE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_IDELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="proponenteiteminventario/proponenteiteminventario">
		<call-query href="updateProponenteiteminventarioProponenteItemInventario">
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORUNITARIODI" query-param="VALORUNITARIODI"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESC" query-param="PORCDESC"/>
			<with-param name="VLRIVA" query-param="VLRIVA"/>
			<with-param name="VLRDESCUENTO" query-param="VLRDESCUENTO"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_TRANSACCION" query-param="KEY_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVODETALLE" query-param="KEY_CONSECUTIVODETALLE"/>
			<with-param name="KEY_PROPONENTE" query-param="KEY_PROPONENTE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_IDELEMENTO" query-param="KEY_IDELEMENTO"/>

		</call-query>
	</resource>
	<query id="getProponenteiteminventarioPagProponenteItemInventarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROPONENTE_ITEMINVENTARIO.COMPANIA, PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO, PROPONENTE_ITEMINVENTARIO.TRANSACCION, PROPONENTE_ITEMINVENTARIO.CONSECUTIVODETALLE, PROPONENTE_ITEMINVENTARIO.PROPONENTE, PROPONENTE_ITEMINVENTARIO.SUCURSAL, PROPONENTE_ITEMINVENTARIO.IDELEMENTO, TRANSACCIONITEMINVENTARIO.DESCRIPCION, PROPONENTE_ITEMINVENTARIO.CANTIDAD, PROPONENTE_ITEMINVENTARIO.VALORUNITARIO, PROPONENTE_ITEMINVENTARIO.VALORUNITARIODI, PROPONENTE_ITEMINVENTARIO.PORCIVA, PROPONENTE_ITEMINVENTARIO.PORCDESC, PROPONENTE_ITEMINVENTARIO.VLRIVA, PROPONENTE_ITEMINVENTARIO.VLRDESCUENTO, PROPONENTE_ITEMINVENTARIO.VLRTOTAL  FROM PROPONENTE_ITEMINVENTARIO INNER JOIN TRANSACCIONITEMINVENTARIO ON PROPONENTE_ITEMINVENTARIO.COMPANIA = TRANSACCIONITEMINVENTARIO.COMPANIA AND PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO = TRANSACCIONITEMINVENTARIO.TIPOCONTRATO AND PROPONENTE_ITEMINVENTARIO.TRANSACCION = TRANSACCIONITEMINVENTARIO.CONSECUTIVO AND PROPONENTE_ITEMINVENTARIO.IDELEMENTO = TRANSACCIONITEMINVENTARIO.IDELEMENTO WHERE PROPONENTE_ITEMINVENTARIO.COMPANIA = :COMPANIA AND PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO = :TIPOCONTRATO AND PROPONENTE_ITEMINVENTARIO.TRANSACCION = :TRANSACCION AND PROPONENTE_ITEMINVENTARIO.CONSECUTIVODETALLE = :CONSECUTIVO AND PROPONENTE_ITEMINVENTARIO.PROPONENTE = :PROPONENTE) WHERE (CASE WHEN IDELEMENTO IS NULL THEN ' ' ELSE UPPER(IDELEMENTO) END)  LIKE UPPER(:IDELEMENTO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER(:CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VALORUNITARIODI IS NULL THEN ' ' ELSE UPPER(VALORUNITARIODI) END)  LIKE UPPER(:VALORUNITARIODI || '%')  AND (CASE WHEN PORCIVA IS NULL THEN ' ' ELSE UPPER(PORCIVA) END)  LIKE UPPER(:PORCIVA || '%')  AND (CASE WHEN PORCDESC IS NULL THEN ' ' ELSE UPPER(PORCDESC) END)  LIKE UPPER(:PORCDESC || '%')  AND (CASE WHEN VLRIVA IS NULL THEN ' ' ELSE UPPER(VLRIVA) END)  LIKE UPPER(:VLRIVA || '%')  AND (CASE WHEN VLRDESCUENTO IS NULL THEN ' ' ELSE UPPER(VLRDESCUENTO) END)  LIKE UPPER(:VLRDESCUENTO || '%')  AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END)  LIKE UPPER(:VLRTOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCONTRATO":"$TIPOCONTRATO","TRANSACCION":"$TRANSACCION","CONSECUTIVODETALLE":"$CONSECUTIVODETALLE(type:integer)","PROPONENTE":"$PROPONENTE","SUCURSAL":"$SUCURSAL","IDELEMENTO":"$IDELEMENTO","DESCRIPCION":"$DESCRIPCION","CANTIDAD":"$CANTIDAD","VALORUNITARIO":"$VALORUNITARIO","VALORUNITARIODI":"$VALORUNITARIODI","PORCIVA":"$PORCIVA","PORCDESC":"$PORCDESC","VLRIVA":"$VLRIVA","VLRDESCUENTO":"$VLRDESCUENTO","VLRTOTAL":"$VLRTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>
		<param name="IDELEMENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORUNITARIODI" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="PORCDESC" sqlType="STRING"/>
		<param name="VLRIVA" sqlType="STRING"/>
		<param name="VLRDESCUENTO" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proponenteiteminventario/proponenteiteminventario/pag">
		<call-query href="getProponenteiteminventarioPagProponenteItemInventarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>
			<with-param name="IDELEMENTO" query-param="IDELEMENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORUNITARIODI" query-param="VALORUNITARIODI"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESC" query-param="PORCDESC"/>
			<with-param name="VLRIVA" query-param="VLRIVA"/>
			<with-param name="VLRDESCUENTO" query-param="VLRDESCUENTO"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProponenteiteminventarioNumProponenteItemInventarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROPONENTE_ITEMINVENTARIO.COMPANIA, PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO, PROPONENTE_ITEMINVENTARIO.TRANSACCION, PROPONENTE_ITEMINVENTARIO.CONSECUTIVODETALLE, PROPONENTE_ITEMINVENTARIO.PROPONENTE, PROPONENTE_ITEMINVENTARIO.SUCURSAL, PROPONENTE_ITEMINVENTARIO.IDELEMENTO, TRANSACCIONITEMINVENTARIO.DESCRIPCION, PROPONENTE_ITEMINVENTARIO.CANTIDAD, PROPONENTE_ITEMINVENTARIO.VALORUNITARIO, PROPONENTE_ITEMINVENTARIO.VALORUNITARIODI, PROPONENTE_ITEMINVENTARIO.PORCIVA, PROPONENTE_ITEMINVENTARIO.PORCDESC, PROPONENTE_ITEMINVENTARIO.VLRIVA, PROPONENTE_ITEMINVENTARIO.VLRDESCUENTO, PROPONENTE_ITEMINVENTARIO.VLRTOTAL  FROM PROPONENTE_ITEMINVENTARIO INNER JOIN TRANSACCIONITEMINVENTARIO ON PROPONENTE_ITEMINVENTARIO.COMPANIA = TRANSACCIONITEMINVENTARIO.COMPANIA AND PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO = TRANSACCIONITEMINVENTARIO.TIPOCONTRATO AND PROPONENTE_ITEMINVENTARIO.TRANSACCION = TRANSACCIONITEMINVENTARIO.CONSECUTIVO AND PROPONENTE_ITEMINVENTARIO.IDELEMENTO = TRANSACCIONITEMINVENTARIO.IDELEMENTO WHERE PROPONENTE_ITEMINVENTARIO.COMPANIA = :COMPANIA AND PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO = :TIPOCONTRATO AND PROPONENTE_ITEMINVENTARIO.TRANSACCION = :TRANSACCION AND PROPONENTE_ITEMINVENTARIO.CONSECUTIVODETALLE = :CONSECUTIVO AND PROPONENTE_ITEMINVENTARIO.PROPONENTE = :PROPONENTE) WHERE (CASE WHEN IDELEMENTO IS NULL THEN ' ' ELSE UPPER(IDELEMENTO) END)  LIKE UPPER(:IDELEMENTO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER(:CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VALORUNITARIODI IS NULL THEN ' ' ELSE UPPER(VALORUNITARIODI) END)  LIKE UPPER(:VALORUNITARIODI || '%')  AND (CASE WHEN PORCIVA IS NULL THEN ' ' ELSE UPPER(PORCIVA) END)  LIKE UPPER(:PORCIVA || '%')  AND (CASE WHEN PORCDESC IS NULL THEN ' ' ELSE UPPER(PORCDESC) END)  LIKE UPPER(:PORCDESC || '%')  AND (CASE WHEN VLRIVA IS NULL THEN ' ' ELSE UPPER(VLRIVA) END)  LIKE UPPER(:VLRIVA || '%')  AND (CASE WHEN VLRDESCUENTO IS NULL THEN ' ' ELSE UPPER(VLRDESCUENTO) END)  LIKE UPPER(:VLRDESCUENTO || '%')  AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END)  LIKE UPPER(:VLRTOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>
		<param name="IDELEMENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORUNITARIODI" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="PORCDESC" sqlType="STRING"/>
		<param name="VLRIVA" sqlType="STRING"/>
		<param name="VLRDESCUENTO" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proponenteiteminventario/proponenteiteminventario/num">
		<call-query href="getProponenteiteminventarioNumProponenteItemInventarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>
			<with-param name="IDELEMENTO" query-param="IDELEMENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORUNITARIODI" query-param="VALORUNITARIODI"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESC" query-param="PORCDESC"/>
			<with-param name="VLRIVA" query-param="VLRIVA"/>
			<with-param name="VLRDESCUENTO" query-param="VLRDESCUENTO"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>

		</call-query>
	</resource>
	<query id="getProponenteiteminventarioCantidadProponenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(PROPONENTE) PROPONENTE  FROM PROPONENTE_ITEMINVENTARIO WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPOCONTRATO AND TRANSACCION = :TRANSACCION AND CONSECUTIVODETALLE = :CONSECUTIVO AND PROPONENTE = :PROPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PROPONENTE":"$PROPONENTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proponenteiteminventario/cantidadproponente">
		<call-query href="getProponenteiteminventarioCantidadProponenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>

		</call-query>
	</resource>
	<query id="getProponenteiteminventarioTotalesPropItemInventarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(TO_CHAR(SUM(PROPONENTE_ITEMINVENTARIO.VALORUNITARIODI),'9G999G999G999G999G990D99'),'0') VALUNITARIODITOTAL, NVL(TO_CHAR(SUM(PROPONENTE_ITEMINVENTARIO.VLRIVA),'9G999G999G999G999G990D99'),'0') VALIVATOTAL, NVL(TO_CHAR(SUM(PROPONENTE_ITEMINVENTARIO.VLRDESCUENTO),'9G999G999G999G999G990D99'),'0') VALDESCTOTAL, NVL(TO_CHAR(SUM(PROPONENTE_ITEMINVENTARIO.VLRTOTAL),'9G999G999G999G999G990D99'),'0') VALTOTAL  FROM PROPONENTE_ITEMINVENTARIO LEFT JOIN INVENTARIO ON PROPONENTE_ITEMINVENTARIO.COMPANIA = INVENTARIO.COMPANIA AND PROPONENTE_ITEMINVENTARIO.IDELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE PROPONENTE_ITEMINVENTARIO.COMPANIA = :COMPANIA AND PROPONENTE_ITEMINVENTARIO.TIPOCONTRATO = :TIPOCONTRATO AND PROPONENTE_ITEMINVENTARIO.CONSECUTIVODETALLE = :CONSECUTIVO AND PROPONENTE_ITEMINVENTARIO.PROPONENTE = :PROPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALUNITARIODITOTAL":"$VALUNITARIODITOTAL","VALIVATOTAL":"$VALIVATOTAL","VALDESCTOTAL":"$VALDESCTOTAL","VALTOTAL":"$VALTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proponenteiteminventario/totalespropiteminventario">
		<call-query href="getProponenteiteminventarioTotalesPropItemInventarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>

		</call-query>
	</resource>
	<query id="insertProponenteiteminventarioDesdeTransaccionItemInventario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT        INTO PROPONENTE_ITEMINVENTARIO         (           COMPANIA,            TIPOCONTRATO,            TRANSACCION,            CONSECUTIVODETALLE,           PROPONENTE,           SUCURSAL,            IDELEMENTO,          VLRTOTAL,           VLRDESCUENTO,           VLRIVA,          PORCDESC,          CANTIDAD,           VALORUNITARIO,           VALORUNITARIODI,            PORCIVA          )         (SELECT COMPANIA,                TIPOCONTRATO,                 CONSECUTIVO TRANSACCION,                 :CONSECUTIVO  CONSECUTIVODETALLE,                 :PROPONENTE  PROPONENTE,                 :SUCURSAL  SUCURSAL,                 IDELEMENTO,                 0 VLRTOTAL,               0 VLRDESCUENTO,                 0 VLRIVA,                0 PORCDESC,                0 CANTIDAD,                 0 VALORUNITARIO,                0 VALORUNITARIODI,                0 PORCIVA          FROM TRANSACCIONITEMINVENTARIO        WHERE COMPANIA     = :COMPANIA            AND TIPOCONTRATO = :TIPOCONTRATO           AND CONSECUTIVO  = :TRANSACCION          AND IDELEMENTO NOT IN (SELECT IDELEMENTO                                   FROM PROPONENTE_ITEMINVENTARIO                                  WHERE COMPANIA           = :COMPANIA                                    AND TIPOCONTRATO       = :TIPOCONTRATO                                   AND CONSECUTIVO        = :TRANSACCION                                    AND PROPONENTE         = :PROPONENTE )      )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="PROPONENTE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>

	</query>
	<resource method="POST" path="proponenteiteminventario/desdetransaccioniteminventario">
		<call-query href="insertProponenteiteminventarioDesdeTransaccionItemInventario">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>

		</call-query>
	</resource>
	<query id="getProponenteiteminventarioElementosportxQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(IDELEMENTO) ELEMENTOS  FROM PROPONENTE_ITEMINVENTARIO WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPO_CONTRATO AND TRANSACCION = :TRANSACCIONPAR AND IDELEMENTO = :ELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTOS":"$ELEMENTOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="TRANSACCIONPAR" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proponenteiteminventario/elementosportx">
		<call-query href="getProponenteiteminventarioElementosportxQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="TRANSACCIONPAR" query-param="TRANSACCIONPAR"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>

		</call-query>
	</resource>

</data>