<data name="inversionesrv" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertInversionesrv" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INVERSIONRV (COMPANIA, CODIGO, FONDO, ORIGENRECURSOS, ENTIDADEMISORA, VI_NUMERO, VI_VALORUNITARIO, VI_VALORNOMGLOBAL, RF_NUMERO, RF_VALORNOMGLOBAL, RF_VALORUNITARIO, FECHAADQUISICION, FECHAREPORREND, SITUACIONFINAL, INTERMEDIARIA, TIPOINVERSION, MONEDA, ANO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :FONDO, :ORIGENRECURSOS, :ENTIDADEMISORA, :VI_NUMERO, :VI_VALORUNITARIO, :VI_VALORNOMGLOBAL, :RF_NUMERO, :RF_VALORNOMGLOBAL, :RF_VALORUNITARIO, TO_DATE(:FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAREPORREND,'DD/MM/YYYY HH24:MI:SS'), :SITUACIONFINAL, :INTERMEDIARIA, :TIPOINVERSION, :MONEDA, :ANO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="ORIGENRECURSOS" sqlType="STRING"/>
		<param defaultValue="" name="ENTIDADEMISORA" sqlType="STRING"/>
		<param defaultValue="0" name="VI_NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="VI_VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="VI_VALORNOMGLOBAL" sqlType="STRING"/>
		<param defaultValue="0" name="RF_NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="RF_VALORNOMGLOBAL" sqlType="STRING"/>
		<param defaultValue="0" name="RF_VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAADQUISICION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAREPORREND" sqlType="STRING"/>
		<param defaultValue="" name="SITUACIONFINAL" sqlType="STRING"/>
		<param defaultValue="" name="INTERMEDIARIA" sqlType="STRING"/>
		<param defaultValue="" name="TIPOINVERSION" sqlType="STRING"/>
		<param defaultValue="COP" name="MONEDA" sqlType="STRING"/>
		<param defaultValue="" name="ANO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="inversionesrv">
		<call-query href="insertInversionesrv">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="ORIGENRECURSOS" query-param="ORIGENRECURSOS"/>
			<with-param name="ENTIDADEMISORA" query-param="ENTIDADEMISORA"/>
			<with-param name="VI_NUMERO" query-param="VI_NUMERO"/>
			<with-param name="VI_VALORUNITARIO" query-param="VI_VALORUNITARIO"/>
			<with-param name="VI_VALORNOMGLOBAL" query-param="VI_VALORNOMGLOBAL"/>
			<with-param name="RF_NUMERO" query-param="RF_NUMERO"/>
			<with-param name="RF_VALORNOMGLOBAL" query-param="RF_VALORNOMGLOBAL"/>
			<with-param name="RF_VALORUNITARIO" query-param="RF_VALORUNITARIO"/>
			<with-param name="FECHAADQUISICION" query-param="FECHAADQUISICION"/>
			<with-param name="FECHAREPORREND" query-param="FECHAREPORREND"/>
			<with-param name="SITUACIONFINAL" query-param="SITUACIONFINAL"/>
			<with-param name="INTERMEDIARIA" query-param="INTERMEDIARIA"/>
			<with-param name="TIPOINVERSION" query-param="TIPOINVERSION"/>
			<with-param name="MONEDA" query-param="MONEDA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteInversionesrv" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM INVERSIONRV WHERE INVERSIONRV.COMPANIA= :KEY_COMPANIA AND INVERSIONRV.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="inversionesrv">
		<call-query href="deleteInversionesrv">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getInversionesrvPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  INVERSIONRV.COMPANIA, INVERSIONRV.CODIGO , INVERSIONRV.FONDO , INVERSIONRV.ANO , FUENTE_RECURSOS.NOMBRE, TIPO_INVERSION.NOMBRE NOMBREINVERSION  FROM INVERSIONRV LEFT JOIN FUENTE_RECURSOS ON INVERSIONRV.COMPANIA = FUENTE_RECURSOS.COMPANIA AND INVERSIONRV.ANO = FUENTE_RECURSOS.ANO AND INVERSIONRV.ORIGENRECURSOS = FUENTE_RECURSOS.CODIGO LEFT JOIN TIPO_INVERSION ON INVERSIONRV.TIPOINVERSION = TIPO_INVERSION.CODIGO ORDER BY INVERSIONRV.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FONDO IS NULL THEN ' ' ELSE UPPER(FONDO) END)  LIKE UPPER( '%' || :FONDO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBREINVERSION IS NULL THEN ' ' ELSE UPPER(NOMBREINVERSION) END)  LIKE UPPER( '%' || :NOMBREINVERSION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","FONDO":"$FONDO","ANO":"$ANO(type:integer)","NOMBRE":"$NOMBRE","NOMBREINVERSION":"$NOMBREINVERSION"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREINVERSION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inversionesrv">
		<call-query href="getInversionesrvPaginaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREINVERSION" query-param="NOMBREINVERSION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInversionesrvNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  INVERSIONRV.COMPANIA, INVERSIONRV.CODIGO , INVERSIONRV.FONDO , INVERSIONRV.ANO , FUENTE_RECURSOS.NOMBRE, TIPO_INVERSION.NOMBRE NOMBREINVERSION  FROM INVERSIONRV LEFT JOIN FUENTE_RECURSOS ON INVERSIONRV.COMPANIA = FUENTE_RECURSOS.COMPANIA AND INVERSIONRV.ANO = FUENTE_RECURSOS.ANO AND INVERSIONRV.ORIGENRECURSOS = FUENTE_RECURSOS.CODIGO LEFT JOIN TIPO_INVERSION ON INVERSIONRV.TIPOINVERSION = TIPO_INVERSION.CODIGO ORDER BY INVERSIONRV.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FONDO IS NULL THEN ' ' ELSE UPPER(FONDO) END)  LIKE UPPER( '%' || :FONDO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBREINVERSION IS NULL THEN ' ' ELSE UPPER(NOMBREINVERSION) END)  LIKE UPPER( '%' || :NOMBREINVERSION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREINVERSION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inversionesrv/numero">
		<call-query href="getInversionesrvNumeroQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREINVERSION" query-param="NOMBREINVERSION"/>

		</call-query>
	</resource>
	<query id="getInversionesrvRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  INVERSIONRV.COMPANIA, INVERSIONRV.CODIGO ,INVERSIONRV.ANO, INVERSIONRV.FONDO , INVERSIONRV.ORIGENRECURSOS, INVERSIONRV.ENTIDADEMISORA, INVERSIONRV.VI_NUMERO, INVERSIONRV.VI_VALORUNITARIO, INVERSIONRV.VI_VALORNOMGLOBAL, INVERSIONRV.RF_NUMERO, INVERSIONRV.RF_VALORNOMGLOBAL, INVERSIONRV.RF_VALORUNITARIO,(TO_CHAR(INVERSIONRV.FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS')) FECHAADQUISICION,(TO_CHAR(INVERSIONRV.FECHAREPORREND,'DD/MM/YYYY HH24:MI:SS')) FECHAREPORREND, INVERSIONRV.SITUACIONFINAL, INVERSIONRV.INTERMEDIARIA, INVERSIONRV.TIPOINVERSION, INVERSIONRV.MONEDA, INVERSIONRV.CREATED_BY,(TO_CHAR(INVERSIONRV.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, INVERSIONRV.MODIFIED_BY,(TO_CHAR(INVERSIONRV.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM INVERSIONRV WHERE INVERSIONRV.COMPANIA= :KEY_COMPANIA AND INVERSIONRV.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","FONDO":"$FONDO","ORIGENRECURSOS":"$ORIGENRECURSOS","ENTIDADEMISORA":"$ENTIDADEMISORA","VI_NUMERO":"$VI_NUMERO(type:double)","VI_VALORUNITARIO":"$VI_VALORUNITARIO(type:double)","VI_VALORNOMGLOBAL":"$VI_VALORNOMGLOBAL(type:double)","RF_NUMERO":"$RF_NUMERO(type:double)","RF_VALORNOMGLOBAL":"$RF_VALORNOMGLOBAL(type:double)","RF_VALORUNITARIO":"$RF_VALORUNITARIO(type:double)","FECHAADQUISICION":"$FECHAADQUISICION","FECHAREPORREND":"$FECHAREPORREND","SITUACIONFINAL":"$SITUACIONFINAL","INTERMEDIARIA":"$INTERMEDIARIA","TIPOINVERSION":"$TIPOINVERSION(type:integer)","MONEDA":"$MONEDA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inversionesrv/data">
		<call-query href="getInversionesrvRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateInversionesrv" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVERSIONRV SET FONDO=:FONDO, ORIGENRECURSOS=:ORIGENRECURSOS, ENTIDADEMISORA=:ENTIDADEMISORA, VI_NUMERO=:VI_NUMERO, VI_VALORUNITARIO=:VI_VALORUNITARIO, VI_VALORNOMGLOBAL=:VI_VALORNOMGLOBAL, RF_NUMERO=:RF_NUMERO, RF_VALORNOMGLOBAL=:RF_VALORNOMGLOBAL, RF_VALORUNITARIO=:RF_VALORUNITARIO, FECHAADQUISICION=TO_DATE(:FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS'), FECHAREPORREND=TO_DATE(:FECHAREPORREND,'DD/MM/YYYY HH24:MI:SS'), SITUACIONFINAL=:SITUACIONFINAL, INTERMEDIARIA=:INTERMEDIARIA, TIPOINVERSION=:TIPOINVERSION, MONEDA=:MONEDA, ANO=:ANO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE INVERSIONRV.COMPANIA= :KEY_COMPANIA AND INVERSIONRV.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FONDO" sqlType="STRING"/>
		<param name="ORIGENRECURSOS" sqlType="STRING"/>
		<param name="ENTIDADEMISORA" sqlType="STRING"/>
		<param name="VI_NUMERO" sqlType="STRING"/>
		<param name="VI_VALORUNITARIO" sqlType="STRING"/>
		<param name="VI_VALORNOMGLOBAL" sqlType="STRING"/>
		<param name="RF_NUMERO" sqlType="STRING"/>
		<param name="RF_VALORNOMGLOBAL" sqlType="STRING"/>
		<param name="RF_VALORUNITARIO" sqlType="STRING"/>
		<param name="FECHAADQUISICION" sqlType="STRING"/>
		<param name="FECHAREPORREND" sqlType="STRING"/>
		<param name="SITUACIONFINAL" sqlType="STRING"/>
		<param name="INTERMEDIARIA" sqlType="STRING"/>
		<param name="TIPOINVERSION" sqlType="STRING"/>
		<param name="MONEDA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="inversionesrv">
		<call-query href="updateInversionesrv">
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="ORIGENRECURSOS" query-param="ORIGENRECURSOS"/>
			<with-param name="ENTIDADEMISORA" query-param="ENTIDADEMISORA"/>
			<with-param name="VI_NUMERO" query-param="VI_NUMERO"/>
			<with-param name="VI_VALORUNITARIO" query-param="VI_VALORUNITARIO"/>
			<with-param name="VI_VALORNOMGLOBAL" query-param="VI_VALORNOMGLOBAL"/>
			<with-param name="RF_NUMERO" query-param="RF_NUMERO"/>
			<with-param name="RF_VALORNOMGLOBAL" query-param="RF_VALORNOMGLOBAL"/>
			<with-param name="RF_VALORUNITARIO" query-param="RF_VALORUNITARIO"/>
			<with-param name="FECHAADQUISICION" query-param="FECHAADQUISICION"/>
			<with-param name="FECHAREPORREND" query-param="FECHAREPORREND"/>
			<with-param name="SITUACIONFINAL" query-param="SITUACIONFINAL"/>
			<with-param name="INTERMEDIARIA" query-param="INTERMEDIARIA"/>
			<with-param name="TIPOINVERSION" query-param="TIPOINVERSION"/>
			<with-param name="MONEDA" query-param="MONEDA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>