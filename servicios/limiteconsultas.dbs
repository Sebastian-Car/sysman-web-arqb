<data name="limiteconsultas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getLimiteconsultasGetregistroxconsultaymoduloQuery"  useConfig="sysmandsunist">
		<sql>SELECT REGISTROS FROM LIMITE_CONSULTAS WHERE UPPER(INFORME) = UPPER(:INFORME) AND APLICACION = :APLICACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"REGISTROS":"$REGISTROS(type:double)"}]}}		</result>
		<param name="INFORME" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="limiteconsultas/getregistroxconsultaymodulo">
		<call-query href="getLimiteconsultasGetregistroxconsultaymoduloQuery">
			<with-param name="INFORME" query-param="INFORME"/>
			<with-param name="APLICACION" query-param="APLICACION"/>

		</call-query>
	</resource>
	<query id="insertLimiteconsultasSetregistros" keyColumns="INFORME,APLICACION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO LIMITE_CONSULTAS (INFORME, APLICACION, REGISTROS, CREATED_BY, DATE_CREATED) VALUES (:INFORME, :APLICACION, :REGISTROS, :CREATED_BY, SYSDATE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_INFORME":"$INFORME","KEY_APLICACION":"$APLICACION"}]}}		</result>
		<param name="INFORME" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="REGISTROS" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="limiteconsultas/setregistros">
		<call-query href="insertLimiteconsultasSetregistros">
			<with-param name="INFORME" query-param="INFORME"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="REGISTROS" query-param="REGISTROS"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateLimiteconsultasUpdateregistros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE LIMITE_CONSULTAS SET REGISTROS=:REGISTROS, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=SYSDATE WHERE LIMITE_CONSULTAS.INFORME= :KEY_INFORME AND LIMITE_CONSULTAS.APLICACION= :KEY_APLICACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="REGISTROS" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_INFORME" sqlType="STRING"/>
		<param name="KEY_APLICACION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="limiteconsultas/updateregistros">
		<call-query href="updateLimiteconsultasUpdateregistros">
			<with-param name="REGISTROS" query-param="REGISTROS"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_INFORME" query-param="KEY_INFORME"/>
			<with-param name="KEY_APLICACION" query-param="KEY_APLICACION"/>

		</call-query>
	</resource>

</data>