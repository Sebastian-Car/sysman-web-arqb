	<query id="updateNatclasesdeprueba" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_CLASES_DE_PRUEBA SET PRUEBA=:PRUEBA, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_CLASES_DE_PRUEBA.COMPANIA= :KEY_COMPANIA AND NAT_CLASES_DE_PRUEBA.PRUEBA= :KEY_PRUEBA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PRUEBA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
