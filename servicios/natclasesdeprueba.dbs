	<query id="getNatclasesdepruebaTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT NAT_CLASES_DE_PRUEBA.PRUEBA, NAT_CLASES_DE_PRUEBA.DESCRIPCION  FROM NAT_CLASES_DE_PRUEBA WHERE NAT_CLASES_DE_PRUEBA.COMPANIA = :COMPANIA</sql>
