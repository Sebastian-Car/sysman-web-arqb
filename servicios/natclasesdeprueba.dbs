<data name="natclasesdeprueba" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatclasesdepruebaPagPruebadescripcioneducacionexperienciaconsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CLAPRUE.PRUEBA, CARGOS.NOMBRE_DEL_CARGO, CLAPRUE.DESCRIPCION, NVL(RELPRUE.EDUCACION,0) EDUCACION, NVL(RELPRUE.EXPERIENCIA,0) EXPERIENCIA, RELPRUE.CONSECUTIVO  FROM NAT_CLASES_DE_PRUEBA CLAPRUE INNER JOIN NAT_RELACION_PRUEBAS RELPRUE ON CLAPRUE.COMPANIA = RELPRUE.COMPANIA AND CLAPRUE.PRUEBA = RELPRUE.PRUEBA INNER JOIN NAT_APERTURA APERT ON APERT.COMPANIA = RELPRUE.COMPANIA AND APERT.NRO_CONVOCATORIA = RELPRUE.NRO_CONVOCATORIA INNER JOIN CARGOS ON CARGOS.COMPANIA = APERT.COMPANIA AND CARGOS.ID_DE_CARGO = APERT.CODIGOCARGO WHERE APERT.COMPANIA = :COMPANIA AND APERT.NRO_CONVOCATORIA = :CONVOCATORIA) WHERE (CASE WHEN PRUEBA IS NULL THEN ' ' ELSE UPPER(PRUEBA) END)  LIKE UPPER(:PRUEBA || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN EDUCACION IS NULL THEN ' ' ELSE UPPER(EDUCACION) END)  LIKE UPPER(:EDUCACION || '%')  AND (CASE WHEN EXPERIENCIA IS NULL THEN ' ' ELSE UPPER(EXPERIENCIA) END)  LIKE UPPER( '%' || :EXPERIENCIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRUEBA":"$PRUEBA","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","DESCRIPCION":"$DESCRIPCION","EDUCACION":"$EDUCACION(type:integer)","EXPERIENCIA":"$EXPERIENCIA(type:integer)","CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="EDUCACION" sqlType="STRING"/>
		<param name="EXPERIENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natclasesdeprueba/pruebadescripcioneducacionexperienciaconsecutivo/pag">
		<call-query href="getNatclasesdepruebaPagPruebadescripcioneducacionexperienciaconsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="EDUCACION" query-param="EDUCACION"/>
			<with-param name="EXPERIENCIA" query-param="EXPERIENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatclasesdepruebaNumPruebadescripcioneducacionexperienciaconsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT CLAPRUE.PRUEBA, CARGOS.NOMBRE_DEL_CARGO, CLAPRUE.DESCRIPCION, NVL(RELPRUE.EDUCACION,0) EDUCACION, NVL(RELPRUE.EXPERIENCIA,0) EXPERIENCIA, RELPRUE.CONSECUTIVO  FROM NAT_CLASES_DE_PRUEBA CLAPRUE INNER JOIN NAT_RELACION_PRUEBAS RELPRUE ON CLAPRUE.COMPANIA = RELPRUE.COMPANIA AND CLAPRUE.PRUEBA = RELPRUE.PRUEBA INNER JOIN NAT_APERTURA APERT ON APERT.COMPANIA = RELPRUE.COMPANIA AND APERT.NRO_CONVOCATORIA = RELPRUE.NRO_CONVOCATORIA INNER JOIN CARGOS ON CARGOS.COMPANIA = APERT.COMPANIA AND CARGOS.ID_DE_CARGO = APERT.CODIGOCARGO WHERE APERT.COMPANIA = :COMPANIA AND APERT.NRO_CONVOCATORIA = :CONVOCATORIA) WHERE (CASE WHEN PRUEBA IS NULL THEN ' ' ELSE UPPER(PRUEBA) END)  LIKE UPPER(:PRUEBA || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN EDUCACION IS NULL THEN ' ' ELSE UPPER(EDUCACION) END)  LIKE UPPER(:EDUCACION || '%')  AND (CASE WHEN EXPERIENCIA IS NULL THEN ' ' ELSE UPPER(EXPERIENCIA) END)  LIKE UPPER( '%' || :EXPERIENCIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="EDUCACION" sqlType="STRING"/>
		<param name="EXPERIENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natclasesdeprueba/pruebadescripcioneducacionexperienciaconsecutivo/num">
		<call-query href="getNatclasesdepruebaNumPruebadescripcioneducacionexperienciaconsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="EDUCACION" query-param="EDUCACION"/>
			<with-param name="EXPERIENCIA" query-param="EXPERIENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getNatclasesdepruebaPagPruebasPorConvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_CLASES_DE_PRUEBA.PRUEBA, NAT_CLASES_DE_PRUEBA.DESCRIPCION  FROM NAT_CLASES_DE_PRUEBA INNER JOIN NAT_RELACION_PRUEBAS ON NAT_CLASES_DE_PRUEBA.PRUEBA = NAT_RELACION_PRUEBAS.PRUEBA WHERE NAT_RELACION_PRUEBAS.COMPANIA = :COMPANIA AND NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA = :CONVOCATORIA ORDER BY NAT_RELACION_PRUEBAS.CONSECUTIVO) WHERE (CASE WHEN PRUEBA IS NULL THEN ' ' ELSE UPPER(PRUEBA) END)  LIKE UPPER(:PRUEBA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRUEBA":"$PRUEBA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
