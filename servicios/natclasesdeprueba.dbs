	<query id="insertNatclasesdeprueba" keyColumns="COMPANIA,PRUEBA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_CLASES_DE_PRUEBA (PRUEBA, DESCRIPCION, COMPANIA, DATE_CREATED, CREATED_BY) VALUES (:PRUEBA, :DESCRIPCION, :COMPANIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PRUEBA":"$PRUEBA"}]}}		</result>
		<param name="PRUEBA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natclasesdeprueba">
		<call-query href="insertNatclasesdeprueba">
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatclasesdeprueba" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_CLASES_DE_PRUEBA WHERE NAT_CLASES_DE_PRUEBA.COMPANIA= :KEY_COMPANIA AND NAT_CLASES_DE_PRUEBA.PRUEBA= :KEY_PRUEBA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PRUEBA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natclasesdeprueba">
		<call-query href="deleteNatclasesdeprueba">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PRUEBA" query-param="KEY_PRUEBA"/>

		</call-query>
	</resource>
	<query id="getNatclasesdepruebaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PRUEBA, DESCRIPCION, COMPANIA  FROM NAT_CLASES_DE_PRUEBA WHERE COMPANIA =:COMPANIA ORDER BY PRUEBA) WHERE (CASE WHEN PRUEBA IS NULL THEN ' ' ELSE UPPER(PRUEBA) END)  LIKE UPPER(:PRUEBA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRUEBA":"$PRUEBA","DESCRIPCION":"$DESCRIPCION","COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natclasesdeprueba">
		<call-query href="getNatclasesdepruebaPaginaQuery">
