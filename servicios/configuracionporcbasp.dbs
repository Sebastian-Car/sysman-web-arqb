<data name="configuracionporcbasp" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConfiguracionporcbaspPagBaspanoxcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ANO,(TO_CHAR(INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) INICIO_VIGENCIA,(TO_CHAR(FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) FINAL_VIGENCIA, LIMITE_INFERIOR, LIMITE_SUPERIOR, TOPE_SALARIAL FROM CONFIGURACION_PORC_BASP WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN INICIO_VIGENCIA IS NULL THEN ' ' ELSE UPPER(INICIO_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:INICIO_VIGENCIA), '%')) AND (CASE WHEN FINAL_VIGENCIA IS NULL THEN ' ' ELSE UPPER(FINAL_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:FINAL_VIGENCIA), '%')) AND (CASE WHEN LIMITE_INFERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_INFERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_INFERIOR), '%')) AND (CASE WHEN LIMITE_SUPERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_SUPERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_SUPERIOR), '%')) AND (CASE WHEN TOPE_SALARIAL IS NULL THEN ' ' ELSE UPPER(TOPE_SALARIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOPE_SALARIAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","INICIO_VIGENCIA":"$INICIO_VIGENCIA","FINAL_VIGENCIA":"$FINAL_VIGENCIA","LIMITE_INFERIOR":"$LIMITE_INFERIOR(type:double)","LIMITE_SUPERIOR":"$LIMITE_SUPERIOR(type:double)","TOPE_SALARIAL":"$TOPE_SALARIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="FINAL_VIGENCIA" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TOPE_SALARIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="configuracionporcbasp/baspanoxcompania/pag">
		<call-query href="getConfiguracionporcbaspPagBaspanoxcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="INICIO_VIGENCIA" query-param="INICIO_VIGENCIA"/>
			<with-param name="FINAL_VIGENCIA" query-param="FINAL_VIGENCIA"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TOPE_SALARIAL" query-param="TOPE_SALARIAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConfiguracionporcbaspNumBaspanoxcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ANO,(TO_CHAR(INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) INICIO_VIGENCIA,(TO_CHAR(FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) FINAL_VIGENCIA, LIMITE_INFERIOR, LIMITE_SUPERIOR, TOPE_SALARIAL FROM CONFIGURACION_PORC_BASP WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN INICIO_VIGENCIA IS NULL THEN ' ' ELSE UPPER(INICIO_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:INICIO_VIGENCIA), '%')) AND (CASE WHEN FINAL_VIGENCIA IS NULL THEN ' ' ELSE UPPER(FINAL_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:FINAL_VIGENCIA), '%')) AND (CASE WHEN LIMITE_INFERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_INFERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_INFERIOR), '%')) AND (CASE WHEN LIMITE_SUPERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_SUPERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_SUPERIOR), '%')) AND (CASE WHEN TOPE_SALARIAL IS NULL THEN ' ' ELSE UPPER(TOPE_SALARIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOPE_SALARIAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="FINAL_VIGENCIA" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TOPE_SALARIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionporcbasp/baspanoxcompania/num">
		<call-query href="getConfiguracionporcbaspNumBaspanoxcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="INICIO_VIGENCIA" query-param="INICIO_VIGENCIA"/>
			<with-param name="FINAL_VIGENCIA" query-param="FINAL_VIGENCIA"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TOPE_SALARIAL" query-param="TOPE_SALARIAL"/>

		</call-query>
	</resource>
	<query id="insertConfiguracionporcbasp" keyColumns="COMPANIA,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONFIGURACION_PORC_BASP (COMPANIA, ANO, INICIO_VIGENCIA, FINAL_VIGENCIA, LIMITE_INFERIOR, LIMITE_SUPERIOR, TOPE_SALARIAL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ANO, TO_DATE(:INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'), :LIMITE_INFERIOR, :LIMITE_SUPERIOR, :TOPE_SALARIAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_INICIO_VIGENCIA":"$INICIO_VIGENCIA","KEY_FINAL_VIGENCIA":"$FINAL_VIGENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="FINAL_VIGENCIA" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TOPE_SALARIAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="configuracionporcbasp">
		<call-query href="insertConfiguracionporcbasp">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="INICIO_VIGENCIA" query-param="INICIO_VIGENCIA"/>
			<with-param name="FINAL_VIGENCIA" query-param="FINAL_VIGENCIA"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TOPE_SALARIAL" query-param="TOPE_SALARIAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteConfiguracionporcbasp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONFIGURACION_PORC_BASP WHERE COMPANIA = :KEY_COMPANIA AND ANO = :KEY_ANO AND TRUNC(INICIO_VIGENCIA) = TO_CHAR(TO_DATE(:KEY_INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'),'DD/MM/YYYY') AND TRUNC(FINAL_VIGENCIA) = TO_CHAR(TO_DATE(:KEY_FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'),'DD/MM/YYYY')</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_FINAL_VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="configuracionporcbasp">
		<call-query href="deleteConfiguracionporcbasp">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_INICIO_VIGENCIA" query-param="KEY_INICIO_VIGENCIA"/>
			<with-param name="KEY_FINAL_VIGENCIA" query-param="KEY_FINAL_VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getConfiguracionporcbaspPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ANO,(TO_CHAR(INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) INICIO_VIGENCIA,(TO_CHAR(FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) FINAL_VIGENCIA, LIMITE_INFERIOR, LIMITE_SUPERIOR, TOPE_SALARIAL FROM CONFIGURACION_PORC_BASP WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN INICIO_VIGENCIA IS NULL THEN ' ' ELSE UPPER(INICIO_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:INICIO_VIGENCIA), '%')) AND (CASE WHEN FINAL_VIGENCIA IS NULL THEN ' ' ELSE UPPER(FINAL_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:FINAL_VIGENCIA), '%')) AND (CASE WHEN LIMITE_INFERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_INFERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_INFERIOR), '%')) AND (CASE WHEN LIMITE_SUPERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_SUPERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_SUPERIOR), '%')) AND (CASE WHEN TOPE_SALARIAL IS NULL THEN ' ' ELSE UPPER(TOPE_SALARIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOPE_SALARIAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","INICIO_VIGENCIA":"$INICIO_VIGENCIA","FINAL_VIGENCIA":"$FINAL_VIGENCIA","LIMITE_INFERIOR":"$LIMITE_INFERIOR(type:double)","LIMITE_SUPERIOR":"$LIMITE_SUPERIOR(type:double)","TOPE_SALARIAL":"$TOPE_SALARIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="FINAL_VIGENCIA" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TOPE_SALARIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="configuracionporcbasp">
		<call-query href="getConfiguracionporcbaspPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="INICIO_VIGENCIA" query-param="INICIO_VIGENCIA"/>
			<with-param name="FINAL_VIGENCIA" query-param="FINAL_VIGENCIA"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TOPE_SALARIAL" query-param="TOPE_SALARIAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConfiguracionporcbaspNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ANO,(TO_CHAR(INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) INICIO_VIGENCIA,(TO_CHAR(FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS')) FINAL_VIGENCIA, LIMITE_INFERIOR, LIMITE_SUPERIOR, TOPE_SALARIAL FROM CONFIGURACION_PORC_BASP WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN INICIO_VIGENCIA IS NULL THEN ' ' ELSE UPPER(INICIO_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:INICIO_VIGENCIA), '%')) AND (CASE WHEN FINAL_VIGENCIA IS NULL THEN ' ' ELSE UPPER(FINAL_VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:FINAL_VIGENCIA), '%')) AND (CASE WHEN LIMITE_INFERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_INFERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_INFERIOR), '%')) AND (CASE WHEN LIMITE_SUPERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_SUPERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:LIMITE_SUPERIOR), '%')) AND (CASE WHEN TOPE_SALARIAL IS NULL THEN ' ' ELSE UPPER(TOPE_SALARIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOPE_SALARIAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="FINAL_VIGENCIA" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TOPE_SALARIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionporcbasp/numero">
		<call-query href="getConfiguracionporcbaspNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="INICIO_VIGENCIA" query-param="INICIO_VIGENCIA"/>
			<with-param name="FINAL_VIGENCIA" query-param="FINAL_VIGENCIA"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TOPE_SALARIAL" query-param="TOPE_SALARIAL"/>

		</call-query>
	</resource>
	<query id="getConfiguracionporcbaspRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM CONFIGURACION_PORC_BASP WHERE CONFIGURACION_PORC_BASP.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_PORC_BASP.ANO= :KEY_ANO AND CONFIGURACION_PORC_BASP.INICIO_VIGENCIA= TO_DATE(:KEY_INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS') AND CONFIGURACION_PORC_BASP.FINAL_VIGENCIA= TO_DATE(:KEY_FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","INICIO_VIGENCIA":"$INICIO_VIGENCIA","FINAL_VIGENCIA":"$FINAL_VIGENCIA","LIMITE_INFERIOR":"$LIMITE_INFERIOR(type:double)","LIMITE_SUPERIOR":"$LIMITE_SUPERIOR(type:double)","TOPE_SALARIAL":"$TOPE_SALARIAL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_FINAL_VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionporcbasp/data">
		<call-query href="getConfiguracionporcbaspRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_INICIO_VIGENCIA" query-param="KEY_INICIO_VIGENCIA"/>
			<with-param name="KEY_FINAL_VIGENCIA" query-param="KEY_FINAL_VIGENCIA"/>

		</call-query>
	</resource>
	<query id="updateConfiguracionporcbasp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONFIGURACION_PORC_BASP SET ANO=:ANO, INICIO_VIGENCIA=TO_DATE(:INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'), FINAL_VIGENCIA=TO_DATE(:FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'), LIMITE_INFERIOR=:LIMITE_INFERIOR, LIMITE_SUPERIOR=:LIMITE_SUPERIOR, TOPE_SALARIAL=:TOPE_SALARIAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE CONFIGURACION_PORC_BASP.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_PORC_BASP.ANO= :KEY_ANO AND TRUNC(CONFIGURACION_PORC_BASP.INICIO_VIGENCIA)= TO_CHAR(TO_DATE(:KEY_INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'),'DD/MM/YYYY') AND TRUNC(CONFIGURACION_PORC_BASP.FINAL_VIGENCIA)= TO_CHAR(TO_DATE(:KEY_FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS'),'DD/MM/YYYY') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="FINAL_VIGENCIA" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TOPE_SALARIAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_FINAL_VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="configuracionporcbasp">
		<call-query href="updateConfiguracionporcbasp">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="INICIO_VIGENCIA" query-param="INICIO_VIGENCIA"/>
			<with-param name="FINAL_VIGENCIA" query-param="FINAL_VIGENCIA"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TOPE_SALARIAL" query-param="TOPE_SALARIAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_INICIO_VIGENCIA" query-param="KEY_INICIO_VIGENCIA"/>
			<with-param name="KEY_FINAL_VIGENCIA" query-param="KEY_FINAL_VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getConfiguracionporcbaspValidarrangovigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) AS EXISTE FROM CONFIGURACION_PORC_BASP WHERE COMPANIA = :UN_COMPANIA AND ANO = :UN_ANO AND TO_DATE(:INICIO_VIGENCIA,'DD/MM/YYYY HH24:MI:SS') &lt;= FINAL_VIGENCIA AND TO_DATE(:FINAL_VIGENCIA,'DD/MM/YYYY HH24:MI:SS') &gt;= INICIO_VIGENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="INICIO_VIGENCIA" sqlType="STRING"/>
		<param name="FINAL_VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionporcbasp/validarrangovigencia">
		<call-query href="getConfiguracionporcbaspValidarrangovigenciaQuery">
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="INICIO_VIGENCIA" query-param="INICIO_VIGENCIA"/>
			<with-param name="FINAL_VIGENCIA" query-param="FINAL_VIGENCIA"/>

		</call-query>
	</resource>

</data>