<data name="multassanciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertMultassanciones" keyColumns="COMPANIA,CLASEORDEN,NUMERO,TIPOTRANSACCION,ACTO_ADMINISTRATIVO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO MULTAS_SANCIONES (COMPANIA, CLASEORDEN, NUMERO, TIPOTRANSACCION, ACTO_ADMINISTRATIVO, CONSECUTIVO, DESCRIPCION, FECHAACTOADMINISTRATIVO, VALORMULTA, VALORPAGADOMULTA, ESTADOMULTA, ACTOREVOCACION, FECHAACTOREVOCACION, INDICADOR_ENVIO, TIPO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :NUMERO, :TIPOTRANSACCION, :ACTO_ADMINISTRATIVO, :CONSECUTIVO, :DESCRIPCION, TO_DATE(:FECHAACTOADMINISTRATIVO,'DD/MM/YYYY HH24:MI:SS'), :VALORMULTA, :VALORPAGADOMULTA, :ESTADOMULTA, :ACTOREVOCACION, TO_DATE(:FECHAACTOREVOCACION,'DD/MM/YYYY HH24:MI:SS'), :INDICADOR_ENVIO, :TIPO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_NUMERO":"$NUMERO(type:long)","KEY_TIPOTRANSACCION":"$TIPOTRANSACCION","KEY_ACTO_ADMINISTRATIVO":"$ACTO_ADMINISTRATIVO","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="ACTO_ADMINISTRATIVO" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAACTOADMINISTRATIVO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORMULTA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORPAGADOMULTA" sqlType="STRING"/>
		<param defaultValue="0" name="ESTADOMULTA" sqlType="STRING"/>
		<param defaultValue="" name="ACTOREVOCACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAACTOREVOCACION" sqlType="STRING"/>
		<param defaultValue="0" name="INDICADOR_ENVIO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="multassanciones">
		<call-query href="insertMultassanciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="ACTO_ADMINISTRATIVO" query-param="ACTO_ADMINISTRATIVO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHAACTOADMINISTRATIVO" query-param="FECHAACTOADMINISTRATIVO"/>
			<with-param name="VALORMULTA" query-param="VALORMULTA"/>
			<with-param name="VALORPAGADOMULTA" query-param="VALORPAGADOMULTA"/>
			<with-param name="ESTADOMULTA" query-param="ESTADOMULTA"/>
			<with-param name="ACTOREVOCACION" query-param="ACTOREVOCACION"/>
			<with-param name="FECHAACTOREVOCACION" query-param="FECHAACTOREVOCACION"/>
			<with-param name="INDICADOR_ENVIO" query-param="INDICADOR_ENVIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteMultassanciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM MULTAS_SANCIONES WHERE MULTAS_SANCIONES.COMPANIA= :KEY_COMPANIA AND MULTAS_SANCIONES.CLASEORDEN= :KEY_CLASEORDEN AND MULTAS_SANCIONES.NUMERO= :KEY_NUMERO AND MULTAS_SANCIONES.TIPOTRANSACCION= :KEY_TIPOTRANSACCION AND MULTAS_SANCIONES.ACTO_ADMINISTRATIVO= :KEY_ACTO_ADMINISTRATIVO AND MULTAS_SANCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPOTRANSACCION" sqlType="STRING"/>
		<param name="KEY_ACTO_ADMINISTRATIVO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="multassanciones">
		<call-query href="deleteMultassanciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPOTRANSACCION" query-param="KEY_TIPOTRANSACCION"/>
			<with-param name="KEY_ACTO_ADMINISTRATIVO" query-param="KEY_ACTO_ADMINISTRATIVO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getMultassancionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MULTAS_SANCIONES.COMPANIA, MULTAS_SANCIONES.CLASEORDEN, MULTAS_SANCIONES.NUMERO, MULTAS_SANCIONES.TIPOTRANSACCION, MULTAS_SANCIONES.ACTO_ADMINISTRATIVO, MULTAS_SANCIONES.CONSECUTIVO, MULTAS_SANCIONES.DESCRIPCION,(TO_CHAR(MULTAS_SANCIONES.FECHAACTOADMINISTRATIVO,'DD/MM/YYYY HH24:MI:SS')) FECHAACTOADMINISTRATIVO, MULTAS_SANCIONES.VALORMULTA, MULTAS_SANCIONES.VALORPAGADOMULTA, MULTAS_SANCIONES.ESTADOMULTA, CASE WHEN MULTAS_SANCIONES.TIPOTRANSACCION='M' THEN (CASE MULTAS_SANCIONES.ESTADOMULTA WHEN 0 THEN 'EN FIRME' WHEN 1 THEN 'EN FIRME SIN PAGO MULTA Y SE ENCUENTRA EN MORA' WHEN 2 THEN 'PAGADA' WHEN 3 THEN 'REVOCADA' END) ELSE (CASE MULTAS_SANCIONES.ESTADOMULTA WHEN 0 THEN 'EN FIRME' WHEN 1 THEN 'REVOCADA' END) END NESTADOMULTA, CASE INDICADOR_ENVIO WHEN 0 THEN 'SANCION O MULTA NUEVA' WHEN 1 THEN 'CAMBIO DATOS DE REVOCATORIA O CUMPLIMIENTO DE LA SANCION' WHEN 2 THEN 'INFORMACION ERRONEA' WHEN 3 THEN 'INFORMACION ERRONEA EN NIT Y/O NUMERO DE CONTRATO' END NINDICADOR_ENVIO, MULTAS_SANCIONES.ACTOREVOCACION,(TO_CHAR(MULTAS_SANCIONES.FECHAACTOREVOCACION,'DD/MM/YYYY HH24:MI:SS')) FECHAACTOREVOCACION, MULTAS_SANCIONES.INDICADOR_ENVIO, MULTAS_SANCIONES.TIPO  FROM MULTAS_SANCIONES WHERE MULTAS_SANCIONES.COMPANIA = :COMPANIA AND MULTAS_SANCIONES.CLASEORDEN = :CLASEORDEN AND MULTAS_SANCIONES.NUMERO = :NUMEROORDEN AND MULTAS_SANCIONES.TIPOTRANSACCION = :TIPOTRANSACCION ORDER BY CONSECUTIVO) WHERE (CASE WHEN ACTO_ADMINISTRATIVO IS NULL THEN ' ' ELSE UPPER(ACTO_ADMINISTRATIVO) END)  LIKE UPPER(:ACTO_ADMINISTRATIVO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHAACTOADMINISTRATIVO IS NULL THEN ' ' ELSE UPPER(FECHAACTOADMINISTRATIVO) END)  LIKE UPPER( '%' || :FECHAACTOADMINISTRATIVO || '%')  AND (CASE WHEN VALORMULTA IS NULL THEN ' ' ELSE UPPER(VALORMULTA) END)  LIKE UPPER( '%' || :VALORMULTA || '%')  AND (CASE WHEN VALORPAGADOMULTA IS NULL THEN ' ' ELSE UPPER(VALORPAGADOMULTA) END)  LIKE UPPER( '%' || :VALORPAGADOMULTA || '%')  AND (CASE WHEN NESTADOMULTA IS NULL THEN ' ' ELSE UPPER(NESTADOMULTA) END)  LIKE UPPER( '%' || :NESTADOMULTA || '%')  AND (CASE WHEN NINDICADOR_ENVIO IS NULL THEN ' ' ELSE UPPER(NINDICADOR_ENVIO) END)  LIKE UPPER( '%' || :NINDICADOR_ENVIO || '%')  AND (CASE WHEN ACTOREVOCACION IS NULL THEN ' ' ELSE UPPER(ACTOREVOCACION) END)  LIKE UPPER( '%' || :ACTOREVOCACION || '%')  AND (CASE WHEN FECHAACTOREVOCACION IS NULL THEN ' ' ELSE UPPER(FECHAACTOREVOCACION) END)  LIKE UPPER( '%' || :FECHAACTOREVOCACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","TIPOTRANSACCION":"$TIPOTRANSACCION","ACTO_ADMINISTRATIVO":"$ACTO_ADMINISTRATIVO","CONSECUTIVO":"$CONSECUTIVO(type:integer)","DESCRIPCION":"$DESCRIPCION","FECHAACTOADMINISTRATIVO":"$FECHAACTOADMINISTRATIVO","VALORMULTA":"$VALORMULTA","VALORPAGADOMULTA":"$VALORPAGADOMULTA","ESTADOMULTA":"$ESTADOMULTA(type:integer)","NESTADOMULTA":"$NESTADOMULTA","NINDICADOR_ENVIO":"$NINDICADOR_ENVIO","ACTOREVOCACION":"$ACTOREVOCACION","FECHAACTOREVOCACION":"$FECHAACTOREVOCACION","INDICADOR_ENVIO":"$INDICADOR_ENVIO(type:integer)","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="ACTO_ADMINISTRATIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHAACTOADMINISTRATIVO" sqlType="STRING"/>
		<param name="VALORMULTA" sqlType="STRING"/>
		<param name="VALORPAGADOMULTA" sqlType="STRING"/>
		<param name="NESTADOMULTA" sqlType="STRING"/>
		<param name="NINDICADOR_ENVIO" sqlType="STRING"/>
		<param name="ACTOREVOCACION" sqlType="STRING"/>
		<param name="FECHAACTOREVOCACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="multassanciones">
		<call-query href="getMultassancionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="ACTO_ADMINISTRATIVO" query-param="ACTO_ADMINISTRATIVO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHAACTOADMINISTRATIVO" query-param="FECHAACTOADMINISTRATIVO"/>
			<with-param name="VALORMULTA" query-param="VALORMULTA"/>
			<with-param name="VALORPAGADOMULTA" query-param="VALORPAGADOMULTA"/>
			<with-param name="NESTADOMULTA" query-param="NESTADOMULTA"/>
			<with-param name="NINDICADOR_ENVIO" query-param="NINDICADOR_ENVIO"/>
			<with-param name="ACTOREVOCACION" query-param="ACTOREVOCACION"/>
			<with-param name="FECHAACTOREVOCACION" query-param="FECHAACTOREVOCACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMultassancionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MULTAS_SANCIONES.COMPANIA, MULTAS_SANCIONES.CLASEORDEN, MULTAS_SANCIONES.NUMERO, MULTAS_SANCIONES.TIPOTRANSACCION, MULTAS_SANCIONES.ACTO_ADMINISTRATIVO, MULTAS_SANCIONES.CONSECUTIVO, MULTAS_SANCIONES.DESCRIPCION,(TO_CHAR(MULTAS_SANCIONES.FECHAACTOADMINISTRATIVO,'DD/MM/YYYY HH24:MI:SS')) FECHAACTOADMINISTRATIVO, MULTAS_SANCIONES.VALORMULTA, MULTAS_SANCIONES.VALORPAGADOMULTA, MULTAS_SANCIONES.ESTADOMULTA, CASE WHEN MULTAS_SANCIONES.TIPOTRANSACCION='M' THEN (CASE MULTAS_SANCIONES.ESTADOMULTA WHEN 0 THEN 'EN FIRME' WHEN 1 THEN 'EN FIRME SIN PAGO MULTA Y SE ENCUENTRA EN MORA' WHEN 2 THEN 'PAGADA' WHEN 3 THEN 'REVOCADA' END) ELSE (CASE MULTAS_SANCIONES.ESTADOMULTA WHEN 0 THEN 'EN FIRME' WHEN 1 THEN 'REVOCADA' END) END NESTADOMULTA, CASE INDICADOR_ENVIO WHEN 0 THEN 'SANCION O MULTA NUEVA' WHEN 1 THEN 'CAMBIO DATOS DE REVOCATORIA O CUMPLIMIENTO DE LA SANCION' WHEN 2 THEN 'INFORMACION ERRONEA' WHEN 3 THEN 'INFORMACION ERRONEA EN NIT Y/O NUMERO DE CONTRATO' END NINDICADOR_ENVIO, MULTAS_SANCIONES.ACTOREVOCACION,(TO_CHAR(MULTAS_SANCIONES.FECHAACTOREVOCACION,'DD/MM/YYYY HH24:MI:SS')) FECHAACTOREVOCACION, MULTAS_SANCIONES.INDICADOR_ENVIO, MULTAS_SANCIONES.TIPO  FROM MULTAS_SANCIONES WHERE MULTAS_SANCIONES.COMPANIA = :COMPANIA AND MULTAS_SANCIONES.CLASEORDEN = :CLASEORDEN AND MULTAS_SANCIONES.NUMERO = :NUMEROORDEN AND MULTAS_SANCIONES.TIPOTRANSACCION = :TIPOTRANSACCION ORDER BY CONSECUTIVO) WHERE (CASE WHEN ACTO_ADMINISTRATIVO IS NULL THEN ' ' ELSE UPPER(ACTO_ADMINISTRATIVO) END)  LIKE UPPER(:ACTO_ADMINISTRATIVO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHAACTOADMINISTRATIVO IS NULL THEN ' ' ELSE UPPER(FECHAACTOADMINISTRATIVO) END)  LIKE UPPER( '%' || :FECHAACTOADMINISTRATIVO || '%')  AND (CASE WHEN VALORMULTA IS NULL THEN ' ' ELSE UPPER(VALORMULTA) END)  LIKE UPPER( '%' || :VALORMULTA || '%')  AND (CASE WHEN VALORPAGADOMULTA IS NULL THEN ' ' ELSE UPPER(VALORPAGADOMULTA) END)  LIKE UPPER( '%' || :VALORPAGADOMULTA || '%')  AND (CASE WHEN NESTADOMULTA IS NULL THEN ' ' ELSE UPPER(NESTADOMULTA) END)  LIKE UPPER( '%' || :NESTADOMULTA || '%')  AND (CASE WHEN NINDICADOR_ENVIO IS NULL THEN ' ' ELSE UPPER(NINDICADOR_ENVIO) END)  LIKE UPPER( '%' || :NINDICADOR_ENVIO || '%')  AND (CASE WHEN ACTOREVOCACION IS NULL THEN ' ' ELSE UPPER(ACTOREVOCACION) END)  LIKE UPPER( '%' || :ACTOREVOCACION || '%')  AND (CASE WHEN FECHAACTOREVOCACION IS NULL THEN ' ' ELSE UPPER(FECHAACTOREVOCACION) END)  LIKE UPPER( '%' || :FECHAACTOREVOCACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="ACTO_ADMINISTRATIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHAACTOADMINISTRATIVO" sqlType="STRING"/>
		<param name="VALORMULTA" sqlType="STRING"/>
		<param name="VALORPAGADOMULTA" sqlType="STRING"/>
		<param name="NESTADOMULTA" sqlType="STRING"/>
		<param name="NINDICADOR_ENVIO" sqlType="STRING"/>
		<param name="ACTOREVOCACION" sqlType="STRING"/>
		<param name="FECHAACTOREVOCACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="multassanciones/numero">
		<call-query href="getMultassancionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="ACTO_ADMINISTRATIVO" query-param="ACTO_ADMINISTRATIVO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHAACTOADMINISTRATIVO" query-param="FECHAACTOADMINISTRATIVO"/>
			<with-param name="VALORMULTA" query-param="VALORMULTA"/>
			<with-param name="VALORPAGADOMULTA" query-param="VALORPAGADOMULTA"/>
			<with-param name="NESTADOMULTA" query-param="NESTADOMULTA"/>
			<with-param name="NINDICADOR_ENVIO" query-param="NINDICADOR_ENVIO"/>
			<with-param name="ACTOREVOCACION" query-param="ACTOREVOCACION"/>
			<with-param name="FECHAACTOREVOCACION" query-param="FECHAACTOREVOCACION"/>

		</call-query>
	</resource>
	<query id="updateMultassanciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MULTAS_SANCIONES SET ACTO_ADMINISTRATIVO=:ACTO_ADMINISTRATIVO, CONSECUTIVO=:CONSECUTIVO, DESCRIPCION=:DESCRIPCION, FECHAACTOADMINISTRATIVO=TO_DATE(:FECHAACTOADMINISTRATIVO,'DD/MM/YYYY HH24:MI:SS'), VALORMULTA=:VALORMULTA, VALORPAGADOMULTA=:VALORPAGADOMULTA, ESTADOMULTA=:ESTADOMULTA, ACTOREVOCACION=:ACTOREVOCACION, FECHAACTOREVOCACION=TO_DATE(:FECHAACTOREVOCACION,'DD/MM/YYYY HH24:MI:SS'), INDICADOR_ENVIO=:INDICADOR_ENVIO, TIPO=:TIPO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE MULTAS_SANCIONES.COMPANIA= :KEY_COMPANIA AND MULTAS_SANCIONES.CLASEORDEN= :KEY_CLASEORDEN AND MULTAS_SANCIONES.NUMERO= :KEY_NUMERO AND MULTAS_SANCIONES.TIPOTRANSACCION= :KEY_TIPOTRANSACCION AND MULTAS_SANCIONES.ACTO_ADMINISTRATIVO= :KEY_ACTO_ADMINISTRATIVO AND MULTAS_SANCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ACTO_ADMINISTRATIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHAACTOADMINISTRATIVO" sqlType="STRING"/>
		<param name="VALORMULTA" sqlType="STRING"/>
		<param name="VALORPAGADOMULTA" sqlType="STRING"/>
		<param name="ESTADOMULTA" sqlType="STRING"/>
		<param name="ACTOREVOCACION" sqlType="STRING"/>
		<param name="FECHAACTOREVOCACION" sqlType="STRING"/>
		<param name="INDICADOR_ENVIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPOTRANSACCION" sqlType="STRING"/>
		<param name="KEY_ACTO_ADMINISTRATIVO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="multassanciones">
		<call-query href="updateMultassanciones">
			<with-param name="ACTO_ADMINISTRATIVO" query-param="ACTO_ADMINISTRATIVO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHAACTOADMINISTRATIVO" query-param="FECHAACTOADMINISTRATIVO"/>
			<with-param name="VALORMULTA" query-param="VALORMULTA"/>
			<with-param name="VALORPAGADOMULTA" query-param="VALORPAGADOMULTA"/>
			<with-param name="ESTADOMULTA" query-param="ESTADOMULTA"/>
			<with-param name="ACTOREVOCACION" query-param="ACTOREVOCACION"/>
			<with-param name="FECHAACTOREVOCACION" query-param="FECHAACTOREVOCACION"/>
			<with-param name="INDICADOR_ENVIO" query-param="INDICADOR_ENVIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPOTRANSACCION" query-param="KEY_TIPOTRANSACCION"/>
			<with-param name="KEY_ACTO_ADMINISTRATIVO" query-param="KEY_ACTO_ADMINISTRATIVO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>