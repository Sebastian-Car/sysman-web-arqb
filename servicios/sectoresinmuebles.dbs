<data name="sectoresinmuebles" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSectoresinmueblesSoloCodsectorDescripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO_SECTOR, DESCRIPCION  FROM SECTOR_INMUEBLE WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_SECTOR":"$CODIGO_SECTOR","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sectoresinmuebles/solocodsectordescripcion">
		<call-query href="getSectoresinmueblesSoloCodsectorDescripcionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertSectoresinmuebles" keyColumns="COMPANIA,CODIGO_SECTOR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SECTOR_INMUEBLE (COMPANIA, CODIGO_SECTOR, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_SECTOR, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_SECTOR":"$CODIGO_SECTOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_SECTOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sectoresinmuebles">
		<call-query href="insertSectoresinmuebles">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_SECTOR" query-param="CODIGO_SECTOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSectoresinmuebles" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SECTOR_INMUEBLE WHERE SECTOR_INMUEBLE.COMPANIA= :KEY_COMPANIA AND SECTOR_INMUEBLE.CODIGO_SECTOR= :KEY_CODIGO_SECTOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_SECTOR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sectoresinmuebles">
		<call-query href="deleteSectoresinmuebles">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_SECTOR" query-param="KEY_CODIGO_SECTOR"/>

		</call-query>
	</resource>
	<query id="getSectoresinmueblesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, SECTOR_INMUEBLE.CODIGO_SECTOR CODIGO, SECTOR_INMUEBLE.DESCRIPCION DESCRIPCION  FROM SECTOR_INMUEBLE WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sectoresinmuebles">
		<call-query href="getSectoresinmueblesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSectoresinmueblesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, SECTOR_INMUEBLE.CODIGO_SECTOR CODIGO, SECTOR_INMUEBLE.DESCRIPCION DESCRIPCION  FROM SECTOR_INMUEBLE WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sectoresinmuebles/numero">
		<call-query href="getSectoresinmueblesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateSectoresinmuebles" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SECTOR_INMUEBLE SET DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SECTOR_INMUEBLE.COMPANIA= :KEY_COMPANIA AND SECTOR_INMUEBLE.CODIGO_SECTOR= :KEY_CODIGO_SECTOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_SECTOR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sectoresinmuebles">
		<call-query href="updateSectoresinmuebles">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_SECTOR" query-param="KEY_CODIGO_SECTOR"/>

		</call-query>
	</resource>

</data>