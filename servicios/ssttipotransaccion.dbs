	<query id="getSsttipotransaccionNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE,(CASE IND_REPONSABLE WHEN 0 THEN 'false' ELSE 'true' END) IND_REPONSABLE, RUTAFORMATO_PLANTILLA,(CASE IND_COMITE WHEN 0 THEN 'false' ELSE 'true' END) IND_COMITE, CLASE_TRANSACCION,(CASE IND_AGENTE WHEN 0 THEN 'false' ELSE 'true' END) IND_AGENTE FROM SST_TIPO_TRANSACCION WHERE COMPANIA= :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipotransaccion/todosporcompania/num">
		<call-query href="getSsttipotransaccionNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSsttipotransaccionIndicadorDeEmpleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE IND_REPONSABLE WHEN 0 THEN 'false' ELSE 'true' END) IND_REPONSABLE FROM SST_TIPO_TRANSACCION WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IND_REPONSABLE":"$IND_REPONSABLE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipotransaccion/indicadordeempleado">
		<call-query href="getSsttipotransaccionIndicadorDeEmpleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSsttipotransaccionPagCodnombrefinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SST_TIPO_TRANSACCION WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :TIPOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttipotransaccion/codnombrefinal/pag">
		<call-query href="getSsttipotransaccionPagCodnombrefinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttipotransaccionNumCodnombrefinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SST_TIPO_TRANSACCION WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :TIPOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipotransaccion/codnombrefinal/num">
		<call-query href="getSsttipotransaccionNumCodnombrefinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertSsttipotransaccion" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_TIPO_TRANSACCION (COMPANIA, CODIGO, NOMBRE, RUTAFORMATO_PLANTILLA, IND_REPONSABLE, IND_COMITE, CLASE_TRANSACCION, IND_AGENTE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :RUTAFORMATO_PLANTILLA, :IND_REPONSABLE, :IND_COMITE, :CLASE_TRANSACCION, :IND_AGENTE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="RUTAFORMATO_PLANTILLA" sqlType="STRING"/>
		<param defaultValue="0" name="IND_REPONSABLE" sqlType="STRING"/>
		<param defaultValue="0" name="IND_COMITE" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_TRANSACCION" sqlType="STRING"/>
		<param defaultValue="0" name="IND_AGENTE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ssttipotransaccion">
		<call-query href="insertSsttipotransaccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RUTAFORMATO_PLANTILLA" query-param="RUTAFORMATO_PLANTILLA"/>
			<with-param name="IND_REPONSABLE" query-param="IND_REPONSABLE"/>
			<with-param name="IND_COMITE" query-param="IND_COMITE"/>
			<with-param name="CLASE_TRANSACCION" query-param="CLASE_TRANSACCION"/>
			<with-param name="IND_AGENTE" query-param="IND_AGENTE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSsttipotransaccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_TIPO_TRANSACCION WHERE SST_TIPO_TRANSACCION.COMPANIA= :KEY_COMPANIA AND SST_TIPO_TRANSACCION.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="ssttipotransaccion">
		<call-query href="deleteSsttipotransaccion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSsttipotransaccionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_TIPO_TRANSACCION.COMPANIA, SST_TIPO_TRANSACCION.CODIGO, SST_TIPO_TRANSACCION.NOMBRE, SST_TIPO_TRANSACCION.RUTAFORMATO_PLANTILLA,(CASE SST_TIPO_TRANSACCION.IND_REPONSABLE WHEN 0 THEN 'false' ELSE 'true' END) IND_REPONSABLE,(CASE SST_TIPO_TRANSACCION.IND_COMITE WHEN 0 THEN 'false' ELSE 'true' END) IND_COMITE, SST_TIPO_TRANSACCION.CLASE_TRANSACCION, SST_CLASE_TRANSACCION.NOMBRE NOMBRE_CLASE ,(CASE SST_TIPO_TRANSACCION.IND_AGENTE WHEN 0 THEN 'false' ELSE 'true' END) IND_AGENTE FROM SST_TIPO_TRANSACCION LEFT JOIN SST_CLASE_TRANSACCION ON SST_TIPO_TRANSACCION.CLASE_TRANSACCION = SST_CLASE_TRANSACCION.CODIGO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN RUTAFORMATO_PLANTILLA IS NULL THEN ' ' ELSE UPPER(RUTAFORMATO_PLANTILLA) END)  LIKE UPPER( '%' || :RUTAFORMATO_PLANTILLA || '%')  AND (CASE WHEN IND_REPONSABLE IS NULL THEN ' ' ELSE UPPER(IND_REPONSABLE) END)  LIKE UPPER(:IND_REPONSABLE || '%')  AND (CASE WHEN IND_COMITE IS NULL THEN ' ' ELSE UPPER(IND_COMITE) END)  LIKE UPPER(:IND_COMITE || '%')  AND (CASE WHEN CLASE_TRANSACCION IS NULL THEN ' ' ELSE UPPER(CLASE_TRANSACCION) END)  LIKE UPPER(:CLASE_TRANSACCION || '%')  AND (CASE WHEN NOMBRE_CLASE IS NULL THEN ' ' ELSE UPPER(NOMBRE_CLASE) END)  LIKE UPPER( '%' || :NOMBRE_CLASE || '%')  AND (CASE WHEN IND_AGENTE IS NULL THEN ' ' ELSE UPPER(IND_AGENTE) END)  LIKE UPPER( '%' || :IND_AGENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","RUTAFORMATO_PLANTILLA":"$RUTAFORMATO_PLANTILLA","IND_REPONSABLE":"$IND_REPONSABLE(type:boolean)","IND_COMITE":"$IND_COMITE(type:boolean)","CLASE_TRANSACCION":"$CLASE_TRANSACCION","NOMBRE_CLASE":"$NOMBRE_CLASE","IND_AGENTE":"$IND_AGENTE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RUTAFORMATO_PLANTILLA" sqlType="STRING"/>
		<param name="IND_REPONSABLE" sqlType="STRING"/>
		<param name="IND_COMITE" sqlType="STRING"/>
		<param name="CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="NOMBRE_CLASE" sqlType="STRING"/>
		<param name="IND_AGENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttipotransaccion">
		<call-query href="getSsttipotransaccionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RUTAFORMATO_PLANTILLA" query-param="RUTAFORMATO_PLANTILLA"/>
			<with-param name="IND_REPONSABLE" query-param="IND_REPONSABLE"/>
			<with-param name="IND_COMITE" query-param="IND_COMITE"/>
			<with-param name="CLASE_TRANSACCION" query-param="CLASE_TRANSACCION"/>
			<with-param name="NOMBRE_CLASE" query-param="NOMBRE_CLASE"/>
			<with-param name="IND_AGENTE" query-param="IND_AGENTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttipotransaccionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_TIPO_TRANSACCION.COMPANIA, SST_TIPO_TRANSACCION.CODIGO, SST_TIPO_TRANSACCION.NOMBRE, SST_TIPO_TRANSACCION.RUTAFORMATO_PLANTILLA,(CASE SST_TIPO_TRANSACCION.IND_REPONSABLE WHEN 0 THEN 'false' ELSE 'true' END) IND_REPONSABLE,(CASE SST_TIPO_TRANSACCION.IND_COMITE WHEN 0 THEN 'false' ELSE 'true' END) IND_COMITE, SST_TIPO_TRANSACCION.CLASE_TRANSACCION, SST_CLASE_TRANSACCION.NOMBRE NOMBRE_CLASE ,(CASE SST_TIPO_TRANSACCION.IND_AGENTE WHEN 0 THEN 'false' ELSE 'true' END) IND_AGENTE FROM SST_TIPO_TRANSACCION LEFT JOIN SST_CLASE_TRANSACCION ON SST_TIPO_TRANSACCION.CLASE_TRANSACCION = SST_CLASE_TRANSACCION.CODIGO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN RUTAFORMATO_PLANTILLA IS NULL THEN ' ' ELSE UPPER(RUTAFORMATO_PLANTILLA) END)  LIKE UPPER( '%' || :RUTAFORMATO_PLANTILLA || '%')  AND (CASE WHEN IND_REPONSABLE IS NULL THEN ' ' ELSE UPPER(IND_REPONSABLE) END)  LIKE UPPER(:IND_REPONSABLE || '%')  AND (CASE WHEN IND_COMITE IS NULL THEN ' ' ELSE UPPER(IND_COMITE) END)  LIKE UPPER(:IND_COMITE || '%')  AND (CASE WHEN CLASE_TRANSACCION IS NULL THEN ' ' ELSE UPPER(CLASE_TRANSACCION) END)  LIKE UPPER(:CLASE_TRANSACCION || '%')  AND (CASE WHEN NOMBRE_CLASE IS NULL THEN ' ' ELSE UPPER(NOMBRE_CLASE) END)  LIKE UPPER( '%' || :NOMBRE_CLASE || '%')  AND (CASE WHEN IND_AGENTE IS NULL THEN ' ' ELSE UPPER(IND_AGENTE) END)  LIKE UPPER( '%' || :IND_AGENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RUTAFORMATO_PLANTILLA" sqlType="STRING"/>
		<param name="IND_REPONSABLE" sqlType="STRING"/>
		<param name="IND_COMITE" sqlType="STRING"/>
		<param name="CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="NOMBRE_CLASE" sqlType="STRING"/>
		<param name="IND_AGENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipotransaccion/numero">
		<call-query href="getSsttipotransaccionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RUTAFORMATO_PLANTILLA" query-param="RUTAFORMATO_PLANTILLA"/>
			<with-param name="IND_REPONSABLE" query-param="IND_REPONSABLE"/>
			<with-param name="IND_COMITE" query-param="IND_COMITE"/>
			<with-param name="CLASE_TRANSACCION" query-param="CLASE_TRANSACCION"/>
			<with-param name="NOMBRE_CLASE" query-param="NOMBRE_CLASE"/>
			<with-param name="IND_AGENTE" query-param="IND_AGENTE"/>

		</call-query>
	</resource>
	<query id="updateSsttipotransaccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_TIPO_TRANSACCION SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, RUTAFORMATO_PLANTILLA=:RUTAFORMATO_PLANTILLA, IND_REPONSABLE=:IND_REPONSABLE, IND_COMITE=:IND_COMITE, CLASE_TRANSACCION=:CLASE_TRANSACCION, IND_AGENTE=:IND_AGENTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_TIPO_TRANSACCION.COMPANIA= :KEY_COMPANIA AND SST_TIPO_TRANSACCION.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RUTAFORMATO_PLANTILLA" sqlType="STRING"/>
		<param name="IND_REPONSABLE" sqlType="STRING"/>
		<param name="IND_COMITE" sqlType="STRING"/>
		<param name="CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="IND_AGENTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ssttipotransaccion">
		<call-query href="updateSsttipotransaccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RUTAFORMATO_PLANTILLA" query-param="RUTAFORMATO_PLANTILLA"/>
			<with-param name="IND_REPONSABLE" query-param="IND_REPONSABLE"/>
			<with-param name="IND_COMITE" query-param="IND_COMITE"/>
			<with-param name="CLASE_TRANSACCION" query-param="CLASE_TRANSACCION"/>
			<with-param name="IND_AGENTE" query-param="IND_AGENTE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>