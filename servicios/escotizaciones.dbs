<data name="escotizaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEscotizacionesTodosAlSumarYContarNumeroValorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ROUND(SUM(VLR_ELEMENTO)/COUNT(VLR_ELEMENTO),0) VALOR  FROM ES_COTIZACIONES WHERE COMPANIA = :COMPANIA AND COD_ESTUDIO = :CODESTUDIO AND COD_ITEM = :COD_ITEM AND COD_ELEMENTO = :ELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escotizaciones/todosalsumarycontarnumerovalor">
		<call-query href="getEscotizacionesTodosAlSumarYContarNumeroValorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>

		</call-query>
	</resource>
	<query id="getEscotizacionesSfcotizacionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANOCONTRATO, AUXILIAR, CENTRO_COSTO, COMPANIA,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD,(TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, NUMCONTRATO, NUMERO, OBJETO_COTIZACION, SUCURSAL, TERCERO, TIEMPO_COTIZADO, TIPO, TIPOCONTRATO, TOTAL_TCOTIZADO, VALOR_BASE, VALOR_DESCUENTO, VALOR_ICA, VALOR_IVA, VALOR_RETE, VALOR_TOTAL  FROM SF_COTIZACION WHERE COMPANIA = :COMPANIA AND ANOCONTRATO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANOCONTRATO":"$ANOCONTRATO(type:integer)","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","COMPANIA":"$COMPANIA","FECHA_SOLICITUD":"$FECHA_SOLICITUD","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","NUMCONTRATO":"$NUMCONTRATO(type:long)","NUMERO":"$NUMERO(type:long)","OBJETO_COTIZACION":"$OBJETO_COTIZACION","SUCURSAL":"$SUCURSAL","TERCERO":"$TERCERO","TIEMPO_COTIZADO":"$TIEMPO_COTIZADO","TIPO":"$TIPO","TIPOCONTRATO":"$TIPOCONTRATO","TOTAL_TCOTIZADO":"$TOTAL_TCOTIZADO","VALOR_BASE":"$VALOR_BASE","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_ICA":"$VALOR_ICA","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_TOTAL":"$VALOR_TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escotizaciones/sfcotizaciones">
		<call-query href="getEscotizacionesSfcotizacionesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertEscotizaciones" keyColumns="COMPANIA,COD_ESTUDIO,COD_ITEM,COD_ELEMENTO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_COTIZACIONES (COMPANIA, ANO, COD_ESTUDIO, COD_ITEM, COD_ELEMENTO, CONSECUTIVO, ENTIDAD, NUM_COTIZACION, VLR_ELEMENTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :COD_ESTUDIO, :COD_ITEM, :COD_ELEMENTO, :CONSECUTIVO, :ENTIDAD, :NUM_COTIZACION, :VLR_ELEMENTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO","KEY_COD_ITEM":"$COD_ITEM","KEY_COD_ELEMENTO":"$COD_ELEMENTO","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="" name="ANO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ELEMENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="ENTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="NUM_COTIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="VLR_ELEMENTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="escotizaciones">
		<call-query href="insertEscotizaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ELEMENTO" query-param="COD_ELEMENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="NUM_COTIZACION" query-param="NUM_COTIZACION"/>
			<with-param name="VLR_ELEMENTO" query-param="VLR_ELEMENTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEscotizaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_COTIZACIONES WHERE ES_COTIZACIONES.COMPANIA= :KEY_COMPANIA AND ES_COTIZACIONES.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_COTIZACIONES.COD_ITEM= :KEY_COD_ITEM AND ES_COTIZACIONES.COD_ELEMENTO= :KEY_COD_ELEMENTO AND ES_COTIZACIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_ITEM" sqlType="STRING"/>
		<param name="KEY_COD_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="escotizaciones">
		<call-query href="deleteEscotizaciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_COD_ITEM" query-param="KEY_COD_ITEM"/>
			<with-param name="KEY_COD_ELEMENTO" query-param="KEY_COD_ELEMENTO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEscotizacionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_COTIZACIONES.COMPANIA, ES_COTIZACIONES.ANO, ES_COTIZACIONES.COD_ESTUDIO, ES_COTIZACIONES.COD_ITEM, ES_COTIZACIONES.COD_ELEMENTO, ES_COTIZACIONES.CONSECUTIVO, ES_COTIZACIONES.ENTIDAD, ES_COTIZACIONES.NUM_COTIZACION, ES_COTIZACIONES.VLR_ELEMENTO  FROM ES_COTIZACIONES WHERE ES_COTIZACIONES.COMPANIA =:COMPANIA AND ES_COTIZACIONES.COD_ESTUDIO = :CODESTUDIO AND ES_COTIZACIONES.COD_ITEM = :COD_ITEM AND ES_COTIZACIONES.COD_ELEMENTO = :ELEMENTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN COD_ITEM IS NULL THEN ' ' ELSE UPPER(COD_ITEM) END)  LIKE UPPER(:COD_ITEM || '%')  AND (CASE WHEN COD_ELEMENTO IS NULL THEN ' ' ELSE UPPER(COD_ELEMENTO) END)  LIKE UPPER(:COD_ELEMENTO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN ENTIDAD IS NULL THEN ' ' ELSE UPPER(ENTIDAD) END)  LIKE UPPER( '%' || :ENTIDAD || '%')  AND (CASE WHEN NUM_COTIZACION IS NULL THEN ' ' ELSE UPPER(NUM_COTIZACION) END)  LIKE UPPER(:NUM_COTIZACION || '%')  AND (CASE WHEN VLR_ELEMENTO IS NULL THEN ' ' ELSE UPPER(VLR_ELEMENTO) END)  LIKE UPPER(:VLR_ELEMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","COD_ESTUDIO":"$COD_ESTUDIO","COD_ITEM":"$COD_ITEM","COD_ELEMENTO":"$COD_ELEMENTO","CONSECUTIVO":"$CONSECUTIVO(type:integer)","ENTIDAD":"$ENTIDAD","NUM_COTIZACION":"$NUM_COTIZACION","VLR_ELEMENTO":"$VLR_ELEMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_ELEMENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ENTIDAD" sqlType="STRING"/>
		<param name="NUM_COTIZACION" sqlType="STRING"/>
		<param name="VLR_ELEMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="escotizaciones">
		<call-query href="getEscotizacionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_ELEMENTO" query-param="COD_ELEMENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="NUM_COTIZACION" query-param="NUM_COTIZACION"/>
			<with-param name="VLR_ELEMENTO" query-param="VLR_ELEMENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEscotizacionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_COTIZACIONES.COMPANIA, ES_COTIZACIONES.ANO, ES_COTIZACIONES.COD_ESTUDIO, ES_COTIZACIONES.COD_ITEM, ES_COTIZACIONES.COD_ELEMENTO, ES_COTIZACIONES.CONSECUTIVO, ES_COTIZACIONES.ENTIDAD, ES_COTIZACIONES.NUM_COTIZACION, ES_COTIZACIONES.VLR_ELEMENTO  FROM ES_COTIZACIONES WHERE ES_COTIZACIONES.COMPANIA =:COMPANIA AND ES_COTIZACIONES.COD_ESTUDIO = :CODESTUDIO AND ES_COTIZACIONES.COD_ITEM = :COD_ITEM AND ES_COTIZACIONES.COD_ELEMENTO = :ELEMENTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN COD_ITEM IS NULL THEN ' ' ELSE UPPER(COD_ITEM) END)  LIKE UPPER(:COD_ITEM || '%')  AND (CASE WHEN COD_ELEMENTO IS NULL THEN ' ' ELSE UPPER(COD_ELEMENTO) END)  LIKE UPPER(:COD_ELEMENTO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN ENTIDAD IS NULL THEN ' ' ELSE UPPER(ENTIDAD) END)  LIKE UPPER( '%' || :ENTIDAD || '%')  AND (CASE WHEN NUM_COTIZACION IS NULL THEN ' ' ELSE UPPER(NUM_COTIZACION) END)  LIKE UPPER(:NUM_COTIZACION || '%')  AND (CASE WHEN VLR_ELEMENTO IS NULL THEN ' ' ELSE UPPER(VLR_ELEMENTO) END)  LIKE UPPER(:VLR_ELEMENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_ELEMENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ENTIDAD" sqlType="STRING"/>
		<param name="NUM_COTIZACION" sqlType="STRING"/>
		<param name="VLR_ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escotizaciones/numero">
		<call-query href="getEscotizacionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_ELEMENTO" query-param="COD_ELEMENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="NUM_COTIZACION" query-param="NUM_COTIZACION"/>
			<with-param name="VLR_ELEMENTO" query-param="VLR_ELEMENTO"/>

		</call-query>
	</resource>
	<query id="updateEscotizaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_COTIZACIONES SET COMPANIA=:COMPANIA, ANO=:ANO, COD_ESTUDIO=:COD_ESTUDIO, COD_ITEM=:COD_ITEM, COD_ELEMENTO=:COD_ELEMENTO, CONSECUTIVO=:CONSECUTIVO, ENTIDAD=:ENTIDAD, NUM_COTIZACION=:NUM_COTIZACION, VLR_ELEMENTO=:VLR_ELEMENTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_COTIZACIONES.COMPANIA= :KEY_COMPANIA AND ES_COTIZACIONES.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_COTIZACIONES.COD_ITEM= :KEY_COD_ITEM AND ES_COTIZACIONES.COD_ELEMENTO= :KEY_COD_ELEMENTO AND ES_COTIZACIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ELEMENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ENTIDAD" sqlType="STRING"/>
		<param name="NUM_COTIZACION" sqlType="STRING"/>
		<param name="VLR_ELEMENTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_ITEM" sqlType="STRING"/>
		<param name="KEY_COD_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="escotizaciones">
		<call-query href="updateEscotizaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ELEMENTO" query-param="COD_ELEMENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="NUM_COTIZACION" query-param="NUM_COTIZACION"/>
			<with-param name="VLR_ELEMENTO" query-param="VLR_ELEMENTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_COD_ITEM" query-param="KEY_COD_ITEM"/>
			<with-param name="KEY_COD_ELEMENTO" query-param="KEY_COD_ELEMENTO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>