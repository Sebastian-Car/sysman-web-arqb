<data name="bpejesestrategicos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpejesestrategicosPagGetejeestrategicoxpoliticaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO_EJE, NOMBRE FROM BP_POLITICA_EJE_ESTRATEGICO WHERE COMPANIA = :COMPANIA AND CODIGO_POLITICA = :POLITICA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_EJE":"$CODIGO_EJE(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="POLITICA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpejesestrategicos/getejeestrategicoxpolitica/pag">
		<call-query href="getBpejesestrategicosPagGetejeestrategicoxpoliticaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="POLITICA" query-param="POLITICA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpejesestrategicosNumGetejeestrategicoxpoliticaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO_EJE, NOMBRE FROM BP_POLITICA_EJE_ESTRATEGICO WHERE COMPANIA = :COMPANIA AND CODIGO_POLITICA = :POLITICA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="POLITICA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpejesestrategicos/getejeestrategicoxpolitica/num">
		<call-query href="getBpejesestrategicosNumGetejeestrategicoxpoliticaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="POLITICA" query-param="POLITICA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertBpejesestrategicos" keyColumns="COMPANIA,CODIGO_POLITICA,CODIGO_EJE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_POLITICA_EJE_ESTRATEGICO (COMPANIA, CODIGO_POLITICA, CODIGO_EJE, NOMBRE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_POLITICA, :CODIGO_EJE, :NOMBRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_POLITICA":"$CODIGO_POLITICA(type:integer)","KEY_CODIGO_EJE":"$CODIGO_EJE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_POLITICA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpejesestrategicos">
		<call-query href="insertBpejesestrategicos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_POLITICA" query-param="CODIGO_POLITICA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpejesestrategicos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_POLITICA_EJE_ESTRATEGICO WHERE BP_POLITICA_EJE_ESTRATEGICO.COMPANIA= :KEY_COMPANIA AND BP_POLITICA_EJE_ESTRATEGICO.CODIGO_POLITICA= :KEY_CODIGO_POLITICA AND BP_POLITICA_EJE_ESTRATEGICO.CODIGO_EJE= :KEY_CODIGO_EJE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_POLITICA" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_EJE" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="bpejesestrategicos">
		<call-query href="deleteBpejesestrategicos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_POLITICA" query-param="KEY_CODIGO_POLITICA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>

		</call-query>
	</resource>
	<query id="getBpejesestrategicosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO_POLITICA, CODIGO_EJE, NOMBRE FROM BP_POLITICA_EJE_ESTRATEGICO WHERE COMPANIA = :COMPANIA AND CODIGO_POLITICA = :POLITICA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_POLITICA":"$CODIGO_POLITICA(type:integer)","CODIGO_EJE":"$CODIGO_EJE(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="POLITICA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpejesestrategicos">
		<call-query href="getBpejesestrategicosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="POLITICA" query-param="POLITICA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpejesestrategicosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO_POLITICA, CODIGO_EJE, NOMBRE FROM BP_POLITICA_EJE_ESTRATEGICO WHERE COMPANIA = :COMPANIA AND CODIGO_POLITICA = :POLITICA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="POLITICA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpejesestrategicos/numero">
		<call-query href="getBpejesestrategicosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="POLITICA" query-param="POLITICA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateBpejesestrategicos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_POLITICA_EJE_ESTRATEGICO SET COMPANIA=:COMPANIA, CODIGO_POLITICA=:CODIGO_POLITICA, CODIGO_EJE=:CODIGO_EJE, NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_POLITICA_EJE_ESTRATEGICO.COMPANIA= :KEY_COMPANIA AND BP_POLITICA_EJE_ESTRATEGICO.CODIGO_POLITICA= :KEY_CODIGO_POLITICA AND BP_POLITICA_EJE_ESTRATEGICO.CODIGO_EJE= :KEY_CODIGO_EJE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_POLITICA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_POLITICA" sqlType="STRING"/>
		<param name="KEY_CODIGO_EJE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpejesestrategicos">
		<call-query href="updateBpejesestrategicos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_POLITICA" query-param="CODIGO_POLITICA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_POLITICA" query-param="KEY_CODIGO_POLITICA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>

		</call-query>
	</resource>

</data>