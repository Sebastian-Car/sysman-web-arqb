<data name="tipodeautomotor" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipodeautomotorTodosLosTiposQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE, TIPO_DE_AUTOMOTOR  FROM TIPO_DE_AUTOMOTOR ORDER BY TIPO_DE_AUTOMOTOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","TIPO_DE_AUTOMOTOR":"$TIPO_DE_AUTOMOTOR"}]}}		</result>
 
	</query>
	<resource method="GET" path="tipodeautomotor/todoslostipos">
		<call-query href="getTipodeautomotorTodosLosTiposQuery">
 
		</call-query>
	</resource>
	<query id="insertTipodeautomotor" keyColumns="TIPO_DE_AUTOMOTOR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPO_DE_AUTOMOTOR (NOMBRE, TIPO_DE_AUTOMOTOR, DATE_CREATED, CREATED_BY) VALUES (:NOMBRE, :TIPO_DE_AUTOMOTOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_TIPO_DE_AUTOMOTOR":"$TIPO_DE_AUTOMOTOR"}]}}		</result>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_DE_AUTOMOTOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tipodeautomotor">
		<call-query href="insertTipodeautomotor">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_DE_AUTOMOTOR" query-param="TIPO_DE_AUTOMOTOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTipodeautomotor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPO_DE_AUTOMOTOR WHERE TIPO_DE_AUTOMOTOR.TIPO_DE_AUTOMOTOR= :KEY_TIPO_DE_AUTOMOTOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_TIPO_DE_AUTOMOTOR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tipodeautomotor">
		<call-query href="deleteTipodeautomotor">
			<with-param name="KEY_TIPO_DE_AUTOMOTOR" query-param="KEY_TIPO_DE_AUTOMOTOR"/>

		</call-query>
	</resource>
	<query id="getTipodeautomotorPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NOMBRE, TIPO_DE_AUTOMOTOR  FROM TIPO_DE_AUTOMOTOR ORDER BY TIPO_DE_AUTOMOTOR) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_DE_AUTOMOTOR IS NULL THEN ' ' ELSE UPPER(TIPO_DE_AUTOMOTOR) END)  LIKE UPPER(:TIPO_DE_AUTOMOTOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","TIPO_DE_AUTOMOTOR":"$TIPO_DE_AUTOMOTOR"}]}}		</result>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_DE_AUTOMOTOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipodeautomotor">
		<call-query href="getTipodeautomotorPaginaQuery">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_DE_AUTOMOTOR" query-param="TIPO_DE_AUTOMOTOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipodeautomotorNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NOMBRE, TIPO_DE_AUTOMOTOR  FROM TIPO_DE_AUTOMOTOR ORDER BY TIPO_DE_AUTOMOTOR) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_DE_AUTOMOTOR IS NULL THEN ' ' ELSE UPPER(TIPO_DE_AUTOMOTOR) END)  LIKE UPPER(:TIPO_DE_AUTOMOTOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_DE_AUTOMOTOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipodeautomotor/numero">
		<call-query href="getTipodeautomotorNumeroQuery">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_DE_AUTOMOTOR" query-param="TIPO_DE_AUTOMOTOR"/>

		</call-query>
	</resource>
	<query id="updateTipodeautomotor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPO_DE_AUTOMOTOR SET NOMBRE=:NOMBRE, TIPO_DE_AUTOMOTOR=:TIPO_DE_AUTOMOTOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPO_DE_AUTOMOTOR.TIPO_DE_AUTOMOTOR= :KEY_TIPO_DE_AUTOMOTOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_DE_AUTOMOTOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_TIPO_DE_AUTOMOTOR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipodeautomotor">
		<call-query href="updateTipodeautomotor">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_DE_AUTOMOTOR" query-param="TIPO_DE_AUTOMOTOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_TIPO_DE_AUTOMOTOR" query-param="KEY_TIPO_DE_AUTOMOTOR"/>

		</call-query>
	</resource>

</data>