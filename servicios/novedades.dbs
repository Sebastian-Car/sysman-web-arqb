		</call-query>
	</resource>
	<query id="getNovedadesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NOVEDADES.COMPANIA, NOVEDADES.ID_DE_EMPLEADO, NOVEDADES.VALOR,(TO_CHAR(NOVEDADES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, NOVEDADES.ID_DE_PROCESO, NOVEDADES.ANO, NOVEDADES.MES, NOVEDADES.PERIODO, NOVEDADES.ID_DE_CONCEPTO, PERSONAL.NOMBRECOMPLETO NOMBRECOMPLETO, ( SELECT CONCEPTOS.NOMBRE_CONCEPTO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = NOVEDADES.COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO = NOVEDADES.ID_DE_CONCEPTO ) NOMBRECONCEPTO FROM NOVEDADES INNER JOIN PERSONAL ON PERSONAL.COMPANIA = NOVEDADES.COMPANIA AND PERSONAL.ID_DE_EMPLEADO = NOVEDADES.ID_DE_EMPLEADO WHERE NOVEDADES.COMPANIA =:COMPANIA AND NOVEDADES.ID_DE_PROCESO IN (0) AND NOVEDADES.ANO IN (0) AND NOVEDADES.MES IN (0) AND NOVEDADES.PERIODO IN (0) AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(CONCAT(PCK_NOMINA_COM1.FC_PARAMETRO(:COMPANIA,12), ',301,304,309'),' ','') ),CONCAT('',CONCAT(NOVEDADES.ID_DE_CONCEPTO, '')),1) &gt; 0 AND PERSONAL.ESTADO_ACTUAL IN (1) ORDER BY NOVEDADES.ID_DE_EMPLEADO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END) LIKE UPPER(CONCAT(:ID_DE_PROCESO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(:MES, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECONCEPTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="novedades/numero">
		<call-query href="getNovedadesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
