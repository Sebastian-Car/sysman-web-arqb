<data name="novedades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNovedadesPagListarGrillaPorCompaniaAnoMesPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, VALOR, OBSERVACIONES, (SELECT CONCEPTOS.NOMBRE_CONCEPTO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA =NOVEDADES.COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO=NOVEDADES.ID_DE_CONCEPTO ) NOMBRE_CONCEPTO  FROM NOVEDADES WHERE NOVEDADES.COMPANIA = :COMPANIA_AUX AND NOVEDADES.ID_DE_PROCESO = :ID_DE_PROCESO_AUX AND NOVEDADES.ANO = :ANO_AUX AND NOVEDADES.MES = :MES_AUX AND NOVEDADES.PERIODO = :PERIODO_AUX AND NOVEDADES.ID_DE_EMPLEADO = :ID_DE_EMPLEADO_AUX ORDER BY NOVEDADES.COMPANIA, NOVEDADES.ID_DE_PROCESO, NOVEDADES.ANO, NOVEDADES.MES, NOVEDADES.PERIODO, NOVEDADES.ID_DE_EMPLEADO, NOVEDADES.ID_DE_CONCEPTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END)  LIKE UPPER(:ID_DE_PROCESO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER(:OBSERVACIONES || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FECHA":"$FECHA","VALOR":"$VALOR","OBSERVACIONES":"$OBSERVACIONES","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA_AUX" sqlType="STRING"/>
		<param name="ID_DE_PROCESO_AUX" sqlType="STRING"/>
		<param name="ANO_AUX" sqlType="STRING"/>
		<param name="MES_AUX" sqlType="STRING"/>
		<param name="PERIODO_AUX" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO_AUX" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="novedades/listargrillaporcompaniaanomesperiodo/pag">
		<call-query href="getNovedadesPagListarGrillaPorCompaniaAnoMesPeriodoQuery">
			<with-param name="COMPANIA_AUX" query-param="COMPANIA_AUX"/>
			<with-param name="ID_DE_PROCESO_AUX" query-param="ID_DE_PROCESO_AUX"/>
