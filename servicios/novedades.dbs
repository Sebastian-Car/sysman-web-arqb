	</resource>
	<query id="getNovedadesListarDatosPorCompaniaAnoMesPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, VALOR, OBSERVACIONES, (SELECT CONCEPTOS.NOMBRE_CONCEPTO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA =NOVEDADES.COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO=NOVEDADES.ID_DE_CONCEPTO ) NOMBRE_CONCEPTO  FROM NOVEDADES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FECHA":"$FECHA","VALOR":"$VALOR","OBSERVACIONES":"$OBSERVACIONES","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
 
	</query>
	<resource method="GET" path="novedades/listardatosporcompaniaanomesperiodo">
		<call-query href="getNovedadesListarDatosPorCompaniaAnoMesPeriodoQuery">
 
		</call-query>
	</resource>
	<query id="getNovedadesAcumnovedadescalcnominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOVEDADES.ID_DE_PROCESO, NOVEDADES.ANO, NOVEDADES.MES, NOVEDADES.PERIODO, NOVEDADES.ID_DE_EMPLEADO, NOVEDADES.ID_DE_CONCEPTO, NOVEDADES.VALOR SUMACONCEPTO  FROM NOVEDADES INNER JOIN PERSONAL ON (NOVEDADES.COMPANIA=PERSONAL.COMPANIA) AND (NOVEDADES.ID_DE_EMPLEADO=PERSONAL.ID_DE_EMPLEADO),PERIODOS WHERE NOVEDADES.COMPANIA = :COMPANIA AND NOVEDADES.VALOR &lt;&gt; 0 AND PERSONAL.ID_DE_EMPLEADO BETWEEN :EMPINICIAL AND :EMPFINAL AND PERSONAL.DEPENDENCIA BETWEEN NVL(:DEPENDENCIAINI,' ') AND :DEPENDENCIAFIN AND PERSONAL.ID_DE_TIPO BETWEEN NVL(:TIPOINI,' ') AND :TIPOFIN AND PERSONAL.ID_CENTRO_DE_COSTO BETWEEN NVL(:CENTROINI,' ') AND :CENTROFIN AND PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:PROCESO AND PERIODOS.ANO =:ANO AND PERIODOS.MES =:MES AND PERIODOS.PERIODO =:PERIODO AND ( PERSONAL.FECHA_DE_INGRESO &lt;= PERIODOS.FECHAFINAL AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 OR PERSONAL.FECHA_DE_RETIRO &gt;=PERIODOS.FECHAFINAL AND PERSONAL.FECHA_DE_INGRESO &lt;=PERIODOS.FECHAINICIO AND PERSONAL.ESTADO_ACTUAL = 3 ) AND (NOVEDADES.ID_DE_PROCESO IN (0) OR NOVEDADES.ID_DE_PROCESO = :PROCESO) AND (NOVEDADES.ANO IN(0) OR NOVEDADES.ANO =:ANO) AND (NOVEDADES.MES IN(0) OR NOVEDADES.MES = :MES ) AND (NOVEDADES.PERIODO IN(0) OR NOVEDADES.PERIODO = :PERIODO) AND NOVEDADES.ID_DE_EMPLEADO BETWEEN :EMPINICIAL AND :EMPFINAL AND NOVEDADES.ID_DE_EMPLEADO NOT IN(0) ORDER BY NOVEDADES.ID_DE_PROCESO, NOVEDADES.ANO, NOVEDADES.MES, NOVEDADES.PERIODO, NOVEDADES.ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","SUMACONCEPTO":"$SUMACONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPINICIAL" sqlType="STRING"/>
		<param name="EMPFINAL" sqlType="STRING"/>
		<param name="DEPENDENCIAINI" sqlType="STRING"/>
		<param name="DEPENDENCIAFIN" sqlType="STRING"/>
		<param name="TIPOINI" sqlType="STRING"/>
		<param name="TIPOFIN" sqlType="STRING"/>
		<param name="CENTROINI" sqlType="STRING"/>
		<param name="CENTROFIN" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="novedades/acumnovedadescalcnomina">
		<call-query href="getNovedadesAcumnovedadescalcnominaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPINICIAL" query-param="EMPINICIAL"/>
			<with-param name="EMPFINAL" query-param="EMPFINAL"/>
			<with-param name="DEPENDENCIAINI" query-param="DEPENDENCIAINI"/>
			<with-param name="DEPENDENCIAFIN" query-param="DEPENDENCIAFIN"/>
			<with-param name="TIPOINI" query-param="TIPOINI"/>
			<with-param name="TIPOFIN" query-param="TIPOFIN"/>
			<with-param name="CENTROINI" query-param="CENTROINI"/>
			<with-param name="CENTROFIN" query-param="CENTROFIN"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getNovedadesNovedadesgeneralescalculoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO, VALOR SUMACONCEPTO  FROM NOVEDADES WHERE COMPANIA = :COMPANIA AND VALOR &lt;&gt; 0 AND (ID_DE_PROCESO IN (0) OR ID_DE_PROCESO = :PROCESO) AND (ANO IN(0) OR ANO =:ANO) AND (MES IN(0) OR MES = :MES ) AND (PERIODO IN(0) OR PERIODO = :PERIODO) AND ID_DE_EMPLEADO IN(0) ORDER BY ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","SUMACONCEPTO":"$SUMACONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="novedades/novedadesgeneralescalculo">
		<call-query href="getNovedadesNovedadesgeneralescalculoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="updateNovedadesActnovedadcalculo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NOVEDADES SET VALOR = :VALOR WHERE NOVEDADES.COMPANIA= :KEY_COMPANIA AND NOVEDADES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND NOVEDADES.ANO= :KEY_ANO AND NOVEDADES.MES= :KEY_MES AND NOVEDADES.PERIODO= :KEY_PERIODO AND NOVEDADES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND NOVEDADES.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="novedades/actnovedadcalculo">
		<call-query href="updateNovedadesActnovedadcalculo">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateNovedadesActnovedadacumcalculo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NOVEDADES SET VALOR = VALOR + :VALOR WHERE NOVEDADES.COMPANIA= :KEY_COMPANIA AND NOVEDADES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND NOVEDADES.ANO= :KEY_ANO AND NOVEDADES.MES= :KEY_MES AND NOVEDADES.PERIODO= :KEY_PERIODO AND NOVEDADES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND NOVEDADES.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="novedades/actnovedadacumcalculo">
		<call-query href="updateNovedadesActnovedadacumcalculo">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getNovedadesCuentanovedadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(0) CUENTA  FROM NOVEDADES WHERE COMPANIA =:COMPANIA AND ID_DE_PROCESO = :PROCESO AND ANO = :ANO AND MES = :MES AND PERIODO = :PERIODO AND ID_DE_EMPLEADO = :EMPLEADO AND ID_DE_CONCEPTO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
