	<query id="deleteNovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NOVEDADES WHERE NOVEDADES.COMPANIA= :KEY_COMPANIA AND NOVEDADES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND NOVEDADES.ANO= :KEY_ANO AND NOVEDADES.MES= :KEY_MES AND NOVEDADES.PERIODO= :KEY_PERIODO AND NOVEDADES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND NOVEDADES.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="novedades">
