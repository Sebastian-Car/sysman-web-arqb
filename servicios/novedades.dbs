	<query id="updateNovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NOVEDADES SET COMPANIA=:COMPANIA, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, VALOR=:VALOR, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), ID_DE_PROCESO=:ID_DE_PROCESO, ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NOVEDADES.COMPANIA= :KEY_COMPANIA AND NOVEDADES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND NOVEDADES.ANO= :KEY_ANO AND NOVEDADES.MES= :KEY_MES AND NOVEDADES.PERIODO= :KEY_PERIODO AND NOVEDADES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND NOVEDADES.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
