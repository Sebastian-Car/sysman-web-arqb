	<query id="getUsuariosNombreCompletoPorCodigoQuery"  useConfig="sysmanirisst">
		<sql>SELECT (CONCAT(USUARIO.NOMBRE1 ,CONCAT( ' ' ,CONCAT( USUARIO.NOMBRE2 ,CONCAT(' ' ,CONCAT( USUARIO.APELLIDO1 ,CONCAT(' ' ,USUARIO.APELLIDO2))))))) NOMBRE FROM USUARIO WHERE CODIGO LIKE :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
