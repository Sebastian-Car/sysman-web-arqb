	<query id="getUsuariosPorSegundaClaveQuery"  useConfig="sysmanirisst">
		<sql>SELECT DISTINCT SEGUNDA_CLAVE, CORREOELECTRONICO, CONCAT(NOMBRE1 ,CONCAT(' ' , NOMBRE2)) NOMBRE FROM USUARIO WHERE CODIGO =:USUARIO AND TO_CHAR(SYSDATE,'DD/MM/YYYY HH24:MI:SS') &lt;= TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SEGUNDA_CLAVE":"$SEGUNDA_CLAVE","CORREOELECTRONICO":"$CORREOELECTRONICO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
