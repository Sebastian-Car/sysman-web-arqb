		</call-query>
	</resource>
	<query id="updateUsuariosUpdateestado" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE USUARIO SET ESTADO=:ESTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE USUARIO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="usuarios/updateestado">
		<call-query href="updateUsuariosUpdateestado">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getUsuariosEsadminQuery"  useConfig="sysmanirisst">
		<sql>SELECT U.CODIGO AS CODIGO_USUARIO, G.CODIGO AS CODIGO_GRUPO,(CASE G.ES_ADMINISTRADOR WHEN 0 THEN 'false' ELSE 'true' END) ES_ADMINISTRADOR FROM USUARIO U INNER JOIN USUARIO_D D ON U.CODIGO = D.USUARIO INNER JOIN USUARIO G ON D.GRUPO = G.CODIGO WHERE U.CODIGO = :USUARIO AND D.APLICACION = 999 AND G.TIPOCUENTA = 'G' AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_USUARIO":"$CODIGO_USUARIO","CODIGO_GRUPO":"$CODIGO_GRUPO","ES_ADMINISTRADOR":"$ES_ADMINISTRADOR(type:boolean)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuarios/esadmin">
		<call-query href="getUsuariosEsadminQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
