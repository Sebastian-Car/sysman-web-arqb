	<query id="getUsuariosNumPortipouserfinalQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, CONCAT(NOMBRE1 ,CONCAT( ' ' ,CONCAT(NOMBRE2 ,CONCAT(' ' ,CONCAT(APELLIDO1 ,CONCAT(' ' ,APELLIDO2)))))) NOMBRE  FROM USUARIO WHERE TIPOCUENTA = 'U' AND CODIGO &gt;= :CODIGOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
