	<query id="getUsuariosNumGetusuariospagcodigoynombrestipocuentaqueryQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT USUARIO.CODIGO, ( CONCAT(USUARIO.NOMBRE1 ,CONCAT( ' ' ,CONCAT(USUARIO.NOMBRE2 ,CONCAT( ' ' ,CONCAT( USUARIO.APELLIDO1 ,CONCAT( ' ' ,USUARIO.APELLIDO2))))))) NOMBRE FROM USUARIO WHERE USUARIO.TIPOCUENTA = 'U' ORDER BY USUARIO.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuarios/getusuariospagcodigoynombrestipocuentaquery/num">
		<call-query href="getUsuariosNumGetusuariospagcodigoynombrestipocuentaqueryQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
