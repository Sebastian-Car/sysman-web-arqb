	<query id="getUsuariosUsuariovigenteQuery"  useConfig="sysmanirisst">
		<sql>SELECT CASE WHEN TRUNC(FECHA_LIMITE_ING) &gt;= TRUNC(SYSDATE) THEN 'SI' ELSE 'NO' END AS VIGENTE FROM USUARIO WHERE TIPOCUENTA IN ('U') AND CODIGO LIKE :CODIGO AND NVL(MAN_FECHA_LIMITE,0) &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENTE":"$VIGENTE"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
