	<query id="getUsuariosDiasVigenciaContraseniaQuery"  useConfig="sysmanirisst">
		<sql>SELECT TRUNC(CURRENT_DATE) -TRUNC(FECHA_ACTCONTRASENA) DIAS_VIGENCIA FROM USUARIO WHERE CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIAS_VIGENCIA":"$DIAS_VIGENCIA(type:integer)"}]}}		</result>
