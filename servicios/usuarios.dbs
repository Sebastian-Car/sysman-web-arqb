	</resource>
	<query id="getUsuariosCargarDatosUsuarioQuery"  useConfig="sysmanirisst">
		<sql>SELECT  CODIGO, NOMBRE1, NOMBRE2, APELLIDO1, APELLIDO2, CEDULA, SUCURSAL, PAIS , REGION , CIUDAD , CORREOELECTRONICO , TITULO_PROFESIONAL , ESTILO, IDIOMA, RUTA_IMAGEN, FRASEDELDIA, GENERO, IDENTIFICADOR, ESTADO, DIRECCION, CELULAR,(TO_CHAR(FECHANACIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHANACIMIENTO, MINUTOSBLOQUEO  FROM USUARIO WHERE TIPOCUENTA = 'U' AND CODIGO =:CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE1":"$NOMBRE1","NOMBRE2":"$NOMBRE2","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","CEDULA":"$CEDULA","SUCURSAL":"$SUCURSAL","PAIS":"$PAIS","REGION":"$REGION","CIUDAD":"$CIUDAD","CORREOELECTRONICO":"$CORREOELECTRONICO","TITULO_PROFESIONAL":"$TITULO_PROFESIONAL","ESTILO":"$ESTILO","IDIOMA":"$IDIOMA","RUTA_IMAGEN":"$RUTA_IMAGEN","FRASEDELDIA":"$FRASEDELDIA","GENERO":"$GENERO","IDENTIFICADOR":"$IDENTIFICADOR","ESTADO":"$ESTADO","DIRECCION":"$DIRECCION","CELULAR":"$CELULAR","FECHANACIMIENTO":"$FECHANACIMIENTO","MINUTOSBLOQUEO":"$MINUTOSBLOQUEO(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
