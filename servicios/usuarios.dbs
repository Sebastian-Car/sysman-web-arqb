	<query id="getUsuariosPagAutorizaabonosspcuentaqueryQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, ABONOMONTO, ABONOCLAVE  FROM USUARIO WHERE USUARIO.TIPOCUENTA='U' AND USUARIO.ABONOSUPER NOT IN (0) ORDER BY USUARIO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ABONOMONTO IS NULL THEN ' ' ELSE UPPER(ABONOMONTO) END)  LIKE UPPER(:ABONOMONTO || '%')  AND (CASE WHEN ABONOCLAVE IS NULL THEN ' ' ELSE UPPER(ABONOCLAVE) END)  LIKE UPPER(:ABONOCLAVE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","ABONOMONTO":"$ABONOMONTO(type:integer)","ABONOCLAVE":"$ABONOCLAVE"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ABONOMONTO" sqlType="STRING"/>
		<param name="ABONOCLAVE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="usuarios/autorizaabonosspcuentaquery/pag">
		<call-query href="getUsuariosPagAutorizaabonosspcuentaqueryQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ABONOMONTO" query-param="ABONOMONTO"/>
			<with-param name="ABONOCLAVE" query-param="ABONOCLAVE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getUsuariosNumAutorizaabonosspcuentaqueryQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, ABONOMONTO, ABONOCLAVE  FROM USUARIO WHERE USUARIO.TIPOCUENTA='U' AND USUARIO.ABONOSUPER NOT IN (0) ORDER BY USUARIO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ABONOMONTO IS NULL THEN ' ' ELSE UPPER(ABONOMONTO) END)  LIKE UPPER( '%' || :ABONOMONTO || '%')  AND (CASE WHEN ABONOCLAVE IS NULL THEN ' ' ELSE UPPER(ABONOCLAVE) END)  LIKE UPPER( '%' || :ABONOCLAVE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ABONOMONTO" sqlType="STRING"/>
		<param name="ABONOCLAVE" sqlType="STRING"/>

	</query>
