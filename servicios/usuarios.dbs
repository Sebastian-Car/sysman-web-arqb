		</call-query>
	</resource>
	<query id="getUsuariosDatosSolicitudCdpQuery"  useConfig="sysmanirisst">
		<sql>SELECT CEDULA, ( CONCAT(USUARIO.NOMBRE1 ,CONCAT(' ' ,CONCAT(USUARIO.NOMBRE2 ,CONCAT( ' ' ,CONCAT( USUARIO.APELLIDO1 ,CONCAT(' ' ,USUARIO.APELLIDO2 ))))))) NOMBRECOMPLETO, SUCURSAL FROM USUARIO WHERE CODIGO =:CODIGO</sql>
