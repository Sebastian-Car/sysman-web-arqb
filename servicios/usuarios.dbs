	<query id="getUsuariosEmailsusuariosQuery"  useConfig="sysmanirisst">
		<sql>SELECT CODIGO, CORREOELECTRONICO FROM USUARIO WHERE INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:USUARIO,' ','') ),CONCAT('',CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE (CODIGO,' ','') ),'') ),1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CORREOELECTRONICO":"$CORREOELECTRONICO"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
