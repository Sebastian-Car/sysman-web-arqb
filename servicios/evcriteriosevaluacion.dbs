<data name="evcriteriosevaluacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEvcriteriosevaluacionPagCodigonombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO, CLASE_EVALUACION  FROM EV_CRITERIOS_EVALUACION WHERE (MOVIMIENTO = 0 OR MOVIMIENTO IS NULL) AND IND_GRUPO != 0 AND CLASE_EVALUACION = :CLASEEVALUACION AND COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_GRUPO IS NULL THEN ' ' ELSE UPPER(IND_GRUPO) END)  LIKE UPPER( '%' || :IND_GRUPO || '%')  AND (CASE WHEN CLASE_EVALUACION IS NULL THEN ' ' ELSE UPPER(CLASE_EVALUACION) END)  LIKE UPPER( '%' || :CLASE_EVALUACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","IND_GRUPO":"$IND_GRUPO(type:boolean)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)"}]}}		</result>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_GRUPO" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/codigonombre/pag">
		<call-query href="getEvcriteriosevaluacionPagCodigonombreQuery">
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_GRUPO" query-param="IND_GRUPO"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvcriteriosevaluacionNumCodigonombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO, CLASE_EVALUACION  FROM EV_CRITERIOS_EVALUACION WHERE (MOVIMIENTO = 0 OR MOVIMIENTO IS NULL) AND IND_GRUPO != 0 AND CLASE_EVALUACION = :CLASEEVALUACION AND COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_GRUPO IS NULL THEN ' ' ELSE UPPER(IND_GRUPO) END)  LIKE UPPER( '%' || :IND_GRUPO || '%')  AND (CASE WHEN CLASE_EVALUACION IS NULL THEN ' ' ELSE UPPER(CLASE_EVALUACION) END)  LIKE UPPER( '%' || :CLASE_EVALUACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_GRUPO" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/codigonombre/num">
		<call-query href="getEvcriteriosevaluacionNumCodigonombreQuery">
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_GRUPO" query-param="IND_GRUPO"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>

		</call-query>
	</resource>
	<query id="getEvcriteriosevaluacionPagCodigonombreporclaseevaluacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM EV_CRITERIOS_EVALUACION WHERE COMPANIA = :COMPANIA AND CLASE_EVALUACION = :CLASEEVALUACION ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/codigonombreporclaseevaluacion/pag">
		<call-query href="getEvcriteriosevaluacionPagCodigonombreporclaseevaluacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
