	<query id="insertEvcriteriosevaluacionCopiarde" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql> INSERT INTO EV_CRITERIOS_EVALUACION ( COMPANIA, CODIGO, CLASE_EVALUACION, NOMBRE, TEXTO, MOVIMIENTO, PUNTAJE, IND_GRUPO, IND_TEXTO, IND_SELECCION_MULTIPLE, CREATED_BY, DATE_CREATED, ESCOMPROMISO, PUNTAJEMAXIMO ) SELECT COMPANIA, CONCAT( TRIM(:MI_CODIGO), SUBSTR(CODIGO,LENGTH(:MI_COPIARDE) + 1,LENGTH(:MI_COPIARDE) )) CODIGO, CLASE_EVALUACION, NOMBRE, TEXTO, MOVIMIENTO, PUNTAJE, IND_GRUPO, IND_TEXTO, IND_SELECCION_MULTIPLE, :USUARIO, SYSDATE, ESCOMPROMISO, PUNTAJEMAXIMO FROM EV_CRITERIOS_EVALUACION WHERE COMPANIA =:COMPANIA AND CLASE_EVALUACION =:CLASE_EVALUACION AND SUBSTR(CODIGO,1,LENGTH(:MI_COPIARDE) ) IN ( :MI_COPIARDE ) AND LENGTH(CODIGO) &gt; LENGTH(:MI_COPIARDE) AND IND_GRUPO IN ( 0 ) ORDER BY CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MI_CODIGO" sqlType="STRING"/>
		<param name="MI_COPIARDE" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evcriteriosevaluacion/copiarde">
		<call-query href="insertEvcriteriosevaluacionCopiarde">
			<with-param name="MI_CODIGO" query-param="MI_CODIGO"/>
			<with-param name="MI_COPIARDE" query-param="MI_COPIARDE"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>

		</call-query>
	</resource>
	<query id="getEvcriteriosevaluacionPagCriteriosEvaluadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT EV_CRITERIO_GRUPO.COMPANIA, EV_CRITERIOS_EVALUACION.CODIGO CRITERIO_EVALUADO, EV_CRITERIO_GRUPO.CLASE_EVALUACION CLASE_EVALUACION, 0 VALOR_ASIGNADO, EV_CRITERIO_GRUPO.GRUPO, EV_CRITERIOS_EVALUACION.NOMBRE,(CASE EV_CRITERIOS_EVALUACION.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, EV_CRITERIOS_EVALUACION.PUNTAJE,(CASE EV_CRITERIOS_EVALUACION.IND_TEXTO WHEN 0 THEN 'false' ELSE 'true' END) IND_TEXTO, '' TEXTO  FROM EV_CRITERIOS_EVALUACION INNER JOIN EV_CRITERIO_GRUPO ON EV_CRITERIOS_EVALUACION.COMPANIA = EV_CRITERIO_GRUPO.COMPANIA AND SUBSTR(EV_CRITERIOS_EVALUACION.CODIGO,1,LENGTH(EV_CRITERIO_GRUPO.CODIGO_CRITERIO)) = EV_CRITERIO_GRUPO.CODIGO_CRITERIO AND EV_CRITERIOS_EVALUACION.CLASE_EVALUACION = EV_CRITERIO_GRUPO.CLASE_EVALUACION INNER JOIN EV_EVALUACIONES ON EV_CRITERIO_GRUPO.GRUPO = EV_EVALUACIONES.GRUPO_APLICAR AND EV_CRITERIO_GRUPO.COMPANIA = EV_EVALUACIONES.COMPANIA AND EV_CRITERIO_GRUPO.CLASE_EVALUACION = EV_EVALUACIONES.CLASE_EVALUACION WHERE EV_CRITERIO_GRUPO.COMPANIA = :COMPANIA AND EV_CRITERIO_GRUPO.CLASE_EVALUACION = :CLASE AND EV_EVALUACIONES.CONSECUTIVO = :EVALUACION AND EV_CRITERIOS_EVALUACION.MOVIMIENTO = 0 AND EV_CRITERIOS_EVALUACION.CODIGO NOT IN (SELECT EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO FROM EV_SUBDETALLE_EVALUACION INNER JOIN EV_CRITERIOS_EVALUACION ON EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO = EV_CRITERIOS_EVALUACION.CODIGO AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = EV_CRITERIOS_EVALUACION.CLASE_EVALUACION AND EV_SUBDETALLE_EVALUACION.COMPANIA = EV_CRITERIOS_EVALUACION.COMPANIA WHERE EV_SUBDETALLE_EVALUACION.COMPANIA = :COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION = :EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR = :CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = :CLASE AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION = :TIPO AND EV_SUBDETALLE_EVALUACION.MOVIMIENTO = 0 )) WHERE (CASE WHEN CRITERIO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CRITERIO_EVALUADO) END)  LIKE UPPER(:CRITERIO_EVALUADO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CRITERIO_EVALUADO":"$CRITERIO_EVALUADO","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","VALOR_ASIGNADO":"$VALOR_ASIGNADO(type:double)","GRUPO":"$GRUPO(type:integer)","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","PUNTAJE":"$PUNTAJE(type:integer)","IND_TEXTO":"$IND_TEXTO(type:boolean)","TEXTO":"$TEXTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/criteriosevaluados/pag">
		<call-query href="getEvcriteriosevaluacionPagCriteriosEvaluadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CRITERIO_EVALUADO" query-param="CRITERIO_EVALUADO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvcriteriosevaluacionNumCriteriosEvaluadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT EV_CRITERIO_GRUPO.COMPANIA, EV_CRITERIOS_EVALUACION.CODIGO CRITERIO_EVALUADO, EV_CRITERIO_GRUPO.CLASE_EVALUACION CLASE_EVALUACION, 0 VALOR_ASIGNADO, EV_CRITERIO_GRUPO.GRUPO, EV_CRITERIOS_EVALUACION.NOMBRE,(CASE EV_CRITERIOS_EVALUACION.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, EV_CRITERIOS_EVALUACION.PUNTAJE,(CASE EV_CRITERIOS_EVALUACION.IND_TEXTO WHEN 0 THEN 'false' ELSE 'true' END) IND_TEXTO, '' TEXTO  FROM EV_CRITERIOS_EVALUACION INNER JOIN EV_CRITERIO_GRUPO ON EV_CRITERIOS_EVALUACION.COMPANIA = EV_CRITERIO_GRUPO.COMPANIA AND SUBSTR(EV_CRITERIOS_EVALUACION.CODIGO,1,LENGTH(EV_CRITERIO_GRUPO.CODIGO_CRITERIO)) = EV_CRITERIO_GRUPO.CODIGO_CRITERIO AND EV_CRITERIOS_EVALUACION.CLASE_EVALUACION = EV_CRITERIO_GRUPO.CLASE_EVALUACION INNER JOIN EV_EVALUACIONES ON EV_CRITERIO_GRUPO.GRUPO = EV_EVALUACIONES.GRUPO_APLICAR AND EV_CRITERIO_GRUPO.COMPANIA = EV_EVALUACIONES.COMPANIA AND EV_CRITERIO_GRUPO.CLASE_EVALUACION = EV_EVALUACIONES.CLASE_EVALUACION WHERE EV_CRITERIO_GRUPO.COMPANIA = :COMPANIA AND EV_CRITERIO_GRUPO.CLASE_EVALUACION = :CLASE AND EV_EVALUACIONES.CONSECUTIVO = :EVALUACION AND EV_CRITERIOS_EVALUACION.MOVIMIENTO = 0 AND EV_CRITERIOS_EVALUACION.CODIGO NOT IN (SELECT EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO FROM EV_SUBDETALLE_EVALUACION INNER JOIN EV_CRITERIOS_EVALUACION ON EV_SUBDETALLE_EVALUACION.CRITERIO_EVALUADO = EV_CRITERIOS_EVALUACION.CODIGO AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = EV_CRITERIOS_EVALUACION.CLASE_EVALUACION AND EV_SUBDETALLE_EVALUACION.COMPANIA = EV_CRITERIOS_EVALUACION.COMPANIA WHERE EV_SUBDETALLE_EVALUACION.COMPANIA = :COMPANIA AND EV_SUBDETALLE_EVALUACION.EVALUACION = :EVALUACION AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_SUBDETALLE_EVALUACION.CEDULA_EVALUADOR = :CEDULA_EVALUADOR AND EV_SUBDETALLE_EVALUACION.CLASE_EVALUACION = :CLASE AND EV_SUBDETALLE_EVALUACION.TIPO_EVALUACION = :TIPO AND EV_SUBDETALLE_EVALUACION.MOVIMIENTO = 0 )) WHERE (CASE WHEN CRITERIO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CRITERIO_EVALUADO) END)  LIKE UPPER(:CRITERIO_EVALUADO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CRITERIO_EVALUADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/criteriosevaluados/num">
		<call-query href="getEvcriteriosevaluacionNumCriteriosEvaluadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CRITERIO_EVALUADO" query-param="CRITERIO_EVALUADO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

</data>