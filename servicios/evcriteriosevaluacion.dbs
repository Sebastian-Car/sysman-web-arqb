	<query id="updateEvcriteriosevaluacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_CRITERIOS_EVALUACION SET CODIGO=:CODIGO, CLASE_EVALUACION=:CLASE_EVALUACION, NOMBRE=:NOMBRE, TEXTO=:TEXTO, MOVIMIENTO=:MOVIMIENTO, ESCOMPROMISO=:ESCOMPROMISO, PUNTAJEMAXIMO=:PUNTAJEMAXIMO, PUNTAJE=:PUNTAJE, IND_GRUPO=:IND_GRUPO, IND_TEXTO=:IND_TEXTO, IND_SELECCION_MULTIPLE=:IND_SELECCION_MULTIPLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_CRITERIOS_EVALUACION.COMPANIA= :KEY_COMPANIA AND EV_CRITERIOS_EVALUACION.CODIGO= :KEY_CODIGO AND EV_CRITERIOS_EVALUACION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="ESCOMPROMISO" sqlType="STRING"/>
		<param name="PUNTAJEMAXIMO" sqlType="STRING"/>
		<param name="PUNTAJE" sqlType="STRING"/>
		<param name="IND_GRUPO" sqlType="STRING"/>
		<param name="IND_TEXTO" sqlType="STRING"/>
		<param name="IND_SELECCION_MULTIPLE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>

	</query>
