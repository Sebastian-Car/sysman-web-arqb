	<query id="getEvcriteriosevaluacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, CLASE_EVALUACION, NOMBRE, TEXTO,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE ESCOMPROMISO WHEN 0 THEN 'false' ELSE 'true' END) ESCOMPROMISO, PUNTAJEMAXIMO, PUNTAJE,(CASE IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO,(CASE IND_TEXTO WHEN 0 THEN 'false' ELSE 'true' END) IND_TEXTO,(CASE IND_SELECCION_MULTIPLE WHEN 0 THEN 'false' ELSE 'true' END) IND_SELECCION_MULTIPLE, NULL COPIAR_DE  FROM EV_CRITERIOS_EVALUACION WHERE COMPANIA = :COMPANIA AND CLASE_EVALUACION = :CLASE_EVALUACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END)  LIKE UPPER( '%' || :TEXTO || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%')  AND (CASE WHEN ESCOMPROMISO IS NULL THEN ' ' ELSE UPPER(ESCOMPROMISO) END)  LIKE UPPER(:ESCOMPROMISO || '%')  AND (CASE WHEN PUNTAJEMAXIMO IS NULL THEN ' ' ELSE UPPER(PUNTAJEMAXIMO) END)  LIKE UPPER(:PUNTAJEMAXIMO || '%')  AND (CASE WHEN PUNTAJE IS NULL THEN ' ' ELSE UPPER(PUNTAJE) END)  LIKE UPPER(:PUNTAJE || '%')  AND (CASE WHEN IND_GRUPO IS NULL THEN ' ' ELSE UPPER(IND_GRUPO) END)  LIKE UPPER(:IND_GRUPO || '%')  AND (CASE WHEN IND_TEXTO IS NULL THEN ' ' ELSE UPPER(IND_TEXTO) END)  LIKE UPPER(:IND_TEXTO || '%')  AND (CASE WHEN IND_SELECCION_MULTIPLE IS NULL THEN ' ' ELSE UPPER(IND_SELECCION_MULTIPLE) END)  LIKE UPPER(:IND_SELECCION_MULTIPLE || '%')  AND (CASE WHEN COPIAR_DE IS NULL THEN ' ' ELSE UPPER(COPIAR_DE) END)  LIKE UPPER(:COPIAR_DE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
