			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvcriteriosevaluacionNumCriteriosPadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE,(CASE ESCOMPROMISO WHEN 0 THEN 'false' ELSE 'true' END) ESCOMPROMISO,(CASE IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO, CLASE_EVALUACION  FROM EV_CRITERIOS_EVALUACION WHERE COMPANIA = :COMPANIA AND MOVIMIENTO IN (0) AND IND_GRUPO NOT IN (0) AND CLASE_EVALUACION = :CLASEEVALUACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/criteriospadre/num">
		<call-query href="getEvcriteriosevaluacionNumCriteriosPadreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertEvcriteriosevaluacion" keyColumns="COMPANIA,CODIGO,CLASE_EVALUACION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_CRITERIOS_EVALUACION (COMPANIA, CODIGO, CLASE_EVALUACION, NOMBRE, TEXTO, MOVIMIENTO, ESCOMPROMISO, PUNTAJEMAXIMO, PUNTAJE, IND_GRUPO, IND_TEXTO, IND_SELECCION_MULTIPLE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :CLASE_EVALUACION, :NOMBRE, :TEXTO, :MOVIMIENTO, :ESCOMPROMISO, :PUNTAJEMAXIMO, :PUNTAJE, :IND_GRUPO, :IND_TEXTO, :IND_SELECCION_MULTIPLE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="TEXTO" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="ESCOMPROMISO" sqlType="STRING"/>
		<param defaultValue="0" name="PUNTAJEMAXIMO" sqlType="STRING"/>
		<param defaultValue="0" name="PUNTAJE" sqlType="STRING"/>
		<param defaultValue="0" name="IND_GRUPO" sqlType="STRING"/>
		<param defaultValue="0" name="IND_TEXTO" sqlType="STRING"/>
		<param defaultValue="0" name="IND_SELECCION_MULTIPLE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evcriteriosevaluacion">
		<call-query href="insertEvcriteriosevaluacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="ESCOMPROMISO" query-param="ESCOMPROMISO"/>
			<with-param name="PUNTAJEMAXIMO" query-param="PUNTAJEMAXIMO"/>
			<with-param name="PUNTAJE" query-param="PUNTAJE"/>
			<with-param name="IND_GRUPO" query-param="IND_GRUPO"/>
			<with-param name="IND_TEXTO" query-param="IND_TEXTO"/>
			<with-param name="IND_SELECCION_MULTIPLE" query-param="IND_SELECCION_MULTIPLE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEvcriteriosevaluacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_CRITERIOS_EVALUACION WHERE EV_CRITERIOS_EVALUACION.COMPANIA= :KEY_COMPANIA AND EV_CRITERIOS_EVALUACION.CODIGO= :KEY_CODIGO AND EV_CRITERIOS_EVALUACION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="evcriteriosevaluacion">
		<call-query href="deleteEvcriteriosevaluacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>

		</call-query>
	</resource>
	<query id="getEvcriteriosevaluacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, CLASE_EVALUACION, NOMBRE, TEXTO,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE ESCOMPROMISO WHEN 0 THEN 'false' ELSE 'true' END) ESCOMPROMISO, PUNTAJEMAXIMO, PUNTAJE,(CASE IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO,(CASE IND_TEXTO WHEN 0 THEN 'false' ELSE 'true' END) IND_TEXTO,(CASE IND_SELECCION_MULTIPLE WHEN 0 THEN 'false' ELSE 'true' END) IND_SELECCION_MULTIPLE, NULL COPIAR_DE  FROM EV_CRITERIOS_EVALUACION WHERE COMPANIA = :COMPANIA AND CLASE_EVALUACION = :CLASE_EVALUACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END)  LIKE UPPER( '%' || :TEXTO || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%')  AND (CASE WHEN ESCOMPROMISO IS NULL THEN ' ' ELSE UPPER(ESCOMPROMISO) END)  LIKE UPPER(:ESCOMPROMISO || '%')  AND (CASE WHEN PUNTAJEMAXIMO IS NULL THEN ' ' ELSE UPPER(PUNTAJEMAXIMO) END)  LIKE UPPER(:PUNTAJEMAXIMO || '%')  AND (CASE WHEN PUNTAJE IS NULL THEN ' ' ELSE UPPER(PUNTAJE) END)  LIKE UPPER(:PUNTAJE || '%')  AND (CASE WHEN IND_GRUPO IS NULL THEN ' ' ELSE UPPER(IND_GRUPO) END)  LIKE UPPER(:IND_GRUPO || '%')  AND (CASE WHEN IND_TEXTO IS NULL THEN ' ' ELSE UPPER(IND_TEXTO) END)  LIKE UPPER(:IND_TEXTO || '%')  AND (CASE WHEN IND_SELECCION_MULTIPLE IS NULL THEN ' ' ELSE UPPER(IND_SELECCION_MULTIPLE) END)  LIKE UPPER(:IND_SELECCION_MULTIPLE || '%')  AND (CASE WHEN COPIAR_DE IS NULL THEN ' ' ELSE UPPER(COPIAR_DE) END)  LIKE UPPER(:COPIAR_DE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","NOMBRE":"$NOMBRE","TEXTO":"$TEXTO","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","ESCOMPROMISO":"$ESCOMPROMISO(type:boolean)","PUNTAJEMAXIMO":"$PUNTAJEMAXIMO(type:integer)","PUNTAJE":"$PUNTAJE(type:integer)","IND_GRUPO":"$IND_GRUPO(type:boolean)","IND_TEXTO":"$IND_TEXTO(type:boolean)","IND_SELECCION_MULTIPLE":"$IND_SELECCION_MULTIPLE(type:boolean)","COPIAR_DE":"$COPIAR_DE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="ESCOMPROMISO" sqlType="STRING"/>
		<param name="PUNTAJEMAXIMO" sqlType="STRING"/>
		<param name="PUNTAJE" sqlType="STRING"/>
		<param name="IND_GRUPO" sqlType="STRING"/>
		<param name="IND_TEXTO" sqlType="STRING"/>
		<param name="IND_SELECCION_MULTIPLE" sqlType="STRING"/>
		<param name="COPIAR_DE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
