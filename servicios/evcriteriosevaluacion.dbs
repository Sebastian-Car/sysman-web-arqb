	<query id="getEvcriteriosevaluacionTotalDePuntajePorPadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(PUNTAJE) PUNTAJE  FROM EV_CRITERIOS_EVALUACION WHERE COMPANIA = :COMPANIA AND MOVIMIENTO NOT IN (0) AND IND_GRUPO IN(0) AND CLASE_EVALUACION = :CLASEEVALUACION AND SUBSTR(CODIGO,1,LENGTH(:CODIGO)) = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PUNTAJE":"$PUNTAJE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/totaldepuntajeporpadre">
		<call-query href="getEvcriteriosevaluacionTotalDePuntajePorPadreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getEvcriteriosevaluacionPagCriteriosPadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE,(CASE ESCOMPROMISO WHEN 0 THEN 'false' ELSE 'true' END) ESCOMPROMISO,(CASE IND_GRUPO WHEN 0 THEN 'false' ELSE 'true' END) IND_GRUPO, CLASE_EVALUACION  FROM EV_CRITERIOS_EVALUACION WHERE COMPANIA = :COMPANIA AND MOVIMIENTO IN (0) AND IND_GRUPO NOT IN (0) AND CLASE_EVALUACION = :CLASEEVALUACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ESCOMPROMISO":"$ESCOMPROMISO(type:boolean)","IND_GRUPO":"$IND_GRUPO(type:boolean)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evcriteriosevaluacion/criteriospadre/pag">
		<call-query href="getEvcriteriosevaluacionPagCriteriosPadreQuery">
