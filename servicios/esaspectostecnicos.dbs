<data name="esaspectostecnicos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsaspectostecnicosPagCodnombreportipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COD_ASPTEC, NOMBRE  FROM ES_ASP_TECN WHERE COMPANIA = :COMPANIA AND COD_T_ASPTEC = :COD_T_ASPTEC) WHERE (CASE WHEN COD_ASPTEC IS NULL THEN ' ' ELSE UPPER(COD_ASPTEC) END)  LIKE UPPER(:COD_ASPTEC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_ASPTEC":"$COD_ASPTEC(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_ASPTEC" sqlType="STRING"/>
		<param name="COD_ASPTEC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esaspectostecnicos/codnombreportipo/pag">
		<call-query href="getEsaspectostecnicosPagCodnombreportipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_ASPTEC" query-param="COD_T_ASPTEC"/>
			<with-param name="COD_ASPTEC" query-param="COD_ASPTEC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsaspectostecnicosNumCodnombreportipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COD_ASPTEC, NOMBRE  FROM ES_ASP_TECN WHERE COMPANIA = :COMPANIA AND COD_T_ASPTEC = :COD_T_ASPTEC) WHERE (CASE WHEN COD_ASPTEC IS NULL THEN ' ' ELSE UPPER(COD_ASPTEC) END)  LIKE UPPER(:COD_ASPTEC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_ASPTEC" sqlType="STRING"/>
		<param name="COD_ASPTEC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esaspectostecnicos/codnombreportipo/num">
		<call-query href="getEsaspectostecnicosNumCodnombreportipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_ASPTEC" query-param="COD_T_ASPTEC"/>
			<with-param name="COD_ASPTEC" query-param="COD_ASPTEC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertEsaspectostecnicos" keyColumns="COMPANIA,COD_ASPTEC,COD_T_ASPTEC" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_ASP_TECN (COMPANIA, COD_ASPTEC, COD_T_ASPTEC, NOMBRE, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_ASPTEC, :COD_T_ASPTEC, :NOMBRE, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ASPTEC":"$COD_ASPTEC(type:integer)","KEY_COD_T_ASPTEC":"$COD_T_ASPTEC(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ASPTEC" sqlType="STRING"/>
		<param name="COD_T_ASPTEC" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esaspectostecnicos">
		<call-query href="insertEsaspectostecnicos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ASPTEC" query-param="COD_ASPTEC"/>
			<with-param name="COD_T_ASPTEC" query-param="COD_T_ASPTEC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsaspectostecnicos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_ASP_TECN WHERE ES_ASP_TECN.COMPANIA= :KEY_COMPANIA AND ES_ASP_TECN.COD_ASPTEC= :KEY_COD_ASPTEC AND ES_ASP_TECN.COD_T_ASPTEC= :KEY_COD_T_ASPTEC</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ASPTEC" sqlType="INTEGER"/>
		<param name="KEY_COD_T_ASPTEC" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="esaspectostecnicos">
		<call-query href="deleteEsaspectostecnicos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ASPTEC" query-param="KEY_COD_ASPTEC"/>
			<with-param name="KEY_COD_T_ASPTEC" query-param="KEY_COD_T_ASPTEC"/>

		</call-query>
	</resource>
	<query id="getEsaspectostecnicosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_ASP_TECN.COMPANIA, ES_ASP_TECN.COD_ASPTEC, ES_ASP_TECN.COD_T_ASPTEC, ES_ASP_TECN.NOMBRE, ES_ASP_TECN.DESCRIPCION  FROM ES_ASP_TECN WHERE COMPANIA = :COMPANIA AND ES_ASP_TECN.COD_T_ASPTEC= :CODIGO) WHERE (CASE WHEN COD_ASPTEC IS NULL THEN ' ' ELSE UPPER(COD_ASPTEC) END)  LIKE UPPER(:COD_ASPTEC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ASPTEC":"$COD_ASPTEC(type:integer)","COD_T_ASPTEC":"$COD_T_ASPTEC(type:integer)","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COD_ASPTEC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esaspectostecnicos">
		<call-query href="getEsaspectostecnicosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COD_ASPTEC" query-param="COD_ASPTEC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsaspectostecnicosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_ASP_TECN.COMPANIA, ES_ASP_TECN.COD_ASPTEC, ES_ASP_TECN.COD_T_ASPTEC, ES_ASP_TECN.NOMBRE, ES_ASP_TECN.DESCRIPCION  FROM ES_ASP_TECN WHERE COMPANIA = :COMPANIA AND ES_ASP_TECN.COD_T_ASPTEC= :CODIGO) WHERE (CASE WHEN COD_ASPTEC IS NULL THEN ' ' ELSE UPPER(COD_ASPTEC) END)  LIKE UPPER(:COD_ASPTEC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COD_ASPTEC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esaspectostecnicos/numero">
		<call-query href="getEsaspectostecnicosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COD_ASPTEC" query-param="COD_ASPTEC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateEsaspectostecnicos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ASP_TECN SET COD_ASPTEC=:COD_ASPTEC, NOMBRE=:NOMBRE, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_ASP_TECN.COMPANIA= :KEY_COMPANIA AND ES_ASP_TECN.COD_ASPTEC= :KEY_COD_ASPTEC AND ES_ASP_TECN.COD_T_ASPTEC= :KEY_COD_T_ASPTEC</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COD_ASPTEC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ASPTEC" sqlType="STRING"/>
		<param name="KEY_COD_T_ASPTEC" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esaspectostecnicos">
		<call-query href="updateEsaspectostecnicos">
			<with-param name="COD_ASPTEC" query-param="COD_ASPTEC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ASPTEC" query-param="KEY_COD_ASPTEC"/>
			<with-param name="KEY_COD_T_ASPTEC" query-param="KEY_COD_T_ASPTEC"/>

		</call-query>
	</resource>

</data>