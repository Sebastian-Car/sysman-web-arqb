		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="PREIND" sqlType="STRING"/>
		<param name="TRPRAN" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
