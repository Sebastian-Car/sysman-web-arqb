	<query id="getIpfacturadosreservaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_FACTURADOSRESERVA.COMPANIA, IP_FACTURADOSRESERVA.CONSECUTIVO, IP_FACTURADOSRESERVA.PREANO, IP_FACTURADOSRESERVA.AVALUO, IP_FACTURADOSRESERVA.PREIND, CASE WHEN IP_FACTURADOSRESERVA.PREIND = 'M' THEN 'Manual' ELSE 'Retroactivo' END PREINDT , IP_FACTURADOSRESERVA.TRPRAN, IP_FACTURADOSRESERVA.TRPCOD,(CASE IP_FACTURADOSRESERVA.INDHIP WHEN 0 THEN 'false' ELSE 'true' END) INDHIP,(CASE IP_FACTURADOSRESERVA.INDCAR WHEN 0 THEN 'false' ELSE 'true' END) INDCAR,(CASE IP_FACTURADOSRESERVA.INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE,(CASE IP_FACTURADOSRESERVA.ANTERIOR_RURAL WHEN 0 THEN 'false' ELSE 'true' END) ANTERIOR_RURAL, IP_FACTURADOSRESERVA.CODIGO, IP_FACTURADOSRESERVA.NUMERO_ORDEN,(CASE IP_FACTURADOSRESERVA.NOCOBRADO WHEN 0 THEN 'false' ELSE 'true' END) NOCOBRADO, IP_FACTURADOSRESERVA.OBSERVACIONES,(TO_CHAR(IP_FACTURADOSRESERVA.PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, IP_FACTURADOSRESERVA.DOCNUM, IP_FACTURADOSRESERVA.PAG_BAN, IP_FACTURADOSRESERVA.PREVAL, IP_FACTURADOSRESERVA.TRPPOR,(CASE IP_FACTURADOSRESERVA.PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, TO_CHAR(IP_FACTURADOSRESERVA.FECHAPAGO,'DD/MM/YYYY') FECHAPAGO, TO_CHAR(IP_FACTURADOSRESERVA.FECHAPRESCRIPCION,'DD/MM/YYYY') FECHAPRESCRIPCION, IP_FACTURADOSRESERVA.TOTALABONADO, IP_FACTURADOSRESERVA.VALORULTIMOABONO, TO_CHAR(IP_FACTURADOSRESERVA.FECHAULTIMOABONO,'DD/MM/YYYY') FECHAULTIMOABONO,(CASE IP_FACTURADOSRESERVA.INDPAGO_ACPAG WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_ACPAG,(CASE IP_FACTURADOSRESERVA.INDEXEOTROS WHEN 0 THEN 'false' ELSE 'true' END) INDEXEOTROS,(CASE IP_FACTURADOSRESERVA.INDPAGO_CUOTAS WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_CUOTAS,(CASE IP_FACTURADOSRESERVA.IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD, IP_FACTURADOSRESERVA.AREAM2, IP_FACTURADOSRESERVA.AREA_CONSTRUIDA, IP_FACTURADOSRESERVA.TOTAL VALORXVIGENCIA  FROM IP_FACTURADOSRESERVA WHERE IP_FACTURADOSRESERVA.COMPANIA = :COMPANIA AND IP_FACTURADOSRESERVA.CODIGO = :CODIGOELEMENTO AND IP_FACTURADOSRESERVA.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_FACTURADOSRESERVA.PREANO DESC, IP_FACTURADOSRESERVA.CODIGO) WHERE (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN PREIND IS NULL THEN ' ' ELSE UPPER(PREIND) END)  LIKE UPPER( '%' || :PREIND || '%')  AND (CASE WHEN TRPRAN IS NULL THEN ' ' ELSE UPPER(TRPRAN) END)  LIKE UPPER( '%' || :TRPRAN || '%')  AND (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER( '%' || :TRPCOD || '%')  AND (CASE WHEN INDCAR IS NULL THEN ' ' ELSE UPPER(INDCAR) END)  LIKE UPPER( '%' || :INDCAR || '%')  AND (CASE WHEN INDEXE IS NULL THEN ' ' ELSE UPPER(INDEXE) END)  LIKE UPPER( '%' || :INDEXE || '%')  AND (CASE WHEN ANTERIOR_RURAL IS NULL THEN ' ' ELSE UPPER(ANTERIOR_RURAL) END)  LIKE UPPER( '%' || :ANTERIOR_RURAL || '%')  AND (CASE WHEN NOCOBRADO IS NULL THEN ' ' ELSE UPPER(NOCOBRADO) END)  LIKE UPPER( '%' || :NOCOBRADO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER( '%' || :PAG_BAN || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER( '%' || :PREVAL || '%')  AND (CASE WHEN TRPPOR IS NULL THEN ' ' ELSE UPPER(TRPPOR) END)  LIKE UPPER( '%' || :TRPPOR || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%')  AND (CASE WHEN FECHAPRESCRIPCION IS NULL THEN ' ' ELSE UPPER(FECHAPRESCRIPCION) END)  LIKE UPPER( '%' || :FECHAPRESCRIPCION || '%')  AND (CASE WHEN TOTALABONADO IS NULL THEN ' ' ELSE UPPER(TOTALABONADO) END)  LIKE UPPER( '%' || :TOTALABONADO || '%')  AND (CASE WHEN VALORULTIMOABONO IS NULL THEN ' ' ELSE UPPER(VALORULTIMOABONO) END)  LIKE UPPER( '%' || :VALORULTIMOABONO || '%')  AND (CASE WHEN FECHAULTIMOABONO IS NULL THEN ' ' ELSE UPPER(FECHAULTIMOABONO) END)  LIKE UPPER( '%' || :FECHAULTIMOABONO || '%')  AND (CASE WHEN INDPAGO_ACPAG IS NULL THEN ' ' ELSE UPPER(INDPAGO_ACPAG) END)  LIKE UPPER( '%' || :INDPAGO_ACPAG || '%')  AND (CASE WHEN INDEXEOTROS IS NULL THEN ' ' ELSE UPPER(INDEXEOTROS) END)  LIKE UPPER( '%' || :INDEXEOTROS || '%')  AND (CASE WHEN INDPAGO_CUOTAS IS NULL THEN ' ' ELSE UPPER(INDPAGO_CUOTAS) END)  LIKE UPPER( '%' || :INDPAGO_CUOTAS || '%')  AND (CASE WHEN IND_PROCESOJUD IS NULL THEN ' ' ELSE UPPER(IND_PROCESOJUD) END)  LIKE UPPER( '%' || :IND_PROCESOJUD || '%')  AND (CASE WHEN AREAM2 IS NULL THEN ' ' ELSE UPPER(AREAM2) END)  LIKE UPPER( '%' || :AREAM2 || '%')  AND (CASE WHEN AREA_CONSTRUIDA IS NULL THEN ' ' ELSE UPPER(AREA_CONSTRUIDA) END)  LIKE UPPER( '%' || :AREA_CONSTRUIDA || '%')  AND (CASE WHEN VALORXVIGENCIA IS NULL THEN ' ' ELSE UPPER(VALORXVIGENCIA) END)  LIKE UPPER( '%' || :VALORXVIGENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
