	<query id="getVidetallescategoriaconceptoCiudadDestinoTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT CIUDAD.CODIGO, CIUDAD.NOMBRE  FROM VI_DETALLE_CATEGORIA_CONCEPTO INNER JOIN CIUDAD ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADDESTINO = CIUDAD.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTODESTINO = CIUDAD.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISDESTINO = CIUDAD.PAIS INNER JOIN DEPARTAMENTO ON CIUDAD.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND CIUDAD.PAIS = DEPARTAMENTO.PAIS INNER JOIN PAISES ON DEPARTAMENTO.PAIS = PAISES.PAIS INNER JOIN PERSONAL ON VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = PERSONAL.ID_DE_CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = PERSONAL.ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = PERSONAL.COMPANIA WHERE PERSONAL.COMPANIA = :COMPANIA AND DEPARTAMENTO.PAIS = :PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO AND PERSONAL.NUMERO_DCTO = :TERCERO AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = :ANO</sql>
