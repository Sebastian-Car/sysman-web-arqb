	<query id="updateVidetallescategoriaconcepto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_DETALLE_CATEGORIA_CONCEPTO SET COMPANIA=:COMPANIA, ANO=:ANO, ESCALAFON=:ESCALAFON, ID_CATEGORIA=:ID_CATEGORIA, CODIGO_CONCEPTO=:CODIGO_CONCEPTO, CONSECUTIVO=:CONSECUTIVO, TARIFA=:TARIFA, PAISORIGEN=:PAISORIGEN, DEPARTAMENTOORIGEN=:DEPARTAMENTOORIGEN, CIUDADORIGEN=:CIUDADORIGEN, PAISDESTINO=:PAISDESTINO, DEPARTAMENTODESTINO=:DEPARTAMENTODESTINO, CIUDADDESTINO=:CIUDADDESTINO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA= :KEY_COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO= :KEY_ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON= :KEY_ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA= :KEY_ID_CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO AND VI_DETALLE_CATEGORIA_CONCEPTO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_CATEGORIA" sqlType="STRING"/>
