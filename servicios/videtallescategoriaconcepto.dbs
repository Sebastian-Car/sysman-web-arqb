<data name="videtallescategoriaconcepto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVidetallescategoriaconceptoPaisDeOrigenPorTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PAISES.PAIS, PAISES.NOMBRE, PERSONAL.ID_DE_EMPLEADO  FROM VI_DETALLE_CATEGORIA_CONCEPTO INNER JOIN CIUDAD ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADORIGEN = CIUDAD.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTOORIGEN = CIUDAD.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = CIUDAD.PAIS INNER JOIN DEPARTAMENTO ON CIUDAD.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND CIUDAD.PAIS = DEPARTAMENTO.PAIS INNER JOIN PAISES ON DEPARTAMENTO.PAIS = PAISES.PAIS INNER JOIN PERSONAL ON VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = PERSONAL.ID_DE_CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = PERSONAL.ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = PERSONAL.COMPANIA WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.NUMERO_DCTO = :TERCERO AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","NOMBRE":"$NOMBRE","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtallescategoriaconcepto/paisdeorigenportercero">
		<call-query href="getVidetallescategoriaconceptoPaisDeOrigenPorTerceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getVidetallescategoriaconceptoDepartamentoDeOrigenPorTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE, PERSONAL.ID_DE_EMPLEADO, DEPARTAMENTO.PAIS  FROM VI_DETALLE_CATEGORIA_CONCEPTO INNER JOIN CIUDAD ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADORIGEN = CIUDAD.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTOORIGEN = CIUDAD.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = CIUDAD.PAIS INNER JOIN DEPARTAMENTO ON CIUDAD.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND CIUDAD.PAIS = DEPARTAMENTO.PAIS INNER JOIN PAISES ON DEPARTAMENTO.PAIS = PAISES.PAIS INNER JOIN PERSONAL ON VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = PERSONAL.ID_DE_CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = PERSONAL.ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = PERSONAL.COMPANIA WHERE PERSONAL.COMPANIA = :COMPANIA AND DEPARTAMENTO.PAIS = :PAIS AND personal.NUMERO_DCTO = :TERCERO AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","PAIS":"$PAIS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtallescategoriaconcepto/departamentodeorigenportercero">
		<call-query href="getVidetallescategoriaconceptoDepartamentoDeOrigenPorTerceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getVidetallescategoriaconceptoCiudadDeOrigenPorTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT CIUDAD.CODIGO, CIUDAD.NOMBRE, PERSONAL.ID_DE_EMPLEADO, CIUDAD.PAIS, CIUDAD.DEPARTAMENTO  FROM VI_DETALLE_CATEGORIA_CONCEPTO INNER JOIN CIUDAD ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADORIGEN = CIUDAD.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTOORIGEN = CIUDAD.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = CIUDAD.PAIS INNER JOIN DEPARTAMENTO ON CIUDAD.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND CIUDAD.PAIS = DEPARTAMENTO.PAIS INNER JOIN PAISES ON DEPARTAMENTO.PAIS = PAISES.PAIS INNER JOIN PERSONAL ON VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = PERSONAL.ID_DE_CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = PERSONAL.ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = PERSONAL.COMPANIA WHERE PERSONAL.COMPANIA = :COMPANIA AND CIUDAD.PAIS = :PAIS AND CIUDAD.DEPARTAMENTO = :DEPARTAMENTO AND PERSONAL.NUMERO_DCTO = :TERCERO AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtallescategoriaconcepto/ciudaddeorigenportercero">
