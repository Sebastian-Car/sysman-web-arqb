	<query id="getVidetallescategoriaconceptoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA, VI_DETALLE_CATEGORIA_CONCEPTO.ANO, VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON, VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA, VI_DETALLE_CATEGORIA_CONCEPTO.CONSECUTIVO, VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE NOMBRECONCEPTO, PAISORIGEN, PAISES.NOMBRE PAISORIGENNOMBRE, DEPARTAMENTOORIGEN, DEPARTAMENTO.NOMBRE DEPTOORIGENNOMBRE, CIUDADORIGEN, CIUDAD.NOMBRE CIUDADORIGENNOMBRE, PAISDESTINO, PAISESDESTINO.NOMBRE PAISDESTINONOMBRE, DEPARTAMENTODESTINO, DEPTODESTINO.NOMBRE DEPTODESTINONOMBRE, CIUDADDESTINO, CIUDADDESTINO.NOMBRE CIUDADDESTINONOMBRE, VI_DETALLE_CATEGORIA_CONCEPTO.TARIFA  FROM VI_DETALLE_CATEGORIA_CONCEPTO LEFT JOIN PAISES ON VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = PAISES.PAIS LEFT JOIN DEPARTAMENTO ON VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTOORIGEN = DEPARTAMENTO.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = DEPARTAMENTO.PAIS LEFT JOIN CIUDAD ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADORIGEN = CIUDAD.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTOORIGEN = CIUDAD.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = CIUDAD.PAIS LEFT JOIN PAISES PAISESDESTINO ON VI_DETALLE_CATEGORIA_CONCEPTO.PAISDESTINO = PAISESDESTINO.PAIS LEFT JOIN DEPARTAMENTO DEPTODESTINO ON VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTODESTINO = DEPTODESTINO.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISDESTINO = DEPTODESTINO.PAIS LEFT JOIN CIUDAD CIUDADDESTINO ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADDESTINO = CIUDADDESTINO.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTODESTINO = CIUDADDESTINO.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISDESTINO = CIUDADDESTINO.PAIS LEFT JOIN VI_CONCEPTO_VIATICOS ON VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = VI_CONCEPTO_VIATICOS.COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO = VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = VI_CONCEPTO_VIATICOS.ANO WHERE VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = :COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = :CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = :ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = :ESCALAFON) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN PAISORIGENNOMBRE IS NULL THEN ' ' ELSE UPPER(PAISORIGENNOMBRE) END)  LIKE UPPER( '%' || :PAISORIGENNOMBRE || '%')  AND (CASE WHEN DEPTOORIGENNOMBRE IS NULL THEN ' ' ELSE UPPER(DEPTOORIGENNOMBRE) END)  LIKE UPPER( '%' || :DEPTOORIGENNOMBRE || '%')  AND (CASE WHEN CIUDADORIGENNOMBRE IS NULL THEN ' ' ELSE UPPER(CIUDADORIGENNOMBRE) END)  LIKE UPPER( '%' || :CIUDADORIGENNOMBRE || '%')  AND (CASE WHEN PAISDESTINONOMBRE IS NULL THEN ' ' ELSE UPPER(PAISDESTINONOMBRE) END)  LIKE UPPER( '%' || :PAISDESTINONOMBRE || '%')  AND (CASE WHEN DEPTODESTINONOMBRE IS NULL THEN ' ' ELSE UPPER(DEPTODESTINONOMBRE) END)  LIKE UPPER( '%' || :DEPTODESTINONOMBRE || '%')  AND (CASE WHEN CIUDADDESTINONOMBRE IS NULL THEN ' ' ELSE UPPER(CIUDADDESTINONOMBRE) END)  LIKE UPPER( '%' || :CIUDADDESTINONOMBRE || '%')  AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END)  LIKE UPPER( '%' || :TARIFA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
