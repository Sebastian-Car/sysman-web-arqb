	<query id="insertVidetallescategoriaconcepto" keyColumns="COMPANIA,ANO,ESCALAFON,ID_CATEGORIA,CODIGO_CONCEPTO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VI_DETALLE_CATEGORIA_CONCEPTO (COMPANIA, ANO, ESCALAFON, ID_CATEGORIA, CODIGO_CONCEPTO, CONSECUTIVO, TARIFA, PAISORIGEN, DEPARTAMENTOORIGEN, CIUDADORIGEN, PAISDESTINO, DEPARTAMENTODESTINO, CIUDADDESTINO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :ESCALAFON, :ID_CATEGORIA, :CODIGO_CONCEPTO, :CONSECUTIVO, :TARIFA, :PAISORIGEN, :DEPARTAMENTOORIGEN, :CIUDADORIGEN, :PAISDESTINO, :DEPARTAMENTODESTINO, :CIUDADDESTINO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_ESCALAFON":"$ESCALAFON","KEY_ID_CATEGORIA":"$ID_CATEGORIA","KEY_CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_CATEGORIA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="1" name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="TARIFA" sqlType="STRING"/>
		<param defaultValue="" name="PAISORIGEN" sqlType="STRING"/>
		<param defaultValue="" name="DEPARTAMENTOORIGEN" sqlType="STRING"/>
		<param defaultValue="" name="CIUDADORIGEN" sqlType="STRING"/>
		<param defaultValue="" name="PAISDESTINO" sqlType="STRING"/>
		<param defaultValue="" name="DEPARTAMENTODESTINO" sqlType="STRING"/>
		<param defaultValue="" name="CIUDADDESTINO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="videtallescategoriaconcepto">
		<call-query href="insertVidetallescategoriaconcepto">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_CATEGORIA" query-param="ID_CATEGORIA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="PAISORIGEN" query-param="PAISORIGEN"/>
			<with-param name="DEPARTAMENTOORIGEN" query-param="DEPARTAMENTOORIGEN"/>
			<with-param name="CIUDADORIGEN" query-param="CIUDADORIGEN"/>
			<with-param name="PAISDESTINO" query-param="PAISDESTINO"/>
			<with-param name="DEPARTAMENTODESTINO" query-param="DEPARTAMENTODESTINO"/>
			<with-param name="CIUDADDESTINO" query-param="CIUDADDESTINO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVidetallescategoriaconcepto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VI_DETALLE_CATEGORIA_CONCEPTO WHERE VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA= :KEY_COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO= :KEY_ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON= :KEY_ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA= :KEY_ID_CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO AND VI_DETALLE_CATEGORIA_CONCEPTO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_ESCALAFON" sqlType="STRING"/>
		<param name="KEY_ID_CATEGORIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="videtallescategoriaconcepto">
		<call-query href="deleteVidetallescategoriaconcepto">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_ESCALAFON" query-param="KEY_ESCALAFON"/>
			<with-param name="KEY_ID_CATEGORIA" query-param="KEY_ID_CATEGORIA"/>
			<with-param name="KEY_CODIGO_CONCEPTO" query-param="KEY_CODIGO_CONCEPTO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getVidetallescategoriaconceptoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA, VI_DETALLE_CATEGORIA_CONCEPTO.ANO, VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON, VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA, VI_DETALLE_CATEGORIA_CONCEPTO.CONSECUTIVO, VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE NOMBRECONCEPTO, PAISORIGEN, PAISES.NOMBRE PAISORIGENNOMBRE, DEPARTAMENTOORIGEN, DEPARTAMENTO.NOMBRE DEPTOORIGENNOMBRE, CIUDADORIGEN, CIUDAD.NOMBRE CIUDADORIGENNOMBRE, PAISDESTINO, PAISESDESTINO.NOMBRE PAISDESTINONOMBRE, DEPARTAMENTODESTINO, DEPTODESTINO.NOMBRE DEPTODESTINONOMBRE, CIUDADDESTINO, CIUDADDESTINO.NOMBRE CIUDADDESTINONOMBRE, VI_DETALLE_CATEGORIA_CONCEPTO.TARIFA  FROM VI_DETALLE_CATEGORIA_CONCEPTO LEFT JOIN PAISES ON VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = PAISES.PAIS LEFT JOIN DEPARTAMENTO ON VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTOORIGEN = DEPARTAMENTO.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = DEPARTAMENTO.PAIS LEFT JOIN CIUDAD ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADORIGEN = CIUDAD.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTOORIGEN = CIUDAD.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISORIGEN = CIUDAD.PAIS LEFT JOIN PAISES PAISESDESTINO ON VI_DETALLE_CATEGORIA_CONCEPTO.PAISDESTINO = PAISESDESTINO.PAIS LEFT JOIN DEPARTAMENTO DEPTODESTINO ON VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTODESTINO = DEPTODESTINO.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISDESTINO = DEPTODESTINO.PAIS LEFT JOIN CIUDAD CIUDADDESTINO ON VI_DETALLE_CATEGORIA_CONCEPTO.CIUDADDESTINO = CIUDADDESTINO.CODIGO AND VI_DETALLE_CATEGORIA_CONCEPTO.DEPARTAMENTODESTINO = CIUDADDESTINO.DEPARTAMENTO AND VI_DETALLE_CATEGORIA_CONCEPTO.PAISDESTINO = CIUDADDESTINO.PAIS LEFT JOIN VI_CONCEPTO_VIATICOS ON VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = VI_CONCEPTO_VIATICOS.COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO = VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = VI_CONCEPTO_VIATICOS.ANO WHERE VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = :COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = :CATEGORIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = :ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = :ESCALAFON) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN PAISORIGENNOMBRE IS NULL THEN ' ' ELSE UPPER(PAISORIGENNOMBRE) END)  LIKE UPPER( '%' || :PAISORIGENNOMBRE || '%')  AND (CASE WHEN DEPTOORIGENNOMBRE IS NULL THEN ' ' ELSE UPPER(DEPTOORIGENNOMBRE) END)  LIKE UPPER( '%' || :DEPTOORIGENNOMBRE || '%')  AND (CASE WHEN CIUDADORIGENNOMBRE IS NULL THEN ' ' ELSE UPPER(CIUDADORIGENNOMBRE) END)  LIKE UPPER( '%' || :CIUDADORIGENNOMBRE || '%')  AND (CASE WHEN PAISDESTINONOMBRE IS NULL THEN ' ' ELSE UPPER(PAISDESTINONOMBRE) END)  LIKE UPPER( '%' || :PAISDESTINONOMBRE || '%')  AND (CASE WHEN DEPTODESTINONOMBRE IS NULL THEN ' ' ELSE UPPER(DEPTODESTINONOMBRE) END)  LIKE UPPER( '%' || :DEPTODESTINONOMBRE || '%')  AND (CASE WHEN CIUDADDESTINONOMBRE IS NULL THEN ' ' ELSE UPPER(CIUDADDESTINONOMBRE) END)  LIKE UPPER( '%' || :CIUDADDESTINONOMBRE || '%')  AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END)  LIKE UPPER( '%' || :TARIFA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ESCALAFON":"$ESCALAFON","ID_CATEGORIA":"$ID_CATEGORIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRECONCEPTO":"$NOMBRECONCEPTO","PAISORIGEN":"$PAISORIGEN","PAISORIGENNOMBRE":"$PAISORIGENNOMBRE","DEPARTAMENTOORIGEN":"$DEPARTAMENTOORIGEN","DEPTOORIGENNOMBRE":"$DEPTOORIGENNOMBRE","CIUDADORIGEN":"$CIUDADORIGEN","CIUDADORIGENNOMBRE":"$CIUDADORIGENNOMBRE","PAISDESTINO":"$PAISDESTINO","PAISDESTINONOMBRE":"$PAISDESTINONOMBRE","DEPARTAMENTODESTINO":"$DEPARTAMENTODESTINO","DEPTODESTINONOMBRE":"$DEPTODESTINONOMBRE","CIUDADDESTINO":"$CIUDADDESTINO","CIUDADDESTINONOMBRE":"$CIUDADDESTINONOMBRE","TARIFA":"$TARIFA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="PAISORIGENNOMBRE" sqlType="STRING"/>
		<param name="DEPTOORIGENNOMBRE" sqlType="STRING"/>
		<param name="CIUDADORIGENNOMBRE" sqlType="STRING"/>
		<param name="PAISDESTINONOMBRE" sqlType="STRING"/>
		<param name="DEPTODESTINONOMBRE" sqlType="STRING"/>
		<param name="CIUDADDESTINONOMBRE" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
