		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, DOCNUM, PRECOD, NUMERO_ORDEN, PREANO,(CASE PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, PREANO DESDE, PREANO HASTA, OBSERVACIONES,(CASE ANULADO WHEN 0 THEN 'false' ELSE 'true' END) IND, OBS_ANULACION  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND ANULADO IN (0) AND PRECOD = :PREDIO) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER( '%' || :PRECOD || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%')  AND (CASE WHEN DESDE IS NULL THEN ' ' ELSE UPPER(DESDE) END)  LIKE UPPER( '%' || :DESDE || '%')  AND (CASE WHEN HASTA IS NULL THEN ' ' ELSE UPPER(HASTA) END)  LIKE UPPER( '%' || :HASTA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN IND IS NULL THEN ' ' ELSE UPPER(IND) END)  LIKE UPPER( '%' || :IND || '%')  AND (CASE WHEN OBS_ANULACION IS NULL THEN ' ' ELSE UPPER(OBS_ANULACION) END)  LIKE UPPER( '%' || :OBS_ANULACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
