	<query id="updateIppagosdobles" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_PAGOSDOBLES SET AFECTAFACT=:AFECTAFACT, INDPAGO_ACPAG=:INDPAGO_ACPAG, ANO_EXCEDENTE=:ANO_EXCEDENTE, PAGO=:PAGO, VALOR=:VALOR, TIPO=:TIPO, C1=:C1, C2=:C2, C3=:C3, C4=:C4, C13=:C13, C14=:C14, C15=:C15, C16=:C16, C17=:C17, C18=:C18, C19=:C19, C20=:C20, OBSERVACIONES=:OBSERVACIONES, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_PAGOSDOBLES.COMPANIA= :KEY_COMPANIA AND IP_PAGOSDOBLES.DOCNUM= :KEY_DOCNUM AND IP_PAGOSDOBLES.PRECOD= :KEY_PRECOD AND IP_PAGOSDOBLES.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_PAGOSDOBLES.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="AFECTAFACT" sqlType="STRING"/>
		<param name="INDPAGO_ACPAG" sqlType="STRING"/>
		<param name="ANO_EXCEDENTE" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
