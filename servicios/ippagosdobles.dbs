<data name="ippagosdobles" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIppagosdoblesPorPreanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PREANO  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND PRECOD = :CODIGO AND NUMERO_ORDEN = :NUMERO_ORDEN AND PAGO IN(0) AND GPAGODOBLE NOT IN (0) AND ANULADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosdobles/porpreano">
		<call-query href="getIppagosdoblesPorPreanoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIppagosdoblesCuantosAnosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(PREANO) CANT  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND PRECOD = :PREDIO AND PREANO &lt;= :ANO AND TIPO IN ('D') AND PAGO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANT":"$CANT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosdobles/cuantosanosporpredio">
		<call-query href="getIppagosdoblesCuantosAnosPorPredioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getIppagosdoblesCantidadDeAnosPagadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(PREANO) CANT  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND PRECOD = :PREDIO AND TIPO IN ('D') AND PAGO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANT":"$CANT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosdobles/cantidaddeanospagados">
		<call-query href="getIppagosdoblesCantidadDeAnosPagadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>
	<query id="insertIppagosdoblesSaldos" keyColumns="COMPANIA,DOCNUM,PRECOD,NUMERO_ORDEN,PREANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_PAGOSDOBLES (COMPANIA, DOCNUM, PRECOD, NUMERO_ORDEN, PREANO, VALOR, FECHA, TIPO, OBSERVACIONES, PAGO, BANCO, ANULADO, FECHAANULADO, ANULADOPOR, DESCUENTO, CONCEPTO, GPAGODOBLE, ASIGNADO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :DOCNUM, :PRECOD, :NUMERO_ORDEN, :PREANO, :VALOR, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :TIPO, :OBSERVACIONES, :PAGO, :BANCO, :ANULADO, TO_DATE(:FECHAANULADO,'DD/MM/YYYY HH24:MI:SS'), :ANULADOPOR, :DESCUENTO, :CONCEPTO, :GPAGODOBLE, :ASIGNADO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DOCNUM":"$DOCNUM","KEY_PRECOD":"$PRECOD","KEY_NUMERO_ORDEN":"$NUMERO_ORDEN","KEY_PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="PAGO" sqlType="STRING"/>
		<param defaultValue="888" name="BANCO" sqlType="STRING"/>
		<param defaultValue="0" name="ANULADO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAANULADO" sqlType="STRING"/>
		<param defaultValue="" name="ANULADOPOR" sqlType="STRING"/>
		<param defaultValue="0" name="DESCUENTO" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="GPAGODOBLE" sqlType="STRING"/>
		<param defaultValue="0" name="ASIGNADO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ippagosdobles/saldos">
		<call-query href="insertIppagosdoblesSaldos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PRECOD" query-param="PRECOD"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="ANULADO" query-param="ANULADO"/>
			<with-param name="FECHAANULADO" query-param="FECHAANULADO"/>
			<with-param name="ANULADOPOR" query-param="ANULADOPOR"/>
			<with-param name="DESCUENTO" query-param="DESCUENTO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="GPAGODOBLE" query-param="GPAGODOBLE"/>
			<with-param name="ASIGNADO" query-param="ASIGNADO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="updateIppagosdoblesSaldos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_PAGOSDOBLES SET DOCNUM=:DOCNUM, PRECOD=:PRECOD, FECHAANULADO=TO_DATE(:FECHAANULADO,'DD/MM/YYYY HH24:MI:SS'), PREANO=:PREANO, VALOR=:VALOR, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), OBSERVACIONES=:OBSERVACIONES, PAGO=:PAGO, BANCO=:BANCO, DESCUENTO=:DESCUENTO, CONCEPTO=:CONCEPTO, ASIGNADO=:ASIGNADO, ANULADO=:ANULADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_PAGOSDOBLES.COMPANIA= :KEY_COMPANIA AND IP_PAGOSDOBLES.DOCNUM= :KEY_DOCNUM AND IP_PAGOSDOBLES.PRECOD= :KEY_PRECOD AND IP_PAGOSDOBLES.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_PAGOSDOBLES.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="FECHAANULADO" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="DESCUENTO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="ASIGNADO" sqlType="STRING"/>
		<param name="ANULADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DOCNUM" sqlType="STRING"/>
		<param name="KEY_PRECOD" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="KEY_PREANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ippagosdobles/saldos">
		<call-query href="updateIppagosdoblesSaldos">
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PRECOD" query-param="PRECOD"/>
			<with-param name="FECHAANULADO" query-param="FECHAANULADO"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="DESCUENTO" query-param="DESCUENTO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="ASIGNADO" query-param="ASIGNADO"/>
			<with-param name="ANULADO" query-param="ANULADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DOCNUM" query-param="KEY_DOCNUM"/>
			<with-param name="KEY_PRECOD" query-param="KEY_PRECOD"/>
			<with-param name="KEY_NUMERO_ORDEN" query-param="KEY_NUMERO_ORDEN"/>
			<with-param name="KEY_PREANO" query-param="KEY_PREANO"/>

		</call-query>
	</resource>
	<query id="deleteIppagosdoblesSaldos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_PAGOSDOBLES WHERE IP_PAGOSDOBLES.COMPANIA= :KEY_COMPANIA AND IP_PAGOSDOBLES.DOCNUM= :KEY_DOCNUM AND IP_PAGOSDOBLES.PRECOD= :KEY_PRECOD AND IP_PAGOSDOBLES.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_PAGOSDOBLES.PREANO= :KEY_PREANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DOCNUM" sqlType="STRING"/>
		<param name="KEY_PRECOD" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="KEY_PREANO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ippagosdobles/saldos">
		<call-query href="deleteIppagosdoblesSaldos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DOCNUM" query-param="KEY_DOCNUM"/>
			<with-param name="KEY_PRECOD" query-param="KEY_PRECOD"/>
			<with-param name="KEY_NUMERO_ORDEN" query-param="KEY_NUMERO_ORDEN"/>
			<with-param name="KEY_PREANO" query-param="KEY_PREANO"/>

		</call-query>
	</resource>
	<query id="getIppagosdoblesPagSaldosPagosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_PAGOSDOBLES.COMPANIA, IP_PAGOSDOBLES.DOCNUM, IP_PAGOSDOBLES.PRECOD, IP_PAGOSDOBLES.NUMERO_ORDEN, IP_PAGOSDOBLES.PREANO, IP_PAGOSDOBLES.VALOR,(TO_CHAR(IP_PAGOSDOBLES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, IP_PAGOSDOBLES.TIPO, IP_PAGOSDOBLES.OBSERVACIONES, IP_PAGOSDOBLES.ANO_EXCEDENTE,(CASE IP_PAGOSDOBLES.PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, IP_PAGOSDOBLES.BANCO,(CASE IP_PAGOSDOBLES.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO,(TO_CHAR(IP_PAGOSDOBLES.FECHAANULADO,'DD/MM/YYYY HH24:MI:SS')) FECHAANULADO, IP_PAGOSDOBLES.ANULADOPOR,(CASE IP_PAGOSDOBLES.DESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) DESCUENTO, IP_PAGOSDOBLES.CONCEPTO,(CASE IP_PAGOSDOBLES.GPAGODOBLE WHEN 0 THEN 'false' ELSE 'true' END) GPAGODOBLE,(CASE IP_PAGOSDOBLES.ASIGNADO WHEN 0 THEN 'false' ELSE 'true' END) ASIGNADO, IP_PAGOSDOBLES.CREATED_BY,(TO_CHAR(IP_PAGOSDOBLES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, IP_PAGOSDOBLES.MODIFIED_BY,(TO_CHAR(IP_PAGOSDOBLES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, IP_USUARIOS_PREDIAL.NOMBRE PROPIETARIO  FROM IP_PAGOSDOBLES INNER JOIN IP_USUARIOS_PREDIAL ON IP_PAGOSDOBLES.COMPANIA = IP_USUARIOS_PREDIAL.COMPANIA AND IP_PAGOSDOBLES.PRECOD = IP_USUARIOS_PREDIAL.CODIGO AND IP_PAGOSDOBLES.NUMERO_ORDEN = IP_USUARIOS_PREDIAL.NUMERO_ORDEN WHERE IP_PAGOSDOBLES.COMPANIA = :COMPANIA AND IP_PAGOSDOBLES.TIPO = :TIPO AND IP_PAGOSDOBLES.ANULADO IN (0) AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN (0) ORDER BY IP_PAGOSDOBLES.FECHA DESC) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER( '%' || :PRECOD || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER( '%' || :PAGO || '%')  AND (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END)  LIKE UPPER( '%' || :BANCO || '%')  AND (CASE WHEN DESCUENTO IS NULL THEN ' ' ELSE UPPER(DESCUENTO) END)  LIKE UPPER( '%' || :DESCUENTO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN PROPIETARIO IS NULL THEN ' ' ELSE UPPER(PROPIETARIO) END)  LIKE UPPER( '%' || :PROPIETARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DOCNUM":"$DOCNUM","PRECOD":"$PRECOD","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","VALOR":"$VALOR","FECHA":"$FECHA","TIPO":"$TIPO","OBSERVACIONES":"$OBSERVACIONES","ANO_EXCEDENTE":"$ANO_EXCEDENTE(type:integer)","PAGO":"$PAGO(type:boolean)","BANCO":"$BANCO","ANULADO":"$ANULADO(type:boolean)","FECHAANULADO":"$FECHAANULADO","ANULADOPOR":"$ANULADOPOR","DESCUENTO":"$DESCUENTO(type:boolean)","CONCEPTO":"$CONCEPTO(type:integer)","GPAGODOBLE":"$GPAGODOBLE(type:boolean)","ASIGNADO":"$ASIGNADO(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","PROPIETARIO":"$PROPIETARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="DESCUENTO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROPIETARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ippagosdobles/saldospagos/pag">
		<call-query href="getIppagosdoblesPagSaldosPagosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PRECOD" query-param="PRECOD"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="DESCUENTO" query-param="DESCUENTO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROPIETARIO" query-param="PROPIETARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIppagosdoblesNumSaldosPagosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_PAGOSDOBLES.COMPANIA, IP_PAGOSDOBLES.DOCNUM, IP_PAGOSDOBLES.PRECOD, IP_PAGOSDOBLES.NUMERO_ORDEN, IP_PAGOSDOBLES.PREANO, IP_PAGOSDOBLES.VALOR,(TO_CHAR(IP_PAGOSDOBLES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, IP_PAGOSDOBLES.TIPO, IP_PAGOSDOBLES.OBSERVACIONES, IP_PAGOSDOBLES.ANO_EXCEDENTE,(CASE IP_PAGOSDOBLES.PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, IP_PAGOSDOBLES.BANCO,(CASE IP_PAGOSDOBLES.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO,(TO_CHAR(IP_PAGOSDOBLES.FECHAANULADO,'DD/MM/YYYY HH24:MI:SS')) FECHAANULADO, IP_PAGOSDOBLES.ANULADOPOR,(CASE IP_PAGOSDOBLES.DESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) DESCUENTO, IP_PAGOSDOBLES.CONCEPTO,(CASE IP_PAGOSDOBLES.GPAGODOBLE WHEN 0 THEN 'false' ELSE 'true' END) GPAGODOBLE,(CASE IP_PAGOSDOBLES.ASIGNADO WHEN 0 THEN 'false' ELSE 'true' END) ASIGNADO, IP_PAGOSDOBLES.CREATED_BY,(TO_CHAR(IP_PAGOSDOBLES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, IP_PAGOSDOBLES.MODIFIED_BY,(TO_CHAR(IP_PAGOSDOBLES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, IP_USUARIOS_PREDIAL.NOMBRE PROPIETARIO  FROM IP_PAGOSDOBLES INNER JOIN IP_USUARIOS_PREDIAL ON IP_PAGOSDOBLES.COMPANIA = IP_USUARIOS_PREDIAL.COMPANIA AND IP_PAGOSDOBLES.PRECOD = IP_USUARIOS_PREDIAL.CODIGO AND IP_PAGOSDOBLES.NUMERO_ORDEN = IP_USUARIOS_PREDIAL.NUMERO_ORDEN WHERE IP_PAGOSDOBLES.COMPANIA = :COMPANIA AND IP_PAGOSDOBLES.TIPO = :TIPO AND IP_PAGOSDOBLES.ANULADO IN (0) AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN (0) ORDER BY IP_PAGOSDOBLES.FECHA DESC) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER( '%' || :PRECOD || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER( '%' || :PAGO || '%')  AND (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END)  LIKE UPPER( '%' || :BANCO || '%')  AND (CASE WHEN DESCUENTO IS NULL THEN ' ' ELSE UPPER(DESCUENTO) END)  LIKE UPPER( '%' || :DESCUENTO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN PROPIETARIO IS NULL THEN ' ' ELSE UPPER(PROPIETARIO) END)  LIKE UPPER( '%' || :PROPIETARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="DESCUENTO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROPIETARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosdobles/saldospagos/num">
		<call-query href="getIppagosdoblesNumSaldosPagosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
