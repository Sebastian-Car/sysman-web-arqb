	<query id="getIppagosdoblesPagPorCompaniaYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PRECOD, DOCNUM, PREANO, VALOR, TIPO, ANO_EXCEDENTE,(CASE PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, OBSERVACIONES  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND PAGO IN (0) AND TIPO = :TIPO) WHERE (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER(:PRECOD || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRECOD":"$PRECOD","DOCNUM":"$DOCNUM","PREANO":"$PREANO(type:integer)","VALOR":"$VALOR","TIPO":"$TIPO","ANO_EXCEDENTE":"$ANO_EXCEDENTE(type:integer)","PAGO":"$PAGO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ippagosdobles/porcompaniaytipo/pag">
		<call-query href="getIppagosdoblesPagPorCompaniaYTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="PRECOD" query-param="PRECOD"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIppagosdoblesNumPorCompaniaYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PRECOD, DOCNUM, PREANO, VALOR, TIPO, ANO_EXCEDENTE,(CASE PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, OBSERVACIONES  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND PAGO IN (0) AND TIPO = :TIPO) WHERE (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER(:PRECOD || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>

	</query>
