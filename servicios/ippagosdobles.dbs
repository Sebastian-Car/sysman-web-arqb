		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosdobles/precodnoanulado/num">
		<call-query href="getIppagosdoblesNumPrecodNoAnuladoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PRECOD" query-param="PRECOD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getIppagosdoblesPrecodNoAnuladoPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, DOCNUM, PRECOD, NUMERO_ORDEN, PREANO,(CASE PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, PREANO DESDE, PREANO HASTA, OBSERVACIONES,(CASE ANULADO WHEN 0 THEN 'false' ELSE 'true' END) IND, OBS_ANULACION  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND ANULADO IN (0) AND PRECOD = :PREDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DOCNUM":"$DOCNUM","PRECOD":"$PRECOD","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","PAGADO":"$PAGADO(type:boolean)","DESDE":"$DESDE(type:integer)","HASTA":"$HASTA(type:integer)","OBSERVACIONES":"$OBSERVACIONES","IND":"$IND(type:boolean)","OBS_ANULACION":"$OBS_ANULACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosdobles/precodnoanuladoporpredio">
		<call-query href="getIppagosdoblesPrecodNoAnuladoPorPredioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>

</data>