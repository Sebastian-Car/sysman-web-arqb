	<query id="getIppagosdoblesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_PAGOSDOBLES.COMPANIA, IP_PAGOSDOBLES.DOCNUM, IP_PAGOSDOBLES.PRECOD, IP_PAGOSDOBLES.NUMERO_ORDEN, IP_PAGOSDOBLES.PREANO,(CASE IP_PAGOSDOBLES.PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO,(CASE IP_PAGOSDOBLES.AFECTAFACT WHEN 0 THEN 'false' ELSE 'true' END) AFECTAFACT,(CASE IP_PAGOSDOBLES.INDPAGO_ACPAG WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO_ACPAG, IP_USUARIOS_PREDIAL.NOMBRE PROPIETARIO, IP_PAGOSDOBLES.ANO_EXCEDENTE, IP_PAGOSDOBLES.VALOR, IP_PAGOSDOBLES.C1, IP_PAGOSDOBLES.C2, IP_PAGOSDOBLES.C3, IP_PAGOSDOBLES.C4, IP_PAGOSDOBLES.C13, IP_PAGOSDOBLES.C14, IP_PAGOSDOBLES.C15, IP_PAGOSDOBLES.C16, IP_PAGOSDOBLES.C17, IP_PAGOSDOBLES.C18, IP_PAGOSDOBLES.C19, IP_PAGOSDOBLES.C20,(TO_CHAR(IP_PAGOSDOBLES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, IP_PAGOSDOBLES.OBSERVACIONES  FROM IP_PAGOSDOBLES INNER JOIN IP_USUARIOS_PREDIAL ON IP_PAGOSDOBLES.COMPANIA = IP_USUARIOS_PREDIAL.COMPANIA AND IP_PAGOSDOBLES.PRECOD = IP_USUARIOS_PREDIAL.CODIGO AND IP_PAGOSDOBLES.NUMERO_ORDEN = IP_USUARIOS_PREDIAL.NUMERO_ORDEN WHERE IP_PAGOSDOBLES.COMPANIA = :MI_COMPANIA AND IP_PAGOSDOBLES.TIPO = :MI_TIPO ORDER BY IP_PAGOSDOBLES.DATE_CREATED DESC) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER(:PRECOD || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER(:PAGO || '%')  AND (CASE WHEN AFECTAFACT IS NULL THEN ' ' ELSE UPPER(AFECTAFACT) END)  LIKE UPPER(:AFECTAFACT || '%')  AND (CASE WHEN INDPAGO_ACPAG IS NULL THEN ' ' ELSE UPPER(INDPAGO_ACPAG) END)  LIKE UPPER(:INDPAGO_ACPAG || '%')  AND (CASE WHEN PROPIETARIO IS NULL THEN ' ' ELSE UPPER(PROPIETARIO) END)  LIKE UPPER( '%' || :PROPIETARIO || '%')  AND (CASE WHEN ANO_EXCEDENTE IS NULL THEN ' ' ELSE UPPER(ANO_EXCEDENTE) END)  LIKE UPPER(:ANO_EXCEDENTE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN C1 IS NULL THEN ' ' ELSE UPPER(C1) END)  LIKE UPPER(:C1 || '%')  AND (CASE WHEN C2 IS NULL THEN ' ' ELSE UPPER(C2) END)  LIKE UPPER(:C2 || '%')  AND (CASE WHEN C3 IS NULL THEN ' ' ELSE UPPER(C3) END)  LIKE UPPER(:C3 || '%')  AND (CASE WHEN C4 IS NULL THEN ' ' ELSE UPPER(C4) END)  LIKE UPPER(:C4 || '%')  AND (CASE WHEN C13 IS NULL THEN ' ' ELSE UPPER(C13) END)  LIKE UPPER(:C13 || '%')  AND (CASE WHEN C14 IS NULL THEN ' ' ELSE UPPER(C14) END)  LIKE UPPER(:C14 || '%')  AND (CASE WHEN C15 IS NULL THEN ' ' ELSE UPPER(C15) END)  LIKE UPPER(:C15 || '%')  AND (CASE WHEN C16 IS NULL THEN ' ' ELSE UPPER(C16) END)  LIKE UPPER(:C16 || '%')  AND (CASE WHEN C17 IS NULL THEN ' ' ELSE UPPER(C17) END)  LIKE UPPER(:C17 || '%')  AND (CASE WHEN C18 IS NULL THEN ' ' ELSE UPPER(C18) END)  LIKE UPPER(:C18 || '%')  AND (CASE WHEN C19 IS NULL THEN ' ' ELSE UPPER(C19) END)  LIKE UPPER(:C19 || '%')  AND (CASE WHEN C20 IS NULL THEN ' ' ELSE UPPER(C20) END)  LIKE UPPER(:C20 || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DOCNUM":"$DOCNUM","PRECOD":"$PRECOD","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","PAGO":"$PAGO(type:boolean)","AFECTAFACT":"$AFECTAFACT(type:boolean)","INDPAGO_ACPAG":"$INDPAGO_ACPAG(type:boolean)","PROPIETARIO":"$PROPIETARIO","ANO_EXCEDENTE":"$ANO_EXCEDENTE(type:integer)","VALOR":"$VALOR","C1":"$C1","C2":"$C2","C3":"$C3","C4":"$C4","C13":"$C13","C14":"$C14","C15":"$C15","C16":"$C16","C17":"$C17","C18":"$C18","C19":"$C19","C20":"$C20","FECHA":"$FECHA","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="MI_COMPANIA" sqlType="STRING"/>
		<param name="MI_TIPO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="AFECTAFACT" sqlType="STRING"/>
		<param name="INDPAGO_ACPAG" sqlType="STRING"/>
		<param name="PROPIETARIO" sqlType="STRING"/>
		<param name="ANO_EXCEDENTE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="C1" sqlType="STRING"/>
		<param name="C2" sqlType="STRING"/>
		<param name="C3" sqlType="STRING"/>
		<param name="C4" sqlType="STRING"/>
		<param name="C13" sqlType="STRING"/>
		<param name="C14" sqlType="STRING"/>
		<param name="C15" sqlType="STRING"/>
		<param name="C16" sqlType="STRING"/>
		<param name="C17" sqlType="STRING"/>
		<param name="C18" sqlType="STRING"/>
		<param name="C19" sqlType="STRING"/>
		<param name="C20" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
