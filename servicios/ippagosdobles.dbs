	<query id="insertIppagosdobles" keyColumns="COMPANIA,DOCNUM,PRECOD,NUMERO_ORDEN,PREANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_PAGOSDOBLES (COMPANIA, DOCNUM, PRECOD, NUMERO_ORDEN, PREANO, AFECTAFACT, INDPAGO_ACPAG, ANO_EXCEDENTE, VALOR, C1, C2, C3, C4, C13, C14, C15, C16, C17, C18, C19, C20, OBSERVACIONES, FECHA, TIPO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DOCNUM, :PRECOD, :NUMERO_ORDEN, :PREANO, :AFECTAFACT, :INDPAGO_ACPAG, :ANO_EXCEDENTE, :VALOR, :C1, :C2, :C3, :C4, :C13, :C14, :C15, :C16, :C17, :C18, :C19, :C20, :OBSERVACIONES, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :TIPO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DOCNUM":"$DOCNUM","KEY_PRECOD":"$PRECOD","KEY_NUMERO_ORDEN":"$NUMERO_ORDEN","KEY_PREANO":"$PREANO(type:integer)"}]}}		</result>
