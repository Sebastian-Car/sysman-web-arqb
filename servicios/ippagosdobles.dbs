	<query id="getIppagosdoblesPagAbonosSaldosParaAnulacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, DOCNUM, PRECOD, NUMERO_ORDEN, PREANO,(CASE PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, PREANO DESDE, PREANO HASTA, OBSERVACIONES,(CASE ANULADO WHEN 0 THEN 'false' ELSE 'true' END) IND, OBS_ANULACION  FROM IP_PAGOSDOBLES WHERE COMPANIA = :COMPANIA AND ANULADO IN (0) AND PRECOD = :PREDIO) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER( '%' || :PRECOD || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%')  AND (CASE WHEN DESDE IS NULL THEN ' ' ELSE UPPER(DESDE) END)  LIKE UPPER( '%' || :DESDE || '%')  AND (CASE WHEN HASTA IS NULL THEN ' ' ELSE UPPER(HASTA) END)  LIKE UPPER( '%' || :HASTA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN IND IS NULL THEN ' ' ELSE UPPER(IND) END)  LIKE UPPER( '%' || :IND || '%')  AND (CASE WHEN OBS_ANULACION IS NULL THEN ' ' ELSE UPPER(OBS_ANULACION) END)  LIKE UPPER( '%' || :OBS_ANULACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DOCNUM":"$DOCNUM","PRECOD":"$PRECOD","NUMERO_ORDEN":"$NUMERO_ORDEN","PREANO":"$PREANO(type:integer)","PAGADO":"$PAGADO(type:boolean)","DESDE":"$DESDE(type:integer)","HASTA":"$HASTA(type:integer)","OBSERVACIONES":"$OBSERVACIONES","IND":"$IND(type:boolean)","OBS_ANULACION":"$OBS_ANULACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="PAGADO" sqlType="STRING"/>
		<param name="DESDE" sqlType="STRING"/>
		<param name="HASTA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="IND" sqlType="STRING"/>
		<param name="OBS_ANULACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
