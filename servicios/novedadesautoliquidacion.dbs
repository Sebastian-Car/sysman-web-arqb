	<query id="updateNovedadesautoliquidacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NOVEDADES_AUTOLIQUIDACION SET NOMBRE_FONDO=:NOMBRE_FONDO, TOTAL_APORTES_ARP=:TOTAL_APORTES_ARP, NUMERO_AUT_PAGO_INCAPARP=:NUMERO_AUT_PAGO_INCAPARP, VALOR_TOTAL_INCAP_PAGADASARP=:VALOR_TOTAL_INCAP_PAGADASARP, VALOR_AP_PAGADOS_OTROS_RIESGOS=:VALOR_AP_PAGADOS_OTROS_RIESGOS, VALOR_TOTAL_COTIZACION=:VALOR_TOTAL_COTIZACION, DIAS_MORA_ARP=:DIAS_MORA_ARP, VALOR_INTERESES_MORA_ARP=:VALOR_INTERESES_MORA_ARP, SUBTOTAL_APORTES_ARP=:SUBTOTAL_APORTES_ARP, NUMERO_RAD_AUT_SALDO_FAVORARP=:NUMERO_RAD_AUT_SALDO_FAVORARP, VALOR_SALDOPERIODOANTERIORARP=:VALOR_SALDOPERIODOANTERIORARP, VALOR_TOTAL_NETO_ARP=:VALOR_TOTAL_NETO_ARP, VALOR_FONDO_SOLIDARIDAD_ARP=:VALOR_FONDO_SOLIDARIDAD_ARP, TOTAL_AFILIADOS_RIESGOS=:TOTAL_AFILIADOS_RIESGOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NOVEDADES_AUTOLIQUIDACION.COMPANIA= :KEY_COMPANIA AND NOVEDADES_AUTOLIQUIDACION.ANO= :KEY_ANO AND NOVEDADES_AUTOLIQUIDACION.MES= :KEY_MES AND NOVEDADES_AUTOLIQUIDACION.PERIODO= :KEY_PERIODO AND NOVEDADES_AUTOLIQUIDACION.TIPO_ADMINISTRADORA= :KEY_TIPO_ADMINISTRADORA AND NOVEDADES_AUTOLIQUIDACION.CODIGO_FONDO= :KEY_CODIGO_FONDO AND NOVEDADES_AUTOLIQUIDACION.NIT= :KEY_NIT AND NOVEDADES_AUTOLIQUIDACION.SUCURSAL= :KEY_SUCURSAL AND NOVEDADES_AUTOLIQUIDACION.ID_DE_PROCESO= :KEY_ID_DE_PROCESO</sql>
