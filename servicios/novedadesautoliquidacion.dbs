			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNovedadesautoliquidacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NOVEDADES_AUTOLIQUIDACION WHERE NOVEDADES_AUTOLIQUIDACION.COMPANIA= :KEY_COMPANIA AND NOVEDADES_AUTOLIQUIDACION.ANO= :KEY_ANO AND NOVEDADES_AUTOLIQUIDACION.MES= :KEY_MES AND NOVEDADES_AUTOLIQUIDACION.PERIODO= :KEY_PERIODO AND NOVEDADES_AUTOLIQUIDACION.TIPO_ADMINISTRADORA= :KEY_TIPO_ADMINISTRADORA AND NOVEDADES_AUTOLIQUIDACION.CODIGO_FONDO= :KEY_CODIGO_FONDO AND NOVEDADES_AUTOLIQUIDACION.NIT= :KEY_NIT AND NOVEDADES_AUTOLIQUIDACION.SUCURSAL= :KEY_SUCURSAL AND NOVEDADES_AUTOLIQUIDACION.ID_DE_PROCESO= :KEY_ID_DE_PROCESO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_ADMINISTRADORA" sqlType="STRING"/>
		<param name="KEY_CODIGO_FONDO" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>

	</query>
