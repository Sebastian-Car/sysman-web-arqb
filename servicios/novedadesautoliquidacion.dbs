			<with-param name="VALOR_TOTAL_COTIZACION" query-param="VALOR_TOTAL_COTIZACION"/>
			<with-param name="DIAS_MORA_ARP" query-param="DIAS_MORA_ARP"/>
			<with-param name="VALOR_INTERESES_MORA_ARP" query-param="VALOR_INTERESES_MORA_ARP"/>
			<with-param name="SUBTOTAL_APORTES_ARP" query-param="SUBTOTAL_APORTES_ARP"/>
			<with-param name="NUMERO_RAD_AUT_SALDO_FAVORARP" query-param="NUMERO_RAD_AUT_SALDO_FAVORARP"/>
			<with-param name="VALOR_SALDOPERIODOANTERIORARP" query-param="VALOR_SALDOPERIODOANTERIORARP"/>
