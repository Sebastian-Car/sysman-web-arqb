			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_TIPO_ADMINISTRADORA" query-param="KEY_TIPO_ADMINISTRADORA"/>
			<with-param name="KEY_CODIGO_FONDO" query-param="KEY_CODIGO_FONDO"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>

		</call-query>
	</resource>
	<query id="getNovedadesautoliquidacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOVEDADES_AUTOLIQUIDACION.COMPANIA, NOVEDADES_AUTOLIQUIDACION.ANO, NOVEDADES_AUTOLIQUIDACION.MES, NOVEDADES_AUTOLIQUIDACION.PERIODO, NOVEDADES_AUTOLIQUIDACION.TIPO_ADMINISTRADORA, NOVEDADES_AUTOLIQUIDACION.CODIGO_FONDO, NOVEDADES_AUTOLIQUIDACION.NIT, NOVEDADES_AUTOLIQUIDACION.SUCURSAL, NOVEDADES_AUTOLIQUIDACION.ID_DE_PROCESO, NOVEDADES_AUTOLIQUIDACION.NOMBRE_FONDO, NOVEDADES_AUTOLIQUIDACION.TOTAL_APORTES_ARP, NOVEDADES_AUTOLIQUIDACION.NUMERO_AUT_PAGO_INCAPARP, NOVEDADES_AUTOLIQUIDACION.VALOR_TOTAL_INCAP_PAGADASARP, NOVEDADES_AUTOLIQUIDACION.VALOR_AP_PAGADOS_OTROS_RIESGOS, NOVEDADES_AUTOLIQUIDACION.VALOR_TOTAL_COTIZACION, NOVEDADES_AUTOLIQUIDACION.DIAS_MORA_ARP, NOVEDADES_AUTOLIQUIDACION.VALOR_INTERESES_MORA_ARP, NOVEDADES_AUTOLIQUIDACION.SUBTOTAL_APORTES_ARP, NOVEDADES_AUTOLIQUIDACION.NUMERO_RAD_AUT_SALDO_FAVORARP, NOVEDADES_AUTOLIQUIDACION.VALOR_SALDOPERIODOANTERIORARP, NOVEDADES_AUTOLIQUIDACION.VALOR_TOTAL_NETO_ARP, NOVEDADES_AUTOLIQUIDACION.VALOR_FONDO_SOLIDARIDAD_ARP, NOVEDADES_AUTOLIQUIDACION.TOTAL_AFILIADOS_RIESGOS  FROM NOVEDADES_AUTOLIQUIDACION WHERE NOVEDADES_AUTOLIQUIDACION.COMPANIA= :KEY_COMPANIA AND NOVEDADES_AUTOLIQUIDACION.ANO= :KEY_ANO AND NOVEDADES_AUTOLIQUIDACION.MES= :KEY_MES AND NOVEDADES_AUTOLIQUIDACION.PERIODO= :KEY_PERIODO AND NOVEDADES_AUTOLIQUIDACION.TIPO_ADMINISTRADORA= :KEY_TIPO_ADMINISTRADORA AND NOVEDADES_AUTOLIQUIDACION.CODIGO_FONDO= :KEY_CODIGO_FONDO AND NOVEDADES_AUTOLIQUIDACION.NIT= :KEY_NIT AND NOVEDADES_AUTOLIQUIDACION.SUCURSAL= :KEY_SUCURSAL AND NOVEDADES_AUTOLIQUIDACION.ID_DE_PROCESO= :KEY_ID_DE_PROCESO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","TIPO_ADMINISTRADORA":"$TIPO_ADMINISTRADORA","CODIGO_FONDO":"$CODIGO_FONDO","NIT":"$NIT","SUCURSAL":"$SUCURSAL","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","NOMBRE_FONDO":"$NOMBRE_FONDO","TOTAL_APORTES_ARP":"$TOTAL_APORTES_ARP","NUMERO_AUT_PAGO_INCAPARP":"$NUMERO_AUT_PAGO_INCAPARP","VALOR_TOTAL_INCAP_PAGADASARP":"$VALOR_TOTAL_INCAP_PAGADASARP","VALOR_AP_PAGADOS_OTROS_RIESGOS":"$VALOR_AP_PAGADOS_OTROS_RIESGOS","VALOR_TOTAL_COTIZACION":"$VALOR_TOTAL_COTIZACION","DIAS_MORA_ARP":"$DIAS_MORA_ARP","VALOR_INTERESES_MORA_ARP":"$VALOR_INTERESES_MORA_ARP","SUBTOTAL_APORTES_ARP":"$SUBTOTAL_APORTES_ARP","NUMERO_RAD_AUT_SALDO_FAVORARP":"$NUMERO_RAD_AUT_SALDO_FAVORARP","VALOR_SALDOPERIODOANTERIORARP":"$VALOR_SALDOPERIODOANTERIORARP","VALOR_TOTAL_NETO_ARP":"$VALOR_TOTAL_NETO_ARP","VALOR_FONDO_SOLIDARIDAD_ARP":"$VALOR_FONDO_SOLIDARIDAD_ARP","TOTAL_AFILIADOS_RIESGOS":"$TOTAL_AFILIADOS_RIESGOS"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_TIPO_ADMINISTRADORA" sqlType="STRING"/>
		<param name="KEY_CODIGO_FONDO" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>

	</query>
