<data name="transaccionesafectapppto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTransaccionesafectappptoDetallesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, VALOR, NVL(:VALORDOCUMENTO,0) VALORDOCUMENTO FROM TRANSACCIONES_AFECTAPPTO WHERE COMPANIA = :KEY_COMPANIA AND TIPO = :KEY_TIPO AND ANO = :KEY_ANO AND NUMERO_MODELO = :KEY_NUMERO_MODELO AND NUMERO = :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","VALOR":"$VALOR","VALORDOCUMENTO":"$VALORDOCUMENTO(type:integer)"}]}}		</result>
		<param name="VALORDOCUMENTO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO_MODELO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transaccionesafectapppto/detalles">
		<call-query href="getTransaccionesafectappptoDetallesQuery">
			<with-param name="VALORDOCUMENTO" query-param="VALORDOCUMENTO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO_MODELO" query-param="KEY_NUMERO_MODELO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getTransaccionesafectappptoSeleccionadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(COMPROBANTE_PPTAL.COMPANIA, '-'), COMPROBANTE_PPTAL.TIPO), '-'), COMPROBANTE_PPTAL. NUMERO), '-'), DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO) INDICE, DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, SUBSTR(COMPROBANTE_PPTAL.DESCRIPCION, 1, 100) DESCRIPCION,(TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, DETALLE_COMPROBANTE_PPTAL.CUENTA, TRANSACCIONES_AFECTAPPTO.VALOR SALDO, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO = '99999999999999999999' THEN CENTRO_COSTO.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, ' - '), CENTRO_COSTO.NOMBRE) END CENTRO_COSTO_NOM, CASE WHEN DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO = '99999999999999999999' THEN FUENTE_RECURSOS.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO, ' - '), FUENTE_RECURSOS.NOMBRE) END FUENTE_RECURSOS_NOM, CASE WHEN DETALLE_COMPROBANTE_PPTAL.AUXILIAR = '99999999999999999999' THEN AUXILIAR.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.AUXILIAR, ' - '), AUXILIAR.NOMBRE) END AUXILIAR_NOM, CASE WHEN DETALLE_COMPROBANTE_PPTAL.REFERENCIA = '99999999999999999999' THEN REFERENCIA.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.REFERENCIA, ' - '), REFERENCIA.NOMBRE) END REFERENCIA_NOM, DETALLE_COMPROBANTE_PPTAL.ANO FROM TRANSACCIONES_AFECTAPPTO INNER JOIN DETALLE_COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TRANSACCIONES_AFECTAPPTO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = TRANSACCIONES_AFECTAPPTO.ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = TRANSACCIONES_AFECTAPPTO.TIPO_CPTE AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = TRANSACCIONES_AFECTAPPTO.COMPROBANTE AND DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO = TRANSACCIONES_AFECTAPPTO.CONSECUTIVO INNER JOIN COMPROBANTE_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND COMPROBANTE_PPTAL.TIPO = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND COMPROBANTE_PPTAL.NUMERO = DETALLE_COMPROBANTE_PPTAL.COMPROBANTE INNER JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = CENTRO_COSTO.ANO AND DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO INNER JOIN AUXILIAR ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = AUXILIAR.ANO AND DETALLE_COMPROBANTE_PPTAL.AUXILIAR = AUXILIAR.CODIGO INNER JOIN REFERENCIA ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = REFERENCIA.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = REFERENCIA.ANO AND DETALLE_COMPROBANTE_PPTAL.REFERENCIA = REFERENCIA.CODIGO INNER JOIN FUENTE_RECURSOS ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = FUENTE_RECURSOS.ANO AND DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO WHERE TRANSACCIONES_AFECTAPPTO.COMPANIA = :KEY_COMPANIA AND TRANSACCIONES_AFECTAPPTO.TIPO = :KEY_TIPO AND TRANSACCIONES_AFECTAPPTO.ANO = :KEY_ANO AND TRANSACCIONES_AFECTAPPTO.NUMERO_MODELO = :KEY_NUMERO_MODELO AND TRANSACCIONES_AFECTAPPTO.NUMERO = :KEY_NUMERO ORDER BY FECHA DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"INDICE":"$INDICE","COMPANIA":"$COMPANIA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","SALDO":"$SALDO","CENTRO_COSTO_NOM":"$CENTRO_COSTO_NOM","FUENTE_RECURSOS_NOM":"$FUENTE_RECURSOS_NOM","AUXILIAR_NOM":"$AUXILIAR_NOM","REFERENCIA_NOM":"$REFERENCIA_NOM","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO_MODELO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transaccionesafectapppto/seleccionados">
		<call-query href="getTransaccionesafectappptoSeleccionadosQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO_MODELO" query-param="KEY_NUMERO_MODELO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>

</data>