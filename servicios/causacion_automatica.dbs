<data name="causacion_automatica" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCausacion_automaticaExisteregistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) TOTAL FROM CAUSACION_AUTOMATICA WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_COMPROBANTE = :TIPO AND NUMERO_COMPROBANTE = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="causacion_automatica/existeregistro">
		<call-query href="getCausacion_automaticaExisteregistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaConsultapreviewQuery"  useConfig="sysmandsunist">
		<sql>SELECT (SELECT COUNT(*) FROM TEMP_DETALLE_COMPROBANTE_CNT LEFT JOIN PLAN_CONTABLE ON TEMP_DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND TEMP_DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO AND TEMP_DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO WHERE TEMP_DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND TEMP_DETALLE_COMPROBANTE_CNT.ANO = :ANO AND TEMP_DETALLE_COMPROBANTE_CNT.COMPROBANTE = :NUMERO AND TEMP_DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO )AS sqlC_CUENTA,(SELECT COUNT(*) FROM TEMP_DETALLE_COMPROBANTE_PPTAL INNER JOIN TERCERO ON TEMP_DETALLE_COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND TEMP_DETALLE_COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND TEMP_DETALLE_COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL WHERE TEMP_DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND TEMP_DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND TEMP_DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = :NUMERO AND TEMP_DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = :TIPO) AS sqlP_CUENTA FROM DUAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SQLC_CUENTA":"$SQLC_CUENTA(type:integer)","SQLP_CUENTA":"$SQLP_CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="causacion_automatica/consultapreview">
		<call-query href="getCausacion_automaticaConsultapreviewQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="deleteCausacion_automaticaEliminarconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CAUSACION_AUTOMATICA WHERE CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CAUSACION_AUTOMATICA.ANO= :KEY_ANO AND CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE= :KEY_COMPROBANTE AND CAUSACION_AUTOMATICA.TIPO_COMPROBANTE= :KEY_TIPO_CPTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_TIPO_CPTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="causacion_automatica/eliminarconceptos">
		<call-query href="deleteCausacion_automaticaEliminarconceptos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_COMPROBANTE" query-param="KEY_COMPROBANTE"/>
			<with-param name="KEY_TIPO_CPTE" query-param="KEY_TIPO_CPTE"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaPagCuentasanticipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND ANTICIPO = -1) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="causacion_automatica/cuentasanticipo/pag">
		<call-query href="getCausacion_automaticaPagCuentasanticipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaNumCuentasanticipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND ANTICIPO = -1) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="causacion_automatica/cuentasanticipo/num">
		<call-query href="getCausacion_automaticaNumCuentasanticipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateCausacion_automaticaIndicadoranticipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET IND_ANTICIPO = :IND_ANTICIPO WHERE COMPANIA = :KEY_COMPANIA AND ANO = :KEY_ANO AND TIPO = :KEY_TIPO AND NUMERO = :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IND_ANTICIPO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="causacion_automatica/indicadoranticipo">
		<call-query href="updateCausacion_automaticaIndicadoranticipo">
			<with-param name="IND_ANTICIPO" query-param="IND_ANTICIPO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaGetcomprobanteaplicaley1819Query"  useConfig="sysmandsunist">
		<sql>SELECT CC.COMPANIA, CC.ANO, CC.TIPO, CC.NUMERO, CC.TERCERO, CA.VALOR VALORBASE,(CASE TERCERO.LEY1819 WHEN 0 THEN 'false' ELSE 'true' END) LEY1819,(CASE RETENCIONES.ALEY1819 WHEN 0 THEN 'false' ELSE 'true' END) ALEY1819 FROM COMPROBANTE_CNT CC INNER JOIN CAUSACION_AUTOMATICA CA ON CC.COMPANIA = CA.COMPANIA AND CC.ANO = CA.ANO AND CC.TIPO = CA.TIPO_COMPROBANTE AND CC.NUMERO = CA.NUMERO_COMPROBANTE INNER JOIN TERCERO ON CC.COMPANIA = TERCERO.COMPANIA AND CC.TERCERO = TERCERO.NIT AND CC.SUCURSAL = TERCERO.SUCURSAL INNER JOIN COMPROBANTE_CNTRETENCION CRETEN ON CC.COMPANIA = CRETEN.COMPANIA AND CC.ANO = CRETEN.ANO AND CC.TIPO = CRETEN.TIPO AND CC.NUMERO = CRETEN.NUMERO AND CA.CONCEPTO = CRETEN.CONCEPTO AND CA.PROVEEDOR = CRETEN.PROVEEDOR AND CA.REFERENCIADO = CRETEN.REFERENCIADO AND CA.CENTROCOSTO = CRETEN.CENTROCOSTO INNER JOIN RETENCIONES ON CRETEN.COMPANIA = RETENCIONES.COMPANIA AND CRETEN.ANO = RETENCIONES.ANO AND CRETEN.TIPORETENCION = RETENCIONES.TIPO AND CRETEN.CODIGORETENCION = RETENCIONES.CODIGO WHERE CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO AND CC.TIPO = :TIPO AND CC.NUMERO = :NUMERO AND CA.CONCEPTO = :CONCEPTO AND CA.PROVEEDOR = :PROVEEDOR AND CA.REFERENCIADO = :REFERENCIADO AND CA.CENTROCOSTO = :CENTROCOSTO AND RETENCIONES.ALEY1819 = -1 AND TERCERO.LEY1819 = -1 GROUP BY CC.COMPANIA, CC.ANO, CC.TIPO, CC.NUMERO, CC.TERCERO,CA.VALOR, TERCERO.LEY1819, RETENCIONES.ALEY1819</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TERCERO":"$TERCERO","VALORBASE":"$VALORBASE","LEY1819":"$LEY1819(type:boolean)","ALEY1819":"$ALEY1819(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="REFERENCIADO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="causacion_automatica/getcomprobanteaplicaley1819">
		<call-query href="getCausacion_automaticaGetcomprobanteaplicaley1819Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="REFERENCIADO" query-param="REFERENCIADO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="updateCausacion_automaticaActualizaibc" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CAUSACION_AUTOMATICA SET IBC = :IBC WHERE COMPANIA = :KEY_COMPANIA AND ANO = :KEY_ANO AND TIPO_COMPROBANTE = :KEY_TIPO AND NUMERO_COMPROBANTE = :KEY_NUMERO AND CONCEPTO = :KEY_CONCEPTO AND PROVEEDOR = :KEY_PROVEEDOR AND REFERENCIADO = :KEY_REFERENCIADO AND CENTROCOSTO = :KEY_CENTROCOSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IBC" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_PROVEEDOR" sqlType="STRING"/>
		<param name="KEY_REFERENCIADO" sqlType="STRING"/>
		<param name="KEY_CENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="causacion_automatica/actualizaibc">
		<call-query href="updateCausacion_automaticaActualizaibc">
			<with-param name="IBC" query-param="IBC"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_PROVEEDOR" query-param="KEY_PROVEEDOR"/>
			<with-param name="KEY_REFERENCIADO" query-param="KEY_REFERENCIADO"/>
			<with-param name="KEY_CENTROCOSTO" query-param="KEY_CENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaTodosporcompaniaanonumerotipocomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT('X') AS CONTEO FROM CAUSACION_AUTOMATICA WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_COMPROBANTE = :TIPOCPTE AND NUMERO_COMPROBANTE = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCPTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="causacion_automatica/todosporcompaniaanonumerotipocomprobante">
		<call-query href="getCausacion_automaticaTodosporcompaniaanonumerotipocomprobanteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCPTE" query-param="TIPOCPTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="insertCausacion_automatica" keyColumns="COMPANIA,ANO,NUMERO_COMPROBANTE,TIPO_COMPROBANTE,CONCEPTO,PROVEEDOR,REFERENCIADO,CENTROCOSTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CAUSACION_AUTOMATICA (COMPANIA, ANO, NUMERO_COMPROBANTE, TIPO_COMPROBANTE, CONCEPTO, PROVEEDOR, IBC, APORTESVOLUNTARIOS, AFC, DEDUCIBLE_VIVIENDA, MEDPREPAGADA, APORTESARL, CREATED_BY, DATE_CREATED, REFERENCIADO, VALOR, CENTROCOSTO, CUENTACONTABLE, CUENTA_ANTICIPO, VALOR_ANTICIPO) VALUES (:COMPANIA, :ANO, :NUMERO_COMPROBANTE, :TIPO_COMPROBANTE, :CONCEPTO, :PROVEEDOR, :IBC, :APORTESVOLUNTARIOS, :AFC, :DEDUCIBLE_VIVIENDA, :MEDPREPAGADA, :APORTESARL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :REFERENCIADO, :VALOR, :CENTROCOSTO, :CUENTACONTABLE, :CUENTA_ANTICIPO, :VALOR_ANTICIPO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_NUMERO_COMPROBANTE":"$NUMERO_COMPROBANTE(type:long)","KEY_TIPO_COMPROBANTE":"$TIPO_COMPROBANTE","KEY_CONCEPTO":"$CONCEPTO","KEY_PROVEEDOR":"$PROVEEDOR","KEY_REFERENCIADO":"$REFERENCIADO","KEY_CENTROCOSTO":"$CENTROCOSTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO_COMPROBANTE" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param defaultValue="0" name="IBC" sqlType="STRING"/>
		<param defaultValue="0" name="APORTESVOLUNTARIOS" sqlType="STRING"/>
		<param defaultValue="0" name="AFC" sqlType="STRING"/>
		<param defaultValue="0" name="DEDUCIBLE_VIVIENDA" sqlType="STRING"/>
		<param defaultValue="0" name="MEDPREPAGADA" sqlType="STRING"/>
		<param defaultValue="0" name="APORTESARL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="REFERENCIADO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR" sqlType="STRING"/>
		<param defaultValue="0" name="CENTROCOSTO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACONTABLE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_ANTICIPO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_ANTICIPO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="causacion_automatica">
		<call-query href="insertCausacion_automatica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO_COMPROBANTE" query-param="NUMERO_COMPROBANTE"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="IBC" query-param="IBC"/>
			<with-param name="APORTESVOLUNTARIOS" query-param="APORTESVOLUNTARIOS"/>
			<with-param name="AFC" query-param="AFC"/>
			<with-param name="DEDUCIBLE_VIVIENDA" query-param="DEDUCIBLE_VIVIENDA"/>
			<with-param name="MEDPREPAGADA" query-param="MEDPREPAGADA"/>
			<with-param name="APORTESARL" query-param="APORTESARL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="REFERENCIADO" query-param="REFERENCIADO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>
			<with-param name="CUENTACONTABLE" query-param="CUENTACONTABLE"/>
			<with-param name="CUENTA_ANTICIPO" query-param="CUENTA_ANTICIPO"/>
			<with-param name="VALOR_ANTICIPO" query-param="VALOR_ANTICIPO"/>

		</call-query>
	</resource>
	<query id="deleteCausacion_automatica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CAUSACION_AUTOMATICA WHERE CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CAUSACION_AUTOMATICA.ANO= :KEY_ANO AND CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE= :KEY_NUMERO_COMPROBANTE AND CAUSACION_AUTOMATICA.TIPO_COMPROBANTE= :KEY_TIPO_COMPROBANTE AND CAUSACION_AUTOMATICA.CONCEPTO= :KEY_CONCEPTO AND CAUSACION_AUTOMATICA.PROVEEDOR= :KEY_PROVEEDOR AND CAUSACION_AUTOMATICA.REFERENCIADO= :KEY_REFERENCIADO AND CAUSACION_AUTOMATICA.CENTROCOSTO= :KEY_CENTROCOSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_NUMERO_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_PROVEEDOR" sqlType="STRING"/>
		<param name="KEY_REFERENCIADO" sqlType="STRING"/>
		<param name="KEY_CENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="causacion_automatica">
		<call-query href="deleteCausacion_automatica">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO_COMPROBANTE" query-param="KEY_NUMERO_COMPROBANTE"/>
			<with-param name="KEY_TIPO_COMPROBANTE" query-param="KEY_TIPO_COMPROBANTE"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_PROVEEDOR" query-param="KEY_PROVEEDOR"/>
			<with-param name="KEY_REFERENCIADO" query-param="KEY_REFERENCIADO"/>
			<with-param name="KEY_CENTROCOSTO" query-param="KEY_CENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CAUSACION_AUTOMATICA.REFERENCIADO,CAUSACION_AUTOMATICA.CENTROCOSTO, CAUSACION_AUTOMATICA.COMPANIA, CAUSACION_AUTOMATICA.ANO, CAUSACION_AUTOMATICA.TIPO_COMPROBANTE, CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE, CAUSACION_AUTOMATICA.CONCEPTO, CAUSACION_AUTOMATICA.PROVEEDOR, TA_CONCEPTOS.NOMBRE NOMBRE_CONCEPTO, TA_PROVEEDORES.NOMBRE NOMBRE_PROVEEDOR FROM CAUSACION_AUTOMATICA LEFT JOIN TA_CONCEPTOS ON CAUSACION_AUTOMATICA.COMPANIA = TA_CONCEPTOS.COMPANIA AND CAUSACION_AUTOMATICA.ANO = TA_CONCEPTOS.ANO AND CAUSACION_AUTOMATICA.CONCEPTO = TA_CONCEPTOS.CODIGO LEFT JOIN TA_PROVEEDORES ON CAUSACION_AUTOMATICA.COMPANIA = TA_PROVEEDORES.COMPANIA AND CAUSACION_AUTOMATICA.ANO = TA_PROVEEDORES.ANO AND CAUSACION_AUTOMATICA.PROVEEDOR = TA_PROVEEDORES.CODIGO WHERE CAUSACION_AUTOMATICA.COMPANIA = :COMPANIA AND CAUSACION_AUTOMATICA.ANO = :ANO AND CAUSACION_AUTOMATICA.TIPO_COMPROBANTE = :TIPO AND CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE = :NUMERO) INI WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN PROVEEDOR IS NULL THEN ' ' ELSE UPPER(PROVEEDOR) END) LIKE UPPER(CONCAT(:PROVEEDOR, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN NOMBRE_PROVEEDOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROVEEDOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROVEEDOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"REFERENCIADO":"$REFERENCIADO","CENTROCOSTO":"$CENTROCOSTO","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_COMPROBANTE":"$TIPO_COMPROBANTE","NUMERO_COMPROBANTE":"$NUMERO_COMPROBANTE(type:long)","CONCEPTO":"$CONCEPTO","PROVEEDOR":"$PROVEEDOR","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","NOMBRE_PROVEEDOR":"$NOMBRE_PROVEEDOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_PROVEEDOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="causacion_automatica">
		<call-query href="getCausacion_automaticaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="NOMBRE_PROVEEDOR" query-param="NOMBRE_PROVEEDOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CAUSACION_AUTOMATICA.REFERENCIADO,CAUSACION_AUTOMATICA.CENTROCOSTO, CAUSACION_AUTOMATICA.COMPANIA, CAUSACION_AUTOMATICA.ANO, CAUSACION_AUTOMATICA.TIPO_COMPROBANTE, CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE, CAUSACION_AUTOMATICA.CONCEPTO, CAUSACION_AUTOMATICA.PROVEEDOR, TA_CONCEPTOS.NOMBRE NOMBRE_CONCEPTO, TA_PROVEEDORES.NOMBRE NOMBRE_PROVEEDOR FROM CAUSACION_AUTOMATICA LEFT JOIN TA_CONCEPTOS ON CAUSACION_AUTOMATICA.COMPANIA = TA_CONCEPTOS.COMPANIA AND CAUSACION_AUTOMATICA.ANO = TA_CONCEPTOS.ANO AND CAUSACION_AUTOMATICA.CONCEPTO = TA_CONCEPTOS.CODIGO LEFT JOIN TA_PROVEEDORES ON CAUSACION_AUTOMATICA.COMPANIA = TA_PROVEEDORES.COMPANIA AND CAUSACION_AUTOMATICA.ANO = TA_PROVEEDORES.ANO AND CAUSACION_AUTOMATICA.PROVEEDOR = TA_PROVEEDORES.CODIGO WHERE CAUSACION_AUTOMATICA.COMPANIA = :COMPANIA AND CAUSACION_AUTOMATICA.ANO = :ANO AND CAUSACION_AUTOMATICA.TIPO_COMPROBANTE = :TIPO AND CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE = :NUMERO) INI WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN PROVEEDOR IS NULL THEN ' ' ELSE UPPER(PROVEEDOR) END) LIKE UPPER(CONCAT(:PROVEEDOR, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN NOMBRE_PROVEEDOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROVEEDOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROVEEDOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_PROVEEDOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="causacion_automatica/numero">
		<call-query href="getCausacion_automaticaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="NOMBRE_PROVEEDOR" query-param="NOMBRE_PROVEEDOR"/>

		</call-query>
	</resource>
	<query id="getCausacion_automaticaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT CAUSACION_AUTOMATICA.COMPANIA, CAUSACION_AUTOMATICA.ANO, CAUSACION_AUTOMATICA.TIPO_COMPROBANTE, CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE, CAUSACION_AUTOMATICA.CONCEPTO, CAUSACION_AUTOMATICA.PROVEEDOR, CAUSACION_AUTOMATICA.REFERENCIADO, CAUSACION_AUTOMATICA.CENTROCOSTO, CAUSACION_AUTOMATICA.VALOR, CAUSACION_AUTOMATICA.IBC, CAUSACION_AUTOMATICA.APORTESVOLUNTARIOS, CAUSACION_AUTOMATICA.AFC, CAUSACION_AUTOMATICA.DEDUCIBLE_VIVIENDA, CAUSACION_AUTOMATICA.MEDPREPAGADA, CAUSACION_AUTOMATICA.APORTESARL, CAUSACION_AUTOMATICA.CREATED_BY, CAUSACION_AUTOMATICA.MODIFIED_BY,(TO_CHAR(CAUSACION_AUTOMATICA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(CAUSACION_AUTOMATICA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TA_CONCEPTOS.NOMBRE AS NOMBRE_CONCEPTO, TA_PROVEEDORES.NOMBRE AS NOMBRE_PROVEEDOR, CAUSACION_AUTOMATICA.CUENTACONTABLE, CAUSACION_AUTOMATICA.CUENTA_ANTICIPO, CAUSACION_AUTOMATICA.VALOR_ANTICIPO FROM CAUSACION_AUTOMATICA LEFT JOIN TA_CONCEPTOS ON CAUSACION_AUTOMATICA.COMPANIA = TA_CONCEPTOS.COMPANIA AND CAUSACION_AUTOMATICA.ANO = TA_CONCEPTOS.ANO AND CAUSACION_AUTOMATICA.CONCEPTO = TA_CONCEPTOS.CODIGO LEFT JOIN TA_PROVEEDORES ON CAUSACION_AUTOMATICA.COMPANIA = TA_PROVEEDORES.COMPANIA AND CAUSACION_AUTOMATICA.ANO = TA_PROVEEDORES.ANO AND CAUSACION_AUTOMATICA.PROVEEDOR = TA_PROVEEDORES.CODIGO WHERE CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CAUSACION_AUTOMATICA.ANO= :KEY_ANO AND CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE= :KEY_NUMERO_COMPROBANTE AND CAUSACION_AUTOMATICA.TIPO_COMPROBANTE= :KEY_TIPO_COMPROBANTE AND CAUSACION_AUTOMATICA.CONCEPTO= :KEY_CONCEPTO AND CAUSACION_AUTOMATICA.PROVEEDOR= :KEY_PROVEEDOR AND CAUSACION_AUTOMATICA.REFERENCIADO= :KEY_REFERENCIADO AND CAUSACION_AUTOMATICA.CENTROCOSTO= :KEY_CENTROCOSTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_COMPROBANTE":"$TIPO_COMPROBANTE","NUMERO_COMPROBANTE":"$NUMERO_COMPROBANTE(type:long)","CONCEPTO":"$CONCEPTO","PROVEEDOR":"$PROVEEDOR","REFERENCIADO":"$REFERENCIADO","CENTROCOSTO":"$CENTROCOSTO","VALOR":"$VALOR","IBC":"$IBC","APORTESVOLUNTARIOS":"$APORTESVOLUNTARIOS","AFC":"$AFC","DEDUCIBLE_VIVIENDA":"$DEDUCIBLE_VIVIENDA","MEDPREPAGADA":"$MEDPREPAGADA","APORTESARL":"$APORTESARL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","NOMBRE_PROVEEDOR":"$NOMBRE_PROVEEDOR","CUENTACONTABLE":"$CUENTACONTABLE","CUENTA_ANTICIPO":"$CUENTA_ANTICIPO","VALOR_ANTICIPO":"$VALOR_ANTICIPO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_PROVEEDOR" sqlType="STRING"/>
		<param name="KEY_REFERENCIADO" sqlType="STRING"/>
		<param name="KEY_CENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="causacion_automatica/data">
		<call-query href="getCausacion_automaticaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO_COMPROBANTE" query-param="KEY_NUMERO_COMPROBANTE"/>
			<with-param name="KEY_TIPO_COMPROBANTE" query-param="KEY_TIPO_COMPROBANTE"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_PROVEEDOR" query-param="KEY_PROVEEDOR"/>
			<with-param name="KEY_REFERENCIADO" query-param="KEY_REFERENCIADO"/>
			<with-param name="KEY_CENTROCOSTO" query-param="KEY_CENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="updateCausacion_automatica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CAUSACION_AUTOMATICA SET COMPANIA=:COMPANIA, ANO=:ANO, NUMERO_COMPROBANTE=:NUMERO_COMPROBANTE, TIPO_COMPROBANTE=:TIPO_COMPROBANTE, CONCEPTO=:CONCEPTO, PROVEEDOR=:PROVEEDOR, IBC=:IBC, APORTESVOLUNTARIOS=:APORTESVOLUNTARIOS, AFC=:AFC, DEDUCIBLE_VIVIENDA=:DEDUCIBLE_VIVIENDA, MEDPREPAGADA=:MEDPREPAGADA, APORTESARL=:APORTESARL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), REFERENCIADO=:REFERENCIADO, VALOR=:VALOR, CENTROCOSTO=:CENTROCOSTO, CUENTACONTABLE=:CUENTACONTABLE, CUENTA_ANTICIPO=:CUENTA_ANTICIPO, VALOR_ANTICIPO=:VALOR_ANTICIPO WHERE CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CAUSACION_AUTOMATICA.ANO= :KEY_ANO AND CAUSACION_AUTOMATICA.NUMERO_COMPROBANTE= :KEY_NUMERO_COMPROBANTE AND CAUSACION_AUTOMATICA.TIPO_COMPROBANTE= :KEY_TIPO_COMPROBANTE AND CAUSACION_AUTOMATICA.CONCEPTO= :KEY_CONCEPTO AND CAUSACION_AUTOMATICA.PROVEEDOR= :KEY_PROVEEDOR AND CAUSACION_AUTOMATICA.REFERENCIADO= :KEY_REFERENCIADO AND CAUSACION_AUTOMATICA.CENTROCOSTO= :KEY_CENTROCOSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO_COMPROBANTE" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="APORTESVOLUNTARIOS" sqlType="STRING"/>
		<param name="AFC" sqlType="STRING"/>
		<param name="DEDUCIBLE_VIVIENDA" sqlType="STRING"/>
		<param name="MEDPREPAGADA" sqlType="STRING"/>
		<param name="APORTESARL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="REFERENCIADO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>
		<param name="CUENTACONTABLE" sqlType="STRING"/>
		<param name="CUENTA_ANTICIPO" sqlType="STRING"/>
		<param name="VALOR_ANTICIPO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_PROVEEDOR" sqlType="STRING"/>
		<param name="KEY_REFERENCIADO" sqlType="STRING"/>
		<param name="KEY_CENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="causacion_automatica">
		<call-query href="updateCausacion_automatica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO_COMPROBANTE" query-param="NUMERO_COMPROBANTE"/>
