<data name="plancntequivalente" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPlancntequivalenteCodigoporanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO  FROM PLAN_CNT_EQUIVALENTE WHERE COMPANIA = :COMPANIA AND ANO = :ANIO ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="plancntequivalente/codigoporano">
		<call-query href="getPlancntequivalenteCodigoporanoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>
	<query id="getPlancntequivalentePagCodigoYNombre6Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CNT_EQUIVALENTE.CODIGO, PLAN_CNT_EQUIVALENTE.NOMBRE  FROM PLAN_CNT_EQUIVALENTE WHERE PLAN_CNT_EQUIVALENTE.COMPANIA = :COMPANIA AND PLAN_CNT_EQUIVALENTE.ANO = :ANO AND LENGTH(CODIGO) &gt;= 6 ORDER BY PLAN_CNT_EQUIVALENTE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="plancntequivalente/codigoynombre6/pag">
		<call-query href="getPlancntequivalentePagCodigoYNombre6Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlancntequivalenteNumCodigoYNombre6Query"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_CNT_EQUIVALENTE.CODIGO, PLAN_CNT_EQUIVALENTE.NOMBRE  FROM PLAN_CNT_EQUIVALENTE WHERE PLAN_CNT_EQUIVALENTE.COMPANIA = :COMPANIA AND PLAN_CNT_EQUIVALENTE.ANO = :ANO AND LENGTH(CODIGO) &gt;= 6 ORDER BY PLAN_CNT_EQUIVALENTE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="plancntequivalente/codigoynombre6/num">
		<call-query href="getPlancntequivalenteNumCodigoYNombre6Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

</data>