<data name="proyectospersonal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertProyectospersonal" keyColumns="COMPANIA,ID_DE_EMPLEADO,ID_DE_PROYECTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PROYECTOSPERSONAL (COMPANIA, ID_DE_EMPLEADO, ID_DE_PROYECTO, FECHAINICIAL, FECHAFINAL, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_EMPLEADO, :ID_DE_PROYECTO, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_DE_PROYECTO":"$ID_DE_PROYECTO","KEY_FECHAINICIAL":"$FECHAINICIAL","KEY_FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_PROYECTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="proyectospersonal">
		<call-query href="insertProyectospersonal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_PROYECTO" query-param="ID_DE_PROYECTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteProyectospersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PROYECTOSPERSONAL WHERE PROYECTOSPERSONAL.COMPANIA= :KEY_COMPANIA AND PROYECTOSPERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND PROYECTOSPERSONAL.ID_DE_PROYECTO= :KEY_ID_DE_PROYECTO AND PROYECTOSPERSONAL.FECHAINICIAL= TO_DATE(:KEY_FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')  AND PROYECTOSPERSONAL.FECHAFINAL= TO_DATE(:KEY_FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_PROYECTO" sqlType="STRING"/>
		<param name="KEY_FECHAINICIAL" sqlType="STRING"/>
		<param name="KEY_FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="proyectospersonal">
		<call-query href="deleteProyectospersonal">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_PROYECTO" query-param="KEY_ID_DE_PROYECTO"/>
			<with-param name="KEY_FECHAINICIAL" query-param="KEY_FECHAINICIAL"/>
			<with-param name="KEY_FECHAFINAL" query-param="KEY_FECHAFINAL"/>

		</call-query>
	</resource>
	<query id="getProyectospersonalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROYECTOSPERSONAL.COMPANIA, PROYECTOSPERSONAL.ID_DE_EMPLEADO, PROYECTOSPERSONAL.ID_DE_PROYECTO,(TO_CHAR(PROYECTOSPERSONAL.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, TO_CHAR(PROYECTOSPERSONAL.FECHAINICIAL, 'DD/MM/YYYY') FECHAINICIAL_LB,(TO_CHAR(PROYECTOSPERSONAL.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, TO_CHAR(PROYECTOSPERSONAL.FECHAFINAL, 'DD/MM/YYYY') FECHAFINAL_LB, PROYECTOSPERSONAL.DESCRIPCION, (SELECT PROYECTOSNOM.NOMBREPROYECTO FROM PROYECTOSNOM WHERE COMPANIA = PROYECTOSPERSONAL.COMPANIA AND ID_DE_PROYECTO = PROYECTOSPERSONAL.ID_DE_PROYECTO ) NOMBREPROYECTO_LB  FROM PROYECTOSPERSONAL WHERE PROYECTOSPERSONAL.COMPANIA = :COMPANIA AND PROYECTOSPERSONAL.ID_DE_EMPLEADO = :CODIGO) WHERE (CASE WHEN ID_DE_PROYECTO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROYECTO) END)  LIKE UPPER(:ID_DE_PROYECTO || '%')  AND (CASE WHEN FECHAINICIAL_LB IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL_LB) END)  LIKE UPPER( '%' || :FECHAINICIAL_LB || '%')  AND (CASE WHEN FECHAFINAL_LB IS NULL THEN ' ' ELSE UPPER(FECHAFINAL_LB) END)  LIKE UPPER( '%' || :FECHAFINAL_LB || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBREPROYECTO_LB IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO_LB) END)  LIKE UPPER( '%' || :NOMBREPROYECTO_LB || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_PROYECTO":"$ID_DE_PROYECTO","FECHAINICIAL":"$FECHAINICIAL","FECHAINICIAL_LB":"$FECHAINICIAL_LB","FECHAFINAL":"$FECHAFINAL","FECHAFINAL_LB":"$FECHAFINAL_LB","DESCRIPCION":"$DESCRIPCION","NOMBREPROYECTO_LB":"$NOMBREPROYECTO_LB"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ID_DE_PROYECTO" sqlType="STRING"/>
		<param name="FECHAINICIAL_LB" sqlType="STRING"/>
		<param name="FECHAFINAL_LB" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBREPROYECTO_LB" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proyectospersonal">
		<call-query href="getProyectospersonalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ID_DE_PROYECTO" query-param="ID_DE_PROYECTO"/>
			<with-param name="FECHAINICIAL_LB" query-param="FECHAINICIAL_LB"/>
			<with-param name="FECHAFINAL_LB" query-param="FECHAFINAL_LB"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBREPROYECTO_LB" query-param="NOMBREPROYECTO_LB"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProyectospersonalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROYECTOSPERSONAL.COMPANIA, PROYECTOSPERSONAL.ID_DE_EMPLEADO, PROYECTOSPERSONAL.ID_DE_PROYECTO,(TO_CHAR(PROYECTOSPERSONAL.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, TO_CHAR(PROYECTOSPERSONAL.FECHAINICIAL, 'DD/MM/YYYY') FECHAINICIAL_LB,(TO_CHAR(PROYECTOSPERSONAL.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, TO_CHAR(PROYECTOSPERSONAL.FECHAFINAL, 'DD/MM/YYYY') FECHAFINAL_LB, PROYECTOSPERSONAL.DESCRIPCION, (SELECT PROYECTOSNOM.NOMBREPROYECTO FROM PROYECTOSNOM WHERE COMPANIA = PROYECTOSPERSONAL.COMPANIA AND ID_DE_PROYECTO = PROYECTOSPERSONAL.ID_DE_PROYECTO ) NOMBREPROYECTO_LB  FROM PROYECTOSPERSONAL WHERE PROYECTOSPERSONAL.COMPANIA = :COMPANIA AND PROYECTOSPERSONAL.ID_DE_EMPLEADO = :CODIGO) WHERE (CASE WHEN ID_DE_PROYECTO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROYECTO) END)  LIKE UPPER(:ID_DE_PROYECTO || '%')  AND (CASE WHEN FECHAINICIAL_LB IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL_LB) END)  LIKE UPPER( '%' || :FECHAINICIAL_LB || '%')  AND (CASE WHEN FECHAFINAL_LB IS NULL THEN ' ' ELSE UPPER(FECHAFINAL_LB) END)  LIKE UPPER( '%' || :FECHAFINAL_LB || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBREPROYECTO_LB IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO_LB) END)  LIKE UPPER( '%' || :NOMBREPROYECTO_LB || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ID_DE_PROYECTO" sqlType="STRING"/>
		<param name="FECHAINICIAL_LB" sqlType="STRING"/>
		<param name="FECHAFINAL_LB" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBREPROYECTO_LB" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proyectospersonal/numero">
		<call-query href="getProyectospersonalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ID_DE_PROYECTO" query-param="ID_DE_PROYECTO"/>
			<with-param name="FECHAINICIAL_LB" query-param="FECHAINICIAL_LB"/>
			<with-param name="FECHAFINAL_LB" query-param="FECHAFINAL_LB"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBREPROYECTO_LB" query-param="NOMBREPROYECTO_LB"/>

		</call-query>
	</resource>
	<query id="updateProyectospersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROYECTOSPERSONAL SET ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_DE_PROYECTO=:ID_DE_PROYECTO, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PROYECTOSPERSONAL.COMPANIA= :KEY_COMPANIA AND PROYECTOSPERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND PROYECTOSPERSONAL.ID_DE_PROYECTO= :KEY_ID_DE_PROYECTO AND PROYECTOSPERSONAL.FECHAINICIAL= TO_DATE(:KEY_FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')  AND PROYECTOSPERSONAL.FECHAFINAL= TO_DATE(:KEY_FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_PROYECTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROYECTO" sqlType="STRING"/>
		<param name="KEY_FECHAINICIAL" sqlType="STRING"/>
		<param name="KEY_FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="proyectospersonal">
		<call-query href="updateProyectospersonal">
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_PROYECTO" query-param="ID_DE_PROYECTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_PROYECTO" query-param="KEY_ID_DE_PROYECTO"/>
			<with-param name="KEY_FECHAINICIAL" query-param="KEY_FECHAINICIAL"/>
			<with-param name="KEY_FECHAFINAL" query-param="KEY_FECHAFINAL"/>

		</call-query>
	</resource>

</data>