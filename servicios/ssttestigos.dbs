<data name="ssttestigos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSsttestigos" keyColumns="COMPANIA,CONSECUTIVO,NUMERO_DCTO,SUCURSAL,FACTOR_RIESGO,TIPO_TRANSACCION,CLASE_TRANSACCION,NUMERO_DCTO_TESTIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_TESTIGOS (COMPANIA, CONSECUTIVO, NUMERO_DCTO, SUCURSAL, FACTOR_RIESGO, TIPO_TRANSACCION, CLASE_TRANSACCION, NUMERO_DCTO_TESTIGO, NOMBRECOMPLETO, OBSERVACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONSECUTIVO, :NUMERO_DCTO, :SUCURSAL, :FACTOR_RIESGO, :TIPO_TRANSACCION, :CLASE_TRANSACCION, :NUMERO_DCTO_TESTIGO, :NOMBRECOMPLETO, :OBSERVACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_FACTOR_RIESGO":"$FACTOR_RIESGO","KEY_TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","KEY_CLASE_TRANSACCION":"$CLASE_TRANSACCION","KEY_NUMERO_DCTO_TESTIGO":"$NUMERO_DCTO_TESTIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="NUMERO_DCTO_TESTIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ssttestigos">
		<call-query href="insertSsttestigos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CLASE_TRANSACCION" query-param="CLASE_TRANSACCION"/>
			<with-param name="NUMERO_DCTO_TESTIGO" query-param="NUMERO_DCTO_TESTIGO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSsttestigos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_TESTIGOS WHERE SST_TESTIGOS.COMPANIA= :KEY_COMPANIA AND SST_TESTIGOS.CONSECUTIVO= :KEY_CONSECUTIVO AND SST_TESTIGOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND SST_TESTIGOS.SUCURSAL= :KEY_SUCURSAL AND SST_TESTIGOS.FACTOR_RIESGO= :KEY_FACTOR_RIESGO AND SST_TESTIGOS.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_TESTIGOS.CLASE_TRANSACCION= :KEY_CLASE_TRANSACCION AND SST_TESTIGOS.NUMERO_DCTO_TESTIGO= :KEY_NUMERO_DCTO_TESTIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FACTOR_RIESGO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="INTEGER"/>
		<param name="KEY_CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO_TESTIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ssttestigos">
		<call-query href="deleteSsttestigos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_FACTOR_RIESGO" query-param="KEY_FACTOR_RIESGO"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>
			<with-param name="KEY_CLASE_TRANSACCION" query-param="KEY_CLASE_TRANSACCION"/>
			<with-param name="KEY_NUMERO_DCTO_TESTIGO" query-param="KEY_NUMERO_DCTO_TESTIGO"/>

		</call-query>
	</resource>
	<query id="getSsttestigosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CONSECUTIVO, NUMERO_DCTO, SUCURSAL, FACTOR_RIESGO, TIPO_TRANSACCION, CLASE_TRANSACCION, NUMERO_DCTO_TESTIGO, NOMBRECOMPLETO, OBSERVACION  FROM SST_TESTIGOS WHERE COMPANIA = :COMPANIA AND CONSECUTIVO = :CONSECUTIVO AND NUMERO_DCTO = :NUMERO_DCTO AND SUCURSAL = :SUCURSAL AND FACTOR_RIESGO = :FACTOR_RIESGO AND TIPO_TRANSACCION = :TIPO_TRANSACCION AND CLASE_TRANSACCION = :CLASE_TRANSACCION) WHERE (CASE WHEN NUMERO_DCTO_TESTIGO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO_TESTIGO) END)  LIKE UPPER(:NUMERO_DCTO_TESTIGO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","FACTOR_RIESGO":"$FACTOR_RIESGO","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CLASE_TRANSACCION":"$CLASE_TRANSACCION","NUMERO_DCTO_TESTIGO":"$NUMERO_DCTO_TESTIGO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="NUMERO_DCTO_TESTIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttestigos">
		<call-query href="getSsttestigosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CLASE_TRANSACCION" query-param="CLASE_TRANSACCION"/>
			<with-param name="NUMERO_DCTO_TESTIGO" query-param="NUMERO_DCTO_TESTIGO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttestigosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CONSECUTIVO, NUMERO_DCTO, SUCURSAL, FACTOR_RIESGO, TIPO_TRANSACCION, CLASE_TRANSACCION, NUMERO_DCTO_TESTIGO, NOMBRECOMPLETO, OBSERVACION  FROM SST_TESTIGOS WHERE COMPANIA = :COMPANIA AND CONSECUTIVO = :CONSECUTIVO AND NUMERO_DCTO = :NUMERO_DCTO AND SUCURSAL = :SUCURSAL AND FACTOR_RIESGO = :FACTOR_RIESGO AND TIPO_TRANSACCION = :TIPO_TRANSACCION AND CLASE_TRANSACCION = :CLASE_TRANSACCION) WHERE (CASE WHEN NUMERO_DCTO_TESTIGO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO_TESTIGO) END)  LIKE UPPER(:NUMERO_DCTO_TESTIGO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="NUMERO_DCTO_TESTIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttestigos/numero">
		<call-query href="getSsttestigosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CLASE_TRANSACCION" query-param="CLASE_TRANSACCION"/>
			<with-param name="NUMERO_DCTO_TESTIGO" query-param="NUMERO_DCTO_TESTIGO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>

		</call-query>
	</resource>
	<query id="updateSsttestigos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_TESTIGOS SET NUMERO_DCTO_TESTIGO=:NUMERO_DCTO_TESTIGO, NOMBRECOMPLETO=:NOMBRECOMPLETO, OBSERVACION=:OBSERVACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_TESTIGOS.COMPANIA= :KEY_COMPANIA AND SST_TESTIGOS.CONSECUTIVO= :KEY_CONSECUTIVO AND SST_TESTIGOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND SST_TESTIGOS.SUCURSAL= :KEY_SUCURSAL AND SST_TESTIGOS.FACTOR_RIESGO= :KEY_FACTOR_RIESGO AND SST_TESTIGOS.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_TESTIGOS.CLASE_TRANSACCION= :KEY_CLASE_TRANSACCION AND SST_TESTIGOS.NUMERO_DCTO_TESTIGO= :KEY_NUMERO_DCTO_TESTIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO_DCTO_TESTIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FACTOR_RIESGO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CLASE_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO_TESTIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ssttestigos">
		<call-query href="updateSsttestigos">
			<with-param name="NUMERO_DCTO_TESTIGO" query-param="NUMERO_DCTO_TESTIGO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_FACTOR_RIESGO" query-param="KEY_FACTOR_RIESGO"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>
			<with-param name="KEY_CLASE_TRANSACCION" query-param="KEY_CLASE_TRANSACCION"/>
			<with-param name="KEY_NUMERO_DCTO_TESTIGO" query-param="KEY_NUMERO_DCTO_TESTIGO"/>

		</call-query>
	</resource>

</data>