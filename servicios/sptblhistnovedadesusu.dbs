<data name="sptblhistnovedadesusu" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSptblhistnovedadesusuPagPorCicloYCodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_TBL_HIST_NOVEDADES_USU.COMPANIA, SP_TBL_HIST_NOVEDADES_USU.CODIGORUTA, SP_TBL_HIST_NOVEDADES_USU.IDNOVEDAD, CASE WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'A' THEN 'Activo' WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'S' THEN 'Suspendido' WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'R' THEN 'Retirado' WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'C' THEN 'Cortado' END ESTADO, TO_CHAR(SP_TBL_HIST_NOVEDADES_USU.FECHA,'DD/MM/YYYY HH24:MI:SS')FECHA, SP_TBL_HIST_NOVEDADES_USU.DESCRIPCION  FROM SP_TBL_HIST_NOVEDADES_USU WHERE SP_TBL_HIST_NOVEDADES_USU.COMPANIA = :COMPANIA AND SP_TBL_HIST_NOVEDADES_USU.CICLO = :CICLO AND SP_TBL_HIST_NOVEDADES_USU.CODIGORUTA = :CODIGORUTAINI) WHERE (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGORUTA":"$CODIGORUTA","IDNOVEDAD":"$IDNOVEDAD","ESTADO":"$ESTADO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTAINI" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sptblhistnovedadesusu/porcicloycodruta/pag">
		<call-query href="getSptblhistnovedadesusuPagPorCicloYCodrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTAINI" query-param="CODIGORUTAINI"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSptblhistnovedadesusuNumPorCicloYCodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_TBL_HIST_NOVEDADES_USU.COMPANIA, SP_TBL_HIST_NOVEDADES_USU.CODIGORUTA, SP_TBL_HIST_NOVEDADES_USU.IDNOVEDAD, CASE WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'A' THEN 'Activo' WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'S' THEN 'Suspendido' WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'R' THEN 'Retirado' WHEN SP_TBL_HIST_NOVEDADES_USU.ESTADO = 'C' THEN 'Cortado' END ESTADO, TO_CHAR(SP_TBL_HIST_NOVEDADES_USU.FECHA,'DD/MM/YYYY HH24:MI:SS')FECHA, SP_TBL_HIST_NOVEDADES_USU.DESCRIPCION  FROM SP_TBL_HIST_NOVEDADES_USU WHERE SP_TBL_HIST_NOVEDADES_USU.COMPANIA = :COMPANIA AND SP_TBL_HIST_NOVEDADES_USU.CICLO = :CICLO AND SP_TBL_HIST_NOVEDADES_USU.CODIGORUTA = :CODIGORUTAINI) WHERE (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTAINI" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptblhistnovedadesusu/porcicloycodruta/num">
		<call-query href="getSptblhistnovedadesusuNumPorCicloYCodrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTAINI" query-param="CODIGORUTAINI"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>

</data>