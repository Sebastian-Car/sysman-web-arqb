	<query id="getVistasaldosplanespptalResumenpptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT RESUMENPPTO_A.APRDEFINITIVA, RESUMENPPTO_P.ADICION, RESUMENPPTO_P.REDUCCION, RESUMENPPTO_P.TRASLADO, RESUMENPPTO_A.APRDEFINITIVA + RESUMENPPTO_P.ADICION + RESUMENPPTO_P.REDUCCION + RESUMENPPTO_P.TRASLADO APRDEFINITIVACAMPO, RESUMENPPTO_P.APLAZAMIENTO, RESUMENPPTO_A.APRDEFINITIVA + RESUMENPPTO_P.ADICION + RESUMENPPTO_P.REDUCCION + RESUMENPPTO_P.TRASLADO + RESUMENPPTO_P.APLAZAMIENTO APROPIACIONVIGENTE, RESUMENPPTO_P.REINTEGRO + RESUMENPPTO_A.REINTEGRO REINTEGROSACUM, RESUMENPPTO_A.APRDEFINITIVA + RESUMENPPTO_P.ADICION + RESUMENPPTO_P.REDUCCION + RESUMENPPTO_P.TRASLADO+ RESUMENPPTO_P.APLAZAMIENTO DISPONIBLEACUMULADO, RESUMENPPTO_A.PACTOTAL PACTOTALA, RESUMENPPTO_P.PAC_APROPIADO PAC_APROPIADOP, RESUMENPPTO_P.MODIFPAC MODIFPACP, RESUMENPPTO_P.PACTOTAL PACTOTALP, RESUMENPPTO_A.PACTOTAL + RESUMENPPTO_P.PACTOTAL PACTOTALF, ( RESUMENPPTO_A.PACTOTAL + RESUMENPPTO_P.PACTOTAL ) - ( RESUMENPPTO_A.EJECUCIONPPT - RESUMENPPTO_A.REINTEGRO + RESUMENPPTO_P. EJECUCIONPPT - RESUMENPPTO_P.REINTEGRO ) + ( RESUMENPPTO_P.REINTEGRO + RESUMENPPTO_A.REINTEGRO ) SALDOPACACUMULADO, RESUMENPPTO_P.PAC_PROGRAMADO + RESUMENPPTO_A.PAC_PROGRAMADO PACPROGRAMADOF, RESUMENPPTO_A.APRDEFINITIVA - (RESUMENPPTO_A.PACTOTAL + RESUMENPPTO_P.PACTOTAL) + RESUMENPPTO_P.MODIFPAC SALDOPACXINCORPORAR, RESUMENPPTO_A.DISPONIBILIDAD DISPONIBILIDADA, RESUMENPPTO_P.DISPONIBILIDAD DISPONIBILIDADP, RESUMENPPTO_A.DISPONIBILIDAD + RESUMENPPTO_P.DISPONIBILIDAD DISPONIBILIDADF, ( CASE WHEN ( RESUMENPPTO_A.APRDEFINITIVA + RESUMENPPTO_P.ADICION + RESUMENPPTO_P.REDUCCION + RESUMENPPTO_P.TRASLADO + RESUMENPPTO_P .APLAZAMIENTO ) &lt;&gt; 0 THEN ( RESUMENPPTO_A.DISPONIBILIDAD + RESUMENPPTO_P.DISPONIBILIDAD ) / ( RESUMENPPTO_A.APRDEFINITIVA + RESUMENPPTO_P.ADICION + RESUMENPPTO_P.REDUCCION + RESUMENPPTO_P.TRASLADO + RESUMENPPTO_P.APLAZAMIENTO ) ELSE 0 END ) * 100 PORUTILIZACION, ( RESUMENPPTO_A.APRDEFINITIVA + RESUMENPPTO_P.ADICION + RESUMENPPTO_P.REDUCCION + RESUMENPPTO_P.TRASLADO + RESUMENPPTO_P.APLAZAMIENTO ) - ( RESUMENPPTO_A.DISPONIBILIDAD + RESUMENPPTO_P.DISPONIBILIDAD ) + ( RESUMENPPTO_P.REINTEGRO + RESUMENPPTO_A.REINTEGRO ) SALDODISPONIBLE , ( RESUMENPPTO_A.DISPONIBILIDAD + RESUMENPPTO_P.DISPONIBILIDAD ) - ( RESUMENPPTO_A.REGCONT + RESUMENPPTO_A.REGNOCONTRACT + RESUMENPPTO_P .REGCONT + RESUMENPPTO_P.REGNOCONTRACT ) DISPXREG, RESUMENPPTO_A.REGCONT + RESUMENPPTO_A.REGNOCONTRACT REGISTROSA, RESUMENPPTO_P.REGCONT + RESUMENPPTO_P.REGNOCONTRACT REGISTROSP, RESUMENPPTO_A.REGCONT + RESUMENPPTO_A.REGNOCONTRACT + RESUMENPPTO_P.REGCONT + RESUMENPPTO_P.REGNOCONTRACT REGISTROSF, ( RESUMENPPTO_A.REGCONT + RESUMENPPTO_A.REGNOCONTRACT + RESUMENPPTO_P.REGCONT + RESUMENPPTO_P.REGNOCONTRACT ) - ( RESUMENPPTO_P .TOTALREO + RESUMENPPTO_A.TOTALREO ) REGXPAGAR, RESUMENPPTO_A.TOTALREO REOA, RESUMENPPTO_P.TOTALREO REOP, RESUMENPPTO_P.TOTALREO + RESUMENPPTO_A.TOTALREO REOF, ( RESUMENPPTO_P.TOTALREO + RESUMENPPTO_A.TOTALREO ) - ( RESUMENPPTO_A.EJECUCIONPPT - RESUMENPPTO_A.REINTEGRO + RESUMENPPTO_P. EJECUCIONPPT - RESUMENPPTO_P.REINTEGRO ) PORPAGAR, RESUMENPPTO_A.EJECUCIONPPT - RESUMENPPTO_A.REINTEGRO PAGOSA, RESUMENPPTO_P.EJECUCIONPPT - RESUMENPPTO_P.REINTEGRO PAGOSP, RESUMENPPTO_A.EJECUCIONPPT - RESUMENPPTO_A.REINTEGRO + RESUMENPPTO_P.EJECUCIONPPT - RESUMENPPTO_P.REINTEGRO PAGOSF, RESUMENPPTO_A.PACEJECUTADOA, RESUMENPPTO_P.PACEJECUTADO_P, RESUMENPPTO_A.PACEJECUTADOA + RESUMENPPTO_P.PACEJECUTADO_P PACEJECUTADOF FROM ( SELECT V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END ) APROPIADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) MODIFPAC, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONCNT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END ) TRASLADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONPPT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END ) APLAZAMIENTO, SUM(V_SALDO_PLAN_PPTAL.ADICION) ADICION, SUM(V_SALDO_PLAN_PPTAL.REDUCCION) REDUCCION, SUM(V_SALDO_PLAN_PPTAL.DISPONIBILIDAD) DISPONIBILIDAD, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) REG_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) REG_NO_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_REVERSION) REG_REVERSION, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAANTERIOR) VIGENCIAANTERIOR, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAFUTURA) VIGENCIAFUTURA, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) PAC_APROPIADO, SUM(V_SALDO_PLAN_PPTAL.PAC_PROGRAMADO) PAC_PROGRAMADO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) MODIF_REG_CONT, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) MODIF_REG_NOCONT, SUM(V_SALDO_PLAN_PPTAL.REINTEGRO) REINTEGRO, V_PLAN_PRESUPUESTAL.NATURALEZA, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) REGNOCONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) REGCONT, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) PACTOTAL, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) REO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) MODIFREO, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) TOTALREO, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALMODIFINGRESOS, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALINGRESOS, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) INGRESOSCAUSADOS, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) MODIFICACIONICA, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) TOTALICA, SUM(V_SALDO_PLAN_PPTAL.PAC_EJECUTADO) PACEJECUTADO_P FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN :MESINICIAL AND :MESFINAL GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, V_PLAN_PRESUPUESTAL.NATURALEZA ) RESUMENPPTO_P LEFT JOIN ( SELECT V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END ) APROPIADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) MODIFPAC, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONCNT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END ) TRASLADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONPPT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END ) APLAZAMIENTO, SUM(V_SALDO_PLAN_PPTAL.ADICION) ADICION, SUM(V_SALDO_PLAN_PPTAL.REDUCCION) REDUCCION, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END ) + SUM(V_SALDO_PLAN_PPTAL.ADICION) + SUM(V_SALDO_PLAN_PPTAL.REDUCCION) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END ) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END ) APRDEFINITIVA, SUM(V_SALDO_PLAN_PPTAL.DISPONIBILIDAD) DISPONIBILIDAD, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) REG_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) REG_NO_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_REVERSION) REG_REVERSION, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAANTERIOR) VIGENCIAANTERIOR, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAFUTURA) VIGENCIAFUTURA, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) PAC_APROPIADO, SUM(V_SALDO_PLAN_PPTAL.PAC_PROGRAMADO) PAC_PROGRAMADO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) MODIF_REG_CONT, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) MODIF_REG_NOCONT, SUM(V_SALDO_PLAN_PPTAL.REINTEGRO) REINTEGRO, V_PLAN_PRESUPUESTAL.NATURALEZA, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) REGNOCONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) REGCONT, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) PACTOTAL, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) REO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) MODIFREO, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) TOTALREO, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALMODIFINGRESOS, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALINGRESOS, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) INGRESOSCAUSADOS, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) MODIFICACIONICA, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) TOTALICA, SUM(V_SALDO_PLAN_PPTAL.PAC_EJECUTADO) PACEJECUTADOA, SUM(V_SALDO_PLAN_PPTAL.EJE_PPT_DEBITO) SUMADEEJE_PPT_DEBITO FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt; :MESINICIAL GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, V_PLAN_PRESUPUESTAL.NATURALEZA ) RESUMENPPTO_A ON RESUMENPPTO_P.COMPANIA = RESUMENPPTO_A.COMPANIA AND RESUMENPPTO_P.ANO = RESUMENPPTO_A.ANO AND RESUMENPPTO_P.ID = RESUMENPPTO_A.ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APRDEFINITIVA":"$APRDEFINITIVA","ADICION":"$ADICION","REDUCCION":"$REDUCCION","TRASLADO":"$TRASLADO","APRDEFINITIVACAMPO":"$APRDEFINITIVACAMPO","APLAZAMIENTO":"$APLAZAMIENTO","APROPIACIONVIGENTE":"$APROPIACIONVIGENTE","REINTEGROSACUM":"$REINTEGROSACUM","DISPONIBLEACUMULADO":"$DISPONIBLEACUMULADO","PACTOTALA":"$PACTOTALA","PAC_APROPIADOP":"$PAC_APROPIADOP","MODIFPACP":"$MODIFPACP","PACTOTALP":"$PACTOTALP","PACTOTALF":"$PACTOTALF","SALDOPACACUMULADO":"$SALDOPACACUMULADO","PACPROGRAMADOF":"$PACPROGRAMADOF","SALDOPACXINCORPORAR":"$SALDOPACXINCORPORAR","DISPONIBILIDADA":"$DISPONIBILIDADA","DISPONIBILIDADP":"$DISPONIBILIDADP","DISPONIBILIDADF":"$DISPONIBILIDADF","PORUTILIZACION":"$PORUTILIZACION","SALDODISPONIBLE":"$SALDODISPONIBLE","DISPXREG":"$DISPXREG","REGISTROSA":"$REGISTROSA","REGISTROSP":"$REGISTROSP","REGISTROSF":"$REGISTROSF","REGXPAGAR":"$REGXPAGAR","REOA":"$REOA","REOP":"$REOP","REOF":"$REOF","PORPAGAR":"$PORPAGAR","PAGOSA":"$PAGOSA","PAGOSP":"$PAGOSP","PAGOSF":"$PAGOSF","PACEJECUTADOA":"$PACEJECUTADOA","PACEJECUTADO_P":"$PACEJECUTADO_P","PACEJECUTADOF":"$PACEJECUTADOF"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistasaldosplanespptal/resumenppto">
		<call-query href="getVistasaldosplanespptalResumenpptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MESINICIAL" query-param="MESINICIAL"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getVistasaldosplanespptalConsultarApropiacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APROPIACION_DEBITO -APROPIACION_CREDITO ELSE APROPIACION_CREDITO-APROPIACION_DEBITO END)) APROPIADO,TO_CHAR( SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APROPIACION_DEBITO -APROPIACION_CREDITO ELSE APROPIACION_CREDITO-APROPIACION_DEBITO END) +SUM(V_SALDO_PLAN_PPTAL.ADICION)+SUM(V_SALDO_PLAN_PPTAL.REDUCCION)+SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APLAZAM_DEBITO -APLAZAM_CREDITO ELSE APLAZAM_CREDITO-APLAZAM_DEBITO END) +SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN TRASLADO_DEBITO -TRASLADO_CREDITO ELSE TRASLADO_CREDITO-TRASLADO_DEBITO END)) APRDEFINITIVA,TO_CHAR(SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END)) APLAZAMIENTO FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt; :MES GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA , V_SALDO_PLAN_PPTAL.ANO , V_SALDO_PLAN_PPTAL.ID , V_PLAN_PRESUPUESTAL.NATURALEZA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APROPIADO":"$APROPIADO","APRDEFINITIVA":"$APRDEFINITIVA","APLAZAMIENTO":"$APLAZAMIENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistasaldosplanespptal/consultarapropiacion">
		<call-query href="getVistasaldosplanespptalConsultarApropiacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getVistasaldosplanespptalSaldodisponiblerubroauxiliaresQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(RESUMENPPTO_A.APRDEFINITIVA + RESUMENPPTO_P.ADICION + RESUMENPPTO_P.REDUCCION + RESUMENPPTO_P.TRASLADO + RESUMENPPTO_P.APLAZAMIENTO ) SALDODISPONIBLE FROM ( SELECT V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END ) APROPIADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) MODIFPAC, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONCNT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END ) TRASLADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONPPT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END ) APLAZAMIENTO, SUM(V_SALDO_PLAN_PPTAL.ADICION) ADICION, SUM(V_SALDO_PLAN_PPTAL.REDUCCION) REDUCCION, SUM(V_SALDO_PLAN_PPTAL.DISPONIBILIDAD) DISPONIBILIDAD, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) REG_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) REG_NO_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_REVERSION) REG_REVERSION, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAANTERIOR) VIGENCIAANTERIOR, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAFUTURA) VIGENCIAFUTURA, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) PAC_APROPIADO, SUM(V_SALDO_PLAN_PPTAL.PAC_PROGRAMADO) PAC_PROGRAMADO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) MODIF_REG_CONT, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) MODIF_REG_NOCONT, SUM(V_SALDO_PLAN_PPTAL.REINTEGRO) REINTEGRO, V_PLAN_PRESUPUESTAL.NATURALEZA, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) REGNOCONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) REGCONT, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) PACTOTAL, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) REO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) MODIFREO, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) TOTALREO, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALMODIFINGRESOS, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALINGRESOS, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) INGRESOSCAUSADOS, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) MODIFICACIONICA, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) TOTALICA, SUM(V_SALDO_PLAN_PPTAL.PAC_EJECUTADO) PACEJECUTADO_P FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA =:COMPANIA AND V_SALDO_PLAN_PPTAL.ANO =:ANO AND V_SALDO_PLAN_PPTAL.CODIGO =:CODIGO AND V_SALDO_PLAN_PPTAL.FUENTE_RECURSO =:FUENTE AND V_SALDO_PLAN_PPTAL.CENTRO_COSTO =:CENTRO_COSTO AND V_SALDO_PLAN_PPTAL.REFERENCIA =:REFERENCIA AND V_SALDO_PLAN_PPTAL.MES BETWEEN :MESINICIAL AND :MESFINAL GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, V_PLAN_PRESUPUESTAL.NATURALEZA ) RESUMENPPTO_P LEFT JOIN ( SELECT V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END ) APROPIADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) MODIFPAC, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONCNT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END ) TRASLADO, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONPPT, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END ) APLAZAMIENTO, SUM(V_SALDO_PLAN_PPTAL.ADICION) ADICION, SUM(V_SALDO_PLAN_PPTAL.REDUCCION) REDUCCION, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END ) + SUM(V_SALDO_PLAN_PPTAL.ADICION) + SUM(V_SALDO_PLAN_PPTAL.REDUCCION) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END ) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END ) APRDEFINITIVA, SUM(V_SALDO_PLAN_PPTAL.DISPONIBILIDAD) DISPONIBILIDAD, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) REG_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) REG_NO_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_REVERSION) REG_REVERSION, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAANTERIOR) VIGENCIAANTERIOR, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAFUTURA) VIGENCIAFUTURA, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) PAC_APROPIADO, SUM(V_SALDO_PLAN_PPTAL.PAC_PROGRAMADO) PAC_PROGRAMADO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) MODIF_REG_CONT, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) MODIF_REG_NOCONT, SUM(V_SALDO_PLAN_PPTAL.REINTEGRO) REINTEGRO, V_PLAN_PRESUPUESTAL.NATURALEZA, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) REGNOCONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) REGCONT, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) + SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END ) PACTOTAL, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) REO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) MODIFREO, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) + SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) TOTALREO, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALMODIFINGRESOS, SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALINGRESOS, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) INGRESOSCAUSADOS, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) MODIFICACIONICA, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) + SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) TOTALICA, SUM(V_SALDO_PLAN_PPTAL.PAC_EJECUTADO) PACEJECUTADOA, SUM(V_SALDO_PLAN_PPTAL.EJE_PPT_DEBITO) SUMADEEJE_PPT_DEBITO FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA =:COMPANIA AND V_SALDO_PLAN_PPTAL.ANO =:ANO AND V_SALDO_PLAN_PPTAL.CODIGO =:CODIGO AND V_SALDO_PLAN_PPTAL.FUENTE_RECURSO =:FUENTE AND V_SALDO_PLAN_PPTAL.CENTRO_COSTO =:CENTRO_COSTO AND V_SALDO_PLAN_PPTAL.REFERENCIA =:REFERENCIA AND V_SALDO_PLAN_PPTAL.MES &lt;:MESINICIAL GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, V_PLAN_PRESUPUESTAL.NATURALEZA ) RESUMENPPTO_A ON RESUMENPPTO_P.COMPANIA = RESUMENPPTO_A.COMPANIA AND RESUMENPPTO_P.ANO = RESUMENPPTO_A.ANO AND RESUMENPPTO_P.ID = RESUMENPPTO_A.ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALDODISPONIBLE":"$SALDODISPONIBLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
