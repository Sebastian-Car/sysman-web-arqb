<data name="vistasaldosplanespptal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVistasaldosplanespptalPacPorAnoCodigoSinmes13Query"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NVL(SUM(PAC_APROPIADO),0), '99,999,999,999,999,990.90') PAC_APROPIADO, TO_CHAR(NVL(SUM(PAC_PROGRAMADO),0), '99,999,999,999,999,990.90') PAC_PROGRAMADO, TO_CHAR(NVL(SUM(( CASE WHEN :NATURALEZA IN('D') THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END)),0), '99,999,999,999,999,990.90') MODIFICACIONESPAC  FROM V_SALDO_PLAN_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND ID = :CODIGO AND MES NOT IN (13) ORDER BY MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAC_APROPIADO":"$PAC_APROPIADO","PAC_PROGRAMADO":"$PAC_PROGRAMADO","MODIFICACIONESPAC":"$MODIFICACIONESPAC"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistasaldosplanespptal/pacporanocodigosinmes13">
		<call-query href="getVistasaldosplanespptalPacPorAnoCodigoSinmes13Query">
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getVistasaldosplanespptalPagPorAnoCodigoSinMes13Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, CODIGO, MES, PAC_APROPIADO, PAC_PROGRAMADO, DECODE(MES,0,'VIGENCIA ANTERIOR', 1,'ENERO', 2,'FEBRERO', 3,'MARZO', 4,'ABRIL', 5,'MAYO', 6,'JUNIO', 7,'JULIO', 8,'AGOSTO', 9,'SEPTIEMBRE', 10,'OCTUBRE', 11,'NOVIEMBRE', 12,'DICIEMBRE') nombreMES, CASE WHEN :NATURALEZA IN('D') THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END MODIFICACIONESPAC  FROM V_SALDO_PLAN_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND ID = :CODIGO AND MES NOT IN(13) ORDER BY MES) WHERE (CASE WHEN PAC_APROPIADO IS NULL THEN ' ' ELSE UPPER(PAC_APROPIADO) END)  LIKE UPPER(:PAC_APROPIADO || '%')  AND (CASE WHEN PAC_PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PAC_PROGRAMADO) END)  LIKE UPPER(:PAC_PROGRAMADO || '%')  AND (CASE WHEN NOMBREMES IS NULL THEN ' ' ELSE UPPER(NOMBREMES) END)  LIKE UPPER( '%' || :NOMBREMES || '%')  AND (CASE WHEN MODIFICACIONESPAC IS NULL THEN ' ' ELSE UPPER(MODIFICACIONESPAC) END)  LIKE UPPER(:MODIFICACIONESPAC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","MES":"$MES(type:integer)","PAC_APROPIADO":"$PAC_APROPIADO","PAC_PROGRAMADO":"$PAC_PROGRAMADO","NOMBREMES":"$NOMBREMES","MODIFICACIONESPAC":"$MODIFICACIONESPAC"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAC_APROPIADO" sqlType="STRING"/>
		<param name="PAC_PROGRAMADO" sqlType="STRING"/>
		<param name="NOMBREMES" sqlType="STRING"/>
		<param name="MODIFICACIONESPAC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistasaldosplanespptal/poranocodigosinmes13/pag">
		<call-query href="getVistasaldosplanespptalPagPorAnoCodigoSinMes13Query">
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAC_APROPIADO" query-param="PAC_APROPIADO"/>
			<with-param name="PAC_PROGRAMADO" query-param="PAC_PROGRAMADO"/>
			<with-param name="NOMBREMES" query-param="NOMBREMES"/>
			<with-param name="MODIFICACIONESPAC" query-param="MODIFICACIONESPAC"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistasaldosplanespptalNumPorAnoCodigoSinMes13Query"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO, CODIGO, MES, PAC_APROPIADO, PAC_PROGRAMADO, DECODE(MES,0,'VIGENCIA ANTERIOR', 1,'ENERO', 2,'FEBRERO', 3,'MARZO', 4,'ABRIL', 5,'MAYO', 6,'JUNIO', 7,'JULIO', 8,'AGOSTO', 9,'SEPTIEMBRE', 10,'OCTUBRE', 11,'NOVIEMBRE', 12,'DICIEMBRE') nombreMES, CASE WHEN :NATURALEZA IN('D') THEN MODIF_PAC_DEBITO - MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO - MODIF_PAC_DEBITO END MODIFICACIONESPAC  FROM V_SALDO_PLAN_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND ID = :CODIGO AND MES NOT IN(13) ORDER BY MES) WHERE (CASE WHEN PAC_APROPIADO IS NULL THEN ' ' ELSE UPPER(PAC_APROPIADO) END)  LIKE UPPER(:PAC_APROPIADO || '%')  AND (CASE WHEN PAC_PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PAC_PROGRAMADO) END)  LIKE UPPER( '%' || :PAC_PROGRAMADO || '%')  AND (CASE WHEN NOMBREMES IS NULL THEN ' ' ELSE UPPER(NOMBREMES) END)  LIKE UPPER( '%' || :NOMBREMES || '%')  AND (CASE WHEN MODIFICACIONESPAC IS NULL THEN ' ' ELSE UPPER(MODIFICACIONESPAC) END)  LIKE UPPER( '%' || :MODIFICACIONESPAC || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAC_APROPIADO" sqlType="STRING"/>
		<param name="PAC_PROGRAMADO" sqlType="STRING"/>
		<param name="NOMBREMES" sqlType="STRING"/>
		<param name="MODIFICACIONESPAC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistasaldosplanespptal/poranocodigosinmes13/num">
		<call-query href="getVistasaldosplanespptalNumPorAnoCodigoSinMes13Query">
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAC_APROPIADO" query-param="PAC_APROPIADO"/>
			<with-param name="PAC_PROGRAMADO" query-param="PAC_PROGRAMADO"/>
			<with-param name="NOMBREMES" query-param="NOMBREMES"/>
			<with-param name="MODIFICACIONESPAC" query-param="MODIFICACIONESPAC"/>

		</call-query>
	</resource>
	<query id="getVistasaldosplanespptalResumenPptoIngresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  RESUMENPPTO_A.APRDEFINITIVA, RESUMENPPTO_P.ADICION, RESUMENPPTO_P.REDUCCION, RESUMENPPTO_P.TRASLADO, RESUMENPPTO_A.APRDEFINITIVA+RESUMENPPTO_P.ADICION+RESUMENPPTO_P.REDUCCION+RESUMENPPTO_P.TRASLADO APRDEFINITIVACAMPO, RESUMENPPTO_P.APLAZAMIENTO, RESUMENPPTO_A.APRDEFINITIVA+RESUMENPPTO_P.ADICION+RESUMENPPTO_P.REDUCCION+RESUMENPPTO_P.TRASLADO+RESUMENPPTO_P.APLAZAMIENTO APROPIACIONVIGENTE, RESUMENPPTO_A.TOTALINGRESOS INGRESOSA, RESUMENPPTO_P.TOTALINGRESOS INGRESOSP, RESUMENPPTO_P.TOTALINGRESOS+RESUMENPPTO_A.TOTALINGRESOS INGRESOSF, RESUMENPPTO_P.EJECUCIONCNT+RESUMENPPTO_A.EJECUCIONCNT EJECUCIONCNTF, (RESUMENPPTO_P.TOTALINGRESOS+RESUMENPPTO_A.TOTALINGRESOS)+(RESUMENPPTO_P.EJECUCIONCNT+RESUMENPPTO_A.EJECUCIONCNT) TOTALRECAUDADO, (RESUMENPPTO_A.APRDEFINITIVA+RESUMENPPTO_P.ADICION+RESUMENPPTO_P.REDUCCION+RESUMENPPTO_P.TRASLADO)-(RESUMENPPTO_P.TOTALINGRESOS+RESUMENPPTO_A.TOTALINGRESOS)+(RESUMENPPTO_P.EJECUCIONCNT+RESUMENPPTO_A.EJECUCIONCNT) SALDOPOREJECUTAR, RESUMENPPTO_A.PACTOTAL PACTOTALA, RESUMENPPTO_P.PACTOTAL PACTOTALP, RESUMENPPTO_A.PACTOTAL+RESUMENPPTO_P.PACTOTAL PACTOTALF, (CASE WHEN (RESUMENPPTO_A.APRDEFINITIVA+RESUMENPPTO_P.ADICION+RESUMENPPTO_P.REDUCCION+RESUMENPPTO_P.TRASLADO) &lt;&gt; 0 THEN (RESUMENPPTO_A.PACTOTAL+RESUMENPPTO_P.PACTOTAL)/(RESUMENPPTO_A.APRDEFINITIVA+RESUMENPPTO_P.ADICION+RESUMENPPTO_P.REDUCCION+RESUMENPPTO_P.TRASLADO) ELSE 0 END)*100 PORCAPROPIADO, (RESUMENPPTO_A.APRDEFINITIVA+RESUMENPPTO_P.ADICION+RESUMENPPTO_P.REDUCCION+RESUMENPPTO_P.TRASLADO)-(RESUMENPPTO_A.PACTOTAL+RESUMENPPTO_P.PACTOTAL) REZAGO, (RESUMENPPTO_A.APRDEFINITIVA+RESUMENPPTO_P.ADICION+RESUMENPPTO_P.REDUCCION+RESUMENPPTO_P.TRASLADO)-(RESUMENPPTO_P.TOTALINGRESOS+RESUMENPPTO_A.TOTALINGRESOS)+(RESUMENPPTO_P.EJECUCIONCNT+RESUMENPPTO_A.EJECUCIONCNT) PACPROGXEJEC, RESUMENPPTO_A.INGRESOSCAUSADOS INGRESOSCAUSADOSA, RESUMENPPTO_P.INGRESOSCAUSADOS INGRESOSCAUSADOSP, RESUMENPPTO_P.INGRESOSCAUSADOS+RESUMENPPTO_A.INGRESOSCAUSADOS INGRESOSCAUSADOSF, RESUMENPPTO_A.MODIFICACIONICA MODIFICACIONICAA, RESUMENPPTO_P.MODIFICACIONICA MODIFICACIONICAP, RESUMENPPTO_P.MODIFICACIONICA+RESUMENPPTO_A.MODIFICACIONICA MODIFICACIONICAF, ((RESUMENPPTO_P.INGRESOSCAUSADOS )+(RESUMENPPTO_A.INGRESOSCAUSADOS))+((RESUMENPPTO_P.MODIFICACIONICA)+(RESUMENPPTO_A.MODIFICACIONICA)) TOTALICAF  FROM (SELECT V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APROPIACION_DEBITO-APROPIACION_CREDITO ELSE APROPIACION_CREDITO-APROPIACION_DEBITO END) APROPIADO, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN MODIF_PAC_DEBITO-MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO-MODIF_PAC_DEBITO END) MODIFPAC, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN EJE_CNT_DEBITO-EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO-EJE_CNT_DEBITO END) EJECUCIONCNT, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN TRASLADO_DEBITO-TRASLADO_CREDITO ELSE TRASLADO_CREDITO-TRASLADO_DEBITO END) TRASLADO, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN EJE_PPT_DEBITO-EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO-EJE_PPT_DEBITO END) EJECUCIONPPT, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APLAZAM_DEBITO-APLAZAM_CREDITO ELSE APLAZAM_CREDITO-APLAZAM_DEBITO END) APLAZAMIENTO, SUM(V_SALDO_PLAN_PPTAL.ADICION) ADICION, SUM(V_SALDO_PLAN_PPTAL.REDUCCION) REDUCCION, SUM(V_SALDO_PLAN_PPTAL.DISPONIBILIDAD) DISPONIBILIDAD, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) REG_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) REG_NO_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_REVERSION) REG_REVERSION, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAANTERIOR) VIGENCIAANTERIOR, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAFUTURA) VIGENCIAFUTURA, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) PAC_APROPIADO, SUM(V_SALDO_PLAN_PPTAL.PAC_PROGRAMADO) PAC_PROGRAMADO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) MODIF_REG_CONT, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) MODIF_REG_NOCONT, SUM(V_SALDO_PLAN_PPTAL.REINTEGRO) REINTEGRO, V_PLAN_PRESUPUESTAL.NATURALEZA, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT)+SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) REGNOCONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT)+SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) REGCONT, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) + SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN MODIF_PAC_DEBITO-MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO-MODIF_PAC_DEBITO END) PACTOTAL, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) REO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) MODIFREO, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION)+SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) TOTALREO, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALMODIFINGRESOS, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN EJE_PPT_DEBITO-EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO-EJE_PPT_DEBITO END)+SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALINGRESOS, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) INGRESOSCAUSADOS, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) MODIFICACIONICA, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS)+SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) TOTALICA, SUM(V_SALDO_PLAN_PPTAL.PAC_EJECUTADO) PACEJECUTADO_P FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID= :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN :MESINICIAL AND :MESFINAL GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, V_PLAN_PRESUPUESTAL.NATURALEZA)RESUMENPPTO_P LEFT JOIN (SELECT V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APROPIACION_DEBITO-APROPIACION_CREDITO ELSE APROPIACION_CREDITO-APROPIACION_DEBITO END) APROPIADO, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN MODIF_PAC_DEBITO-MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO-MODIF_PAC_DEBITO END) MODIFPAC, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN EJE_CNT_DEBITO-EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO-EJE_CNT_DEBITO END) EJECUCIONCNT, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN TRASLADO_DEBITO-TRASLADO_CREDITO ELSE TRASLADO_CREDITO-TRASLADO_DEBITO END) TRASLADO, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN EJE_PPT_DEBITO-EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO-EJE_PPT_DEBITO END) EJECUCIONPPT, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APLAZAM_DEBITO-APLAZAM_CREDITO ELSE APLAZAM_CREDITO-APLAZAM_DEBITO END) APLAZAMIENTO, SUM(V_SALDO_PLAN_PPTAL.ADICION) ADICION, SUM(V_SALDO_PLAN_PPTAL.REDUCCION) REDUCCION, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APROPIACION_DEBITO-APROPIACION_CREDITO ELSE APROPIACION_CREDITO-APROPIACION_DEBITO END)+SUM(V_SALDO_PLAN_PPTAL.ADICION)+SUM(V_SALDO_PLAN_PPTAL.REDUCCION)+SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APLAZAM_DEBITO-APLAZAM_CREDITO ELSE APLAZAM_CREDITO-APLAZAM_DEBITO END)+SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN TRASLADO_DEBITO-TRASLADO_CREDITO ELSE TRASLADO_CREDITO-TRASLADO_DEBITO END) APRDEFINITIVA, SUM(V_SALDO_PLAN_PPTAL.DISPONIBILIDAD) DISPONIBILIDAD, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT) REG_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT) REG_NO_CONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_REVERSION) REG_REVERSION, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAANTERIOR) VIGENCIAANTERIOR, SUM(V_SALDO_PLAN_PPTAL.VIGENCIAFUTURA) VIGENCIAFUTURA, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO) PAC_APROPIADO, SUM(V_SALDO_PLAN_PPTAL.PAC_PROGRAMADO) PAC_PROGRAMADO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) MODIF_REG_CONT, SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) MODIF_REG_NOCONT, SUM(V_SALDO_PLAN_PPTAL.REINTEGRO) REINTEGRO, V_PLAN_PRESUPUESTAL.NATURALEZA, SUM(V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT)+SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT) REGNOCONTRACT, SUM(V_SALDO_PLAN_PPTAL.REG_CONTRACT)+SUM(V_SALDO_PLAN_PPTAL.MODIF_REG_CONT) REGCONT, SUM(V_SALDO_PLAN_PPTAL.PAC_APROPIADO)+SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN MODIF_PAC_DEBITO-MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO-MODIF_PAC_DEBITO END) PACTOTAL, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION) REO, SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) MODIFREO, SUM(V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION)+SUM(V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION) TOTALREO, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALMODIFINGRESOS, SUM(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN EJE_PPT_DEBITO-EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO-EJE_PPT_DEBITO END)+SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS) TOTALINGRESOS, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS) INGRESOSCAUSADOS, SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) MODIFICACIONICA, SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS)+SUM(V_SALDO_PLAN_PPTAL.MODIF_INGRESOS_CAUSADOS) TOTALICA, SUM(V_SALDO_PLAN_PPTAL.PAC_EJECUTADO) PACEJECUTADOA, SUM(V_SALDO_PLAN_PPTAL.EJE_PPT_DEBITO) SUMADEEJE_PPT_DEBITO FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID= :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt; :MESINICIAL GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, V_PLAN_PRESUPUESTAL.NATURALEZA)RESUMENPPTO_A ON RESUMENPPTO_P.COMPANIA = RESUMENPPTO_A.COMPANIA AND RESUMENPPTO_P.ANO = RESUMENPPTO_A.ANO AND RESUMENPPTO_P.ID = RESUMENPPTO_A.ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APRDEFINITIVA":"$APRDEFINITIVA","ADICION":"$ADICION","REDUCCION":"$REDUCCION","TRASLADO":"$TRASLADO","APRDEFINITIVACAMPO":"$APRDEFINITIVACAMPO","APLAZAMIENTO":"$APLAZAMIENTO","APROPIACIONVIGENTE":"$APROPIACIONVIGENTE","INGRESOSA":"$INGRESOSA","INGRESOSP":"$INGRESOSP","INGRESOSF":"$INGRESOSF","EJECUCIONCNTF":"$EJECUCIONCNTF","TOTALRECAUDADO":"$TOTALRECAUDADO","SALDOPOREJECUTAR":"$SALDOPOREJECUTAR","PACTOTALA":"$PACTOTALA","PACTOTALP":"$PACTOTALP","PACTOTALF":"$PACTOTALF","PORCAPROPIADO":"$PORCAPROPIADO","REZAGO":"$REZAGO","PACPROGXEJEC":"$PACPROGXEJEC","INGRESOSCAUSADOSA":"$INGRESOSCAUSADOSA","INGRESOSCAUSADOSP":"$INGRESOSCAUSADOSP","INGRESOSCAUSADOSF":"$INGRESOSCAUSADOSF","MODIFICACIONICAA":"$MODIFICACIONICAA","MODIFICACIONICAP":"$MODIFICACIONICAP","MODIFICACIONICAF":"$MODIFICACIONICAF","TOTALICAF":"$TOTALICAF"}]}}		</result>
