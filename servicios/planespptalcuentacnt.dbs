			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanespptalcuentacntNumCuentasPptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.RECONOCIMIENTO, PLAN_PPTAL_CUENTACNT.AUXILIAR, PLAN_PPTAL_CUENTACNT.CENTRO_COSTO, PLAN_PPTAL_CUENTACNT.FUENTE_RECURSO, PLAN_PPTAL_CUENTACNT.REFERENCIA FROM PLAN_PPTAL_CUENTACNT INNER JOIN PLAN_PRESUPUESTAL ON PLAN_PRESUPUESTAL.COMPANIA = PLAN_PPTAL_CUENTACNT.COMPANIA AND PLAN_PRESUPUESTAL.ANO = PLAN_PPTAL_CUENTACNT.ANO AND PLAN_PRESUPUESTAL.CODIGO = PLAN_PPTAL_CUENTACNT.RUBRO WHERE PLAN_PPTAL_CUENTACNT.COMPANIA= :COMPANIA AND PLAN_PPTAL_CUENTACNT.ANO = :ANO AND PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE = :CUENTA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN RECONOCIMIENTO IS NULL THEN ' ' ELSE UPPER(RECONOCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:RECONOCIMIENTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RECONOCIMIENTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>

	</query>
