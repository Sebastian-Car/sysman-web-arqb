<data name="planespptalcuentacnt" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPlanespptalcuentacntPagCuentasPptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_PRESUPUESTAL.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.RECONOCIMIENTO, PLAN_PPTAL_CUENTACNT.AUXILIAR, PLAN_PPTAL_CUENTACNT.CENTRO_COSTO, PLAN_PPTAL_CUENTACNT.FUENTE_RECURSO, PLAN_PPTAL_CUENTACNT.REFERENCIA FROM PLAN_PPTAL_CUENTACNT INNER JOIN PLAN_PRESUPUESTAL ON PLAN_PRESUPUESTAL.COMPANIA = PLAN_PPTAL_CUENTACNT.COMPANIA AND PLAN_PRESUPUESTAL.ANO = PLAN_PPTAL_CUENTACNT.ANO AND PLAN_PRESUPUESTAL.CODIGO = PLAN_PPTAL_CUENTACNT.RUBRO WHERE PLAN_PPTAL_CUENTACNT.COMPANIA= :COMPANIA AND PLAN_PPTAL_CUENTACNT.ANO = :ANO AND PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE = :CUENTA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN RECONOCIMIENTO IS NULL THEN ' ' ELSE UPPER(RECONOCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:RECONOCIMIENTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","RECONOCIMIENTO":"$RECONOCIMIENTO","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","FUENTE_RECURSO":"$FUENTE_RECURSO","REFERENCIA":"$REFERENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RECONOCIMIENTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planespptalcuentacnt/cuentaspptal/pag">
		<call-query href="getPlanespptalcuentacntPagCuentasPptalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
