	<query id="getPlanespptalcuentacntPorplancontableQuery"  useConfig="sysmandsunist">
		<sql>SELECT PLAN_PPTAL_CUENTACNT.COMPANIA, PLAN_PPTAL_CUENTACNT.ANO, PLAN_PPTAL_CUENTACNT.AUXILIAR, PLAN_PPTAL_CUENTACNT.REFERENCIA, PLAN_PPTAL_CUENTACNT.FUENTE_RECURSO, PLAN_PPTAL_CUENTACNT.CENTRO_COSTO, PLAN_PPTAL_CUENTACNT.RUBRO, PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE FROM PLAN_PPTAL_CUENTACNT WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CUENTA_CONTABLE = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","CENTRO_COSTO":"$CENTRO_COSTO","RUBRO":"$RUBRO","CUENTA_CONTABLE":"$CUENTA_CONTABLE"}]}}		</result>
