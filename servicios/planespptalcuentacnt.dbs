	<query id="getPlanespptalcuentacntEquivalenciaContableQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PLAN_PPTAL_CUENTACNT.ANO, PLAN_PPTAL_CUENTACNT.COMPANIA, PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE, PLAN_PPTAL_CUENTACNT.RUBRO, PLAN_CONTABLE.NOMBRE, PLAN_PPTAL_CUENTACNT.CREATED_BY,(TO_CHAR(PLAN_PPTAL_CUENTACNT.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(PLAN_PPTAL_CUENTACNT.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, PLAN_PPTAL_CUENTACNT.MODIFIED_BY  FROM PLAN_PPTAL_CUENTACNT INNER JOIN PLAN_CONTABLE ON PLAN_PPTAL_CUENTACNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND PLAN_PPTAL_CUENTACNT.ANO = PLAN_CONTABLE.ANO AND PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE = PLAN_CONTABLE.CODIGO WHERE PLAN_PPTAL_CUENTACNT.COMPANIA = :COMPANIA AND PLAN_PPTAL_CUENTACNT.ANO = :ANO AND PLAN_PPTAL_CUENTACNT.RUBRO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","COMPANIA":"$COMPANIA","CUENTA_CONTABLE":"$CUENTA_CONTABLE","RUBRO":"$RUBRO","NOMBRE":"$NOMBRE","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
