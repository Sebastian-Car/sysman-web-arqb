	<query id="updatePlanespptalcuentacnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CUENTACNT SET AUXILIAR=:AUXILIAR, REFERENCIA=:REFERENCIA, FUENTE_RECURSO=:FUENTE_RECURSO, CENTRO_COSTO=:CENTRO_COSTO, RUBRO=:RUBRO, CUENTA_CONTABLE=:CUENTA_CONTABLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PPTAL_CUENTACNT.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CUENTACNT.ANO= :KEY_ANO AND PLAN_PPTAL_CUENTACNT.RUBRO= :KEY_RUBRO AND PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE= :KEY_CUENTA_CONTABLE</sql>
