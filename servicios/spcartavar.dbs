<data name="spcartavar" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpcartavarCartasPorDesviacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_CARTA_VAR.CODIGO, SP_CARTA_VAR.PREGUNTA  FROM SP_CARTA_VAR WHERE SP_CARTA_VAR.COMPANIA = :COMPANIA AND SP_CARTA_VAR.CLASE = :CLASE AND SP_CARTA_VAR.SUBCLASE = :SUBCLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","PREGUNTA":"$PREGUNTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="SUBCLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spcartavar/cartaspordesviacion">
		<call-query href="getSpcartavarCartasPorDesviacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="SUBCLASE" query-param="SUBCLASE"/>

		</call-query>
	</resource>

</data>