<data name="ta_detalle_conceptos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTa_detalle_conceptosConsultagrillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT TA_DETALLE_CONCEPTOS.COMPANIA, TA_DETALLE_CONCEPTOS.ANO, TA_DETALLE_CONCEPTOS.CODIGO, TA_DETALLE_CONCEPTOS.TIPORETENCION, TA_DETALLE_CONCEPTOS.CODIGORETENCION, RETENCIONES.NOMBRE NOMBRE_RETENCION, TA_DETALLE_CONCEPTOS.MODIFIED_BY,(TO_CHAR(TA_DETALLE_CONCEPTOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM TA_DETALLE_CONCEPTOS INNER JOIN RETENCIONES ON TA_DETALLE_CONCEPTOS.TIPORETENCION = RETENCIONES.TIPO AND TA_DETALLE_CONCEPTOS.COMPANIA = RETENCIONES.COMPANIA AND TA_DETALLE_CONCEPTOS.ANO = RETENCIONES.ANO AND TA_DETALLE_CONCEPTOS.CODIGORETENCION = RETENCIONES.CODIGO WHERE TA_DETALLE_CONCEPTOS.COMPANIA = :COMPANIA AND TA_DETALLE_CONCEPTOS.ANO = :ANO AND TA_DETALLE_CONCEPTOS.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","TIPORETENCION":"$TIPORETENCION","CODIGORETENCION":"$CODIGORETENCION","NOMBRE_RETENCION":"$NOMBRE_RETENCION","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ta_detalle_conceptos/consultagrilla">
		<call-query href="getTa_detalle_conceptosConsultagrillaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertTa_detalle_conceptosPrepararanio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql> INSERT INTO TA_DETALLE_CONCEPTOS ( COMPANIA, ANO, CODIGO, TIPORETENCION, CODIGORETENCION, CREATED_BY, DATE_CREATED ) SELECT COMPANIA, :ANOPREPARAR, CODIGO, TIPORETENCION, CODIGORETENCION, CREATED_BY, TO_DATE(:DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS') FROM TA_DETALLE_CONCEPTOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO= :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANOPREPARAR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ta_detalle_conceptos/prepararanio">
		<call-query href="insertTa_detalle_conceptosPrepararanio">
			<with-param name="ANOPREPARAR" query-param="ANOPREPARAR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertTa_detalle_conceptos" keyColumns="COMPANIA,ANO,CODIGO,TIPORETENCION,CODIGORETENCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TA_DETALLE_CONCEPTOS (COMPANIA, ANO, CODIGO, TIPORETENCION, CODIGORETENCION, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ANO, :CODIGO, :TIPORETENCION, :CODIGORETENCION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO","KEY_TIPORETENCION":"$TIPORETENCION","KEY_CODIGORETENCION":"$CODIGORETENCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPORETENCION" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ta_detalle_conceptos">
		<call-query href="insertTa_detalle_conceptos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteTa_detalle_conceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TA_DETALLE_CONCEPTOS WHERE TA_DETALLE_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND TA_DETALLE_CONCEPTOS.ANO= :KEY_ANO AND TA_DETALLE_CONCEPTOS.CODIGO= :KEY_CODIGO AND TA_DETALLE_CONCEPTOS.TIPORETENCION= :KEY_TIPORETENCION AND TA_DETALLE_CONCEPTOS.CODIGORETENCION= :KEY_CODIGORETENCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPORETENCION" sqlType="STRING"/>
		<param name="KEY_CODIGORETENCION" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ta_detalle_conceptos">
		<call-query href="deleteTa_detalle_conceptos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPORETENCION" query-param="KEY_TIPORETENCION"/>
			<with-param name="KEY_CODIGORETENCION" query-param="KEY_CODIGORETENCION"/>

		</call-query>
	</resource>
	<query id="updateTa_detalle_conceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TA_DETALLE_CONCEPTOS SET TIPORETENCION=:TIPORETENCION, CODIGORETENCION=:CODIGORETENCION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE TA_DETALLE_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND TA_DETALLE_CONCEPTOS.ANO= :KEY_ANO AND TA_DETALLE_CONCEPTOS.CODIGO= :KEY_CODIGO AND TA_DETALLE_CONCEPTOS.TIPORETENCION= :KEY_TIPORETENCION AND TA_DETALLE_CONCEPTOS.CODIGORETENCION= :KEY_CODIGORETENCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPORETENCION" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPORETENCION" sqlType="STRING"/>
		<param name="KEY_CODIGORETENCION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ta_detalle_conceptos">
		<call-query href="updateTa_detalle_conceptos">
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPORETENCION" query-param="KEY_TIPORETENCION"/>
			<with-param name="KEY_CODIGORETENCION" query-param="KEY_CODIGORETENCION"/>

		</call-query>
	</resource>

</data>