<data name="cmdetcausautomatica" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertCmdetcausautomatica" keyColumns="COMPANIA,ANO,CODIGO_TRANSACCION,VARIABLE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CM_DET_CAUSACION_AUTOMATICA (COMPANIA, ANO, CODIGO_TRANSACCION, VARIABLE, CUENTA_DEBITO, CUENTA_CREDITO, CENTRO_COSTO, TERCERO, SUCURSAL, AUXILIAR, REFERENCIA, FUENTE_RECURSO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO_TRANSACCION, :VARIABLE, :CUENTA_DEBITO, :CUENTA_CREDITO, :CENTRO_COSTO, :TERCERO, :SUCURSAL, :AUXILIAR, :REFERENCIA, :FUENTE_RECURSO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO_TRANSACCION":"$CODIGO_TRANSACCION","KEY_VARIABLE":"$VARIABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_TRANSACCION" sqlType="STRING"/>
		<param name="VARIABLE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_DEBITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_CREDITO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cmdetcausautomatica">
		<call-query href="insertCmdetcausautomatica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_TRANSACCION" query-param="CODIGO_TRANSACCION"/>
			<with-param name="VARIABLE" query-param="VARIABLE"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteCmdetcausautomatica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CM_DET_CAUSACION_AUTOMATICA WHERE CM_DET_CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CM_DET_CAUSACION_AUTOMATICA.ANO= :KEY_ANO AND CM_DET_CAUSACION_AUTOMATICA.CODIGO_TRANSACCION= :KEY_CODIGO_TRANSACCION AND CM_DET_CAUSACION_AUTOMATICA.VARIABLE= :KEY_VARIABLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_VARIABLE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="cmdetcausautomatica">
		<call-query href="deleteCmdetcausautomatica">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO_TRANSACCION" query-param="KEY_CODIGO_TRANSACCION"/>
			<with-param name="KEY_VARIABLE" query-param="KEY_VARIABLE"/>

		</call-query>
	</resource>
	<query id="getCmdetcausautomaticaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, CODIGO_TRANSACCION, VARIABLE, CUENTA_DEBITO, CUENTA_CREDITO, CENTRO_COSTO, TERCERO, SUCURSAL, AUXILIAR, REFERENCIA, FUENTE_RECURSO, DESCRIPCION FROM CM_DET_CAUSACION_AUTOMATICA WHERE COMPANIA =:COMPANIA AND CODIGO_TRANSACCION =:CODIGO ORDER BY VARIABLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO_TRANSACCION":"$CODIGO_TRANSACCION","VARIABLE":"$VARIABLE","CUENTA_DEBITO":"$CUENTA_DEBITO","CUENTA_CREDITO":"$CUENTA_CREDITO","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmdetcausautomatica">
		<call-query href="getCmdetcausautomaticaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="updateCmdetcausautomatica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_DET_CAUSACION_AUTOMATICA SET ANO=:ANO, VARIABLE=:VARIABLE, CUENTA_DEBITO=:CUENTA_DEBITO, CUENTA_CREDITO=:CUENTA_CREDITO, CENTRO_COSTO=:CENTRO_COSTO, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, AUXILIAR=:AUXILIAR, REFERENCIA=:REFERENCIA, FUENTE_RECURSO=:FUENTE_RECURSO, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CM_DET_CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CM_DET_CAUSACION_AUTOMATICA.ANO= :KEY_ANO AND CM_DET_CAUSACION_AUTOMATICA.CODIGO_TRANSACCION= :KEY_CODIGO_TRANSACCION AND CM_DET_CAUSACION_AUTOMATICA.VARIABLE= :KEY_VARIABLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="VARIABLE" sqlType="STRING"/>
		<param name="CUENTA_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_VARIABLE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmdetcausautomatica">
		<call-query href="updateCmdetcausautomatica">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="VARIABLE" query-param="VARIABLE"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO_TRANSACCION" query-param="KEY_CODIGO_TRANSACCION"/>
			<with-param name="KEY_VARIABLE" query-param="KEY_VARIABLE"/>

		</call-query>
	</resource>

</data>