<data name="planpptalconfig" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPlanpptalconfigNaturalezaycodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SALDO_AUX_PPTAL.COMPANIA, SALDO_AUX_PPTAL.ANO, SALDO_AUX_PPTAL.ID, SALDO_AUX_PPTAL.CODIGO, SALDO_AUX_PPTAL.NOMBRE, SALDO_AUX_PPTAL.CODIGOSCHIP, SALDO_AUX_PPTAL.RECURSOSCHIP, SALDO_AUX_PPTAL.ORIGENESPECIFICOINGRESOS, SALDO_AUX_PPTAL.DESTINACIONDELOSRECURSOS, SALDO_AUX_PPTAL.DEPENDENCIASCHIP, SALDO_AUX_PPTAL.FINALIDADGASTO, CASE WHEN SALDO_AUX_PPTAL.SITUACIONFONDOSSCHIP IN (0) THEN 0 ELSE -1 END SITUACIONFONDOSSCHIP, SALDO_AUX_PPTAL.VIGENCIAGASTO, SALDO_AUX_PPTAL.VIGENCIATESORERIASCHIP, SALDO_AUX_PPTAL.CR1_RESGUARDOSCHIP, SALDO_AUX_PPTAL.CODIGOSIRECI, CASE WHEN SALDO_AUX_PPTAL.RECAUDO_VA IN (0) THEN 0 ELSE -1 END RECAUDO_VA, SALDO_AUX_PPTAL.COD_RECIPROCA  FROM V_PLAN_PRESUPUESTAL SALDO_AUX_PPTAL WHERE SALDO_AUX_PPTAL.COMPANIA = '001' AND SALDO_AUX_PPTAL.ANO = 2012 AND SALDO_AUX_PPTAL.NATURALEZA = 'D' AND SALDO_AUX_PPTAL.MOVIMIENTO NOT IN (0) AND SALDO_AUX_PPTAL.REGALIAS NOT IN ( CASE WHEN 'V' IN ('R') THEN 0 ELSE 1 END) ORDER BY SALDO_AUX_PPTAL.ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGOSCHIP":"$CODIGOSCHIP","RECURSOSCHIP":"$RECURSOSCHIP(type:double)","ORIGENESPECIFICOINGRESOS":"$ORIGENESPECIFICOINGRESOS","DESTINACIONDELOSRECURSOS":"$DESTINACIONDELOSRECURSOS","DEPENDENCIASCHIP":"$DEPENDENCIASCHIP","FINALIDADGASTO":"$FINALIDADGASTO","SITUACIONFONDOSSCHIP":"$SITUACIONFONDOSSCHIP(type:integer)","VIGENCIAGASTO":"$VIGENCIAGASTO(type:double)","VIGENCIATESORERIASCHIP":"$VIGENCIATESORERIASCHIP(type:double)","CR1_RESGUARDOSCHIP":"$CR1_RESGUARDOSCHIP","CODIGOSIRECI":"$CODIGOSIRECI","RECAUDO_VA":"$RECAUDO_VA(type:integer)","COD_RECIPROCA":"$COD_RECIPROCA"}]}}		</result>
 
	</query>
	<resource method="GET" path="planpptalconfig/naturalezaycodigo">
		<call-query href="getPlanpptalconfigNaturalezaycodigoQuery">
 
		</call-query>
	</resource>
	<query id="updatePlanpptalconfigPorcodigoynaturaleza" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CONFIG SET CODIGOSCHIP=:CODIGOSCHIP, RECURSOSCHIP=:RECURSOSCHIP, ORIGENESPECIFICOINGRESOS=:ORIGENESPECIFICOINGRESOS, DESTINACIONDELOSRECURSOS=:DESTINACIONDELOSRECURSOS, DEPENDENCIASCHIP=:DEPENDENCIASCHIP, SITUACIONFONDOSSCHIP=:SITUACIONFONDOSSCHIP, RECAUDO_VA=:RECAUDO_VA, FINALIDADGASTO=:FINALIDADGASTO, VIGENCIAGASTO=:VIGENCIAGASTO, VIGENCIATESORERIASCHIP=:VIGENCIATESORERIASCHIP, CR1_RESGUARDOSCHIP=:CR1_RESGUARDOSCHIP, CODIGOSIRECI=:CODIGOSIRECI, COD_RECIPROCA=:COD_RECIPROCA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PPTAL_CONFIG.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CONFIG.ANO= :KEY_ANO AND PLAN_PPTAL_CONFIG.CODIGO= :KEY_CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO= :KEY_CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO= :KEY_TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL= :KEY_SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR= :KEY_AUXILIAR AND PLAN_PPTAL_CONFIG.REFERENCIA= :KEY_REFERENCIA AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOSCHIP" sqlType="STRING"/>
		<param name="RECURSOSCHIP" sqlType="STRING"/>
		<param name="ORIGENESPECIFICOINGRESOS" sqlType="STRING"/>
		<param name="DESTINACIONDELOSRECURSOS" sqlType="STRING"/>
		<param name="DEPENDENCIASCHIP" sqlType="STRING"/>
		<param name="SITUACIONFONDOSSCHIP" sqlType="STRING"/>
		<param name="RECAUDO_VA" sqlType="STRING"/>
		<param name="FINALIDADGASTO" sqlType="STRING"/>
		<param name="VIGENCIAGASTO" sqlType="STRING"/>
		<param name="VIGENCIATESORERIASCHIP" sqlType="STRING"/>
		<param name="CR1_RESGUARDOSCHIP" sqlType="STRING"/>
		<param name="CODIGOSIRECI" sqlType="STRING"/>
		<param name="COD_RECIPROCA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_AUXILIAR" sqlType="STRING"/>
		<param name="KEY_REFERENCIA" sqlType="STRING"/>
		<param name="KEY_FUENTE_RECURSO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planpptalconfig/porcodigoynaturaleza">
		<call-query href="updatePlanpptalconfigPorcodigoynaturaleza">
			<with-param name="CODIGOSCHIP" query-param="CODIGOSCHIP"/>
			<with-param name="RECURSOSCHIP" query-param="RECURSOSCHIP"/>
			<with-param name="ORIGENESPECIFICOINGRESOS" query-param="ORIGENESPECIFICOINGRESOS"/>
			<with-param name="DESTINACIONDELOSRECURSOS" query-param="DESTINACIONDELOSRECURSOS"/>
			<with-param name="DEPENDENCIASCHIP" query-param="DEPENDENCIASCHIP"/>
			<with-param name="SITUACIONFONDOSSCHIP" query-param="SITUACIONFONDOSSCHIP"/>
			<with-param name="RECAUDO_VA" query-param="RECAUDO_VA"/>
			<with-param name="FINALIDADGASTO" query-param="FINALIDADGASTO"/>
			<with-param name="VIGENCIAGASTO" query-param="VIGENCIAGASTO"/>
			<with-param name="VIGENCIATESORERIASCHIP" query-param="VIGENCIATESORERIASCHIP"/>
			<with-param name="CR1_RESGUARDOSCHIP" query-param="CR1_RESGUARDOSCHIP"/>
			<with-param name="CODIGOSIRECI" query-param="CODIGOSIRECI"/>
			<with-param name="COD_RECIPROCA" query-param="COD_RECIPROCA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_AUXILIAR" query-param="KEY_AUXILIAR"/>
			<with-param name="KEY_REFERENCIA" query-param="KEY_REFERENCIA"/>
			<with-param name="KEY_FUENTE_RECURSO" query-param="KEY_FUENTE_RECURSO"/>

		</call-query>
	</resource>
	<query id="getPlanpptalconfigPagGplanpptalconfigQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT P.COMPANIA, P.ANO, P.CODIGO, P.CENTRO_COSTO, P.TERCERO, P.SUCURSAL, P.AUXILIAR, P.REFERENCIA, P.FUENTE_RECURSO, VP.NOMBRE, P.NATURALEZA, P.CODIGO_SUPERSALUD,(CASE PP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_PPTAL_CONFIG P INNER JOIN V_PLAN_PRESUPUESTAL VP ON P.COMPANIA = VP.COMPANIA AND P.ANO = VP.ANO AND P.CODIGO = VP.CODIGO AND P.CENTRO_COSTO = VP.CENTRO_COSTO AND P.AUXILIAR = VP.AUXILIAR AND P.FUENTE_RECURSO = VP.FUENTE_RECURSO AND P.REFERENCIA = VP.REFERENCIA INNER JOIN PLAN_PRESUPUESTAL PP ON P.COMPANIA = PP.COMPANIA AND P.ANO = PP.ANO AND P.CODIGO = PP.CODIGO WHERE P.COMPANIA = :COMPANIA AND P.ANO = :ANO AND NVL(P.CODIGO_SUPERSALUD,'-') = CASE WHEN (:ESTADO = 1 ) THEN '-' ELSE NVL(P.CODIGO_SUPERSALUD,'-') END AND P.FUENTE_RECURSO &lt;&gt; CASE WHEN (:MANEJA_AUXILIARFUENTE = 'SI' ) THEN '99999999999999999999' ELSE '-' END) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(CONCAT('%',:NATURALEZA), '%')) AND (CASE WHEN CODIGO_SUPERSALUD IS NULL THEN ' ' ELSE UPPER(CODIGO_SUPERSALUD) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_SUPERSALUD), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","CODIGO_SUPERSALUD":"$CODIGO_SUPERSALUD","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="MANEJA_AUXILIARFUENTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO_SUPERSALUD" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planpptalconfig/gplanpptalconfig/pag">
		<call-query href="getPlanpptalconfigPagGplanpptalconfigQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MANEJA_AUXILIARFUENTE" query-param="MANEJA_AUXILIARFUENTE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="CODIGO_SUPERSALUD" query-param="CODIGO_SUPERSALUD"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanpptalconfigNumGplanpptalconfigQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT P.COMPANIA, P.ANO, P.CODIGO, P.CENTRO_COSTO, P.TERCERO, P.SUCURSAL, P.AUXILIAR, P.REFERENCIA, P.FUENTE_RECURSO, VP.NOMBRE, P.NATURALEZA, P.CODIGO_SUPERSALUD,(CASE PP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_PPTAL_CONFIG P INNER JOIN V_PLAN_PRESUPUESTAL VP ON P.COMPANIA = VP.COMPANIA AND P.ANO = VP.ANO AND P.CODIGO = VP.CODIGO AND P.CENTRO_COSTO = VP.CENTRO_COSTO AND P.AUXILIAR = VP.AUXILIAR AND P.FUENTE_RECURSO = VP.FUENTE_RECURSO AND P.REFERENCIA = VP.REFERENCIA INNER JOIN PLAN_PRESUPUESTAL PP ON P.COMPANIA = PP.COMPANIA AND P.ANO = PP.ANO AND P.CODIGO = PP.CODIGO WHERE P.COMPANIA = :COMPANIA AND P.ANO = :ANO AND NVL(P.CODIGO_SUPERSALUD,'-') = CASE WHEN (:ESTADO = 1 ) THEN '-' ELSE NVL(P.CODIGO_SUPERSALUD,'-') END AND P.FUENTE_RECURSO &lt;&gt; CASE WHEN (:MANEJA_AUXILIARFUENTE = 'SI' ) THEN '99999999999999999999' ELSE '-' END) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(CONCAT('%',:NATURALEZA), '%')) AND (CASE WHEN CODIGO_SUPERSALUD IS NULL THEN ' ' ELSE UPPER(CODIGO_SUPERSALUD) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_SUPERSALUD), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="MANEJA_AUXILIARFUENTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO_SUPERSALUD" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planpptalconfig/gplanpptalconfig/num">
		<call-query href="getPlanpptalconfigNumGplanpptalconfigQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MANEJA_AUXILIARFUENTE" query-param="MANEJA_AUXILIARFUENTE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="CODIGO_SUPERSALUD" query-param="CODIGO_SUPERSALUD"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="getPlanpptalconfigTodosaniosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO  FROM PLAN_PPTAL_CONFIG WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planpptalconfig/todosanios">
		<call-query href="getPlanpptalconfigTodosaniosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPlanpptalconfigPagFutCategoriasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_PPTAL_CONFIG.COMPANIA, PLAN_PPTAL_CONFIG.ANO, PLAN_PPTAL_CONFIG.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PPTAL_CONFIG.DESTINO, CASE PLAN_PPTAL_CONFIG.DESTINO WHEN 'F' THEN 'Funcionamiento' WHEN 'I' THEN 'Inversión' WHEN 'S' THEN 'Servicio de la Deuda' WHEN 'I' THEN 'Libre destinación' END NOMDESTINO, PLAN_PPTAL_CONFIG.CODIGOFUT_H, PLAN_PPTAL_CONFIG.FUENTE_FLS, FUENTESFUTCATEGORIAS.NOMBRE_FUT, PLAN_PPTAL_CONFIG.HECHOVICTIMIZANTE, HECHOVICTIMIZANTE.NOMBRE NOMBRE_HECHO, PLAN_PPTAL_CONFIG.TIPO_FUTSALUD, PLAN_PPTAL_CONFIG.TIPOVIGENCIA, PLAN_PPTAL_CONFIG.FUENTE  FROM PLAN_PPTAL_CONFIG INNER JOIN PLAN_PRESUPUESTAL ON PLAN_PPTAL_CONFIG.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = PLAN_PRESUPUESTAL.ANO AND PLAN_PPTAL_CONFIG.CODIGO = PLAN_PRESUPUESTAL.CODIGO LEFT JOIN HECHOVICTIMIZANTE ON PLAN_PPTAL_CONFIG.COMPANIA = HECHOVICTIMIZANTE.COMPANIA AND PLAN_PPTAL_CONFIG.HECHOVICTIMIZANTE = HECHOVICTIMIZANTE.CODIGO AND PLAN_PPTAL_CONFIG.ANO = HECHOVICTIMIZANTE.ANO LEFT JOIN FUENTESFUTCATEGORIAS ON PLAN_PPTAL_CONFIG.COMPANIA = FUENTESFUTCATEGORIAS.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = FUENTESFUTCATEGORIAS.ANO AND PLAN_PPTAL_CONFIG.FUENTE_FLS = FUENTESFUTCATEGORIAS.CODIGO_FUT WHERE PLAN_PPTAL_CONFIG.COMPANIA = :COMPANIA AND PLAN_PPTAL_CONFIG.ANO = :ANO AND NVL(PLAN_PPTAL_CONFIG.DESTINO,'-')= CASE WHEN (:DESTINO) IS NOT NULL THEN (:DESTINO) ELSE NVL(PLAN_PPTAL_CONFIG.DESTINO,'-') END AND NVL(PLAN_PPTAL_CONFIG.NATURALEZA, '-') = CASE WHEN (:NATURALEZA) IS NOT NULL THEN (:NATURALEZA) ELSE NVL(PLAN_PPTAL_CONFIG.NATURALEZA,'-') END AND PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN(0) ORDER BY PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMDESTINO IS NULL THEN ' ' ELSE UPPER(NOMDESTINO) END)  LIKE UPPER( '%' || :NOMDESTINO || '%')  AND (CASE WHEN CODIGOFUT_H IS NULL THEN ' ' ELSE UPPER(CODIGOFUT_H) END)  LIKE UPPER( '%' || :CODIGOFUT_H || '%')  AND (CASE WHEN NOMBRE_FUT IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUT) END)  LIKE UPPER( '%' || :NOMBRE_FUT || '%')  AND (CASE WHEN NOMBRE_HECHO IS NULL THEN ' ' ELSE UPPER(NOMBRE_HECHO) END)  LIKE UPPER( '%' || :NOMBRE_HECHO || '%')  AND (CASE WHEN TIPO_FUTSALUD IS NULL THEN ' ' ELSE UPPER(TIPO_FUTSALUD) END)  LIKE UPPER( '%' || :TIPO_FUTSALUD || '%')  AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END)  LIKE UPPER( '%' || :TIPOVIGENCIA || '%')  AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER( '%' || :FUENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESTINO":"$DESTINO","NOMDESTINO":"$NOMDESTINO","CODIGOFUT_H":"$CODIGOFUT_H","FUENTE_FLS":"$FUENTE_FLS","NOMBRE_FUT":"$NOMBRE_FUT","HECHOVICTIMIZANTE":"$HECHOVICTIMIZANTE","NOMBRE_HECHO":"$NOMBRE_HECHO","TIPO_FUTSALUD":"$TIPO_FUTSALUD(type:integer)","TIPOVIGENCIA":"$TIPOVIGENCIA","FUENTE":"$FUENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMDESTINO" sqlType="STRING"/>
