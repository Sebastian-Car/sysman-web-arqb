	<query id="getPlanpptalconfigPagConfiguracionUnidadEjecutoraQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_PPTAL_CONFIG.COMPANIA , PLAN_PPTAL_CONFIG.ANO , PLAN_PPTAL_CONFIG.CENTRO_COSTO , PLAN_PPTAL_CONFIG.TERCERO , PLAN_PPTAL_CONFIG.SUCURSAL , PLAN_PPTAL_CONFIG.AUXILIAR , PLAN_PPTAL_CONFIG.REFERENCIA , PLAN_PPTAL_CONFIG.FUENTE_RECURSO, PLAN_PPTAL_CONFIG.CODIGO , V.NOMBRE, CASE WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='1.0' THEN 'ADMINISTRACION CENTRAL' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='2.0' THEN 'CONCEJO - SOLO MUNICIPIOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='3.0' THEN 'ASAMBLEA - SOLO DEPARTAMENTOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='4.0' THEN 'CONTRALORIA' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='5.0' THEN 'PERSONERIA - SOLO MUNICIPIOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='6.0' THEN 'SECRETARIA DE EDUCACION' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='7.0' THEN 'SECRETARIA DE SALUD' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='8.0' THEN 'UNIDAD DE SERVICIOS PUBLICOS - SOLO MUNICIPIOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='9.0' THEN 'LICORES - SOLO DEPARTAMENTOS' ELSE ' ' END UNIDADEJECUTORA_FUTAUX, PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT FROM PLAN_PPTAL_CONFIG INNER JOIN V_PLAN_PRESUPUESTAL V ON PLAN_PPTAL_CONFIG.COMPANIA =V.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = V.ANO AND PLAN_PPTAL_CONFIG.CODIGO = V.CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO = V.CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO = V.TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL = V.SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR = V.AUXILIAR AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO = V.FUENTE_RECURSO AND PLAN_PPTAL_CONFIG.REFERENCIA = V.REFERENCIA WHERE V.COMPANIA = :COMPANIA AND V.ANO = :ANO AND V.NATURALEZA IN ('D') AND V.DESTINO IN('F') ORDER BY PLAN_PPTAL_CONFIG.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN UNIDADEJECUTORA_FUTAUX IS NULL THEN ' ' ELSE UPPER(UNIDADEJECUTORA_FUTAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:UNIDADEJECUTORA_FUTAUX), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","UNIDADEJECUTORA_FUTAUX":"$UNIDADEJECUTORA_FUTAUX","UNIDADEJECUTORA_FUT":"$UNIDADEJECUTORA_FUT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="UNIDADEJECUTORA_FUTAUX" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planpptalconfig/configuracionunidadejecutora/pag">
		<call-query href="getPlanpptalconfigPagConfiguracionUnidadEjecutoraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="UNIDADEJECUTORA_FUTAUX" query-param="UNIDADEJECUTORA_FUTAUX"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanpptalconfigNumConfiguracionUnidadEjecutoraQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_PPTAL_CONFIG.COMPANIA , PLAN_PPTAL_CONFIG.ANO , PLAN_PPTAL_CONFIG.CENTRO_COSTO , PLAN_PPTAL_CONFIG.TERCERO , PLAN_PPTAL_CONFIG.SUCURSAL , PLAN_PPTAL_CONFIG.AUXILIAR , PLAN_PPTAL_CONFIG.REFERENCIA , PLAN_PPTAL_CONFIG.FUENTE_RECURSO, PLAN_PPTAL_CONFIG.CODIGO , V.NOMBRE, CASE WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='1.0' THEN 'ADMINISTRACION CENTRAL' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='2.0' THEN 'CONCEJO - SOLO MUNICIPIOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='3.0' THEN 'ASAMBLEA - SOLO DEPARTAMENTOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='4.0' THEN 'CONTRALORIA' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='5.0' THEN 'PERSONERIA - SOLO MUNICIPIOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='6.0' THEN 'SECRETARIA DE EDUCACION' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='7.0' THEN 'SECRETARIA DE SALUD' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='8.0' THEN 'UNIDAD DE SERVICIOS PUBLICOS - SOLO MUNICIPIOS' WHEN PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT='9.0' THEN 'LICORES - SOLO DEPARTAMENTOS' ELSE ' ' END UNIDADEJECUTORA_FUTAUX, PLAN_PPTAL_CONFIG.UNIDADEJECUTORA_FUT FROM PLAN_PPTAL_CONFIG INNER JOIN V_PLAN_PRESUPUESTAL V ON PLAN_PPTAL_CONFIG.COMPANIA =V.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = V.ANO AND PLAN_PPTAL_CONFIG.CODIGO = V.CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO = V.CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO = V.TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL = V.SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR = V.AUXILIAR AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO = V.FUENTE_RECURSO AND PLAN_PPTAL_CONFIG.REFERENCIA = V.REFERENCIA WHERE V.COMPANIA = :COMPANIA AND V.ANO = :ANO AND V.NATURALEZA IN ('D') AND V.DESTINO IN('F') ORDER BY PLAN_PPTAL_CONFIG.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN UNIDADEJECUTORA_FUTAUX IS NULL THEN ' ' ELSE UPPER(UNIDADEJECUTORA_FUTAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:UNIDADEJECUTORA_FUTAUX), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="UNIDADEJECUTORA_FUTAUX" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planpptalconfig/configuracionunidadejecutora/num">
		<call-query href="getPlanpptalconfigNumConfiguracionUnidadEjecutoraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="UNIDADEJECUTORA_FUTAUX" query-param="UNIDADEJECUTORA_FUTAUX"/>

		</call-query>
	</resource>
	<query id="updatePlanpptalconfigConfiguraejecutora" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CONFIG SET UNIDADEJECUTORA_FUT=:UNIDADEJECUTORA_FUT, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PPTAL_CONFIG.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CONFIG.ANO= :KEY_ANO AND PLAN_PPTAL_CONFIG.CODIGO= :KEY_CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO= :KEY_CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO= :KEY_TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL= :KEY_SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR= :KEY_AUXILIAR AND PLAN_PPTAL_CONFIG.REFERENCIA= :KEY_REFERENCIA AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

