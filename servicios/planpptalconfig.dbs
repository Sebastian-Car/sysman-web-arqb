		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="DEPENDENCIASCHIP" sqlType="STRING"/>
		<param name="CONSITUACIONFONDOS" sqlType="STRING"/>
		<param name="VIGENCIAGASTO" sqlType="STRING"/>
