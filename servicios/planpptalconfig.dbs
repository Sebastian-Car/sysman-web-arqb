	<query id="updatePlanpptalconfigActualizaIndicador" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CONFIG  SET   CODIGOSCHIP   = NULL ,        DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),        MODIFIED_BY   = :MODIFIED_BY WHERE  PLAN_PPTAL_CONFIG.CODIGOSCHIP IN (SELECT CODIGO                                          FROM PLAN_SCHIP                                         WHERE ENTIDAD = :ENTIDAD                                           AND MOVIMIENTO IN (0))</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="ENTIDAD" sqlType="STRING"/>

	</query>
