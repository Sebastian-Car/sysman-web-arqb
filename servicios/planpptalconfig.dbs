	<query id="getPlanpptalconfigPagGplanpptalconfigsiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  P.COMPANIA, P.ANO, P.CODIGO, P.CENTRO_COSTO, P.TERCERO, P.SUCURSAL, P.AUXILIAR, P.REFERENCIA, P.FUENTE_RECURSO, VP.NOMBRE, P.NATURALEZA, P.CODIGO_SIA,(CASE PP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_PPTAL_CONFIG P INNER JOIN V_PLAN_PRESUPUESTAL VP ON P.COMPANIA = VP.COMPANIA AND P.ANO = VP.ANO AND P.CODIGO = VP.CODIGO AND P.CENTRO_COSTO = VP.CENTRO_COSTO AND P.AUXILIAR = VP.AUXILIAR AND P.FUENTE_RECURSO = VP.FUENTE_RECURSO INNER JOIN PLAN_PRESUPUESTAL PP ON P.COMPANIA = PP.COMPANIA AND P.ANO = PP.ANO AND P.CODIGO = PP.CODIGO WHERE P.COMPANIA = :COMPANIA AND P.ANO = :ANO AND NVL(P.CODIGO_SIA,'-') = CASE WHEN (:ESTADO = 1 ) THEN '-' ELSE NVL(P.CODIGO_SIA,'-') END AND P.FUENTE_RECURSO &lt;&gt; CASE WHEN (:MANEJA_AUXILIARFUENTE = 'SI' ) THEN '99999999999999999999' ELSE '-' END) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER( '%' || :FUENTE_RECURSO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END)  LIKE UPPER(:NATURALEZA || '%')  AND (CASE WHEN CODIGO_SIA IS NULL THEN ' ' ELSE UPPER(CODIGO_SIA) END)  LIKE UPPER(:CODIGO_SIA || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","CODIGO_SIA":"$CODIGO_SIA","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="MANEJA_AUXILIARFUENTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO_SIA" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planpptalconfig/gplanpptalconfigsia/pag">
