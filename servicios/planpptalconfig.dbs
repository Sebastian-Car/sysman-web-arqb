	<query id="getPlanpptalconfigNumListaConfiguracionChipQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PP.COMPANIA, PP.CENTRO_COSTO, PP.TERCERO, PP.SUCURSAL, PP.AUXILIAR, PP.REFERENCIA, PP.FUENTE_RECURSO, PP.SECTOR_REGALIAS, PP.ANO, PP.CODIGO, V.NOMBRE, PP.CODIGOFUT_H, F.NOMBREFU_FUT, PP.FUENTE_FUT, PP.FUENTEFUT_RESERVA, PP.TIPOVIGENCIA,(CASE PP.SITUACIONFONDOSSCHIP WHEN 0 THEN 'false' ELSE 'true' END) SITUACIONFONDOSSCHIP,(CASE PP.FUT_TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) FUT_TRANSFERENCIA, PP.FUENTE, SR.NOMBRE NOMBRE_SECTOR_REGA, PP.CODIGOFUT_REGALIAS, PP.FUENTE_FUTREGALIAS,(CASE PP.DISPONIBILIDAD_INICIAL_FUT WHEN 0 THEN 'false' ELSE 'true' END) DISPONIBILIDAD_INICIAL_FUT, PP.CODIGO_BPIN_SGR  FROM PLAN_PPTAL_CONFIG PP LEFT JOIN SECTORES_REGALIAS SR ON PP.SECTOR_REGALIAS = SR.CODIGO INNER JOIN V_PLAN_PRESUPUESTAL V ON PP.COMPANIA = V.COMPANIA AND PP.ANO = V.ANO AND PP.CODIGO = V.CODIGO AND PP.CENTRO_COSTO = V.CENTRO_COSTO AND PP.TERCERO = V.TERCERO AND PP.SUCURSAL = V.SUCURSAL AND PP.AUXILIAR = V.AUXILIAR AND PP.FUENTE_RECURSO = V.FUENTE_RECURSO AND PP.REFERENCIA = V.REFERENCIA LEFT JOIN FUENTESFUT F ON V.COMPANIA = F.COMPANIA AND V.ANO = F.ANO AND V.FUENTE_FUT = F.CODIGOFU_FUT AND V.DESTINO = F.DESTINO AND V.NATURALEZA = F.NATURALEZA_FUT WHERE V.COMPANIA =:COMPANIA AND V.ANO =:ANO AND V.NATURALEZA =:NATURALEZA AND V.DESTINO =:DESTINO AND CASE WHEN PCK_SYSMAN_UTL.FC_PAR(V.COMPANIA,'MANEJA AUXILIAR POR FUENTE EN PRESUPUESTO',3,SYSDATE,-1) IN ('SI') THEN PP.FUENTE_RECURSO ELSE '0' END NOT IN (PCK_DATOS.FC_CONS_FUENTE()) ORDER BY PP.CODIGO) WHERE (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER( '%' || :AUXILIAR || '%')  AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END)  LIKE UPPER( '%' || :REFERENCIA || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER(:FUENTE_RECURSO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGOFUT_H IS NULL THEN ' ' ELSE UPPER(CODIGOFUT_H) END)  LIKE UPPER(:CODIGOFUT_H || '%')  AND (CASE WHEN NOMBREFU_FUT IS NULL THEN ' ' ELSE UPPER(NOMBREFU_FUT) END)  LIKE UPPER( '%' || :NOMBREFU_FUT || '%')  AND (CASE WHEN FUENTE_FUT IS NULL THEN ' ' ELSE UPPER(FUENTE_FUT) END)  LIKE UPPER(:FUENTE_FUT || '%')  AND (CASE WHEN FUENTEFUT_RESERVA IS NULL THEN ' ' ELSE UPPER(FUENTEFUT_RESERVA) END)  LIKE UPPER(:FUENTEFUT_RESERVA || '%')  AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END)  LIKE UPPER(:TIPOVIGENCIA || '%')  AND (CASE WHEN SITUACIONFONDOSSCHIP IS NULL THEN ' ' ELSE UPPER(SITUACIONFONDOSSCHIP) END)  LIKE UPPER(:SITUACIONFONDOSSCHIP || '%')  AND (CASE WHEN FUT_TRANSFERENCIA IS NULL THEN ' ' ELSE UPPER(FUT_TRANSFERENCIA) END)  LIKE UPPER(:FUT_TRANSFERENCIA || '%')  AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER(:FUENTE || '%')  AND (CASE WHEN NOMBRE_SECTOR_REGA IS NULL THEN ' ' ELSE UPPER(NOMBRE_SECTOR_REGA) END)  LIKE UPPER( '%' || :NOMBRE_SECTOR_REGA || '%')  AND (CASE WHEN CODIGOFUT_REGALIAS IS NULL THEN ' ' ELSE UPPER(CODIGOFUT_REGALIAS) END)  LIKE UPPER(:CODIGOFUT_REGALIAS || '%')  AND (CASE WHEN FUENTE_FUTREGALIAS IS NULL THEN ' ' ELSE UPPER(FUENTE_FUTREGALIAS) END)  LIKE UPPER(:FUENTE_FUTREGALIAS || '%')  AND (CASE WHEN DISPONIBILIDAD_INICIAL_FUT IS NULL THEN ' ' ELSE UPPER(DISPONIBILIDAD_INICIAL_FUT) END)  LIKE UPPER(:DISPONIBILIDAD_INICIAL_FUT || '%')  AND (CASE WHEN CODIGO_BPIN_SGR IS NULL THEN ' ' ELSE UPPER(CODIGO_BPIN_SGR) END)  LIKE UPPER(:CODIGO_BPIN_SGR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOFUT_H" sqlType="STRING"/>
		<param name="NOMBREFU_FUT" sqlType="STRING"/>
		<param name="FUENTE_FUT" sqlType="STRING"/>
		<param name="FUENTEFUT_RESERVA" sqlType="STRING"/>
		<param name="TIPOVIGENCIA" sqlType="STRING"/>
		<param name="SITUACIONFONDOSSCHIP" sqlType="STRING"/>
		<param name="FUT_TRANSFERENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="NOMBRE_SECTOR_REGA" sqlType="STRING"/>
		<param name="CODIGOFUT_REGALIAS" sqlType="STRING"/>
		<param name="FUENTE_FUTREGALIAS" sqlType="STRING"/>
		<param name="DISPONIBILIDAD_INICIAL_FUT" sqlType="STRING"/>
		<param name="CODIGO_BPIN_SGR" sqlType="STRING"/>

	</query>
