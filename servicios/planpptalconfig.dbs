		<param name="CODIGO_BPIN_SGR" sqlType="STRING"/>
		<param name="CODIGO_CCEPT" sqlType="STRING"/>
		<param name="FUENTE_CUIPO" sqlType="STRING"/>
		<param name="SECTOR_CUIPO" sqlType="STRING"/>
		<param name="PROGRAMA_CUIPO" sqlType="STRING"/>
		<param name="CODIGO_CPC_CUIPO" sqlType="STRING"/>
		<param name="POLITCA_PUBLICA_CUIPO" sqlType="STRING"/>
		<param name="TERCERO_CHIP" sqlType="STRING"/>
		<param name="APLICA_DEST_ESPECIFICA" sqlType="STRING"/>
		<param name="TIPO_NORMA" sqlType="STRING"/>
		<param name="NUMERO_NORMA" sqlType="STRING"/>
