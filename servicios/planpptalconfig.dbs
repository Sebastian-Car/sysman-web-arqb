	<query id="getPlanpptalconfigPagConfiguracionFutCategoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_PPTAL_CONFIG.COMPANIA, PLAN_PPTAL_CONFIG.ANO, PLAN_PPTAL_CONFIG.CENTRO_COSTO, PLAN_PPTAL_CONFIG.TERCERO, PLAN_PPTAL_CONFIG.SUCURSAL, PLAN_PPTAL_CONFIG.AUXILIAR, PLAN_PPTAL_CONFIG.REFERENCIA, PLAN_PPTAL_CONFIG.FUENTE_RECURSO, PLAN_PPTAL_CONFIG.DESTINO, PLAN_PPTAL_CONFIG.CODIGO, V.NOMBRE, CASE PLAN_PPTAL_CONFIG.DESTINO WHEN 'F' THEN 'Funcionamiento' WHEN 'I' THEN 'Inversion' WHEN 'S' THEN 'Servicio de la Deuda' WHEN 'I' THEN 'Libre destinacion' END NOMDESTINO, PLAN_PPTAL_CONFIG.FUT_DESPLAZADOS1, PLAN_PPTAL_CONFIG.FUT_CUENTAXPAGAR, PLAN_PPTAL_CONFIG.FUT_EJECUCIONSALUD, PLAN_PPTAL_CONFIG.FUT_SALUD_TESORERIA, PLAN_PPTAL_CONFIG.FUT_VIGENCIA_FUTURA, PLAN_PPTAL_CONFIG.FUT_INGRESOS_RESERVAS, PLAN_PPTAL_CONFIG.FUT_VICTIMAS1, PLAN_PPTAL_CONFIG.FUENTE_FLS, PLAN_PPTAL_CONFIG.TIPOVIGENCIA FROM PLAN_PPTAL_CONFIG INNER JOIN V_PLAN_PRESUPUESTAL V ON PLAN_PPTAL_CONFIG.COMPANIA = V.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = V.ANO AND PLAN_PPTAL_CONFIG.CODIGO = V.CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO = V.CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO = V.TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL = V.SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR = V.AUXILIAR AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO = V.FUENTE_RECURSO AND PLAN_PPTAL_CONFIG.REFERENCIA = V.REFERENCIA WHERE PLAN_PPTAL_CONFIG.COMPANIA = :COMPANIA AND PLAN_PPTAL_CONFIG.ANO = :ANO AND NVL(PLAN_PPTAL_CONFIG.NATURALEZA, '-') = CASE WHEN ( :NATURALEZA ) IS NOT NULL THEN ( :NATURALEZA ) ELSE NVL(PLAN_PPTAL_CONFIG.NATURALEZA, '-') END AND NVL(PLAN_PPTAL_CONFIG.FUT_DESPLAZADOS1, '-') = CASE WHEN :CONFIGURAR IN ( 'D1' ) THEN '-' ELSE NVL(PLAN_PPTAL_CONFIG.FUT_DESPLAZADOS1, '-') END AND NVL(PLAN_PPTAL_CONFIG.FUT_CUENTAXPAGAR, '-') = CASE WHEN :CONFIGURAR IN ( 'CP' ) THEN '-' ELSE NVL(PLAN_PPTAL_CONFIG.FUT_CUENTAXPAGAR, '-') END AND NVL(PLAN_PPTAL_CONFIG.FUT_EJECUCIONSALUD, '-') = CASE WHEN :CONFIGURAR IN ( 'FS' ) THEN '-' ELSE NVL(PLAN_PPTAL_CONFIG.FUT_EJECUCIONSALUD, '-') END AND NVL(PLAN_PPTAL_CONFIG.FUT_SALUD_TESORERIA, '-') = CASE WHEN :CONFIGURAR IN ( 'TS' ) THEN '-' ELSE NVL(PLAN_PPTAL_CONFIG.FUT_SALUD_TESORERIA, '-') END AND NVL(PLAN_PPTAL_CONFIG.FUT_VIGENCIA_FUTURA, '-') = CASE WHEN :CONFIGURAR IN ( 'VI' ) THEN '-' ELSE NVL(PLAN_PPTAL_CONFIG.FUT_VIGENCIA_FUTURA, '-') END AND NVL(PLAN_PPTAL_CONFIG.FUT_INGRESOS_RESERVAS, '-') = CASE WHEN :CONFIGURAR IN ( 'IR' ) THEN '-' ELSE NVL(PLAN_PPTAL_CONFIG.FUT_INGRESOS_RESERVAS, '-') END AND NVL(PLAN_PPTAL_CONFIG.FUT_VICTIMAS1, '-') = CASE WHEN :CONFIGURAR IN ( 'V1' ) THEN '-' ELSE NVL(PLAN_PPTAL_CONFIG.FUT_VICTIMAS1, '-') END AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO NOT IN CASE WHEN :PARAMETRO = 'SI' THEN '99999999999999999999' ELSE '.' END AND V.IND_COVID IN (CASE WHEN :COVID NOT IN (0) THEN '-1' ELSE '0' END) ORDER BY PLAN_PPTAL_CONFIG.CODIGO) INI WHERE (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN NOMDESTINO IS NULL THEN ' ' ELSE UPPER(NOMDESTINO) END) LIKE UPPER(CONCAT(:NOMDESTINO, '%')) AND (CASE WHEN FUT_DESPLAZADOS1 IS NULL THEN ' ' ELSE UPPER(FUT_DESPLAZADOS1) END) LIKE UPPER(CONCAT(CONCAT('%',:FUT_DESPLAZADOS1), '%')) AND (CASE WHEN FUT_CUENTAXPAGAR IS NULL THEN ' ' ELSE UPPER(FUT_CUENTAXPAGAR) END) LIKE UPPER(CONCAT(CONCAT('%',:FUT_CUENTAXPAGAR), '%')) AND (CASE WHEN FUT_EJECUCIONSALUD IS NULL THEN ' ' ELSE UPPER(FUT_EJECUCIONSALUD) END) LIKE UPPER(CONCAT(:FUT_EJECUCIONSALUD, '%')) AND (CASE WHEN FUT_SALUD_TESORERIA IS NULL THEN ' ' ELSE UPPER(FUT_SALUD_TESORERIA) END) LIKE UPPER(CONCAT(:FUT_SALUD_TESORERIA, '%')) AND (CASE WHEN FUT_VIGENCIA_FUTURA IS NULL THEN ' ' ELSE UPPER(FUT_VIGENCIA_FUTURA) END) LIKE UPPER(CONCAT(:FUT_VIGENCIA_FUTURA, '%')) AND (CASE WHEN FUT_INGRESOS_RESERVAS IS NULL THEN ' ' ELSE UPPER(FUT_INGRESOS_RESERVAS) END) LIKE UPPER(CONCAT(:FUT_INGRESOS_RESERVAS, '%')) AND (CASE WHEN FUT_VICTIMAS1 IS NULL THEN ' ' ELSE UPPER(FUT_VICTIMAS1) END) LIKE UPPER(CONCAT(:FUT_VICTIMAS1, '%')) AND (CASE WHEN FUENTE_FLS IS NULL THEN ' ' ELSE UPPER(FUENTE_FLS) END) LIKE UPPER(CONCAT(:FUENTE_FLS, '%')) AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOVIGENCIA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","DESTINO":"$DESTINO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NOMDESTINO":"$NOMDESTINO","FUT_DESPLAZADOS1":"$FUT_DESPLAZADOS1","FUT_CUENTAXPAGAR":"$FUT_CUENTAXPAGAR","FUT_EJECUCIONSALUD":"$FUT_EJECUCIONSALUD","FUT_SALUD_TESORERIA":"$FUT_SALUD_TESORERIA","FUT_VIGENCIA_FUTURA":"$FUT_VIGENCIA_FUTURA","FUT_INGRESOS_RESERVAS":"$FUT_INGRESOS_RESERVAS","FUT_VICTIMAS1":"$FUT_VICTIMAS1","FUENTE_FLS":"$FUENTE_FLS","TIPOVIGENCIA":"$TIPOVIGENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CONFIGURAR" sqlType="STRING"/>
		<param name="PARAMETRO" sqlType="STRING"/>
		<param name="COVID" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMDESTINO" sqlType="STRING"/>
		<param name="FUT_DESPLAZADOS1" sqlType="STRING"/>
		<param name="FUT_CUENTAXPAGAR" sqlType="STRING"/>
		<param name="FUT_EJECUCIONSALUD" sqlType="STRING"/>
		<param name="FUT_SALUD_TESORERIA" sqlType="STRING"/>
		<param name="FUT_VIGENCIA_FUTURA" sqlType="STRING"/>
		<param name="FUT_INGRESOS_RESERVAS" sqlType="STRING"/>
		<param name="FUT_VICTIMAS1" sqlType="STRING"/>
		<param name="FUENTE_FLS" sqlType="STRING"/>
		<param name="TIPOVIGENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
