			<with-param name="RES_CODIGO_CIERRE" query-param="RES_CODIGO_CIERRE"/>
			<with-param name="RES_FUENTE_RECURSO_CIERRE" query-param="RES_FUENTE_RECURSO_CIERRE"/>
			<with-param name="RES_REFERENCIA_CIERRE" query-param="RES_REFERENCIA_CIERRE"/>
			<with-param name="RES_CENTRO_COSTO_CIERRE" query-param="RES_CENTRO_COSTO_CIERRE"/>
			<with-param name="RES_AUXILIAR_CIERRE" query-param="RES_AUXILIAR_CIERRE"/>
			<with-param name="REO_CODIGO_CIERRE" query-param="REO_CODIGO_CIERRE"/>
			<with-param name="REO_FUENTE_RECURSO_CIERRE" query-param="REO_FUENTE_RECURSO_CIERRE"/>
			<with-param name="REO_REFERENCIA_CIERRE" query-param="REO_REFERENCIA_CIERRE"/>
			<with-param name="REO_CENTRO_COSTO_CIERRE" query-param="REO_CENTRO_COSTO_CIERRE"/>
