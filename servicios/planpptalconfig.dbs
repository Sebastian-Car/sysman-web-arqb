	<query id="updatePlanpptalconfigConfiguracionChip" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CONFIG SET SECTOR_REGALIAS=:SECTOR_REGALIAS, CODIGOFUT_H=:CODIGOFUT_H, FUENTE_FUT=:FUENTE_FUT, FUENTEFUT_RESERVA=:FUENTEFUT_RESERVA, SITUACIONFONDOSSCHIP=:SITUACIONFONDOSSCHIP, FUT_TRANSFERENCIA=:FUT_TRANSFERENCIA, FUENTE=:FUENTE, CODIGOFUT_REGALIAS=:CODIGOFUT_REGALIAS, FUENTE_FUTREGALIAS=:FUENTE_FUTREGALIAS, DISPONIBILIDAD_INICIAL_FUT=:DISPONIBILIDAD_INICIAL_FUT, CODIGO_BPIN_SGR=:CODIGO_BPIN_SGR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PPTAL_CONFIG.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CONFIG.ANO= :KEY_ANO AND PLAN_PPTAL_CONFIG.CODIGO= :KEY_CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO= :KEY_CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO= :KEY_TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL= :KEY_SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR= :KEY_AUXILIAR AND PLAN_PPTAL_CONFIG.REFERENCIA= :KEY_REFERENCIA AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SECTOR_REGALIAS" sqlType="STRING"/>
		<param name="CODIGOFUT_H" sqlType="STRING"/>
		<param name="FUENTE_FUT" sqlType="STRING"/>
		<param name="FUENTEFUT_RESERVA" sqlType="STRING"/>
		<param name="SITUACIONFONDOSSCHIP" sqlType="STRING"/>
		<param name="FUT_TRANSFERENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CODIGOFUT_REGALIAS" sqlType="STRING"/>
		<param name="FUENTE_FUTREGALIAS" sqlType="STRING"/>
		<param name="DISPONIBILIDAD_INICIAL_FUT" sqlType="STRING"/>
		<param name="CODIGO_BPIN_SGR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
