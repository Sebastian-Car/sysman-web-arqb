	<query id="updatePlanpptalconfigUpdatereclasificacioncierre" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CONFIG SET ANO_CIERRE=:ANO_CIERRE, RES_CODIGO_CIERRE=:RES_CODIGO_CIERRE, RES_FUENTE_RECURSO_CIERRE=:RES_FUENTE_RECURSO_CIERRE, RES_REFERENCIA_CIERRE=:RES_REFERENCIA_CIERRE, RES_CENTRO_COSTO_CIERRE=:RES_CENTRO_COSTO_CIERRE, RES_AUXILIAR_CIERRE=:RES_AUXILIAR_CIERRE, REO_CODIGO_CIERRE=:REO_CODIGO_CIERRE, REO_FUENTE_RECURSO_CIERRE=:REO_FUENTE_RECURSO_CIERRE, REO_REFERENCIA_CIERRE=:REO_REFERENCIA_CIERRE, REO_CENTRO_COSTO_CIERRE=:REO_CENTRO_COSTO_CIERRE, REO_AUXILIAR_CIERRE=:REO_AUXILIAR_CIERRE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE PLAN_PPTAL_CONFIG.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CONFIG.ANO= :KEY_ANO AND PLAN_PPTAL_CONFIG.CODIGO= :KEY_CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO= :KEY_CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO= :KEY_TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL= :KEY_SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR= :KEY_AUXILIAR AND PLAN_PPTAL_CONFIG.REFERENCIA= :KEY_REFERENCIA AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
