			<with-param name="PROGRAMA_CUIPO" query-param="PROGRAMA_CUIPO"/>
			<with-param name="CODIGO_CPC_CUIPO" query-param="CODIGO_CPC_CUIPO"/>
			<with-param name="POLITCA_PUBLICA_CUIPO" query-param="POLITCA_PUBLICA_CUIPO"/>
			<with-param name="TERCERO_CHIP" query-param="TERCERO_CHIP"/>
			<with-param name="APLICA_DEST_ESPECIFICA" query-param="APLICA_DEST_ESPECIFICA"/>
			<with-param name="TIPO_NORMA" query-param="TIPO_NORMA"/>
			<with-param name="NUMERO_NORMA" query-param="NUMERO_NORMA"/>
			<with-param name="FECHA_NORMA" query-param="FECHA_NORMA"/>
			<with-param name="CODIGO_PRODUCTO_CUIPO" query-param="CODIGO_PRODUCTO_CUIPO"/>
			<with-param name="SECCION_PPTAL_CUIPO" query-param="SECCION_PPTAL_CUIPO"/>
			<with-param name="VALOR_NORMA" query-param="VALOR_NORMA"/>
			<with-param name="TRANSFERENCIA" query-param="TRANSFERENCIA"/>
			<with-param name="TIPO_RECURSO_SGR" query-param="TIPO_RECURSO_SGR"/>
			<with-param name="DETALLE_SECTORIAL" query-param="DETALLE_SECTORIAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_AUXILIAR" query-param="KEY_AUXILIAR"/>
			<with-param name="KEY_REFERENCIA" query-param="KEY_REFERENCIA"/>
			<with-param name="KEY_FUENTE_RECURSO" query-param="KEY_FUENTE_RECURSO"/>

		</call-query>
