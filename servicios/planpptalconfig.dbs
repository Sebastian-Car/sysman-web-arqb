	<query id="getPlanpptalconfigNumFutCategoriasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_PPTAL_CONFIG.COMPANIA, PLAN_PPTAL_CONFIG.ANO, PLAN_PPTAL_CONFIG.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PPTAL_CONFIG.DESTINO, CASE PLAN_PPTAL_CONFIG.DESTINO WHEN 'F' THEN 'Funcionamiento' WHEN 'I' THEN 'Inversión' WHEN 'S' THEN 'Servicio de la Deuda' WHEN 'I' THEN 'Libre destinación' END NOMDESTINO, PLAN_PPTAL_CONFIG.CODIGOFUT_H, PLAN_PPTAL_CONFIG.FUENTE_FLS, FUENTESFUTCATEGORIAS.NOMBRE_FUT, PLAN_PPTAL_CONFIG.HECHOVICTIMIZANTE, HECHOVICTIMIZANTE.NOMBRE NOMBRE_HECHO, PLAN_PPTAL_CONFIG.TIPO_FUTSALUD, PLAN_PPTAL_CONFIG.TIPOVIGENCIA, PLAN_PPTAL_CONFIG.FUENTE  FROM PLAN_PPTAL_CONFIG INNER JOIN PLAN_PRESUPUESTAL ON PLAN_PPTAL_CONFIG.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = PLAN_PRESUPUESTAL.ANO AND PLAN_PPTAL_CONFIG.CODIGO = PLAN_PRESUPUESTAL.CODIGO LEFT JOIN HECHOVICTIMIZANTE ON PLAN_PPTAL_CONFIG.COMPANIA = HECHOVICTIMIZANTE.COMPANIA AND PLAN_PPTAL_CONFIG.HECHOVICTIMIZANTE = HECHOVICTIMIZANTE.CODIGO AND PLAN_PPTAL_CONFIG.ANO = HECHOVICTIMIZANTE.ANO LEFT JOIN FUENTESFUTCATEGORIAS ON PLAN_PPTAL_CONFIG.COMPANIA = FUENTESFUTCATEGORIAS.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = FUENTESFUTCATEGORIAS.ANO AND PLAN_PPTAL_CONFIG.FUENTE_FLS = FUENTESFUTCATEGORIAS.CODIGO_FUT WHERE PLAN_PPTAL_CONFIG.COMPANIA = :COMPANIA AND PLAN_PPTAL_CONFIG.ANO = :ANO AND NVL(PLAN_PPTAL_CONFIG.DESTINO,'-')= CASE WHEN (:DESTINO) IS NOT NULL THEN (:DESTINO) ELSE NVL(PLAN_PPTAL_CONFIG.DESTINO,'-') END AND NVL(PLAN_PPTAL_CONFIG.NATURALEZA, '-') = CASE WHEN (:NATURALEZA) IS NOT NULL THEN (:NATURALEZA) ELSE NVL(PLAN_PPTAL_CONFIG.NATURALEZA,'-') END AND PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN(0) ORDER BY PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMDESTINO IS NULL THEN ' ' ELSE UPPER(NOMDESTINO) END)  LIKE UPPER( '%' || :NOMDESTINO || '%')  AND (CASE WHEN CODIGOFUT_H IS NULL THEN ' ' ELSE UPPER(CODIGOFUT_H) END)  LIKE UPPER( '%' || :CODIGOFUT_H || '%')  AND (CASE WHEN NOMBRE_FUT IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUT) END)  LIKE UPPER( '%' || :NOMBRE_FUT || '%')  AND (CASE WHEN NOMBRE_HECHO IS NULL THEN ' ' ELSE UPPER(NOMBRE_HECHO) END)  LIKE UPPER( '%' || :NOMBRE_HECHO || '%')  AND (CASE WHEN TIPO_FUTSALUD IS NULL THEN ' ' ELSE UPPER(TIPO_FUTSALUD) END)  LIKE UPPER( '%' || :TIPO_FUTSALUD || '%')  AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END)  LIKE UPPER( '%' || :TIPOVIGENCIA || '%')  AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER( '%' || :FUENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMDESTINO" sqlType="STRING"/>
		<param name="CODIGOFUT_H" sqlType="STRING"/>
		<param name="NOMBRE_FUT" sqlType="STRING"/>
		<param name="NOMBRE_HECHO" sqlType="STRING"/>
		<param name="TIPO_FUTSALUD" sqlType="STRING"/>
		<param name="TIPOVIGENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>

	</query>
