	</resource>
	<query id="getPlanpptalconfigNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT PLAN_PPTAL_CONFIG.COMPANIA, V_PLAN_PRESUPUESTAL.CODIGO, PLAN_PPTAL_CONFIG.ANO, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO, V_PLAN_PRESUPUESTAL.NOMBRE, PLAN_PPTAL_CONFIG.CODIGOSCHIP, PLAN_PPTAL_CONFIG.RECURSOSCHIP, PLAN_PPTAL_CONFIG.ORIGENESPECIFICOINGRESOS, PLAN_PPTAL_CONFIG.DESTINACIONDELOSRECURSOS, PLAN_PPTAL_CONFIG.FINALIDADGASTO, PLAN_PPTAL_CONFIG.CENTRO_COSTO, PLAN_PPTAL_CONFIG.TERCERO, PLAN_PPTAL_CONFIG.SUCURSAL, PLAN_PPTAL_CONFIG.AUXILIAR, PLAN_PPTAL_CONFIG.REFERENCIA, PLAN_PPTAL_CONFIG.DEPENDENCIASCHIP,(CASE V_PLAN_PRESUPUESTAL.CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS, PLAN_PPTAL_CONFIG.VIGENCIAGASTO, PLAN_PPTAL_CONFIG.VIGENCIATESORERIASCHIP, PLAN_PPTAL_CONFIG.CR1_RESGUARDOSCHIP, PLAN_PPTAL_CONFIG.CODIGOSIRECI,(CASE PLAN_PPTAL_CONFIG.RECAUDO_VA WHEN 0 THEN 'false' ELSE 'true' END) RECAUDO_VA, PLAN_PPTAL_CONFIG.COD_RECIPROCA, PLAN_PPTAL_CONFIG.CODIGO_BPIN_SGR, PLAN_PPTAL_CONFIG.CODIGO_CCEPT, PLAN_PPTAL_CONFIG.FUENTE_CUIPO, PLAN_PPTAL_CONFIG.SECTOR_CUIPO, PLAN_PPTAL_CONFIG.PROGRAMA_CUIPO, PLAN_PPTAL_CONFIG.CODIGO_CPC_CUIPO, PLAN_PPTAL_CONFIG.POLITCA_PUBLICA_CUIPO, PLAN_PPTAL_CONFIG.TERCERO_CHIP,(CASE V_PLAN_PRESUPUESTAL.APLICA_DEST_ESPECIFICA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DEST_ESPECIFICA, V_PLAN_PRESUPUESTAL.TIPO_NORMA, V_PLAN_PRESUPUESTAL.NUMERO_NORMA,(TO_CHAR(V_PLAN_PRESUPUESTAL.FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_NORMA, PLAN_PPTAL_CONFIG.CODIGO_PRODUCTO_CUIPO, PLAN_PPTAL_CONFIG.SECCION_PPTAL_CUIPO, V_PLAN_PRESUPUESTAL.VALOR_NORMA,(CASE V_PLAN_PRESUPUESTAL.TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TRANSFERENCIA, PLAN_PPTAL_CONFIG.TIPO_RECURSO_SGR, PLAN_PPTAL_CONFIG.DETALLE_SECTORIAL FROM PLAN_PPTAL_CONFIG INNER JOIN V_PLAN_PRESUPUESTAL ON PLAN_PPTAL_CONFIG.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = V_PLAN_PRESUPUESTAL.ANO AND PLAN_PPTAL_CONFIG.CODIGO = V_PLAN_PRESUPUESTAL.CODIGO AND PLAN_PPTAL_CONFIG.AUXILIAR = V_PLAN_PRESUPUESTAL.AUXILIAR AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO = V_PLAN_PRESUPUESTAL.FUENTE_RECURSO AND PLAN_PPTAL_CONFIG.REFERENCIA = V_PLAN_PRESUPUESTAL.REFERENCIA AND PLAN_PPTAL_CONFIG.CENTRO_COSTO = V_PLAN_PRESUPUESTAL.CENTRO_COSTO INNER JOIN SALDO_AUX_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = SALDO_AUX_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = SALDO_AUX_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.CODIGO = SALDO_AUX_PPTAL.CODIGO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = SALDO_AUX_PPTAL.CENTRO_COSTO AND V_PLAN_PRESUPUESTAL.AUXILIAR = SALDO_AUX_PPTAL.AUXILIAR AND V_PLAN_PRESUPUESTAL.REFERENCIA = SALDO_AUX_PPTAL.REFERENCIA AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = SALDO_AUX_PPTAL.FUENTE_RECURSO WHERE PLAN_PPTAL_CONFIG.COMPANIA = :COMPANIA AND PLAN_PPTAL_CONFIG.ANO = :ANO AND PLAN_PPTAL_CONFIG.NATURALEZA = :NATURALEZA AND ( ( :REGALIAS IN ( 'R' ) AND V_PLAN_PRESUPUESTAL.REGALIAS NOT IN ( 0 ) ) OR ( :REGALIAS NOT IN ( 'R' ) AND V_PLAN_PRESUPUESTAL.REGALIAS IN ( 0 ) ) ) AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN ( 0 ) AND ( V_PLAN_PRESUPUESTAL.FUENTE_RECURSO NOT IN ( PCK_DATOS.FC_CONS_FUENTE() ) OR V_PLAN_PRESUPUESTAL.CENTRO_COSTO NOT IN ( PCK_DATOS.FC_CONS_CENTRO() ) OR V_PLAN_PRESUPUESTAL.AUXILIAR NOT IN ( PCK_DATOS.FC_CONS_AUXILIAR() ) OR V_PLAN_PRESUPUESTAL.REFERENCIA NOT IN ( PCK_DATOS.FC_CONS_REFERENCIA() ) OR V_PLAN_PRESUPUESTAL.CODIGO = V_PLAN_PRESUPUESTAL.ID ) ORDER BY 2) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN CODIGOSCHIP IS NULL THEN ' ' ELSE UPPER(CODIGOSCHIP) END) LIKE UPPER(CONCAT(:CODIGOSCHIP, '%')) AND (CASE WHEN ORIGENESPECIFICOINGRESOS IS NULL THEN ' ' ELSE UPPER(ORIGENESPECIFICOINGRESOS) END) LIKE UPPER(CONCAT(:ORIGENESPECIFICOINGRESOS, '%')) AND (CASE WHEN DESTINACIONDELOSRECURSOS IS NULL THEN ' ' ELSE UPPER(DESTINACIONDELOSRECURSOS) END) LIKE UPPER(CONCAT(:DESTINACIONDELOSRECURSOS, '%')) AND (CASE WHEN FINALIDADGASTO IS NULL THEN ' ' ELSE UPPER(FINALIDADGASTO) END) LIKE UPPER(CONCAT(:FINALIDADGASTO, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN DEPENDENCIASCHIP IS NULL THEN ' ' ELSE UPPER(DEPENDENCIASCHIP) END) LIKE UPPER(CONCAT(:DEPENDENCIASCHIP, '%')) AND (CASE WHEN CONSITUACIONFONDOS IS NULL THEN ' ' ELSE UPPER(CONSITUACIONFONDOS) END) LIKE UPPER(CONCAT(:CONSITUACIONFONDOS, '%')) AND (CASE WHEN VIGENCIAGASTO IS NULL THEN ' ' ELSE UPPER(VIGENCIAGASTO) END) LIKE UPPER(CONCAT(:VIGENCIAGASTO, '%')) AND (CASE WHEN VIGENCIATESORERIASCHIP IS NULL THEN ' ' ELSE UPPER(VIGENCIATESORERIASCHIP) END) LIKE UPPER(CONCAT(:VIGENCIATESORERIASCHIP, '%')) AND (CASE WHEN CR1_RESGUARDOSCHIP IS NULL THEN ' ' ELSE UPPER(CR1_RESGUARDOSCHIP) END) LIKE UPPER(CONCAT(:CR1_RESGUARDOSCHIP, '%')) AND (CASE WHEN CODIGOSIRECI IS NULL THEN ' ' ELSE UPPER(CODIGOSIRECI) END) LIKE UPPER(CONCAT(:CODIGOSIRECI, '%')) AND (CASE WHEN RECAUDO_VA IS NULL THEN ' ' ELSE UPPER(RECAUDO_VA) END) LIKE UPPER(CONCAT(:RECAUDO_VA, '%')) AND (CASE WHEN COD_RECIPROCA IS NULL THEN ' ' ELSE UPPER(COD_RECIPROCA) END) LIKE UPPER(CONCAT(:COD_RECIPROCA, '%')) AND (CASE WHEN CODIGO_BPIN_SGR IS NULL THEN ' ' ELSE UPPER(CODIGO_BPIN_SGR) END) LIKE UPPER(CONCAT(:CODIGO_BPIN_SGR, '%')) AND (CASE WHEN CODIGO_CCEPT IS NULL THEN ' ' ELSE UPPER(CODIGO_CCEPT) END) LIKE UPPER(CONCAT(:CODIGO_CCEPT, '%')) AND (CASE WHEN FUENTE_CUIPO IS NULL THEN ' ' ELSE UPPER(FUENTE_CUIPO) END) LIKE UPPER(CONCAT(:FUENTE_CUIPO, '%')) AND (CASE WHEN SECTOR_CUIPO IS NULL THEN ' ' ELSE UPPER(SECTOR_CUIPO) END) LIKE UPPER(CONCAT(:SECTOR_CUIPO, '%')) AND (CASE WHEN PROGRAMA_CUIPO IS NULL THEN ' ' ELSE UPPER(PROGRAMA_CUIPO) END) LIKE UPPER(CONCAT(:PROGRAMA_CUIPO, '%')) AND (CASE WHEN CODIGO_CPC_CUIPO IS NULL THEN ' ' ELSE UPPER(CODIGO_CPC_CUIPO) END) LIKE UPPER(CONCAT(:CODIGO_CPC_CUIPO, '%')) AND (CASE WHEN POLITCA_PUBLICA_CUIPO IS NULL THEN ' ' ELSE UPPER(POLITCA_PUBLICA_CUIPO) END) LIKE UPPER(CONCAT(:POLITCA_PUBLICA_CUIPO, '%')) AND (CASE WHEN TERCERO_CHIP IS NULL THEN ' ' ELSE UPPER(TERCERO_CHIP) END) LIKE UPPER(CONCAT(:TERCERO_CHIP, '%')) AND (CASE WHEN APLICA_DEST_ESPECIFICA IS NULL THEN ' ' ELSE UPPER(APLICA_DEST_ESPECIFICA) END) LIKE UPPER(CONCAT(:APLICA_DEST_ESPECIFICA, '%')) AND (CASE WHEN TIPO_NORMA IS NULL THEN ' ' ELSE UPPER(TIPO_NORMA) END) LIKE UPPER(CONCAT(:TIPO_NORMA, '%')) AND (CASE WHEN NUMERO_NORMA IS NULL THEN ' ' ELSE UPPER(NUMERO_NORMA) END) LIKE UPPER(CONCAT(:NUMERO_NORMA, '%')) AND (CASE WHEN FECHA_NORMA IS NULL THEN ' ' ELSE UPPER(FECHA_NORMA) END) LIKE UPPER(CONCAT(:FECHA_NORMA, '%')) AND (CASE WHEN CODIGO_PRODUCTO_CUIPO IS NULL THEN ' ' ELSE UPPER(CODIGO_PRODUCTO_CUIPO) END) LIKE UPPER(CONCAT(:CODIGO_PRODUCTO_CUIPO, '%')) AND (CASE WHEN SECCION_PPTAL_CUIPO IS NULL THEN ' ' ELSE UPPER(SECCION_PPTAL_CUIPO) END) LIKE UPPER(CONCAT(:SECCION_PPTAL_CUIPO, '%')) AND (CASE WHEN VALOR_NORMA IS NULL THEN ' ' ELSE UPPER(VALOR_NORMA) END) LIKE UPPER(CONCAT(:VALOR_NORMA, '%')) AND (CASE WHEN TRANSFERENCIA IS NULL THEN ' ' ELSE UPPER(TRANSFERENCIA) END) LIKE UPPER(CONCAT(:TRANSFERENCIA, '%')) AND (CASE WHEN TIPO_RECURSO_SGR IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSO_SGR) END) LIKE UPPER(CONCAT(:TIPO_RECURSO_SGR, '%')) AND (CASE WHEN DETALLE_SECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLE_SECTORIAL) END) LIKE UPPER(CONCAT(:DETALLE_SECTORIAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOSCHIP" sqlType="STRING"/>
		<param name="ORIGENESPECIFICOINGRESOS" sqlType="STRING"/>
		<param name="DESTINACIONDELOSRECURSOS" sqlType="STRING"/>
		<param name="FINALIDADGASTO" sqlType="STRING"/>
