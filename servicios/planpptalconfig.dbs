			<with-param name="CR1_RESGUARDOSCHIP" query-param="CR1_RESGUARDOSCHIP"/>
			<with-param name="CODIGOSIRECI" query-param="CODIGOSIRECI"/>
			<with-param name="RECAUDO_VA" query-param="RECAUDO_VA"/>
			<with-param name="COD_RECIPROCA" query-param="COD_RECIPROCA"/>
			<with-param name="CODIGO_BPIN_SGR" query-param="CODIGO_BPIN_SGR"/>
			<with-param name="CODIGO_CCEPT" query-param="CODIGO_CCEPT"/>
			<with-param name="FUENTE_CUIPO" query-param="FUENTE_CUIPO"/>
