	<query id="getPlanpptalconfigPagGrillareclasificacioncierreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_PPTAL_CONFIG.COMPANIA, PLAN_PPTAL_CONFIG.ANO, PLAN_PPTAL_CONFIG.CODIGO, SALDOS.NOMBRE_RUBRO, PLAN_PPTAL_CONFIG.FUENTE_RECURSO, PLAN_PPTAL_CONFIG.REFERENCIA, PLAN_PPTAL_CONFIG.CENTRO_COSTO, PLAN_PPTAL_CONFIG.AUXILIAR, PLAN_PPTAL_CONFIG.TERCERO, PLAN_PPTAL_CONFIG.SUCURSAL, SALDOS.SALDO, SALDOS.TIPOVIGENCIA, PLAN_PPTAL_CONFIG.ANO_CIERRE, PLAN_PPTAL_CONFIG.RES_CODIGO_CIERRE, PLAN_PPTAL_CONFIG.RES_FUENTE_RECURSO_CIERRE, PLAN_PPTAL_CONFIG.RES_REFERENCIA_CIERRE, PLAN_PPTAL_CONFIG.RES_CENTRO_COSTO_CIERRE, PLAN_PPTAL_CONFIG.RES_AUXILIAR_CIERRE, PLAN_PPTAL_CONFIG.REO_CODIGO_CIERRE, PLAN_PPTAL_CONFIG.REO_FUENTE_RECURSO_CIERRE, PLAN_PPTAL_CONFIG.REO_REFERENCIA_CIERRE, PLAN_PPTAL_CONFIG.REO_CENTRO_COSTO_CIERRE, PLAN_PPTAL_CONFIG.REO_AUXILIAR_CIERRE FROM PLAN_PPTAL_CONFIG INNER JOIN (SELECT DP.COMPANIA, DP.ANO, DP.CUENTA, PP.NOMBRE NOMBRE_RUBRO, TIPOV.NOMBRE TIPOVIGENCIA, CASE WHEN PP.MAN_CEN_CTO IN(0) THEN PCK_DATOS.FC_CONS_CENTRO ELSE DP.CENTRO_COSTO END CENTRO_COSTO, CASE WHEN PP.MAN_AUX_TER IN(0) THEN PCK_DATOS.FC_CONS_TERCERO ELSE DP.TERCERO END TERCERO, CASE WHEN PP.MAN_AUX_TER IN(0) THEN PCK_DATOS.FC_CONS_SUCURSAL ELSE DP.SUCURSAL END SUCURSAL, CASE WHEN PP.MAN_AUX_GEN IN(0) THEN PCK_DATOS.FC_CONS_AUXILIAR ELSE DP.AUXILIAR END AUXILIAR, CASE WHEN PP.MAN_AUX_FUE IN(0) THEN PCK_DATOS.FC_CONS_FUENTE ELSE DP.FUENTE_RECURSO END FUENTE_RECURSO, CASE WHEN PP.MAN_AUX_REF IN(0) THEN PCK_DATOS.FC_CONS_REFERENCIA ELSE DP.REFERENCIA END REFERENCIA, SUM((DP.VALOR_DEBITO - DP.VALOR_CREDITO ) - (DP.DEBITO_AFECTADO - DP.CREDITO_AFECTADO ) + (DP.MODIFICACION_DEBITO - DP.MODIFICACION_CREDITO)) SALDO FROM DETALLE_COMPROBANTE_PPTAL DP INNER JOIN PLAN_PRESUPUESTAL PP ON DP.COMPANIA = PP.COMPANIA AND DP.ANO = PP.ANO AND DP.CUENTA = PP.CODIGO INNER JOIN TIPO_COMPROBPP TC ON DP.COMPANIA = TC.COMPANIA AND DP.TIPO_CPTE = TC.CODIGO INNER JOIN TIPOVIGENCIA TIPOV ON PP.TIPOVIGENCIA = TIPOV.CODIGO WHERE DP.COMPANIA = :COMPANIA AND DP.ANO = :ANO AND PP.NATURALEZA = 'D' AND TC.CLASE = CASE WHEN :CLASE = 'APROPIACION' THEN 'RES' ELSE CASE WHEN :CLASE = 'CAJA' THEN 'REO' ELSE TC.CLASE END END AND PP.TIPOVIGENCIA IN(CASE WHEN :TIPOCIERRE = 'REG' AND :VIGENCIA IS NULL THEN PP.TIPOVIGENCIA ELSE :VIGENCIA END) AND PP.REGALIAS = CASE WHEN :TIPOCIERRE = 'REG' THEN -1 ELSE 0 END AND ((DP.VALOR_DEBITO - DP.VALOR_CREDITO ) - (DP.DEBITO_AFECTADO - DP.CREDITO_AFECTADO ) + (DP.MODIFICACION_DEBITO - DP.MODIFICACION_CREDITO))&gt;0 GROUP BY DP.COMPANIA, DP.ANO, DP.CUENTA, PP.NOMBRE, TIPOV.NOMBRE, CASE WHEN PP.MAN_CEN_CTO IN(0) THEN PCK_DATOS.FC_CONS_CENTRO ELSE DP.CENTRO_COSTO END , CASE WHEN PP.MAN_AUX_TER IN(0) THEN PCK_DATOS.FC_CONS_TERCERO ELSE DP.TERCERO END , CASE WHEN PP.MAN_AUX_TER IN(0) THEN PCK_DATOS.FC_CONS_SUCURSAL ELSE DP.SUCURSAL END , CASE WHEN PP.MAN_AUX_GEN IN(0) THEN PCK_DATOS.FC_CONS_AUXILIAR ELSE DP.AUXILIAR END , CASE WHEN PP.MAN_AUX_FUE IN(0) THEN PCK_DATOS.FC_CONS_FUENTE ELSE DP.FUENTE_RECURSO END , CASE WHEN PP.MAN_AUX_REF IN(0) THEN PCK_DATOS.FC_CONS_REFERENCIA ELSE DP.REFERENCIA END ) SALDOS ON PLAN_PPTAL_CONFIG.COMPANIA = SALDOS.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = SALDOS.ANO AND PLAN_PPTAL_CONFIG.CODIGO = SALDOS.CUENTA AND PLAN_PPTAL_CONFIG.TERCERO = SALDOS.TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL = SALDOS.SUCURSAL AND PLAN_PPTAL_CONFIG.CENTRO_COSTO = SALDOS.CENTRO_COSTO AND PLAN_PPTAL_CONFIG.AUXILIAR = SALDOS.AUXILIAR AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO = SALDOS.FUENTE_RECURSO AND PLAN_PPTAL_CONFIG.REFERENCIA = SALDOS.REFERENCIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE_RUBRO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RUBRO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RUBRO), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOVIGENCIA), '%')) AND (CASE WHEN RES_CODIGO_CIERRE IS NULL THEN ' ' ELSE UPPER(RES_CODIGO_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:RES_CODIGO_CIERRE), '%')) AND (CASE WHEN RES_FUENTE_RECURSO_CIERRE IS NULL THEN ' ' ELSE UPPER(RES_FUENTE_RECURSO_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:RES_FUENTE_RECURSO_CIERRE), '%')) AND (CASE WHEN RES_REFERENCIA_CIERRE IS NULL THEN ' ' ELSE UPPER(RES_REFERENCIA_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:RES_REFERENCIA_CIERRE), '%')) AND (CASE WHEN RES_CENTRO_COSTO_CIERRE IS NULL THEN ' ' ELSE UPPER(RES_CENTRO_COSTO_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:RES_CENTRO_COSTO_CIERRE), '%')) AND (CASE WHEN RES_AUXILIAR_CIERRE IS NULL THEN ' ' ELSE UPPER(RES_AUXILIAR_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:RES_AUXILIAR_CIERRE), '%')) AND (CASE WHEN REO_CODIGO_CIERRE IS NULL THEN ' ' ELSE UPPER(REO_CODIGO_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:REO_CODIGO_CIERRE), '%')) AND (CASE WHEN REO_FUENTE_RECURSO_CIERRE IS NULL THEN ' ' ELSE UPPER(REO_FUENTE_RECURSO_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:REO_FUENTE_RECURSO_CIERRE), '%')) AND (CASE WHEN REO_REFERENCIA_CIERRE IS NULL THEN ' ' ELSE UPPER(REO_REFERENCIA_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:REO_REFERENCIA_CIERRE), '%')) AND (CASE WHEN REO_CENTRO_COSTO_CIERRE IS NULL THEN ' ' ELSE UPPER(REO_CENTRO_COSTO_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:REO_CENTRO_COSTO_CIERRE), '%')) AND (CASE WHEN REO_AUXILIAR_CIERRE IS NULL THEN ' ' ELSE UPPER(REO_AUXILIAR_CIERRE) END) LIKE UPPER(CONCAT(CONCAT('%',:REO_AUXILIAR_CIERRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE_RUBRO":"$NOMBRE_RUBRO","FUENTE_RECURSO":"$FUENTE_RECURSO","REFERENCIA":"$REFERENCIA","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","SALDO":"$SALDO(type:double)","TIPOVIGENCIA":"$TIPOVIGENCIA","ANO_CIERRE":"$ANO_CIERRE(type:integer)","RES_CODIGO_CIERRE":"$RES_CODIGO_CIERRE","RES_FUENTE_RECURSO_CIERRE":"$RES_FUENTE_RECURSO_CIERRE","RES_REFERENCIA_CIERRE":"$RES_REFERENCIA_CIERRE","RES_CENTRO_COSTO_CIERRE":"$RES_CENTRO_COSTO_CIERRE","RES_AUXILIAR_CIERRE":"$RES_AUXILIAR_CIERRE","REO_CODIGO_CIERRE":"$REO_CODIGO_CIERRE","REO_FUENTE_RECURSO_CIERRE":"$REO_FUENTE_RECURSO_CIERRE","REO_REFERENCIA_CIERRE":"$REO_REFERENCIA_CIERRE","REO_CENTRO_COSTO_CIERRE":"$REO_CENTRO_COSTO_CIERRE","REO_AUXILIAR_CIERRE":"$REO_AUXILIAR_CIERRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPOCIERRE" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_RUBRO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="TIPOVIGENCIA" sqlType="STRING"/>
		<param name="RES_CODIGO_CIERRE" sqlType="STRING"/>
		<param name="RES_FUENTE_RECURSO_CIERRE" sqlType="STRING"/>
		<param name="RES_REFERENCIA_CIERRE" sqlType="STRING"/>
		<param name="RES_CENTRO_COSTO_CIERRE" sqlType="STRING"/>
		<param name="RES_AUXILIAR_CIERRE" sqlType="STRING"/>
		<param name="REO_CODIGO_CIERRE" sqlType="STRING"/>
		<param name="REO_FUENTE_RECURSO_CIERRE" sqlType="STRING"/>
		<param name="REO_REFERENCIA_CIERRE" sqlType="STRING"/>
		<param name="REO_CENTRO_COSTO_CIERRE" sqlType="STRING"/>
		<param name="REO_AUXILIAR_CIERRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planpptalconfig/grillareclasificacioncierre/pag">
		<call-query href="getPlanpptalconfigPagGrillareclasificacioncierreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPOCIERRE" query-param="TIPOCIERRE"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_RUBRO" query-param="NOMBRE_RUBRO"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="SALDO" query-param="SALDO"/>
