		<sql>INSERT INTO PLAN_PPTAL_CONFIG (COMPANIA, ANO, CODIGO, CENTRO_COSTO, TERCERO, SUCURSAL, AUXILIAR, REFERENCIA, FUENTE_RECURSO, CODIGOSCHIP, RECURSOSCHIP, ORIGENESPECIFICOINGRESOS, DESTINACIONDELOSRECURSOS, FINALIDADGASTO, VIGENCIAGASTO, DEPENDENCIASCHIP, SITUACIONFONDOSSCHIP, VIGENCIATESORERIASCHIP, NATURALEZA, CR1_RESGUARDOSCHIP, CODIGOSIRECI, COD_RECIPROCA, RECAUDO_VA, RUBRO_EQUIV, FUENTE_PREDIS, DET_FUENTE_PREDIS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :CENTRO_COSTO, :TERCERO, :SUCURSAL, :AUXILIAR, :REFERENCIA, :FUENTE_RECURSO, :CODIGOSCHIP, :RECURSOSCHIP, :ORIGENESPECIFICOINGRESOS, :DESTINACIONDELOSRECURSOS, :FINALIDADGASTO, :VIGENCIAGASTO, :DEPENDENCIASCHIP, :SITUACIONFONDOSSCHIP, :VIGENCIATESORERIASCHIP, :NATURALEZA, :CR1_RESGUARDOSCHIP, :CODIGOSIRECI, :COD_RECIPROCA, :RECAUDO_VA, :RUBRO_EQUIV, :FUENTE_PREDIS, :DET_FUENTE_PREDIS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO","KEY_CENTRO_COSTO":"$CENTRO_COSTO","KEY_TERCERO":"$TERCERO","KEY_SUCURSAL":"$SUCURSAL","KEY_AUXILIAR":"$AUXILIAR","KEY_REFERENCIA":"$REFERENCIA","KEY_FUENTE_RECURSO":"$FUENTE_RECURSO"}]}}		</result>
