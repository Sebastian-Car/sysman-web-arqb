		<sql>DELETE FROM PLAN_PPTAL_CONFIG WHERE PLAN_PPTAL_CONFIG.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CONFIG.ANO= :KEY_ANO AND PLAN_PPTAL_CONFIG.CODIGO= :KEY_CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO= :KEY_CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO= :KEY_TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL= :KEY_SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR= :KEY_AUXILIAR AND PLAN_PPTAL_CONFIG.REFERENCIA= :KEY_REFERENCIA AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_AUXILIAR" sqlType="STRING"/>
		<param name="KEY_REFERENCIA" sqlType="STRING"/>
		<param name="KEY_FUENTE_RECURSO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="planpptalconfig">
		<call-query href="deletePlanpptalconfig">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_AUXILIAR" query-param="KEY_AUXILIAR"/>
			<with-param name="KEY_REFERENCIA" query-param="KEY_REFERENCIA"/>
			<with-param name="KEY_FUENTE_RECURSO" query-param="KEY_FUENTE_RECURSO"/>

		</call-query>
	</resource>
	<query id="getPlanpptalconfigPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT PLAN_PPTAL_CONFIG.COMPANIA, V_PLAN_PRESUPUESTAL.CODIGO, PLAN_PPTAL_CONFIG.ANO, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO, V_PLAN_PRESUPUESTAL.NOMBRE, PLAN_PPTAL_CONFIG.CODIGOSCHIP, PLAN_PPTAL_CONFIG.RECURSOSCHIP, PLAN_PPTAL_CONFIG.ORIGENESPECIFICOINGRESOS, PLAN_PPTAL_CONFIG.DESTINACIONDELOSRECURSOS, PLAN_PPTAL_CONFIG.FINALIDADGASTO, PLAN_PPTAL_CONFIG.CENTRO_COSTO, PLAN_PPTAL_CONFIG.TERCERO, PLAN_PPTAL_CONFIG.SUCURSAL, PLAN_PPTAL_CONFIG.AUXILIAR, PLAN_PPTAL_CONFIG.REFERENCIA, PLAN_PPTAL_CONFIG.DEPENDENCIASCHIP,(CASE V_PLAN_PRESUPUESTAL.CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS, PLAN_PPTAL_CONFIG.VIGENCIAGASTO, PLAN_PPTAL_CONFIG.VIGENCIATESORERIASCHIP, PLAN_PPTAL_CONFIG.CR1_RESGUARDOSCHIP, PLAN_PPTAL_CONFIG.CODIGOSIRECI,(CASE PLAN_PPTAL_CONFIG.RECAUDO_VA WHEN 0 THEN 'false' ELSE 'true' END) RECAUDO_VA, PLAN_PPTAL_CONFIG.COD_RECIPROCA, PLAN_PPTAL_CONFIG.CODIGO_BPIN_SGR, PLAN_PPTAL_CONFIG.CODIGO_CCEPT, PLAN_PPTAL_CONFIG.FUENTE_CUIPO, PLAN_PPTAL_CONFIG.SECTOR_CUIPO, PLAN_PPTAL_CONFIG.PROGRAMA_CUIPO, PLAN_PPTAL_CONFIG.CODIGO_CPC_CUIPO, PLAN_PPTAL_CONFIG.POLITCA_PUBLICA_CUIPO, PLAN_PPTAL_CONFIG.TERCERO_CHIP,(CASE V_PLAN_PRESUPUESTAL.APLICA_DEST_ESPECIFICA WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DEST_ESPECIFICA, V_PLAN_PRESUPUESTAL.TIPO_NORMA, V_PLAN_PRESUPUESTAL.NUMERO_NORMA,(TO_CHAR(V_PLAN_PRESUPUESTAL.FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_NORMA, PLAN_PPTAL_CONFIG.CODIGO_PRODUCTO_CUIPO, PLAN_PPTAL_CONFIG.SECCION_PPTAL_CUIPO, V_PLAN_PRESUPUESTAL.VALOR_NORMA,(CASE V_PLAN_PRESUPUESTAL.TRANSFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TRANSFERENCIA, PLAN_PPTAL_CONFIG.TIPO_RECURSO_SGR, PLAN_PPTAL_CONFIG.DETALLE_SECTORIAL FROM PLAN_PPTAL_CONFIG INNER JOIN V_PLAN_PRESUPUESTAL ON PLAN_PPTAL_CONFIG.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = V_PLAN_PRESUPUESTAL.ANO AND PLAN_PPTAL_CONFIG.CODIGO = V_PLAN_PRESUPUESTAL.CODIGO AND PLAN_PPTAL_CONFIG.AUXILIAR = V_PLAN_PRESUPUESTAL.AUXILIAR AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO = V_PLAN_PRESUPUESTAL.FUENTE_RECURSO AND PLAN_PPTAL_CONFIG.REFERENCIA = V_PLAN_PRESUPUESTAL.REFERENCIA AND PLAN_PPTAL_CONFIG.CENTRO_COSTO = V_PLAN_PRESUPUESTAL.CENTRO_COSTO INNER JOIN SALDO_AUX_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = SALDO_AUX_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = SALDO_AUX_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.CODIGO = SALDO_AUX_PPTAL.CODIGO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = SALDO_AUX_PPTAL.CENTRO_COSTO AND V_PLAN_PRESUPUESTAL.AUXILIAR = SALDO_AUX_PPTAL.AUXILIAR AND V_PLAN_PRESUPUESTAL.REFERENCIA = SALDO_AUX_PPTAL.REFERENCIA AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = SALDO_AUX_PPTAL.FUENTE_RECURSO WHERE PLAN_PPTAL_CONFIG.COMPANIA = :COMPANIA AND PLAN_PPTAL_CONFIG.ANO = :ANO AND PLAN_PPTAL_CONFIG.NATURALEZA = :NATURALEZA AND ( ( :REGALIAS IN ( 'R' ) AND V_PLAN_PRESUPUESTAL.REGALIAS NOT IN ( 0 ) ) OR ( :REGALIAS NOT IN ( 'R' ) AND V_PLAN_PRESUPUESTAL.REGALIAS IN ( 0 ) ) ) AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN ( 0 ) AND ( V_PLAN_PRESUPUESTAL.FUENTE_RECURSO NOT IN ( PCK_DATOS.FC_CONS_FUENTE() ) OR V_PLAN_PRESUPUESTAL.CENTRO_COSTO NOT IN ( PCK_DATOS.FC_CONS_CENTRO() ) OR V_PLAN_PRESUPUESTAL.AUXILIAR NOT IN ( PCK_DATOS.FC_CONS_AUXILIAR() ) OR V_PLAN_PRESUPUESTAL.REFERENCIA NOT IN ( PCK_DATOS.FC_CONS_REFERENCIA() ) OR V_PLAN_PRESUPUESTAL.CODIGO = V_PLAN_PRESUPUESTAL.ID ) ORDER BY 2) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN CODIGOSCHIP IS NULL THEN ' ' ELSE UPPER(CODIGOSCHIP) END) LIKE UPPER(CONCAT(:CODIGOSCHIP, '%')) AND (CASE WHEN ORIGENESPECIFICOINGRESOS IS NULL THEN ' ' ELSE UPPER(ORIGENESPECIFICOINGRESOS) END) LIKE UPPER(CONCAT(:ORIGENESPECIFICOINGRESOS, '%')) AND (CASE WHEN DESTINACIONDELOSRECURSOS IS NULL THEN ' ' ELSE UPPER(DESTINACIONDELOSRECURSOS) END) LIKE UPPER(CONCAT(:DESTINACIONDELOSRECURSOS, '%')) AND (CASE WHEN FINALIDADGASTO IS NULL THEN ' ' ELSE UPPER(FINALIDADGASTO) END) LIKE UPPER(CONCAT(:FINALIDADGASTO, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN DEPENDENCIASCHIP IS NULL THEN ' ' ELSE UPPER(DEPENDENCIASCHIP) END) LIKE UPPER(CONCAT(:DEPENDENCIASCHIP, '%')) AND (CASE WHEN CONSITUACIONFONDOS IS NULL THEN ' ' ELSE UPPER(CONSITUACIONFONDOS) END) LIKE UPPER(CONCAT(:CONSITUACIONFONDOS, '%')) AND (CASE WHEN VIGENCIAGASTO IS NULL THEN ' ' ELSE UPPER(VIGENCIAGASTO) END) LIKE UPPER(CONCAT(:VIGENCIAGASTO, '%')) AND (CASE WHEN VIGENCIATESORERIASCHIP IS NULL THEN ' ' ELSE UPPER(VIGENCIATESORERIASCHIP) END) LIKE UPPER(CONCAT(:VIGENCIATESORERIASCHIP, '%')) AND (CASE WHEN CR1_RESGUARDOSCHIP IS NULL THEN ' ' ELSE UPPER(CR1_RESGUARDOSCHIP) END) LIKE UPPER(CONCAT(:CR1_RESGUARDOSCHIP, '%')) AND (CASE WHEN CODIGOSIRECI IS NULL THEN ' ' ELSE UPPER(CODIGOSIRECI) END) LIKE UPPER(CONCAT(:CODIGOSIRECI, '%')) AND (CASE WHEN RECAUDO_VA IS NULL THEN ' ' ELSE UPPER(RECAUDO_VA) END) LIKE UPPER(CONCAT(:RECAUDO_VA, '%')) AND (CASE WHEN COD_RECIPROCA IS NULL THEN ' ' ELSE UPPER(COD_RECIPROCA) END) LIKE UPPER(CONCAT(:COD_RECIPROCA, '%')) AND (CASE WHEN CODIGO_BPIN_SGR IS NULL THEN ' ' ELSE UPPER(CODIGO_BPIN_SGR) END) LIKE UPPER(CONCAT(:CODIGO_BPIN_SGR, '%')) AND (CASE WHEN CODIGO_CCEPT IS NULL THEN ' ' ELSE UPPER(CODIGO_CCEPT) END) LIKE UPPER(CONCAT(:CODIGO_CCEPT, '%')) AND (CASE WHEN FUENTE_CUIPO IS NULL THEN ' ' ELSE UPPER(FUENTE_CUIPO) END) LIKE UPPER(CONCAT(:FUENTE_CUIPO, '%')) AND (CASE WHEN SECTOR_CUIPO IS NULL THEN ' ' ELSE UPPER(SECTOR_CUIPO) END) LIKE UPPER(CONCAT(:SECTOR_CUIPO, '%')) AND (CASE WHEN PROGRAMA_CUIPO IS NULL THEN ' ' ELSE UPPER(PROGRAMA_CUIPO) END) LIKE UPPER(CONCAT(:PROGRAMA_CUIPO, '%')) AND (CASE WHEN CODIGO_CPC_CUIPO IS NULL THEN ' ' ELSE UPPER(CODIGO_CPC_CUIPO) END) LIKE UPPER(CONCAT(:CODIGO_CPC_CUIPO, '%')) AND (CASE WHEN POLITCA_PUBLICA_CUIPO IS NULL THEN ' ' ELSE UPPER(POLITCA_PUBLICA_CUIPO) END) LIKE UPPER(CONCAT(:POLITCA_PUBLICA_CUIPO, '%')) AND (CASE WHEN TERCERO_CHIP IS NULL THEN ' ' ELSE UPPER(TERCERO_CHIP) END) LIKE UPPER(CONCAT(:TERCERO_CHIP, '%')) AND (CASE WHEN APLICA_DEST_ESPECIFICA IS NULL THEN ' ' ELSE UPPER(APLICA_DEST_ESPECIFICA) END) LIKE UPPER(CONCAT(:APLICA_DEST_ESPECIFICA, '%')) AND (CASE WHEN TIPO_NORMA IS NULL THEN ' ' ELSE UPPER(TIPO_NORMA) END) LIKE UPPER(CONCAT(:TIPO_NORMA, '%')) AND (CASE WHEN NUMERO_NORMA IS NULL THEN ' ' ELSE UPPER(NUMERO_NORMA) END) LIKE UPPER(CONCAT(:NUMERO_NORMA, '%')) AND (CASE WHEN FECHA_NORMA IS NULL THEN ' ' ELSE UPPER(FECHA_NORMA) END) LIKE UPPER(CONCAT(:FECHA_NORMA, '%')) AND (CASE WHEN CODIGO_PRODUCTO_CUIPO IS NULL THEN ' ' ELSE UPPER(CODIGO_PRODUCTO_CUIPO) END) LIKE UPPER(CONCAT(:CODIGO_PRODUCTO_CUIPO, '%')) AND (CASE WHEN SECCION_PPTAL_CUIPO IS NULL THEN ' ' ELSE UPPER(SECCION_PPTAL_CUIPO) END) LIKE UPPER(CONCAT(:SECCION_PPTAL_CUIPO, '%')) AND (CASE WHEN VALOR_NORMA IS NULL THEN ' ' ELSE UPPER(VALOR_NORMA) END) LIKE UPPER(CONCAT(:VALOR_NORMA, '%')) AND (CASE WHEN TRANSFERENCIA IS NULL THEN ' ' ELSE UPPER(TRANSFERENCIA) END) LIKE UPPER(CONCAT(:TRANSFERENCIA, '%')) AND (CASE WHEN TIPO_RECURSO_SGR IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSO_SGR) END) LIKE UPPER(CONCAT(:TIPO_RECURSO_SGR, '%')) AND (CASE WHEN DETALLE_SECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLE_SECTORIAL) END) LIKE UPPER(CONCAT(:DETALLE_SECTORIAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBRE":"$NOMBRE","CODIGOSCHIP":"$CODIGOSCHIP","RECURSOSCHIP":"$RECURSOSCHIP(type:integer)","ORIGENESPECIFICOINGRESOS":"$ORIGENESPECIFICOINGRESOS","DESTINACIONDELOSRECURSOS":"$DESTINACIONDELOSRECURSOS","FINALIDADGASTO":"$FINALIDADGASTO","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","DEPENDENCIASCHIP":"$DEPENDENCIASCHIP","CONSITUACIONFONDOS":"$CONSITUACIONFONDOS(type:boolean)","VIGENCIAGASTO":"$VIGENCIAGASTO(type:integer)","VIGENCIATESORERIASCHIP":"$VIGENCIATESORERIASCHIP(type:integer)","CR1_RESGUARDOSCHIP":"$CR1_RESGUARDOSCHIP","CODIGOSIRECI":"$CODIGOSIRECI","RECAUDO_VA":"$RECAUDO_VA(type:boolean)","COD_RECIPROCA":"$COD_RECIPROCA","CODIGO_BPIN_SGR":"$CODIGO_BPIN_SGR","CODIGO_CCEPT":"$CODIGO_CCEPT","FUENTE_CUIPO":"$FUENTE_CUIPO","SECTOR_CUIPO":"$SECTOR_CUIPO","PROGRAMA_CUIPO":"$PROGRAMA_CUIPO","CODIGO_CPC_CUIPO":"$CODIGO_CPC_CUIPO","POLITCA_PUBLICA_CUIPO":"$POLITCA_PUBLICA_CUIPO","TERCERO_CHIP":"$TERCERO_CHIP","APLICA_DEST_ESPECIFICA":"$APLICA_DEST_ESPECIFICA(type:boolean)","TIPO_NORMA":"$TIPO_NORMA","NUMERO_NORMA":"$NUMERO_NORMA","FECHA_NORMA":"$FECHA_NORMA","CODIGO_PRODUCTO_CUIPO":"$CODIGO_PRODUCTO_CUIPO","SECCION_PPTAL_CUIPO":"$SECCION_PPTAL_CUIPO","VALOR_NORMA":"$VALOR_NORMA(type:double)","TRANSFERENCIA":"$TRANSFERENCIA(type:boolean)","TIPO_RECURSO_SGR":"$TIPO_RECURSO_SGR","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOSCHIP" sqlType="STRING"/>
		<param name="ORIGENESPECIFICOINGRESOS" sqlType="STRING"/>
		<param name="DESTINACIONDELOSRECURSOS" sqlType="STRING"/>
		<param name="FINALIDADGASTO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="DEPENDENCIASCHIP" sqlType="STRING"/>
		<param name="CONSITUACIONFONDOS" sqlType="STRING"/>
		<param name="VIGENCIAGASTO" sqlType="STRING"/>
		<param name="VIGENCIATESORERIASCHIP" sqlType="STRING"/>
		<param name="CR1_RESGUARDOSCHIP" sqlType="STRING"/>
		<param name="CODIGOSIRECI" sqlType="STRING"/>
		<param name="RECAUDO_VA" sqlType="STRING"/>
		<param name="COD_RECIPROCA" sqlType="STRING"/>
		<param name="CODIGO_BPIN_SGR" sqlType="STRING"/>
		<param name="CODIGO_CCEPT" sqlType="STRING"/>
		<param name="FUENTE_CUIPO" sqlType="STRING"/>
		<param name="SECTOR_CUIPO" sqlType="STRING"/>
		<param name="PROGRAMA_CUIPO" sqlType="STRING"/>
		<param name="CODIGO_CPC_CUIPO" sqlType="STRING"/>
		<param name="POLITCA_PUBLICA_CUIPO" sqlType="STRING"/>
		<param name="TERCERO_CHIP" sqlType="STRING"/>
		<param name="APLICA_DEST_ESPECIFICA" sqlType="STRING"/>
		<param name="TIPO_NORMA" sqlType="STRING"/>
		<param name="NUMERO_NORMA" sqlType="STRING"/>
		<param name="FECHA_NORMA" sqlType="STRING"/>
		<param name="CODIGO_PRODUCTO_CUIPO" sqlType="STRING"/>
		<param name="SECCION_PPTAL_CUIPO" sqlType="STRING"/>
		<param name="VALOR_NORMA" sqlType="STRING"/>
		<param name="TRANSFERENCIA" sqlType="STRING"/>
		<param name="TIPO_RECURSO_SGR" sqlType="STRING"/>
		<param name="DETALLE_SECTORIAL" sqlType="STRING"/>
