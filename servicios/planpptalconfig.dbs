	<query id="getPlanpptalconfigNumListaConfiguracionchipDeudaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_PPTAL_CONFIG.COMPANIA, PLAN_PPTAL_CONFIG.ANO, PLAN_PPTAL_CONFIG.CENTRO_COSTO, PLAN_PPTAL_CONFIG.TERCERO, PLAN_PPTAL_CONFIG.SUCURSAL, PLAN_PPTAL_CONFIG.AUXILIAR, PLAN_PPTAL_CONFIG.REFERENCIA, PLAN_PPTAL_CONFIG.FUENTE_RECURSO, PLAN_PPTAL_CONFIG.SECTOR_REGALIAS, PLAN_PPTAL_CONFIG.CODIGO, V.NOMBRE, PLAN_PPTAL_CONFIG.FUENTE_FUT, PLAN_PPTAL_CONFIG.TIPODEUDA_FUT, PLAN_PPTAL_CONFIG.TIPOOPERACION_FUT, FUENTESFUT.NOMBREFU_FUT, CASE WHEN PLAN_PPTAL_CONFIG.TIPODEUDA_FUT = 1 THEN 'Interna' WHEN PLAN_PPTAL_CONFIG.TIPODEUDA_FUT = 2 THEN 'Externa' ELSE '' END TIPODEUDA_FUTNOM, CASE WHEN PLAN_PPTAL_CONFIG.TIPOOPERACION_FUT = 1 THEN 'Intereses' WHEN PLAN_PPTAL_CONFIG.TIPOOPERACION_FUT = 2 THEN 'Amortización' WHEN PLAN_PPTAL_CONFIG.TIPOOPERACION_FUT = 3 THEN 'Comisiones y Otros' ELSE '' END TIPOOPERACION_FUTNOM, PLAN_PPTAL_CONFIG.DESTINO  FROM PLAN_PPTAL_CONFIG INNER JOIN FUENTESFUT ON PLAN_PPTAL_CONFIG.COMPANIA = FUENTESFUT.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = FUENTESFUT.ANO AND PLAN_PPTAL_CONFIG.FUENTE_FUT = FUENTESFUT.CODIGOFU_FUT AND PLAN_PPTAL_CONFIG.DESTINO = FUENTESFUT.DESTINO INNER JOIN V_PLAN_PRESUPUESTAL V ON PLAN_PPTAL_CONFIG.COMPANIA =V.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = V.ANO AND PLAN_PPTAL_CONFIG.CODIGO = V.CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO = V.CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO = V.TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL = V.SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR = V.AUXILIAR AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO = V.FUENTE_RECURSO AND PLAN_PPTAL_CONFIG.REFERENCIA = V.REFERENCIA WHERE PLAN_PPTAL_CONFIG.COMPANIA = :COMPANIA AND PLAN_PPTAL_CONFIG.ANO = :ANO AND PLAN_PPTAL_CONFIG.DESTINO IN ('S') ORDER BY PLAN_PPTAL_CONFIG.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FUENTE_FUT IS NULL THEN ' ' ELSE UPPER(FUENTE_FUT) END)  LIKE UPPER( '%' || :FUENTE_FUT || '%')  AND (CASE WHEN TIPODEUDA_FUT IS NULL THEN ' ' ELSE UPPER(TIPODEUDA_FUT) END)  LIKE UPPER( '%' || :TIPODEUDA_FUT || '%')  AND (CASE WHEN TIPOOPERACION_FUT IS NULL THEN ' ' ELSE UPPER(TIPOOPERACION_FUT) END)  LIKE UPPER( '%' || :TIPOOPERACION_FUT || '%')  AND (CASE WHEN NOMBREFU_FUT IS NULL THEN ' ' ELSE UPPER(NOMBREFU_FUT) END)  LIKE UPPER( '%' || :NOMBREFU_FUT || '%')  AND (CASE WHEN TIPODEUDA_FUTNOM IS NULL THEN ' ' ELSE UPPER(TIPODEUDA_FUTNOM) END)  LIKE UPPER( '%' || :TIPODEUDA_FUTNOM || '%')  AND (CASE WHEN TIPOOPERACION_FUTNOM IS NULL THEN ' ' ELSE UPPER(TIPOOPERACION_FUTNOM) END)  LIKE UPPER( '%' || :TIPOOPERACION_FUTNOM || '%')  AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END)  LIKE UPPER( '%' || :DESTINO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTE_FUT" sqlType="STRING"/>
		<param name="TIPODEUDA_FUT" sqlType="STRING"/>
		<param name="TIPOOPERACION_FUT" sqlType="STRING"/>
		<param name="NOMBREFU_FUT" sqlType="STRING"/>
		<param name="TIPODEUDA_FUTNOM" sqlType="STRING"/>
		<param name="TIPOOPERACION_FUTNOM" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>

	</query>
