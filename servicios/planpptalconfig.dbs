	<query id="updatePlanpptalconfigConfiguracionFutCat" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CONFIG SET FUT_DESPLAZADOS1=:FUT_DESPLAZADOS1, FUT_CUENTAXPAGAR=:FUT_CUENTAXPAGAR, FUT_EJECUCIONSALUD=:FUT_EJECUCIONSALUD, FUT_SALUD_TESORERIA=:FUT_SALUD_TESORERIA, FUT_VIGENCIA_FUTURA=:FUT_VIGENCIA_FUTURA, FUT_INGRESOS_RESERVAS=:FUT_INGRESOS_RESERVAS, FUT_VICTIMAS1=:FUT_VICTIMAS1, FUENTE_FLS=:FUENTE_FLS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PPTAL_CONFIG.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CONFIG.ANO= :KEY_ANO AND PLAN_PPTAL_CONFIG.CODIGO= :KEY_CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO= :KEY_CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO= :KEY_TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL= :KEY_SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR= :KEY_AUXILIAR AND PLAN_PPTAL_CONFIG.REFERENCIA= :KEY_REFERENCIA AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FUT_DESPLAZADOS1" sqlType="STRING"/>
		<param name="FUT_CUENTAXPAGAR" sqlType="STRING"/>
		<param name="FUT_EJECUCIONSALUD" sqlType="STRING"/>
		<param name="FUT_SALUD_TESORERIA" sqlType="STRING"/>
		<param name="FUT_VIGENCIA_FUTURA" sqlType="STRING"/>
		<param name="FUT_INGRESOS_RESERVAS" sqlType="STRING"/>
		<param name="FUT_VICTIMAS1" sqlType="STRING"/>
		<param name="FUENTE_FLS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_AUXILIAR" sqlType="STRING"/>
		<param name="KEY_REFERENCIA" sqlType="STRING"/>
		<param name="KEY_FUENTE_RECURSO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planpptalconfig/configuracionfutcat">
		<call-query href="updatePlanpptalconfigConfiguracionFutCat">
			<with-param name="FUT_DESPLAZADOS1" query-param="FUT_DESPLAZADOS1"/>
			<with-param name="FUT_CUENTAXPAGAR" query-param="FUT_CUENTAXPAGAR"/>
			<with-param name="FUT_EJECUCIONSALUD" query-param="FUT_EJECUCIONSALUD"/>
			<with-param name="FUT_SALUD_TESORERIA" query-param="FUT_SALUD_TESORERIA"/>
			<with-param name="FUT_VIGENCIA_FUTURA" query-param="FUT_VIGENCIA_FUTURA"/>
			<with-param name="FUT_INGRESOS_RESERVAS" query-param="FUT_INGRESOS_RESERVAS"/>
			<with-param name="FUT_VICTIMAS1" query-param="FUT_VICTIMAS1"/>
			<with-param name="FUENTE_FLS" query-param="FUENTE_FLS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_AUXILIAR" query-param="KEY_AUXILIAR"/>
			<with-param name="KEY_REFERENCIA" query-param="KEY_REFERENCIA"/>
			<with-param name="KEY_FUENTE_RECURSO" query-param="KEY_FUENTE_RECURSO"/>

		</call-query>
	</resource>
	<query id="getPlanpptalconfigPagCodigoconauxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PCK_SYSMAN_UTL.FC_CODIGO_PPTAL(PLAN_PPTAL_CONFIG.COMPANIA ,PLAN_PPTAL_CONFIG.ANO,PLAN_PPTAL_CONFIG.CODIGO,PLAN_PPTAL_CONFIG.CENTRO_COSTO ,PLAN_PPTAL_CONFIG.TERCERO,PLAN_PPTAL_CONFIG.SUCURSAL,PLAN_PPTAL_CONFIG.AUXILIAR,PLAN_PPTAL_CONFIG.REFERENCIA,PLAN_PPTAL_CONFIG.FUENTE_RECURSO) ID, PLAN_PPTAL_CONFIG.CODIGO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PPTAL_CONFIG.CENTRO_COSTO, PLAN_PPTAL_CONFIG.TERCERO, PLAN_PPTAL_CONFIG.AUXILIAR, PLAN_PPTAL_CONFIG.REFERENCIA, PLAN_PPTAL_CONFIG.FUENTE_RECURSO, PLAN_PPTAL_CONFIG.SUCURSAL  FROM PLAN_PPTAL_CONFIG INNER JOIN PLAN_PRESUPUESTAL ON PLAN_PPTAL_CONFIG.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PLAN_PPTAL_CONFIG.ANO = PLAN_PRESUPUESTAL.ANO AND PLAN_PPTAL_CONFIG.CODIGO = PLAN_PRESUPUESTAL.CODIGO WHERE PLAN_PPTAL_CONFIG.COMPANIA = :COMPANIA AND PLAN_PPTAL_CONFIG.ANO = :ANO ORDER BY PLAN_PPTAL_CONFIG.CODIGO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END)  LIKE UPPER(:REFERENCIA || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER(:FUENTE_RECURSO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
