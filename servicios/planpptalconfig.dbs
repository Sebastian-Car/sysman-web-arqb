	<query id="updatePlanpptalconfig" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_PPTAL_CONFIG SET CODIGO=:CODIGO, CODIGOSCHIP=:CODIGOSCHIP, RECURSOSCHIP=:RECURSOSCHIP, ORIGENESPECIFICOINGRESOS=:ORIGENESPECIFICOINGRESOS, DESTINACIONDELOSRECURSOS=:DESTINACIONDELOSRECURSOS, FINALIDADGASTO=:FINALIDADGASTO, DEPENDENCIASCHIP=:DEPENDENCIASCHIP, SITUACIONFONDOSSCHIP=:SITUACIONFONDOSSCHIP, VIGENCIAGASTO=:VIGENCIAGASTO, VIGENCIATESORERIASCHIP=:VIGENCIATESORERIASCHIP, CR1_RESGUARDOSCHIP=:CR1_RESGUARDOSCHIP, CODIGOSIRECI=:CODIGOSIRECI, RECAUDO_VA=:RECAUDO_VA, COD_RECIPROCA=:COD_RECIPROCA, CODIGO_BPIN_SGR=:CODIGO_BPIN_SGR, CODIGO_CCEPT=:CODIGO_CCEPT, FUENTE_CUIPO=:FUENTE_CUIPO, SECTOR_CUIPO=:SECTOR_CUIPO, PROGRAMA_CUIPO=:PROGRAMA_CUIPO, CODIGO_CPC_CUIPO=:CODIGO_CPC_CUIPO, POLITCA_PUBLICA_CUIPO=:POLITCA_PUBLICA_CUIPO, TERCERO_CHIP=:TERCERO_CHIP, APLICA_DEST_ESPECIFICA=:APLICA_DEST_ESPECIFICA, TIPO_NORMA=:TIPO_NORMA, NUMERO_NORMA=:NUMERO_NORMA, FECHA_NORMA=TO_DATE(:FECHA_NORMA,'DD/MM/YYYY HH24:MI:SS'), CODIGO_PRODUCTO_CUIPO=:CODIGO_PRODUCTO_CUIPO, SECCION_PPTAL_CUIPO=:SECCION_PPTAL_CUIPO, VALOR_NORMA=:VALOR_NORMA, TRANSFERENCIA=:TRANSFERENCIA, TIPO_RECURSO_SGR=:TIPO_RECURSO_SGR, DETALLE_SECTORIAL=:DETALLE_SECTORIAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_PPTAL_CONFIG.COMPANIA= :KEY_COMPANIA AND PLAN_PPTAL_CONFIG.ANO= :KEY_ANO AND PLAN_PPTAL_CONFIG.CODIGO= :KEY_CODIGO AND PLAN_PPTAL_CONFIG.CENTRO_COSTO= :KEY_CENTRO_COSTO AND PLAN_PPTAL_CONFIG.TERCERO= :KEY_TERCERO AND PLAN_PPTAL_CONFIG.SUCURSAL= :KEY_SUCURSAL AND PLAN_PPTAL_CONFIG.AUXILIAR= :KEY_AUXILIAR AND PLAN_PPTAL_CONFIG.REFERENCIA= :KEY_REFERENCIA AND PLAN_PPTAL_CONFIG.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

