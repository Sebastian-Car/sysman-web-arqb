	<resource method="GET" path="nominacune/detallecune">
		<call-query href="getNominacuneDetallecuneQuery">
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="UN_MES" query-param="UN_MES"/>
			<with-param name="UN_NUMERO_DCTO" query-param="UN_NUMERO_DCTO"/>
			<with-param name="UN_CONSEC" query-param="UN_CONSEC"/>

		</call-query>
	</resource>
	<query id="getNominacuneGetnie176Query"  useConfig="sysmandsunist">
		<sql>SELECT CONCEPTOS.NOMBRE_CONCEPTO, SUM(HISTORICOS.VALOR) AS TOTALVALOR FROM HISTORICOS INNER JOIN CONCEPTOS ON HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA AND HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO INNER JOIN PERSONAL ON HISTORICOS.COMPANIA = PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO WHERE HISTORICOS.COMPANIA = :UN_COMPANIA AND HISTORICOS.ANO = :UN_ANO AND HISTORICOS.MES = :UN_MES AND CONCEPTOS.CONCEPTO_CUNE = 'NIE176' AND PERSONAL.NUMERO_DCTO = :UN_NUMERO_DCTO GROUP BY CONCEPTOS.NOMBRE_CONCEPTO ORDER BY SUM(HISTORICOS.VALOR) DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","TOTALVALOR":"$TOTALVALOR(type:integer)"}]}}		</result>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="UN_MES" sqlType="STRING"/>
		<param name="UN_NUMERO_DCTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nominacune/getnie176">
		<call-query href="getNominacuneGetnie176Query">
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="UN_MES" query-param="UN_MES"/>
			<with-param name="UN_NUMERO_DCTO" query-param="UN_NUMERO_DCTO"/>

		</call-query>
	</resource>
	<query id="getNominacuneListadonominasQuery"  useConfig="sysmandsunist">
		<sql>SELECT NIE012 AS NUM_NOMINAS FROM NOMINA_CUNE WHERE COMPANIA = :UN_COMPANIA AND ANO = :UN_ANO AND MES = :UN_MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUM_NOMINAS":"$NUM_NOMINAS"}]}}		</result>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="UN_MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nominacune/listadonominas">
