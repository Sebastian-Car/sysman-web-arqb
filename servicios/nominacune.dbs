<data name="nominacune" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNominacuneGetnominacuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT N.ANO AANO,N.MES BMES,N.NUMERO_DCTO CNUMERO_DCTO,P.NOMBRECOMPLETO DNOMBRECOMPLETO,N.CONS_TIPONOMINA GCONS_TIPONOMINA ,N.PERIODO HPERIODO,(TO_CHAR(N.NIE002,'DD/MM/YYYY HH24:MI:SS')) NIE002,(TO_CHAR(N.NIE003,'DD/MM/YYYY HH24:MI:SS')) NIE003,(TO_CHAR(N.NIE004,'DD/MM/YYYY HH24:MI:SS')) NIE004,(TO_CHAR(N.NIE005,'DD/MM/YYYY HH24:MI:SS')) NIE005,N.NIE006,(TO_CHAR(N.NIE008,'DD/MM/YYYY HH24:MI:SS')) NIE008,N.NIE009,N.NIE010,N.NIE011,N.NIE012,N.NIE013,N.NIE014,N.NIE015,N.NIE016,N.NIE024,N.NIE025,N.NIE029,N.NIE030,N.NIE200,N.NIE031,N.NIE041,N.NIE042,(CASE N.NIE043 WHEN 0 THEN 'false' ELSE 'true' END) NIE043,N.NIE044 ,N.NIE045,N.NIE046,N.NIE047,N.NIE048,N.NIE049,N.NIE050,N.NIE051,N.NIE052,N.NIE053,(CASE N.NIE056 WHEN 0 THEN 'false' ELSE 'true' END) NIE056,N.NIE061,N.NIE062,N.NIE063,(CASE N.NIE064 WHEN 0 THEN 'false' ELSE 'true' END) NIE064,N.NIE065,N.NIE066,N.NIE067,N.NIE068,(TO_CHAR(N.NIE203,'DD/MM/YYYY HH24:MI:SS')) NIE203,N.NIE069,N.NIE070,N.NIE071,N.NIE072,N.NIE073,N.NIE076,N.NIE078,N.NIE081,N.NIE083,N.NIE086,N.NIE088,N.NIE091,N.NIE093,N.NIE096,N.NIE098,(CASE N.NIE199 WHEN 0 THEN 'false' ELSE 'true' END) NIE199,N.NIE101,N.NIE103,N.NIE106,N.NIE108,(TO_CHAR(N.NIE109,'DD/MM/YYYY HH24:MI:SS')) NIE109,(TO_CHAR(N.NIE110,'DD/MM/YYYY HH24:MI:SS')) NIE110,N.NIE111,N.NIE112,N.NIE115,N.NIE116,N.NIE117,N.NIE118,N.NIE119,N.NIE120,N.NIE122,N.NIE125,N.NIE126,N.NIE127,N.NIE130,N.NIE131,N.NIE134,N.NIE135,(TO_CHAR(N.NIE136,'DD/MM/YYYY HH24:MI:SS')) NIE136,(TO_CHAR(N.NIE137,'DD/MM/YYYY HH24:MI:SS')) NIE137,N.NIE138,N.NIE139,N.NIE140,N.NIE141,N.NIE142,N.NIE145,N.NIE146,N.NIE147,N.NIE148,N.NIE149,N.NIE150,N.NIE151,N.NIE152,N.NIE153,N.NIE154,N.NIE155,N.NIE156,N.NIE157,N.NIE158,N.NIE159,N.NIE160,N.NIE161,N.NIE163,N.NIE164,N.NIE166,N.NIE167 ,N.NIE168,N.NIE169,N.NIE170,N.NIE171,N.NIE172,N.NIE173,N.NIE174,N.NIE175,N.NIE176,N.NIE177,N.NIE179,N.NIE180,N.NIE181,N.NIE182,N.NIE183,N.NIE184,N.NIE185,N.NIE186,N.NIE187,N.NIE188,N.NIE189,N.NIE193,N.NIE194,N.NIE195,N.NIE196,N.NIE197,N.NIE198,N.NIE201,N.NIE202 FROM NOMINA_CUNE N INNER JOIN PERSONAL P ON N.COMPANIA = P.COMPANIA AND N.NUMERO_DCTO = P.NUMERO_DCTO AND N.NIE009 = P.ID_DE_EMPLEADO WHERE N.COMPANIA = :UN_COMPANIA AND N.ANO = :UN_ANO AND N.MES = :UN_MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"AANO":"$AANO(type:integer)","BMES":"$BMES(type:integer)","CNUMERO_DCTO":"$CNUMERO_DCTO","DNOMBRECOMPLETO":"$DNOMBRECOMPLETO","GCONS_TIPONOMINA":"$GCONS_TIPONOMINA(type:integer)","HPERIODO":"$HPERIODO(type:integer)","NIE002":"$NIE002","NIE003":"$NIE003","NIE004":"$NIE004","NIE005":"$NIE005","NIE006":"$NIE006(type:integer)","NIE008":"$NIE008","NIE009":"$NIE009(type:integer)","NIE010":"$NIE010","NIE011":"$NIE011","NIE012":"$NIE012","NIE013":"$NIE013","NIE014":"$NIE014","NIE015":"$NIE015","NIE016":"$NIE016","NIE024":"$NIE024","NIE025":"$NIE025","NIE029":"$NIE029(type:integer)","NIE030":"$NIE030","NIE200":"$NIE200","NIE031":"$NIE031","NIE041":"$NIE041","NIE042":"$NIE042","NIE043":"$NIE043(type:boolean)","NIE044":"$NIE044","NIE045":"$NIE045","NIE046":"$NIE046","NIE047":"$NIE047","NIE048":"$NIE048","NIE049":"$NIE049","NIE050":"$NIE050","NIE051":"$NIE051","NIE052":"$NIE052","NIE053":"$NIE053","NIE056":"$NIE056(type:boolean)","NIE061":"$NIE061","NIE062":"$NIE062","NIE063":"$NIE063","NIE064":"$NIE064(type:boolean)","NIE065":"$NIE065","NIE066":"$NIE066","NIE067":"$NIE067","NIE068":"$NIE068","NIE203":"$NIE203","NIE069":"$NIE069","NIE070":"$NIE070","NIE071":"$NIE071","NIE072":"$NIE072","NIE073":"$NIE073","NIE076":"$NIE076","NIE078":"$NIE078","NIE081":"$NIE081","NIE083":"$NIE083","NIE086":"$NIE086","NIE088":"$NIE088","NIE091":"$NIE091","NIE093":"$NIE093","NIE096":"$NIE096","NIE098":"$NIE098","NIE199":"$NIE199(type:boolean)","NIE101":"$NIE101","NIE103":"$NIE103","NIE106":"$NIE106","NIE108":"$NIE108","NIE109":"$NIE109","NIE110":"$NIE110","NIE111":"$NIE111","NIE112":"$NIE112","NIE115":"$NIE115","NIE116":"$NIE116","NIE117":"$NIE117","NIE118":"$NIE118","NIE119":"$NIE119","NIE120":"$NIE120","NIE122":"$NIE122","NIE125":"$NIE125","NIE126":"$NIE126(type:integer)","NIE127":"$NIE127","NIE130":"$NIE130","NIE131":"$NIE131","NIE134":"$NIE134","NIE135":"$NIE135","NIE136":"$NIE136","NIE137":"$NIE137","NIE138":"$NIE138","NIE139":"$NIE139","NIE140":"$NIE140","NIE141":"$NIE141","NIE142":"$NIE142","NIE145":"$NIE145","NIE146":"$NIE146","NIE147":"$NIE147","NIE148":"$NIE148","NIE149":"$NIE149","NIE150":"$NIE150","NIE151":"$NIE151","NIE152":"$NIE152","NIE153":"$NIE153","NIE154":"$NIE154","NIE155":"$NIE155","NIE156":"$NIE156","NIE157":"$NIE157","NIE158":"$NIE158","NIE159":"$NIE159","NIE160":"$NIE160","NIE161":"$NIE161","NIE163":"$NIE163","NIE164":"$NIE164","NIE166":"$NIE166","NIE167":"$NIE167(type:double)","NIE168":"$NIE168","NIE169":"$NIE169(type:double)","NIE170":"$NIE170","NIE171":"$NIE171","NIE172":"$NIE172","NIE173":"$NIE173","NIE174":"$NIE174","NIE175":"$NIE175","NIE176":"$NIE176","NIE177":"$NIE177","NIE179":"$NIE179","NIE180":"$NIE180","NIE181":"$NIE181","NIE182":"$NIE182","NIE183":"$NIE183","NIE184":"$NIE184","NIE185":"$NIE185","NIE186":"$NIE186","NIE187":"$NIE187","NIE188":"$NIE188","NIE189":"$NIE189","NIE193":"$NIE193","NIE194":"$NIE194","NIE195":"$NIE195","NIE196":"$NIE196","NIE197":"$NIE197","NIE198":"$NIE198","NIE201":"$NIE201","NIE202":"$NIE202"}]}}		</result>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="UN_MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nominacune/getnominacune">
		<call-query href="getNominacuneGetnominacuneQuery">
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="UN_MES" query-param="UN_MES"/>

		</call-query>
	</resource>
	<query id="getNominacunePagEmpleadoscuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT P.NUMERO_DCTO, P.NOMBRECOMPLETO FROM NOMINA_CUNE N INNER JOIN PERSONAL P ON N.COMPANIA = P.COMPANIA AND N.NUMERO_DCTO = P.NUMERO_DCTO AND N.NIE009 = P.ID_DE_EMPLEADO WHERE N.COMPANIA = :COMPANIA AND N.ANO = :UN_ANO AND N.MES = :UN_MES AND (:UN_TIPONOM = 'T_NE_BASE' AND N.NIE199 = 0 OR :UN_TIPONOM IN ('T_NE_AJUSTE_RE','T_NE_ELIMINACION') AND N.NIE199 NOT IN (0) ) GROUP BY P.NUMERO_DCTO, P.NOMBRECOMPLETO ORDER BY P.NUMERO_DCTO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="UN_MES" sqlType="STRING"/>
		<param name="UN_TIPONOM" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nominacune/empleadoscune/pag">
		<call-query href="getNominacunePagEmpleadoscuneQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="UN_MES" query-param="UN_MES"/>
			<with-param name="UN_TIPONOM" query-param="UN_TIPONOM"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNominacuneNumEmpleadoscuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT P.NUMERO_DCTO, P.NOMBRECOMPLETO FROM NOMINA_CUNE N INNER JOIN PERSONAL P ON N.COMPANIA = P.COMPANIA AND N.NUMERO_DCTO = P.NUMERO_DCTO AND N.NIE009 = P.ID_DE_EMPLEADO WHERE N.COMPANIA = :COMPANIA AND N.ANO = :UN_ANO AND N.MES = :UN_MES AND (:UN_TIPONOM = 'T_NE_BASE' AND N.NIE199 = 0 OR :UN_TIPONOM IN ('T_NE_AJUSTE_RE','T_NE_ELIMINACION') AND N.NIE199 NOT IN (0) ) GROUP BY P.NUMERO_DCTO, P.NOMBRECOMPLETO ORDER BY P.NUMERO_DCTO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="UN_MES" sqlType="STRING"/>
		<param name="UN_TIPONOM" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nominacune/empleadoscune/num">
		<call-query href="getNominacuneNumEmpleadoscuneQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="UN_MES" query-param="UN_MES"/>
			<with-param name="UN_TIPONOM" query-param="UN_TIPONOM"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>

		</call-query>
	</resource>
	<query id="getNominacuneDatoscuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT N.NUMERO_DCTO,(CASE N.NIE199 WHEN 0 THEN 'false' ELSE 'true' END) NIE199, N.NIE012, N.PERIODO, N.CONS_TIPONOMINA, P.NOMBRECOMPLETO,(TO_CHAR(N.NIE008,'DD/MM/YYYY HH24:MI:SS')) NIE008 FROM NOMINA_CUNE N INNER JOIN PERSONAL P ON N.COMPANIA = P.COMPANIA AND N.NUMERO_DCTO = P.NUMERO_DCTO AND N.NIE009 = P.ID_DE_EMPLEADO WHERE N.NUMERO_DCTO BETWEEN :UN_NUMERODOC_INI AND :UN_NUMERODOC_FIN AND N.COMPANIA = :UN_COMPANIA AND N.ANO = :UN_ANO AND N.MES = :UN_MES AND ( :UN_TIPONOM = 'T_NE_BASE' AND N.NIE199 = 0 OR :UN_TIPONOM IN ('T_NE_AJUSTE_RE','T_NE_ELIMINACION') AND N.CONS_TIPONOMINA = (SELECT MAX(N2.CONS_TIPONOMINA) FROM NOMINA_CUNE N2 WHERE N.NUMERO_DCTO = N2.NUMERO_DCTO AND N.COMPANIA = N2.COMPANIA AND N.ANO = N2.ANO AND N.MES = N2.MES AND N2.NIE199 NOT IN ( 0 )) ) ORDER BY N.NUMERO_DCTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NIE199":"$NIE199(type:boolean)","NIE012":"$NIE012","PERIODO":"$PERIODO(type:integer)","CONS_TIPONOMINA":"$CONS_TIPONOMINA(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","NIE008":"$NIE008"}]}}		</result>
		<param name="UN_NUMERODOC_INI" sqlType="STRING"/>
		<param name="UN_NUMERODOC_FIN" sqlType="STRING"/>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="UN_MES" sqlType="STRING"/>
		<param name="UN_TIPONOM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nominacune/datoscune">
		<call-query href="getNominacuneDatoscuneQuery">
			<with-param name="UN_NUMERODOC_INI" query-param="UN_NUMERODOC_INI"/>
			<with-param name="UN_NUMERODOC_FIN" query-param="UN_NUMERODOC_FIN"/>
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="UN_MES" query-param="UN_MES"/>
			<with-param name="UN_TIPONOM" query-param="UN_TIPONOM"/>

		</call-query>
	</resource>
	<query id="getNominacuneNie008Query"  useConfig="sysmandsunist">
		<sql>SELECT (TO_CHAR(NIE008,'DD/MM/YYYY HH24:MI:SS')) NIE008, NIE012 FROM NOMINA_CUNE WHERE COMPANIA = :COMPANIA AND NUMERO_DCTO = :UN_NUMERO_DCTO AND ANO = :UN_ANO AND MES = :UN_MES AND PERIODO = :UN_PERIODO AND NIE012 &lt;&gt; :UN_NIE012</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIE008":"$NIE008","NIE012":"$NIE012"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UN_NUMERO_DCTO" sqlType="STRING"/>
		<param name="UN_ANO" sqlType="STRING"/>
		<param name="UN_MES" sqlType="STRING"/>
		<param name="UN_PERIODO" sqlType="STRING"/>
		<param name="UN_NIE012" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nominacune/nie008">
		<call-query href="getNominacuneNie008Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UN_NUMERO_DCTO" query-param="UN_NUMERO_DCTO"/>
			<with-param name="UN_ANO" query-param="UN_ANO"/>
			<with-param name="UN_MES" query-param="UN_MES"/>
			<with-param name="UN_PERIODO" query-param="UN_PERIODO"/>
			<with-param name="UN_NIE012" query-param="UN_NIE012"/>

		</call-query>
	</resource>
	<query id="getNominacuneDetallecuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE NIE199 WHEN 0 THEN 'false' ELSE 'true' END) NIE199,(TO_CHAR(NIE002,'DD/MM/YYYY HH24:MI:SS')) NIE002,(TO_CHAR(NIE003,'DD/MM/YYYY HH24:MI:SS')) NIE003,(TO_CHAR(NIE004,'DD/MM/YYYY HH24:MI:SS')) NIE004,(TO_CHAR(NIE005,'DD/MM/YYYY HH24:MI:SS')) NIE005,NIE006,(TO_CHAR(NIE008,'DD/MM/YYYY HH24:MI:SS')) NIE008,NIE009,NIE010,NIE011,NIE012,NIE013,NIE014,NIE015,NIE016,NIE024,NIE025,NIE029,NIE030,NIE200,NIE031,NIE041,NIE042,(CASE NIE043 WHEN 0 THEN 'false' ELSE 'true' END) NIE043,NIE044,NIE045,NIE046,NIE047,NIE048,NIE049,NIE050,NIE051,NIE052,NIE053,(CASE NIE056 WHEN 0 THEN 'false' ELSE 'true' END) NIE056,NIE061,NIE062,NIE063,TO_CHAR(NIE064) NIE064,NIE065,NIE066,NIE067,NIE068,(TO_CHAR(NIE203,'DD/MM/YYYY HH24:MI:SS')) NIE203,NIE069,NIE070,NIE071,NIE072,NIE073,NIE076,NIE078,NIE081,NIE083,NIE086,NIE088,NIE091,NIE093,NIE096,NIE098,NIE101,NIE103,NIE106,NIE108,(TO_CHAR(NIE109,'DD/MM/YYYY HH24:MI:SS')) NIE109,(TO_CHAR(NIE110,'DD/MM/YYYY HH24:MI:SS')) NIE110,NIE111,NIE112,NIE115,NIE116,NIE117,NIE118,NIE119,NIE120,NIE122,NIE125,NIE126,NIE127,NIE130,NIE131,NIE134,NIE135,(TO_CHAR(NIE136,'DD/MM/YYYY HH24:MI:SS')) NIE136,(TO_CHAR(NIE137,'DD/MM/YYYY HH24:MI:SS')) NIE137,NIE138,NIE139,NIE140,NIE141,NIE142,NIE145,NIE146,NIE147,NIE148,NIE149,NIE150,NIE151,NIE152,NIE153,NIE154,NIE155,NIE156,NIE157,NIE158,NIE159,NIE160,NIE161,NIE163,NIE164,NIE166,NIE167,NIE168,NIE169,NIE170,NIE171,NIE172,NIE173,NIE174,NIE175,NIE176,NIE177,NIE179,NIE180,NIE181,NIE182,NIE183,NIE184,NIE185,NIE186,NIE187,NIE188,NIE189,NIE193,NIE194,NIE195,NIE196,NIE197,NIE198,NIE201,NIE202, NIE051,NIE041,NIE044,NIE052,NIE065,(TO_CHAR(NIEA192,'DD/MM/YYYY HH24:MI:SS')) NIEA192 FROM NOMINA_CUNE WHERE COMPANIA = :UN_COMPANIA AND ANO = :UN_ANO AND MES = :UN_MES AND NUMERO_DCTO = :UN_NUMERO_DCTO AND CONS_TIPONOMINA = :UN_CONSEC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIE199":"$NIE199(type:boolean)","NIE002":"$NIE002","NIE003":"$NIE003","NIE004":"$NIE004","NIE005":"$NIE005","NIE006":"$NIE006(type:integer)","NIE008":"$NIE008","NIE009":"$NIE009(type:integer)","NIE010":"$NIE010","NIE011":"$NIE011","NIE012":"$NIE012","NIE013":"$NIE013","NIE014":"$NIE014","NIE015":"$NIE015","NIE016":"$NIE016","NIE024":"$NIE024","NIE025":"$NIE025","NIE029":"$NIE029(type:integer)","NIE030":"$NIE030","NIE200":"$NIE200","NIE031":"$NIE031","NIE041":"$NIE041","NIE042":"$NIE042","NIE043":"$NIE043(type:boolean)","NIE044":"$NIE044","NIE045":"$NIE045","NIE046":"$NIE046","NIE047":"$NIE047","NIE048":"$NIE048","NIE049":"$NIE049","NIE050":"$NIE050","NIE051":"$NIE051","NIE052":"$NIE052","NIE053":"$NIE053","NIE056":"$NIE056(type:boolean)","NIE061":"$NIE061","NIE062":"$NIE062","NIE063":"$NIE063","NIE064":"$NIE064","NIE065":"$NIE065","NIE066":"$NIE066","NIE067":"$NIE067","NIE068":"$NIE068","NIE203":"$NIE203","NIE069":"$NIE069","NIE070":"$NIE070","NIE071":"$NIE071","NIE072":"$NIE072","NIE073":"$NIE073","NIE076":"$NIE076","NIE078":"$NIE078","NIE081":"$NIE081","NIE083":"$NIE083","NIE086":"$NIE086","NIE088":"$NIE088","NIE091":"$NIE091","NIE093":"$NIE093","NIE096":"$NIE096","NIE098":"$NIE098","NIE101":"$NIE101","NIE103":"$NIE103","NIE106":"$NIE106","NIE108":"$NIE108","NIE109":"$NIE109","NIE110":"$NIE110","NIE111":"$NIE111","NIE112":"$NIE112","NIE115":"$NIE115","NIE116":"$NIE116","NIE117":"$NIE117","NIE118":"$NIE118","NIE119":"$NIE119","NIE120":"$NIE120","NIE122":"$NIE122","NIE125":"$NIE125","NIE126":"$NIE126(type:integer)","NIE127":"$NIE127","NIE130":"$NIE130","NIE131":"$NIE131","NIE134":"$NIE134","NIE135":"$NIE135","NIE136":"$NIE136","NIE137":"$NIE137","NIE138":"$NIE138","NIE139":"$NIE139","NIE140":"$NIE140","NIE141":"$NIE141","NIE142":"$NIE142","NIE145":"$NIE145","NIE146":"$NIE146","NIE147":"$NIE147","NIE148":"$NIE148","NIE149":"$NIE149","NIE150":"$NIE150","NIE151":"$NIE151","NIE152":"$NIE152","NIE153":"$NIE153","NIE