<data name="estadosdocdian" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="deleteEstadosdocdianBorrarTodosDatos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ESTADO_DOC_DIAN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

 
	</query>
	<resource method="DELETE" path="estadosdocdian/borrartodosdatos">
		<call-query href="deleteEstadosdocdianBorrarTodosDatos">
 
		</call-query>
	</resource>
	<query id="insertEstadosdocdian" keyColumns="NUM_DOCUMENTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ESTADO_DOC_DIAN (NUM_DOCUMENTO, TIPO_DOCUMENTO, MENSAJE, DOCUMENTKEY, DATE_CREATED, CREATED_BY) VALUES (:NUM_DOCUMENTO, :TIPO_DOCUMENTO, :MENSAJE, :DOCUMENTKEY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_NUM_DOCUMENTO":"$NUM_DOCUMENTO(type:long)"}]}}		</result>
		<param name="NUM_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="MENSAJE" sqlType="STRING"/>
		<param defaultValue="" name="DOCUMENTKEY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="estadosdocdian">
		<call-query href="insertEstadosdocdian">
			<with-param name="NUM_DOCUMENTO" query-param="NUM_DOCUMENTO"/>
			<with-param name="TIPO_DOCUMENTO" query-param="TIPO_DOCUMENTO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="DOCUMENTKEY" query-param="DOCUMENTKEY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getEstadosdocdianPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUM_DOCUMENTO, TIPO_DOCUMENTO, MENSAJE, DOCUMENTKEY FROM ESTADO_DOC_DIAN) INI WHERE (CASE WHEN NUM_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NUM_DOCUMENTO) END) LIKE UPPER(CONCAT(:NUM_DOCUMENTO, '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOCUMENTO), '%')) AND (CASE WHEN MENSAJE IS NULL THEN ' ' ELSE UPPER(MENSAJE) END) LIKE UPPER(CONCAT(CONCAT('%',:MENSAJE), '%')) AND (CASE WHEN DOCUMENTKEY IS NULL THEN ' ' ELSE UPPER(DOCUMENTKEY) END) LIKE UPPER(CONCAT(CONCAT('%',:DOCUMENTKEY), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUM_DOCUMENTO":"$NUM_DOCUMENTO(type:long)","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","MENSAJE":"$MENSAJE","DOCUMENTKEY":"$DOCUMENTKEY"}]}}		</result>
		<param name="NUM_DOCUMENTO" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="MENSAJE" sqlType="STRING"/>
		<param name="DOCUMENTKEY" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estadosdocdian">
		<call-query href="getEstadosdocdianPaginaQuery">
			<with-param name="NUM_DOCUMENTO" query-param="NUM_DOCUMENTO"/>
			<with-param name="TIPO_DOCUMENTO" query-param="TIPO_DOCUMENTO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="DOCUMENTKEY" query-param="DOCUMENTKEY"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstadosdocdianNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUM_DOCUMENTO, TIPO_DOCUMENTO, MENSAJE, DOCUMENTKEY FROM ESTADO_DOC_DIAN) INI WHERE (CASE WHEN NUM_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NUM_DOCUMENTO) END) LIKE UPPER(CONCAT(:NUM_DOCUMENTO, '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOCUMENTO), '%')) AND (CASE WHEN MENSAJE IS NULL THEN ' ' ELSE UPPER(MENSAJE) END) LIKE UPPER(CONCAT(CONCAT('%',:MENSAJE), '%')) AND (CASE WHEN DOCUMENTKEY IS NULL THEN ' ' ELSE UPPER(DOCUMENTKEY) END) LIKE UPPER(CONCAT(CONCAT('%',:DOCUMENTKEY), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NUM_DOCUMENTO" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="MENSAJE" sqlType="STRING"/>
		<param name="DOCUMENTKEY" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estadosdocdian/numero">
		<call-query href="getEstadosdocdianNumeroQuery">
			<with-param name="NUM_DOCUMENTO" query-param="NUM_DOCUMENTO"/>
			<with-param name="TIPO_DOCUMENTO" query-param="TIPO_DOCUMENTO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="DOCUMENTKEY" query-param="DOCUMENTKEY"/>

		</call-query>
	</resource>

</data>