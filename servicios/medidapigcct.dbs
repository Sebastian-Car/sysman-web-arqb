<data name="medidapigcct" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getMedidapigcctPagBpmedidasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO_MEDIDA,DESCRIPCION_MEDIDA FROM MEDIDA_PIGCCT WHERE COMPANIA = :COMPANIA AND CODIGO_EJE = :EJE) INI WHERE (CASE WHEN CODIGO_MEDIDA IS NULL THEN ' ' ELSE UPPER(CODIGO_MEDIDA) END) LIKE UPPER(CONCAT(:CODIGO_MEDIDA, '%')) AND (CASE WHEN DESCRIPCION_MEDIDA IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_MEDIDA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_MEDIDA":"$CODIGO_MEDIDA(type:integer)","DESCRIPCION_MEDIDA":"$DESCRIPCION_MEDIDA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EJE" sqlType="STRING"/>
		<param name="CODIGO_MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION_MEDIDA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="medidapigcct/bpmedidas/pag">
		<call-query href="getMedidapigcctPagBpmedidasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EJE" query-param="EJE"/>
			<with-param name="CODIGO_MEDIDA" query-param="CODIGO_MEDIDA"/>
			<with-param name="DESCRIPCION_MEDIDA" query-param="DESCRIPCION_MEDIDA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMedidapigcctNumBpmedidasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO_MEDIDA,DESCRIPCION_MEDIDA FROM MEDIDA_PIGCCT WHERE COMPANIA = :COMPANIA AND CODIGO_EJE = :EJE) INI WHERE (CASE WHEN CODIGO_MEDIDA IS NULL THEN ' ' ELSE UPPER(CODIGO_MEDIDA) END) LIKE UPPER(CONCAT(:CODIGO_MEDIDA, '%')) AND (CASE WHEN DESCRIPCION_MEDIDA IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_MEDIDA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EJE" sqlType="STRING"/>
		<param name="CODIGO_MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION_MEDIDA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="medidapigcct/bpmedidas/num">
		<call-query href="getMedidapigcctNumBpmedidasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EJE" query-param="EJE"/>
			<with-param name="CODIGO_MEDIDA" query-param="CODIGO_MEDIDA"/>
			<with-param name="DESCRIPCION_MEDIDA" query-param="DESCRIPCION_MEDIDA"/>

		</call-query>
	</resource>
	<query id="insertMedidapigcct" keyColumns="COMPANIA,CODIGO_MEDIDA,CODIGO_EJE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO MEDIDA_PIGCCT (COMPANIA, CODIGO_MEDIDA, DESCRIPCION_MEDIDA, CODIGO_EJE, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO_MEDIDA, :DESCRIPCION_MEDIDA, :CODIGO_EJE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_MEDIDA":"$CODIGO_MEDIDA(type:integer)","KEY_CODIGO_EJE":"$CODIGO_EJE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_MEDIDA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_MEDIDA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="medidapigcct">
		<call-query href="insertMedidapigcct">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_MEDIDA" query-param="CODIGO_MEDIDA"/>
			<with-param name="DESCRIPCION_MEDIDA" query-param="DESCRIPCION_MEDIDA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteMedidapigcct" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM MEDIDA_PIGCCT WHERE MEDIDA_PIGCCT.COMPANIA= :KEY_COMPANIA AND MEDIDA_PIGCCT.CODIGO_MEDIDA= :KEY_CODIGO_MEDIDA AND MEDIDA_PIGCCT.CODIGO_EJE= :KEY_CODIGO_EJE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_MEDIDA" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_EJE" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="medidapigcct">
		<call-query href="deleteMedidapigcct">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_MEDIDA" query-param="KEY_CODIGO_MEDIDA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>

		</call-query>
	</resource>
	<query id="getMedidapigcctPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO_MEDIDA, DESCRIPCION_MEDIDA, CODIGO_EJE FROM MEDIDA_PIGCCT WHERE COMPANIA = :COMPANIA AND CODIGO_EJE = :CODIGO) INI WHERE (CASE WHEN CODIGO_MEDIDA IS NULL THEN ' ' ELSE UPPER(CODIGO_MEDIDA) END) LIKE UPPER(CONCAT(:CODIGO_MEDIDA, '%')) AND (CASE WHEN DESCRIPCION_MEDIDA IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_MEDIDA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_MEDIDA":"$CODIGO_MEDIDA(type:integer)","DESCRIPCION_MEDIDA":"$DESCRIPCION_MEDIDA","CODIGO_EJE":"$CODIGO_EJE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGO_MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION_MEDIDA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="medidapigcct">
		<call-query href="getMedidapigcctPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_MEDIDA" query-param="CODIGO_MEDIDA"/>
			<with-param name="DESCRIPCION_MEDIDA" query-param="DESCRIPCION_MEDIDA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMedidapigcctNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO_MEDIDA, DESCRIPCION_MEDIDA, CODIGO_EJE FROM MEDIDA_PIGCCT WHERE COMPANIA = :COMPANIA AND CODIGO_EJE = :CODIGO) INI WHERE (CASE WHEN CODIGO_MEDIDA IS NULL THEN ' ' ELSE UPPER(CODIGO_MEDIDA) END) LIKE UPPER(CONCAT(:CODIGO_MEDIDA, '%')) AND (CASE WHEN DESCRIPCION_MEDIDA IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_MEDIDA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGO_MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION_MEDIDA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="medidapigcct/numero">
		<call-query href="getMedidapigcctNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_MEDIDA" query-param="CODIGO_MEDIDA"/>
			<with-param name="DESCRIPCION_MEDIDA" query-param="DESCRIPCION_MEDIDA"/>

		</call-query>
	</resource>
	<query id="updateMedidapigcct" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MEDIDA_PIGCCT SET COMPANIA=:COMPANIA, CODIGO_MEDIDA=:CODIGO_MEDIDA, DESCRIPCION_MEDIDA=:DESCRIPCION_MEDIDA, CODIGO_EJE=:CODIGO_EJE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE MEDIDA_PIGCCT.COMPANIA= :KEY_COMPANIA AND MEDIDA_PIGCCT.CODIGO_MEDIDA= :KEY_CODIGO_MEDIDA AND MEDIDA_PIGCCT.CODIGO_EJE= :KEY_CODIGO_EJE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION_MEDIDA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_MEDIDA" sqlType="STRING"/>
		<param name="KEY_CODIGO_EJE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="medidapigcct">
		<call-query href="updateMedidapigcct">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_MEDIDA" query-param="CODIGO_MEDIDA"/>
			<with-param name="DESCRIPCION_MEDIDA" query-param="DESCRIPCION_MEDIDA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_MEDIDA" query-param="KEY_CODIGO_MEDIDA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>

		</call-query>
	</resource>

</data>