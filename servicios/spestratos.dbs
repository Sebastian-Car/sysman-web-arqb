	<query id="getSpestratosCodigoNombreUsoPorUsoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE, USO  FROM SP_ESTRATOS WHERE COMPANIA = :COMPANIA AND USO = :USO ORDER BY CODIGO</sql>
