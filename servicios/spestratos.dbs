			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USOINICIAL" query-param="USOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpestratosPagPorUsoYCompaniaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SP_ESTRATOS.CODIGO, SP_ESTRATOS.NOMBRE  FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA = :COMPANIA AND SP_ESTRATOS.USO = :USOINICIAL AND SP_ESTRATOS.CODIGO &gt;= :CODIGOINICIAL ORDER BY SP_ESTRATOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
