<data name="spestratos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpestratosPagTodosEntreUsosYCodigoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SP_ESTRATOS WHERE COMPANIA= :COMPANIA AND USO BETWEEN :USOINICIAL AND :USOFINAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="USOFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spestratos/todosentreusosycodigoinicial/pag">
		<call-query href="getSpestratosPagTodosEntreUsosYCodigoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USOINICIAL" query-param="USOINICIAL"/>
			<with-param name="USOFINAL" query-param="USOFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpestratosNumTodosEntreUsosYCodigoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SP_ESTRATOS WHERE COMPANIA= :COMPANIA AND USO BETWEEN :USOINICIAL AND :USOFINAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="USOFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/todosentreusosycodigoinicial/num">
		<call-query href="getSpestratosNumTodosEntreUsosYCodigoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USOINICIAL" query-param="USOINICIAL"/>
			<with-param name="USOFINAL" query-param="USOFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpestratosPagTodosEntreUsosYCodigoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SP_ESTRATOS WHERE COMPANIA= :COMPANIA AND CODIGO &gt;= :ESTRATOINICIAL AND USO BETWEEN :USOINICIAL AND :USOFINAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTRATOINICIAL" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="USOFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spestratos/todosentreusosycodigofinal/pag">
		<call-query href="getSpestratosPagTodosEntreUsosYCodigoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTRATOINICIAL" query-param="ESTRATOINICIAL"/>
			<with-param name="USOINICIAL" query-param="USOINICIAL"/>
			<with-param name="USOFINAL" query-param="USOFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpestratosNumTodosEntreUsosYCodigoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SP_ESTRATOS WHERE COMPANIA= :COMPANIA AND CODIGO &gt;= :ESTRATOINICIAL AND USO BETWEEN :USOINICIAL AND :USOFINAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTRATOINICIAL" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="USOFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/todosentreusosycodigofinal/num">
		<call-query href="getSpestratosNumTodosEntreUsosYCodigoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTRATOINICIAL" query-param="ESTRATOINICIAL"/>
			<with-param name="USOINICIAL" query-param="USOINICIAL"/>
			<with-param name="USOFINAL" query-param="USOFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpestratosCodnombreporcompaniayusoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM SP_ESTRATOS WHERE COMPANIA = :COMPANIA AND USO = :USO_ACTUAL ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USO_ACTUAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/codnombreporcompaniayuso">
		<call-query href="getSpestratosCodnombreporcompaniayusoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USO_ACTUAL" query-param="USO_ACTUAL"/>

		</call-query>
	</resource>
	<query id="getSpestratosPagTodosLosEstratosPorUsoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  'T' CODIGO, 'TODOS' NOMBRE  FROM DUAL UNION SELECT SP_ESTRATOS.CODIGO, SP_ESTRATOS.NOMBRE FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA = :COMPANIA AND SP_ESTRATOS.USO = :USO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spestratos/todoslosestratosporuso/pag">
		<call-query href="getSpestratosPagTodosLosEstratosPorUsoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpestratosNumTodosLosEstratosPorUsoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  'T' CODIGO, 'TODOS' NOMBRE  FROM DUAL UNION SELECT SP_ESTRATOS.CODIGO, SP_ESTRATOS.NOMBRE FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA = :COMPANIA AND SP_ESTRATOS.USO = :USO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/todoslosestratosporuso/num">
		<call-query href="getSpestratosNumTodosLosEstratosPorUsoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpestratosTodosPorEstratoFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ESTRATOS.CODIGO, NVL(ESTRATOS.NOMBRE,'NA') NOMBRE  FROM SP_ESTRATOS ESTRATOS WHERE ESTRATOS.COMPANIA = :COMPANIA AND ESTRATOS.USO =: USO ORDER BY ESTRATOS.CODIGO, ESTRATOS.COMPANIA, ESTRATOS.USO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/todosporestratofin">
		<call-query href="getSpestratosTodosPorEstratoFinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="" query-param=""/>

		</call-query>
	</resource>
	<query id="getSpestratosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT SP_ESTRATOS.CODIGO  FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA = :COMPANIA ORDER BY SP_ESTRATOS.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/porcompania">
		<call-query href="getSpestratosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertSpestratos" keyColumns="COMPANIA,USO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_ESTRATOS (COMPANIA, USO, CODIGO, NOMBRE, CLASIFICACIONSUI, CLASIFICACIONSUIASEO, HOMOLOGACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :USO, :CODIGO, :NOMBRE, :CLASIFICACIONSUI, :CLASIFICACIONSUIASEO, :HOMOLOGACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_USO":"$USO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CLASIFICACIONSUI" sqlType="STRING"/>
		<param defaultValue="" name="CLASIFICACIONSUIASEO" sqlType="STRING"/>
		<param defaultValue="" name="HOMOLOGACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spestratos">
		<call-query href="insertSpestratos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASIFICACIONSUI" query-param="CLASIFICACIONSUI"/>
			<with-param name="CLASIFICACIONSUIASEO" query-param="CLASIFICACIONSUIASEO"/>
			<with-param name="HOMOLOGACION" query-param="HOMOLOGACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSpestratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA= :KEY_COMPANIA AND SP_ESTRATOS.USO= :KEY_USO AND SP_ESTRATOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_USO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spestratos">
		<call-query href="deleteSpestratos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_USO" query-param="KEY_USO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpestratosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, USO, CODIGO, NOMBRE, CLASIFICACIONSUI, CLASIFICACIONSUIASEO, HOMOLOGACION  FROM SP_ESTRATOS WHERE COMPANIA = :COMPANIA AND USO = :USO ORDER BY USO, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASIFICACIONSUI IS NULL THEN ' ' ELSE UPPER(CLASIFICACIONSUI) END)  LIKE UPPER( '%' || :CLASIFICACIONSUI || '%')  AND (CASE WHEN CLASIFICACIONSUIASEO IS NULL THEN ' ' ELSE UPPER(CLASIFICACIONSUIASEO) END)  LIKE UPPER( '%' || :CLASIFICACIONSUIASEO || '%')  AND (CASE WHEN HOMOLOGACION IS NULL THEN ' ' ELSE UPPER(HOMOLOGACION) END)  LIKE UPPER( '%' || :HOMOLOGACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","USO":"$USO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASIFICACIONSUI":"$CLASIFICACIONSUI","CLASIFICACIONSUIASEO":"$CLASIFICACIONSUIASEO","HOMOLOGACION":"$HOMOLOGACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASIFICACIONSUI" sqlType="STRING"/>
		<param name="CLASIFICACIONSUIASEO" sqlType="STRING"/>
		<param name="HOMOLOGACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spestratos">
		<call-query href="getSpestratosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASIFICACIONSUI" query-param="CLASIFICACIONSUI"/>
			<with-param name="CLASIFICACIONSUIASEO" query-param="CLASIFICACIONSUIASEO"/>
			<with-param name="HOMOLOGACION" query-param="HOMOLOGACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpestratosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, USO, CODIGO, NOMBRE, CLASIFICACIONSUI, CLASIFICACIONSUIASEO, HOMOLOGACION  FROM SP_ESTRATOS WHERE COMPANIA = :COMPANIA AND USO = :USO ORDER BY USO, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASIFICACIONSUI IS NULL THEN ' ' ELSE UPPER(CLASIFICACIONSUI) END)  LIKE UPPER( '%' || :CLASIFICACIONSUI || '%')  AND (CASE WHEN CLASIFICACIONSUIASEO IS NULL THEN ' ' ELSE UPPER(CLASIFICACIONSUIASEO) END)  LIKE UPPER( '%' || :CLASIFICACIONSUIASEO || '%')  AND (CASE WHEN HOMOLOGACION IS NULL THEN ' ' ELSE UPPER(HOMOLOGACION) END)  LIKE UPPER( '%' || :HOMOLOGACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASIFICACIONSUI" sqlType="STRING"/>
		<param name="CLASIFICACIONSUIASEO" sqlType="STRING"/>
		<param name="HOMOLOGACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/numero">
		<call-query href="getSpestratosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASIFICACIONSUI" query-param="CLASIFICACIONSUI"/>
			<with-param name="CLASIFICACIONSUIASEO" query-param="CLASIFICACIONSUIASEO"/>
			<with-param name="HOMOLOGACION" query-param="HOMOLOGACION"/>

		</call-query>
	</resource>
	<query id="updateSpestratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_ESTRATOS SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, CLASIFICACIONSUI=:CLASIFICACIONSUI, CLASIFICACIONSUIASEO=:CLASIFICACIONSUIASEO, HOMOLOGACION=:HOMOLOGACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_ESTRATOS.COMPANIA= :KEY_COMPANIA AND SP_ESTRATOS.USO= :KEY_USO AND SP_ESTRATOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASIFICACIONSUI" sqlType="STRING"/>
		<param name="CLASIFICACIONSUIASEO" sqlType="STRING"/>
		<param name="HOMOLOGACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_USO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spestratos">
		<call-query href="updateSpestratos">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASIFICACIONSUI" query-param="CLASIFICACIONSUI"/>
			<with-param name="CLASIFICACIONSUIASEO" query-param="CLASIFICACIONSUIASEO"/>
			<with-param name="HOMOLOGACION" query-param="HOMOLOGACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_USO" query-param="KEY_USO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpestratosPorCodigoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT SP_ESTRATOS.CODIGO  FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA = :COMPANIA AND SP_ESTRATOS.CODIGO &gt;= :CODIGOINICIAL ORDER BY SP_ESTRATOS.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/porcodigoinicial">
		<call-query href="getSpestratosPorCodigoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>

		</call-query>
	</resource>
	<query id="getSpestratosPagPorUsoYCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SP_ESTRATOS.CODIGO, SP_ESTRATOS.NOMBRE  FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA = :COMPANIA AND SP_ESTRATOS.USO = :USOINICIAL ORDER BY SP_ESTRATOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spestratos/porusoycompania/pag">
		<call-query href="getSpestratosPagPorUsoYCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="USOINICIAL" query-param="USOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpestratosNumPorUsoYCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SP_ESTRATOS.CODIGO, SP_ESTRATOS.NOMBRE  FROM SP_ESTRATOS WHERE SP_ESTRATOS.COMPANIA = :COMPANIA AND SP_ESTRATOS.USO = :USOINICIAL ORDER BY SP_ESTRATOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestratos/porusoycompania/num">
