<data name="esfuenteetapatipo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsfuenteetapatipoPagCodigonombrefuentesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO FUENTE , NOMBRE NOMBRE_FUENTE  FROM ES_FUENTE_ETAPA_TIPO WHERE TIPO_OPCION IN (1)) WHERE (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER(:FUENTE || '%')  AND (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END)  LIKE UPPER( '%' || :NOMBRE_FUENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FUENTE":"$FUENTE","NOMBRE_FUENTE":"$NOMBRE_FUENTE"}]}}		</result>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="NOMBRE_FUENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo/codigonombrefuentes/pag">
		<call-query href="getEsfuenteetapatipoPagCodigonombrefuentesQuery">
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="NOMBRE_FUENTE" query-param="NOMBRE_FUENTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsfuenteetapatipoNumCodigonombrefuentesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO FUENTE , NOMBRE NOMBRE_FUENTE  FROM ES_FUENTE_ETAPA_TIPO WHERE TIPO_OPCION IN (1)) WHERE (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER(:FUENTE || '%')  AND (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END)  LIKE UPPER( '%' || :NOMBRE_FUENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="NOMBRE_FUENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo/codigonombrefuentes/num">
		<call-query href="getEsfuenteetapatipoNumCodigonombrefuentesQuery">
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="NOMBRE_FUENTE" query-param="NOMBRE_FUENTE"/>

		</call-query>
	</resource>
	<query id="getEsfuenteetapatipoPagCodigonombreetapasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO ETAPA , NOMBRE NOMBRE_ETAPA  FROM ES_FUENTE_ETAPA_TIPO WHERE TIPO_OPCION IN (2)) WHERE (CASE WHEN ETAPA IS NULL THEN ' ' ELSE UPPER(ETAPA) END)  LIKE UPPER(:ETAPA || '%')  AND (CASE WHEN NOMBRE_ETAPA IS NULL THEN ' ' ELSE UPPER(NOMBRE_ETAPA) END)  LIKE UPPER( '%' || :NOMBRE_ETAPA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ETAPA":"$ETAPA","NOMBRE_ETAPA":"$NOMBRE_ETAPA"}]}}		</result>
		<param name="ETAPA" sqlType="STRING"/>
		<param name="NOMBRE_ETAPA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo/codigonombreetapas/pag">
		<call-query href="getEsfuenteetapatipoPagCodigonombreetapasQuery">
			<with-param name="ETAPA" query-param="ETAPA"/>
			<with-param name="NOMBRE_ETAPA" query-param="NOMBRE_ETAPA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsfuenteetapatipoNumCodigonombreetapasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO ETAPA , NOMBRE NOMBRE_ETAPA  FROM ES_FUENTE_ETAPA_TIPO WHERE TIPO_OPCION IN (2)) WHERE (CASE WHEN ETAPA IS NULL THEN ' ' ELSE UPPER(ETAPA) END)  LIKE UPPER(:ETAPA || '%')  AND (CASE WHEN NOMBRE_ETAPA IS NULL THEN ' ' ELSE UPPER(NOMBRE_ETAPA) END)  LIKE UPPER( '%' || :NOMBRE_ETAPA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ETAPA" sqlType="STRING"/>
		<param name="NOMBRE_ETAPA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo/codigonombreetapas/num">
		<call-query href="getEsfuenteetapatipoNumCodigonombreetapasQuery">
			<with-param name="ETAPA" query-param="ETAPA"/>
			<with-param name="NOMBRE_ETAPA" query-param="NOMBRE_ETAPA"/>

		</call-query>
	</resource>
	<query id="getEsfuenteetapatipoPagCodigonombretiposQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO TIPO , NOMBRE NOMBRE_TIPO  FROM ES_FUENTE_ETAPA_TIPO WHERE TIPO_OPCION IN (3)) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","NOMBRE_TIPO":"$NOMBRE_TIPO"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo/codigonombretipos/pag">
		<call-query href="getEsfuenteetapatipoPagCodigonombretiposQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsfuenteetapatipoNumCodigonombretiposQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO TIPO , NOMBRE NOMBRE_TIPO  FROM ES_FUENTE_ETAPA_TIPO WHERE TIPO_OPCION IN (3)) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo/codigonombretipos/num">
		<call-query href="getEsfuenteetapatipoNumCodigonombretiposQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>

		</call-query>
	</resource>
	<query id="insertEsfuenteetapatipo" keyColumns="COMPANIA,CODIGO,TIPO_OPCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_FUENTE_ETAPA_TIPO (COMPANIA, CODIGO, NOMBRE, DESCRIPCION, TIPO_OPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :DESCRIPCION, :TIPO_OPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_TIPO_OPCION":"$TIPO_OPCION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO_OPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esfuenteetapatipo">
		<call-query href="insertEsfuenteetapatipo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPO_OPCION" query-param="TIPO_OPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsfuenteetapatipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_FUENTE_ETAPA_TIPO WHERE ES_FUENTE_ETAPA_TIPO.COMPANIA= :KEY_COMPANIA AND ES_FUENTE_ETAPA_TIPO.CODIGO= :KEY_CODIGO AND ES_FUENTE_ETAPA_TIPO.TIPO_OPCION= :KEY_TIPO_OPCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPO_OPCION" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="esfuenteetapatipo">
		<call-query href="deleteEsfuenteetapatipo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPO_OPCION" query-param="KEY_TIPO_OPCION"/>

		</call-query>
	</resource>
	<query id="getEsfuenteetapatipoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, DESCRIPCION, TIPO_OPCION  FROM ES_FUENTE_ETAPA_TIPO WHERE COMPANIA = :COMPANIA AND TIPO_OPCION = :TIPO_OPERACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","TIPO_OPCION":"$TIPO_OPCION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_OPERACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo">
		<call-query href="getEsfuenteetapatipoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_OPERACION" query-param="TIPO_OPERACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsfuenteetapatipoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, DESCRIPCION, TIPO_OPCION  FROM ES_FUENTE_ETAPA_TIPO WHERE COMPANIA = :COMPANIA AND TIPO_OPCION = :TIPO_OPERACION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_OPERACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esfuenteetapatipo/numero">
		<call-query href="getEsfuenteetapatipoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_OPERACION" query-param="TIPO_OPERACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateEsfuenteetapatipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_FUENTE_ETAPA_TIPO SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_FUENTE_ETAPA_TIPO.COMPANIA= :KEY_COMPANIA AND ES_FUENTE_ETAPA_TIPO.CODIGO= :KEY_CODIGO AND ES_FUENTE_ETAPA_TIPO.TIPO_OPCION= :KEY_TIPO_OPCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPO_OPCION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esfuenteetapatipo">
		<call-query href="updateEsfuenteetapatipo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPO_OPCION" query-param="KEY_TIPO_OPCION"/>

		</call-query>
	</resource>

</data>