<data name="configcierrepptal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConfigcierrepptalPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONFIG_CIERRE_PPTAL.COMPANIA, PCK_PRESUPUESTO_CIE.FC_NOMBRETIPOCIERRE( CONFIG_CIERRE_PPTAL.TIPOCIERRE ) NOMBRETIPOCIERRE, CONFIG_CIERRE_PPTAL.TIPOCIERRE, CONFIG_CIERRE_PPTAL.CLASERESERVA, TINI.NOMBRE NOMBREVINI, TFIN.NOMBRE NOMBREVFIN, CONFIG_CIERRE_PPTAL.TIPOVIGENCIAINICI, CONFIG_CIERRE_PPTAL.TIPOVIGENCIAFINAL, CONFIG_CIERRE_PPTAL.DIGITOSCAMBIO,(CASE CONFIG_CIERRE_PPTAL.CREAJERARQUIA WHEN 0 THEN 'false' ELSE 'true' END) CREAJERARQUIA,(CASE CONFIG_CIERRE_PPTAL.GENERAR WHEN 0 THEN 'false' ELSE 'true' END) GENERAR, TIPO_DIS, TIPO_REO, TIPO_RES, TIPO_ADI, TDIS.NOMBRE NOMBRE_DIS, TREO.NOMBRE NOMBRE_REO, TRES.NOMBRE NOMBRE_RES, TADI.NOMBRE NOMBRE_ADI,(CASE CONFIG_CIERRE_PPTAL.RECLASIFICAR WHEN 0 THEN 'false' ELSE 'true' END) RECLASIFICAR FROM CONFIG_CIERRE_PPTAL LEFT JOIN TIPO_COMPROBPP TDIS ON TDIS.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TDIS.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_DIS LEFT JOIN TIPO_COMPROBPP TREO ON TREO.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TREO.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_REO LEFT JOIN TIPO_COMPROBPP TRES ON TRES.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TRES.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_RES LEFT JOIN TIPO_COMPROBPP TADI ON TADI.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TADI.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_ADI LEFT JOIN TIPOVIGENCIA TINI ON TINI.CODIGO = CONFIG_CIERRE_PPTAL.TIPOVIGENCIAINICI LEFT JOIN TIPOVIGENCIA TFIN ON TFIN.CODIGO = CONFIG_CIERRE_PPTAL.TIPOVIGENCIAFINAL WHERE CONFIG_CIERRE_PPTAL.COMPANIA = :COMPANIA ORDER BY CONFIG_CIERRE_PPTAL.TIPOCIERRE, CONFIG_CIERRE_PPTAL.CLASERESERVA) WHERE (CASE WHEN NOMBRETIPOCIERRE IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOCIERRE) END)  LIKE UPPER( '%' || :NOMBRETIPOCIERRE || '%')  AND (CASE WHEN CLASERESERVA IS NULL THEN ' ' ELSE UPPER(CLASERESERVA) END)  LIKE UPPER( '%' || :CLASERESERVA || '%')  AND (CASE WHEN NOMBREVINI IS NULL THEN ' ' ELSE UPPER(NOMBREVINI) END)  LIKE UPPER( '%' || :NOMBREVINI || '%')  AND (CASE WHEN NOMBREVFIN IS NULL THEN ' ' ELSE UPPER(NOMBREVFIN) END)  LIKE UPPER( '%' || :NOMBREVFIN || '%')  AND (CASE WHEN DIGITOSCAMBIO IS NULL THEN ' ' ELSE UPPER(DIGITOSCAMBIO) END)  LIKE UPPER( '%' || :DIGITOSCAMBIO || '%')  AND (CASE WHEN CREAJERARQUIA IS NULL THEN ' ' ELSE UPPER(CREAJERARQUIA) END)  LIKE UPPER(:CREAJERARQUIA || '%')  AND (CASE WHEN GENERAR IS NULL THEN ' ' ELSE UPPER(GENERAR) END)  LIKE UPPER(:GENERAR || '%')  AND (CASE WHEN NOMBRE_DIS IS NULL THEN ' ' ELSE UPPER(NOMBRE_DIS) END)  LIKE UPPER( '%' || :NOMBRE_DIS || '%')  AND (CASE WHEN NOMBRE_REO IS NULL THEN ' ' ELSE UPPER(NOMBRE_REO) END)  LIKE UPPER( '%' || :NOMBRE_REO || '%')  AND (CASE WHEN NOMBRE_RES IS NULL THEN ' ' ELSE UPPER(NOMBRE_RES) END)  LIKE UPPER( '%' || :NOMBRE_RES || '%')  AND (CASE WHEN NOMBRE_ADI IS NULL THEN ' ' ELSE UPPER(NOMBRE_ADI) END)  LIKE UPPER( '%' || :NOMBRE_ADI || '%')  AND (CASE WHEN RECLASIFICAR IS NULL THEN ' ' ELSE UPPER(RECLASIFICAR) END)  LIKE UPPER( '%' || :RECLASIFICAR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NOMBRETIPOCIERRE":"$NOMBRETIPOCIERRE","TIPOCIERRE":"$TIPOCIERRE","CLASERESERVA":"$CLASERESERVA","NOMBREVINI":"$NOMBREVINI","NOMBREVFIN":"$NOMBREVFIN","TIPOVIGENCIAINICI":"$TIPOVIGENCIAINICI","TIPOVIGENCIAFINAL":"$TIPOVIGENCIAFINAL","DIGITOSCAMBIO":"$DIGITOSCAMBIO","CREAJERARQUIA":"$CREAJERARQUIA(type:boolean)","GENERAR":"$GENERAR(type:boolean)","TIPO_DIS":"$TIPO_DIS","TIPO_REO":"$TIPO_REO","TIPO_RES":"$TIPO_RES","TIPO_ADI":"$TIPO_ADI","NOMBRE_DIS":"$NOMBRE_DIS","NOMBRE_REO":"$NOMBRE_REO","NOMBRE_RES":"$NOMBRE_RES","NOMBRE_ADI":"$NOMBRE_ADI","RECLASIFICAR":"$RECLASIFICAR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRETIPOCIERRE" sqlType="STRING"/>
		<param name="CLASERESERVA" sqlType="STRING"/>
		<param name="NOMBREVINI" sqlType="STRING"/>
		<param name="NOMBREVFIN" sqlType="STRING"/>
		<param name="DIGITOSCAMBIO" sqlType="STRING"/>
		<param name="CREAJERARQUIA" sqlType="STRING"/>
		<param name="GENERAR" sqlType="STRING"/>
		<param name="NOMBRE_DIS" sqlType="STRING"/>
		<param name="NOMBRE_REO" sqlType="STRING"/>
		<param name="NOMBRE_RES" sqlType="STRING"/>
		<param name="NOMBRE_ADI" sqlType="STRING"/>
		<param name="RECLASIFICAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="configcierrepptal/todosporcompania/pag">
		<call-query href="getConfigcierrepptalPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRETIPOCIERRE" query-param="NOMBRETIPOCIERRE"/>
			<with-param name="CLASERESERVA" query-param="CLASERESERVA"/>
			<with-param name="NOMBREVINI" query-param="NOMBREVINI"/>
			<with-param name="NOMBREVFIN" query-param="NOMBREVFIN"/>
			<with-param name="DIGITOSCAMBIO" query-param="DIGITOSCAMBIO"/>
			<with-param name="CREAJERARQUIA" query-param="CREAJERARQUIA"/>
			<with-param name="GENERAR" query-param="GENERAR"/>
			<with-param name="NOMBRE_DIS" query-param="NOMBRE_DIS"/>
			<with-param name="NOMBRE_REO" query-param="NOMBRE_REO"/>
			<with-param name="NOMBRE_RES" query-param="NOMBRE_RES"/>
			<with-param name="NOMBRE_ADI" query-param="NOMBRE_ADI"/>
			<with-param name="RECLASIFICAR" query-param="RECLASIFICAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConfigcierrepptalNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONFIG_CIERRE_PPTAL.COMPANIA, PCK_PRESUPUESTO_CIE.FC_NOMBRETIPOCIERRE( CONFIG_CIERRE_PPTAL.TIPOCIERRE ) NOMBRETIPOCIERRE, CONFIG_CIERRE_PPTAL.TIPOCIERRE, CONFIG_CIERRE_PPTAL.CLASERESERVA, TINI.NOMBRE NOMBREVINI, TFIN.NOMBRE NOMBREVFIN, CONFIG_CIERRE_PPTAL.TIPOVIGENCIAINICI, CONFIG_CIERRE_PPTAL.TIPOVIGENCIAFINAL, CONFIG_CIERRE_PPTAL.DIGITOSCAMBIO,(CASE CONFIG_CIERRE_PPTAL.CREAJERARQUIA WHEN 0 THEN 'false' ELSE 'true' END) CREAJERARQUIA,(CASE CONFIG_CIERRE_PPTAL.GENERAR WHEN 0 THEN 'false' ELSE 'true' END) GENERAR, TIPO_DIS, TIPO_REO, TIPO_RES, TIPO_ADI, TDIS.NOMBRE NOMBRE_DIS, TREO.NOMBRE NOMBRE_REO, TRES.NOMBRE NOMBRE_RES, TADI.NOMBRE NOMBRE_ADI,(CASE CONFIG_CIERRE_PPTAL.RECLASIFICAR WHEN 0 THEN 'false' ELSE 'true' END) RECLASIFICAR FROM CONFIG_CIERRE_PPTAL LEFT JOIN TIPO_COMPROBPP TDIS ON TDIS.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TDIS.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_DIS LEFT JOIN TIPO_COMPROBPP TREO ON TREO.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TREO.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_REO LEFT JOIN TIPO_COMPROBPP TRES ON TRES.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TRES.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_RES LEFT JOIN TIPO_COMPROBPP TADI ON TADI.COMPANIA = CONFIG_CIERRE_PPTAL.COMPANIA AND TADI.CODIGO = CONFIG_CIERRE_PPTAL.TIPO_ADI LEFT JOIN TIPOVIGENCIA TINI ON TINI.CODIGO = CONFIG_CIERRE_PPTAL.TIPOVIGENCIAINICI LEFT JOIN TIPOVIGENCIA TFIN ON TFIN.CODIGO = CONFIG_CIERRE_PPTAL.TIPOVIGENCIAFINAL WHERE CONFIG_CIERRE_PPTAL.COMPANIA = :COMPANIA ORDER BY CONFIG_CIERRE_PPTAL.TIPOCIERRE, CONFIG_CIERRE_PPTAL.CLASERESERVA) WHERE (CASE WHEN NOMBRETIPOCIERRE IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOCIERRE) END)  LIKE UPPER( '%' || :NOMBRETIPOCIERRE || '%')  AND (CASE WHEN CLASERESERVA IS NULL THEN ' ' ELSE UPPER(CLASERESERVA) END)  LIKE UPPER( '%' || :CLASERESERVA || '%')  AND (CASE WHEN NOMBREVINI IS NULL THEN ' ' ELSE UPPER(NOMBREVINI) END)  LIKE UPPER( '%' || :NOMBREVINI || '%')  AND (CASE WHEN NOMBREVFIN IS NULL THEN ' ' ELSE UPPER(NOMBREVFIN) END)  LIKE UPPER( '%' || :NOMBREVFIN || '%')  AND (CASE WHEN DIGITOSCAMBIO IS NULL THEN ' ' ELSE UPPER(DIGITOSCAMBIO) END)  LIKE UPPER( '%' || :DIGITOSCAMBIO || '%')  AND (CASE WHEN CREAJERARQUIA IS NULL THEN ' ' ELSE UPPER(CREAJERARQUIA) END)  LIKE UPPER(:CREAJERARQUIA || '%')  AND (CASE WHEN GENERAR IS NULL THEN ' ' ELSE UPPER(GENERAR) END)  LIKE UPPER(:GENERAR || '%')  AND (CASE WHEN NOMBRE_DIS IS NULL THEN ' ' ELSE UPPER(NOMBRE_DIS) END)  LIKE UPPER( '%' || :NOMBRE_DIS || '%')  AND (CASE WHEN NOMBRE_REO IS NULL THEN ' ' ELSE UPPER(NOMBRE_REO) END)  LIKE UPPER( '%' || :NOMBRE_REO || '%')  AND (CASE WHEN NOMBRE_RES IS NULL THEN ' ' ELSE UPPER(NOMBRE_RES) END)  LIKE UPPER( '%' || :NOMBRE_RES || '%')  AND (CASE WHEN NOMBRE_ADI IS NULL THEN ' ' ELSE UPPER(NOMBRE_ADI) END)  LIKE UPPER( '%' || :NOMBRE_ADI || '%')  AND (CASE WHEN RECLASIFICAR IS NULL THEN ' ' ELSE UPPER(RECLASIFICAR) END)  LIKE UPPER( '%' || :RECLASIFICAR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRETIPOCIERRE" sqlType="STRING"/>
		<param name="CLASERESERVA" sqlType="STRING"/>
		<param name="NOMBREVINI" sqlType="STRING"/>
		<param name="NOMBREVFIN" sqlType="STRING"/>
		<param name="DIGITOSCAMBIO" sqlType="STRING"/>
		<param name="CREAJERARQUIA" sqlType="STRING"/>
		<param name="GENERAR" sqlType="STRING"/>
		<param name="NOMBRE_DIS" sqlType="STRING"/>
		<param name="NOMBRE_REO" sqlType="STRING"/>
		<param name="NOMBRE_RES" sqlType="STRING"/>
		<param name="NOMBRE_ADI" sqlType="STRING"/>
		<param name="RECLASIFICAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configcierrepptal/todosporcompania/num">
		<call-query href="getConfigcierrepptalNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRETIPOCIERRE" query-param="NOMBRETIPOCIERRE"/>
			<with-param name="CLASERESERVA" query-param="CLASERESERVA"/>
			<with-param name="NOMBREVINI" query-param="NOMBREVINI"/>
			<with-param name="NOMBREVFIN" query-param="NOMBREVFIN"/>
			<with-param name="DIGITOSCAMBIO" query-param="DIGITOSCAMBIO"/>
			<with-param name="CREAJERARQUIA" query-param="CREAJERARQUIA"/>
			<with-param name="GENERAR" query-param="GENERAR"/>
			<with-param name="NOMBRE_DIS" query-param="NOMBRE_DIS"/>
			<with-param name="NOMBRE_REO" query-param="NOMBRE_REO"/>
			<with-param name="NOMBRE_RES" query-param="NOMBRE_RES"/>
			<with-param name="NOMBRE_ADI" query-param="NOMBRE_ADI"/>
			<with-param name="RECLASIFICAR" query-param="RECLASIFICAR"/>

		</call-query>
	</resource>
	<query id="updateConfigcierrepptalPorCompania" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONFIG_CIERRE_PPTAL SET CREAJERARQUIA=:CREAJERARQUIA, GENERAR=:GENERAR, TIPO_DIS=:TIPO_DIS, TIPO_REO=:TIPO_REO, TIPO_RES=:TIPO_RES, TIPO_ADI=:TIPO_ADI, DIGITOSCAMBIO=:DIGITOSCAMBIO, RECLASIFICAR=:RECLASIFICAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONFIG_CIERRE_PPTAL.COMPANIA= :KEY_COMPANIA AND CONFIG_CIERRE_PPTAL.TIPOCIERRE= :KEY_TIPOCIERRE AND CONFIG_CIERRE_PPTAL.CLASERESERVA= :KEY_CLASERESERVA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CREAJERARQUIA" sqlType="STRING"/>
		<param name="GENERAR" sqlType="STRING"/>
		<param name="TIPO_DIS" sqlType="STRING"/>
		<param name="TIPO_REO" sqlType="STRING"/>
		<param name="TIPO_RES" sqlType="STRING"/>
		<param name="TIPO_ADI" sqlType="STRING"/>
		<param name="DIGITOSCAMBIO" sqlType="STRING"/>
		<param name="RECLASIFICAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCIERRE" sqlType="STRING"/>
		<param name="KEY_CLASERESERVA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="configcierrepptal/porcompania">
		<call-query href="updateConfigcierrepptalPorCompania">
			<with-param name="CREAJERARQUIA" query-param="CREAJERARQUIA"/>
			<with-param name="GENERAR" query-param="GENERAR"/>
			<with-param name="TIPO_DIS" query-param="TIPO_DIS"/>
			<with-param name="TIPO_REO" query-param="TIPO_REO"/>
			<with-param name="TIPO_RES" query-param="TIPO_RES"/>
			<with-param name="TIPO_ADI" query-param="TIPO_ADI"/>
			<with-param name="DIGITOSCAMBIO" query-param="DIGITOSCAMBIO"/>
			<with-param name="RECLASIFICAR" query-param="RECLASIFICAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCIERRE" query-param="KEY_TIPOCIERRE"/>
			<with-param name="KEY_CLASERESERVA" query-param="KEY_CLASERESERVA"/>

		</call-query>
	</resource>
	<query id="deleteConfigcierrepptalPorCompania" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE CONFIG_CIERRE_PPTAL WHERE CONFIG_CIERRE_PPTAL.COMPANIA  = :KEY_COMPANIA AND CONFIG_CIERRE_PPTAL.TIPOCIERRE  = :KEY_TIPOCIERRE AND CONFIG_CIERRE_PPTAL.CLASERESERVA= :KEY_CLASERESERVA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCIERRE" sqlType="STRING"/>
		<param name="KEY_CLASERESERVA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="configcierrepptal/porcompania">
		<call-query href="deleteConfigcierrepptalPorCompania">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCIERRE" query-param="KEY_TIPOCIERRE"/>
			<with-param name="KEY_CLASERESERVA" query-param="KEY_CLASERESERVA"/>

		</call-query>
	</resource>

</data>