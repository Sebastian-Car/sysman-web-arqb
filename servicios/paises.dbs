<data name="paises" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPaisesTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PAISES.PAIS, PAISES.NOMBRE  FROM PAISES ORDER BY PAISES.PAIS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="paises/todos">
		<call-query href="getPaisesTodosQuery">
 
		</call-query>
	</resource>
	<query id="getPaisesTodosPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PAIS, NOMBRE  FROM PAISES ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="paises/todospornombre">
		<call-query href="getPaisesTodosPorNombreQuery">
 
		</call-query>
	</resource>
	<query id="getPaisesPagTodosPorNombreyCodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PAISES.PAIS CODIGO, PAISES.NOMBRE FROM PAISES ORDER BY PAIS) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="paises/todospornombreycod/pag">
		<call-query href="getPaisesPagTodosPorNombreyCodQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPaisesNumTodosPorNombreyCodQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PAISES.PAIS CODIGO, PAISES.NOMBRE FROM PAISES ORDER BY PAIS) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="paises/todospornombreycod/num">
		<call-query href="getPaisesNumTodosPorNombreyCodQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPaisesNombrePaisOrigenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PAISES.PAIS, PAISES.NOMBRE PAISORIGENNOMBRE  FROM PAISES ORDER BY PAISES.PAIS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","PAISORIGENNOMBRE":"$PAISORIGENNOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="paises/nombrepaisorigen">
		<call-query href="getPaisesNombrePaisOrigenQuery">
 
		</call-query>
	</resource>
	<query id="getPaisesNombrePaisDesinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PAISES.PAIS, PAISES.NOMBRE PAISDESTINONOMBRE  FROM PAISES ORDER BY PAISES.PAIS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","PAISDESTINONOMBRE":"$PAISDESTINONOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="paises/nombrepaisdesino">
		<call-query href="getPaisesNombrePaisDesinoQuery">
 
		</call-query>
	</resource>
	<query id="getPaisesListadbasicosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PAISES.PAIS, PAISES.NOMBRE NOMBREPAIS  FROM PAISES ORDER BY PAISES.PAIS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","NOMBREPAIS":"$NOMBREPAIS"}]}}		</result>
 
	</query>
	<resource method="GET" path="paises/listadbasicos">
		<call-query href="getPaisesListadbasicosQuery">
 
		</call-query>
	</resource>
	<query id="getPaisesCodigopornombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PAIS  FROM PAISES WHERE NOMBRE = :NOMBRE_PAIS and ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS"}]}}		</result>
		<param name="NOMBRE_PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="paises/codigopornombre">
		<call-query href="getPaisesCodigopornombreQuery">
			<with-param name="NOMBRE_PAIS" query-param="NOMBRE_PAIS"/>

		</call-query>
	</resource>
	<query id="getPaisesTodoscodigoynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT PAIS AS CODIGO, NOMBRE FROM PAISES ORDER BY PAIS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="paises/todoscodigoynombre">
		<call-query href="getPaisesTodoscodigoynombreQuery">
 
		</call-query>
	</resource>
	<query id="insertPaises" keyColumns="PAIS" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PAISES (PAIS, NOMBRE, CODIGODIAN, CODIGODANE, DATE_CREATED, CREATED_BY) VALUES (:PAIS, :NOMBRE, :CODIGODIAN, :CODIGODANE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_PAIS":"$PAIS"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGODIAN" sqlType="STRING"/>
		<param defaultValue="" name="CODIGODANE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="paises">
		<call-query href="insertPaises">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGODIAN" query-param="CODIGODIAN"/>
			<with-param name="CODIGODANE" query-param="CODIGODANE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePaises" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PAISES WHERE PAISES.PAIS= :KEY_PAIS</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_PAIS" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="paises">
		<call-query href="deletePaises">
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>

		</call-query>
	</resource>
	<query id="getPaisesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PAIS, NOMBRE, CODIGODIAN, CODIGODANE  FROM PAISES ORDER BY PAIS) WHERE (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGODIAN IS NULL THEN ' ' ELSE UPPER(CODIGODIAN) END)  LIKE UPPER( '%' || :CODIGODIAN || '%')  AND (CASE WHEN CODIGODANE IS NULL THEN ' ' ELSE UPPER(CODIGODANE) END)  LIKE UPPER( '%' || :CODIGODANE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","NOMBRE":"$NOMBRE","CODIGODIAN":"$CODIGODIAN","CODIGODANE":"$CODIGODANE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGODIAN" sqlType="STRING"/>
		<param name="CODIGODANE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="paises">
		<call-query href="getPaisesPaginaQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGODIAN" query-param="CODIGODIAN"/>
			<with-param name="CODIGODANE" query-param="CODIGODANE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPaisesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PAIS, NOMBRE, CODIGODIAN, CODIGODANE  FROM PAISES ORDER BY PAIS) WHERE (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGODIAN IS NULL THEN ' ' ELSE UPPER(CODIGODIAN) END)  LIKE UPPER( '%' || :CODIGODIAN || '%')  AND (CASE WHEN CODIGODANE IS NULL THEN ' ' ELSE UPPER(CODIGODANE) END)  LIKE UPPER( '%' || :CODIGODANE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGODIAN" sqlType="STRING"/>
		<param name="CODIGODANE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="paises/numero">
		<call-query href="getPaisesNumeroQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGODIAN" query-param="CODIGODIAN"/>
			<with-param name="CODIGODANE" query-param="CODIGODANE"/>

		</call-query>
	</resource>
	<query id="updatePaises" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PAISES SET PAIS=:PAIS, NOMBRE=:NOMBRE, CODIGODIAN=:CODIGODIAN, CODIGODANE=:CODIGODANE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PAISES.PAIS= :KEY_PAIS</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGODIAN" sqlType="STRING"/>
		<param name="CODIGODANE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_PAIS" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="paises">
		<call-query href="updatePaises">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGODIAN" query-param="CODIGODIAN"/>
			<with-param name="CODIGODANE" query-param="CODIGODANE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>

		</call-query>
	</resource>

</data>