<data name="claseclasificador" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertClaseclasificadorPostclaseclasificador" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CLASECLASIFICADOR (COMPANIA, ANO, CODIGO, NOMBRE, APLICACION, APLICACIONINGRESOS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :APLICACION, :APLICACIONINGRESOS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="APLICACION" sqlType="STRING"/>
		<param defaultValue="0" name="APLICACIONINGRESOS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="claseclasificador/postclaseclasificador">
		<call-query href="insertClaseclasificadorPostclaseclasificador">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="APLICACIONINGRESOS" query-param="APLICACIONINGRESOS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateClaseclasificadorPutclaseclasificador" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CLASECLASIFICADOR SET COMPANIA=:COMPANIA, ANO=:ANO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, APLICACION=:APLICACION, APLICACIONINGRESOS=:APLICACIONINGRESOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CLASECLASIFICADOR.COMPANIA= :KEY_COMPANIA AND CLASECLASIFICADOR.ANO= :KEY_ANO AND CLASECLASIFICADOR.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="APLICACIONINGRESOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="claseclasificador/putclaseclasificador">
		<call-query href="updateClaseclasificadorPutclaseclasificador">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="APLICACIONINGRESOS" query-param="APLICACIONINGRESOS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="insertClaseclasificadorInsertclasificadoranonuevo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql> INSERT INTO CLASECLASIFICADOR (COMPANIA,ANO,CODIGO,NOMBRE,APLICACION,APLICACIONINGRESOS,CREATED_BY,DATE_CREATED) SELECT COMPANIA, :ANOPREPARAR ,CODIGO,NOMBRE,APLICACION,APLICACIONINGRESOS, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS') FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANOPREPARAR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="claseclasificador/insertclasificadoranonuevo">
		<call-query href="insertClaseclasificadorInsertclasificadoranonuevo">
			<with-param name="ANOPREPARAR" query-param="ANOPREPARAR"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorGetclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASECLASIFICADOR.CODIGO, CLASECLASIFICADOR.NOMBRE FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY CLASECLASIFICADOR.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/getclasificadores">
		<call-query href="getClaseclasificadorGetclasificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorPagGetclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CLASECLASIFICADOR.CODIGO, CLASECLASIFICADOR.NOMBRE FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANIO ORDER BY CLASECLASIFICADOR.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="claseclasificador/getclasificadores/pag">
		<call-query href="getClaseclasificadorPagGetclasificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorNumGetclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CLASECLASIFICADOR.CODIGO, CLASECLASIFICADOR.NOMBRE FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANIO ORDER BY CLASECLASIFICADOR.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/getclasificadores/num">
		<call-query href="getClaseclasificadorNumGetclasificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorClasificadorvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_NUMBER(APLICACION) APLICACION FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CLASIFICADOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APLICACION":"$APLICACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASIFICADOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/clasificadorvigencia">
		<call-query href="getClaseclasificadorClasificadorvigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASIFICADOR" query-param="CLASIFICADOR"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorGetclaseclasificadorclasepadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASEPADRE FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CLASE AND CLASEPADRE IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEPADRE":"$CLASEPADRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/getclaseclasificadorclasepadre">
		<call-query href="getClaseclasificadorGetclaseclasificadorclasepadreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorGetaplicacionclaseclasificadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, APLICACION FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","APLICACION":"$APLICACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/getaplicacionclaseclasificador">
		<call-query href="getClaseclasificadorGetaplicacionclaseclasificadorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="insertClaseclasificador" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CLASECLASIFICADOR (COMPANIA, ANO, CODIGO, NOMBRE, APLICACION, APLICACIONINGRESOS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :APLICACION, :APLICACIONINGRESOS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="APLICACION" sqlType="STRING"/>
		<param defaultValue="0" name="APLICACIONINGRESOS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="claseclasificador">
		<call-query href="insertClaseclasificador">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="APLICACIONINGRESOS" query-param="APLICACIONINGRESOS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteClaseclasificador" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CLASECLASIFICADOR WHERE CLASECLASIFICADOR.COMPANIA= :KEY_COMPANIA AND CLASECLASIFICADOR.ANO= :KEY_ANO AND CLASECLASIFICADOR.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="claseclasificador">
		<call-query href="deleteClaseclasificador">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE ,CASE APLICACION WHEN 0 THEN 'No Aplica' WHEN 1 THEN 'Rubro' WHEN 2 THEN 'Detalle' END AS NOMBREAPLICACION, CASE APLICACIONINGRESOS WHEN 0 THEN 'No Aplica' WHEN 1 THEN 'Rubro' WHEN 2 THEN 'Detalle' END AS NOMAPLIINGRE, APLICACION, APLICACIONINGRESOS, ORDEN FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPAIA ORDER BY COMPANIA,ANO DESC,CODIGO ASC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREAPLICACION IS NULL THEN ' ' ELSE UPPER(NOMBREAPLICACION) END) LIKE UPPER(CONCAT(:NOMBREAPLICACION, '%')) AND (CASE WHEN NOMAPLIINGRE IS NULL THEN ' ' ELSE UPPER(NOMAPLIINGRE) END) LIKE UPPER(CONCAT(:NOMAPLIINGRE, '%')) AND (CASE WHEN APLICACION IS NULL THEN ' ' ELSE UPPER(APLICACION) END) LIKE UPPER(CONCAT(:APLICACION, '%')) AND (CASE WHEN APLICACIONINGRESOS IS NULL THEN ' ' ELSE UPPER(APLICACIONINGRESOS) END) LIKE UPPER(CONCAT(:APLICACIONINGRESOS, '%')) AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END) LIKE UPPER(CONCAT(:ORDEN, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NOMBREAPLICACION":"$NOMBREAPLICACION","NOMAPLIINGRE":"$NOMAPLIINGRE","APLICACION":"$APLICACION(type:integer)","APLICACIONINGRESOS":"$APLICACIONINGRESOS(type:integer)","ORDEN":"$ORDEN(type:integer)"}]}}		</result>
		<param name="COMPAIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREAPLICACION" sqlType="STRING"/>
		<param name="NOMAPLIINGRE" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="APLICACIONINGRESOS" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="claseclasificador">
		<call-query href="getClaseclasificadorPaginaQuery">
			<with-param name="COMPAIA" query-param="COMPAIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREAPLICACION" query-param="NOMBREAPLICACION"/>
			<with-param name="NOMAPLIINGRE" query-param="NOMAPLIINGRE"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="APLICACIONINGRESOS" query-param="APLICACIONINGRESOS"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE ,CASE APLICACION WHEN 0 THEN 'No Aplica' WHEN 1 THEN 'Rubro' WHEN 2 THEN 'Detalle' END AS NOMBREAPLICACION, CASE APLICACIONINGRESOS WHEN 0 THEN 'No Aplica' WHEN 1 THEN 'Rubro' WHEN 2 THEN 'Detalle' END AS NOMAPLIINGRE, APLICACION, APLICACIONINGRESOS, ORDEN FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPAIA ORDER BY COMPANIA,ANO DESC,CODIGO ASC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREAPLICACION IS NULL THEN ' ' ELSE UPPER(NOMBREAPLICACION) END) LIKE UPPER(CONCAT(:NOMBREAPLICACION, '%')) AND (CASE WHEN NOMAPLIINGRE IS NULL THEN ' ' ELSE UPPER(NOMAPLIINGRE) END) LIKE UPPER(CONCAT(:NOMAPLIINGRE, '%')) AND (CASE WHEN APLICACION IS NULL THEN ' ' ELSE UPPER(APLICACION) END) LIKE UPPER(CONCAT(:APLICACION, '%')) AND (CASE WHEN APLICACIONINGRESOS IS NULL THEN ' ' ELSE UPPER(APLICACIONINGRESOS) END) LIKE UPPER(CONCAT(:APLICACIONINGRESOS, '%')) AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END) LIKE UPPER(CONCAT(:ORDEN, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPAIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREAPLICACION" sqlType="STRING"/>
		<param name="NOMAPLIINGRE" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="APLICACIONINGRESOS" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/numero">
		<call-query href="getClaseclasificadorNumeroQuery">
			<with-param name="COMPAIA" query-param="COMPAIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREAPLICACION" query-param="NOMBREAPLICACION"/>
			<with-param name="NOMAPLIINGRE" query-param="NOMAPLIINGRE"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="APLICACIONINGRESOS" query-param="APLICACIONINGRESOS"/>
			<with-param name="ORDEN" query-param="ORDEN"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, CODIGO, NOMBRE ,CASE APLICACION WHEN 0 THEN 'No Aplica' WHEN 1 THEN 'Rubro' WHEN 2 THEN 'Detalle' END AS NOMBREAPLICACION, CASE APLICACIONINGRESOS WHEN 0 THEN 'No Aplica' WHEN 1 THEN 'Rubro' WHEN 2 THEN 'Detalle' END AS NOMAPLIINGRE, TO_CHAR(APLICACION) AS APLICACION, TO_CHAR(APLICACIONINGRESOS) AS APLICACIONINGRESOS FROM CLASECLASIFICADOR WHERE CLASECLASIFICADOR.COMPANIA= :KEY_COMPANIA AND CLASECLASIFICADOR.ANO= :KEY_ANO AND CLASECLASIFICADOR.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NOMBREAPLICACION":"$NOMBREAPLICACION","NOMAPLIINGRE":"$NOMAPLIINGRE","APLICACION":"$APLICACION","APLICACIONINGRESOS":"$APLICACIONINGRESOS"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/data">
		<call-query href="getClaseclasificadorRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateClaseclasificador" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CLASECLASIFICADOR SET APLICACION=:APLICACION, APLICACIONINGRESOS=:APLICACIONINGRESOS, ORDEN=:ORDEN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CLASECLASIFICADOR.COMPANIA= :KEY_COMPANIA AND CLASECLASIFICADOR.ANO= :KEY_ANO AND CLASECLASIFICADOR.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="APLICACION" sqlType="STRING"/>
		<param name="APLICACIONINGRESOS" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="claseclasificador">
		<call-query href="updateClaseclasificador">
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="APLICACIONINGRESOS" query-param="APLICACIONINGRESOS"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getClaseclasificadorGastosingrclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT APLICACION, APLICACIONINGRESOS FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APLICACION":"$APLICACION(type:integer)","APLICACIONINGRESOS":"$APLICACIONINGRESOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="claseclasificador/gastosingrclasificadores">
		<call-query href="getClaseclasificadorGastosingrclasificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>

</data>