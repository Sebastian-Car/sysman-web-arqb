<data name="dparametrosconsultas" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="deleteDparametrosconsultasTodos" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM D_PARAMETROSCONSULTAS WHERE D_PARAMETROSCONSULTAS.CODIGO_CONSULTA = :CODIGO_CONSULTA AND D_PARAMETROSCONSULTAS.COMPANIA = :COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dparametrosconsultas/todos">
		<call-query href="deleteDparametrosconsultasTodos">
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getDparametrosconsultasEtiquetaYTipoDeParametroQuery"  useConfig="sysmanirisst">
		<sql>SELECT  NOMBRE_PARAMETRO, ETIQUETA_PARAMETRO, TIPO_PARAMETRO  FROM D_PARAMETROSCONSULTAS WHERE COMPANIA = :COMPANIA AND CODIGO_CONSULTA = :CODIGO ORDER BY CODIGO_PARAMETRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_PARAMETRO":"$NOMBRE_PARAMETRO","ETIQUETA_PARAMETRO":"$ETIQUETA_PARAMETRO","TIPO_PARAMETRO":"$TIPO_PARAMETRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dparametrosconsultas/etiquetaytipodeparametro">
		<call-query href="getDparametrosconsultasEtiquetaYTipoDeParametroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertDparametrosconsultas" keyColumns="COMPANIA,CODIGO_CONSULTA,CODIGO_PARAMETRO" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO D_PARAMETROSCONSULTAS (COMPANIA, CODIGO_PARAMETRO, CODIGO_CONSULTA, CODIGO_FILTRO, NOMBRE_PARAMETRO, ETIQUETA_PARAMETRO, TIPO_PARAMETRO, VALOR_FILTRO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_PARAMETRO, :CODIGO_CONSULTA, :CODIGO_FILTRO, :NOMBRE_PARAMETRO, :ETIQUETA_PARAMETRO, :TIPO_PARAMETRO, :VALOR_FILTRO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_CONSULTA":"$CODIGO_CONSULTA","KEY_CODIGO_PARAMETRO":"$CODIGO_PARAMETRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_FILTRO" sqlType="STRING"/>
		<param name="NOMBRE_PARAMETRO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="TIPO_PARAMETRO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_FILTRO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dparametrosconsultas">
		<call-query href="insertDparametrosconsultas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_FILTRO" query-param="CODIGO_FILTRO"/>
			<with-param name="NOMBRE_PARAMETRO" query-param="NOMBRE_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="TIPO_PARAMETRO" query-param="TIPO_PARAMETRO"/>
			<with-param name="VALOR_FILTRO" query-param="VALOR_FILTRO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDparametrosconsultas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM D_PARAMETROSCONSULTAS WHERE D_PARAMETROSCONSULTAS.COMPANIA= :KEY_COMPANIA AND D_PARAMETROSCONSULTAS.CODIGO_CONSULTA= :KEY_CODIGO_CONSULTA AND D_PARAMETROSCONSULTAS.CODIGO_PARAMETRO= :KEY_CODIGO_PARAMETRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PARAMETRO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dparametrosconsultas">
		<call-query href="deleteDparametrosconsultas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONSULTA" query-param="KEY_CODIGO_CONSULTA"/>
			<with-param name="KEY_CODIGO_PARAMETRO" query-param="KEY_CODIGO_PARAMETRO"/>

		</call-query>
	</resource>
	<query id="getDparametrosconsultasPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_PARAMETROSCONSULTAS.COMPANIA , D_PARAMETROSCONSULTAS.CODIGO_CONSULTA , D_PARAMETROSCONSULTAS.CODIGO_PARAMETRO , D_PARAMETROSCONSULTAS.NOMBRE_PARAMETRO, D_PARAMETROSCONSULTAS.ETIQUETA_PARAMETRO, D_PARAMETROSCONSULTAS.TIPO_PARAMETRO , D_PARAMETROSCONSULTAS.VALOR_FILTRO, CASE D_PARAMETROSCONSULTAS.TIPO_PARAMETRO WHEN 'D' THEN 'Date' WHEN 'N' THEN 'Numeric' WHEN 'S' THEN 'String' WHEN 'C' THEN 'Clob' END NOMBRE_TIPO  FROM D_PARAMETROSCONSULTAS LEFT JOIN FILTROS ON D_PARAMETROSCONSULTAS.CODIGO_FILTRO = FILTROS.CODIGO_FILTRO WHERE D_PARAMETROSCONSULTAS.COMPANIA = :COMPANIA AND D_PARAMETROSCONSULTAS.CODIGO_CONSULTA = :CODIGO_CONSULTA ORDER BY D_PARAMETROSCONSULTAS.CODIGO_PARAMETRO) WHERE (CASE WHEN CODIGO_PARAMETRO IS NULL THEN ' ' ELSE UPPER(CODIGO_PARAMETRO) END)  LIKE UPPER(:CODIGO_PARAMETRO || '%')  AND (CASE WHEN ETIQUETA_PARAMETRO IS NULL THEN ' ' ELSE UPPER(ETIQUETA_PARAMETRO) END)  LIKE UPPER( '%' || :ETIQUETA_PARAMETRO || '%')  AND (CASE WHEN VALOR_FILTRO IS NULL THEN ' ' ELSE UPPER(VALOR_FILTRO) END)  LIKE UPPER( '%' || :VALOR_FILTRO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_CONSULTA":"$CODIGO_CONSULTA","CODIGO_PARAMETRO":"$CODIGO_PARAMETRO","NOMBRE_PARAMETRO":"$NOMBRE_PARAMETRO","ETIQUETA_PARAMETRO":"$ETIQUETA_PARAMETRO","TIPO_PARAMETRO":"$TIPO_PARAMETRO","VALOR_FILTRO":"$VALOR_FILTRO","NOMBRE_TIPO":"$NOMBRE_TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="VALOR_FILTRO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dparametrosconsultas">
		<call-query href="getDparametrosconsultasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="VALOR_FILTRO" query-param="VALOR_FILTRO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDparametrosconsultasNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_PARAMETROSCONSULTAS.COMPANIA , D_PARAMETROSCONSULTAS.CODIGO_CONSULTA , D_PARAMETROSCONSULTAS.CODIGO_PARAMETRO , D_PARAMETROSCONSULTAS.NOMBRE_PARAMETRO, D_PARAMETROSCONSULTAS.ETIQUETA_PARAMETRO, D_PARAMETROSCONSULTAS.TIPO_PARAMETRO , D_PARAMETROSCONSULTAS.VALOR_FILTRO, CASE D_PARAMETROSCONSULTAS.TIPO_PARAMETRO WHEN 'D' THEN 'Date' WHEN 'N' THEN 'Numeric' WHEN 'S' THEN 'String' WHEN 'C' THEN 'Clob' END NOMBRE_TIPO  FROM D_PARAMETROSCONSULTAS LEFT JOIN FILTROS ON D_PARAMETROSCONSULTAS.CODIGO_FILTRO = FILTROS.CODIGO_FILTRO WHERE D_PARAMETROSCONSULTAS.COMPANIA = :COMPANIA AND D_PARAMETROSCONSULTAS.CODIGO_CONSULTA = :CODIGO_CONSULTA ORDER BY D_PARAMETROSCONSULTAS.CODIGO_PARAMETRO) WHERE (CASE WHEN CODIGO_PARAMETRO IS NULL THEN ' ' ELSE UPPER(CODIGO_PARAMETRO) END)  LIKE UPPER(:CODIGO_PARAMETRO || '%')  AND (CASE WHEN ETIQUETA_PARAMETRO IS NULL THEN ' ' ELSE UPPER(ETIQUETA_PARAMETRO) END)  LIKE UPPER( '%' || :ETIQUETA_PARAMETRO || '%')  AND (CASE WHEN VALOR_FILTRO IS NULL THEN ' ' ELSE UPPER(VALOR_FILTRO) END)  LIKE UPPER( '%' || :VALOR_FILTRO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="VALOR_FILTRO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dparametrosconsultas/numero">
		<call-query href="getDparametrosconsultasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="VALOR_FILTRO" query-param="VALOR_FILTRO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>

		</call-query>
	</resource>
	<query id="updateDparametrosconsultas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE D_PARAMETROSCONSULTAS SET CODIGO_PARAMETRO=:CODIGO_PARAMETRO, CODIGO_CONSULTA=:CODIGO_CONSULTA, NOMBRE_PARAMETRO=:NOMBRE_PARAMETRO, ETIQUETA_PARAMETRO=:ETIQUETA_PARAMETRO, VALOR_FILTRO=:VALOR_FILTRO, TIPO_PARAMETRO=:TIPO_PARAMETRO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_PARAMETROSCONSULTAS.COMPANIA= :KEY_COMPANIA AND D_PARAMETROSCONSULTAS.CODIGO_CONSULTA= :KEY_CODIGO_CONSULTA AND D_PARAMETROSCONSULTAS.CODIGO_PARAMETRO= :KEY_CODIGO_PARAMETRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_PARAMETRO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="VALOR_FILTRO" sqlType="STRING"/>
		<param name="TIPO_PARAMETRO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PARAMETRO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dparametrosconsultas">
		<call-query href="updateDparametrosconsultas">
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="NOMBRE_PARAMETRO" query-param="NOMBRE_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="VALOR_FILTRO" query-param="VALOR_FILTRO"/>
			<with-param name="TIPO_PARAMETRO" query-param="TIPO_PARAMETRO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONSULTA" query-param="KEY_CODIGO_CONSULTA"/>
			<with-param name="KEY_CODIGO_PARAMETRO" query-param="KEY_CODIGO_PARAMETRO"/>

		</call-query>
	</resource>

</data>