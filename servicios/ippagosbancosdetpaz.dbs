<data name="ippagosbancosdetpaz" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIppagosbancosdetpazListarPagosBancosPyzQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA ,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC,PAG_BAN ,PAQUETE ,BARRAS ,TIPO ,CODIGO_PREDIO ,REFERENCIA ,VALOR  FROM IP_PAGOS_BANCOSDET_PAZ WHERE COMPANIA = :COMPANIA AND TRUNC(PREFEC)= :PREFEC AND PAQUETE= :PAQUETE AND PAG_BAN= :PAG_BAN ORDER BY IP_PAGOS_BANCOSDET_PAZ.CODIGO_PREDIO, IP_PAGOS_BANCOSDET_PAZ.REFERENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PREFEC":"$PREFEC","PAG_BAN":"$PAG_BAN","PAQUETE":"$PAQUETE","BARRAS":"$BARRAS","TIPO":"$TIPO","CODIGO_PREDIO":"$CODIGO_PREDIO","REFERENCIA":"$REFERENCIA","VALOR":"$VALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREFEC" sqlType="STRING"/>
		<param name="PAQUETE" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosbancosdetpaz/listarpagosbancospyz">
		<call-query href="getIppagosbancosdetpazListarPagosBancosPyzQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREFEC" query-param="PREFEC"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="PAG_BAN" query-param="PAG_BAN"/>

		</call-query>
	</resource>
	<query id="insertIppagosbancosdetpazAgregarPagosBancosPyz" keyColumns="PAG_BAN,PAQUETE,COMPANIA,TIPO,REFERENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_PAGOS_BANCOSDET_PAZ (COMPANIA, PREFEC, PAG_BAN, NUMERO_ORDEN, PAQUETE, BARRAS, TIPO, CODIGO_PREDIO, REFERENCIA, VALOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, TO_DATE(:PREFEC,'DD/MM/YYYY HH24:MI:SS'), :PAG_BAN, :NUMERO_ORDEN, :PAQUETE, :BARRAS, :TIPO, :CODIGO_PREDIO, :REFERENCIA, :VALOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_PREFEC":"$PREFEC","KEY_PAG_BAN":"$PAG_BAN","KEY_PAQUETE":"$PAQUETE","KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_REFERENCIA":"$REFERENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREFEC" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="PAQUETE" sqlType="STRING"/>
		<param defaultValue="" name="BARRAS" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO_PREDIO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ippagosbancosdetpaz/agregarpagosbancospyz">
		<call-query href="insertIppagosbancosdetpazAgregarPagosBancosPyz">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREFEC" query-param="PREFEC"/>
			<with-param name="PAG_BAN" query-param="PAG_BAN"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="BARRAS" query-param="BARRAS"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO_PREDIO" query-param="CODIGO_PREDIO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>

</data>