<data name="niifinventariocontas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNiifinventariocontasPagDepreciacionalmacenniifQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIIF_INVENTARIOCONTA.COMPANIA, NIIF_INVENTARIOCONTA.CODIGOELEMENTO, NIIF_INVENTARIOCONTA.CENTRO_COSTO, NIIF_INVENTARIOCONTA.ANO, NIIF_INVENTARIOCONTA.BODEGA, BODEGA.NOMBRE NOMBREBODEGA, NIIF_INVENTARIOCONTA.TIPOACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO, NIIF_INVENTARIOCONTA.CTADEBITOVLRACTIVO, NIIF_INVENTARIOCONTA.CTACREDITOVLRACTIVO, NIIF_INVENTARIOCONTA.CUENTACREDITO, NIIF_INVENTARIOCONTA.CUENTADEBITO  FROM NIIF_INVENTARIOCONTA INNER JOIN TIPO_ACTIVO ON NIIF_INVENTARIOCONTA.COMPANIA = TIPO_ACTIVO.COMPANIA AND NIIF_INVENTARIOCONTA.TIPOACTIVO = TIPO_ACTIVO.CODIGO_TIPOACTIVO INNER JOIN BODEGA ON NIIF_INVENTARIOCONTA.COMPANIA = BODEGA.COMPANIA AND NIIF_INVENTARIOCONTA.BODEGA = BODEGA.CODIGO WHERE NIIF_INVENTARIOCONTA.COMPANIA = :COMPANIA AND NIIF_INVENTARIOCONTA.CODIGOELEMENTO = :CODIGOELEMENTO AND NIIF_INVENTARIOCONTA.ANO = :ANO AND NIIF_INVENTARIOCONTA.CENTRO_COSTO = :CENTRO_COSTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN NOMBREBODEGA IS NULL THEN ' ' ELSE UPPER(NOMBREBODEGA) END)  LIKE UPPER(:NOMBREBODEGA || '%')  AND (CASE WHEN TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTIVO) END)  LIKE UPPER(:TIPOACTIVO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER(:NOMBRE_TIPOACTIVO || '%')  AND (CASE WHEN CTADEBITOVLRACTIVO IS NULL THEN ' ' ELSE UPPER(CTADEBITOVLRACTIVO) END)  LIKE UPPER(:CTADEBITOVLRACTIVO || '%')  AND (CASE WHEN CTACREDITOVLRACTIVO IS NULL THEN ' ' ELSE UPPER(CTACREDITOVLRACTIVO) END)  LIKE UPPER(:CTACREDITOVLRACTIVO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER(:CUENTACREDITO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER( '%' || :CUENTADEBITO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","CENTRO_COSTO":"$CENTRO_COSTO","ANO":"$ANO(type:integer)","BODEGA":"$BODEGA","NOMBREBODEGA":"$NOMBREBODEGA","TIPOACTIVO":"$TIPOACTIVO","NOMBRE_TIPOACTIVO":"$NOMBRE_TIPOACTIVO","CTADEBITOVLRACTIVO":"$CTADEBITOVLRACTIVO","CTACREDITOVLRACTIVO":"$CTACREDITOVLRACTIVO","CUENTACREDITO":"$CUENTACREDITO","CUENTADEBITO":"$CUENTADEBITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="NOMBREBODEGA" sqlType="STRING"/>
		<param name="TIPOACTIVO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>
		<param name="CTADEBITOVLRACTIVO" sqlType="STRING"/>
		<param name="CTACREDITOVLRACTIVO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="niifinventariocontas/depreciacionalmacenniif/pag">
		<call-query href="getNiifinventariocontasPagDepreciacionalmacenniifQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="NOMBREBODEGA" query-param="NOMBREBODEGA"/>
			<with-param name="TIPOACTIVO" query-param="TIPOACTIVO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>
			<with-param name="CTADEBITOVLRACTIVO" query-param="CTADEBITOVLRACTIVO"/>
			<with-param name="CTACREDITOVLRACTIVO" query-param="CTACREDITOVLRACTIVO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNiifinventariocontasNumDepreciacionalmacenniifQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NIIF_INVENTARIOCONTA.COMPANIA, NIIF_INVENTARIOCONTA.CODIGOELEMENTO, NIIF_INVENTARIOCONTA.CENTRO_COSTO, NIIF_INVENTARIOCONTA.ANO, NIIF_INVENTARIOCONTA.BODEGA, NIIF_INVENTARIOCONTA.TIPOACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO, NIIF_INVENTARIOCONTA.CTADEBITOVLRACTIVO, NIIF_INVENTARIOCONTA.CTACREDITOVLRACTIVO, NIIF_INVENTARIOCONTA.CUENTACREDITO, NIIF_INVENTARIOCONTA.CUENTADEBITO  FROM NIIF_INVENTARIOCONTA INNER JOIN TIPO_ACTIVO ON NIIF_INVENTARIOCONTA.COMPANIA = TIPO_ACTIVO.COMPANIA AND NIIF_INVENTARIOCONTA.TIPOACTIVO = TIPO_ACTIVO.CODIGO_TIPOACTIVO WHERE NIIF_INVENTARIOCONTA.COMPANIA = :COMPANIA AND NIIF_INVENTARIOCONTA.CODIGOELEMENTO = :CODIGOELEMENTO AND NIIF_INVENTARIOCONTA.ANO = :ANO AND NIIF_INVENTARIOCONTA.CENTRO_COSTO = :CENTRO_COSTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN BODEGA IS NULL THEN ' ' ELSE UPPER(BODEGA) END)  LIKE UPPER(:BODEGA || '%')  AND (CASE WHEN TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTIVO) END)  LIKE UPPER(:TIPOACTIVO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER(:NOMBRE_TIPOACTIVO || '%')  AND (CASE WHEN CTADEBITOVLRACTIVO IS NULL THEN ' ' ELSE UPPER(CTADEBITOVLRACTIVO) END)  LIKE UPPER(:CTADEBITOVLRACTIVO || '%')  AND (CASE WHEN CTACREDITOVLRACTIVO IS NULL THEN ' ' ELSE UPPER(CTACREDITOVLRACTIVO) END)  LIKE UPPER(:CTACREDITOVLRACTIVO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER(:CUENTACREDITO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER( '%' || :CUENTADEBITO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>
		<param name="TIPOACTIVO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>
		<param name="CTADEBITOVLRACTIVO" sqlType="STRING"/>
		<param name="CTACREDITOVLRACTIVO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="niifinventariocontas/depreciacionalmacenniif/num">
		<call-query href="getNiifinventariocontasNumDepreciacionalmacenniifQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="BODEGA" query-param="BODEGA"/>
			<with-param name="TIPOACTIVO" query-param="TIPOACTIVO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>
			<with-param name="CTADEBITOVLRACTIVO" query-param="CTADEBITOVLRACTIVO"/>
			<with-param name="CTACREDITOVLRACTIVO" query-param="CTACREDITOVLRACTIVO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>

		</call-query>
	</resource>
	<query id="insertNiifinventariocontas" keyColumns="COMPANIA,CODIGOELEMENTO,ANO,TIPOACTIVO,BODEGA,CENTRO_COSTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NIIF_INVENTARIOCONTA (COMPANIA, CODIGOELEMENTO, TIPOACTIVO, ANO, CENTRO_COSTO, CUENTACREDITO, CUENTADEBITO, CTADEBITOVLRACTIVO, CTACREDITOVLRACTIVO, BODEGA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGOELEMENTO, :TIPOACTIVO, :ANO, :CENTRO_COSTO, :CUENTACREDITO, :CUENTADEBITO, :CTADEBITOVLRACTIVO, :CTACREDITOVLRACTIVO, :BODEGA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOELEMENTO":"$CODIGOELEMENTO","KEY_ANO":"$ANO(type:integer)","KEY_TIPOACTIVO":"$TIPOACTIVO","KEY_BODEGA":"$BODEGA","KEY_CENTRO_COSTO":"$CENTRO_COSTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="TIPOACTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACREDITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADEBITO" sqlType="STRING"/>
		<param defaultValue="" name="CTADEBITOVLRACTIVO" sqlType="STRING"/>
		<param defaultValue="" name="CTACREDITOVLRACTIVO" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="niifinventariocontas">
		<call-query href="insertNiifinventariocontas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="TIPOACTIVO" query-param="TIPOACTIVO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>
			<with-param name="CTADEBITOVLRACTIVO" query-param="CTADEBITOVLRACTIVO"/>
			<with-param name="CTACREDITOVLRACTIVO" query-param="CTACREDITOVLRACTIVO"/>
			<with-param name="BODEGA" query-param="BODEGA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNiifinventariocontas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NIIF_INVENTARIOCONTA WHERE NIIF_INVENTARIOCONTA.COMPANIA= :KEY_COMPANIA AND NIIF_INVENTARIOCONTA.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND NIIF_INVENTARIOCONTA.ANO= :KEY_ANO AND NIIF_INVENTARIOCONTA.TIPOACTIVO= :KEY_TIPOACTIVO AND NIIF_INVENTARIOCONTA.BODEGA= :KEY_BODEGA AND NIIF_INVENTARIOCONTA.CENTRO_COSTO= :KEY_CENTRO_COSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOACTIVO" sqlType="STRING"/>
		<param name="KEY_BODEGA" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="niifinventariocontas">
		<call-query href="deleteNiifinventariocontas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOACTIVO" query-param="KEY_TIPOACTIVO"/>
			<with-param name="KEY_BODEGA" query-param="KEY_BODEGA"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>

		</call-query>
	</resource>
	<query id="updateNiifinventariocontas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NIIF_INVENTARIOCONTA SET COMPANIA=:COMPANIA, CODIGOELEMENTO=:CODIGOELEMENTO, TIPOACTIVO=:TIPOACTIVO, ANO=:ANO, CENTRO_COSTO=:CENTRO_COSTO, CUENTACREDITO=:CUENTACREDITO, CUENTADEBITO=:CUENTADEBITO, CTACREDITOVLRACTIVO=:CTACREDITOVLRACTIVO, CTADEBITOVLRACTIVO=:CTADEBITOVLRACTIVO, BODEGA=:BODEGA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NIIF_INVENTARIOCONTA.COMPANIA= :KEY_COMPANIA AND NIIF_INVENTARIOCONTA.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND NIIF_INVENTARIOCONTA.ANO= :KEY_ANO AND NIIF_INVENTARIOCONTA.TIPOACTIVO= :KEY_TIPOACTIVO AND NIIF_INVENTARIOCONTA.BODEGA= :KEY_BODEGA AND NIIF_INVENTARIOCONTA.CENTRO_COSTO= :KEY_CENTRO_COSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="TIPOACTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="CTACREDITOVLRACTIVO" sqlType="STRING"/>
		<param name="CTADEBITOVLRACTIVO" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOACTIVO" sqlType="STRING"/>
		<param name="KEY_BODEGA" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="niifinventariocontas">
		<call-query href="updateNiifinventariocontas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="TIPOACTIVO" query-param="TIPOACTIVO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>
			<with-param name="CTACREDITOVLRACTIVO" query-param="CTACREDITOVLRACTIVO"/>
			<with-param name="CTADEBITOVLRACTIVO" query-param="CTADEBITOVLRACTIVO"/>
			<with-param name="BODEGA" query-param="BODEGA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOACTIVO" query-param="KEY_TIPOACTIVO"/>
			<with-param name="KEY_BODEGA" query-param="KEY_BODEGA"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>

		</call-query>
	</resource>

</data>