<data name="spmodelotipopregunta" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getSpmodelotipopreguntaTodasPreguntasPorClaseQuery"  useConfig="sysmanirisst">
		<sql>SELECT  SP_MODELO_TIPO_PREGUNTA.PREGUNTA  FROM SP_MODELO_TIPO_PREGUNTA WHERE SP_MODELO_TIPO_PREGUNTA.COMPANIA = :COMPANIA AND SP_MODELO_TIPO_PREGUNTA.CLASE = :CLASE AND SP_MODELO_TIPO_PREGUNTA.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREGUNTA":"$PREGUNTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmodelotipopregunta/todaspreguntasporclase">
		<call-query href="getSpmodelotipopreguntaTodasPreguntasPorClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpmodelotipopreguntaTodosPorPreguntaSegunClaseQuery"  useConfig="sysmanirisst">
		<sql>SELECT  SP_MODELO_TIPO_PREGUNTA.CODIGO ,SP_MODELO_TIPO_PREGUNTA.PREGUNTA  FROM SP_MODELO_TIPO_PREGUNTA WHERE SP_MODELO_TIPO_PREGUNTA.COMPANIA = :COMPANIA AND SP_MODELO_TIPO_PREGUNTA.CLASE = :CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","PREGUNTA":"$PREGUNTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmodelotipopregunta/todosporpreguntasegunclase">
		<call-query href="getSpmodelotipopreguntaTodosPorPreguntaSegunClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>

</data>