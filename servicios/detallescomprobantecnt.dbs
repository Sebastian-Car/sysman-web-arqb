	<query id="getDetallescomprobantecntPagMovimientosconciliacionbancariaquery3Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D.COMPANIA, D.ANO, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, D.NRO_DOCUMENTO, TO_CHAR(D.FECHA, 'DD/MM/YYYY HH24:MI:SS') FECHA, D.VALOR_DEBITO, D.VALOR_CREDITO,(CASE D.PAGADOBANCO WHEN 0 THEN 'false' ELSE 'true' END) PAGADOBANCO, TO_CHAR(D.FECHA_CONCILIA, 'DD/MM/YYYY HH24:MI:SS') FECHA_CONCILIA, D.DESCRIPCION, D.TERCERO, D.TIPO_CPTE_AFECT, D.CMPTE_AFECTADO, TO_CHAR(D.FECHA_CONSIGNACIONPLANO, 'DD/MM/YYYY HH24:MI:SS') FECHA_CONSIGNACIONPLANO,(CASE D.SINIDENTIFICAR WHEN 0 THEN 'false' ELSE 'true' END) SINIDENTIFICAR, TO_CHAR(D.FECHA_IDENTIFICACION, 'DD/MM/YYYY HH24:MI:SS') FECHA_IDENTIFICACION, D.CONCILIADOR,(CASE C.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE C.ENTREGADO WHEN 0 THEN 'false' ELSE 'true' END) ENTREGADO FROM DETALLE_COMPROBANTE_CNT D INNER JOIN COMPROBANTE_CNT C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPO_CPTE = C.TIPO AND D.COMPROBANTE = C.NUMERO INNER JOIN TIPO_COMPROBANTE T ON T.COMPANIA = D.COMPANIA AND T.CODIGO = D.TIPO_CPTE WHERE D.COMPANIA = :COMPANIA AND D.CUENTA = :CUENTA AND INSTR(REPLACE(CONCAT(CONCAT('''', REPLACE(:CLASESCONTABLES, ' ', '')), ''''), ',', ''','''), T.CLASE_CONTABLE, 1) &gt; 0 AND ( ( TRUNC(D.FECHA) &lt;= TO_DATE(:ULTIMODIA, 'DD/MM/YYYY') AND D.PAGADOBANCO IN (0) ) OR ( d.fecha_concilia between to_date(concat(concat('01',:MES), :NUMERO_ANO), 'ddmmyyyy') and to_date(concat(concat('31',:MES), :NUMERO_ANO),'ddmmyyyy') ) ) ORDER BY D.FECHA, COMPROBANTE) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO), '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NRO_DOCUMENTO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(:VALOR_DEBITO, '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN PAGADOBANCO IS NULL THEN ' ' ELSE UPPER(PAGADOBANCO) END) LIKE UPPER(CONCAT(CONCAT('%',:PAGADOBANCO), '%')) AND (CASE WHEN FECHA_CONCILIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONCILIA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_CONCILIA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN TIPO_CPTE_AFECT IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE_AFECT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE_AFECT), '%')) AND (CASE WHEN CMPTE_AFECTADO IS NULL THEN ' ' ELSE UPPER(CMPTE_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CMPTE_AFECTADO), '%')) AND (CASE WHEN SINIDENTIFICAR IS NULL THEN ' ' ELSE UPPER(SINIDENTIFICAR) END) LIKE UPPER(CONCAT(:SINIDENTIFICAR, '%')) AND (CASE WHEN FECHA_IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(FECHA_IDENTIFICACION) END) LIKE UPPER(CONCAT(:FECHA_IDENTIFICACION, '%')) AND (CASE WHEN CONCILIADOR IS NULL THEN ' ' ELSE UPPER(CONCILIADOR) END) LIKE UPPER(CONCAT(:CONCILIADOR, '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(CONCAT('%',:IMPRESO), '%')) AND (CASE WHEN ENTREGADO IS NULL THEN ' ' ELSE UPPER(ENTREGADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENTREGADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","NRO_DOCUMENTO":"$NRO_DOCUMENTO","FECHA":"$FECHA","VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","PAGADOBANCO":"$PAGADOBANCO(type:boolean)","FECHA_CONCILIA":"$FECHA_CONCILIA","DESCRIPCION":"$DESCRIPCION","TERCERO":"$TERCERO","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","FECHA_CONSIGNACIONPLANO":"$FECHA_CONSIGNACIONPLANO","SINIDENTIFICAR":"$SINIDENTIFICAR(type:boolean)","FECHA_IDENTIFICACION":"$FECHA_IDENTIFICACION","CONCILIADOR":"$CONCILIADOR","IMPRESO":"$IMPRESO(type:boolean)","ENTREGADO":"$ENTREGADO(type:boolean)"}]}}		</result>
