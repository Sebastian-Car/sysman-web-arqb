	<query id="updateDetallescomprobantecntActualizaabono" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_CNT SET DETALLE_COMPROBANTE_CNT.ABONOINICIAL=TO_NUMBER(:ABONOACTUALIZA) WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE AND DETALLE_COMPROBANTE_CNT.CONSECUTIVO = :CONSECUTIVO</sql>
