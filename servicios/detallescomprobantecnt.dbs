	<query id="getDetallescomprobantecntPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.CUENTA,(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_CNT.NATURALEZA, DETALLE_COMPROBANTE_CNT.TIPOPPTAL, DETALLE_COMPROBANTE_CNT.NUMEROPPTAL, DETALLE_COMPROBANTE_CNT.CUENTAPPTAL, DETALLE_COMPROBANTE_CNT.CONSECUTIVOPPTO, DETALLE_COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, DETALLE_COMPROBANTE_CNT.BASE_GRAVABLE, DETALLE_COMPROBANTE_CNT.TIPO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.NRO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.CENTRO_COSTO, PLAN_CONTABLE.NOMBRE NOMBREPLANCONTABLE, CENTRO_COSTO.NOMBRE NOMBRECENTROCOSTO, DETALLE_COMPROBANTE_CNT.BANCO_RETENCION, DETALLE_COMPROBANTE_CNT.TIPO_CPTE_AFECT, DETALLE_COMPROBANTE_CNT.CMPTE_AFECTADO, DETALLE_COMPROBANTE_CNT.BASE_IVA, DETALLE_COMPROBANTE_CNT.FORMATO_CONCEPTO_EX, DETALLE_COMPROBANTE_CNT.TERCERO, TRIM(TERCERO.NOMBRE) NOMBRETERCERO, DETALLE_COMPROBANTE_CNT.SUCURSAL, DETALLE_COMPROBANTE_CNT.AUXILIAR, AUXILIAR.NOMBRE NOMBREAUXILIAR, NVL(CASE :MES WHEN '1' THEN SALDO_AUX_CONTABLE.SALDO1 WHEN '2' THEN SALDO_AUX_CONTABLE.SALDO2 WHEN '3' THEN SALDO_AUX_CONTABLE.SALDO3 WHEN '4' THEN SALDO_AUX_CONTABLE.SALDO4 WHEN '5' THEN SALDO_AUX_CONTABLE.SALDO5 WHEN '6' THEN SALDO_AUX_CONTABLE.SALDO6 WHEN '7' THEN SALDO_AUX_CONTABLE.SALDO7 WHEN '8' THEN SALDO_AUX_CONTABLE.SALDO8 WHEN '9' THEN SALDO_AUX_CONTABLE.SALDO9 WHEN '10' THEN SALDO_AUX_CONTABLE.SALDO10 WHEN '11' THEN SALDO_AUX_CONTABLE.SALDO11 WHEN '12' THEN SALDO_AUX_CONTABLE.SALDO12 END, 0) SALDOCUENTA,(TO_CHAR(DETALLE_COMPROBANTE_CNT.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, DETALLE_COMPROBANTE_CNT.PORDISTRIBUIDOCNT, DETALLE_COMPROBANTE_CNT.PORCENTAJERETENCION,(CASE DETALLE_COMPROBANTE_CNT.RECONOCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) RECONOCIMIENTO, DETALLE_COMPROBANTE_CNT.D_RESPONSABLECNT, DETALLE_COMPROBANTE_CNT.D_DEPENDENCIACNT, CASE :SALDO WHEN '0' THEN PLAN_CONTABLE.SALDO0 WHEN '1' THEN PLAN_CONTABLE.SALDO1 WHEN '2' THEN PLAN_CONTABLE.SALDO2 WHEN '3' THEN PLAN_CONTABLE.SALDO3 WHEN '4' THEN PLAN_CONTABLE.SALDO4 WHEN '5' THEN PLAN_CONTABLE.SALDO5 WHEN '6' THEN PLAN_CONTABLE.SALDO6 WHEN '7' THEN PLAN_CONTABLE.SALDO7 WHEN '8' THEN PLAN_CONTABLE.SALDO8 WHEN '9' THEN PLAN_CONTABLE.SALDO9 WHEN '10' THEN PLAN_CONTABLE.SALDO10 WHEN '11' THEN PLAN_CONTABLE.SALDO11 WHEN '12' THEN PLAN_CONTABLE.SALDO12 WHEN '13' THEN PLAN_CONTABLE.SALDO13 END SALDO13,(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA_CONSIGNACIONPLANO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONSIGNACIONPLANO, DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO, DETALLE_COMPROBANTE_CNT.EJECUCION_CREDITO, DETALLE_COMPROBANTE_CNT.REFERENCIA, DETALLE_COMPROBANTE_CNT.FUENTE_RECURSO, DETALLE_COMPROBANTE_CNT.ANO_AFECT, DETALLE_COMPROBANTE_CNT.CONSECUTIVOAFECTADO, DETALLE_COMPROBANTE_CNT.CHEQUEPARAANULAR,(CASE DETALLE_COMPROBANTE_CNT.CIERRE WHEN 0 THEN 'false' ELSE 'true' END) CIERRE,(CASE DETALLE_COMPROBANTE_CNT.PAGADOBANCO WHEN 0 THEN 'false' ELSE 'true' END) PAGADOBANCO, DETALLE_COMPROBANTE_CNT.TIPOCONTRATO, DETALLE_COMPROBANTE_CNT.NUMEROCONTRATO, DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO, DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO,(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHACONCILIA,'DD/MM/YYYY HH24:MI:SS')) FECHACONCILIA, DETALLE_COMPROBANTE_CNT.ABONOINICIAL, DETALLE_COMPROBANTE_CNT.VALORTOTAL, DETALLE_COMPROBANTE_CNT.DEBITOSAFECTADOS_CXP, DETALLE_COMPROBANTE_CNT.CREDITOSAFECTADOS_CXP, DETALLE_COMPROBANTE_CNT.TEXTOD,(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA_CONCILIACION_PLANO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONCILIACION_PLANO, DETALLE_COMPROBANTE_CNT.CONCEPTO_EX, DETALLE_COMPROBANTE_CNT.CONCILIADOR, DETALLE_COMPROBANTE_CNT.REVELACIONES, DETALLE_COMPROBANTE_CNT.PAIS, DETALLE_COMPROBANTE_CNT.DEPARTAMENTO, DETALLE_COMPROBANTE_CNT.CIUDAD, DETALLE_COMPROBANTE_CNT.D_RESPSUCURSALCNT, DETALLE_COMPROBANTE_CNT.CREATED_BY,(TO_CHAR(DETALLE_COMPROBANTE_CNT.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, DETALLE_COMPROBANTE_CNT.MODIFIED_BY,(TO_CHAR(DETALLE_COMPROBANTE_CNT.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, DETALLE_COMPROBANTE_CNT.CODIGO_PPTAL, DETALLE_COMPROBANTE_CNT.ID, DETALLE_COMPROBANTE_CNT.TIPO_NOTA, DETALLE_COMPROBANTE_CNT.CODIGO_NOTA, TIPO_COMPROBANTE.CLASE_CONTABLE, PLAN_CONTABLE.CLASECUENTA,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE PLAN_CONTABLE.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_CONTABLE.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE PLAN_CONTABLE.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE PLAN_CONTABLE.MOSTRARF1001 WHEN 0 THEN 'false' ELSE 'true' END) MOSTRARF1001, DETALLE_COMPROBANTE_CNT.CODIGO_FLUJO_EFECTIVO,(CASE PLAN_CONTABLE.MOSTRAR_EN_FLUJO WHEN 0 THEN 'false' ELSE 'true' END) MOSTRAR_EN_FLUJO,DETALLE_COMPROBANTE_CNT.CONCEPTO_CUDS, DETALLE_COMPROBANTE_CNT.NUMEROPROCESO, DETALLE_COMPROBANTE_CNT.EQUIV_SIGEC ,DETALLE_COMPROBANTE_CNT.NOMBRE_FUNCIONARIO  FROM DETALLE_COMPROBANTE_CNT LEFT JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO LEFT JOIN SALDO_AUX_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = SALDO_AUX_CONTABLE.COMPANIA   AND DETALLE_COMPROBANTE_CNT.ANO = SALDO_AUX_CONTABLE.ANO   AND DETALLE_COMPROBANTE_CNT.ID = SALDO_AUX_CONTABLE.ID LEFT JOIN AUXILIAR ON DETALLE_COMPROBANTE_CNT.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = AUXILIAR.ANO AND DETALLE_COMPROBANTE_CNT.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_CNT.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = CENTRO_COSTO.ANO AND DETALLE_COMPROBANTE_CNT.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPOCOMP AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :NUMEROCOMP AND PLAN_CONTABLE.MOVIMIENTO + PLAN_CONTABLE.MAN_CEN_CTO + PLAN_CONTABLE.MAN_AUX_TER + PLAN_CONTABLE.MAN_AUX_GEN + PLAN_CONTABLE.MAN_AUX_REF+ PLAN_CONTABLE.MAN_AUX_FUE &lt;&gt; 0 ORDER BY DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CONSECUTIVO) INI WHERE (:CONSECUTIVO IS NULL OR UPPER(NVL(CONSECUTIVO,'')) LIKE UPPER(:CONSECUTIVO || '%')) AND (:CUENTA IS NULL OR UPPER(NVL(CUENTA,'')) LIKE UPPER('%' || :CUENTA || '%')) AND (:FECHA IS NULL OR UPPER(NVL(FECHA,'')) LIKE UPPER('%' || :FECHA || '%')) AND (:CUENTAPPTAL IS NULL OR UPPER(NVL(CUENTAPPTAL,'')) LIKE UPPER('%' || :CUENTAPPTAL || '%')) AND (:DESCRIPCION IS NULL OR UPPER(NVL(DESCRIPCION,'')) LIKE UPPER('%' || :DESCRIPCION || '%')) AND (:VALOR_DEBITO IS NULL OR UPPER(NVL(VALOR_DEBITO,'')) LIKE UPPER('%' || :VALOR_DEBITO || '%')) AND (:VALOR_CREDITO IS NULL OR UPPER(NVL(VALOR_CREDITO,'')) LIKE UPPER('%' || :VALOR_CREDITO || '%')) AND (:BASE_GRAVABLE IS NULL OR UPPER(NVL(BASE_GRAVABLE,'')) LIKE UPPER('%' || :BASE_GRAVABLE || '%')) AND (:TIPO_DOCUMENTO IS NULL OR UPPER(NVL(TIPO_DOCUMENTO,'')) LIKE UPPER('%' || :TIPO_DOCUMENTO || '%')) AND (:NRO_DOCUMENTO IS NULL OR UPPER(NVL(NRO_DOCUMENTO,'')) LIKE UPPER('%' || :NRO_DOCUMENTO || '%')) AND (:CENTRO_COSTO IS NULL OR UPPER(NVL(CENTRO_COSTO,'')) LIKE UPPER('%' || :CENTRO_COSTO || '%')) AND (:NOMBREPLANCONTABLE IS NULL OR UPPER(NVL(NOMBREPLANCONTABLE,'')) LIKE UPPER('%' || :NOMBREPLANCONTABLE || '%')) AND (:NOMBRECENTROCOSTO IS NULL OR UPPER(NVL(NOMBRECENTROCOSTO,'')) LIKE UPPER('%' || :NOMBRECENTROCOSTO || '%')) AND (:BANCO_RETENCION IS NULL OR UPPER(NVL(BANCO_RETENCION,'')) LIKE UPPER('%' || :BANCO_RETENCION || '%')) AND (:TIPO_CPTE_AFECT IS NULL OR UPPER(NVL(TIPO_CPTE_AFECT,'')) LIKE UPPER('%' || :TIPO_CPTE_AFECT || '%')) AND (:CMPTE_AFECTADO IS NULL OR UPPER(NVL(CMPTE_AFECTADO,'')) LIKE UPPER('%' || :CMPTE_AFECTADO || '%')) AND (:BASE_IVA IS NULL OR UPPER(NVL(BASE_IVA,'')) LIKE UPPER('%' || :BASE_IVA || '%')) AND (:FORMATO_CONCEPTO_EX IS NULL OR UPPER(NVL(FORMATO_CONCEPTO_EX,'')) LIKE UPPER('%' || :FORMATO_CONCEPTO_EX || '%')) AND (:TERCERO IS NULL OR UPPER(NVL(TERCERO,'')) LIKE UPPER('%' || :TERCERO || '%')) AND (:NOMBRETERCERO IS NULL OR UPPER(NVL(NOMBRETERCERO,'')) LIKE UPPER('%' || :NOMBRETERCERO || '%')) AND (:SUCURSAL IS NULL OR UPPER(NVL(SUCURSAL,'')) LIKE UPPER('%' || :SUCURSAL || '%')) AND (:AUXILIAR IS NULL OR UPPER(NVL(AUXILIAR,'')) LIKE UPPER('%' || :AUXILIAR || '%')) AND (:NOMBREAUXILIAR IS NULL OR UPPER(NVL(NOMBREAUXILIAR,'')) LIKE UPPER('%' || :NOMBREAUXILIAR || '%')) AND (:SALDOCUENTA IS NULL OR UPPER(NVL(SALDOCUENTA,'')) LIKE UPPER('%' || :SALDOCUENTA || '%')) AND (:HORA IS NULL OR UPPER(NVL(HORA,'')) LIKE UPPER('%' || :HORA || '%')) AND (:PORDISTRIBUIDOCNT IS NULL OR UPPER(NVL(PORDISTRIBUIDOCNT,'')) LIKE UPPER('%' || :PORDISTRIBUIDOCNT || '%')) AND (:PORCENTAJERETENCION IS NULL OR UPPER(NVL(PORCENTAJERETENCION,'')) LIKE UPPER('%' || :PORCENTAJERETENCION || '%')) AND (:RECONOCIMIENTO IS NULL OR UPPER(NVL(RECONOCIMIENTO,'')) LIKE UPPER('%' || :RECONOCIMIENTO || '%')) AND (:D_RESPONSABLECNT IS NULL OR UPPER(NVL(D_RESPONSABLECNT,'')) LIKE UPPER('%' || :D_RESPONSABLECNT || '%')) AND (:D_DEPENDENCIACNT IS NULL OR UPPER(NVL(D_DEPENDENCIACNT,'')) LIKE UPPER('%' || :D_DEPENDENCIACNT || '%')) AND (:SALDO13 IS NULL OR UPPER(NVL(SALDO13,'')) LIKE UPPER('%' || :SALDO13 || '%')) AND (:FECHA_CONSIGNACIONPLANO IS NULL OR UPPER(NVL(FECHA_CONSIGNACIONPLANO,'')) LIKE UPPER('%' || :FECHA_CONSIGNACIONPLANO || '%')) AND (:TIPO_NOTA IS NULL OR UPPER(NVL(TIPO_NOTA,'')) LIKE UPPER('%' || :TIPO_NOTA || '%')) AND (:CODIGO_NOTA IS NULL OR UPPER(NVL(CODIGO_NOTA,'')) LIKE UPPER('%' || :CODIGO_NOTA || '%')) AND (:CLASE_CONTABLE IS NULL OR UPPER(NVL(CLASE_CONTABLE,'')) LIKE UPPER('%' || :CLASE_CONTABLE || '%')) AND (:CLASECUENTA IS NULL OR UPPER(NVL(CLASECUENTA,'')) LIKE UPPER('%' || :CLASECUENTA || '%')) AND (:MOVIMIENTO IS NULL OR UPPER(NVL(MOVIMIENTO,'')) LIKE UPPER('%' || :MOVIMIENTO || '%')) AND (:MAN_CEN_CTO IS NULL OR UPPER(NVL(MAN_CEN_CTO,'')) LIKE UPPER('%' || :MAN_CEN_CTO || '%')) AND (:MAN_AUX_TER IS NULL OR UPPER(NVL(MAN_AUX_TER,'')) LIKE UPPER('%' || :MAN_AUX_TER || '%')) AND (:MAN_AUX_GEN IS NULL OR UPPER(NVL(MAN_AUX_GEN,'')) LIKE UPPER('%' || :MAN_AUX_GEN || '%')) AND (:MOSTRARF1001 IS NULL OR UPPER(NVL(MOSTRARF1001,'')) LIKE UPPER('%' || :MOSTRARF1001 || '%')) AND (:CODIGO_FLUJO_EFECTIVO IS NULL OR UPPER(NVL(CODIGO_FLUJO_EFECTIVO,'')) LIKE UPPER('%' || :CODIGO_FLUJO_EFECTIVO || '%')) AND (:CONCEPTO_CUDS IS NULL OR UPPER(NVL(CONCEPTO_CUDS,'')) LIKE UPPER('%' || :CONCEPTO_CUDS || '%')) AND (:NUMEROPROCESO IS NULL OR UPPER(NVL(NUMEROPROCESO,'')) LIKE UPPER('%' || :NUMEROPROCESO || '%')) AND (:NOMBRE_FUNCIONARIO IS NULL OR UPPER(NVL(NOMBRE_FUNCIONARIO,'')) LIKE UPPER('%' || :NOMBRE_FUNCIONARIO || '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","FECHA":"$FECHA","NATURALEZA":"$NATURALEZA","TIPOPPTAL":"$TIPOPPTAL","NUMEROPPTAL":"$NUMEROPPTAL(type:long)","CUENTAPPTAL":"$CUENTAPPTAL","CONSECUTIVOPPTO":"$CONSECUTIVOPPTO(type:integer)","DESCRIPCION":"$DESCRIPCION","VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","BASE_GRAVABLE":"$BASE_GRAVABLE","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","CENTRO_COSTO":"$CENTRO_COSTO","NOMBREPLANCONTABLE":"$NOMBREPLANCONTABLE","NOMBRECENTROCOSTO":"$NOMBRECENTROCOSTO","BANCO_RETENCION":"$BANCO_RETENCION","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","BASE_IVA":"$BASE_IVA","FORMATO_CONCEPTO_EX":"$FORMATO_CONCEPTO_EX","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","NOMBREAUXILIAR":"$NOMBREAUXILIAR","SALDOCUENTA":"$SALDOCUENTA","HORA":"$HORA","PORDISTRIBUIDOCNT":"$PORDISTRIBUIDOCNT","PORCENTAJERETENCION":"$PORCENTAJERETENCION","RECONOCIMIENTO":"$RECONOCIMIENTO(type:boolean)","D_RESPONSABLECNT":"$D_RESPONSABLECNT","D_DEPENDENCIACNT":"$D_DEPENDENCIACNT","SALDO13":"$SALDO13","FECHA_CONSIGNACIONPLANO":"$FECHA_CONSIGNACIONPLANO","EJECUCION_DEBITO":"$EJECUCION_DEBITO","EJECUCION_CREDITO":"$EJECUCION_CREDITO","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","ANO_AFECT":"$ANO_AFECT(type:integer)","CONSECUTIVOAFECTADO":"$CONSECUTIVOAFECTADO(type:integer)","CHEQUEPARAANULAR":"$CHEQUEPARAANULAR","CIERRE":"$CIERRE(type:boolean)","PAGADOBANCO":"$PAGADOBANCO(type:boolean)","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO","DEBITO_AFECTADO":"$DEBITO_AFECTADO","CREDITO_AFECTADO":"$CREDITO_AFECTADO","FECHACONCILIA":"$FECHACONCILIA","ABONOINICIAL":"$ABONOINICIAL","VALORTOTAL":"$VALORTOTAL","DEBITOSAFECTADOS_CXP":"$DEBITOSAFECTADOS_CXP","CREDITOSAFECTADOS_CXP":"$CREDITOSAFECTADOS_CXP","TEXTOD":"$TEXTOD","FECHA_CONCILIACION_PLANO":"$FECHA_CONCILIACION_PLANO","CONCEPTO_EX":"$CONCEPTO_EX","CONCILIADOR":"$CONCILIADOR","REVELACIONES":"$REVELACIONES","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","D_RESPSUCURSALCNT":"$D_RESPSUCURSALCNT","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CODIGO_PPTAL":"$CODIGO_PPTAL","ID":"$ID","TIPO_NOTA":"$TIPO_NOTA","CODIGO_NOTA":"$CODIGO_NOTA","CLASE_CONTABLE":"$CLASE_CONTABLE","CLASECUENTA":"$CLASECUENTA","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MOSTRARF1001":"$MOSTRARF1001(type:boolean)","CODIGO_FLUJO_EFECTIVO":"$CODIGO_FLUJO_EFECTIVO","MOSTRAR_EN_FLUJO":"$MOSTRAR_EN_FLUJO(type:boolean)","CONCEPTO_CUDS":"$CONCEPTO_CUDS","NUMEROPROCESO":"$NUMEROPROCESO","EQUIV_SIGEC":"$EQUIV_SIGEC","NOMBRE_FUNCIONARIO":"$NOMBRE_FUNCIONARIO"}]}}		</result>
