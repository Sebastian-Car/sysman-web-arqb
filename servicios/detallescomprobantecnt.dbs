	<query id="getDetallescomprobantecntConsultacpteafectadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CMPTE_AFECTADO, TIPO_CPTE_AFECT FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPO AND COMPROBANTE = :NUMERO AND CMPTE_AFECTADO IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

