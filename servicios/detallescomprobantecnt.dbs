), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(:VALOR_DEBITO, '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN PAGADOBANCO IS NULL THEN ' ' ELSE UPPER(PAGADOBANCO) END) LIKE UPPER(CONCAT(CONCAT('%',:PAGADOBANCO), '%')) AND (CASE WHEN FECHA_CONCILIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONCILIA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_CONCILIA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN TIPO_CPTE_AFECT IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE_AFECT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE_AFECT), '%')) AND (CASE WHEN CMPTE_AFECTADO IS NULL THEN ' ' ELSE UPPER(CMPTE_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CMPTE_AFECTADO), '%')) AND (CASE WHEN SINIDENTIFICAR IS NULL THEN ' ' ELSE UPPER(SINIDENTIFICAR) END) LIKE UPPER(CONCAT(:SINIDENTIFICAR, '%')) AND (CASE WHEN FECHA_IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(FECHA_IDENTIFICACION) END) LIKE UPPER(CONCAT(:FECHA_IDENTIFICACION, '%')) AND (CASE WHEN CONCILIADOR IS NULL THEN ' ' ELSE UPPER(CONCILIADOR) END) LIKE UPPER(CONCAT(:CONCILIADOR, '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(CONCAT('%',:IMPRESO), '%')) AND (CASE WHEN ENTREGADO IS NULL THEN ' ' ELSE UPPER(ENTREGADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENTREGADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
