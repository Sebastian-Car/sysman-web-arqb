	<query id="getDetallescomprobantecntNumIngresosTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS') FECHA, TERCERO.NOMBRE TERCERO_NOMBRE, DETALLE_COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.TIPO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.NRO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.CUENTA CODIGO_CUENTA, CENTRO_COSTO.CODIGO CENTRO_COSTO_CODIGO, CENTRO_COSTO.NOMBRE CENTRO_COSTO_NOMBRE, AUXILIAR.CODIGO AUXILIAR_CODIGO, AUXILIAR.NOMBRE AUXILIAR_NOMBRE, ( CASE WHEN 'D'=:NATURALEZA THEN DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO - DETALLE_COMPROBANTE_CNT.EJECUCION_CREDITO ELSE DETALLE_COMPROBANTE_CNT.EJECUCION_CREDITO - DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO END ) VALORT FROM COMPROBANTE_CNT INNER JOIN DETALLE_COMPROBANTE_CNT ON DETALLE_COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = COMPROBANTE_CNT.TIPO AND DETALLE_COMPROBANTE_CNT.ANO = COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = COMPROBANTE_CNT.NUMERO INNER JOIN DETALLE_COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = DETALLE_COMPROBANTE_CNT.TIPOPPTAL AND DETALLE_COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = DETALLE_COMPROBANTE_CNT.NUMEROPPTAL AND DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO = DETALLE_COMPROBANTE_CNT.CONSECUTIVOPPTO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = DETALLE_COMPROBANTE_CNT.CUENTAPPTAL INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN AUXILIAR ON DETALLE_COMPROBANTE_CNT.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_CNT.AUXILIAR = AUXILIAR.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = AUXILIAR.ANO INNER JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_CNT.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_CNT.CENTRO_COSTO = CENTRO_COSTO.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = CENTRO_COSTO.ANO WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND DETALLE_COMPROBANTE_PPTAL.ID = :CODIGO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = CASE WHEN 'TODOS'=:TCOMPONENTE THEN DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE ELSE :TCOMPONENTE END AND EXTRACT (MONTH FROM DETALLE_COMPROBANTE_CNT.FECHA) BETWEEN :MESINICIAL AND :MESFINAL ORDER BY DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.FECHA) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN TERCERO_NOMBRE IS NULL THEN ' ' ELSE UPPER(TERCERO_NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO_NOMBRE), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(:TIPO_DOCUMENTO, '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NRO_DOCUMENTO), '%')) AND (CASE WHEN CODIGO_CUENTA IS NULL THEN ' ' ELSE UPPER(CODIGO_CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CUENTA), '%')) AND (CASE WHEN CENTRO_COSTO_CODIGO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO_CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO_CODIGO), '%')) AND (CASE WHEN CENTRO_COSTO_NOMBRE IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO_NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO_NOMBRE), '%')) AND (CASE WHEN AUXILIAR_CODIGO IS NULL THEN ' ' ELSE UPPER(AUXILIAR_CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR_CODIGO), '%')) AND (CASE WHEN AUXILIAR_NOMBRE IS NULL THEN ' ' ELSE UPPER(AUXILIAR_NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR_NOMBRE), '%')) AND (CASE WHEN VALORT IS NULL THEN ' ' ELSE UPPER(VALORT) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORT), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TCOMPONENTE" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TERCERO_NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param name="CODIGO_CUENTA" sqlType="STRING"/>
		<param name="CENTRO_COSTO_CODIGO" sqlType="STRING"/>
		<param name="CENTRO_COSTO_NOMBRE" sqlType="STRING"/>
		<param name="AUXILIAR_CODIGO" sqlType="STRING"/>
		<param name="AUXILIAR_NOMBRE" sqlType="STRING"/>
		<param name="VALORT" sqlType="STRING"/>

	</query>
