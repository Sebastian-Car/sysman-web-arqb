	<query id="getDetallescomprobantecntCuadreCarteraFTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(TOTALDEUDA)TOTALDEUDA, SUM(SALDOT)SALDOT, SUM( CASE WHEN DIFERENCIAENDIAST BETWEEN 0 AND 30 THEN SALDOT ELSE 0 END )SALDO1T, SUM( CASE WHEN DIFERENCIAENDIAST BETWEEN 31 AND 60 THEN SALDOT ELSE 0 END )SALDO2T, SUM( CASE WHEN DIFERENCIAENDIAST BETWEEN 61 AND 90 THEN SALDOT ELSE 0 END )SALDO3T, SUM( CASE WHEN DIFERENCIAENDIAST BETWEEN 91 AND 180 THEN SALDOT ELSE 0 END )SALDO4T, SUM( CASE WHEN DIFERENCIAENDIAST BETWEEN 181 AND 270 THEN SALDOT ELSE 0 END )SALDO5T, SUM( CASE WHEN DIFERENCIAENDIAST BETWEEN 271 AND 360 THEN SALDOT ELSE 0 END )SALDO6T, SUM( CASE WHEN DIFERENCIAENDIAST &gt; 360 THEN SALDOT ELSE 0 END )SALDO7T, SUM(VALOR_DEBITO)VALOR_DEBITO, SUM(VALOR_CREDITO)VALOR_CREDITO, SUM(DEBITO_AFECTADO)DEBITO_AFECTADO, SUM(CREDITO_AFECTADO)CREDITO_AFECTADO, SUM(ABONOINICIAL)ABONOINICIAL FROM( SELECT DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO AS TOTALDEUDA, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.COMPROBANTE AS COMPROBANTECARTERA, DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.SUCURSAL, DETALLE_COMPROBANTE_CNT.CUENTA, TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA_ABONOINICIAL,'DD/MM/YYYY')FECHA_ABONOINICIAL, TERCERO.NOMBRE, CASE WHEN TIPO_COMPROBANTE.CLASE_CONTABLE = 'V' THEN CASE WHEN TERCERO.CLASEENTIDADOFICIAL &lt;&gt; 0 THEN 'Entidades Oficiales' ELSE 'Particulares' END ELSE 'Independiente / Particular' END AS CLASE, (DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO)-(DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO)- DETALLE_COMPROBANTE_CNT.ABONOINICIAL AS SALDOT, PCK_SYSMAN_UTL.FC_DIASMESCOMERCIAL(TO_DATE(:FECHA,'DD/MM/YYYY'),(COMPROBANTE_CNT.FECHA_VCN_DOC))- 1 AS DIFERENCIAENDIAST , CONCAT(CONCAT(CONCAT(CONCAT(DETALLE_COMPROBANTE_CNT.DESCRIPCION,'-'),DETALLE_COMPROBANTE_CNT.TIPO_CPTE),'-'),DETALLE_COMPROBANTE_CNT .COMPROBANTE)DESCRIPCIONT, 1 AS TIPOINFORME, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO, DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO, DETALLE_COMPROBANTE_CNT.ABONOINICIAL FROM DETALLE_COMPROBANTE_CNT INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO INNER JOIN COMPROBANTE_CNT ON DETALLE_COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNT.COMPANIA AND COMPROBANTE_CNT.ANO = DETALLE_COMPROBANTE_CNT.ANO AND COMPROBANTE_CNT.TIPO = DETALLE_COMPROBANTE_CNT.TIPO_CPTE AND COMPROBANTE_CNT.NUMERO = DETALLE_COMPROBANTE_CNT.COMPROBANTE WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = :TERCERO AND DETALLE_COMPROBANTE_CNT.CUENTA = :CUENTA AND DETALLE_COMPROBANTE_CNT.ANO &lt;= :ANO AND COMPROBANTE_CNT.FECHA_VCN_DOC &lt;= TO_DATE(:FECHA,'DD/MM/YYYY') AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ('V') )TABLA GROUP BY COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTALDEUDA":"$TOTALDEUDA(type:double)","SALDOT":"$SALDOT(type:double)","SALDO1T":"$SALDO1T(type:double)","SALDO2T":"$SALDO2T(type:double)","SALDO3T":"$SALDO3T(type:double)","SALDO4T":"$SALDO4T(type:double)","SALDO5T":"$SALDO5T(type:double)","SALDO6T":"$SALDO6T(type:double)","SALDO7T":"$SALDO7T(type:double)","VALOR_DEBITO":"$VALOR_DEBITO(type:double)","VALOR_CREDITO":"$VALOR_CREDITO(type:double)","DEBITO_AFECTADO":"$DEBITO_AFECTADO(type:double)","CREDITO_AFECTADO":"$CREDITO_AFECTADO(type:double)","ABONOINICIAL":"$ABONOINICIAL(type:double)"}]}}		</result>
		<param name="FECHA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
