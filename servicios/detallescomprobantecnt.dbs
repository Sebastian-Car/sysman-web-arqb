	<query id="updateDetallescomprobantecnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_CNT SET COMPANIA=:COMPANIA, ANO=:ANO, TIPO_CPTE=:TIPO_CPTE, COMPROBANTE=:COMPROBANTE, CONSECUTIVO=:CONSECUTIVO, CUENTA=:CUENTA, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), NATURALEZA=:NATURALEZA, TIPOPPTAL=:TIPOPPTAL, NUMEROPPTAL=:NUMEROPPTAL, CUENTAPPTAL=:CUENTAPPTAL, CONSECUTIVOPPTO=:CONSECUTIVOPPTO, DESCRIPCION=:DESCRIPCION, VALOR_DEBITO=:VALOR_DEBITO, VALOR_CREDITO=:VALOR_CREDITO, BASE_GRAVABLE=:BASE_GRAVABLE, TIPO_DOCUMENTO=:TIPO_DOCUMENTO, NRO_DOCUMENTO=:NRO_DOCUMENTO, CENTRO_COSTO=:CENTRO_COSTO, BANCO_RETENCION=:BANCO_RETENCION, TIPO_CPTE_AFECT=:TIPO_CPTE_AFECT, CMPTE_AFECTADO=:CMPTE_AFECTADO, BASE_IVA=:BASE_IVA, FORMATO_CONCEPTO_EX=:FORMATO_CONCEPTO_EX, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, AUXILIAR=:AUXILIAR, SALDOCUENTA=:SALDOCUENTA, HORA=TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), PORDISTRIBUIDOCNT=:PORDISTRIBUIDOCNT, PORCENTAJERETENCION=:PORCENTAJERETENCION, RECONOCIMIENTO=:RECONOCIMIENTO, D_RESPONSABLECNT=:D_RESPONSABLECNT, D_DEPENDENCIACNT=:D_DEPENDENCIACNT, FECHA_CONSIGNACIONPLANO=TO_DATE(:FECHA_CONSIGNACIONPLANO,'DD/MM/YYYY HH24:MI:SS'), EJECUCION_DEBITO=:EJECUCION_DEBITO, EJECUCION_CREDITO=:EJECUCION_CREDITO, REFERENCIA=:REFERENCIA, FUENTE_RECURSO=:FUENTE_RECURSO, ANO_AFECT=:ANO_AFECT, CONSECUTIVOAFECTADO=:CONSECUTIVOAFECTADO, CHEQUEPARAANULAR=:CHEQUEPARAANULAR, CIERRE=:CIERRE, PAGADOBANCO=:PAGADOBANCO, TIPOCONTRATO=:TIPOCONTRATO, NUMEROCONTRATO=:NUMEROCONTRATO, DEBITO_AFECTADO=:DEBITO_AFECTADO, CREDITO_AFECTADO=:CREDITO_AFECTADO, FECHACONCILIA=TO_DATE(:FECHACONCILIA,'DD/MM/YYYY HH24:MI:SS'), ABONOINICIAL=:ABONOINICIAL, VALORTOTAL=:VALORTOTAL, DEBITOSAFECTADOS_CXP=:DEBITOSAFECTADOS_CXP, CREDITOSAFECTADOS_CXP=:CREDITOSAFECTADOS_CXP, TEXTOD=:TEXTOD, FECHA_CONCILIACION_PLANO=TO_DATE(:FECHA_CONCILIACION_PLANO,'DD/MM/YYYY HH24:MI:SS'), CONCEPTO_EX=:CONCEPTO_EX, CONCILIADOR=:CONCILIADOR, REVELACIONES=:REVELACIONES, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CODIGO_PPTAL=:CODIGO_PPTAL, TIPO_NOTA=:TIPO_NOTA, CODIGO_NOTA=:CODIGO_NOTA, CODIGO_FLUJO_EFECTIVO=:CODIGO_FLUJO_EFECTIVO, CONCEPTO_CUDS=:CONCEPTO_CUDS, NUMEROPROCESO=:NUMEROPROCESO, EQUIV_SIGEC=:EQUIV_SIGEC, NOMBRE_FUNCIONARIO=:NOMBRE_FUNCIONARIO  WHERE DETALLE_COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO= :KEY_ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE= :KEY_TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.COMPROBANTE= :KEY_COMPROBANTE AND DETALLE_COMPROBANTE_CNT.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

