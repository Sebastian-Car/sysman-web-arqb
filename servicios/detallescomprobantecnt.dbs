	<query id="updateDetallescomprobantecntTesoreriasSalud" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_CNT SET CODIGO_FUT=:CODIGO_FUT, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO= :KEY_ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE= :KEY_TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.COMPROBANTE= :KEY_COMPROBANTE AND DETALLE_COMPROBANTE_CNT.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
