	<query id="insertDetallescomprobantecnt" keyColumns="COMPANIA,ANO,TIPO_CPTE,COMPROBANTE,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLE_COMPROBANTE_CNT (COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CUENTA, FECHA, NATURALEZA, TIPOPPTAL, NUMEROPPTAL, CUENTAPPTAL, CONSECUTIVOPPTO, DESCRIPCION, VALOR_DEBITO, VALOR_CREDITO, BASE_GRAVABLE, TIPO_DOCUMENTO, NRO_DOCUMENTO, CENTRO_COSTO, BANCO_RETENCION, TIPO_CPTE_AFECT, CMPTE_AFECTADO, BASE_IVA, FORMATO_CONCEPTO_EX, TERCERO, SUCURSAL, AUXILIAR, SALDOCUENTA, HORA, PORDISTRIBUIDOCNT, PORCENTAJERETENCION, RECONOCIMIENTO, D_RESPONSABLECNT, D_DEPENDENCIACNT, FECHA_CONSIGNACIONPLANO, EJECUCION_DEBITO, EJECUCION_CREDITO, REFERENCIA, FUENTE_RECURSO, ANO_AFECT, CONSECUTIVOAFECTADO, CHEQUEPARAANULAR, CIERRE, PAGADOBANCO, TIPOCONTRATO, NUMEROCONTRATO, DEBITO_AFECTADO, CREDITO_AFECTADO, FECHACONCILIA, ABONOINICIAL, VALORTOTAL, DEBITOSAFECTADOS_CXP, CREDITOSAFECTADOS_CXP, TEXTOD, FECHA_CONCILIACION_PLANO, CONCEPTO_EX, CONCILIADOR, REVELACIONES, D_RESPSUCURSALCNT, CREATED_BY, DATE_CREATED, CODIGO_PPTAL, ID, TIPO_NOTA, CODIGO_NOTA, CODIGO_FLUJO_EFECTIVO, CONCEPTO_CUDS, NUMEROPROCESO, EQUIV_SIGEC, NOMBRE_FUNCIONARIO) VALUES (:COMPANIA, :ANO, :TIPO_CPTE, :COMPROBANTE, :CONSECUTIVO, :CUENTA, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :NATURALEZA, :TIPOPPTAL, :NUMEROPPTAL, :CUENTAPPTAL, :CONSECUTIVOPPTO, :DESCRIPCION, :VALOR_DEBITO, :VALOR_CREDITO, :BASE_GRAVABLE, :TIPO_DOCUMENTO, :NRO_DOCUMENTO, :CENTRO_COSTO, :BANCO_RETENCION, :TIPO_CPTE_AFECT, :CMPTE_AFECTADO, :BASE_IVA, :FORMATO_CONCEPTO_EX, :TERCERO, :SUCURSAL, :AUXILIAR, :SALDOCUENTA, TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), :PORDISTRIBUIDOCNT, :PORCENTAJERETENCION, :RECONOCIMIENTO, :D_RESPONSABLECNT, :D_DEPENDENCIACNT, TO_DATE(:FECHA_CONSIGNACIONPLANO,'DD/MM/YYYY HH24:MI:SS'), :EJECUCION_DEBITO, :EJECUCION_CREDITO, :REFERENCIA, :FUENTE_RECURSO, :ANO_AFECT, :CONSECUTIVOAFECTADO, :CHEQUEPARAANULAR, :CIERRE, :PAGADOBANCO, :TIPOCONTRATO, :NUMEROCONTRATO, :DEBITO_AFECTADO, :CREDITO_AFECTADO, TO_DATE(:FECHACONCILIA,'DD/MM/YYYY HH24:MI:SS'), :ABONOINICIAL, :VALORTOTAL, :DEBITOSAFECTADOS_CXP, :CREDITOSAFECTADOS_CXP, :TEXTOD, TO_DATE(:FECHA_CONCILIACION_PLANO,'DD/MM/YYYY HH24:MI:SS'), :CONCEPTO_EX, :CONCILIADOR, :REVELACIONES, :D_RESPSUCURSALCNT, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CODIGO_PPTAL, :ID, :TIPO_NOTA, :CODIGO_NOTA, :CODIGO_FLUJO_EFECTIVO, :CONCEPTO_CUDS, :NUMEROPROCESO, :EQUIV_SIGEC , :NOMBRE_FUNCIONARIO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO_CPTE":"$TIPO_CPTE","KEY_COMPROBANTE":"$COMPROBANTE(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
