		<param defaultValue="0" name="VALOR_CREDITO" sqlType="STRING"/>
		<param defaultValue="0" name="EJECUCION_DEBITO" sqlType="STRING"/>
		<param defaultValue="0" name="EJECUCION_CREDITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTAPPTAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
