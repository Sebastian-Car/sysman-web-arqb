	<query id="insertDetallescomprobantecntCorpoboyacaServicio" keyColumns="COMPANIA,ANO,TIPO_CPTE,COMPROBANTE,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLE_COMPROBANTE_CNT (COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CUENTA, CUENTAPPTAL, FECHA, NATURALEZA, VALOR_DEBITO, VALOR_CREDITO, EJECUCION_DEBITO, EJECUCION_CREDITO, DESCRIPCION, CENTRO_COSTO, TERCERO, SUCURSAL, AUXILIAR, ANO_AFECT, NRO_DOCUMENTO, TIPO_CPTE_AFECT, CMPTE_AFECTADO, CONSECUTIVOAFECTADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO_CPTE, :COMPROBANTE, :CONSECUTIVO, :CUENTA, :CUENTAPPTAL, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :NATURALEZA, :VALOR_DEBITO, :VALOR_CREDITO, :EJECUCION_DEBITO, :EJECUCION_CREDITO, :DESCRIPCION, :CENTRO_COSTO, :TERCERO, :SUCURSAL, :AUXILIAR, :ANO_AFECT, :NRO_DOCUMENTO, :TIPO_CPTE_AFECT, :CMPTE_AFECTADO, :CONSECUTIVOAFECTADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO_CPTE":"$TIPO_CPTE","KEY_COMPROBANTE":"$COMPROBANTE(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTAPPTAL" sqlType="STRING"/>
