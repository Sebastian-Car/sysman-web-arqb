	<query id="getDetallescomprobantecntEquivalenciasPresupuestalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT D.COMPANIA, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, P.CODIGO CUENTA, ABS( CASE WHEN P.NATURALEZA = 'D' THEN D.VALOR_DEBITO - D.VALOR_CREDITO ELSE D.VALOR_CREDITO - D.VALOR_DEBITO END ) VALOR, COUNT(D.COMPANIA) CONTADOR, CASE WHEN D.CUENTAPPTAL IS NULL THEN MIN(C.RUBRO) ELSE D.CUENTAPPTAL END RUBRO_PPTAL, D.FUENTE_RECURSO FROM DETALLE_COMPROBANTE_CNT D INNER JOIN PLAN_CONTABLE P ON D.COMPANIA = P.COMPANIA AND D.ANO = P.ANO AND D.CUENTA = P.CODIGO INNER JOIN PLAN_PPTAL_CUENTACNT C ON P.COMPANIA = C.COMPANIA AND P.ANO = C.ANO AND P.CODIGO = C.CUENTA_CONTABLE WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANO AND D.TIPO_CPTE = :TIPO_CPTE AND D.COMPROBANTE = :COMPROBANTE GROUP BY D.COMPANIA, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, D.FUENTE_RECURSO, P.CODIGO, D.CUENTAPPTAL, CASE WHEN P.NATURALEZA = 'D' THEN D.VALOR_DEBITO - D.VALOR_CREDITO ELSE D.VALOR_CREDITO - D.VALOR_DEBITO END ORDER BY CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","VALOR":"$VALOR(type:double)","CONTADOR":"$CONTADOR(type:integer)","RUBRO_PPTAL":"$RUBRO_PPTAL","FUENTE_RECURSO":"$FUENTE_RECURSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
