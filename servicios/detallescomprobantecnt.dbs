	<query id="getDetallescomprobantecntTodosSinCodigoniifQuery"  useConfig="sysmandsunist">
		<sql>SELECT PC.CODIGO_NIIF, PC.CODIGO, PC.SALDO13, NVL((SELECT SUM(CASE WHEN NATURALEZA = 'D' THEN VALOR_DEBITO-VALOR_CREDITO ELSE VALOR_CREDITO-VALOR_DEBITO END) VALOR FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA = PC.COMPANIA AND ANO = PC.ANO AND CUENTA = PC.CODIGO AND TIPO_CPTE IN ('ACN','RCN','AEN') GROUP BY COMPANIA, ANO, CUENTA, FECHA, NATURALEZA, CODIGO_PPTAL, TIPOPPTAL, CUENTAPPTAL),0) VALOR FROM PLAN_CONTABLE PC WHERE PC.COMPANIA = :COMPANIA AND PC.ANO = :ANO AND PC.CODIGO_NIIF IS NULL AND PC.MAN_CEN_CTO+PC.MOVIMIENTO+PC.MAN_AUX_TER+PC.MAN_AUX_GEN+PC.MAN_AUX_FUE+PC.MAN_AUX_REF &lt;&gt; 0 ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_NIIF":"$CODIGO_NIIF","CODIGO":"$CODIGO","SALDO13":"$SALDO13","VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
