	<query id="getDetallescomprobantecntNumListacomprobantesaeliminarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE NOMBRECNT, DETALLE_COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO FROM DETALLE_COMPROBANTE_CNT LEFT JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :NUMERO ORDER BY DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CUENTA) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN NOMBRECNT IS NULL THEN ' ' ELSE UPPER(NOMBRECNT) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECNT), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBRECNT" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/listacomprobantesaeliminar/num">
		<call-query href="getDetallescomprobantecntNumListacomprobantesaeliminarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NOMBRECNT" query-param="NOMBRECNT"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR_DEBITO" query-param="VALOR_DEBITO"/>
			<with-param name="VALOR_CREDITO" query-param="VALOR_CREDITO"/>

		</call-query>
	</resource>
