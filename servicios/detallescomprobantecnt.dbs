	<query id="getDetallescomprobantecntPagConceptoExogenaFormatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.TERCERO, TERCERO.NOMBRE, COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.CUENTA, DETALLE_COMPROBANTE_CNT.CONCEPTO_EX, DETALLE_COMPROBANTE_CNT.CONCEPTO_DIST, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO FROM COMPROBANTE_CNT INNER JOIN DETALLE_COMPROBANTE_CNT ON COMPROBANTE_CNT.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND COMPROBANTE_CNT.ANO = DETALLE_COMPROBANTE_CNT.ANO AND COMPROBANTE_CNT.TIPO = DETALLE_COMPROBANTE_CNT.TIPO_CPTE AND COMPROBANTE_CNT.NUMERO = DETALLE_COMPROBANTE_CNT.COMPROBANTE INNER JOIN CONFIGURACION_EXOGENA ON DETALLE_COMPROBANTE_CNT.COMPANIA = CONFIGURACION_EXOGENA.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = CONFIGURACION_EXOGENA.ANO INNER JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND CONFIGURACION_EXOGENA.FORMATO = :FORMATO AND TIPO_COMPROBANTE.IND_REPORTAR_1001 NOT IN(0) AND PLAN_CONTABLE.MOSTRARF1001 NOT IN(0) AND TERCERO.IND_PAGO_RETENCION IN(0)) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN CONCEPTO_EX IS NULL THEN ' ' ELSE UPPER(CONCEPTO_EX) END) LIKE UPPER(CONCAT(:CONCEPTO_EX, '%')) AND (CASE WHEN CONCEPTO_DIST IS NULL THEN ' ' ELSE UPPER(CONCEPTO_DIST) END) LIKE UPPER(CONCAT(:CONCEPTO_DIST, '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(:VALOR_DEBITO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","TERCERO":"$TERCERO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","CUENTA":"$CUENTA","CONCEPTO_EX":"$CONCEPTO_EX","CONCEPTO_DIST":"$CONCEPTO_DIST","VALOR_CREDITO":"$VALOR_CREDITO","VALOR_DEBITO":"$VALOR_DEBITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CONCEPTO_EX" sqlType="STRING"/>
		<param name="CONCEPTO_DIST" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
