	<resource method="GET" path="detallescomprobantecnt/numero">
		<call-query href="getDetallescomprobantecntNumeroQuery">
			<with-param name="MES" query-param="MES"/>									 
			<with-param name="SALDO" query-param="SALDO"/>									 
			<with-param name="COMPANIA" query-param="COMPANIA"/>
