	<query id="getDetallescomprobantecntDebitoCreditoDolQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(DEBITO_EQUIV),0) DEBITODOL, NVL(SUM(CREDITO_EQUIV),0) CREDITODOL FROM DETALLE_COMPROBANTE_CNT WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = CASE WHEN :TIPOCOMP = 'CIE' THEN ' ' ELSE :TIPOCOMP END AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :NUMEROCOMP</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEBITODOL":"$DEBITODOL(type:integer)","CREDITODOL":"$CREDITODOL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>

	</query>
