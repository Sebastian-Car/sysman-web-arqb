	</resource>
	<query id="updateDetallescomprobantecntNroDocumento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_CNT SET DETALLE_COMPROBANTE_CNT.NRO_DOCUMENTO = (SELECT COMPROBANTE_CNTBANCOS.NUMEROCHEQUE FROM COMPROBANTE_CNTBANCOS WHERE COMPROBANTE_CNTBANCOS.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND COMPROBANTE_CNTBANCOS.ANO = DETALLE_COMPROBANTE_CNT.ANO AND COMPROBANTE_CNTBANCOS.TIPO = DETALLE_COMPROBANTE_CNT.TIPO_CPTE AND COMPROBANTE_CNTBANCOS.NUMERO = DETALLE_COMPROBANTE_CNT.COMPROBANTE AND COMPROBANTE_CNTBANCOS.CUENTA = DETALLE_COMPROBANTE_CNT.CUENTA), DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA AND ANO= :ANO AND TIPO_CPTE = :TIPOCOMP AND COMPROBANTE = :NUMEROCOMP</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallescomprobantecnt/nrodocumento">
		<call-query href="updateDetallescomprobantecntNroDocumento">
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT TRIM(TO_CHAR(NVL(SUM(VALOR_DEBITO),0), '99,999,999,999,999,990.90')) VALOR_DEBITO, TRIM(TO_CHAR(NVL(SUM(VALOR_CREDITO),0), '99,999,999,999,999,990.90')) VALOR_CREDITO, TRIM(TO_CHAR(ABS(NVL(SUM(VALOR_DEBITO),0)-NVL(SUM(VALOR_CREDITO),0)), '99,999,999,999,999,990.90')) TOTAL FROM DETALLE_COMPROBANTE_CNT INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPOCOMP AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :NUMEROCOMP AND (PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","TOTAL":"$TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/totales">
		<call-query href="getDetallescomprobantecntTotalesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntDetallesPorConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT TIPOPPTAL,NUMEROPPTAL,CONSECUTIVOPPTO FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA= :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPOCOMP AND COMPROBANTE = :NUMEROCOMP AND CONSECUTIVO = :CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOPPTAL":"$TIPOPPTAL","NUMEROPPTAL":"$NUMEROPPTAL(type:long)","CONSECUTIVOPPTO":"$CONSECUTIVOPPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/detallesporconsecutivo">
		<call-query href="getDetallescomprobantecntDetallesPorConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntPagIngresosTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS') FECHA, TERCERO.NOMBRE TERCERO_NOMBRE, DETALLE_COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.TIPO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.NRO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.CUENTA CODIGO_CUENTA, CENTRO_COSTO.CODIGO CENTRO_COSTO_CODIGO, CENTRO_COSTO.NOMBRE CENTRO_COSTO_NOMBRE, AUXILIAR.CODIGO AUXILIAR_CODIGO, AUXILIAR.NOMBRE AUXILIAR_NOMBRE, ( CASE WHEN 'D'=:NATURALEZA THEN DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO - DETALLE_COMPROBANTE_CNT.EJECUCION_CREDITO ELSE DETALLE_COMPROBANTE_CNT.EJECUCION_CREDITO - DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO END ) VALORT FROM COMPROBANTE_CNT INNER JOIN DETALLE_COMPROBANTE_CNT ON DETALLE_COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = COMPROBANTE_CNT.TIPO AND DETALLE_COMPROBANTE_CNT.ANO = COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = COMPROBANTE_CNT.NUMERO INNER JOIN DETALLE_COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = DETALLE_COMPROBANTE_CNT.TIPOPPTAL AND DETALLE_COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = DETALLE_COMPROBANTE_CNT.NUMEROPPTAL AND DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO = DETALLE_COMPROBANTE_CNT.CONSECUTIVOPPTO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = DETALLE_COMPROBANTE_CNT.CUENTAPPTAL INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN AUXILIAR ON DETALLE_COMPROBANTE_CNT.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_CNT.AUXILIAR = AUXILIAR.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = AUXILIAR.ANO INNER JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_CNT.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_CNT.CENTRO_COSTO = CENTRO_COSTO.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = CENTRO_COSTO.ANO WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND DETALLE_COMPROBANTE_PPTAL.ID = :CODIGO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = CASE WHEN 'TODOS'=:TCOMPONENTE THEN DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE ELSE :TCOMPONENTE END AND EXTRACT (MONTH FROM DETALLE_COMPROBANTE_CNT.FECHA) BETWEEN :MESINICIAL AND :MESFINAL ORDER BY DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.FECHA) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN TERCERO_NOMBRE IS NULL THEN ' ' ELSE UPPER(TERCERO_NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO_NOMBRE), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(:TIPO_DOCUMENTO, '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NRO_DOCUMENTO), '%')) AND (CASE WHEN CODIGO_CUENTA IS NULL THEN ' ' ELSE UPPER(CODIGO_CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CUENTA), '%')) AND (CASE WHEN CENTRO_COSTO_CODIGO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO_CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO_CODIGO), '%')) AND (CASE WHEN CENTRO_COSTO_NOMBRE IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO_NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO_NOMBRE), '%')) AND (CASE WHEN AUXILIAR_CODIGO IS NULL THEN ' ' ELSE UPPER(AUXILIAR_CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR_CODIGO), '%')) AND (CASE WHEN AUXILIAR_NOMBRE IS NULL THEN ' ' ELSE UPPER(AUXILIAR_NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR_NOMBRE), '%')) AND (CASE WHEN VALORT IS NULL THEN ' ' ELSE UPPER(VALORT) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORT), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","FECHA":"$FECHA","TERCERO_NOMBRE":"$TERCERO_NOMBRE","DESCRIPCION":"$DESCRIPCION","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","CODIGO_CUENTA":"$CODIGO_CUENTA","CENTRO_COSTO_CODIGO":"$CENTRO_COSTO_CODIGO","CENTRO_COSTO_NOMBRE":"$CENTRO_COSTO_NOMBRE","AUXILIAR_CODIGO":"$AUXILIAR_CODIGO","AUXILIAR_NOMBRE":"$AUXILIAR_NOMBRE","VALORT":"$VALORT"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TCOMPONENTE" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
