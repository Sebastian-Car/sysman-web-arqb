	</resource>
	<query id="getDetallescomprobantecntPagGrillaporanoymesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT RETENCION.COMPANIA, RETENCION.TIPO_CPTE, RETENCION.COMPROBANTE, RETENCION.ANO, RETENCION.CONSECUTIVO, -1 DEPURADO, TO_CHAR(RETENCION.FECHA,'DD/MM/YYYY') FECHA , RETENCION.CUENTA, RETENCION.VALOR_CREDITO, RETENCION.TIPO_PAGO_RETENCION, RETENCION.COMPROBANTE_PAGO_RETENCION, RETENCION.ANO_RETENCION, RETENCION.BANCO_RETENCION, TO_CHAR(RETENCION.FECHA_PAGO_RETENCION,'DD/MM/YYYY') FECHA_PAGO_RETENCION, CASE WHEN RETENCION.PAGO_RETENCION IN (0) THEN 0 ELSE -1 END PAGO_RETENCION FROM DETALLE_COMPROBANTE_CNT RETENCION INNER JOIN TIPO_COMPROBANTE T_RETENCION ON RETENCION.COMPANIA = T_RETENCION.COMPANIA AND RETENCION.TIPO_CPTE = T_RETENCION.CODIGO INNER JOIN PLAN_CONTABLE CUENTARET ON RETENCION.COMPANIA = CUENTARET.COMPANIA AND RETENCION.ANO = CUENTARET.ANO AND RETENCION.CUENTA = CUENTARET.CODIGO WHERE RETENCION.COMPANIA = :COMPANIA AND RETENCION.ANO_RETENCION = :ANIO AND EXTRACT(MONTH FROM RETENCION.FECHA_PAGO_RETENCION) = :MES AND RETENCION.VALOR_CREDITO NOT IN(0) AND CUENTARET.CLASECUENTA IN('I') AND T_RETENCION.CLASE_CONTABLE NOT IN('Z') UNION ALL SELECT DISTINCT RETE.COMPANIA, RETE.TIPO_CPTE, RETE.COMPROBANTE, RETE.ANO, RETE.CONSECUTIVO, 0 DEPURADO, TO_CHAR(RETE.FECHA,'DD/MM/YYYY') FECHA , RETE.CUENTA, RETE.VALOR_CREDITO, RETE.TIPO_PAGO_RETENCION, RETE.COMPROBANTE_PAGO_RETENCION, RETE.ANO_RETENCION, RETE.BANCO_RETENCION, TO_CHAR(RETE.FECHA_PAGO_RETENCION,'DD/MM/YYYY') FECHA_PAGO_RETENCION, CASE WHEN RETE.PAGO_RETENCION IN (0) THEN 0 ELSE -1 END PAGO_RETENCION FROM COMPROBANTE_CNTAFECTADOS RELA INNER JOIN COMPROBANTE_CNT EGR_CNT ON RELA.COMPANIA = EGR_CNT.COMPANIA AND RELA.ANO = EGR_CNT.ANO AND RELA.TIPO_CPTE = EGR_CNT.TIPO AND RELA.COMPROBANTE = EGR_CNT.NUMERO INNER JOIN TIPO_COMPROBANTE ON EGR_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND EGR_CNT.TIPO = TIPO_COMPROBANTE.CODIGO INNER JOIN DETALLE_COMPROBANTE_CNT EGR ON EGR_CNT.COMPANIA = EGR.COMPANIA AND EGR_CNT.ANO = EGR.ANO AND EGR_CNT.TIPO = EGR.TIPO_CPTE AND EGR_CNT.NUMERO = EGR.COMPROBANTE INNER JOIN PLAN_CONTABLE ON EGR.COMPANIA = PLAN_CONTABLE.COMPANIA AND EGR.ANO = PLAN_CONTABLE.ANO AND EGR.CUENTA = PLAN_CONTABLE.CODIGO INNER JOIN COMPROBANTE_CNT RETE_CNT ON RELA.COMPANIA = RETE_CNT.COMPANIA AND RELA.ANO_AFECT = RETE_CNT.ANO AND RELA.TIPO_CPTE_AFECT = RETE_CNT.TIPO AND RELA.COMPROBANTE_AFECT = RETE_CNT.NUMERO INNER JOIN DETALLE_COMPROBANTE_CNT RETE ON RETE_CNT.COMPANIA = RETE.COMPANIA AND RETE_CNT.ANO = RETE.ANO AND RETE_CNT.TIPO = RETE.TIPO_CPTE AND RETE_CNT.NUMERO = RETE.COMPROBANTE INNER JOIN PLAN_CONTABLE CUENTARETE ON RETE.COMPANIA = CUENTARETE.COMPANIA AND RETE.ANO = CUENTARETE.ANO AND RETE.CUENTA = CUENTARETE.CODIGO WHERE EGR.COMPANIA = :COMPANIA AND EGR.ANO = :ANIO AND EXTRACT(MONTH FROM EGR.FECHA) = :MES AND RETE.PAGO_RETENCION IN(0) AND PLAN_CONTABLE.CLASECUENTA IN('B') AND TIPO_COMPROBANTE.CLASE_CONTABLE IN('E','G') AND CUENTARETE.CLASECUENTA IN('I') UNION ALL SELECT DISTINCT RETE.COMPANIA, RETE.TIPO_CPTE, RETE.COMPROBANTE, RETE.ANO, RETE.CONSECUTIVO, 0 DEPURADO, TO_CHAR(RETE.FECHA,'DD/MM/YYYY') FECHA, RETE.CUENTA, RETE.VALOR_CREDITO, NULL TIPO_PAGO_RETENCION, NULL COMPROBANTE_PAGO_RETENCION, RETE.ANO_RETENCION, NULL BANCO_RETENCION, NULL FECHA_PAGO_RETENCION, CASE WHEN RETE.PAGO_RETENCION IN (0) THEN 0 ELSE -1 END PAGO_RETENCION FROM DETALLE_COMPROBANTE_CNT EGR INNER JOIN TIPO_COMPROBANTE ON EGR.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND EGR.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO INNER JOIN PLAN_CONTABLE ON EGR.COMPANIA = PLAN_CONTABLE.COMPANIA AND EGR.ANO = PLAN_CONTABLE.ANO AND EGR.CUENTA = PLAN_CONTABLE.CODIGO INNER JOIN (SELECT DET.COMPANIA, DET.TIPO_CPTE, DET.COMPROBANTE, DET.ANO, DET.CONSECUTIVO, DET.CUENTA, DET.VALOR_CREDITO, DET.FECHA, DET.ANO_RETENCION, CASE WHEN DET.PAGO_RETENCION IN (0) THEN 0 ELSE -1 END PAGO_RETENCION FROM DETALLE_COMPROBANTE_CNT DET INNER JOIN PLAN_CONTABLE ON PLAN_CONTABLE.COMPANIA = DET.COMPANIA AND PLAN_CONTABLE.ANO = DET.ANO AND PLAN_CONTABLE.CODIGO = DET.CUENTA WHERE DET.COMPANIA = :COMPANIA AND DET.ANO = :ANIO AND EXTRACT(MONTH FROM DET.FECHA) = :MES AND DET.PAGO_RETENCION IN(0) AND PLAN_CONTABLE.CLASECUENTA IN('I') ) RETE ON EGR.COMPANIA = RETE.COMPANIA AND EGR.ANO = RETE.ANO AND EGR.TIPO_CPTE = RETE.TIPO_CPTE AND EGR.COMPROBANTE = RETE.COMPROBANTE WHERE EGR.COMPANIA = :COMPANIA AND EGR.ANO = :ANIO AND EXTRACT(MONTH FROM EGR.FECHA) = :MES AND PLAN_CONTABLE.CLASECUENTA IN('B') AND TIPO_COMPROBANTE.CLASE_CONTABLE IN('E','G','I','S') ORDER BY COMPANIA, DEPURADO DESC , TIPO_CPTE, COMPROBANTE, CONSECUTIVO ASC) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(:TIPO_CPTE, '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN DEPURADO IS NULL THEN ' ' ELSE UPPER(DEPURADO) END) LIKE UPPER(CONCAT(:DEPURADO, '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(:VALOR_CREDITO, '%')) AND (CASE WHEN BANCO_RETENCION IS NULL THEN ' ' ELSE UPPER(BANCO_RETENCION) END) LIKE UPPER(CONCAT(:BANCO_RETENCION, '%')) AND (CASE WHEN FECHA_PAGO_RETENCION IS NULL THEN ' ' ELSE UPPER(FECHA_PAGO_RETENCION) END) LIKE UPPER(CONCAT(:FECHA_PAGO_RETENCION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","DEPURADO":"$DEPURADO(type:integer)","FECHA":"$FECHA","CUENTA":"$CUENTA","VALOR_CREDITO":"$VALOR_CREDITO","TIPO_PAGO_RETENCION":"$TIPO_PAGO_RETENCION","COMPROBANTE_PAGO_RETENCION":"$COMPROBANTE_PAGO_RETENCION(type:long)","ANO_RETENCION":"$ANO_RETENCION(type:integer)","BANCO_RETENCION":"$BANCO_RETENCION","FECHA_PAGO_RETENCION":"$FECHA_PAGO_RETENCION","PAGO_RETENCION":"$PAGO_RETENCION(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
