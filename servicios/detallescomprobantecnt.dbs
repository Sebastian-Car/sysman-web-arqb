		</call-query>
	</resource>
	<query id="getDetallescomprobantecntPagTerceroEgresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.TERCERO, TERCERO.NOMBRE, DETALLE_COMPROBANTE_CNT.SUCURSAL, CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO + DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO ELSE DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - DETALLE_COMPROBANTE_CNT.VALOR_DEBITO + DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO - DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO END SALDO FROM DETALLE_COMPROBANTE_CNT INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND PLAN_CONTABLE.CLASECUENTA IN ( 'P', 'E' ) AND INSTR(REPLACE(CONCAT(CONCAT('''', REPLACE(:COMPROBANTE, ' ', '')), ''''), ',', ''','''), CONCAT(CONCAT(CONCAT(CONCAT('', TO_CHAR (DETALLE_COMPROBANTE_CNT.ANO)), DETALLE_COMPROBANTE_CNT.TIPO_CPTE), DETALLE_COMPROBANTE_CNT.COMPROBANTE), ''), 1) &gt; 0 AND ( CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO + DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO ELSE DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - DETALLE_COMPROBANTE_CNT.VALOR_DEBITO + DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO - DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO END ) NOT IN ( 01 ) ORDER BY DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.CONSECUTIVO) INI WHERE (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","TERCERO":"$TERCERO","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","SALDO":"$SALDO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/terceroegresos/pag">
		<call-query href="getDetallescomprobantecntPagTerceroEgresosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntNumTerceroEgresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.TERCERO, TERCERO.NOMBRE, DETALLE_COMPROBANTE_CNT.SUCURSAL, CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO + DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO ELSE DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - DETALLE_COMPROBANTE_CNT.VALOR_DEBITO + DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO - DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO END SALDO FROM DETALLE_COMPROBANTE_CNT INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND PLAN_CONTABLE.CLASECUENTA IN ( 'P', 'E' ) AND INSTR(REPLACE(CONCAT(CONCAT('''', REPLACE(:COMPROBANTE, ' ', '')), ''''), ',', ''','''), CONCAT(CONCAT(CONCAT(CONCAT('', TO_CHAR (DETALLE_COMPROBANTE_CNT.ANO)), DETALLE_COMPROBANTE_CNT.TIPO_CPTE), DETALLE_COMPROBANTE_CNT.COMPROBANTE), ''), 1) &gt; 0 AND ( CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO + DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO ELSE DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - DETALLE_COMPROBANTE_CNT.VALOR_DEBITO + DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO - DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO END ) NOT IN ( 01 ) ORDER BY DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.CONSECUTIVO) INI WHERE (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>

	</query>
