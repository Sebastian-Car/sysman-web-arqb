		</call-query>
	</resource>
	<query id="getDetallescomprobantecntTodosPorCompaniaAnoNumeroTipoComprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT('X') AS CONTEO FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA=:COMPANIA AND ANO= :ANO AND TIPO_CPTE=:STRTIPOCOMPROBANTE AND COMPROBANTE=:NUMERO ORDER BY COMPANIA, ANO, TIPO_CPTE, COMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
