	<query id="getDetallescomprobantecntTodosPorXCompaniaNitSucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT 'x' AS x FROM DETALLE_COMPROBANTE_CNT WHERE DETALLE_COMPROBANTE_CNT.COMPANIA=:COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO =:NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL=:SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
