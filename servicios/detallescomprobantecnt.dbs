	<query id="updateDetallescomprobantecntMovimientosConciliacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_CNT SET COMPANIA=:COMPANIA, ANO=:ANO, TIPO_CPTE=:TIPO_CPTE, COMPROBANTE=:COMPROBANTE, CONSECUTIVO=:CONSECUTIVO, NRO_DOCUMENTO=:NRO_DOCUMENTO, FECHA=:FECHA, VALOR_DEBITO=:VALOR_DEBITO, VALOR_CREDITO=:VALOR_CREDITO, PAGADOBANCO=:PAGADOBANCO, FECHA_CONCILIA=:FECHA_CONCILIA, DESCRIPCION=:DESCRIPCION, TERCERO=:TERCERO, TIPO_CPTE_AFECT=:TIPO_CPTE_AFECT, CMPTE_AFECTADO=:CMPTE_AFECTADO, FECHA_CONSIGNACIONPLANO=TO_DATE(:FECHA_CONSIGNACIONPLANO,'DD/MM/YYYY HH24:MI:SS'), SINIDENTIFICAR=CASE WHEN :SINIDENTIFICAR = 'true' THEN -1 WHEN :SINIDENTIFICAR = '1' THEN -1 ELSE 0 END, FECHA_IDENTIFICACION=TO_DATE(:FECHA_IDENTIFICACION,'DD/MM/YYYY HH24:MI:SS'), CONCILIADOR=:CONCILIADOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO= :KEY_ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE= :KEY_TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.COMPROBANTE= :KEY_COMPROBANTE AND DETALLE_COMPROBANTE_CNT.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
