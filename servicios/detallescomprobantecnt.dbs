	<query id="getDetallescomprobantecntExistenciaPorComprobanteYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_CNT.COMPROBANTE, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.ANO FROM DETALLE_COMPROBANTE_CNT INNER JOIN COMPROBANTE_CNT ON DETALLE_COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = COMPROBANTE_CNT.TIPO AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = COMPROBANTE_CNT.NUMERO WHERE COMPROBANTE_CNT.NUMERO = :COMPROBANTE AND COMPROBANTE_CNT.TIPO = :TIPO_CPTE GROUP BY DETALLE_COMPROBANTE_CNT.COMPROBANTE, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE(type:integer)","DESCRIPCION":"$DESCRIPCION","TIPO":"$TIPO","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>

	</query>
