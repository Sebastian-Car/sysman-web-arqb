	<query id="getDetallescomprobantecntNumMovimientosCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.CUENTA, DETALLE_COMPROBANTE_CNT.MES, TO_CHAR( DETALLE_COMPROBANTE_CNT.FECHA, 'DD/MM/YYYY HH24:MI:SS' ) FECHA, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, DETALLE_COMPROBANTE_CNT.TIPO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.NRO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.CENTRO_COSTO, DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.SUCURSAL, DETALLE_COMPROBANTE_CNT.AUXILIAR, DETALLE_COMPROBANTE_CNT.REFERENCIA, DETALLE_COMPROBANTE_CNT.FUENTE_RECURSO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, AUXILIAR.NOMBRE AUXILIAR_NOM, CENTRO_COSTO.NOMBRE CENTRO_COSTO_NOM, TERCERO.NOMBRE TERCERO_NOM, REFERENCIA.NOMBRE REFERENCIA_NOMBRE, FUENTE_RECURSOS.NOMBRE FUENTE_RECURSO_NOMBRE FROM DETALLE_COMPROBANTE_CNT INNER JOIN AUXILIAR ON DETALLE_COMPROBANTE_CNT.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = AUXILIAR.ANO AND DETALLE_COMPROBANTE_CNT.AUXILIAR = AUXILIAR.CODIGO INNER JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_CNT.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = CENTRO_COSTO.ANO AND DETALLE_COMPROBANTE_CNT.CENTRO_COSTO = CENTRO_COSTO.CODIGO INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT INNER JOIN REFERENCIA ON DETALLE_COMPROBANTE_CNT.COMPANIA = REFERENCIA.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = REFERENCIA.ANO AND DETALLE_COMPROBANTE_CNT.REFERENCIA = REFERENCIA.CODIGO INNER JOIN FUENTE_RECURSOS ON DETALLE_COMPROBANTE_CNT.COMPANIA = FUENTE_RECURSOS.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = FUENTE_RECURSOS.ANO AND DETALLE_COMPROBANTE_CNT.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND DETALLE_COMPROBANTE_CNT.MES BETWEEN :MESINICIAL AND :MESFINAL AND SUBSTR(DETALLE_COMPROBANTE_CNT.ID, 0, LENGTH(:ID_PLAN)) = :ID_PLAN ORDER BY DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.FECHA, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE) INI WHERE (:CUENTA IS NULL OR UPPER(NVL(CUENTA, '')) LIKE UPPER('%' || :CUENTA || '%')) AND (:FECHA IS NULL OR UPPER(NVL(FECHA, '')) LIKE UPPER('%' || :FECHA || '%')) AND (:VALOR_DEBITO IS NULL OR UPPER(NVL(VALOR_DEBITO, '')) LIKE UPPER('%' || :VALOR_DEBITO || '%')) AND (:VALOR_CREDITO IS NULL OR UPPER(NVL(VALOR_CREDITO, '')) LIKE UPPER('%' || :VALOR_CREDITO || '%')) AND (:TIPO_DOCUMENTO IS NULL OR UPPER(NVL(TIPO_DOCUMENTO, '')) LIKE UPPER('%' || :TIPO_DOCUMENTO || '%')) AND (:NRO_DOCUMENTO IS NULL OR UPPER(NVL(NRO_DOCUMENTO, '')) LIKE UPPER('%' || :NRO_DOCUMENTO || '%')) AND (:DESCRIPCION IS NULL OR UPPER(NVL(DESCRIPCION, '')) LIKE UPPER('%' || :DESCRIPCION || '%')) AND (:CENTRO_COSTO IS NULL OR UPPER(NVL(CENTRO_COSTO, '')) LIKE UPPER('%' || :CENTRO_COSTO || '%')) AND (:TERCERO IS NULL OR UPPER(NVL(TERCERO, '')) LIKE UPPER('%' || :TERCERO || '%')) AND (:SUCURSAL IS NULL OR UPPER(NVL(SUCURSAL, '')) LIKE UPPER('%' || :SUCURSAL || '%')) AND (:AUXILIAR IS NULL OR UPPER(NVL(AUXILIAR, '')) LIKE UPPER('%' || :AUXILIAR || '%')) AND (:REFERENCIA IS NULL OR UPPER(NVL(REFERENCIA, '')) LIKE UPPER('%' || :REFERENCIA || '%')) AND (:FUENTE_RECURSO IS NULL OR UPPER(NVL(FUENTE_RECURSO, '')) LIKE UPPER('%' || :FUENTE_RECURSO || '%')) AND (:TIPO_CPTE IS NULL OR UPPER(NVL(TIPO_CPTE, '')) LIKE UPPER('%' || :TIPO_CPTE || '%')) AND (:COMPROBANTE IS NULL OR UPPER(NVL(COMPROBANTE, '')) LIKE UPPER('%' || :COMPROBANTE || '%')) AND (:AUXILIAR_NOM IS NULL OR UPPER(NVL(AUXILIAR_NOM, '')) LIKE UPPER('%' || :AUXILIAR_NOM || '%')) AND (:CENTRO_COSTO_NOM IS NULL OR UPPER(NVL(CENTRO_COSTO_NOM, '')) LIKE UPPER('%' || :CENTRO_COSTO_NOM || '%')) AND (:TERCERO_NOM IS NULL OR UPPER(NVL(TERCERO_NOM, '')) LIKE UPPER('%' || :TERCERO_NOM || '%')) AND (:REFERENCIA_NOMBRE IS NULL OR UPPER(NVL(REFERENCIA_NOMBRE, '')) LIKE UPPER('%' || :REFERENCIA_NOMBRE || '%')) AND (:FUENTE_RECURSO_NOMBRE IS NULL OR UPPER(NVL(FUENTE_RECURSO_NOMBRE, '')) LIKE UPPER('%' || :FUENTE_RECURSO_NOMBRE || '%')) ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="AUXILIAR_NOM" sqlType="STRING"/>
		<param name="CENTRO_COSTO_NOM" sqlType="STRING"/>
		<param name="TERCERO_NOM" sqlType="STRING"/>
		<param name="REFERENCIA_NOMBRE" sqlType="STRING"/>
		<param name="FUENTE_RECURSO_NOMBRE" sqlType="STRING"/>

	</query>
