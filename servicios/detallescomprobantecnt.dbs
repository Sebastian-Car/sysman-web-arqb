	<query id="getDetallescomprobantecntValordebitoporcpteQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(VALOR_DEBITO) - SUM(DEBITO_AFECTADO), 0) VALOR FROM DETALLE_COMPROBANTE_CNT D INNER JOIN PLAN_CONTABLE P ON D.COMPANIA = P.COMPANIA AND D.ANO = P.ANO AND D.CUENTA = P.CODIGO WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANO AND D.TIPO_CPTE = :TIPO_CPTE AND D.COMPROBANTE = :NUMERO AND P.CLASECUENTA = 'C'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
