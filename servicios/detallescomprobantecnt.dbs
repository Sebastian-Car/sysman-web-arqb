	<query id="getDetallescomprobantecntValidaidsnQuery"  useConfig="sysmandsunist">
		<sql>SELECT EGR.TIPO_CPTE TIPO, EGR.COMPROBANTE COMPROBANTE,(TO_CHAR(EGR.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COM_PPTAL.TIPO_CPTE_AFECT RES_TIPO, COM_PPTAL.CMPTE_AFECTADO RES, RES.TIPO_CPTE_AFECT DIS_TIPO, RES.CMPTE_AFECTADO DIS FROM DETALLE_COMPROBANTE_CNT EGR INNER JOIN PLAN_CONTABLE CUENTA ON EGR.COMPANIA = CUENTA.COMPANIA AND EGR.ANO = CUENTA.ANO AND EGR.CUENTA = CUENTA.CODIGO LEFT JOIN DETALLE_COMPROBANTE_CNT COM ON EGR.COMPANIA = COM.COMPANIA AND EGR.ANO_AFECT = COM.ANO AND EGR.TIPO_CPTE_AFECT = COM.TIPO_CPTE AND EGR.CMPTE_AFECTADO = COM.COMPROBANTE AND EGR.CONSECUTIVOAFECTADO = COM.CONSECUTIVO AND EGR.TERCERO = COM.TERCERO LEFT JOIN DETALLE_COMPROBANTE_PPTAL COM_PPTAL ON COM_PPTAL.COMPANIA = COM.COMPANIA AND COM_PPTAL.ANO = COM.ANO AND COM_PPTAL.TIPO_CPTE = COM.TIPO_CPTE AND COM_PPTAL.COMPROBANTE = COM.COMPROBANTE LEFT JOIN DETALLE_COMPROBANTE_PPTAL RES ON COM_PPTAL.COMPANIA = RES.COMPANIA AND COM_PPTAL.ANO_AFECT = RES.ANO AND COM_PPTAL.TIPO_CPTE_AFECT = RES.TIPO_CPTE AND COM_PPTAL.CMPTE_AFECTADO = RES.COMPROBANTE AND COM_PPTAL.CONSECUTIVOPPTO = RES.CONSECUTIVO WHERE EGR.COMPANIA = :COMPANIA AND EGR.TERCERO = :TERCERO AND EGR.TIPO_CPTE = :TIPO AND EGR.NRO_DOCUMENTO = :NRODOCUMENTO AND CUENTA.CLASECUENTA IN('P', 'E')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","COMPROBANTE":"$COMPROBANTE(type:long)","FECHA":"$FECHA","RES_TIPO":"$RES_TIPO","RES":"$RES(type:long)","DIS_TIPO":"$DIS_TIPO","DIS":"$DIS(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NRODOCUMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/validaidsn">
		<call-query href="getDetallescomprobantecntValidaidsnQuery">
