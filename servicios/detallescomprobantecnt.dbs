		<sql>SELECT DETALLE_COMPROBANTE_CNT.COMPROBANTE FROM DETALLE_COMPROBANTE_CNT WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPOCOMPROBANTE AND DETALLE_COMPROBANTE_CNT.TERCERO = :TERCERO AND DETALLE_COMPROBANTE_CNT.CUENTA = :CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE(type:long)"}]}}		</result>
