	</query>
	<resource method="GET" path="detallescomprobantecnt/todosporconsecutivocomprobantecuenta">
		<call-query href="getDetallescomprobantecntTodosPorConsecutivoComprobanteCuentaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
