<data name="detallescomprobantecnt" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDetallescomprobantecntLeftPlancontablePorAnioTipoComprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT D.COMPANIA, D.ANO, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, D.CUENTA, TRIM (TO_CHAR(D.VALOR_CREDITO,'999,999,999,999,999,999.99')) VALOR_CREDITO, TRIM (TO_CHAR(D.VALOR_DEBITO,'999,999,999,999,999,999.99')) VALOR_DEBITO, P.CODIGO, P.NOMBRE, D.CUENTAPPTAL FROM DETALLE_COMPROBANTE_CNT D LEFT JOIN PLAN_CONTABLE P ON D.COMPANIA = P.COMPANIA AND D.ANO = P.ANO AND D.CUENTA = P.CODIGO WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANIO AND D.TIPO_CPTE = :TIPO AND D.COMPROBANTE = :COMPROBANTE AND D.VALOR_CREDITO &gt; 0 AND ROWNUM &lt;= 1 ORDER BY D.CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","VALOR_CREDITO":"$VALOR_CREDITO","VALOR_DEBITO":"$VALOR_DEBITO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CUENTAPPTAL":"$CUENTAPPTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/leftplancontableporaniotipocomprobante">
		<call-query href="getDetallescomprobantecntLeftPlancontablePorAnioTipoComprobanteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntLeftPlancontablePorAnioTipoComprobanteVlrdebitoQuery"  useConfig="sysmandsunist">
		<sql>SELECT D.COMPANIA, D.ANO, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, D.CUENTA, TRIM (TO_CHAR(D.VALOR_CREDITO,'999,999,999,999,999,999.99')) VALOR_CREDITO, TRIM (TO_CHAR(D.VALOR_DEBITO,'999,999,999,999,999,999.99')) VALOR_DEBITO, P.CODIGO, P.NOMBRE, NVL(D.CUENTAPPTAL,' ') CUENTAPPTAL FROM DETALLE_COMPROBANTE_CNT D LEFT JOIN PLAN_CONTABLE P ON D.COMPANIA = P.COMPANIA AND D.ANO = P.ANO AND D.CUENTA = P.CODIGO WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANIO AND D.TIPO_CPTE = :TIPO AND D.COMPROBANTE = :COMPROBANTE AND D.VALOR_DEBITO &gt; 0 AND ROWNUM &lt;= 1 ORDER BY D.CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","VALOR_CREDITO":"$VALOR_CREDITO","VALOR_DEBITO":"$VALOR_DEBITO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CUENTAPPTAL":"$CUENTAPPTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/leftplancontableporaniotipocomprobantevlrdebito">
		<call-query href="getDetallescomprobantecntLeftPlancontablePorAnioTipoComprobanteVlrdebitoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntPagTodosporauxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D.COMPANIA, D.ANO, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, TO_CHAR(D.FECHA, 'DD/MM/YYYY') FECHA, D.VALOR_DEBITO, D.VALOR_CREDITO, D.DESCRIPCION, D.EJECUCION_DEBITO, D.EJECUCION_CREDITO, D.TIPO_DOCUMENTO, D.NRO_DOCUMENTO, D.TERCERO, D.SUCURSAL, T.NOMBRE NOMBRETERCERO, D.AUXILIAR, A.NOMBRE NOMBREAUXILIAR, D.FUENTE_RECURSO, F.NOMBRE NOMBREFTERECURSO, D.CENTRO_COSTO, C.NOMBRE NOMBRECENTROCOSTO, D.CUENTA, D.REFERENCIA, R.NOMBRE NOMBREREFERENCIA, D.CODIGO_PPTAL FROM DETALLE_COMPROBANTE_CNT D INNER JOIN TERCERO T ON D.COMPANIA = T.COMPANIA AND D.TERCERO = T.NIT AND D.SUCURSAL = T.SUCURSAL INNER JOIN AUXILIAR A ON D.COMPANIA = A.COMPANIA AND D.ANO = A.ANO AND D.AUXILIAR = A.CODIGO INNER JOIN FUENTE_RECURSOS F ON D.COMPANIA = F.COMPANIA AND D.ANO = F.ANO AND D.AUXILIAR = F.CODIGO INNER JOIN REFERENCIA R ON D.COMPANIA = R.COMPANIA AND D.ANO = R.ANO AND D.REFERENCIA = R.CODIGO INNER JOIN CENTRO_COSTO C ON D.COMPANIA = C.COMPANIA AND D.CENTRO_COSTO = C.CODIGO AND D.ANO = C.ANO WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANOQR AND D.MES BETWEEN :MESINICIALQR AND :MESFINALQR AND D.AUXILIAR = :AUXILIAR ORDER BY D.COMPROBANTE ASC, D.COMPANIA, D.ANO, D.TIPO_CPTE) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(:VALOR_DEBITO, '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(:VALOR_CREDITO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN EJECUCION_DEBITO IS NULL THEN ' ' ELSE UPPER(EJECUCION_DEBITO) END) LIKE UPPER(CONCAT(:EJECUCION_DEBITO, '%')) AND (CASE WHEN EJECUCION_CREDITO IS NULL THEN ' ' ELSE UPPER(EJECUCION_CREDITO) END) LIKE UPPER(CONCAT(:EJECUCION_CREDITO, '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOCUMENTO), '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(:NRO_DOCUMENTO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN NOMBREAUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBREAUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAUXILIAR), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN NOMBREFTERECURSO IS NULL THEN ' ' ELSE UPPER(NOMBREFTERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFTERECURSO), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN CODIGO_PPTAL IS NULL THEN ' ' ELSE UPPER(CODIGO_PPTAL) END) LIKE UPPER(CONCAT(:CODIGO_PPTAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","DESCRIPCION":"$DESCRIPCION","EJECUCION_DEBITO":"$EJECUCION_DEBITO","EJECUCION_CREDITO":"$EJECUCION_CREDITO","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","NOMBRETERCERO":"$NOMBRETERCERO","AUXILIAR":"$AUXILIAR","NOMBREAUXILIAR":"$NOMBREAUXILIAR","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBREFTERECURSO":"$NOMBREFTERECURSO","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRECENTROCOSTO":"$NOMBRECENTROCOSTO","CUENTA":"$CUENTA","REFERENCIA":"$REFERENCIA","NOMBREREFERENCIA":"$NOMBREREFERENCIA","CODIGO_PPTAL":"$CODIGO_PPTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOQR" sqlType="STRING"/>
		<param name="MESINICIALQR" sqlType="STRING"/>
		<param name="MESFINALQR" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="EJECUCION_DEBITO" sqlType="STRING"/>
		<param name="EJECUCION_CREDITO" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="NOMBREAUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBREFTERECURSO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CODIGO_PPTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
