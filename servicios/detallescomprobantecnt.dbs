	<query id="getDetallescomprobantecntPagTercerosegresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CUENTA, DETALLE_COMPROBANTE_CNT.CENTRO_COSTO, DETALLE_COMPROBANTE_CNT.REFERENCIA,DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.TERCERO, TERCERO.NOMBRE, DETALLE_COMPROBANTE_CNT.SUCURSAL, ( DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO + DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT .CREDITO_AFECTADO ) * CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN 1 ELSE - 1 END SALDO FROM PLAN_CONTABLE INNER JOIN DETALLE_COMPROBANTE_CNT ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT .COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.CLASECUENTA IN ( 'P', 'E' ) AND ( ( DETALLE_COMPROBANTE_CNT.ANO = :ANO0 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO0 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE0 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO1 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO1 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE1 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO2 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO2 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE2 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO3 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO3 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE3 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO4 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO4 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE4 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO5 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO5 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE5 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO6 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO6 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE6 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO7 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO7 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE7 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO8 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO8 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE8 ) OR ( DETALLE_COMPROBANTE_CNT.ANO = :ANO9 AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = :TIPO9 AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE9 ) ) AND ( DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO + DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO ) NOT IN ( 0 ) ORDER BY DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.CONSECUTIVO) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(:TIPO_CPTE, '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CUENTA":"$CUENTA","CENTRO_COSTO":"$CENTRO_COSTO","REFERENCIA":"$REFERENCIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","TERCERO":"$TERCERO","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","SALDO":"$SALDO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO0" sqlType="STRING"/>
