	<query id="getDetallescomprobantecntTodosPorAnoMesFechaCuentacajaYRownumQuery"  useConfig="sysmandsunist">
		<sql>SELECT VALOR_DEBITO - VALOR_CREDITO SALDOCUENTA FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = EXTRACT (YEAR FROM TO_DATE(:FECHA, 'DD/MM/YYYY')) AND EXTRACT (MONTH FROM FECHA) = EXTRACT (MONTH FROM TO_DATE(:FECHA, 'DD/MM/YYYY')) AND TRUNC(FECHA) = TO_DATE(:FECHA, 'DD/MM/YYYY') AND SUBSTR(CUENTA,1, LENGTH(:CUENTACAJA)) = :CUENTACAJA AND ROWNUM = 1 GROUP BY COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, VALOR_CREDITO, VALOR_DEBITO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALDOCUENTA":"$SALDOCUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CUENTACAJA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/todosporanomesfechacuentacajayrownum">
