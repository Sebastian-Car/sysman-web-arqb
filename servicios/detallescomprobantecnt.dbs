			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>

		</call-query>
	</resource>
	<query id="insertDetallescomprobantecntDistribuciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLE_COMPROBANTE_CNT ( COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CUENTA, CONSECUTIVO, NATURALEZA, DESCRIPCION, FECHA, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, VALOR_CREDITO, VALOR_DEBITO,CREATED_BY, DATE_CREATED) VALUES ( :COMPANIA, :ANO, :TIPOCOMP, :NUMEROCOMP, :CUENTA, :CONSECUTIVO, :NATURALEZA, :DESCRIPCION, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :TERCERO, :SUCURSAL, :CENTRO_COSTO, :AUXILIAR, CASE WHEN :NATURALEZA = 'D' THEN 0 ELSE :VLRCUENTA END, CASE WHEN :NATURALEZA = 'D' THEN :VLRCUENTA ELSE 0 END,:CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param name="VLRCUENTA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detallescomprobantecnt/distribuciones">
		<call-query href="insertDetallescomprobantecntDistribuciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="VLRCUENTA" query-param="VLRCUENTA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntListacontracuentasgeningresoQuery"  useConfig="sysmandsunist">
		<sql>SELECT TIPO_CPTE, COMPROBANTE, CUENTA, NATURALEZA, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, CONSECUTIVO, VALOR_DEBITO, DEBITO_AFECTADO, VALOR_CREDITO, CREDITO_AFECTADO, CUENTAPPTAL FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPO_CPTE AND COMPROBANTE = :NUMERO AND (SUBSTR(CUENTA,0,1) = '1' AND VALOR_DEBITO NOT IN(0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CUENTA":"$CUENTA","NATURALEZA":"$NATURALEZA","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","CONSECUTIVO":"$CONSECUTIVO(type:integer)","VALOR_DEBITO":"$VALOR_DEBITO","DEBITO_AFECTADO":"$DEBITO_AFECTADO","VALOR_CREDITO":"$VALOR_CREDITO","CREDITO_AFECTADO":"$CREDITO_AFECTADO","CUENTAPPTAL":"$CUENTAPPTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/listacontracuentasgeningreso">
		<call-query href="getDetallescomprobantecntListacontracuentasgeningresoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntValorTotIngresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(NVL(SUM(( CASE WHEN 'D'=:NATURALEZA THEN DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO - DETALLE_COMPROBANTE_CNT.EJECUCION_CREDITO ELSE DETALLE_COMPROBANTE_CNT.EJECUCION_CREDITO - DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO END )),0), '99,999,999,999,999,990.90') TOTAL FROM COMPROBANTE_CNT INNER JOIN DETALLE_COMPROBANTE_CNT ON DETALLE_COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = COMPROBANTE_CNT.TIPO AND DETALLE_COMPROBANTE_CNT.ANO = COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = COMPROBANTE_CNT.NUMERO INNER JOIN DETALLE_COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = DETALLE_COMPROBANTE_CNT.TIPOPPTAL AND DETALLE_COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = DETALLE_COMPROBANTE_CNT.NUMEROPPTAL AND DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO = DETALLE_COMPROBANTE_CNT.CONSECUTIVOPPTO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = DETALLE_COMPROBANTE_CNT.CUENTAPPTAL INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN AUXILIAR ON DETALLE_COMPROBANTE_CNT.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_CNT.AUXILIAR = AUXILIAR.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = AUXILIAR.ANO INNER JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_CNT.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_CNT.CENTRO_COSTO = CENTRO_COSTO.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = CENTRO_COSTO.ANO WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND DETALLE_COMPROBANTE_PPTAL.ID = :CODIGO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = CASE WHEN 'TODOS'=:TCOMPONENTE THEN DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE ELSE :TCOMPONENTE END AND EXTRACT (MONTH FROM DETALLE_COMPROBANTE_CNT.FECHA) BETWEEN :MESINICIAL AND :MESFINAL ORDER BY DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.FECHA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TCOMPONENTE" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
