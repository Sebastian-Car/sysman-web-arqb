	<query id="getDetallescomprobantecntGettotalvencidoporterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM((CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) BETWEEN 1 AND 30 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) BETWEEN 31 AND 60 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) BETWEEN 61 AND 90 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) BETWEEN 91 AND 120 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) BETWEEN 121 AND 150 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) BETWEEN 151 AND 180 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY'))BETWEEN 181 AND 270 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) BETWEEN 271 AND 360 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)+ (CASE WHEN TO_DATE(:FECHAFILTRO,'DD/MM/YYYY')-TO_DATE(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY')) &gt;361 THEN SUM(VALOR_DEBITO-DEBITO_AFECTADO-ABONOINICIAL) ELSE 0 END)) AS TOTAL_VENCIDO FROM DETALLE_COMPROBANTE_CNT INNER JOIN PLAN_CONTABLE V_PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = V_PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = V_PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = V_PLAN_CONTABLE.CODIGO INNER JOIN COMPROBANTE_CNT ON DETALLE_COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNT.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = COMPROBANTE_CNT.TIPO AND DETALLE_COMPROBANTE_CNT.ANO = COMPROBANTE_CNT.ANO AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = COMPROBANTE_CNT.NUMERO INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND VALOR_DEBITO-(DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO+DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO)-ABONOINICIAL &gt;0 AND TO_DATE(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY'),'DD/MM/YYYY') &lt;= TO_DATE(:FECHAFILTRO,'DD/MM/YYYY') AND V_PLAN_CONTABLE.CLASECUENTA = 'C' AND TIPO_COMPROBANTE.CLASE_CONTABLE = 'V' AND TERCERO.NIT =:TERCERO GROUP BY DETALLE_COMPROBANTE_CNT.TERCERO,COMPROBANTE_CNT.FECHA, TERCERO.NOMBRE, TERCERO.DIRECCION, TERCERO.CIUDAD, TERCERO.TELEFONOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_VENCIDO":"$TOTAL_VENCIDO(type:integer)"}]}}		</result>
		<param name="FECHAFILTRO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/gettotalvencidoportercero">
		<call-query href="getDetallescomprobantecntGettotalvencidoporterceroQuery">
			<with-param name="FECHAFILTRO" query-param="FECHAFILTRO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntPagCptesafectadosporaniotipocuentayfechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.COMPROBANTE AS NUMERO,(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_CNT.DESCRIPCION, (CASE NATURALEZA WHEN 'D' THEN VALOR_DEBITO - VALOR_CREDITO- (DEBITO_AFECTADO - CREDITO_AFECTADO) ELSE VALOR_CREDITO - VALOR_DEBITO- (CREDITO_AFECTADO - DEBITO_AFECTADO) END) AS SALDO, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.NATURALEZA FROM DETALLE_COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND DETALLE_COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND TIPO_COMPROBANTE.CLASE_CONTABLE = :COMPRELACIONADO AND DETALLE_COMPROBANTE_CNT.CUENTA= :CUENTA AND DETALLE_COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY HH24:MI:SS') AND DETALLE_COMPROBANTE_CNT.ANO BETWEEN 0 AND :ANOCOMPROBANTE AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE =:TIPO AND (CASE NATURALEZA WHEN 'D' THEN VALOR_DEBITO - VALOR_CREDITO- (DEBITO_AFECTADO - CREDITO_AFECTADO) ELSE VALOR_CREDITO - VALOR_DEBITO- (CREDITO_AFECTADO - DEBITO_AFECTADO) END) &gt; 0 ORDER BY DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","SALDO":"$SALDO(type:double)","ANO":"$ANO(type:integer)","NATURALEZA":"$NATURALEZA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="COMPRELACIONADO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="FECHACOMPROBANTE" sqlType="STRING"/>
		<param name="ANOCOMPROBANTE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
