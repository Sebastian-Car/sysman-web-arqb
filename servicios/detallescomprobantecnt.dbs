	<query id="updateDetallescomprobantecntCorpoboyacaServicio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_CNT SET CREATED_BY = ( SELECT C.CREATED_BY FROM COMPROBANTE_CNT C INNER JOIN DETALLE_COMPROBANTE_CNT D ON C.COMPANIA = D.COMPANIA AND C.ANO = D.ANO AND C.TIPO = D.TIPO_CPTE AND C.NUMERO = D.COMPROBANTE WHERE D.COMPANIA =:COMPANIA AND D.TIPO_CPTE_AFECT =:TIPO AND D.CMPTE_AFECTADO =:NUMERO ) WHERE COMPANIA =:COMPANIA AND TIPO_CPTE_AFECT =:TIPO AND CMPTE_AFECTADO =:NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallescomprobantecnt/corpoboyacaservicio">
		<call-query href="updateDetallescomprobantecntCorpoboyacaServicio">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntPagCuadredecarteraQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CASE WHEN TOTALDEUDA &lt; 0 THEN 0 ELSE TOTALDEUDA END TOTALDEUDA, CONSECUTIVO, ANO, TIPO_CPTE, COMPANIA, CONCAT(TIPO_CPTE,CONCAT(' - ',COMPROBANTECARTERA))COMPROBANTE, COMPROBANTECARTERA, TERCERO, SUCURSAL, CUENTA,(TO_CHAR(FECHA_ABONOINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_ABONOINICIAL, NOMBRE, CLASE, CASE WHEN SALDOT &lt; 0 THEN 0 ELSE SALDOT END SALDOT, DIFERENCIAENDIAST, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 0 AND 30 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 0 AND 30 THEN SALDOT ELSE 0 END ) END AS SALDO1T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 31 AND 60 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 31 AND 60 THEN SALDOT ELSE 0 END ) END AS SALDO2T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 61 AND 90 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 61 AND 90 THEN SALDOT ELSE 0 END ) END AS SALDO3T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 91 AND 180 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 91 AND 180 THEN SALDOT ELSE 0 END ) END AS SALDO4T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 181 AND 270 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 181 AND 270 THEN SALDOT ELSE 0 END ) END AS SALDO5T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 271 AND 360 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 271 AND 360 THEN SALDOT ELSE 0 END ) END AS SALDO6T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST &gt; 360 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST &gt; 360 THEN SALDOT ELSE 0 END ) END AS SALDO7T, DESCRIPCIONT, TIPOINFORME, VALOR_DEBITO, VALOR_CREDITO, DEBITO_AFECTADO, CREDITO_AFECTADO, ABONOINICIAL FROM( SELECT DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO AS TOTALDEUDA, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.COMPROBANTE AS COMPROBANTECARTERA, DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.SUCURSAL, DETALLE_COMPROBANTE_CNT.CUENTA, DETALLE_COMPROBANTE_CNT.FECHA_ABONOINICIAL, TERCERO.NOMBRE, CASE WHEN TIPO_COMPROBANTE.CLASE_CONTABLE = 'V' THEN CASE WHEN TERCERO.CLASEENTIDADOFICIAL &lt;&gt; 0 THEN 'Entidades Oficiales' ELSE 'Particulares' END ELSE 'Independiente / Particular' END AS CLASE, (DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO)-(DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO)- DETALLE_COMPROBANTE_CNT.ABONOINICIAL AS SALDOT, PCK_SYSMAN_UTL.FC_DIASMESCOMERCIAL(TO_DATE(:FECHA,'DD/MM/YYYY'),(DETALLE_COMPROBANTE_CNT.FECHA))- 1 AS DIFERENCIAENDIAST , CONCAT(CONCAT(CONCAT(CONCAT(DETALLE_COMPROBANTE_CNT.DESCRIPCION,'-'),DETALLE_COMPROBANTE_CNT.TIPO_CPTE),'-'),DETALLE_COMPROBANTE_CNT .COMPROBANTE)DESCRIPCIONT, 1 AS TIPOINFORME, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO, DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO, DETALLE_COMPROBANTE_CNT.ABONOINICIAL FROM DETALLE_COMPROBANTE_CNT INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO &lt;= :ANO AND DETALLE_COMPROBANTE_CNT.TERCERO = :TERCERO AND DETALLE_COMPROBANTE_CNT.CUENTA = :CUENTA AND DETALLE_COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHA,'DD/MM/YYYY') AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ('V') )ORDER BY COMPANIA, ANO, TIPO_CPTE, COMPROBANTECARTERA) INI WHERE (CASE WHEN TOTALDEUDA IS NULL THEN ' ' ELSE UPPER(TOTALDEUDA) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTALDEUDA), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN COMPROBANTECARTERA IS NULL THEN ' ' ELSE UPPER(COMPROBANTECARTERA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTECARTERA), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN FECHA_ABONOINICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_ABONOINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_ABONOINICIAL), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE), '%')) AND (CASE WHEN SALDOT IS NULL THEN ' ' ELSE UPPER(SALDOT) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDOT), '%')) AND (CASE WHEN DIFERENCIAENDIAST IS NULL THEN ' ' ELSE UPPER(DIFERENCIAENDIAST) END) LIKE UPPER(CONCAT(CONCAT('%',:DIFERENCIAENDIAST), '%')) AND (CASE WHEN SALDO1T IS NULL THEN ' ' ELSE UPPER(SALDO1T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO1T), '%')) AND (CASE WHEN SALDO2T IS NULL THEN ' ' ELSE UPPER(SALDO2T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO2T), '%')) AND (CASE WHEN SALDO3T IS NULL THEN ' ' ELSE UPPER(SALDO3T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO3T), '%')) AND (CASE WHEN SALDO4T IS NULL THEN ' ' ELSE UPPER(SALDO4T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO4T), '%')) AND (CASE WHEN SALDO5T IS NULL THEN ' ' ELSE UPPER(SALDO5T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO5T), '%')) AND (CASE WHEN SALDO6T IS NULL THEN ' ' ELSE UPPER(SALDO6T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO6T), '%')) AND (CASE WHEN SALDO7T IS NULL THEN ' ' ELSE UPPER(SALDO7T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO7T), '%')) AND (CASE WHEN DESCRIPCIONT IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONT) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCIONT), '%')) AND (CASE WHEN TIPOINFORME IS NULL THEN ' ' ELSE UPPER(TIPOINFORME) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOINFORME), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN DEBITO_AFECTADO IS NULL THEN ' ' ELSE UPPER(DEBITO_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:DEBITO_AFECTADO), '%')) AND (CASE WHEN CREDITO_AFECTADO IS NULL THEN ' ' ELSE UPPER(CREDITO_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CREDITO_AFECTADO), '%')) AND (CASE WHEN ABONOINICIAL IS NULL THEN ' ' ELSE UPPER(ABONOINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:ABONOINICIAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTALDEUDA":"$TOTALDEUDA(type:double)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPANIA":"$COMPANIA","COMPROBANTE":"$COMPROBANTE","COMPROBANTECARTERA":"$COMPROBANTECARTERA(type:long)","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CUENTA":"$CUENTA","FECHA_ABONOINICIAL":"$FECHA_ABONOINICIAL","NOMBRE":"$NOMBRE","CLASE":"$CLASE","SALDOT":"$SALDOT(type:double)","DIFERENCIAENDIAST":"$DIFERENCIAENDIAST(type:integer)","SALDO1T":"$SALDO1T(type:double)","SALDO2T":"$SALDO2T(type:double)","SALDO3T":"$SALDO3T(type:double)","SALDO4T":"$SALDO4T(type:double)","SALDO5T":"$SALDO5T(type:double)","SALDO6T":"$SALDO6T(type:double)","SALDO7T":"$SALDO7T(type:double)","DESCRIPCIONT":"$DESCRIPCIONT","TIPOINFORME":"$TIPOINFORME(type:double)","VALOR_DEBITO":"$VALOR_DEBITO(type:double)","VALOR_CREDITO":"$VALOR_CREDITO(type:double)","DEBITO_AFECTADO":"$DEBITO_AFECTADO(type:double)","CREDITO_AFECTADO":"$CREDITO_AFECTADO(type:double)","ABONOINICIAL":"$ABONOINICIAL(type:double)"}]}}		</result>
