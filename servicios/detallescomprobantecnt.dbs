	</resource>
	<query id="getDetallescomprobantecntNumCuentaafectadaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCAT(CONCAT(TIPO_CPTE, COMPROBANTE),CUENTA) ID, TIPO_CPTE, COMPROBANTE, ANO, CUENTA, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA FROM ( SELECT EGR.TIPO_CPTE, EGR.COMPROBANTE, EGR.ANO, EGR.CUENTA, EGR.FECHA FROM COMPROBANTE_CNTAFECTADOS RELA INNER JOIN TIPO_COMPROBANTE ON RELA.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND RELA.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO INNER JOIN DETALLE_COMPROBANTE_CNT EGR ON RELA.COMPANIA = EGR.COMPANIA AND RELA.ANO = EGR.ANO AND RELA.TIPO_CPTE = EGR.TIPO_CPTE AND RELA.COMPROBANTE = EGR.COMPROBANTE INNER JOIN PLAN_CONTABLE ON EGR.COMPANIA = PLAN_CONTABLE.COMPANIA AND EGR.ANO = PLAN_CONTABLE.ANO AND EGR.CUENTA = PLAN_CONTABLE.CODIGO WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND RELA.TIPO_CPTE_AFECT = :TIPO AND RELA.COMPROBANTE_AFECT = :CODIGO AND PLAN_CONTABLE.CLASECUENTA IN ( 'B' ) AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ( 'E', 'G' ) UNION SELECT EGR.TIPO_CPTE, EGR.COMPROBANTE, EGR.ANO, EGR.CUENTA, EGR.FECHA FROM DETALLE_COMPROBANTE_CNT EGR INNER JOIN TIPO_COMPROBANTE ON EGR.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND EGR.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO INNER JOIN PLAN_CONTABLE ON EGR.COMPANIA = PLAN_CONTABLE.COMPANIA AND EGR.ANO = PLAN_CONTABLE.ANO AND EGR.CUENTA = PLAN_CONTABLE.CODIGO WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND EGR.TIPO_CPTE = :TIPO AND EGR.COMPROBANTE = :CODIGO AND PLAN_CONTABLE.CLASECUENTA IN ( 'B' ) AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ( 'E', 'G' ) )) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(:TIPO_CPTE, '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
