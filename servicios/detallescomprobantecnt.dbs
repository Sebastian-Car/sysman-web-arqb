	<query id="getDetallescomprobantecntTodosPorNumeroDocumentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT D.NRO_DOCUMENTO FROM DETALLE_COMPROBANTE_CNT D INNER JOIN TIPO_COMPROBANTE T ON D.COMPANIA = T.COMPANIA AND D.TIPO_CPTE = T.CODIGO WHERE D.CUENTA = :CUENTABANCARIA AND D.COMPANIA = :COMPANIA AND T.CLASE_CONTABLE = 'E' AND D.VALOR_CREDITO &gt; 0 AND D.NRO_DOCUMENTO IS NOT NULL ORDER BY D.NRO_DOCUMENTO</sql>
