	<query id="getDetallescomprobantecntNumTodosporterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT D.COMPANIA, D.ANO, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, TO_CHAR(D.FECHA, 'DD/MM/YYYY') FECHA, D.VALOR_DEBITO, D.VALOR_CREDITO, D.DESCRIPCION, D.EJECUCION_DEBITO, D.EJECUCION_CREDITO, D.TIPO_DOCUMENTO, D.NRO_DOCUMENTO, D.TERCERO, D.SUCURSAL, T.NOMBRE NOMBRETERCERO, D.AUXILIAR, A.NOMBRE NOMBREAUXILIAR, D.FUENTE_RECURSO, F.NOMBRE NOMBREFTERECURSO, D.CENTRO_COSTO, C.NOMBRE NOMBRECENTROCOSTO, D.CUENTA, D.REFERENCIA, R.NOMBRE NOMBREREFERENCIA, D.CODIGO_PPTAL, D.BASE_GRAVABLE FROM DETALLE_COMPROBANTE_CNT D INNER JOIN TERCERO T ON D.COMPANIA = T.COMPANIA AND D.TERCERO = T.NIT AND D.SUCURSAL = T.SUCURSAL INNER JOIN AUXILIAR A ON D.COMPANIA = A.COMPANIA AND D.ANO = A.ANO AND D.AUXILIAR = A.CODIGO INNER JOIN FUENTE_RECURSOS F ON D.COMPANIA = F.COMPANIA AND D.ANO = F.ANO AND D.AUXILIAR = F.CODIGO INNER JOIN REFERENCIA R ON D.COMPANIA = R.COMPANIA AND D.ANO = R.ANO AND D.REFERENCIA = R.CODIGO INNER JOIN CENTRO_COSTO C ON D.COMPANIA = C.COMPANIA AND D.CENTRO_COSTO = C.CODIGO AND D.ANO = C.ANO WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANOQR AND D.MES BETWEEN :MESINICIALQR AND :MESFINALQR AND D.TERCERO = :TERCERO AND D.SUCURSAL = :SUCURSAL ORDER BY D.FECHA, D.TIPO_CPTE, D.COMPROBANTE) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(:VALOR_DEBITO, '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(:VALOR_CREDITO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN EJECUCION_DEBITO IS NULL THEN ' ' ELSE UPPER(EJECUCION_DEBITO) END) LIKE UPPER(CONCAT(:EJECUCION_DEBITO, '%')) AND (CASE WHEN EJECUCION_CREDITO IS NULL THEN ' ' ELSE UPPER(EJECUCION_CREDITO) END) LIKE UPPER(CONCAT(:EJECUCION_CREDITO, '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOCUMENTO), '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(:NRO_DOCUMENTO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN NOMBREAUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBREAUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAUXILIAR), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN NOMBREFTERECURSO IS NULL THEN ' ' ELSE UPPER(NOMBREFTERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFTERECURSO), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN CODIGO_PPTAL IS NULL THEN ' ' ELSE UPPER(CODIGO_PPTAL) END) LIKE UPPER(CONCAT(:CODIGO_PPTAL, '%')) AND (CASE WHEN BASE_GRAVABLE IS NULL THEN ' ' ELSE UPPER(BASE_GRAVABLE) END) LIKE UPPER(CONCAT(:BASE_GRAVABLE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOQR" sqlType="STRING"/>
		<param name="MESINICIALQR" sqlType="STRING"/>
		<param name="MESFINALQR" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="EJECUCION_DEBITO" sqlType="STRING"/>
		<param name="EJECUCION_CREDITO" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="NOMBREAUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBREFTERECURSO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CODIGO_PPTAL" sqlType="STRING"/>
		<param name="BASE_GRAVABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/todosportercero/num">
		<call-query href="getDetallescomprobantecntNumTodosporterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOQR" query-param="ANOQR"/>
			<with-param name="MESINICIALQR" query-param="MESINICIALQR"/>
