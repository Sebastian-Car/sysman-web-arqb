			<with-param name="BASE_GRAVABLE" query-param="BASE_GRAVABLE"/>
			<with-param name="TIPO_DOCUMENTO" query-param="TIPO_DOCUMENTO"/>
			<with-param name="NRO_DOCUMENTO" query-param="NRO_DOCUMENTO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="NOMBREPLANCONTABLE" query-param="NOMBREPLANCONTABLE"/>
			<with-param name="NOMBRECENTROCOSTO" query-param="NOMBRECENTROCOSTO"/>
			<with-param name="BANCO_RETENCION" query-param="BANCO_RETENCION"/>
			<with-param name="TIPO_CPTE_AFECT" query-param="TIPO_CPTE_AFECT"/>
			<with-param name="CMPTE_AFECTADO" query-param="CMPTE_AFECTADO"/>
