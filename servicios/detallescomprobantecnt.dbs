	<query id="getDetallescomprobantecntGetinformacionbasenotasinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT C.NITCOMPANIA, F.TERCERO NUMTERCERO,(TO_CHAR(F.FECHA_EXPEDICION, 'yyyy-MM-dd HH:mm:ss')) FECHAFACTURA, T.REF_FACTURACION PREFIJO, F.CUENTA_RECAUDO, D.CREATED_BY,(TO_CHAR(D.DATE_CREATED,'yyyy-MM-dd HH:mm:ss')) DATE_CREATED, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA, D.ANO, F.CUENTA_RECAUDO) CUENTA, TER.TELEFONOS, TER.CIUDAD CIUDADTERCERO, TER.DEPARTAMENTO DEPTOTERCERO, TER.REGIMEN REGIMENTERCERO, TER.NOMBRE1 RAZONSOCIAL, TER.NATURALEZA NATURALEZATERCERO, TER.NOMBRE NOMBRECLIENTE, TER.APELLIDO1 APELLIDO1CLIENTE, TER.APELLIDO2 APELLIDO2CLIENTE, TER.DIRECCION DIRECCIONTERECERO, TER.CODIGOPOSTAL CODIGOPOSTALTERCERO, TER.DIRECCIONEMAIL EMAILTERCERO, TER.DIGITOVERIFICACION DIGITOVERIFICACIONTERCERO, ( SELECT CODIGODIAN FROM PAISES WHERE PAIS = TER.PAIS ) PAISTERCERO, F.TIPO_PAGO, F.TIPO_MEDIOPAGO MEDIOPAGO, T.TIPO_MONEDA, T.TIPOFACDIAN, C.DIRECCION DIRECCIONCOMPANIA, C.CIUDAD CIUDADCOMPANIA, C.DEPARTAMENTO DEPTOCOMPANIA, ( SELECT DIGITOVERIFICACION FROM TERCERO WHERE NIT = C.NITCOMPANIA AND ROWNUM = 1 ) DIGITOVERIFICACIONCOMPANIA, (TO_CHAR(F.FECHA_VENCIMIENTO, 'yyyy-MM-dd HH:mm:ss')) FECHA_VENCIMIENTO  FROM DETALLE_COMPROBANTE_CNT D INNER JOIN SF_TIPO_COBRO T INNER JOIN SF_FACTURA F ON T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL ON F.TIPO_CPTE = D.TIPO_CPTE_AFECT AND F.NRO_CPTE = D.CMPTE_AFECTADO AND D.COMPANIA = F.COMPANIA AND D.ANO = T.ANO INNER JOIN COMPANIA C ON (F.COMPANIA = C.CODIGO) WHERE F.COMPANIA = :COMPANIA AND F.NUMERO_FACTURA = :FACTURA AND O.IMPRESO NOT IN ( 0 )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NITCOMPANIA":"$NITCOMPANIA","NUMTERCERO":"$NUMTERCERO","FECHAFACTURA":"$FECHAFACTURA","PREFIJO":"$PREFIJO","CUENTA_RECAUDO":"$CUENTA_RECAUDO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","CUENTA":"$CUENTA","TELEFONOS":"$TELEFONOS","CIUDADTERCERO":"$CIUDADTERCERO","DEPTOTERCERO":"$DEPTOTERCERO","REGIMENTERCERO":"$REGIMENTERCERO","RAZONSOCIAL":"$RAZONSOCIAL","NATURALEZATERCERO":"$NATURALEZATERCERO","NOMBRECLIENTE":"$NOMBRECLIENTE","APELLIDO1CLIENTE":"$APELLIDO1CLIENTE","APELLIDO2CLIENTE":"$APELLIDO2CLIENTE","DIRECCIONTERECERO":"$DIRECCIONTERECERO","CODIGOPOSTALTERCERO":"$CODIGOPOSTALTERCERO","EMAILTERCERO":"$EMAILTERCERO","DIGITOVERIFICACIONTERCERO":"$DIGITOVERIFICACIONTERCERO(type:long)","PAISTERCERO":"$PAISTERCERO","TIPO_PAGO":"$TIPO_PAGO","MEDIOPAGO":"$MEDIOPAGO","TIPO_MONEDA":"$TIPO_MONEDA","TIPOFACDIAN":"$TIPOFACDIAN","DIRECCIONCOMPANIA":"$DIRECCIONCOMPANIA","CIUDADCOMPANIA":"$CIUDADCOMPANIA","DEPTOCOMPANIA":"$DEPTOCOMPANIA","DIGITOVERIFICACIONCOMPANIA":"$DIGITOVERIFICACIONCOMPANIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>

	</query>
