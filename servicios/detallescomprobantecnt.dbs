<query id="getDetallescomprobantecntPagTesoreriaSaludQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE,(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, CASE WHEN DETALLE_COMPROBANTE_CNT.CODIGO_FUT IS NOT NULL THEN DETALLE_COMPROBANTE_CNT.CODIGO_FUT WHEN NVL(DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, 0) &lt;&gt; 0 THEN 'TFSI' WHEN NVL(DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, 0) &lt;&gt; 0 THEN 'PTFS' ELSE NULL END CODIGO_FUT, CUENTABANCOS.TIPO_SALUD FROM DETALLE_COMPROBANTE_CNT INNER JOIN CUENTABANCOS ON DETALLE_COMPROBANTE_CNT.COMPANIA = CUENTABANCOS.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = CUENTABANCOS.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = CUENTABANCOS.IDCONTABLE WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND EXTRACT(MONTH FROM FECHA) BETWEEN :TRIMESTRE - 2 AND :TRIMESTRE AND DETALLE_COMPROBANTE_CNT.CUENTA = :CUENTABANCO ORDER BY DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, DETALLE_COMPROBANTE_CNT.FECHA) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(:TIPO_CPTE, '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END) LIKE UPPER(CONCAT(:CODIGO_FUT, '%')) AND (CASE WHEN TIPO_SALUD IS NULL THEN ' ' ELSE UPPER(TIPO_SALUD) END) LIKE UPPER(CONCAT(:TIPO_SALUD, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","CODIGO_FUT":"$CODIGO_FUT","TIPO_SALUD":"$TIPO_SALUD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TRIMESTRE" sqlType="STRING"/>
		<param name="CUENTABANCO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="TIPO_SALUD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
