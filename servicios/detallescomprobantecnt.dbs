	<query id="updateDetallescomprobantecntTablaretenciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_CNT SET TIPO_PAGO_RETENCION=:TIPO_PAGO_RETENCION, COMPROBANTE_PAGO_RETENCION=:COMPROBANTE_PAGO_RETENCION, ANO_RETENCION=:ANO_RETENCION, BANCO_RETENCION=:BANCO_RETENCION, FECHA_PAGO_RETENCION=TO_DATE(:FECHA_PAGO_RETENCION,'DD/MM/YYYY HH24:MI:SS'), PAGO_RETENCION=:PAGO_RETENCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO= :KEY_ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE= :KEY_TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.COMPROBANTE= :KEY_COMPROBANTE AND DETALLE_COMPROBANTE_CNT.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

