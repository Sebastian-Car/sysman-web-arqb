			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NRODOCUMENTO" query-param="NRODOCUMENTO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntCuentaPagoDeComprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT CUENTA FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA =:COMPANIA AND TIPO_CPTE =:TIPO_CPTE AND COMPROBANTE =:COMPROBANTE AND VALOR_CREDITO IN (0) AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
