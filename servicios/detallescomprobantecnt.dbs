			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantecntPagDocumentosSubConciliacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D.NRO_DOCUMENTO, D.TIPO_CPTE, D.COMPROBANTE, D.ANO, D.CONSECUTIVO FROM DETALLE_COMPROBANTE_CNT D INNER JOIN COMPROBANTE_CNT C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPO_CPTE = C.TIPO AND D.COMPROBANTE = C.NUMERO INNER JOIN TIPO_COMPROBANTE T ON T.COMPANIA = D.COMPANIA AND T.CODIGO = D.TIPO_CPTE INNER JOIN PLAN_CONTABLE ON PLAN_CONTABLE.COMPANIA = D.COMPANIA AND PLAN_CONTABLE.ANO = D.ANO AND PLAN_CONTABLE.CODIGO = D.CUENTA WHERE D.COMPANIA = :COMPANIA AND D.FECHA &lt;= TO_DATE(:ULTIMODIA,'DD/MM/YYYY') AND D.CUENTA = :CUENTA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CLASESCONTABLES), T.CLASE_CONTABLE, 1) &gt;0 AND ((EXTRACT(MONTH FROM D.FECHA) = :MES AND D.ANO = :ANO) OR (EXTRACT(MONTH FROM FECHA_CONCILIA) = :MES AND EXTRACT(YEAR FROM FECHA_CONCILIA) = :ANO) OR (D.PAGADOBANCO = 0)) AND (CASE WHEN PLAN_CONTABLE.MAN_AUX_TER &lt;&gt; 0 THEN D.TERCERO ELSE '999999999999999999' END) = :TERCERO AND (CASE WHEN PLAN_CONTABLE.MAN_AUX_TER &lt;&gt; 0 THEN D.SUCURSAL ELSE '999' END) = :SUCURSAL AND (CASE WHEN PLAN_CONTABLE.MAN_CEN_CTO &lt;&gt; 0 THEN D.CENTRO_COSTO ELSE '99999999999999999999' END) = :CENTRO_COSTO AND (CASE WHEN PLAN_CONTABLE.MAN_AUX_GEN &lt;&gt; 0 THEN D.AUXILIAR ELSE '99999999999999999999' END) = :AUXILIAR AND (CASE WHEN PLAN_CONTABLE.MAN_AUX_FUE &lt;&gt; 0 THEN D.FUENTE_RECURSO ELSE '99999999999999999999' END) = :FUENTE_RECURSO AND (CASE WHEN PLAN_CONTABLE.MAN_AUX_REF &lt;&gt; 0 THEN D.REFERENCIA ELSE '99999999999999999999' END) = :REFERENCIA ORDER BY D.COMPROBANTE) INI WHERE (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(:NRO_DOCUMENTO, '%')) AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_DOCUMENTO":"$NRO_DOCUMENTO","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ULTIMODIA" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CLASESCONTABLES" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
