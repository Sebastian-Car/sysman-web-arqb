	<query id="getDetallescomprobantecntPagTodosPorFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.CUENTA, DETALLE_COMPROBANTE_CNT.MES, TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS') FECHA, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, DETALLE_COMPROBANTE_CNT.TIPO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.NRO_DOCUMENTO, DETALLE_COMPROBANTE_CNT.DESCRIPCION, DETALLE_COMPROBANTE_CNT.CENTRO_COSTO, DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.SUCURSAL, DETALLE_COMPROBANTE_CNT.AUXILIAR, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE, AUXILIAR.NOMBRE AUXILIAR_NOM, CENTRO_COSTO.NOMBRE CENTRO_COSTO_NOM, TERCERO.NOMBRE TERCERO_NOM FROM DETALLE_COMPROBANTE_CNT INNER JOIN AUXILIAR ON DETALLE_COMPROBANTE_CNT.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = AUXILIAR.ANO AND DETALLE_COMPROBANTE_CNT.AUXILIAR = AUXILIAR.CODIGO INNER JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_CNT.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = CENTRO_COSTO.ANO AND DETALLE_COMPROBANTE_CNT.CENTRO_COSTO = CENTRO_COSTO.CODIGO INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT WHERE DETALLE_COMPROBANTE_CNT.COMPANIA= :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO= :ANO AND SUBSTR(DETALLE_COMPROBANTE_CNT.ID,0,LENGTH (:CUENTA)) = :CUENTA AND DETALLE_COMPROBANTE_CNT.MES BETWEEN :MESINICIAL AND :MESFINAL ORDER BY DETALLE_COMPROBANTE_CNT.FECHA, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOCUMENTO), '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NRO_DOCUMENTO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN AUXILIAR_NOM IS NULL THEN ' ' ELSE UPPER(AUXILIAR_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR_NOM), '%')) AND (CASE WHEN CENTRO_COSTO_NOM IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO_NOM), '%')) AND (CASE WHEN TERCERO_NOM IS NULL THEN ' ' ELSE UPPER(TERCERO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO_NOM), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","MES":"$MES(type:long)","FECHA":"$FECHA","VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","DESCRIPCION":"$DESCRIPCION","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","AUXILIAR_NOM":"$AUXILIAR_NOM","CENTRO_COSTO_NOM":"$CENTRO_COSTO_NOM","TERCERO_NOM":"$TERCERO_NOM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="AUXILIAR_NOM" sqlType="STRING"/>
