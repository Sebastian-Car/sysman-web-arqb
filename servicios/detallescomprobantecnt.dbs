			<with-param name="VALOR_DEBITO" query-param="VALOR_DEBITO"/>
			<with-param name="VALOR_CREDITO" query-param="VALOR_CREDITO"/>
			<with-param name="DEBITO_AFECTADO" query-param="DEBITO_AFECTADO"/>
			<with-param name="CREDITO_AFECTADO" query-param="CREDITO_AFECTADO"/>
