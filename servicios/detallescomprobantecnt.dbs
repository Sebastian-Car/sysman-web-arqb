	<query id="deleteDetallescomprobantecnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DETALLE_COMPROBANTE_CNT WHERE DETALLE_COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO= :KEY_ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE= :KEY_TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.COMPROBANTE= :KEY_COMPROBANTE AND DETALLE_COMPROBANTE_CNT.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_CPTE" sqlType="STRING"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
