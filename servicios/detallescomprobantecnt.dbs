	<query id="getDetallescomprobantecntEntreTercerosYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT TIPO_CPTE_AFECT, CMPTE_AFECTADO, TO_CHAR(FECHA_CONSIGNACIONPLANO,'DD/MM/YYYY') FECHA_CONSIGNACIONPLANO, COMPROBANTE, VALOR_CREDITO, COMPANIA, TIPO_CPTE, ANO, VALOR_DEBITO, CUENTA, TERCERO, ABONOINICIAL, VALORTOTAL VLR_DOCUMENTO ,NATURALEZA,TO_CHAR(FECHA,'DD/MM/YYYY')FECHA, CONSECUTIVO FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA =:COMPANIA AND TIPO_CPTE =CASE WHEN :TIPO IS NOT NULL THEN :TIPO ELSE TIPO_CPTE END AND CONCAT(TERCERO,SUCURSAL) BETWEEN CONCAT(:TERCEROI,:SUCURSALI) AND CONCAT(:TERCEROF,:SUCURSALF) ORDER BY COMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","FECHA_CONSIGNACIONPLANO":"$FECHA_CONSIGNACIONPLANO","COMPROBANTE":"$COMPROBANTE(type:long)","VALOR_CREDITO":"$VALOR_CREDITO","COMPANIA":"$COMPANIA","TIPO_CPTE":"$TIPO_CPTE","ANO":"$ANO(type:integer)","VALOR_DEBITO":"$VALOR_DEBITO","CUENTA":"$CUENTA","TERCERO":"$TERCERO","ABONOINICIAL":"$ABONOINICIAL","VLR_DOCUMENTO":"$VLR_DOCUMENTO","NATURALEZA":"$NATURALEZA","FECHA":"$FECHA","CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TERCEROI" sqlType="STRING"/>
		<param name="SUCURSALI" sqlType="STRING"/>
		<param name="TERCEROF" sqlType="STRING"/>
		<param name="SUCURSALF" sqlType="STRING"/>

	</query>
