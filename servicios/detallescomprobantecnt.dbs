	<query id="getDetallescomprobantecntNumCuadredecarteraQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CASE WHEN TOTALDEUDA &lt; 0 THEN 0 ELSE TOTALDEUDA END TOTALDEUDA, CONSECUTIVO, ANO, TIPO_CPTE, COMPANIA, CONCAT(TIPO_CPTE,CONCAT(' - ',COMPROBANTECARTERA))COMPROBANTE, COMPROBANTECARTERA, TERCERO, SUCURSAL, CUENTA,(TO_CHAR(FECHA_ABONOINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_ABONOINICIAL, NOMBRE, CLASE, CASE WHEN SALDOT &lt; 0 THEN 0 ELSE SALDOT END SALDOT, DIFERENCIAENDIAST, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 0 AND 30 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 0 AND 30 THEN SALDOT ELSE 0 END ) END AS SALDO1T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 31 AND 60 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 31 AND 60 THEN SALDOT ELSE 0 END ) END AS SALDO2T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 61 AND 90 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 61 AND 90 THEN SALDOT ELSE 0 END ) END AS SALDO3T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 91 AND 180 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 91 AND 180 THEN SALDOT ELSE 0 END ) END AS SALDO4T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 181 AND 270 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 181 AND 270 THEN SALDOT ELSE 0 END ) END AS SALDO5T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST BETWEEN 271 AND 360 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST BETWEEN 271 AND 360 THEN SALDOT ELSE 0 END ) END AS SALDO6T, CASE WHEN( CASE WHEN DIFERENCIAENDIAST &gt; 360 THEN SALDOT ELSE 0 END )&lt; 0 THEN 0 ELSE ( CASE WHEN DIFERENCIAENDIAST &gt; 360 THEN SALDOT ELSE 0 END ) END AS SALDO7T, DESCRIPCIONT, TIPOINFORME, VALOR_DEBITO, VALOR_CREDITO, DEBITO_AFECTADO, CREDITO_AFECTADO, ABONOINICIAL FROM( SELECT DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO AS TOTALDEUDA, DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.COMPROBANTE AS COMPROBANTECARTERA, DETALLE_COMPROBANTE_CNT.TERCERO, DETALLE_COMPROBANTE_CNT.SUCURSAL, DETALLE_COMPROBANTE_CNT.CUENTA, DETALLE_COMPROBANTE_CNT.FECHA_ABONOINICIAL, TERCERO.NOMBRE, CASE WHEN TIPO_COMPROBANTE.CLASE_CONTABLE = 'V' THEN CASE WHEN TERCERO.CLASEENTIDADOFICIAL &lt;&gt; 0 THEN 'Entidades Oficiales' ELSE 'Particulares' END ELSE 'Independiente / Particular' END AS CLASE, (DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO)-(DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO)- DETALLE_COMPROBANTE_CNT.ABONOINICIAL AS SALDOT, PCK_SYSMAN_UTL.FC_DIASMESCOMERCIAL(TO_DATE(:FECHA,'DD/MM/YYYY'),(DETALLE_COMPROBANTE_CNT.FECHA))- 1 AS DIFERENCIAENDIAST , CONCAT(CONCAT(CONCAT(CONCAT(DETALLE_COMPROBANTE_CNT.DESCRIPCION,'-'),DETALLE_COMPROBANTE_CNT.TIPO_CPTE),'-'),DETALLE_COMPROBANTE_CNT .COMPROBANTE)DESCRIPCIONT, 1 AS TIPOINFORME, DETALLE_COMPROBANTE_CNT.VALOR_DEBITO, DETALLE_COMPROBANTE_CNT.VALOR_CREDITO, DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO, DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO, DETALLE_COMPROBANTE_CNT.ABONOINICIAL FROM DETALLE_COMPROBANTE_CNT INNER JOIN TERCERO ON DETALLE_COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO &lt;= :ANO AND DETALLE_COMPROBANTE_CNT.TERCERO = :TERCERO AND DETALLE_COMPROBANTE_CNT.CUENTA = :CUENTA AND DETALLE_COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHA,'DD/MM/YYYY') AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ('V') )ORDER BY COMPANIA, ANO, TIPO_CPTE, COMPROBANTECARTERA) INI WHERE (CASE WHEN TOTALDEUDA IS NULL THEN ' ' ELSE UPPER(TOTALDEUDA) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTALDEUDA), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN COMPROBANTECARTERA IS NULL THEN ' ' ELSE UPPER(COMPROBANTECARTERA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTECARTERA), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN FECHA_ABONOINICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_ABONOINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_ABONOINICIAL), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE), '%')) AND (CASE WHEN SALDOT IS NULL THEN ' ' ELSE UPPER(SALDOT) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDOT), '%')) AND (CASE WHEN DIFERENCIAENDIAST IS NULL THEN ' ' ELSE UPPER(DIFERENCIAENDIAST) END) LIKE UPPER(CONCAT(CONCAT('%',:DIFERENCIAENDIAST), '%')) AND (CASE WHEN SALDO1T IS NULL THEN ' ' ELSE UPPER(SALDO1T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO1T), '%')) AND (CASE WHEN SALDO2T IS NULL THEN ' ' ELSE UPPER(SALDO2T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO2T), '%')) AND (CASE WHEN SALDO3T IS NULL THEN ' ' ELSE UPPER(SALDO3T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO3T), '%')) AND (CASE WHEN SALDO4T IS NULL THEN ' ' ELSE UPPER(SALDO4T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO4T), '%')) AND (CASE WHEN SALDO5T IS NULL THEN ' ' ELSE UPPER(SALDO5T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO5T), '%')) AND (CASE WHEN SALDO6T IS NULL THEN ' ' ELSE UPPER(SALDO6T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO6T), '%')) AND (CASE WHEN SALDO7T IS NULL THEN ' ' ELSE UPPER(SALDO7T) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO7T), '%')) AND (CASE WHEN DESCRIPCIONT IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONT) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCIONT), '%')) AND (CASE WHEN TIPOINFORME IS NULL THEN ' ' ELSE UPPER(TIPOINFORME) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOINFORME), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN DEBITO_AFECTADO IS NULL THEN ' ' ELSE UPPER(DEBITO_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:DEBITO_AFECTADO), '%')) AND (CASE WHEN CREDITO_AFECTADO IS NULL THEN ' ' ELSE UPPER(CREDITO_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CREDITO_AFECTADO), '%')) AND (CASE WHEN ABONOINICIAL IS NULL THEN ' ' ELSE UPPER(ABONOINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:ABONOINICIAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="FECHA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="TOTALDEUDA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="COMPROBANTECARTERA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA_ABONOINICIAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="SALDOT" sqlType="STRING"/>
		<param name="DIFERENCIAENDIAST" sqlType="STRING"/>
		<param name="SALDO1T" sqlType="STRING"/>
		<param name="SALDO2T" sqlType="STRING"/>
		<param name="SALDO3T" sqlType="STRING"/>
		<param name="SALDO4T" sqlType="STRING"/>
		<param name="SALDO5T" sqlType="STRING"/>
		<param name="SALDO6T" sqlType="STRING"/>
		<param name="SALDO7T" sqlType="STRING"/>
		<param name="DESCRIPCIONT" sqlType="STRING"/>
		<param name="TIPOINFORME" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
		<param name="DEBITO_AFECTADO" sqlType="STRING"/>
		<param name="CREDITO_AFECTADO" sqlType="STRING"/>
		<param name="ABONOINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/cuadredecartera/num">
		<call-query href="getDetallescomprobantecntNumCuadredecarteraQuery">
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="TOTALDEUDA" query-param="TOTALDEUDA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="COMPROBANTECARTERA" query-param="COMPROBANTECARTERA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHA_ABONOINICIAL" query-param="FECHA_ABONOINICIAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="SALDOT" query-param="SALDOT"/>
			<with-param name="DIFERENCIAENDIAST" query-param="DIFERENCIAENDIAST"/>
			<with-param name="SALDO1T" query-param="SALDO1T"/>
			<with-param name="SALDO2T" query-param="SALDO2T"/>
			<with-param name="SALDO3T" query-param="SALDO3T"/>
