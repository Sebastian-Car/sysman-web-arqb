	<query id="getDetallescomprobantecntConceptoExogenasQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_CNT.CONCEPTO_EX FROM DETALLE_COMPROBANTE_CNT INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO WHERE PLAN_CONTABLE.CLASECUENTA IN ('I','R','G','V') AND DETALLE_COMPROBANTE_CNT.COMPANIA= :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO= :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE=(CASE WHEN 'CIE' = :TIPOCOMP THEN ' ' ELSE :TIPOCOMP END) AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :NUMEROCOMP</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONCEPTO_EX":"$CONCEPTO_EX"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>

	</query>
