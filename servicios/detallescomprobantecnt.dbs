	<query id="getDetallescomprobantecntNumCptesafectadosporaniotipocuentayfechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.CONSECUTIVO, DETALLE_COMPROBANTE_CNT.COMPROBANTE AS NUMERO,(TO_CHAR(DETALLE_COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_CNT.DESCRIPCION, (CASE NATURALEZA WHEN 'D' THEN VALOR_DEBITO - VALOR_CREDITO- (DEBITO_AFECTADO - CREDITO_AFECTADO) ELSE VALOR_CREDITO - VALOR_DEBITO- (CREDITO_AFECTADO - DEBITO_AFECTADO) END) AS SALDO, DETALLE_COMPROBANTE_CNT.ANO, DETALLE_COMPROBANTE_CNT.NATURALEZA FROM DETALLE_COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON DETALLE_COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND DETALLE_COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND TIPO_COMPROBANTE.CLASE_CONTABLE = :COMPRELACIONADO AND DETALLE_COMPROBANTE_CNT.CUENTA= :CUENTA AND DETALLE_COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY HH24:MI:SS') AND DETALLE_COMPROBANTE_CNT.ANO BETWEEN 0 AND :ANOCOMPROBANTE AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE =:TIPO AND (CASE NATURALEZA WHEN 'D' THEN VALOR_DEBITO - VALOR_CREDITO- (DEBITO_AFECTADO - CREDITO_AFECTADO) ELSE VALOR_CREDITO - VALOR_DEBITO- (CREDITO_AFECTADO - DEBITO_AFECTADO) END) &gt; 0 ORDER BY DETALLE_COMPROBANTE_CNT.COMPANIA, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, DETALLE_COMPROBANTE_CNT.COMPROBANTE) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
