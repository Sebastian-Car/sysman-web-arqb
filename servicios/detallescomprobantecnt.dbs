	<query id="getDetallescomprobantecntInformacionFacturasFridaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT F.TERCERO NUMTERCERO,(TO_CHAR(F.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURA, F.REF_FACTURACION PREFIJO, F.CUENTA_RECAUDO, D.CREATED_BY, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA,D.ANO,F.CUENTA_RECAUDO) CUENTA, TER.TELEFONOS, F.TIPO_PAGO, F.TIPO_MEDIOPAGO MEDIOPAGO, T.TIPO_MONEDA, T.TIPOFACDIAN FROM DETALLE_COMPROBANTE_CNT D INNER JOIN SF_TIPO_COBRO T INNER JOIN SF_FACTURA F ON T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL ON F.TIPO_CPTE = D.TIPO_CPTE_AFECT AND F.NRO_CPTE = D.CMPTE_AFECTADO AND D.COMPANIA = F.COMPANIA AND D.ANO = T.ANO WHERE F.COMPANIA =:COMPANIA AND F.NUMERO_FACTURA =:FACTURA AND O.IMPRESO NOT IN ( 0 ) AND TO_DATE(TO_CHAR(D.FECHA,'dd/MM/YYYY'), 'dd/MM/YYYY') BETWEEN :FECHAINICIAL AND :FECHAFINAL AND T.CODIGO = :TIPOCOBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMTERCERO":"$NUMTERCERO","FECHAFACTURA":"$FECHAFACTURA","PREFIJO":"$PREFIJO","CUENTA_RECAUDO":"$CUENTA_RECAUDO","CREATED_BY":"$CREATED_BY","CUENTA":"$CUENTA","TELEFONOS":"$TELEFONOS","TIPO_PAGO":"$TIPO_PAGO","MEDIOPAGO":"$MEDIOPAGO","TIPO_MONEDA":"$TIPO_MONEDA","TIPOFACDIAN":"$TIPOFACDIAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantecnt/informacionfacturasfrida">
