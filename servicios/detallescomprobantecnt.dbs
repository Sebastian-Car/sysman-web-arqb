	<query id="getDetallescomprobantecntDebitoCreditoPorCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(DETALLE_COMPROBANTE_CNT.VALOR_DEBITO),0) TOTAL_DEBITO, NVL(SUM(DETALLE_COMPROBANTE_CNT.VALOR_CREDITO),0) TOTAL_CREDITO FROM DETALLE_COMPROBANTE_CNT WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = :ANO AND SUBSTR(DETALLE_COMPROBANTE_CNT.ID,0,LENGTH(:CUENTA)) = :CUENTA AND DETALLE_COMPROBANTE_CNT.MES BETWEEN :MESINICIAL AND :MESFINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_DEBITO":"$TOTAL_DEBITO","TOTAL_CREDITO":"$TOTAL_CREDITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
