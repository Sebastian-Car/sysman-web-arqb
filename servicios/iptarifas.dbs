	<query id="getIptarifasPagPorcentajePorDescuentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_TARIFAS.TRPCOD, IP_TARIFAS.TRPDES, IP_TARIFAS.TRPPOR  FROM IP_TARIFAS WHERE IP_TARIFAS.COMPANIA= :COMPANIA AND IP_TARIFAS.TRPANO = :ANO) WHERE (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER(:TRPCOD || '%')  AND (CASE WHEN TRPDES IS NULL THEN ' ' ELSE UPPER(TRPDES) END)  LIKE UPPER( '%' || :TRPDES || '%')  AND (CASE WHEN TRPPOR IS NULL THEN ' ' ELSE UPPER(TRPPOR) END)  LIKE UPPER(:TRPPOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TRPCOD":"$TRPCOD","TRPDES":"$TRPDES","TRPPOR":"$TRPPOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="TRPDES" sqlType="STRING"/>
		<param name="TRPPOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
