	<query id="getIptarifasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , TRPANO, TRPCOD , TRPRAN, TRPDES, TRPRAN1, TRPRAN2, TRPPOR, PORCBOMB, TRPALUMBRADO, TRPINC,(CASE TRPFOR WHEN 0 THEN 'false' ELSE 'true' END) TRPFOR, TRPINT, TRPCAR,(CASE CONTROL WHEN 0 THEN 'false' ELSE 'true' END) CONTROL, GRUPO_TARIFA, PORCDESCUENTOS  FROM IP_TARIFAS WHERE IP_TARIFAS.COMPANIA = :COMPANIA AND IP_TARIFAS.TRPANO = :ANO ORDER BY IP_TARIFAS.TRPANO DESC , IP_TARIFAS.TRPCOD) WHERE (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER( '%' || :TRPCOD || '%')  AND (CASE WHEN TRPRAN IS NULL THEN ' ' ELSE UPPER(TRPRAN) END)  LIKE UPPER( '%' || :TRPRAN || '%')  AND (CASE WHEN TRPDES IS NULL THEN ' ' ELSE UPPER(TRPDES) END)  LIKE UPPER( '%' || :TRPDES || '%')  AND (CASE WHEN TRPRAN1 IS NULL THEN ' ' ELSE UPPER(TRPRAN1) END)  LIKE UPPER( '%' || :TRPRAN1 || '%')  AND (CASE WHEN TRPRAN2 IS NULL THEN ' ' ELSE UPPER(TRPRAN2) END)  LIKE UPPER( '%' || :TRPRAN2 || '%')  AND (CASE WHEN TRPPOR IS NULL THEN ' ' ELSE UPPER(TRPPOR) END)  LIKE UPPER( '%' || :TRPPOR || '%')  AND (CASE WHEN PORCBOMB IS NULL THEN ' ' ELSE UPPER(PORCBOMB) END)  LIKE UPPER( '%' || :PORCBOMB || '%')  AND (CASE WHEN TRPALUMBRADO IS NULL THEN ' ' ELSE UPPER(TRPALUMBRADO) END)  LIKE UPPER( '%' || :TRPALUMBRADO || '%')  AND (CASE WHEN TRPINC IS NULL THEN ' ' ELSE UPPER(TRPINC) END)  LIKE UPPER( '%' || :TRPINC || '%')  AND (CASE WHEN TRPFOR IS NULL THEN ' ' ELSE UPPER(TRPFOR) END)  LIKE UPPER( '%' || :TRPFOR || '%')  AND (CASE WHEN TRPINT IS NULL THEN ' ' ELSE UPPER(TRPINT) END)  LIKE UPPER( '%' || :TRPINT || '%')  AND (CASE WHEN TRPCAR IS NULL THEN ' ' ELSE UPPER(TRPCAR) END)  LIKE UPPER( '%' || :TRPCAR || '%')  AND (CASE WHEN CONTROL IS NULL THEN ' ' ELSE UPPER(CONTROL) END)  LIKE UPPER( '%' || :CONTROL || '%')  AND (CASE WHEN GRUPO_TARIFA IS NULL THEN ' ' ELSE UPPER(GRUPO_TARIFA) END)  LIKE UPPER( '%' || :GRUPO_TARIFA || '%')  AND (CASE WHEN PORCDESCUENTOS IS NULL THEN ' ' ELSE UPPER(PORCDESCUENTOS) END)  LIKE UPPER( '%' || :PORCDESCUENTOS || '%') ))</sql>
