		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_TARIFAS.TRPCOD, IP_TARIFAS.TRPRAN, IP_TARIFAS.TRPANO, IP_TARIFAS.TRPDES, IP_TARIFAS.TRPPOR  FROM IP_TARIFAS WHERE IP_TARIFAS.COMPANIA = :COMPANIA AND IP_TARIFAS.TRPANO = :ANO) WHERE (CASE WHEN TRPCOD IS NULL THEN ' ' ELSE UPPER(TRPCOD) END)  LIKE UPPER(:TRPCOD || '%')  AND (CASE WHEN TRPRAN IS NULL THEN ' ' ELSE UPPER(TRPRAN) END)  LIKE UPPER(:TRPRAN || '%')  AND (CASE WHEN TRPANO IS NULL THEN ' ' ELSE UPPER(TRPANO) END)  LIKE UPPER(:TRPANO || '%')  AND (CASE WHEN TRPDES IS NULL THEN ' ' ELSE UPPER(TRPDES) END)  LIKE UPPER( '%' || :TRPDES || '%')  AND (CASE WHEN TRPPOR IS NULL THEN ' ' ELSE UPPER(TRPPOR) END)  LIKE UPPER(:TRPPOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
