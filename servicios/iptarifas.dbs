	<query id="updateIptarifas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_TARIFAS SET TRPANO=:TRPANO, TRPCOD=:TRPCOD, TRPRAN=:TRPRAN, TRPDES=:TRPDES, TRPRAN1=:TRPRAN1, TRPRAN2=:TRPRAN2, TRPPOR=:TRPPOR, PORCBOMB=:PORCBOMB, TRPALUMBRADO=:TRPALUMBRADO, TRPINC=:TRPINC, TRPFOR=:TRPFOR, TRPINT=:TRPINT, TRPCAR=:TRPCAR, CONTROL=:CONTROL, GRUPO_TARIFA=:GRUPO_TARIFA, PORCDESCUENTOS=:PORCDESCUENTOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_TARIFAS.COMPANIA= :KEY_COMPANIA AND IP_TARIFAS.TRPCOD= :KEY_TRPCOD AND IP_TARIFAS.TRPANO= :KEY_TRPANO AND IP_TARIFAS.TRPRAN= :KEY_TRPRAN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TRPANO" sqlType="STRING"/>
		<param name="TRPCOD" sqlType="STRING"/>
		<param name="TRPRAN" sqlType="STRING"/>
		<param name="TRPDES" sqlType="STRING"/>
		<param name="TRPRAN1" sqlType="STRING"/>
		<param name="TRPRAN2" sqlType="STRING"/>
		<param name="TRPPOR" sqlType="STRING"/>
		<param name="PORCBOMB" sqlType="STRING"/>
		<param name="TRPALUMBRADO" sqlType="STRING"/>
		<param name="TRPINC" sqlType="STRING"/>
		<param name="TRPFOR" sqlType="STRING"/>
		<param name="TRPINT" sqlType="STRING"/>
		<param name="TRPCAR" sqlType="STRING"/>
		<param name="CONTROL" sqlType="STRING"/>
		<param name="GRUPO_TARIFA" sqlType="STRING"/>
		<param name="PORCDESCUENTOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TRPCOD" sqlType="STRING"/>
		<param name="KEY_TRPANO" sqlType="STRING"/>
		<param name="KEY_TRPRAN" sqlType="STRING"/>

	</query>
