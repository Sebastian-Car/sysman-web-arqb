	<query id="updateResponsables" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RESPONSABLE SET COMPANIA=:COMPANIA, CEDULA=:CEDULA, SUCURSAL=:SUCURSAL, CARGO=:CARGO, ACTIVO=:ACTIVO, NOMBRAMIENTO=:NOMBRAMIENTO, ID_SOLICITANTE=:ID_SOLICITANTE, ID_RESPONSABLE=:ID_RESPONSABLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE RESPONSABLE.COMPANIA= :KEY_COMPANIA AND RESPONSABLE.CEDULA= :KEY_CEDULA AND RESPONSABLE.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="NOMBRAMIENTO" sqlType="STRING"/>
		<param name="ID_SOLICITANTE" sqlType="STRING"/>
		<param name="ID_RESPONSABLE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CEDULA" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="responsables">
		<call-query href="updateResponsables">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="NOMBRAMIENTO" query-param="NOMBRAMIENTO"/>
			<with-param name="ID_SOLICITANTE" query-param="ID_SOLICITANTE"/>
			<with-param name="ID_RESPONSABLE" query-param="ID_RESPONSABLE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CEDULA" query-param="KEY_CEDULA"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getResponsablesPagTodosPorCompaniaYCedulaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  RESPONSABLE.CEDULA , TERCERO.NOMBRE , RESPONSABLE.SUCURSAL  FROM RESPONSABLE INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE RESPONSABLE.COMPANIA =:COMPANIA AND RESPONSABLE.CEDULA = :NUMERO) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CEDULA":"$CEDULA","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
