	</resource>
	<query id="getResponsablesNumActivosConJefeunidadPorDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  R.CEDULA, R.SUCURSAL, T.NOMBRE NOMRESPONSABLE, ( CASE WHEN D.JEFEUNIDAD &lt;&gt; 0 THEN 'true' ELSE 'false' END ) JEFEUNIDADT,(CASE D.JEFEUNIDAD WHEN 0 THEN 'false' ELSE 'true' END) JEFEUNIDAD FROM RESPONSABLE R INNER JOIN DEPENDENCIA_RESPONSABLE D ON R.COMPANIA = D.COMPANIA AND R.CEDULA = D.RESPONSABLE AND R.SUCURSAL = D.SUCURSAL INNER JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL WHERE R.COMPANIA = :COMPANIA AND R.ACTIVO NOT IN(0) AND D.DEPENDENCIA = :DEPENDENCIA AND D.RESPONSABLEALMACEN NOT IN (0)) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%')  AND (CASE WHEN NOMRESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMRESPONSABLE) END)  LIKE UPPER( '%' || :NOMRESPONSABLE || '%')  AND (CASE WHEN JEFEUNIDADT IS NULL THEN ' ' ELSE UPPER(JEFEUNIDADT) END)  LIKE UPPER( '%' || :JEFEUNIDADT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMRESPONSABLE" sqlType="STRING"/>
		<param name="JEFEUNIDADT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="responsables/activosconjefeunidadpordependencia/num">
