	<query id="getResponsablesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  R.COMPANIA, R.CEDULA, R.SUCURSAL, T.NOMBRE, R.CARGO,(CASE R.ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO, R.NOMBRAMIENTO, R.ID_SOLICITANTE, R.ID_RESPONSABLE FROM RESPONSABLE R INNER JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL WHERE R.COMPANIA=:COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER( '%' || :CEDULA || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%')  AND (CASE WHEN ACTIVO IS NULL THEN ' ' ELSE UPPER(ACTIVO) END)  LIKE UPPER( '%' || :ACTIVO || '%')  AND (CASE WHEN NOMBRAMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBRAMIENTO) END)  LIKE UPPER( '%' || :NOMBRAMIENTO || '%') AND (CASE WHEN ID_SOLICITANTE IS NULL THEN ' ' ELSE UPPER(ID_SOLICITANTE) END) LIKE UPPER(CONCAT(:ID_SOLICITANTE, '%')) AND (CASE WHEN ID_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(ID_RESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_RESPONSABLE), '%')) ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
