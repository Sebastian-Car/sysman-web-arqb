<data name="viviaticos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getViviaticosPagSolicitudesSegunTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT VI_VIATICOS.CODSOLICITUD, VI_DETALLE_VIATICOS.TERCERO,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM VI_VIATICOS INNER JOIN VI_DETALLE_VIATICOS ON VI_VIATICOS.COMPANIA = VI_DETALLE_VIATICOS.COMPANIA AND VI_VIATICOS.ANO = VI_DETALLE_VIATICOS.ANO AND VI_VIATICOS.TIPO_VIATICO = VI_DETALLE_VIATICOS.TIPO_VIATICO AND VI_VIATICOS.CODSOLICITUD = VI_DETALLE_VIATICOS.NUMERO WHERE VI_VIATICOS.COMPANIA = :COMPANIA AND VI_VIATICOS.ANO = :ANO AND VI_DETALLE_VIATICOS.TERCERO = :CODIGOTERCERO AND VI_VIATICOS.VALORTOTALVIATICO - VI_VIATICOS.VALORABONADO &gt; 0 AND VI_VIATICOS.APROBADO NOT IN(0)) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODSOLICITUD":"$CODSOLICITUD(type:long)","TERCERO":"$TERCERO","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOTERCERO" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viviaticos/solicitudesseguntercero/pag">
		<call-query href="getViviaticosPagSolicitudesSegunTerceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOTERCERO" query-param="CODIGOTERCERO"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViviaticosNumSolicitudesSegunTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT VI_VIATICOS.CODSOLICITUD, VI_DETALLE_VIATICOS.TERCERO,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM VI_VIATICOS INNER JOIN VI_DETALLE_VIATICOS ON VI_VIATICOS.COMPANIA = VI_DETALLE_VIATICOS.COMPANIA AND VI_VIATICOS.ANO = VI_DETALLE_VIATICOS.ANO AND VI_VIATICOS.TIPO_VIATICO = VI_DETALLE_VIATICOS.TIPO_VIATICO AND VI_VIATICOS.CODSOLICITUD = VI_DETALLE_VIATICOS.NUMERO WHERE VI_VIATICOS.COMPANIA = :COMPANIA AND VI_VIATICOS.ANO = :ANO AND VI_DETALLE_VIATICOS.TERCERO = :CODIGOTERCERO AND VI_VIATICOS.VALORTOTALVIATICO - VI_VIATICOS.VALORABONADO &gt; 0 AND VI_VIATICOS.APROBADO NOT IN(0)) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOTERCERO" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viviaticos/solicitudesseguntercero/num">
		<call-query href="getViviaticosNumSolicitudesSegunTerceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOTERCERO" query-param="CODIGOTERCERO"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getViviaticosPagSinAprobarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD, VI_VIATICOS.NUMSOLICITUD,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBRETERCERO,(CASE VI_VIATICOS.APROBADO WHEN 0 THEN 'false' ELSE 'true' END) APROBADO FROM VI_VIATICOS LEFT JOIN DEPENDENCIA_RESPONSABLE ON VI_VIATICOS.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND VI_VIATICOS.TERCERO = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND VI_VIATICOS.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA =:COMPANIA AND VI_VIATICOS.APROBADO IN 0) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END) LIKE UPPER(CONCAT(:CODSOLICITUD, '%')) AND (CASE WHEN NUMSOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMSOLICITUD) END) LIKE UPPER(CONCAT(:NUMSOLICITUD, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN APROBADO IS NULL THEN ' ' ELSE UPPER(APROBADO) END) LIKE UPPER(CONCAT(:APROBADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_VIATICO":"$TIPO_VIATICO","CODSOLICITUD":"$CODSOLICITUD(type:long)","NUMSOLICITUD":"$NUMSOLICITUD(type:long)","FECHA":"$FECHA","NOMBRETERCERO":"$NOMBRETERCERO","APROBADO":"$APROBADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="NUMSOLICITUD" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="APROBADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viviaticos/sinaprobar/pag">
		<call-query href="getViviaticosPagSinAprobarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="NUMSOLICITUD" query-param="NUMSOLICITUD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="APROBADO" query-param="APROBADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViviaticosNumSinAprobarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD, VI_VIATICOS.NUMSOLICITUD,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBRETERCERO,(CASE VI_VIATICOS.APROBADO WHEN 0 THEN 'false' ELSE 'true' END) APROBADO FROM VI_VIATICOS LEFT JOIN DEPENDENCIA_RESPONSABLE ON VI_VIATICOS.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND VI_VIATICOS.TERCERO = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND VI_VIATICOS.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA =:COMPANIA AND VI_VIATICOS.APROBADO IN 0) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END) LIKE UPPER(CONCAT(:CODSOLICITUD, '%')) AND (CASE WHEN NUMSOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMSOLICITUD) END) LIKE UPPER(CONCAT(:NUMSOLICITUD, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN APROBADO IS NULL THEN ' ' ELSE UPPER(APROBADO) END) LIKE UPPER(CONCAT(:APROBADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="NUMSOLICITUD" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="APROBADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viviaticos/sinaprobar/num">
		<call-query href="getViviaticosNumSinAprobarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="NUMSOLICITUD" query-param="NUMSOLICITUD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="APROBADO" query-param="APROBADO"/>

		</call-query>
	</resource>
	<query id="updateViviaticosAprobacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_VIATICOS SET APROBADO    = :APROBADO,   DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY   = :MODIFIED_BY WHERE COMPANIA  = :KEY_COMPANIA AND ANO         = :KEY_ANO AND TIPO_VIATICO= :KEY_TIPO_VIATICO AND CODSOLICITUD= :KEY_CODSOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="APROBADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_CODSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="viviaticos/aprobacion">
		<call-query href="updateViviaticosAprobacion">
			<with-param name="APROBADO" query-param="APROBADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_VIATICO" query-param="KEY_TIPO_VIATICO"/>
			<with-param name="KEY_CODSOLICITUD" query-param="KEY_CODSOLICITUD"/>

		</call-query>
	</resource>
	<query id="updateViviaticosTotalViaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_VIATICOS SET VALORTOTALVIATICO = :TOTAL,   DATE_MODIFIED       = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY         = :MODIFIED_BY WHERE COMPANIA        = :KEY_COMPANIA AND ANO               = :KEY_ANO AND TIPO_VIATICO      = :KEY_TIPO_VIATICO AND CODSOLICITUD      = :KEY_CODSOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_CODSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="viviaticos/totalviaticos">
		<call-query href="updateViviaticosTotalViaticos">
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_VIATICO" query-param="KEY_TIPO_VIATICO"/>
			<with-param name="KEY_CODSOLICITUD" query-param="KEY_CODSOLICITUD"/>

		</call-query>
	</resource>
	<query id="getViviaticosCodigosolicitudPorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODSOLICITUD  FROM VI_VIATICOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY CODSOLICITUD DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODSOLICITUD":"$CODSOLICITUD(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viviaticos/codigosolicitudporanio">
		<call-query href="getViviaticosCodigosolicitudPorAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getViviaticosPagAprobacionDeComisionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD , VI_VIATICOS.TERCERO , TERCERO.NOMBRE NOMBRETERCERO, VI_VIATICOS.OBJETO ,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM VI_VIATICOS INNER JOIN TERCERO ON VI_VIATICOS.COMPANIA = TERCERO.COMPANIA AND VI_VIATICOS.TERCERO = TERCERO.NIT AND VI_VIATICOS.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA = :COMPANIA AND VI_VIATICOS.DEPENDENCIA = :DEPENDENCIA AND VI_VIATICOS.ESTADO IN ('P')) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_VIATICO":"$TIPO_VIATICO","CODSOLICITUD":"$CODSOLICITUD(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","OBJETO":"$OBJETO","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viviaticos/aprobaciondecomision/pag">
		<call-query href="getViviaticosPagAprobacionDeComisionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViviaticosNumAprobacionDeComisionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD , VI_VIATICOS.TERCERO , TERCERO.NOMBRE NOMBRETERCERO, VI_VIATICOS.OBJETO ,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM VI_VIATICOS INNER JOIN TERCERO ON VI_VIATICOS.COMPANIA = TERCERO.COMPANIA AND VI_VIATICOS.TERCERO = TERCERO.NIT AND VI_VIATICOS.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA = :COMPANIA AND VI_VIATICOS.DEPENDENCIA = :DEPENDENCIA AND VI_VIATICOS.ESTADO IN ('P')) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viviaticos/aprobaciondecomision/num">
		<call-query href="getViviaticosNumAprobacionDeComisionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
