	<query id="getViviaticosPagSolicitudDeTiqueteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD , VI_VIATICOS.TERCERO , TERCERO.NOMBRE NOMBRETERCERO, VI_VIATICOS.OBJETO ,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CASE WHEN VI_VIATICOS.ESTADO IN ('P') THEN 'Pendiente' ELSE CASE WHEN VI_VIATICOS.ESTADO IN ('A') THEN 'Aprobado' ELSE CASE WHEN VI_VIATICOS.ESTADO IN ('N') THEN 'No Aprobado' ELSE CASE WHEN VI_VIATICOS.ESTADO IN ('C') THEN 'Cancelado' END END END END ESTADO  FROM VI_VIATICOS INNER JOIN TERCERO ON VI_VIATICOS.COMPANIA = TERCERO.COMPANIA AND VI_VIATICOS.TERCERO = TERCERO.NIT AND VI_VIATICOS.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_VIATICO":"$TIPO_VIATICO","CODSOLICITUD":"$CODSOLICITUD(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","OBJETO":"$OBJETO","FECHA":"$FECHA","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viviaticos/solicituddetiquete/pag">
		<call-query href="getViviaticosPagSolicitudDeTiqueteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViviaticosNumSolicitudDeTiqueteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD , VI_VIATICOS.TERCERO , TERCERO.NOMBRE NOMBRETERCERO, VI_VIATICOS.OBJETO ,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CASE WHEN VI_VIATICOS.ESTADO IN ('P') THEN 'Pendiente' ELSE CASE WHEN VI_VIATICOS.ESTADO IN ('A') THEN 'Aprobado' ELSE CASE WHEN VI_VIATICOS.ESTADO IN ('N') THEN 'No Aprobado' ELSE CASE WHEN VI_VIATICOS.ESTADO IN ('C') THEN 'Cancelado' END END END END ESTADO  FROM VI_VIATICOS INNER JOIN TERCERO ON VI_VIATICOS.COMPANIA = TERCERO.COMPANIA AND VI_VIATICOS.TERCERO = TERCERO.NIT AND VI_VIATICOS.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viviaticos/solicituddetiquete/num">
		<call-query href="getViviaticosNumSolicitudDeTiqueteQuery">
