		</call-query>
	</resource>
	<query id="getViviaticosNumPendienteslegalizarautoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD, VI_VIATICOS.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, VI_VIATICOS.OBJETO,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, OBSERVACION_LEGALIZACION,(CASE LEGALIZADO_PLAZO WHEN 0 THEN 'false' ELSE 'true' END) LEGALIZADO_PLAZO, ESTADO_LEGALIZACION, CASE ESTADO_LEGALIZACION WHEN 'P' THEN 'Pendiente' WHEN 'A' THEN 'Aprobado' WHEN 'N' THEN 'No Aprobado' ELSE '' END ESTADO_LEGALIZACION1  FROM VI_VIATICOS INNER JOIN TERCERO ON VI_VIATICOS.COMPANIA = TERCERO.COMPANIA AND VI_VIATICOS.TERCERO = TERCERO.NIT AND VI_VIATICOS.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA =:COMPANIA AND VI_VIATICOS.DEPENDENCIA =:DEPENDENCIA AND VI_VIATICOS.ESTADO IN ('A') AND VI_VIATICOS.ESTADO_LEGALIZACION IN ('P')) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER( '%' || :TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN OBSERVACION_LEGALIZACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION_LEGALIZACION) END)  LIKE UPPER( '%' || :OBSERVACION_LEGALIZACION || '%')  AND (CASE WHEN LEGALIZADO_PLAZO IS NULL THEN ' ' ELSE UPPER(LEGALIZADO_PLAZO) END)  LIKE UPPER( '%' || :LEGALIZADO_PLAZO || '%')  AND (CASE WHEN ESTADO_LEGALIZACION1 IS NULL THEN ' ' ELSE UPPER(ESTADO_LEGALIZACION1) END)  LIKE UPPER( '%' || :ESTADO_LEGALIZACION1 || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACION_LEGALIZACION" sqlType="STRING"/>
		<param name="LEGALIZADO_PLAZO" sqlType="STRING"/>
		<param name="ESTADO_LEGALIZACION1" sqlType="STRING"/>

	</query>
