	<query id="updateViviaticosEstadoyobjetoauto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_VIATICOS SET ESTADO=:ESTADO, OBSERVACION_APROB=:OBSERVACION_APROB, FECHA_APROBACION=TO_DATE(:FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VI_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_VIATICOS.ANO= :KEY_ANO AND VI_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_VIATICOS.CODSOLICITUD= :KEY_CODSOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="OBSERVACION_APROB" sqlType="STRING"/>
		<param name="FECHA_APROBACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_CODSOLICITUD" sqlType="STRING"/>

	</query>
