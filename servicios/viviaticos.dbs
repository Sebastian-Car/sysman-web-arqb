FECHA_APROBA_LEGA,'DD/MM/YYYY HH24:MI:SS'), :VALOR_VIATICO_LEGALIZADO, :VALOR_TRANSPORTE_LEGALIZADO, :VALOR_REEMBOLSADO, TO_DATE(:FECHA_REEMBOLSO,'DD/MM/YYYY HH24:MI:SS'), :VALOR_TRANSPORTE_REEMBOLSO, TO_DATE(:FECHA_TRANS_REEMBOLSO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_GRABACION_SIIF,'DD/MM/YYYY HH24:MI:SS'), :CIUDAD_EXPE, :DEPARTAMENTO_EXPE, :PAIS_EXPE, TO_DATE(:FECHA_AUT_FACTURA,'DD/MM/YYYY HH24:MI:SS'), :NUMERO_RADICADO_AUTO, TO_DATE(:FECHA_LEGALIZACION,'DD/MM/YYYY HH24:MI:SS'), :RESUMEN_ACTIVIDADES, :LEGALIZADO_PLAZO, :NUMERO_OFICIO_MINTIC, TO_DATE(:FECHA_RADICADO_MINTIC,'DD/MM/YYYY HH24:MI:SS'), :ESTADO_MINTIC, TO_DATE(:FECHA_APROBA_MINTIC,'DD/MM/YYYY HH24:MI:SS'), :AVAL_COORDINADOR, :NUMERO_RESOLUCION_MINTIC, TO_DATE(:FECHA_RESOLUCION_MINTIC,'DD/MM/YYYY HH24:MI:SS'), :ZONA_EXTERIOR, :DIAS_TRANSITO, :VALOR_TASA_CAMBIO, TO_DATE(:FECHA_TASA_CAMBIO,'DD/MM/YYYY HH24:MI:SS'), :VALOR_TOTAL_PESOS, :NRO_RADICADO_DOC_MINTIC, :OBSERVACION_APROB)</sql>
