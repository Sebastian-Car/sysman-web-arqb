	<query id="insertViviaticos" keyColumns="COMPANIA,ANO,TIPO_VIATICO,CODSOLICITUD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VI_VIATICOS (COMPANIA, ANO, TIPO_VIATICO, CODSOLICITUD, NUMSOLICITUD, NUMERO_RESOLUCION, FECHA, FECHAINICIO, FECHAFIN, PERNOCTA, VEHICULO, PLACA_VEHICULO, OBJETO, OBSERVACION, JUSTIFICACION, OBSERVACIONCOMITE, DEPENDENCIA, TVISITA, PAIS_DESTINO, DEPARTAMENTO_DESTINO, CIUDAD_DESTINO, APROBADO, SABADO, DOMINGO, FESTIVO, TRSNESPECIAL, NODIAS, TSOLICITUD, TERCERO, SUCURSAL, TIPO_CPTE_PPTAL, COMPROBANTE_PPTAL, TIPO_CPTE_CNT, COMPROBANTE_CNT, VALORTOTALVIATICO, VALORABONADO, SALDOTOTAL, ESCALAFON, ID_CATEGORIA, CREATED_BY, DATE_CREATED, PAIS_ORIGEN, DEPARTAMENTO_ORIGEN, CIUDAD_ORIGEN, COD_PERSONA, TCOMISION, VALOR_RESERVA_INICIAL, VALOR_TIQUETE_EMITIDO, NUMERO_LOCALIZADOR, ITINERARIO, NUMERO_RADICADO, FECHA_RADICADO, VALOR_FACTURA_TIQUETE, FECHA_FACTURA_TIQUETE, VALOR_DESCUENTO_AGENCIA, ESTADO, TIPOCOMISION, JEFE_DEPENDENCIA, FECHA_NACIMIENTO, BANCO, CTA_BANCARIA, TELEFONOS, CORREO_ELECTRONICO, OBSERVACION_SOLICITUD, SUCURSAL_JEFE, FECHA_AUT_SIIF_NACION, FECHA_COM_DESEMBOLSO_SIIF, FECHA_DESEMBOLSO_TRANSPORTE, NUMERO_COM_DESEMBOLSO_SIIF, NUMERO_COM_DESEM_TRANSPORTE, FECHA_APROBACION, SALARIO_COMISIONADO, CLASE_TRANSPORTE, DESCRIPCION_TRANS, VALOR_TRANSPORTE, DESTINO_CORRERIA, PAIS_REGRESO, DEPARTAMENTO_REGRESO, CIUDAD_REGRESO, HORA_SALIDA, HORA_REGRESO, NRO_RADICADO_DOC, FECHA_RADICADO_DOC, GENERA_VIATICOS, SOLICITA_TIQUETE, VALOR_DIARIO_COMISION, ESTADO_LEGALIZACION, OBSERVACION_LEGALIZACION, FECHA_APROBA_LEGA, VALOR_VIATICO_LEGALIZADO, VALOR_TRANSPORTE_LEGALIZADO, VALOR_REEMBOLSADO, FECHA_REEMBOLSO, VALOR_TRANSPORTE_REEMBOLSO, FECHA_TRANS_REEMBOLSO, FECHA_GRABACION_SIIF, CIUDAD_EXPE, DEPARTAMENTO_EXPE, PAIS_EXPE, FECHA_AUT_FACTURA, NUMERO_RADICADO_AUTO, FECHA_LEGALIZACION, RESUMEN_ACTIVIDADES, LEGALIZADO_PLAZO, NUMERO_OFICIO_MINTIC, FECHA_RADICADO_MINTIC, ESTADO_MINTIC, FECHA_APROBA_MINTIC, AVAL_COORDINADOR, NUMERO_RESOLUCION_MINTIC, FECHA_RESOLUCION_MINTIC, ZONA_EXTERIOR, DIAS_TRANSITO, VALOR_TASA_CAMBIO, FECHA_TASA_CAMBIO, VALOR_TOTAL_PESOS, NRO_RADI