		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_VIATICOS.COMPANIA, VI_VIATICOS.ANO, VI_VIATICOS.TIPO_VIATICO, VI_VIATICOS.CODSOLICITUD, VI_VIATICOS.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, VI_VIATICOS.OBJETO,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, VI_VIATICOS.ESTADO , CASE VI_VIATICOS.ESTADO WHEN 'P' THEN 'Pendiente' WHEN 'A' THEN 'Aprobado' WHEN 'N' THEN 'No Aprobado' WHEN 'C' THEN 'Cancelado' ELSE '' END ESTADO1 , OBSERVACION_APROB  FROM VI_VIATICOS INNER JOIN TERCERO ON VI_VIATICOS.COMPANIA = TERCERO.COMPANIA AND VI_VIATICOS.TERCERO = TERCERO.NIT AND VI_VIATICOS.SUCURSAL = TERCERO.SUCURSAL WHERE VI_VIATICOS.COMPANIA =:COMPANIA AND VI_VIATICOS.DEPENDENCIA =:DEPENDENCIA AND VI_VIATICOS.ESTADO IN ('P')) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO1 IS NULL THEN ' ' ELSE UPPER(ESTADO1) END)  LIKE UPPER( '%' || :ESTADO1 || '%')  AND (CASE WHEN OBSERVACION_APROB IS NULL THEN ' ' ELSE UPPER(OBSERVACION_APROB) END)  LIKE UPPER( '%' || :OBSERVACION_APROB || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_VIATICO":"$TIPO_VIATICO","CODSOLICITUD":"$CODSOLICITUD(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","OBJETO":"$OBJETO","FECHA":"$FECHA","ESTADO":"$ESTADO","ESTADO1":"$ESTADO1","OBSERVACION_APROB":"$OBSERVACION_APROB"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ESTADO1" sqlType="STRING"/>
		<param name="OBSERVACION_APROB" sqlType="STRING"/>
