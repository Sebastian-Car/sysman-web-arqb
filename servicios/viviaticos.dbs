			<with-param name="ESTADO_LEGALIZACION" query-param="ESTADO_LEGALIZACION"/>
			<with-param name="OBSERVACION_LEGALIZACION" query-param="OBSERVACION_LEGALIZACION"/>
			<with-param name="FECHA_APROBA_LEGA" query-param="FECHA_APROBA_LEGA"/>
			<with-param name="VALOR_VIATICO_LEGALIZADO" query-param="VALOR_VIATICO_LEGALIZADO"/>
			<with-param name="VALOR_TRANSPORTE_LEGALIZADO" query-param="VALOR_TRANSPORTE_LEGALIZADO"/>
			<with-param name="VALOR_REEMBOLSADO" query-param="VALOR_REEMBOLSADO"/>
			<with-param name="FECHA_REEMBOLSO" query-param="FECHA_REEMBOLSO"/>
			<with-param name="VALOR_TRANSPORTE_REEMBOLSO" query-param="VALOR_TRANSPORTE_REEMBOLSO"/>
			<with-param name="FECHA_TRANS_REEMBOLSO" query-param="FECHA_TRANS_REEMBOLSO"/>
			<with-param name="FECHA_GRABACION_SIIF" query-param="FECHA_GRABACION_SIIF"/>
			<with-param name="CIUDAD_EXPE" query-param="CIUDAD_EXPE"/>
			<with-param name="DEPARTAMENTO_EXPE" query-param="DEPARTAMENTO_EXPE"/>
			<with-param name="PAIS_EXPE" query-param="PAIS_EXPE"/>
			<with-param name="FECHA_AUT_FACTURA" query-param="FECHA_AUT_FACTURA"/>
			<with-param name="NUMERO_RADICADO_AUTO" query-param="NUMERO_RADICADO_AUTO"/>
			<with-param name="FECHA_LEGALIZACION" query-param="FECHA_LEGALIZACION"/>
			<with-param name="RESUMEN_ACTIVIDADES" query-param="RESUMEN_ACTIVIDADES"/>
			<with-param name="LEGALIZADO_PLAZO" query-param="LEGALIZADO_PLAZO"/>
			<with-param name="NUMERO_OFICIO_MINTIC" query-param="NUMERO_OFICIO_MINTIC"/>
			<with-param name="FECHA_RADICADO_MINTIC" query-param="FECHA_RADICADO_MINTIC"/>
			<with-param name="ESTADO_MINTIC" query-param="ESTADO_MINTIC"/>
			<with-param name="FECHA_APROBA_MINTIC" query-param="FECHA_APROBA_MINTIC"/>
			<with-param name="AVAL_COORDINADOR" query-param="AVAL_COORDINADOR"/>
			<with-param name="NUMERO_RESOLUCION_MINTIC" query-param="NUMERO_RESOLUCION_MINTIC"/>
			<with-param name="FECHA_RESOLUCION_MINTIC" query-param="FECHA_RESOLUCION_MINTIC"/>
			<with-param name="ZONA_EXTERIOR" query-param="ZONA_EXTERIOR"/>
			<with-param name="DIAS_TRANSITO" query-param="DIAS_TRANSITO"/>
			<with-param name="VALOR_TASA_CAMBIO" query-param="VALOR_TASA_CAMBIO"/>
			<with-param name="FECHA_TASA_CAMBIO" query-param="FECHA_TASA_CAMBIO"/>
			<with-param name="VALOR_TOTAL_PESOS" query-param="VALOR_TOTAL_PESOS"/>
			<with-param name="NRO_RADICADO_DOC_MINTIC" query-param="NRO_RADICADO_DOC_MINTIC"/>
			<with-param name="OBSERVACION_APROB" query-param="OBSERVACION_APROB"/>

		</call-query>
	</resource>
	<query id="deleteViviaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VI_VIATICOS WHERE VI_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_VIATICOS.ANO= :KEY_ANO AND VI_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_VIATICOS.CODSOLICITUD= :KEY_CODSOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_CODSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="viviaticos">
		<call-query href="deleteViviaticos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_VIATICO" query-param="KEY_TIPO_VIATICO"/>
			<with-param name="KEY_CODSOLICITUD" query-param="KEY_CODSOLICITUD"/>

		</call-query>
	</resource>
	<query id="getViviaticosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO , TIPO_VIATICO , CODSOLICITUD , NUMSOLICITUD , OBSERVACION ,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM VI_VIATICOS WHERE COMPANIA = :COMPANIA AND ESTADO NOT IN ('A','C','N') ORDER BY CODSOLICITUD, NUMSOLICITUD) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN NUMSOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMSOLICITUD) END)  LIKE UPPER(:NUMSOLICITUD || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_VIATICO":"$TIPO_VIATICO","CODSOLICITUD":"$CODSOLICITUD(type:long)","NUMSOLICITUD":"$NUMSOLICITUD(type:long)","OBSERVACION":"$OBSERVACION","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="NUMSOLICITUD" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viviaticos">
		<call-query href="getViviaticosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="NUMSOLICITUD" query-param="NUMSOLICITUD"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViviaticosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO , TIPO_VIATICO , CODSOLICITUD , NUMSOLICITUD , OBSERVACION ,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM VI_VIATICOS WHERE COMPANIA = :COMPANIA AND ESTADO NOT IN ('A','C','N') ORDER BY CODSOLICITUD, NUMSOLICITUD) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN NUMSOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMSOLICITUD) END)  LIKE UPPER(:NUMSOLICITUD || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>
		<param name="NUMSOLICITUD" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viviaticos/numero">
		<call-query href="getViviaticosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>
			<with-param name="NUMSOLICITUD" query-param="NUMSOLICITUD"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getViviaticosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VI_VIATICOS.COMPANIA , VI_VIATICOS.ANO , VI_VIATICOS.TIPO_VIATICO , VI_VIATICOS.CODSOLICITUD , VI_VIATICOS.NUMSOLICITUD , VI_VIATICOS.NUMERO_RESOLUCION ,(TO_CHAR(VI_VIATICOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(VI_VIATICOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(VI_VIATICOS.FECHAFIN,'DD/MM/YYYY HH24:MI:SS')) FECHAFIN,(CASE VI_VIATICOS.PERNOCTA WHEN 0 THEN 'false' ELSE 'true' END) PERNOCTA,(CASE VI_VIATICOS.VEHICULO WHEN 0 THEN 'false' ELSE 'true' END) VEHICULO, VI_VIATICOS.PLACA_VEHICULO , VI_VIATICOS.OBJETO , VI_VIATICOS.OBSERVACION , VI_VIATICOS.JUSTIFICACION , VI_VIATICOS.OBSERVACIONCOMITE , VI_VIATICOS.DEPENDENCIA , DP.NOMBRE NOMBREDEPENDENCIA, VI_VIATICOS.TVISITA , VI_VIATICOS.PAIS_DESTINO , VI_VIATICOS.DEPARTAMENTO_DESTINO , VI_VIATICOS.CIUDAD_DESTINO ,(CASE VI_VIATICOS.APROBADO WHEN 0 THEN 'false' ELSE 'true' END) APROBADO,(CASE VI_VIATICOS.SABADO WHEN 0 THEN 'false' ELSE 'true' END) SABADO,(CASE VI_VIATICOS.DOMINGO WHEN 0 THEN 'false' ELSE 'true' END) DOMINGO,(CASE VI_VIATICOS.FESTIVO WHEN 0 THEN 'false' ELSE 'true' END) FESTIVO,(CASE VI_VIATICOS.TRSNESPECIAL WHEN 0 THEN 'false' ELSE 'true' END) TRSNESPECIAL, VI_VIATICOS.NODIAS , VI_VIATICOS.TSOLICITUD , VI_VIATICOS.TERCERO , T.NOMBRE NOMBRETERCERO, VI_VIATICOS.SUCURSAL , VI_VIATICOS.TIPO_CPTE_PPTAL , VI_VIATICOS.COMPROBANTE_PPTAL , VI_VIATICOS.TIPO_CPTE_CNT , VI_VIATICOS.COMPROBANTE_CNT , VI_VIATICOS.VALORTOTALVIATICO , VI_VIATICOS.VALORABONADO , VI_VIATICOS.SALDOTOTAL , VI_VIATICOS.ESCALAFON, VI_VIATICOS.ID_CATEGORIA, VI_VIATICOS.CREATED_BY ,(TO_CHAR(VI_VIATICOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VI_VIATICOS.MODIFIED_BY ,(TO_CHAR(VI_VIATICOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, VI_VIATICOS.PAIS_ORIGEN , VI_VIATICOS.DEPARTAMENTO_ORIGEN , VI_VIATICOS.CIUDAD_ORIGEN , VI_VIATICOS.COD_PERSONA, VI_VIATICOS.TCOMISION, VI_VIATICOS.VALOR_RESERVA_INICIAL , VI_VIATICOS.VALOR_TIQUETE_EMITIDO , VI_VIATICOS.NUMERO_LOCALIZADOR , VI_VIATICOS.ITINERARIO , VI_VIATICOS.NUMERO_RADICADO ,(TO_CHAR(VI_VIATICOS.FECHA_RADICADO,'DD/MM/YYYY HH24:MI:SS')) FECHA_RADICADO, VI_VIATICOS.VALOR_FACTURA_TIQUETE ,(TO_CHAR(VI_VIATICOS.FECHA_FACTURA_TIQUETE,'DD/MM/YYYY HH24:MI:SS')) FECHA_FACTURA_TIQUETE, VI_VIATICOS.VALOR_DESCUENTO_AGENCIA , VI_VIATICOS.ESTADO , VI_VIATICOS.TIPOCOMISION , VI_VIATICOS.JEFE_DEPENDENCIA , VI_VIATICOS.SUCURSAL_JEFE,(TO_CHAR(VI_VIATICOS.FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_APROBACION, TT.NOMBRE NOMBRERESPONSABLE,(TO_CHAR(VI_VIATICOS.FECHA_NACIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_NACIMIENTO, VI_VIATICOS.BANCO, B.NOMBREBANCO, VI_VIATICOS.CTA_BANCARIA, VI_VIATICOS.TELEFONOS, VI_VIATICOS.CORREO_ELECTRONICO, VI_VIATICOS.OBSERVACION_SOLICITUD,(TO_CHAR(VI_VIATICOS.FECHA_AUT_SIIF_NACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_AUT_SIIF_NACION,(TO_CHAR(VI_VIATICOS.FECHA_COM_DESEMBOLSO_SIIF,'DD/MM/YYYY HH24:MI:SS')) FECHA_COM_DESEMBOLSO_SIIF,(TO_CHAR(VI_VIATICOS.FECHA_DESEMBOLSO_TRANSPORTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_DESEMBOLSO_TRANSPORTE, VI_VIATICOS.NUMERO_COM_DESEMBOLSO_SIIF , VI_VIATICOS.NUMERO_COM_DESEM_TRANSPORTE, VI_VIATICOS.SALARIO_COMISIONADO, VI_VIATICOS.CLASE_TRANSPORTE, CT.DESCRIPCION NOMBRECLASETRANSPORTE, VI_VIATICOS.DESCRIPCION_TRANS, VI_VIATICOS.VALOR_TRANSPORTE , VI_VIATICOS.DESTINO_CORRERIA, VI_VIATICOS.PAIS_REGRESO, VI_VIATICOS.DEPARTAMENTO_REGRESO, VI_VIATICOS.CIUDAD_REGRESO,(TO_CHAR(VI_VIATICOS.HORA_SALIDA,'DD/MM/YYYY HH24:MI:SS')) HORA_SALIDA,(TO_CHAR(VI_VIATICOS.HORA_REGRESO,'DD/MM/YYYY HH24:MI:SS')) HORA_REGRESO, VI_VIATICOS.NRO_RADICADO_DOC,(TO_CHAR(VI_VIATICOS.FECHA_RADICADO_DOC,'DD/MM/YYYY HH24:MI:SS')) FECHA_RADICADO_DOC,(CASE VI_VIATICOS.GENERA_VIATICOS WHEN 0 THEN 'false' ELSE 'true' END) GENERA_VIATICOS,(CASE VI_VIATICOS.SOLICITA_TIQUETE WHEN 0 THEN 'false' ELSE 'true' END) SOLICITA_TIQUETE, VI_VIATICOS.VALOR_DIARIO_COMISION, VI_VIATICOS.ESTADO_LEGALIZACION, VI_VIATICOS.OBSERVACION_LEGALIZACION ,(TO_CHAR(VI_VIATICOS.FECHA_APROBA_LEGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_APROBA_LEGA, VI_VIATICOS.VALOR_VIATICO_LEGALIZADO, VI_VIATICOS.VALOR_TRANSPORTE_LEGALIZADO, VI_VIATICOS.VALOR_REEMBOLSADO,(TO_CHAR(VI_VIATICOS.FECHA_REEMBOLSO,'DD/MM/YYYY HH24:MI:SS')) FECHA_REEMBOLSO, VI_VIATICOS.VALOR_TRANSPORTE_REEMBOLSO,(TO_CHAR(VI_VIATICOS.FECHA_TRANS_REEMBOLSO,'DD/MM/YYYY HH24:MI:SS')) FECHA_TRANS_REEMBOLSO,(TO_CHAR(VI_VIATICOS.FECHA_GRABACION_SIIF,'DD/MM/YYYY HH24:MI:SS')) FECHA_GRABACION_SIIF, VI_VIATICOS.CIUDAD_EXPE, VI_VIATICOS.DEPARTAMENTO_EXPE, VI_VIATICOS.PAIS_EXPE, C.NOMBRE NOMBRE_EXPE,(TO_CHAR(VI_VIATICOS.FECHA_AUT_FACTURA,'DD/MM/YYYY HH24:MI:SS')) FECHA_AUT_FACTURA, VI_VIATICOS.NUMERO_RADICADO_AUTO,(TO_CHAR(VI_VIATICOS.FECHA_LEGALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_LEGALIZACION, VI_VIATICOS.RESUMEN_ACTIVIDADES ,(CASE VI_VIATICOS.LEGALIZADO_PLAZO WHEN 0 THEN 'false' ELSE 'true' END) LEGALIZADO_PLAZO, VI_VIATICOS.NUMERO_OFICIO_MINTIC,(TO_CHAR(VI_VIATICOS.FECHA_RADICADO_MINTIC,'DD/MM/YYYY HH24:MI:SS')) FECHA_RADICADO_MINTIC, VI_VIATICOS.ESTADO_MINTIC ,(TO_CHAR(VI_VIATICOS.FECHA_APROBA_MINTIC,'DD/MM/YYYY HH24:MI:SS')) FECHA_APROBA_MINTIC, VI_VIATICOS.AVAL_COORDINADOR, VI_VIATICOS.NUMERO_RESOLUCION_MINTIC,(TO_CHAR(VI_VIATICOS.FECHA_RESOLUCION_MINTIC,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION_MINTIC, VI_VIATICOS.ZONA_EXTERIOR, VI_VIATICOS.DIAS_TRANSITO, VI_VIATICOS.VALOR_TASA_CAMBIO,(TO_CHAR(VI_VIATICOS.FECHA_TASA_CAMBIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_TASA_CAMBIO, VI_VIATICOS.VALOR_TOTAL_PESOS, VI_VIATICOS.NRO_RADICADO_DOC_MINTIC, VI_VIATICOS.OBSERVACION_APROB  FROM VI_VIATICOS INNER JOIN TERCERO T ON VI_VIATICOS.COMPANIA = T.COMPANIA AND VI_VIATICOS.TERCERO = T.NIT AND VI_VIATICOS.SUCURSAL = T.SUCURSAL INNER JOIN DEPENDENCIA DP ON VI_VIATICOS.COMPANIA = DP.COMPANIA AND VI_VIATICOS.DEPENDENCIA = DP.CODIGO INNER JOIN DEPENDENCIA_RESPONSABLE DPR ON VI_VIATICOS.COMPANIA = DPR.COMPANIA AND VI_VIATICOS.DEPENDENCIA= DPR.DEPENDENCIA AND VI_VIATICOS.JEFE_DEPENDENCIA = DPR.RESPONSABLE INNER JOIN RESPONSABLE R ON R.COMPANIA = DPR.COMPANIA AND R.CEDULA= DPR.RESPONSABLE AND R.SUCURSAL = DPR.SUCURSAL INNER JOIN TERCERO TT ON R.COMPANIA = TT.COMPANIA AND R.CEDULA= TT.NIT AND R.SUCURSAL = TT.SUCURSAL LEFT JOIN BANCO B ON B.COMPANIA = VI_VIATICOS.COMPANIA AND B.BANCO= VI_VIATICOS.BANCO LEFT JOIN VI_CLASE_TRANSPORTE CT ON CT.COMPANIA = VI_VIATICOS.COMPANIA AND CT.CODIGO = VI_VIATICOS.CLASE_TRANSPORTE LEFT JOIN CIUDAD C ON VI_VIATICOS.CIUDAD_EXPE = C.CODIGO AND VI_VIATICOS.DEPARTAMENTO_EXPE = C.DEPARTAMENTO AND VI_VIATICOS.PAIS_EXPE = C.PAIS WHERE VI_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_VIATICOS.ANO= :KEY_ANO AND VI_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_VIATICOS.CODSOLICITUD= :KEY_CODSOLICITUD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_VIATICO":"$TIPO_VIATICO","CODSOLICITUD":"$CODSOLICITUD(type:long)","NUMSOLICITUD":"$NUMSOLICITUD(type:long)","NUMERO_RESOLUCION":"$NUMERO_RESOLUCION","FECHA":"$FECHA","FECHAINICIO":"$FECHAINICIO","FECHAFIN":"$FECHAFIN","PERNOCTA":"$PERNOCTA(type:boolean)","VEHICULO":"$VEHICULO(type:boolean)","PLACA_VEHICULO":"$PLACA_VEHICULO","OBJETO":"$OBJETO","OBSERVACION":"$OBSERVACION","JUSTIFICACION":"$JUSTIFICACION","OBSERVACIONCOMITE":"$OBSERVACIONCOMITE","DEPENDENCIA":"$DEPENDENCIA","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","TVISITA":"$TVISITA","PAIS_DESTINO":"$PAIS_DESTINO","DEPARTAMENTO_DESTINO":"$DEPARTAMENTO_DESTINO","CIUDAD_DESTINO":"$CIUDAD_DESTINO","APROBADO":"$APROBADO(type:boolean)","SABADO":"$SABADO(type:boolean)","DOMINGO":"$DOMINGO(type:boolean)","FESTIVO":"$FESTIVO(type:boolean)","TRSNESPECIAL":"$TRSNESPECIAL(type:boolean)","NODIAS":"$NODIAS","TSOLICITUD":"$TSOLICITUD","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","SUCURSAL":"$SUCURSAL","TIPO_CPTE_PPTAL":"$TIPO_CPTE_PPTAL","COMPROBANTE_PPTAL":"$COMPROBANTE_PPTAL(type:long)","TIPO_CPTE_CNT":"$TIPO_CPTE_CNT","COMPROBANTE_CNT":"$COMPROBANTE_CNT(type:long)","VALORTOTALVIATICO":"$VALORTOTALVIATICO","VALORABONADO":"$VALORABONADO","SALDOTOTAL":"$SALDOTOTAL","ESCALAFON":"$ESCALAFON","ID_CATEGORIA":"$ID_CATEGORIA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","PAIS_ORIGEN":"$PAIS_ORIGEN","DEPARTAMENTO_ORIGEN":"$DEPARTAMENTO_ORIGEN","CIUDAD_ORIGEN":"$CIUDAD_ORIGEN","COD_PERSONA":"$COD_PERSONA","TCOMISION":"$TCOMISION","VALOR_RESERVA_INICIAL":"$VALOR_RESERVA_INICIAL","VALOR_TIQUETE_EMITIDO":"$VALOR_TIQUETE_EMITIDO","NUMERO_LOCALIZADOR":"$NUMERO_LOCALIZADOR","ITINERARIO":"$ITINERARIO","NUMERO_RADICADO":"$NUMERO_RADICADO","FECHA_RADICADO":"$FECHA_RADICADO","VALOR_FACTURA_TIQUETE":"$VALOR_FACTURA_TIQUETE","FECHA_FACTURA_TIQUETE":"$FECHA_FACTURA_TIQUETE","VALOR_DESCUENTO_AGENCIA":"$VALOR_DESCUENTO_AGENCIA","ESTADO":"$ESTADO","TIPOCOMISION":"$TIPOCOMISION","JEFE_DEPENDENCIA":"$JEFE_DEPENDENCIA","SUCURSAL_JEFE":"$SUCURSAL_JEFE","FECHA_APROBACION":"$FECHA_APROBACION","NOMBRERESPONSABLE":"$NOMBRERESPONSABLE","FECHA_NACIMIENTO":"$FECHA_NACIMIENTO","BANCO":"$BANCO","NOMBREBANCO":"$NOMBREBANCO","CTA_BANCARIA":"$CTA_BANCARIA","TELEFONOS":"$TELEFONOS","CORREO_ELECTRONICO":"$CORREO_ELECTRONICO","OBSERVACION_SOLICITUD":"$OBSERVACION_SOLICITUD","FECHA_AUT_SIIF_NACION":"$FECHA_AUT_SIIF_NACION","FECHA_COM_DESEMBOLSO_SIIF":"$FECHA_COM_DESEMBOLSO_SIIF","FECHA_DESEMBOLSO_TRANSPORTE":"$FECHA_DESEMBOLSO_TRANSPORTE","NUMERO_COM_DESEMBOLSO_SIIF":"$NUMERO_COM_DESEMBOLSO_SIIF","NUMERO_COM_DESEM_TRANSPORTE":"$NUMERO_COM_DESEM_TRANSPORTE","SALARIO_COMISIONADO":"$SALARIO_COMISIONADO","CLASE_TRANSPORTE":"$CLASE_TRANSPORTE","NOMBRECLASETRANSPORTE":"$NOMBRECLASETRANSPORTE","DESCRIPCION_TRANS":"$DESCRIPCION_TRANS","VALOR_TRANSPORTE":"$VALOR_TRANSPORTE","DESTINO_CORRERIA":"$DESTINO_CORRERIA","PAIS_REGRESO":"$PAIS_REGRESO","DEPARTAMENTO_REGRESO":"$DEPARTAMENTO_REGRESO","CIUDAD_REGRESO":"$CIUDAD_REGRESO","HORA_SALIDA":"$HORA_SALIDA","HORA_REGRESO":"$HORA_REGRESO","NRO_RADICADO_DOC":"$NRO_RADICADO_DOC","FECHA_RADICADO_DOC":"$FECHA_RADICADO_DOC","GENERA_VIATICOS":"$GENERA_VIATICOS(type:boolean)","SOLICITA_TIQUETE":"$SOLICITA_TIQUETE(type:boolean)","VALOR_DIARIO_COMISION":"$VALOR_DIARIO_COMISION","ESTADO_LEGALIZACION":"$ESTADO_LEGALIZACION","OBSERVACION_LEGALIZACION":"$OBSERVACION_LEGALIZACION","FECHA_APROBA_LEGA":"$FECHA_APROBA_LEGA","VALOR_VIATICO_LEGALIZADO":"$VALOR_VIATICO_LEGALIZADO","VALOR_TRANSPORTE_LEGALIZADO":"$VALOR_TRANSPORTE_LEGALIZADO","VALOR_REEMBOLSADO":"$VALOR_REEMBOLSADO","FECHA_REEMBOLSO":"$FECHA_REEMBOLSO","VALOR_TRANSPORTE_REEMBOLSO":"$VALOR_TRANSPORTE_REEMBOLSO","FECHA_TRANS_REEMBOLSO":"$FECHA_TRANS_REEMBOLSO","FECHA_GRABACION_SIIF":"$FECHA_GRABACION_SIIF","CIUDAD_EXPE":"$CIUDAD_EXPE","DEPARTAMENTO_EXPE":"$DEPARTAMENTO_EXPE","PAIS_EXPE":"$PAIS_EXPE","NOMBRE_EXPE":"$NOMBRE_EXPE","FECHA_AUT_FACTURA":"$FECHA_AUT_FACTURA","NUMERO_RADICADO_AUTO":"$NUMERO_RADICADO_AUTO","FECHA_LEGALIZACION":"$FECHA_LEGALIZACION","RESUMEN_ACTIVIDADES":"$RESUMEN_ACTIVIDADES","LEGALIZADO_PLAZO":"$LEGALIZADO_PLAZO(type:boolean)","NUMERO_OFICIO_MINTIC":"$NUMERO_OFICIO_MINTIC","FECHA_RADICADO_MINTIC":"$FECHA_RADICADO_MINTIC","ESTADO_MINTIC":"$ESTADO_MINTIC","FECHA_APROBA_MINTIC":"$FECHA_APROBA_MINTIC","AVAL_COORDINADOR":"$AVAL_COORDINADOR","NUMERO_RESOLUCION_MINTIC":"$NUMERO_RESOLUCION_MINTIC","FECHA_RESOLUCION_MINTIC":"$FECHA_RESOLUCION_MINTIC","ZONA_EXTERIOR":"$ZONA_EXTERIOR","DIAS_TRANSITO":"$DIAS_TRANSITO(type:integer)","VALOR_TASA_CAMBIO":"$VALOR_TASA_CAMBIO","FECHA_TASA_CAMBIO":"$FECHA_TASA_CAMBIO","VALOR_TOTAL_PESOS":"$VALOR_TOTAL_PESOS","NRO_RADICADO_DOC_MINTIC":"$NRO_RADICADO_DOC_MINTIC","OBSERVACION_APROB":"$OBSERVACION_APROB"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_CODSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viviaticos/data">
		<call-query href="getViviaticosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_VIATICO" query-param="KEY_TIPO_VIATICO"/>
			<with-param name="KEY_CODSOLICITUD" query-param="KEY_CODSOLICITUD"/>

		</call-query>
	</resource>
	<query id="updateViviaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_VIATICOS SET ANO=:ANO, TIPO_VIATICO=:TIPO_VIATICO, CODSOLICITUD=:CODSOLICITUD, NUMSOLICITUD=:NUMSOLICITUD, NUMERO_RESOLUCION=:NUMERO_RESOLUCION, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), FECHAINICIO=TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), FECHAFIN=TO_DATE(:FECHAFIN,'DD/MM/YYYY HH24:MI:SS'), PERNOCTA=:PERNOCTA, VEHICULO=:VEHICULO, PLACA_VEHICULO=:PLACA_VEHICULO, OBJETO=:OBJETO, OBSERVACION=:OBSERVACION, JUSTIFICACION=:JUSTIFICACION, OBSERVACIONCOMITE=:OBSERVACIONCOMITE, DEPENDENCIA=:DEPENDENCIA, TVISITA=:TVISITA, PAIS_DESTINO=:PAIS_DESTINO, DEPARTAMENTO_DESTINO=:DEPARTAMENTO_DESTINO, CIUDAD_DESTINO=:CIUDAD_DESTINO, APROBADO=:APROBADO, SABADO=:SABADO, DOMINGO=:DOMINGO, FESTIVO=:FESTIVO, TRSNESPECIAL=:TRSNESPECIAL, NODIAS=:NODIAS, TSOLICITUD=:TSOLICITUD, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, TIPO_CPTE_PPTAL=:TIPO_CPTE_PPTAL, COMPROBANTE_PPTAL=:COMPROBANTE_PPTAL, TIPO_CPTE_CNT=:TIPO_CPTE_CNT, COMPROBANTE_CNT=:COMPROBANTE_CNT, VALORTOTALVIATICO=:VALORTOTALVIATICO, VALORABONADO=:VALORABONADO, SALDOTOTAL=:SALDOTOTAL, ESCALAFON=:ESCALAFON, ID_CATEGORIA=:ID_CATEGORIA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), PAIS_ORIGEN=:PAIS_ORIGEN, DEPARTAMENTO_ORIGEN=:DEPARTAMENTO_ORIGEN, CIUDAD_ORIGEN=:CIUDAD_ORIGEN, COD_PERSONA=:COD_PERSONA, TCOMISION=:TCOMISION, VALOR_RESERVA_INICIAL=:VALOR_RESERVA_INICIAL, VALOR_TIQUETE_EMITIDO=:VALOR_TIQUETE_EMITIDO, NUMERO_LOCALIZADOR=:NUMERO_LOCALIZADOR, ITINERARIO=:ITINERARIO, NUMERO_RADICADO=:NUMERO_RADICADO, FECHA_RADICADO=TO_DATE(:FECHA_RADICADO,'DD/MM/YYYY HH24:MI:SS'), VALOR_FACTURA_TIQUETE=:VALOR_FACTURA_TIQUETE, FECHA_FACTURA_TIQUETE=TO_DATE(:FECHA_FACTURA_TIQUETE,'DD/MM/YYYY HH24:MI:SS'), VALOR_DESCUENTO_AGENCIA=:VALOR_DESCUENTO_AGENCIA, ESTADO=:ESTADO, TIPOCOMISION=:TIPOCOMISION, JEFE_DEPENDENCIA=:JEFE_DEPENDENCIA, FECHA_NACIMIENTO=TO_DATE(:FECHA_NACIMIENTO,'DD/MM/YYYY HH24:MI:SS'), BANCO=:BANCO, CTA_BANCARIA=:CTA_BANCARIA, TELEFONOS=:TELEFONOS, CORREO_ELECTRONICO=:CORREO_ELECTRONICO, OBSERVACION_SOLICITUD=:OBSERVACION_SOLICITUD, SUCURSAL_JEFE=:SUCURSAL_JEFE, FECHA_AUT_SIIF_NACION=TO_DATE(:FECHA_AUT_SIIF_NACION,'DD/MM/YYYY HH24:MI:SS'), FECHA_COM_DESEMBOLSO_SIIF=TO_DATE(:FECHA_COM_DESEMBOLSO_SIIF,'DD/MM/YYYY HH24:MI:SS'), FECHA_DESEMBOLSO_TRANSPORTE=TO_DATE(:FECHA_DESEMBOLSO_TRANSPORTE,'DD/MM/YYYY HH24:MI:SS'), NUMERO_COM_DESEMBOLSO_SIIF=:NUMERO_COM_DESEMBOLSO_SIIF, NUMERO_COM_DESEM_TRANSPORTE=:NUMERO_COM_DESEM_TRANSPORTE, FECHA_APROBACION=TO_DATE(:FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS'), SALARIO_COMISIONADO=:SALARIO_COMISIONADO, CLASE_TRANSPORTE=:CLASE_TRANSPORTE, DESCRIPCION_TRANS=:DESCRIPCION_TRANS, VALOR_TRANSPORTE=:VALOR_TRANSPORTE, DESTINO_CORRERIA=:DESTINO_CORRERIA, PAIS_REGRESO=:PAIS_REGRESO, DEPARTAMENTO_REGRESO=:DEPARTAMENTO_REGRESO, CIUDAD_REGRESO=:CIUDAD_REGRESO, HORA_SALIDA=TO_DATE(:HORA_SALIDA,'DD/MM/YYYY HH24:MI:SS'), HORA_REGRESO=TO_DATE(:HORA_REGRESO,'DD/MM/YYYY HH24:MI:SS'), NRO_RADICADO_DOC=:NRO_RADICADO_DOC, FECHA_RADICADO_DOC=TO_DATE(:FECHA_RADICADO_DOC,'DD/MM/YYYY HH24:MI:SS'), GENERA_VIATICOS=:GENERA_VIATICOS, SOLICITA_TIQUETE=:SOLICITA_TIQUETE, VALOR_DIARIO_COMISION=:VALOR_DIARIO_COMISION, ESTADO_LEGALIZACION=:ESTADO_LEGALIZACION, OBSERVACION_LEGALIZACION=:OBSERVACION_LEGALIZACION, FECHA_APROBA_LEGA=TO_DATE(:FECHA_APROBA_LEGA,'DD/MM/YYYY HH24:MI:SS'), VALOR_VIATICO_LEGALIZADO=:VALOR_VIATICO_LEGALIZADO, VALOR_TRANSPORTE_LEGALIZADO=:VALOR_TRANSPORTE_LEGALIZADO, VALOR_REEMBOLSADO=:VALOR_REEMBOLSADO, FECHA_REEMBOLSO=TO_DATE(:FECHA_REEMBOLSO,'DD/MM/YYYY HH24:MI:SS'), VALOR_TRANSPORTE_REEMBOLSO=:VALOR_TRANSPORTE_REEMBOLSO, FECHA_TRANS_REEMBOLSO=TO_DATE(:FECHA_TRANS_REEMBOLSO,'DD/MM/YYYY HH24:MI:SS'), FECHA_GRABACION_SIIF=TO_DATE(:FECHA_GRABACION_SIIF,'DD/MM/YYYY HH24:MI:SS'), CIUDAD_EXPE=:CIUDAD_EXPE, DEPARTAMENTO_EXPE=:DEPARTAMENTO_EXPE, PAIS_EXPE=:PAIS_EXPE, FECHA_AUT_FACTURA=TO_DATE(:FECHA_AUT_FACTURA,'DD/MM/YYYY HH24:MI:SS'), NUMERO_RADICADO_AUTO=:NUMERO_RADICADO_AUTO, FECHA_LEGALIZACION=TO_DATE(:FECHA_LEGALIZACION,'DD/MM/YYYY HH24:MI:SS'), RESUMEN_ACTIVIDADES=:RESUMEN_ACTIVIDADES, LEGALIZADO_PLAZO=:LEGALIZADO_PLAZO, NUMERO_OFICIO_MINTIC=:NUMERO_OFICIO_MINTIC, FECHA_RADICADO_MINTIC=TO_DATE(:FECHA_RADICADO_MINTIC,'DD/MM/YYYY HH24:MI:SS'), ESTADO_MINTIC=:ESTADO_MINTIC, FECHA_APROBA_MINTIC=TO_DATE(:FECHA_APROBA_MINTIC,'DD/MM/YYYY HH24:MI:SS'), AVAL_COORDINADOR=:AVAL_COORDINADOR, NUMERO_RESOLUCION_MINTIC=:NUMERO_RESOLUCION_MINTIC, FECHA_RESOLUCION_MINTIC=TO_DATE(:FECHA_RESOLUCION_MINTIC,'DD/MM/YYYY HH24:MI:SS'), ZONA_EXTERIOR=:ZONA_EXTERIOR, DIAS_TRANSITO=:DIAS_TRANSITO, VALOR_TASA_CAMBIO=:VALOR_TASA_CAMBIO, FECHA_TASA_CAMBIO=TO_DATE(:FECHA_TASA_CAMBIO,'DD/MM/YYYY HH24:MI:SS'), VALOR_TOTAL_PESOS=:VALOR_TOTAL_PESOS, NRO_RADICADO_DOC_MINTIC=:NRO_RADICADO_DOC_MINTIC, OBSERVACION_APROB=:OBSERVACION_APROB WHERE VI_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_VIATICOS.ANO= :KEY_ANO AND VI_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_VIATICOS.CODSOLICITUD= :KEY_CODSOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

