	<query id="updateViviaticosPendientesporautoservicio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_VIATICOS SET OBSERVACION_LEGALIZACION=:OBSERVACION_LEGALIZACION, LEGALIZADO_PLAZO=:LEGALIZADO_PLAZO, ESTADO_LEGALIZACION=:ESTADO_LEGALIZACION, FECHA_APROBA_LEGA=TO_DATE(:FECHA_APROBA_LEGA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VI_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_VIATICOS.ANO= :KEY_ANO AND VI_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_VIATICOS.CODSOLICITUD= :KEY_CODSOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="OBSERVACION_LEGALIZACION" sqlType="STRING"/>
		<param name="LEGALIZADO_PLAZO" sqlType="STRING"/>
		<param name="ESTADO_LEGALIZACION" sqlType="STRING"/>
		<param name="FECHA_APROBA_LEGA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_CODSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="viviaticos/pendientesporautoservicio">
		<call-query href="updateViviaticosPendientesporautoservicio">
			<with-param name="OBSERVACION_LEGALIZACION" query-param="OBSERVACION_LEGALIZACION"/>
			<with-param name="LEGALIZADO_PLAZO" query-param="LEGALIZADO_PLAZO"/>
			<with-param name="ESTADO_LEGALIZACION" query-param="ESTADO_LEGALIZACION"/>
			<with-param name="FECHA_APROBA_LEGA" query-param="FECHA_APROBA_LEGA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_VIATICO" query-param="KEY_TIPO_VIATICO"/>
			<with-param name="KEY_CODSOLICITUD" query-param="KEY_CODSOLICITUD"/>

		</call-query>
	</resource>

