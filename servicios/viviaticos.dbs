	<query id="getViviaticosPagSolicitudLegalizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, TIPO_VIATICO, CODSOLICITUD , NUMSOLICITUD, OBJETO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM VI_VIATICOS WHERE COMPANIA = :COMPANIA AND ESTADO IN ('A') ORDER BY CODSOLICITUD) WHERE (CASE WHEN CODSOLICITUD IS NULL THEN ' ' ELSE UPPER(CODSOLICITUD) END)  LIKE UPPER(:CODSOLICITUD || '%')  AND (CASE WHEN NUMSOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMSOLICITUD) END)  LIKE UPPER( '%' || :NUMSOLICITUD || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_VIATICO":"$TIPO_VIATICO","CODSOLICITUD":"$CODSOLICITUD(type:long)","NUMSOLICITUD":"$NUMSOLICITUD(type:long)","OBJETO":"$OBJETO","FECHA":"$FECHA"}]}}		</result>
