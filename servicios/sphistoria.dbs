<data name="sphistoria" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSphistoriaListarHistoriaFacturadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_HISTORIA.COMPANIA, SP_HISTORIA.CICLO, SP_HISTORIA.CODIGORUTA, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) NOMBRES, SP_HISTORIA.ANO, SP_HISTORIA.PERIODO, SP_HISTORIA.CODIGOINTERNO, SP_HISTORIA.USO, SP_HISTORIA.ESTRATO, SP_HISTORIA.LECTURA, SP_HISTORIA.BANCOPERPROCESO,(TO_CHAR(SP_HISTORIA.FECHAPAGOPERPROCESO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOPERPROCESO, SP_HISTORIA.PAQUETEPAGOPERPROCESO, TRIM(TO_CHAR(SP_HISTORIA.TOTFACTURAPERACTUAL,'$999,999,999,999,999,999.99') ) TOTFACTURAPERACTUAL, SP_HISTORIA.CONSUMO, SP_HISTORIA.CONSUMOALC, SP_HISTORIA.LECTURA1, SP_HISTORIA.TERCERIZADO, SP_HISTORIA.CONVENIOS, SP_HISTORIA.CONSUMOPROM,(CASE SP_HISTORIA.CONSUMOMANUAL WHEN 0 THEN 'false' ELSE 'true' END) CONSUMOMANUAL, CASE WHEN NVL(SP_HISTORIA.PAGOTERCERIZADO,0) = 0 THEN 'false' ELSE 'true' END PAGOTERCERIZADO, CASE WHEN NVL(SP_HISTORIA.PAGOCONVENIOS,0) = 0 THEN 'false' ELSE 'true' END PAGOCONVENIOS,(TO_CHAR(SP_HISTORIA.FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAEXPEDICION, SP_HISTORIA.INTERVALOFACT FROM SP_HISTORIA INNER JOIN SP_USUARIO ON SP_HISTORIA.COMPANIA = SP_USUARIO.COMPANIA AND SP_HISTORIA.CICLO = SP_USUARIO.CICLO AND SP_HISTORIA.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_HISTORIA.COMPANIA =:KEY_COMPANIA AND SP_HISTORIA.CICLO =:KEY_CICLO AND SP_HISTORIA.CODIGORUTA =:KEY_CODIGORUTA AND SP_HISTORIA.ANO =:KEY_ANO AND SP_HISTORIA.PERIODO =:KEY_PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","NOMBRES":"$NOMBRES","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CODIGOINTERNO":"$CODIGOINTERNO","USO":"$USO","ESTRATO":"$ESTRATO","LECTURA":"$LECTURA","BANCOPERPROCESO":"$BANCOPERPROCESO","FECHAPAGOPERPROCESO":"$FECHAPAGOPERPROCESO","PAQUETEPAGOPERPROCESO":"$PAQUETEPAGOPERPROCESO","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","CONSUMO":"$CONSUMO","CONSUMOALC":"$CONSUMOALC","LECTURA1":"$LECTURA1","TERCERIZADO":"$TERCERIZADO","CONVENIOS":"$CONVENIOS","CONSUMOPROM":"$CONSUMOPROM(type:integer)","CONSUMOMANUAL":"$CONSUMOMANUAL(type:boolean)","PAGOTERCERIZADO":"$PAGOTERCERIZADO","PAGOCONVENIOS":"$PAGOCONVENIOS","FECHAEXPEDICION":"$FECHAEXPEDICION","INTERVALOFACT":"$INTERVALOFACT"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoria/listarhistoriafacturado">
		<call-query href="getSphistoriaListarHistoriaFacturadoQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>

		</call-query>
	</resource>
	<query id="getSphistoriaPagListarHistorialPorCodigorutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, TOTFACTURAPERACTUAL  FROM SP_HISTORIA WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA ORDER BY ANO DESC , PERIODO DESC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN TOTFACTURAPERACTUAL IS NULL THEN ' ' ELSE UPPER(TOTFACTURAPERACTUAL) END)  LIKE UPPER(:TOTFACTURAPERACTUAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="TOTFACTURAPERACTUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sphistoria/listarhistorialporcodigoruta/pag">
		<call-query href="getSphistoriaPagListarHistorialPorCodigorutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="TOTFACTURAPERACTUAL" query-param="TOTFACTURAPERACTUAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSphistoriaNumListarHistorialPorCodigorutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, TOTFACTURAPERACTUAL  FROM SP_HISTORIA WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA ORDER BY ANO DESC , PERIODO DESC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN TOTFACTURAPERACTUAL IS NULL THEN ' ' ELSE UPPER(TOTFACTURAPERACTUAL) END)  LIKE UPPER( '%' || :TOTFACTURAPERACTUAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="TOTFACTURAPERACTUAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoria/listarhistorialporcodigoruta/num">
		<call-query href="getSphistoriaNumListarHistorialPorCodigorutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="TOTFACTURAPERACTUAL" query-param="TOTFACTURAPERACTUAL"/>

		</call-query>
	</resource>
	<query id="getSphistoriaHistoricoFacturadoPorCodigorutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  H.CONCEPTO,C.NOMBRE, H.VALOR  FROM ( SELECT COMPANIA, ANO, PERIODO, CONCEPTO, VALOR FROM SP_HISTORIA UNPIVOT ( VALOR FOR CONCEPTO IN ( C1 AS '1', C2 AS '2', C3 AS '3', C4 AS '4', C5 AS '5', C6 AS '6', C7 AS '7', C8 AS '8', C9 AS '9', C10 AS '10', C11 AS '11', C12 AS '12', C13 AS '13', C14 AS '14', C15 AS '15', C16 AS '16', C17 AS '17', C18 AS '18', C19 AS '19', C20 AS '20', C21 AS '21', C22 AS '22', C23 AS '23', C24 AS '24', C25 AS '25', C26 AS '26', C27 AS '27', C28 AS '28', C29 AS '29', C30 AS '30', C31 AS '31', C32 AS '32', C33 AS '33', C34 AS '34', C35 AS '35', C36 AS '36', C37 AS '37', C38 AS '38', C39 AS '39', C40 AS '40', C41 AS '41', C42 AS '42', C43 AS '43', C44 AS '44', C45 AS '45', C46 AS '46', C47 AS '47', C48 AS '48', C49 AS '49', C50 AS '50', C246 AS '246',C247 AS '247',C248 AS '248',C249 AS '249',C250 AS '250' ) ) WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND ANO = :ANO AND PERIODO = :PERIODO AND VALOR &lt;&gt; 0 ) H INNER JOIN SP_CONCEPTOS C ON H.COMPANIA = C.COMPANIA AND H.CONCEPTO = C.CODIGO ORDER BY H.ANO, H.PERIODO, TO_NUMBER(H.CONCEPTO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONCEPTO":"$CONCEPTO","NOMBRE":"$NOMBRE","VALOR":"$VALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoria/historicofacturadoporcodigoruta">
		<call-query href="getSphistoriaHistoricoFacturadoPorCodigorutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSphistoriaListadoNombrePeriodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT LISTAGG(CONCAT( '''', CONCAT(PERIODOA, '''')),', ') WITHIN GROUP( ORDER BY ANO,PERIODO ) LISTADO FROM ( SELECT DISTINCT PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(UN_COMPANIA =&gt; HISTORIA.COMPANIA,UN_ANO =&gt; HISTORIA.ANO,UN_PERIODO =&gt; HISTORIA .PERIODO,UN_FRECUENCIA =&gt; NULL) PERIODOA, ANO, PERIODO FROM SP_HISTORIA HISTORIA INNER JOIN SP_CONCEPTOS CONCEPTO ON HISTORIA.COMPANIA = CONCEPTO.COMPANIA WHERE HISTORIA.COMPANIA =:COMPANIA AND HISTORIA.CICLO =:CICLO AND HISTORIA.CODIGORUTA =:CODIGORUTA AND CONCAT(ANO , PERIODO) BETWEEN :PERIODO_INICIAL AND :PERIODO_FINAL AND ( CODIGO BETWEEN 1 AND 50 OR CODIGO BETWEEN 246 AND 250 ) ORDER BY ANO, PERIODO )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LISTADO":"$LISTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PERIODO_INICIAL" sqlType="STRING"/>
		<param name="PERIODO_FINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoria/listadonombreperiodos">
		<call-query href="getSphistoriaListadoNombrePeriodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="PERIODO_INICIAL" query-param="PERIODO_INICIAL"/>
			<with-param name="PERIODO_FINAL" query-param="PERIODO_FINAL"/>

		</call-query>
	</resource>

</data>