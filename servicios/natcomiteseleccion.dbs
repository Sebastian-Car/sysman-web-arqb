<data name="natcomiteseleccion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatcomiteseleccion" keyColumns="COMPANIA,NRO_CONVOCATORIA,NUMERO_DCTO,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_COMITE_SELECCION (COMPANIA, NRO_CONVOCATORIA, NUMERO_DCTO, SUCURSAL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NRO_CONVOCATORIA, :NUMERO_DCTO, :SUCURSAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natcomiteseleccion">
		<call-query href="insertNatcomiteseleccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteNatcomiteseleccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_COMITE_SELECCION WHERE NAT_COMITE_SELECCION.COMPANIA= :KEY_COMPANIA AND NAT_COMITE_SELECCION.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_COMITE_SELECCION.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_COMITE_SELECCION.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natcomiteseleccion">
		<call-query href="deleteNatcomiteseleccion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatcomiteseleccionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NAT_COMITE_SELECCION.COMPANIA, NAT_COMITE_SELECCION.SUCURSAL, NAT_COMITE_SELECCION.NRO_CONVOCATORIA, NAT_COMITE_SELECCION.NUMERO_DCTO, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',TERCERO.NOMBRE) ) ) ) NOMBRES FROM NAT_COMITE_SELECCION LEFT JOIN TERCERO ON NAT_COMITE_SELECCION.COMPANIA = TERCERO.COMPANIA AND NAT_COMITE_SELECCION.NUMERO_DCTO = TERCERO.NIT AND NAT_COMITE_SELECCION.SUCURSAL = TERCERO.SUCURSAL WHERE NAT_COMITE_SELECCION.COMPANIA =:COMPANIA AND NAT_COMITE_SELECCION.NRO_CONVOCATORIA =:CONVOCATORIA) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRES":"$NOMBRES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natcomiteseleccion">
		<call-query href="getNatcomiteseleccionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatcomiteseleccionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NAT_COMITE_SELECCION.COMPANIA, NAT_COMITE_SELECCION.SUCURSAL, NAT_COMITE_SELECCION.NRO_CONVOCATORIA, NAT_COMITE_SELECCION.NUMERO_DCTO, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',TERCERO.NOMBRE) ) ) ) NOMBRES FROM NAT_COMITE_SELECCION LEFT JOIN TERCERO ON NAT_COMITE_SELECCION.COMPANIA = TERCERO.COMPANIA AND NAT_COMITE_SELECCION.NUMERO_DCTO = TERCERO.NIT AND NAT_COMITE_SELECCION.SUCURSAL = TERCERO.SUCURSAL WHERE NAT_COMITE_SELECCION.COMPANIA =:COMPANIA AND NAT_COMITE_SELECCION.NRO_CONVOCATORIA =:CONVOCATORIA) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcomiteseleccion/numero">
		<call-query href="getNatcomiteseleccionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>

		</call-query>
	</resource>
	<query id="updateNatcomiteseleccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_COMITE_SELECCION SET COMPANIA=:COMPANIA, NRO_CONVOCATORIA=:NRO_CONVOCATORIA, NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_COMITE_SELECCION.COMPANIA= :KEY_COMPANIA AND NAT_COMITE_SELECCION.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_COMITE_SELECCION.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_COMITE_SELECCION.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natcomiteseleccion">
		<call-query href="updateNatcomiteseleccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>