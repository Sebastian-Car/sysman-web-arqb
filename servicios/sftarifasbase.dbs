<data name="sftarifasbase" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSftarifasbasePagDescripcionYValorPorAnoYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_TARIFAS_BASE.CODIGO, SF_TARIFAS_BASE.DESCRIPCION NOMBRE, SF_TARIFAS_BASE.VALOR PORCENTAJE FROM SF_TARIFAS_BASE WHERE SF_TARIFAS_BASE.COMPANIA = :COMPANIA AND SF_TARIFAS_BASE.TIPO_COBRO = :TIPOCOBRO AND SF_TARIFAS_BASE.ANO = :ANO ORDER BY SF_TARIFAS_BASE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PORCENTAJE":"$PORCENTAJE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftarifasbase/descripcionyvalorporanoytipo/pag">
		<call-query href="getSftarifasbasePagDescripcionYValorPorAnoYTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftarifasbaseNumDescripcionYValorPorAnoYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_TARIFAS_BASE.CODIGO, SF_TARIFAS_BASE.DESCRIPCION NOMBRE, SF_TARIFAS_BASE.VALOR PORCENTAJE FROM SF_TARIFAS_BASE WHERE SF_TARIFAS_BASE.COMPANIA = :COMPANIA AND SF_TARIFAS_BASE.TIPO_COBRO = :TIPOCOBRO AND SF_TARIFAS_BASE.ANO = :ANO ORDER BY SF_TARIFAS_BASE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftarifasbase/descripcionyvalorporanoytipo/num">
		<call-query href="getSftarifasbaseNumDescripcionYValorPorAnoYTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>

		</call-query>
	</resource>
	<query id="getSftarifasbasePagValorporanoytipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_TARIFAS_BASE.CODIGO, SF_TARIFAS_BASE.DESCRIPCION, SF_TARIFAS_BASE.VALOR FROM SF_TARIFAS_BASE WHERE SF_TARIFAS_BASE.COMPANIA = :COMPANIA AND SF_TARIFAS_BASE.TIPO_COBRO = :TIPOCOBRO AND SF_TARIFAS_BASE.ANO = :ANO ORDER BY SF_TARIFAS_BASE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","VALOR":"$VALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftarifasbase/valorporanoytipo/pag">
		<call-query href="getSftarifasbasePagValorporanoytipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftarifasbaseNumValorporanoytipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_TARIFAS_BASE.CODIGO, SF_TARIFAS_BASE.DESCRIPCION, SF_TARIFAS_BASE.VALOR FROM SF_TARIFAS_BASE WHERE SF_TARIFAS_BASE.COMPANIA = :COMPANIA AND SF_TARIFAS_BASE.TIPO_COBRO = :TIPOCOBRO AND SF_TARIFAS_BASE.ANO = :ANO ORDER BY SF_TARIFAS_BASE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftarifasbase/valorporanoytipo/num">
		<call-query href="getSftarifasbaseNumValorporanoytipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR" query-param="VALOR"/>

		</call-query>
	</resource>
	<query id="insertSftarifasbase" keyColumns="COMPANIA,ANO,TIPO_COBRO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_TARIFAS_BASE (COMPANIA, ANO, TIPO_COBRO, CODIGO, FORMULA, VALOR, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO_COBRO, :CODIGO, :FORMULA, :VALOR, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO_COBRO":"$TIPO_COBRO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_COBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="FORMULA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sftarifasbase">
		<call-query href="insertSftarifasbase">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_COBRO" query-param="TIPO_COBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSftarifasbase" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_TARIFAS_BASE WHERE SF_TARIFAS_BASE.COMPANIA= :KEY_COMPANIA AND SF_TARIFAS_BASE.ANO= :KEY_ANO AND SF_TARIFAS_BASE.TIPO_COBRO= :KEY_TIPO_COBRO AND SF_TARIFAS_BASE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_COBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sftarifasbase">
		<call-query href="deleteSftarifasbase">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_COBRO" query-param="KEY_TIPO_COBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSftarifasbasePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , ANO , TIPO_COBRO , CODIGO , FORMULA , VALOR , DESCRIPCION  FROM SF_TARIFAS_BASE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_COBRO = :TIPOCOBRO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FORMULA IS NULL THEN ' ' ELSE UPPER(FORMULA) END)  LIKE UPPER( '%' || :FORMULA || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_COBRO":"$TIPO_COBRO","CODIGO":"$CODIGO","FORMULA":"$FORMULA","VALOR":"$VALOR","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftarifasbase">
		<call-query href="getSftarifasbasePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftarifasbaseNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , ANO , TIPO_COBRO , CODIGO , FORMULA , VALOR , DESCRIPCION  FROM SF_TARIFAS_BASE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_COBRO = :TIPOCOBRO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FORMULA IS NULL THEN ' ' ELSE UPPER(FORMULA) END)  LIKE UPPER( '%' || :FORMULA || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftarifasbase/numero">
		<call-query href="getSftarifasbaseNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateSftarifasbase" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_TARIFAS_BASE SET ANO=:ANO, TIPO_COBRO=:TIPO_COBRO, CODIGO=:CODIGO, FORMULA=:FORMULA, VALOR=:VALOR, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_TARIFAS_BASE.COMPANIA= :KEY_COMPANIA AND SF_TARIFAS_BASE.ANO= :KEY_ANO AND SF_TARIFAS_BASE.TIPO_COBRO= :KEY_TIPO_COBRO AND SF_TARIFAS_BASE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_COBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_COBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sftarifasbase">
		<call-query href="updateSftarifasbase">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_COBRO" query-param="TIPO_COBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_COBRO" query-param="KEY_TIPO_COBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>