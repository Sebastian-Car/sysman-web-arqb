<data name="natcalificacionpruebas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatcalificacionpruebasPagListadoCalificacionPruebasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_CALIFICACION_PRUEBAS.COMPANIA, NAT_CALIFICACION_PRUEBAS.SUCURSAL, NAT_CALIFICACION_PRUEBAS.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.NOMBRE, NAT_CALIFICACION_PRUEBAS.NRO_CONVOCATORIA, NAT_CALIFICACION_PRUEBAS.CALIFICACION, NAT_CALIFICACION_PRUEBAS.OBSERVACIONES, NAT_CALIFICACION_PRUEBAS.PRUEBA  FROM NAT_CALIFICACION_PRUEBAS INNER JOIN NAT_APERTURA_INSCRITOS ON NAT_CALIFICACION_PRUEBAS.NUMERO_DCTO = NAT_APERTURA_INSCRITOS.NUMERO_DCTO AND NAT_CALIFICACION_PRUEBAS.NRO_CONVOCATORIA = NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA WHERE NAT_CALIFICACION_PRUEBAS.COMPANIA = :COMPANIA AND NAT_CALIFICACION_PRUEBAS.NRO_CONVOCATORIA = :CONVOCATORIA AND NAT_CALIFICACION_PRUEBAS.PRUEBA = :PRUEBA AND NAT_APERTURA_INSCRITOS.RECHAZOEXPERIENCIA IN(0) AND NAT_APERTURA_INSCRITOS.RECHAZOESTUDIOS IN(0) AND NAT_APERTURA_INSCRITOS.RECHAZOOTROS IN(0)) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER( '%' || :CALIFICACION || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN PRUEBA IS NULL THEN ' ' ELSE UPPER(PRUEBA) END)  LIKE UPPER(:PRUEBA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","CALIFICACION":"$CALIFICACION","OBSERVACIONES":"$OBSERVACIONES","PRUEBA":"$PRUEBA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natcalificacionpruebas/listadocalificacionpruebas/pag">
		<call-query href="getNatcalificacionpruebasPagListadoCalificacionPruebasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="PRUEBA" query-param="PRUEBA"/>
