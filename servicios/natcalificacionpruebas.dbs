	<query id="updateNatcalificacionpruebas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_CALIFICACION_PRUEBAS SET NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, NRO_CONVOCATORIA=:NRO_CONVOCATORIA, PRUEBA=:PRUEBA, CALIFICACION=:CALIFICACION, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_CALIFICACION_PRUEBAS.COMPANIA= :KEY_COMPANIA AND NAT_CALIFICACION_PRUEBAS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_CALIFICACION_PRUEBAS.SUCURSAL= :KEY_SUCURSAL AND NAT_CALIFICACION_PRUEBAS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_CALIFICACION_PRUEBAS.PRUEBA= :KEY_PRUEBA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_PRUEBA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natcalificacionpruebas">
		<call-query href="updateNatcalificacionpruebas">
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_PRUEBA" query-param="KEY_PRUEBA"/>

		</call-query>
	</resource>

</data>