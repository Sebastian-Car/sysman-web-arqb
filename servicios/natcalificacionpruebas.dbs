	<query id="insertNatcalificacionpruebas" keyColumns="COMPANIA,NUMERO_DCTO,SUCURSAL,NRO_CONVOCATORIA,PRUEBA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_CALIFICACION_PRUEBAS (COMPANIA, NUMERO_DCTO, SUCURSAL, NRO_CONVOCATORIA, PRUEBA, CALIFICACION, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_DCTO, :SUCURSAL, :NRO_CONVOCATORIA, :PRUEBA, :CALIFICACION, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","KEY_PRUEBA":"$PRUEBA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natcalificacionpruebas">
