	<query id="getEvmanualNumNumeromanualversioncodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_MANUAL.COMPANIA, EV_MANUAL.NUMERO_MANUAL, EV_MANUAL.SIGLA, EV_MANUAL.NOMBRE_MANUAL, EV_MANUAL.VERSION, EV_TIPO_REQUISITO.CODIGO, EV_TIPO_REQUISITO.NOMBRE, EV_REQUISITOS.DESCRIPCION, EV_REQUISITOS.ALTERNATIVA, EV_REQUISITOS.TIPO_REQUISITO  FROM EV_MANUAL INNER JOIN EV_REQUISITOS ON EV_MANUAL.COMPANIA = EV_REQUISITOS.COMPANIA AND EV_MANUAL.NUMERO_MANUAL = EV_REQUISITOS.NUMERO_MANUAL AND EV_MANUAL.VERSION = EV_REQUISITOS.VERSION LEFT JOIN EV_TIPO_REQUISITO ON EV_MANUAL.COMPANIA = EV_TIPO_REQUISITO.COMPANIA AND EV_REQUISITOS.TIPO_REQUISITO = EV_TIPO_REQUISITO.CODIGO WHERE EV_MANUAL.COMPANIA = :COMPANIA AND EV_MANUAL.DEPENDENCIA = :DEPENDENCIA AND EV_MANUAL.CARGO = :CARGO AND EV_REQUISITOS.TIPO_REQUISITO IN ('00001','00002')) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN SIGLA IS NULL THEN ' ' ELSE UPPER(SIGLA) END)  LIKE UPPER(:SIGLA || '%')  AND (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END)  LIKE UPPER(:NOMBRE_MANUAL || '%')  AND (CASE WHEN ALTERNATIVA IS NULL THEN ' ' ELSE UPPER(ALTERNATIVA) END)  LIKE UPPER(:ALTERNATIVA || '%')  AND (CASE WHEN TIPO_REQUISITO IS NULL THEN ' ' ELSE UPPER(TIPO_REQUISITO) END)  LIKE UPPER(:TIPO_REQUISITO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
