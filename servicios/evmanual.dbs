	<query id="getEvmanualPagNumeromanualversioncodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_MANUAL.COMPANIA, EV_MANUAL.NUMERO_MANUAL, EV_MANUAL.SIGLA, EV_MANUAL.NOMBRE_MANUAL, EV_MANUAL.VERSION, EV_TIPO_REQUISITO.CODIGO, EV_TIPO_REQUISITO.NOMBRE, EV_REQUISITOS.DESCRIPCION, EV_REQUISITOS.ALTERNATIVA, EV_REQUISITOS.TIPO_REQUISITO  FROM EV_MANUAL INNER JOIN EV_REQUISITOS ON EV_MANUAL.COMPANIA = EV_REQUISITOS.COMPANIA AND EV_MANUAL.NUMERO_MANUAL = EV_REQUISITOS.NUMERO_MANUAL AND EV_MANUAL.VERSION = EV_REQUISITOS.VERSION LEFT JOIN EV_TIPO_REQUISITO ON EV_MANUAL.COMPANIA = EV_TIPO_REQUISITO.COMPANIA AND EV_REQUISITOS.TIPO_REQUISITO = EV_TIPO_REQUISITO.CODIGO WHERE EV_MANUAL.COMPANIA = :COMPANIA AND EV_MANUAL.DEPENDENCIA = :DEPENDENCIA AND EV_MANUAL.CARGO = :CARGO AND EV_REQUISITOS.TIPO_REQUISITO IN ('00001','00002')) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN SIGLA IS NULL THEN ' ' ELSE UPPER(SIGLA) END)  LIKE UPPER(:SIGLA || '%')  AND (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END)  LIKE UPPER(:NOMBRE_MANUAL || '%')  AND (CASE WHEN ALTERNATIVA IS NULL THEN ' ' ELSE UPPER(ALTERNATIVA) END)  LIKE UPPER(:ALTERNATIVA || '%')  AND (CASE WHEN TIPO_REQUISITO IS NULL THEN ' ' ELSE UPPER(TIPO_REQUISITO) END)  LIKE UPPER(:TIPO_REQUISITO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_MANUAL":"$NUMERO_MANUAL","SIGLA":"$SIGLA","NOMBRE_MANUAL":"$NOMBRE_MANUAL","VERSION":"$VERSION","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","ALTERNATIVA":"$ALTERNATIVA(type:integer)","TIPO_REQUISITO":"$TIPO_REQUISITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="NOMBRE_MANUAL" sqlType="STRING"/>
		<param name="ALTERNATIVA" sqlType="STRING"/>
		<param name="TIPO_REQUISITO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
