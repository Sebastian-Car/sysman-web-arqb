	<query id="getEvmanualNumeroVersionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  EV_MANUAL.NUMERO_MANUAL, EV_MANUAL.VERSION  FROM EV_MANUAL WHERE EV_MANUAL.COMPANIA =:COMPANIA ORDER BY EV_MANUAL.NUMERO_MANUAL ASC</sql>
