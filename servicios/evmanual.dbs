	<query id="getEvmanualPagManualporcompaniaytipocompetenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT EVM.NUMERO_MANUAL,EVM.NOMBRE_MANUAL  FROM EV_MANUAL EVM INNER JOIN EV_COMPETENCIAS EVC ON EVM.COMPANIA = EVC.COMPANIA AND EVM.NUMERO_MANUAL = EVC.NUMERO_MANUAL AND EVM.VERSION = EVC.VERSION WHERE EVM.COMPANIA = :COMPANIA AND EVC.TIPO_COMPETENCIA = :TIPOCOMPETENCIAS) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END)  LIKE UPPER( '%' || :NOMBRE_MANUAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_MANUAL":"$NUMERO_MANUAL","NOMBRE_MANUAL":"$NOMBRE_MANUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPETENCIAS" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="NOMBRE_MANUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evmanual/manualporcompaniaytipocompetencia/pag">
		<call-query href="getEvmanualPagManualporcompaniaytipocompetenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPETENCIAS" query-param="TIPOCOMPETENCIAS"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="NOMBRE_MANUAL" query-param="NOMBRE_MANUAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvmanualNumManualporcompaniaytipocompetenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT EVM.NUMERO_MANUAL,EVM.NOMBRE_MANUAL  FROM EV_MANUAL EVM INNER JOIN EV_COMPETENCIAS EVC ON EVM.COMPANIA = EVC.COMPANIA AND EVM.NUMERO_MANUAL = EVC.NUMERO_MANUAL AND EVM.VERSION = EVC.VERSION WHERE EVM.COMPANIA = :COMPANIA AND EVC.TIPO_COMPETENCIA = :TIPOCOMPETENCIAS) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END)  LIKE UPPER( '%' || :NOMBRE_MANUAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPETENCIAS" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="NOMBRE_MANUAL" sqlType="STRING"/>

	</query>
