	<query id="getEvmanualNumNumnomsiglacontieneQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_MANUAL.NUMERO_MANUAL, EV_MANUAL.NOMBRE_MANUAL, EV_MANUAL.SIGLA, EV_MANUAL.COMPANIA, EV_MANUAL.VERSION  FROM EV_MANUAL WHERE EV_MANUAL.COMPANIA = :COMPANIA) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END)  LIKE UPPER( '%' || :NOMBRE_MANUAL || '%')  AND (CASE WHEN SIGLA IS NULL THEN ' ' ELSE UPPER(SIGLA) END)  LIKE UPPER( '%' || :SIGLA || '%') ))</sql>
