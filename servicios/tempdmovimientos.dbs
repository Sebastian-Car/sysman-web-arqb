<data name="tempdmovimientos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTempdmovimientosPagPorDocAsociadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MOVIMIENTO, TIPOMOVIMIENTO, COMPANIA, CLASEDOCASOCIADO , NUMERODOCASOCIADO , CODIGO , ELEMENTO , ESPECIFICACION, CANTIDAD , SALDOCANT, CANTIDAD_AFECT , VALORUNITARIO , VALORTOTAL  FROM TEMP_D_MOVIMIENTO WHERE COMPANIA = :COMPANIA AND CLASEDOCASOCIADO = :CLASEASOCIADO AND TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND MOVIMIENTO = :MOVIMIENTO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END)  LIKE UPPER( '%' || :ESPECIFICACION || '%')  AND (CASE WHEN SALDOCANT IS NULL THEN ' ' ELSE UPPER(SALDOCANT) END)  LIKE UPPER(:SALDOCANT || '%')  AND (CASE WHEN CANTIDAD_AFECT IS NULL THEN ' ' ELSE UPPER(CANTIDAD_AFECT) END)  LIKE UPPER(:CANTIDAD_AFECT || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MOVIMIENTO":"$MOVIMIENTO(type:long)","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","COMPANIA":"$COMPANIA","CLASEDOCASOCIADO":"$CLASEDOCASOCIADO","NUMERODOCASOCIADO":"$NUMERODOCASOCIADO","CODIGO":"$CODIGO","ELEMENTO":"$ELEMENTO","ESPECIFICACION":"$ESPECIFICACION","CANTIDAD":"$CANTIDAD","SALDOCANT":"$SALDOCANT","CANTIDAD_AFECT":"$CANTIDAD_AFECT","VALORUNITARIO":"$VALORUNITARIO","VALORTOTAL":"$VALORTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEASOCIADO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="SALDOCANT" sqlType="STRING"/>
		<param name="CANTIDAD_AFECT" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tempdmovimientos/pordocasociado/pag">
		<call-query href="getTempdmovimientosPagPorDocAsociadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEASOCIADO" query-param="CLASEASOCIADO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="SALDOCANT" query-param="SALDOCANT"/>
			<with-param name="CANTIDAD_AFECT" query-param="CANTIDAD_AFECT"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTempdmovimientosNumPorDocAsociadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MOVIMIENTO, TIPOMOVIMIENTO, COMPANIA, CLASEDOCASOCIADO , NUMERODOCASOCIADO , CODIGO , ELEMENTO , ESPECIFICACION, CANTIDAD , SALDOCANT, CANTIDAD_AFECT , VALORUNITARIO , VALORTOTAL  FROM TEMP_D_MOVIMIENTO WHERE COMPANIA = :COMPANIA AND CLASEDOCASOCIADO = :CLASEASOCIADO AND TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND MOVIMIENTO = :MOVIMIENTO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END)  LIKE UPPER( '%' || :ESPECIFICACION || '%')  AND (CASE WHEN SALDOCANT IS NULL THEN ' ' ELSE UPPER(SALDOCANT) END)  LIKE UPPER(:SALDOCANT || '%')  AND (CASE WHEN CANTIDAD_AFECT IS NULL THEN ' ' ELSE UPPER(CANTIDAD_AFECT) END)  LIKE UPPER(:CANTIDAD_AFECT || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEASOCIADO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="SALDOCANT" sqlType="STRING"/>
		<param name="CANTIDAD_AFECT" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tempdmovimientos/pordocasociado/num">
		<call-query href="getTempdmovimientosNumPorDocAsociadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEASOCIADO" query-param="CLASEASOCIADO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="SALDOCANT" query-param="SALDOCANT"/>
			<with-param name="CANTIDAD_AFECT" query-param="CANTIDAD_AFECT"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>

		</call-query>
	</resource>
	<query id="updateTempdmovimientosDocAsociado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TEMP_D_MOVIMIENTO SET MOVIMIENTO=:MOVIMIENTO, TIPOMOVIMIENTO=:TIPOMOVIMIENTO, COMPANIA=:COMPANIA, CLASEDOCASOCIADO=:CLASEDOCASOCIADO, NUMERODOCASOCIADO=:NUMERODOCASOCIADO, CODIGO=:CODIGO, ELEMENTO=:ELEMENTO, ESPECIFICACION=:ESPECIFICACION, CANTIDAD=:CANTIDAD, CANTIDAD_AFECT=:CANTIDAD_AFECT, VALORUNITARIO=:VALORUNITARIO, VALORTOTAL=:VALORTOTAL, VALORBASE=:VALORBASE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TEMP_D_MOVIMIENTO.COMPANIA= :KEY_COMPANIA AND TEMP_D_MOVIMIENTO.CLASEDOCASOCIADO= :KEY_CLASEDOCASOCIADO AND TEMP_D_MOVIMIENTO.NUMERODOCASOCIADO= :KEY_NUMERODOCASOCIADO AND TEMP_D_MOVIMIENTO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND TEMP_D_MOVIMIENTO.MOVIMIENTO= :KEY_MOVIMIENTO AND TEMP_D_MOVIMIENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOCASOCIADO" sqlType="STRING"/>
		<param name="NUMERODOCASOCIADO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="CANTIDAD_AFECT" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>									
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEDOCASOCIADO" sqlType="STRING"/>
		<param name="KEY_NUMERODOCASOCIADO" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_MOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tempdmovimientos/docasociado">
		<call-query href="updateTempdmovimientosDocAsociado">
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOCASOCIADO" query-param="CLASEDOCASOCIADO"/>
			<with-param name="NUMERODOCASOCIADO" query-param="NUMERODOCASOCIADO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="CANTIDAD_AFECT" query-param="CANTIDAD_AFECT"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>											 
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEDOCASOCIADO" query-param="KEY_CLASEDOCASOCIADO"/>
			<with-param name="KEY_NUMERODOCASOCIADO" query-param="KEY_NUMERODOCASOCIADO"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_MOVIMIENTO" query-param="KEY_MOVIMIENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="deleteTempdmovimientosDocAsociado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TEMP_D_MOVIMIENTO  WHERE COMPANIA = :KEY_COMPANIA    AND CLASEDOCASOCIADO = :KEY_CLASEDOCASOCIADO     AND TIPOMOVIMIENTO = :KEY_TIPOMOVIMIENTO     AND MOVIMIENTO =  :KEY_MOVIMIENTO AND NUMERODOCASOCIADO= :KEY_NUMERODOCASOCIADO AND CODIGO=:KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEDOCASOCIADO" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_MOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_NUMERODOCASOCIADO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tempdmovimientos/docasociado">
		<call-query href="deleteTempdmovimientosDocAsociado">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEDOCASOCIADO" query-param="KEY_CLASEDOCASOCIADO"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_MOVIMIENTO" query-param="KEY_MOVIMIENTO"/>
			<with-param name="KEY_NUMERODOCASOCIADO" query-param="KEY_NUMERODOCASOCIADO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="deleteTempdmovimientosPorMovimientoYTipoMovimiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE TEMP_D_MOVIMIENTO WHERE COMPANIA = :COMPANIA  AND TIPOMOVIMIENTO = :TIPOMOVIMIENTO  AND MOVIMIENTO = :MOVIMIENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tempdmovimientos/pormovimientoytipomovimiento">
		<call-query href="deleteTempdmovimientosPorMovimientoYTipoMovimiento">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>

		</call-query>
	</resource>

</data>