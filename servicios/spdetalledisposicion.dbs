<data name="spdetalledisposicion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSpdetalledisposicion" keyColumns="COMPANIA,CICLO,CODIGORUTA,NUMERORECIBO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_DETALLEDISPOSICION (COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, NUMERORECIBO, FECHAINICIAL, PLACA, PESOASEO, PAIS, DEPARTAMENTO, MUNICIPIO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CICLO, :CODIGORUTA, :ANO, :PERIODO, :NUMERORECIBO, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), :PLACA, :PESOASEO, :PAIS, :DEPARTAMENTO, :MUNICIPIO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_NUMERORECIBO":"$NUMERORECIBO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NUMERORECIBO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINICIAL" sqlType="STRING"/>
		<param defaultValue="" name="PLACA" sqlType="STRING"/>
		<param defaultValue="0" name="PESOASEO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="MUNICIPIO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spdetalledisposicion">
		<call-query href="insertSpdetalledisposicion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NUMERORECIBO" query-param="NUMERORECIBO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="MUNICIPIO" query-param="MUNICIPIO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSpdetalledisposicion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_DETALLEDISPOSICION WHERE SP_DETALLEDISPOSICION.COMPANIA= :KEY_COMPANIA AND SP_DETALLEDISPOSICION.CICLO= :KEY_CICLO AND SP_DETALLEDISPOSICION.CODIGORUTA= :KEY_CODIGORUTA AND SP_DETALLEDISPOSICION.NUMERORECIBO= :KEY_NUMERORECIBO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="INTEGER"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_NUMERORECIBO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spdetalledisposicion">
		<call-query href="deleteSpdetalledisposicion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_NUMERORECIBO" query-param="KEY_NUMERORECIBO"/>

		</call-query>
	</resource>
	<query id="getSpdetalledisposicionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_DETALLEDISPOSICION.COMPANIA, SP_DETALLEDISPOSICION.PAIS PAIS, SP_DETALLEDISPOSICION.DEPARTAMENTO, SP_DETALLEDISPOSICION.MUNICIPIO, SP_DETALLEDISPOSICION.CICLO, SP_DETALLEDISPOSICION.CODIGORUTA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) NOMBRE, SP_DETALLEDISPOSICION.ANO, SP_DETALLEDISPOSICION.PERIODO, SP_DETALLEDISPOSICION.NUMERORECIBO,(TO_CHAR(SP_DETALLEDISPOSICION.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, SP_DETALLEDISPOSICION.PLACA, SP_DETALLEDISPOSICION.PESOASEO, PAISES.NOMBRE NOMBREPAIS, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, CIUDAD.NOMBRE NOMBRECIUDAD FROM SP_DETALLEDISPOSICION INNER JOIN SP_USUARIO ON SP_DETALLEDISPOSICION.COMPANIA = SP_USUARIO.COMPANIA AND SP_DETALLEDISPOSICION.CICLO = SP_USUARIO.CICLO AND SP_DETALLEDISPOSICION.CODIGORUTA = SP_USUARIO.CODIGORUTA INNER JOIN PAISES ON PAISES.PAIS = SP_DETALLEDISPOSICION.PAIS INNER JOIN DEPARTAMENTO ON DEPARTAMENTO.CODIGO = SP_DETALLEDISPOSICION.DEPARTAMENTO AND DEPARTAMENTO.PAIS = SP_DETALLEDISPOSICION.PAIS INNER JOIN CIUDAD ON CIUDAD.CODIGO = SP_DETALLEDISPOSICION.MUNICIPIO AND CIUDAD.DEPARTAMENTO = SP_DETALLEDISPOSICION.DEPARTAMENTO AND CIUDAD.PAIS = SP_DETALLEDISPOSICION.PAIS WHERE SP_DETALLEDISPOSICION.COMPANIA =:COMPANIA AND SP_DETALLEDISPOSICION.CICLO =:CICLODIS AND SP_DETALLEDISPOSICION.ANO =:ANODIS AND SP_DETALLEDISPOSICION.PERIODO = PCK_SERVICIOS_PUBLICOS.FC_ANO_PERIODO_SIGUIENTE(:COMPANIA,:ANODIS,:PERIODODIS,1,NULL)) INI WHERE (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NUMERORECIBO IS NULL THEN ' ' ELSE UPPER(NUMERORECIBO) END) LIKE UPPER(CONCAT(:NUMERORECIBO, '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END) LIKE UPPER(CONCAT(:PLACA, '%')) AND (CASE WHEN PESOASEO IS NULL THEN ' ' ELSE UPPER(PESOASEO) END) LIKE UPPER(CONCAT(:PESOASEO, '%')) AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPAIS), '%')) AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREDEPARTAMENTO), '%')) AND (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECIUDAD), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","MUNICIPIO":"$MUNICIPIO","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","NUMERORECIBO":"$NUMERORECIBO","FECHAINICIAL":"$FECHAINICIAL","PLACA":"$PLACA","PESOASEO":"$PESOASEO","NOMBREPAIS":"$NOMBREPAIS","NOMBREDEPARTAMENTO":"$NOMBREDEPARTAMENTO","NOMBRECIUDAD":"$NOMBRECIUDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLODIS" sqlType="STRING"/>
		<param name="ANODIS" sqlType="STRING"/>
		<param name="PERIODODIS" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NUMERORECIBO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spdetalledisposicion">
		<call-query href="getSpdetalledisposicionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLODIS" query-param="CICLODIS"/>
			<with-param name="ANODIS" query-param="ANODIS"/>
			<with-param name="PERIODODIS" query-param="PERIODODIS"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NUMERORECIBO" query-param="NUMERORECIBO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="NOMBREPAIS" query-param="NOMBREPAIS"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpdetalledisposicionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_DETALLEDISPOSICION.COMPANIA, SP_DETALLEDISPOSICION.PAIS PAIS, SP_DETALLEDISPOSICION.DEPARTAMENTO, SP_DETALLEDISPOSICION.MUNICIPIO, SP_DETALLEDISPOSICION.CICLO, SP_DETALLEDISPOSICION.CODIGORUTA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) NOMBRE, SP_DETALLEDISPOSICION.ANO, SP_DETALLEDISPOSICION.PERIODO, SP_DETALLEDISPOSICION.NUMERORECIBO,(TO_CHAR(SP_DETALLEDISPOSICION.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, SP_DETALLEDISPOSICION.PLACA, SP_DETALLEDISPOSICION.PESOASEO, PAISES.NOMBRE NOMBREPAIS, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, CIUDAD.NOMBRE NOMBRECIUDAD FROM SP_DETALLEDISPOSICION INNER JOIN SP_USUARIO ON SP_DETALLEDISPOSICION.COMPANIA = SP_USUARIO.COMPANIA AND SP_DETALLEDISPOSICION.CICLO = SP_USUARIO.CICLO AND SP_DETALLEDISPOSICION.CODIGORUTA = SP_USUARIO.CODIGORUTA INNER JOIN PAISES ON PAISES.PAIS = SP_DETALLEDISPOSICION.PAIS INNER JOIN DEPARTAMENTO ON DEPARTAMENTO.CODIGO = SP_DETALLEDISPOSICION.DEPARTAMENTO AND DEPARTAMENTO.PAIS = SP_DETALLEDISPOSICION.PAIS INNER JOIN CIUDAD ON CIUDAD.CODIGO = SP_DETALLEDISPOSICION.MUNICIPIO AND CIUDAD.DEPARTAMENTO = SP_DETALLEDISPOSICION.DEPARTAMENTO AND CIUDAD.PAIS = SP_DETALLEDISPOSICION.PAIS WHERE SP_DETALLEDISPOSICION.COMPANIA =:COMPANIA AND SP_DETALLEDISPOSICION.CICLO =:CICLODIS AND SP_DETALLEDISPOSICION.ANO =:ANODIS AND SP_DETALLEDISPOSICION.PERIODO = PCK_SERVICIOS_PUBLICOS.FC_ANO_PERIODO_SIGUIENTE(:COMPANIA,:ANODIS,:PERIODODIS,1,NULL)) INI WHERE (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NUMERORECIBO IS NULL THEN ' ' ELSE UPPER(NUMERORECIBO) END) LIKE UPPER(CONCAT(:NUMERORECIBO, '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END) LIKE UPPER(CONCAT(:PLACA, '%')) AND (CASE WHEN PESOASEO IS NULL THEN ' ' ELSE UPPER(PESOASEO) END) LIKE UPPER(CONCAT(:PESOASEO, '%')) AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPAIS), '%')) AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREDEPARTAMENTO), '%')) AND (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECIUDAD), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLODIS" sqlType="STRING"/>
		<param name="ANODIS" sqlType="STRING"/>
		<param name="PERIODODIS" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NUMERORECIBO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdetalledisposicion/numero">
		<call-query href="getSpdetalledisposicionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLODIS" query-param="CICLODIS"/>
			<with-param name="ANODIS" query-param="ANODIS"/>
			<with-param name="PERIODODIS" query-param="PERIODODIS"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NUMERORECIBO" query-param="NUMERORECIBO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="NOMBREPAIS" query-param="NOMBREPAIS"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>

		</call-query>
	</resource>
	<query id="updateSpdetalledisposicion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_DETALLEDISPOSICION SET CODIGORUTA=:CODIGORUTA, ANO=:ANO, PERIODO=:PERIODO, NUMERORECIBO=:NUMERORECIBO, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), PLACA=:PLACA, PESOASEO=:PESOASEO, PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, MUNICIPIO=:MUNICIPIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_DETALLEDISPOSICION.COMPANIA= :KEY_COMPANIA AND SP_DETALLEDISPOSICION.CICLO= :KEY_CICLO AND SP_DETALLEDISPOSICION.CODIGORUTA= :KEY_CODIGORUTA AND SP_DETALLEDISPOSICION.NUMERORECIBO= :KEY_NUMERORECIBO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NUMERORECIBO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="MUNICIPIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_NUMERORECIBO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spdetalledisposicion">
		<call-query href="updateSpdetalledisposicion">
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NUMERORECIBO" query-param="NUMERORECIBO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="MUNICIPIO" query-param="MUNICIPIO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_NUMERORECIBO" query-param="KEY_NUMERORECIBO"/>

		</call-query>
	</resource>

</data>