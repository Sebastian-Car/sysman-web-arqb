<data name="dc_recurso_actividad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDc_recurso_actividadPagGettodasactividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO, NOMBRE,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM DC_ACTIVIDAD_SUI WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dc_recurso_actividad/gettodasactividades/pag">
		<call-query href="getDc_recurso_actividadPagGettodasactividadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDc_recurso_actividadNumGettodasactividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO, NOMBRE,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM DC_ACTIVIDAD_SUI WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dc_recurso_actividad/gettodasactividades/num">
		<call-query href="getDc_recurso_actividadNumGettodasactividadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="getDc_recurso_actividadPagGettodosrecursosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO, NOMBRE FROM DC_RECURSO_SUI WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dc_recurso_actividad/gettodosrecursos/pag">
		<call-query href="getDc_recurso_actividadPagGettodosrecursosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDc_recurso_actividadNumGettodosrecursosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO, NOMBRE FROM DC_RECURSO_SUI WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dc_recurso_actividad/gettodosrecursos/num">
		<call-query href="getDc_recurso_actividadNumGettodosrecursosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertDc_recurso_actividad" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DC_RECURSO_ACTIVIDAD_SUI (COMPANIA, CODIGO, NOMBRE, CODIGO_RECURSO, CODIGO_ACTIVIDAD, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :CODIGO_RECURSO, :CODIGO_ACTIVIDAD, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_RECURSO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dc_recurso_actividad">
		<call-query href="insertDc_recurso_actividad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_RECURSO" query-param="CODIGO_RECURSO"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDc_recurso_actividad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DC_RECURSO_ACTIVIDAD_SUI WHERE DC_RECURSO_ACTIVIDAD_SUI.COMPANIA= :KEY_COMPANIA AND DC_RECURSO_ACTIVIDAD_SUI.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dc_recurso_actividad">
		<call-query href="deleteDc_recurso_actividad">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getDc_recurso_actividadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT RA.COMPANIA, RA.CODIGO, RA.NOMBRE NOMBRE, RA.CODIGO_RECURSO, R.NOMBRE NOMBRE_RECURSO, RA.CODIGO_ACTIVIDAD, A.NOMBRE NOMBRE_ACTIVIDAD FROM DC_RECURSO_ACTIVIDAD_SUI RA INNER JOIN DC_RECURSO_SUI R ON RA.COMPANIA = R.COMPANIA AND RA.CODIGO_RECURSO = R.CODIGO INNER JOIN DC_ACTIVIDAD_SUI A ON RA.COMPANIA = A.COMPANIA AND RA.CODIGO_ACTIVIDAD = A.CODIGO WHERE RA.COMPANIA = :COMPANIA ORDER BY RA.CODIGO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGO_RECURSO IS NULL THEN ' ' ELSE UPPER(CODIGO_RECURSO) END) LIKE UPPER(CONCAT(:CODIGO_RECURSO, '%')) AND (CASE WHEN NOMBRE_RECURSO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RECURSO), '%')) AND (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END) LIKE UPPER(CONCAT(:CODIGO_ACTIVIDAD, '%')) AND (CASE WHEN NOMBRE_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ACTIVIDAD), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGO_RECURSO":"$CODIGO_RECURSO","NOMBRE_RECURSO":"$NOMBRE_RECURSO","CODIGO_ACTIVIDAD":"$CODIGO_ACTIVIDAD","NOMBRE_ACTIVIDAD":"$NOMBRE_ACTIVIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE_RECURSO" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE_ACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dc_recurso_actividad">
		<call-query href="getDc_recurso_actividadPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_RECURSO" query-param="CODIGO_RECURSO"/>
			<with-param name="NOMBRE_RECURSO" query-param="NOMBRE_RECURSO"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="NOMBRE_ACTIVIDAD" query-param="NOMBRE_ACTIVIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDc_recurso_actividadNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT RA.COMPANIA, RA.CODIGO, RA.NOMBRE NOMBRE, RA.CODIGO_RECURSO, R.NOMBRE NOMBRE_RECURSO, RA.CODIGO_ACTIVIDAD, A.NOMBRE NOMBRE_ACTIVIDAD FROM DC_RECURSO_ACTIVIDAD_SUI RA INNER JOIN DC_RECURSO_SUI R ON RA.COMPANIA = R.COMPANIA AND RA.CODIGO_RECURSO = R.CODIGO INNER JOIN DC_ACTIVIDAD_SUI A ON RA.COMPANIA = A.COMPANIA AND RA.CODIGO_ACTIVIDAD = A.CODIGO WHERE RA.COMPANIA = :COMPANIA ORDER BY RA.CODIGO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGO_RECURSO IS NULL THEN ' ' ELSE UPPER(CODIGO_RECURSO) END) LIKE UPPER(CONCAT(:CODIGO_RECURSO, '%')) AND (CASE WHEN NOMBRE_RECURSO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RECURSO), '%')) AND (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END) LIKE UPPER(CONCAT(:CODIGO_ACTIVIDAD, '%')) AND (CASE WHEN NOMBRE_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ACTIVIDAD), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE_RECURSO" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE_ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dc_recurso_actividad/numero">
		<call-query href="getDc_recurso_actividadNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_RECURSO" query-param="CODIGO_RECURSO"/>
			<with-param name="NOMBRE_RECURSO" query-param="NOMBRE_RECURSO"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="NOMBRE_ACTIVIDAD" query-param="NOMBRE_ACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="updateDc_recurso_actividad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DC_RECURSO_ACTIVIDAD_SUI SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, CODIGO_RECURSO=:CODIGO_RECURSO, CODIGO_ACTIVIDAD=:CODIGO_ACTIVIDAD, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DC_RECURSO_ACTIVIDAD_SUI.COMPANIA= :KEY_COMPANIA AND DC_RECURSO_ACTIVIDAD_SUI.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_RECURSO" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dc_recurso_actividad">
		<call-query href="updateDc_recurso_actividad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_RECURSO" query-param="CODIGO_RECURSO"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>