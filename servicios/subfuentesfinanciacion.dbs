<data name="subfuentesfinanciacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSubfuentesfinanciacion" keyColumns="COMPANIA,CODIGOFUENTE,CODIGOSUBFUENTE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SUBFUENTESFINANCIACION (COMPANIA, CODIGOFUENTE, CODIGOSUBFUENTE, NOMBRE, DESCRIPCION, CODIGODNP, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGOFUENTE, :CODIGOSUBFUENTE, :NOMBRE, :DESCRIPCION, :CODIGODNP, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOFUENTE":"$CODIGOFUENTE","KEY_CODIGOSUBFUENTE":"$CODIGOSUBFUENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOFUENTE" sqlType="STRING"/>
		<param name="CODIGOSUBFUENTE" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGODNP" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="subfuentesfinanciacion">
		<call-query href="insertSubfuentesfinanciacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOFUENTE" query-param="CODIGOFUENTE"/>
			<with-param name="CODIGOSUBFUENTE" query-param="CODIGOSUBFUENTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGODNP" query-param="CODIGODNP"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSubfuentesfinanciacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SUBFUENTESFINANCIACION WHERE SUBFUENTESFINANCIACION.COMPANIA= :KEY_COMPANIA AND SUBFUENTESFINANCIACION.CODIGOFUENTE= :KEY_CODIGOFUENTE AND SUBFUENTESFINANCIACION.CODIGOSUBFUENTE= :KEY_CODIGOSUBFUENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOFUENTE" sqlType="STRING"/>
		<param name="KEY_CODIGOSUBFUENTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="subfuentesfinanciacion">
		<call-query href="deleteSubfuentesfinanciacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOFUENTE" query-param="KEY_CODIGOFUENTE"/>
			<with-param name="KEY_CODIGOSUBFUENTE" query-param="KEY_CODIGOSUBFUENTE"/>

		</call-query>
	</resource>
	<query id="getSubfuentesfinanciacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGOFUENTE, CODIGOSUBFUENTE, NOMBRE, DESCRIPCION, CODIGODNP  FROM SUBFUENTESFINANCIACION WHERE COMPANIA = :COMPANIA AND CODIGOFUENTE = :FUENTE) WHERE (CASE WHEN CODIGOSUBFUENTE IS NULL THEN ' ' ELSE UPPER(CODIGOSUBFUENTE) END)  LIKE UPPER(:CODIGOSUBFUENTE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CODIGODNP IS NULL THEN ' ' ELSE UPPER(CODIGODNP) END)  LIKE UPPER(:CODIGODNP || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOSUBFUENTE":"$CODIGOSUBFUENTE","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","CODIGODNP":"$CODIGODNP"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CODIGOSUBFUENTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGODNP" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="subfuentesfinanciacion">
		<call-query href="getSubfuentesfinanciacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CODIGOSUBFUENTE" query-param="CODIGOSUBFUENTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGODNP" query-param="CODIGODNP"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSubfuentesfinanciacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGOFUENTE, CODIGOSUBFUENTE, NOMBRE, DESCRIPCION, CODIGODNP  FROM SUBFUENTESFINANCIACION WHERE COMPANIA = :COMPANIA AND CODIGOFUENTE = :FUENTE) WHERE (CASE WHEN CODIGOSUBFUENTE IS NULL THEN ' ' ELSE UPPER(CODIGOSUBFUENTE) END)  LIKE UPPER(:CODIGOSUBFUENTE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CODIGODNP IS NULL THEN ' ' ELSE UPPER(CODIGODNP) END)  LIKE UPPER(:CODIGODNP || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CODIGOSUBFUENTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGODNP" sqlType="STRING"/>

	</query>
	<resource method="GET" path="subfuentesfinanciacion/numero">
		<call-query href="getSubfuentesfinanciacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CODIGOSUBFUENTE" query-param="CODIGOSUBFUENTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGODNP" query-param="CODIGODNP"/>

		</call-query>
	</resource>
	<query id="updateSubfuentesfinanciacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SUBFUENTESFINANCIACION SET CODIGOSUBFUENTE=:CODIGOSUBFUENTE, NOMBRE=:NOMBRE, DESCRIPCION=:DESCRIPCION, CODIGODNP=:CODIGODNP, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SUBFUENTESFINANCIACION.COMPANIA= :KEY_COMPANIA AND SUBFUENTESFINANCIACION.CODIGOFUENTE= :KEY_CODIGOFUENTE AND SUBFUENTESFINANCIACION.CODIGOSUBFUENTE= :KEY_CODIGOSUBFUENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOSUBFUENTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGODNP" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOFUENTE" sqlType="STRING"/>
		<param name="KEY_CODIGOSUBFUENTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="subfuentesfinanciacion">
		<call-query href="updateSubfuentesfinanciacion">
			<with-param name="CODIGOSUBFUENTE" query-param="CODIGOSUBFUENTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGODNP" query-param="CODIGODNP"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOFUENTE" query-param="KEY_CODIGOFUENTE"/>
			<with-param name="KEY_CODIGOSUBFUENTE" query-param="KEY_CODIGOSUBFUENTE"/>

		</call-query>
	</resource>

</data>