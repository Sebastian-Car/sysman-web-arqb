	<query id="updateIpnumerosdefacturaConsecrealPorCiaTipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_NUMEROSDEFACTURA SET CONSECUTIVOREAL = :NUMERO, MODIFIED_BY = :MODIFIED_BY, DATE_MODIFIED = :DATE_MODIFIED WHERE COMPANIA = :COMPANIA AND TIPO       = :TIPO AND ACTIVO    &lt;&gt; 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
