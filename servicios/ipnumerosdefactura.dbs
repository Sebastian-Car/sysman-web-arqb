<data name="ipnumerosdefactura" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpnumerosdefacturaMaximoDeSecuenciaPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(IP_NUMEROSDEFACTURA.SECUENCIA) AS SECUENCIA1, IP_NUMEROSDEFACTURA.CONSECUTIVO, IP_NUMEROSDEFACTURA.CONSECUTIVOREAL ,(CASE IP_NUMEROSDEFACTURA.ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO, IP_NUMEROSDEFACTURA.TIPO, IP_TIPOSNUMERACION.DIGITOS  FROM IP_NUMEROSDEFACTURA LEFT JOIN IP_TIPOSNUMERACION ON IP_NUMEROSDEFACTURA.TIPO = IP_TIPOSNUMERACION.CODIGO WHERE IP_NUMEROSDEFACTURA.COMPANIA = :COMPANIA AND IP_NUMEROSDEFACTURA.TIPO = :TIPO AND IP_NUMEROSDEFACTURA.ACTIVO NOT IN (0) GROUP BY IP_NUMEROSDEFACTURA.CONSECUTIVO, IP_NUMEROSDEFACTURA.CONSECUTIVOREAL, IP_NUMEROSDEFACTURA.ACTIVO, IP_NUMEROSDEFACTURA.TIPO, IP_TIPOSNUMERACION.DIGITOS ORDER BY MAX(IP_NUMEROSDEFACTURA.SECUENCIA) DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SECUENCIA1":"$SECUENCIA1(type:integer)","CONSECUTIVO":"$CONSECUTIVO","CONSECUTIVOREAL":"$CONSECUTIVOREAL","ACTIVO":"$ACTIVO(type:boolean)","TIPO":"$TIPO","DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipnumerosdefactura/maximodesecuenciaportipo">
		<call-query href="getIpnumerosdefacturaMaximoDeSecuenciaPorTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="updateIpnumerosdefacturaConsecutivoReal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_NUMEROSDEFACTURA SET CONSECUTIVOREAL = :CONSECUTIVO , DATE_MODIFIED = SYSDATE , MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA AND SECUENCIA = :SECUENCIA AND TIPO = :TIPO AND ACTIVO NOT IN(0)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipnumerosdefactura/consecutivoreal">
		<call-query href="updateIpnumerosdefacturaConsecutivoReal">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getIpnumerosdefacturaConsultaconsecutivoccatastralQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NF.CONSECUTIVOREAL, T.DIGITOS  FROM IP_NUMEROSDEFACTURA NF INNER JOIN IP_TIPOSNUMERACION T ON (NF.TIPO = T.CODIGO) WHERE NF.COMPANIA = :COMPANIA AND NF.TIPO = :TIPOCERTIFICADO AND NF.ACTIVO &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVOREAL":"$CONSECUTIVOREAL","DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCERTIFICADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipnumerosdefactura/consultaconsecutivoccatastral">
		<call-query href="getIpnumerosdefacturaConsultaconsecutivoccatastralQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCERTIFICADO" query-param="TIPOCERTIFICADO"/>

		</call-query>
	</resource>
	<query id="updateIpnumerosdefacturaConsecutivorealportipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_NUMEROSDEFACTURA SET CONSECUTIVOREAL = :NUMCER,   DATE_MODIFIED     = SYSDATE,   MODIFIED_BY       = :MODIFIED_BY WHERE COMPANIA      = :COMPANIA AND TIPO            = :TIPOCERTIFICADO AND ACTIVO         &lt;&gt; 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMCER" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCERTIFICADO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipnumerosdefactura/consecutivorealportipo">
		<call-query href="updateIpnumerosdefacturaConsecutivorealportipo">
			<with-param name="NUMCER" query-param="NUMCER"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCERTIFICADO" query-param="TIPOCERTIFICADO"/>

		</call-query>
	</resource>
	<query id="getIpnumerosdefacturaTodosPorCompaniaPrimeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CONSECUTIVOREAL  FROM IP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA AND TIPO IN ('N') AND ACTIVO IN (-1) AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVOREAL":"$CONSECUTIVOREAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipnumerosdefactura/todosporcompaniaprimero">
		<call-query href="getIpnumerosdefacturaTodosPorCompaniaPrimeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getIpnumerosdefacturaConsecDigitosPorCiaTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NF.CONSECUTIVOREAL, T.DIGITOS  FROM IP_NUMEROSDEFACTURA NF INNER JOIN IP_TIPOSNUMERACION T ON (NF.TIPO = T.CODIGO) WHERE NF.COMPANIA = :COMPANIA AND NF.TIPO = :TIPO AND NF.ACTIVO &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVOREAL":"$CONSECUTIVOREAL","DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
