			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getIpnumerosdefacturaTodosPorCompaniaConsultarActivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) NUMERO  FROM IP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA AND TIPO IN ('N') AND ACTIVO IN (-1)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
