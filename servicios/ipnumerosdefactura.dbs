		</call-query>
	</resource>
	<query id="getIpnumerosdefacturaConsecPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CONSECUTIVOREAL  FROM IP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA AND TIPO = 'N' AND ACTIVO &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVOREAL":"$CONSECUTIVOREAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipnumerosdefactura/consecporcompania">
