<data name="clasetransaccionc" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getClasetransaccioncPagPorclasenovedadQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CLASETRANSACCIONC.TIPOT, CLASETRANSACCIONC.NOMBRE, CLASETRANSACCIONC.CLASENOVEDAD,(CASE CLASETRANSACCIONC.AFECTAITEMS WHEN 0 THEN 'false' ELSE 'true' END) AFECTAITEMS, CLASETRANSACCIONC.TAUTOMATICA,(CASE CLASETRANSACCIONC.LIQUIDACONTRATO WHEN 0 THEN 'false' ELSE 'true' END) LIQUIDACONTRATO, CLASETRANSACCIONC.TIPOMODELO, CLASETRANSACCIONC.TIPOFORMATO,(CASE CLASETRANSACCIONC.APLICA_CALIFICACION WHEN 0 THEN 'false' ELSE 'true' END) APLICA_CALIFICACION,(CASE CLASETRANSACCIONC.INDPAGO WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO FROM CLASETRANSACCIONC WHERE CLASETRANSACCIONC.CLASENOVEDAD = :CLASENOVEDADORD AND CLASETRANSACCIONC.CLASET = :CLASET ORDER BY CLASETRANSACCIONC.TIPOT, CLASETRANSACCIONC.NOMBRE, CLASETRANSACCIONC.CLASET) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOT":"$TIPOT","NOMBRE":"$NOMBRE","CLASENOVEDAD":"$CLASENOVEDAD","AFECTAITEMS":"$AFECTAITEMS(type:boolean)","TAUTOMATICA":"$TAUTOMATICA","LIQUIDACONTRATO":"$LIQUIDACONTRATO(type:boolean)","TIPOMODELO":"$TIPOMODELO","TIPOFORMATO":"$TIPOFORMATO","APLICA_CALIFICACION":"$APLICA_CALIFICACION(type:boolean)","INDPAGO":"$INDPAGO(type:boolean)"}]}}		</result>
		<param name="CLASENOVEDADORD" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="clasetransaccionc/porclasenovedad/pag">
		<call-query href="getClasetransaccioncPagPorclasenovedadQuery">
			<with-param name="CLASENOVEDADORD" query-param="CLASENOVEDADORD"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClasetransaccioncNumPorclasenovedadQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CLASETRANSACCIONC.TIPOT, CLASETRANSACCIONC.NOMBRE, CLASETRANSACCIONC.CLASENOVEDAD,(CASE CLASETRANSACCIONC.AFECTAITEMS WHEN 0 THEN 'false' ELSE 'true' END) AFECTAITEMS, CLASETRANSACCIONC.TAUTOMATICA,(CASE CLASETRANSACCIONC.LIQUIDACONTRATO WHEN 0 THEN 'false' ELSE 'true' END) LIQUIDACONTRATO, CLASETRANSACCIONC.TIPOMODELO, CLASETRANSACCIONC.TIPOFORMATO,(CASE CLASETRANSACCIONC.APLICA_CALIFICACION WHEN 0 THEN 'false' ELSE 'true' END) APLICA_CALIFICACION,(CASE CLASETRANSACCIONC.INDPAGO WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO FROM CLASETRANSACCIONC WHERE CLASETRANSACCIONC.CLASENOVEDAD = :CLASENOVEDADORD AND CLASETRANSACCIONC.CLASET = :CLASET ORDER BY CLASETRANSACCIONC.TIPOT, CLASETRANSACCIONC.NOMBRE, CLASETRANSACCIONC.CLASET) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CLASENOVEDADORD" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasetransaccionc/porclasenovedad/num">
		<call-query href="getClasetransaccioncNumPorclasenovedadQuery">
			<with-param name="CLASENOVEDADORD" query-param="CLASENOVEDADORD"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getClasetransaccioncGetafectaactividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE AFECTA_ACTIVIDADES WHEN 0 THEN 'false' ELSE 'true' END) AFECTA_ACTIVIDADES FROM CLASETRANSACCIONC WHERE CLASET = :CLASET AND TIPOT = :TIPOT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"AFECTA_ACTIVIDADES":"$AFECTA_ACTIVIDADES(type:boolean)"}]}}		</result>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasetransaccionc/getafectaactividades">
