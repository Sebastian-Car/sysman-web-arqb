<data name="seriedocumental" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSeriedocumentalPagCodnombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO ,NOMBRE  FROM SERIEDOCUMENTAL WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="seriedocumental/codnombre/pag">
		<call-query href="getSeriedocumentalPagCodnombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSeriedocumentalNumCodnombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO ,NOMBRE  FROM SERIEDOCUMENTAL WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="seriedocumental/codnombre/num">
		<call-query href="getSeriedocumentalNumCodnombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertSeriedocumental" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SERIEDOCUMENTAL (COMPANIA, CODIGO, NOMBRE, ESTADO, TIEMPO_RETENCION_ARGESTION, TIEMPO_RETENCION_ARCENTRAL, TIEMPO_RETENCION_AHISTORICO, MEDIO_RECUPERACION, ALMACENAMIENTO_FISICO, ESTADO_FISICO, RUTA_DOCUMENTO_MAGNETICO, RUTA_REGISTRO_MAGNETICO, FECHA_FINAL, FECHA_INICIAL, VIGENCIA, UNIDAD_TIEMPO_ARGESTION, UNIDAD_TIEMPO_ARCENTRAL, UNIDAD_TIEMPO_AHISTORICO, SELECCION, CONSERVACION_TOTAL, MICROFILMACION, ELIMINACION, PROCEDIMIENTOS_OBSERVACIONES, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :ESTADO, :TIEMPO_RETENCION_ARGESTION, :TIEMPO_RETENCION_ARCENTRAL, :TIEMPO_RETENCION_AHISTORICO, :MEDIO_RECUPERACION, :ALMACENAMIENTO_FISICO, :ESTADO_FISICO, :RUTA_DOCUMENTO_MAGNETICO, :RUTA_REGISTRO_MAGNETICO, TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), :VIGENCIA, :UNIDAD_TIEMPO_ARGESTION, :UNIDAD_TIEMPO_ARCENTRAL, :UNIDAD_TIEMPO_AHISTORICO, :SELECCION, :CONSERVACION_TOTAL, :MICROFILMACION, :ELIMINACION, :PROCEDIMIENTOS_OBSERVACIONES, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param defaultValue="0" name="TIEMPO_RETENCION_ARGESTION" sqlType="STRING"/>
		<param defaultValue="0" name="TIEMPO_RETENCION_ARCENTRAL" sqlType="STRING"/>
		<param defaultValue="0" name="TIEMPO_RETENCION_AHISTORICO" sqlType="STRING"/>
		<param name="MEDIO_RECUPERACION" sqlType="STRING"/>
		<param name="ALMACENAMIENTO_FISICO" sqlType="STRING"/>
		<param name="ESTADO_FISICO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_DOCUMENTO_MAGNETICO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_REGISTRO_MAGNETICO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="A" name="UNIDAD_TIEMPO_ARGESTION" sqlType="STRING"/>
		<param defaultValue="A" name="UNIDAD_TIEMPO_ARCENTRAL" sqlType="STRING"/>
		<param defaultValue="A" name="UNIDAD_TIEMPO_AHISTORICO" sqlType="STRING"/>
		<param defaultValue="0" name="SELECCION" sqlType="STRING"/>
		<param defaultValue="0" name="CONSERVACION_TOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="MICROFILMACION" sqlType="STRING"/>
		<param defaultValue="0" name="ELIMINACION" sqlType="STRING"/>
		<param defaultValue="" name="PROCEDIMIENTOS_OBSERVACIONES" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="seriedocumental">
		<call-query href="insertSeriedocumental">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIEMPO_RETENCION_ARGESTION" query-param="TIEMPO_RETENCION_ARGESTION"/>
			<with-param name="TIEMPO_RETENCION_ARCENTRAL" query-param="TIEMPO_RETENCION_ARCENTRAL"/>
			<with-param name="TIEMPO_RETENCION_AHISTORICO" query-param="TIEMPO_RETENCION_AHISTORICO"/>
			<with-param name="MEDIO_RECUPERACION" query-param="MEDIO_RECUPERACION"/>
			<with-param name="ALMACENAMIENTO_FISICO" query-param="ALMACENAMIENTO_FISICO"/>
			<with-param name="ESTADO_FISICO" query-param="ESTADO_FISICO"/>
			<with-param name="RUTA_DOCUMENTO_MAGNETICO" query-param="RUTA_DOCUMENTO_MAGNETICO"/>
			<with-param name="RUTA_REGISTRO_MAGNETICO" query-param="RUTA_REGISTRO_MAGNETICO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="UNIDAD_TIEMPO_ARGESTION" query-param="UNIDAD_TIEMPO_ARGESTION"/>
			<with-param name="UNIDAD_TIEMPO_ARCENTRAL" query-param="UNIDAD_TIEMPO_ARCENTRAL"/>
			<with-param name="UNIDAD_TIEMPO_AHISTORICO" query-param="UNIDAD_TIEMPO_AHISTORICO"/>
			<with-param name="SELECCION" query-param="SELECCION"/>
			<with-param name="CONSERVACION_TOTAL" query-param="CONSERVACION_TOTAL"/>
			<with-param name="MICROFILMACION" query-param="MICROFILMACION"/>
			<with-param name="ELIMINACION" query-param="ELIMINACION"/>
			<with-param name="PROCEDIMIENTOS_OBSERVACIONES" query-param="PROCEDIMIENTOS_OBSERVACIONES"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteSeriedocumental" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SERIEDOCUMENTAL WHERE SERIEDOCUMENTAL.COMPANIA= :KEY_COMPANIA AND SERIEDOCUMENTAL.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="seriedocumental">
		<call-query href="deleteSeriedocumental">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSeriedocumentalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SERIEDOCUMENTAL.COMPANIA, SERIEDOCUMENTAL.CODIGO, SERIEDOCUMENTAL.NOMBRE, TIPOS.NOMBRE AS ESTADO  FROM SERIEDOCUMENTAL INNER JOIN TIPOS ON SERIEDOCUMENTAL.ESTADO = TIPOS.ID WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="seriedocumental">
		<call-query href="getSeriedocumentalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSeriedocumentalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SERIEDOCUMENTAL.COMPANIA, SERIEDOCUMENTAL.CODIGO, SERIEDOCUMENTAL.NOMBRE, TIPOS.NOMBRE AS ESTADO  FROM SERIEDOCUMENTAL INNER JOIN TIPOS ON SERIEDOCUMENTAL.ESTADO = TIPOS.ID WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="seriedocumental/numero">
		<call-query href="getSeriedocumentalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getSeriedocumentalRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO, NOMBRE, ESTADO, TIEMPO_RETENCION_ARGESTION, TIEMPO_RETENCION_ARCENTRAL, TIEMPO_RETENCION_AHISTORICO, MEDIO_RECUPERACION, ALMACENAMIENTO_FISICO, ESTADO_FISICO, RUTA_DOCUMENTO_MAGNETICO, RUTA_REGISTRO_MAGNETICO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL, VIGENCIA,UNIDAD_TIEMPO_ARGESTION,UNIDAD_TIEMPO_ARCENTRAL,UNIDAD_TIEMPO_AHISTORICO,(CASE SELECCION WHEN 0 THEN 'false' ELSE 'true' END) SELECCION,(CASE CONSERVACION_TOTAL WHEN 0 THEN 'false' ELSE 'true' END) CONSERVACION_TOTAL,(CASE MICROFILMACION WHEN 0 THEN 'false' ELSE 'true' END) MICROFILMACION,(CASE ELIMINACION WHEN 0 THEN 'false' ELSE 'true' END) ELIMINACION,PROCEDIMIENTOS_OBSERVACIONES, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED FROM SERIEDOCUMENTAL WHERE SERIEDOCUMENTAL.COMPANIA= :KEY_COMPANIA AND SERIEDOCUMENTAL.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ESTADO":"$ESTADO(type:integer)","TIEMPO_RETENCION_ARGESTION":"$TIEMPO_RETENCION_ARGESTION(type:integer)","TIEMPO_RETENCION_ARCENTRAL":"$TIEMPO_RETENCION_ARCENTRAL(type:integer)","TIEMPO_RETENCION_AHISTORICO":"$TIEMPO_RETENCION_AHISTORICO(type:integer)","MEDIO_RECUPERACION":"$MEDIO_RECUPERACION","ALMACENAMIENTO_FISICO":"$ALMACENAMIENTO_FISICO","ESTADO_FISICO":"$ESTADO_FISICO","RUTA_DOCUMENTO_MAGNETICO":"$RUTA_DOCUMENTO_MAGNETICO","RUTA_REGISTRO_MAGNETICO":"$RUTA_REGISTRO_MAGNETICO","FECHA_FINAL":"$FECHA_FINAL","FECHA_INICIAL":"$FECHA_INICIAL","VIGENCIA":"$VIGENCIA(type:integer)","UNIDAD_TIEMPO_ARGESTION":"$UNIDAD_TIEMPO_ARGESTION","UNIDAD_TIEMPO_ARCENTRAL":"$UNIDAD_TIEMPO_ARCENTRAL","UNIDAD_TIEMPO_AHISTORICO":"$UNIDAD_TIEMPO_AHISTORICO","SELECCION":"$SELECCION(type:boolean)","CONSERVACION_TOTAL":"$CONSERVACION_TOTAL(type:boolean)","MICROFILMACION":"$MICROFILMACION(type:boolean)","ELIMINACION":"$ELIMINACION(type:boolean)","PROCEDIMIENTOS_OBSERVACIONES":"$PROCEDIMIENTOS_OBSERVACIONES","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="seriedocumental/data">
		<call-query href="getSeriedocumentalRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateSeriedocumental" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SERIEDOCUMENTAL SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, ESTADO=:ESTADO, TIEMPO_RETENCION_ARGESTION=:TIEMPO_RETENCION_ARGESTION, TIEMPO_RETENCION_ARCENTRAL=:TIEMPO_RETENCION_ARCENTRAL, TIEMPO_RETENCION_AHISTORICO=:TIEMPO_RETENCION_AHISTORICO, MEDIO_RECUPERACION=:MEDIO_RECUPERACION, ALMACENAMIENTO_FISICO=:ALMACENAMIENTO_FISICO, ESTADO_FISICO=:ESTADO_FISICO, RUTA_DOCUMENTO_MAGNETICO=:RUTA_DOCUMENTO_MAGNETICO, RUTA_REGISTRO_MAGNETICO=:RUTA_REGISTRO_MAGNETICO, FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_INICIAL=TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), VIGENCIA=:VIGENCIA, UNIDAD_TIEMPO_ARGESTION=:UNIDAD_TIEMPO_ARGESTION, UNIDAD_TIEMPO_ARCENTRAL=:UNIDAD_TIEMPO_ARCENTRAL, UNIDAD_TIEMPO_AHISTORICO=:UNIDAD_TIEMPO_AHISTORICO, SELECCION=:SELECCION, CONSERVACION_TOTAL=:CONSERVACION_TOTAL, MICROFILMACION=:MICROFILMACION, ELIMINACION=:ELIMINACION, PROCEDIMIENTOS_OBSERVACIONES=:PROCEDIMIENTOS_OBSERVACIONES, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SERIEDOCUMENTAL.COMPANIA= :KEY_COMPANIA AND SERIEDOCUMENTAL.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIEMPO_RETENCION_ARGESTION" sqlType="STRING"/>
		<param name="TIEMPO_RETENCION_ARCENTRAL" sqlType="STRING"/>
		<param name="TIEMPO_RETENCION_AHISTORICO" sqlType="STRING"/>
		<param name="MEDIO_RECUPERACION" sqlType="STRING"/>
		<param name="ALMACENAMIENTO_FISICO" sqlType="STRING"/>
		<param name="ESTADO_FISICO" sqlType="STRING"/>
		<param name="RUTA_DOCUMENTO_MAGNETICO" sqlType="STRING"/>
		<param name="RUTA_REGISTRO_MAGNETICO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="UNIDAD_TIEMPO_ARGESTION" sqlType="STRING"/>
		<param name="UNIDAD_TIEMPO_ARCENTRAL" sqlType="STRING"/>
		<param name="UNIDAD_TIEMPO_AHISTORICO" sqlType="STRING"/>
		<param name="SELECCION" sqlType="STRING"/>
		<param name="CONSERVACION_TOTAL" sqlType="STRING"/>
		<param name="MICROFILMACION" sqlType="STRING"/>
		<param name="ELIMINACION" sqlType="STRING"/>
		<param name="PROCEDIMIENTOS_OBSERVACIONES" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="seriedocumental">
		<call-query href="updateSeriedocumental">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIEMPO_RETENCION_ARGESTION" query-param="TIEMPO_RETENCION_ARGESTION"/>
			<with-param name="TIEMPO_RETENCION_ARCENTRAL" query-param="TIEMPO_RETENCION_ARCENTRAL"/>
			<with-param name="TIEMPO_RETENCION_AHISTORICO" query-param="TIEMPO_RETENCION_AHISTORICO"/>
			<with-param name="MEDIO_RECUPERACION" query-param="MEDIO_RECUPERACION"/>
			<with-param name="ALMACENAMIENTO_FISICO" query-param="ALMACENAMIENTO_FISICO"/>
			<with-param name="ESTADO_FISICO" query-param="ESTADO_FISICO"/>
			<with-param name="RUTA_DOCUMENTO_MAGNETICO" query-param="RUTA_DOCUMENTO_MAGNETICO"/>
			<with-param name="RUTA_REGISTRO_MAGNETICO" query-param="RUTA_REGISTRO_MAGNETICO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="UNIDAD_TIEMPO_ARGESTION" query-param="UNIDAD_TIEMPO_ARGESTION"/>
			<with-param name="UNIDAD_TIEMPO_ARCENTRAL" query-param="UNIDAD_TIEMPO_ARCENTRAL"/>
			<with-param name="UNIDAD_TIEMPO_AHISTORICO" query-param="UNIDAD_TIEMPO_AHISTORICO"/>
			<with-param name="SELECCION" query-param="SELECCION"/>
			<with-param name="CONSERVACION_TOTAL" query-param="CONSERVACION_TOTAL"/>
			<with-param name="MICROFILMACION" query-param="MICROFILMACION"/>
			<with-param name="ELIMINACION" query-param="ELIMINACION"/>
			<with-param name="PROCEDIMIENTOS_OBSERVACIONES" query-param="PROCEDIMIENTOS_OBSERVACIONES"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>