<data name="marcas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getMarcasTodosMarcaNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MARCA,NOMBRE  FROM MARCA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MARCA":"$MARCA","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="marcas/todosmarcanombre">
		<call-query href="getMarcasTodosMarcaNombreQuery">
 
		</call-query>
	</resource>
	<query id="insertMarcas" keyColumns="MARCA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO MARCA (MARCA, NOMBRE, DATE_CREATED, CREATED_BY) VALUES (:MARCA, :NOMBRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_MARCA":"$MARCA"}]}}		</result>
		<param name="MARCA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="marcas">
		<call-query href="insertMarcas">
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteMarcas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM MARCA WHERE MARCA.MARCA= :KEY_MARCA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_MARCA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="marcas">
		<call-query href="deleteMarcas">
			<with-param name="KEY_MARCA" query-param="KEY_MARCA"/>

		</call-query>
	</resource>
	<query id="getMarcasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MARCA,NOMBRE  FROM MARCA ORDER BY MARCA) WHERE (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER(:MARCA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MARCA":"$MARCA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="MARCA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="marcas">
		<call-query href="getMarcasPaginaQuery">
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMarcasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MARCA,NOMBRE  FROM MARCA ORDER BY MARCA) WHERE (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER(:MARCA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="MARCA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="marcas/numero">
		<call-query href="getMarcasNumeroQuery">
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateMarcas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MARCA SET MARCA=:MARCA, NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE MARCA.MARCA= :KEY_MARCA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MARCA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_MARCA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="marcas">
		<call-query href="updateMarcas">
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_MARCA" query-param="KEY_MARCA"/>

		</call-query>
	</resource>

</data>