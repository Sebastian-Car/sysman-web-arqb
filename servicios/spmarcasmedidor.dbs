<data name="spmarcasmedidor" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpmarcasmedidorPagTodosPorMarcaYDigitosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MARCA, DIGITOS  FROM SP_MARCAS_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY MARCA, COMPANIA) WHERE (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MARCA":"$MARCA","DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spmarcasmedidor/todospormarcaydigitos/pag">
		<call-query href="getSpmarcasmedidorPagTodosPorMarcaYDigitosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpmarcasmedidorNumTodosPorMarcaYDigitosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MARCA, DIGITOS  FROM SP_MARCAS_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY MARCA, COMPANIA) WHERE (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmarcasmedidor/todospormarcaydigitos/num">
		<call-query href="getSpmarcasmedidorNumTodosPorMarcaYDigitosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>

		</call-query>
	</resource>
	<query id="getSpmarcasmedidorTodosOrdenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MARCA, DIGITOS  FROM SP_MARCAS_MEDIDOR ORDER BY MARCA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MARCA":"$MARCA","DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
 
	</query>
	<resource method="GET" path="spmarcasmedidor/todosorden">
		<call-query href="getSpmarcasmedidorTodosOrdenQuery">
 
		</call-query>
	</resource>
	<query id="getSpmarcasmedidorPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MARCA, DIGITOS  FROM SP_MARCAS_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY MARCA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MARCA":"$MARCA","DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmarcasmedidor/porcompania">
		<call-query href="getSpmarcasmedidorPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertSpmarcasmedidor" keyColumns="COMPANIA,MARCA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_MARCAS_MEDIDOR (COMPANIA, MARCA, DIGITOS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :MARCA, :DIGITOS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_MARCA":"$MARCA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spmarcasmedidor">
		<call-query href="insertSpmarcasmedidor">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSpmarcasmedidor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_MARCAS_MEDIDOR WHERE SP_MARCAS_MEDIDOR.COMPANIA= :KEY_COMPANIA AND SP_MARCAS_MEDIDOR.MARCA= :KEY_MARCA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MARCA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spmarcasmedidor">
		<call-query href="deleteSpmarcasmedidor">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MARCA" query-param="KEY_MARCA"/>

		</call-query>
	</resource>
	<query id="getSpmarcasmedidorPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,MARCA,DIGITOS  FROM SP_MARCAS_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY MARCA) WHERE (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER(:DIGITOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","MARCA":"$MARCA","DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spmarcasmedidor">
		<call-query href="getSpmarcasmedidorPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpmarcasmedidorNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA,MARCA,DIGITOS  FROM SP_MARCAS_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY MARCA) WHERE (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmarcasmedidor/numero">
		<call-query href="getSpmarcasmedidorNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>

		</call-query>
	</resource>
	<query id="updateSpmarcasmedidor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_MARCAS_MEDIDOR SET COMPANIA=:COMPANIA, MARCA=:MARCA, DIGITOS=:DIGITOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_MARCAS_MEDIDOR.COMPANIA= :KEY_COMPANIA AND SP_MARCAS_MEDIDOR.MARCA= :KEY_MARCA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MARCA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spmarcasmedidor">
		<call-query href="updateSpmarcasmedidor">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MARCA" query-param="KEY_MARCA"/>

		</call-query>
	</resource>

</data>