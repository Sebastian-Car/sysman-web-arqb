<data name="variablesdetramites" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertVariablesdetramites" keyColumns="COMPANIA,PROCESOS,TIPO_TRAMITE,NUMERO,CONSECUTIVO,NODO_VARIABLE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VARIABLES_DE_TRAMITES (COMPANIA, PROCESOS, TIPO_TRAMITE, NUMERO, CONSECUTIVO, NODO_VARIABLE, VALOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :PROCESOS, :TIPO_TRAMITE, :NUMERO, :CONSECUTIVO, :NODO_VARIABLE, :VALOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROCESOS":"$PROCESOS","KEY_TIPO_TRAMITE":"$TIPO_TRAMITE","KEY_NUMERO":"$NUMERO(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)","KEY_NODO_VARIABLE":"$NODO_VARIABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESOS" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NODO_VARIABLE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="variablesdetramites">
		<call-query href="insertVariablesdetramites">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESOS" query-param="PROCESOS"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NODO_VARIABLE" query-param="NODO_VARIABLE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVariablesdetramites" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VARIABLES_DE_TRAMITES WHERE VARIABLES_DE_TRAMITES.COMPANIA= :KEY_COMPANIA AND VARIABLES_DE_TRAMITES.PROCESOS= :KEY_PROCESOS AND VARIABLES_DE_TRAMITES.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND VARIABLES_DE_TRAMITES.NUMERO= :KEY_NUMERO AND VARIABLES_DE_TRAMITES.CONSECUTIVO= :KEY_CONSECUTIVO AND VARIABLES_DE_TRAMITES.NODO_VARIABLE= :KEY_NODO_VARIABLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCESOS" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NODO_VARIABLE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="variablesdetramites">
		<call-query href="deleteVariablesdetramites">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCESOS" query-param="KEY_PROCESOS"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NODO_VARIABLE" query-param="KEY_NODO_VARIABLE"/>

		</call-query>
	</resource>
	<query id="getVariablesdetramitesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, PROCESOS, TIPO_TRAMITE, NUMERO, CONSECUTIVO, NODO_VARIABLE, VALOR  FROM VARIABLES_DE_TRAMITES WHERE COMPANIA = :COMPANIA AND PROCESOS = :PROCESO AND TIPO_TRAMITE = :TIPO_TRAMITE AND NUMERO = :NUMERO AND CONSECUTIVO = :CONSECUTIVO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN NODO_VARIABLE IS NULL THEN ' ' ELSE UPPER(NODO_VARIABLE) END)  LIKE UPPER(:NODO_VARIABLE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCESOS":"$PROCESOS","TIPO_TRAMITE":"$TIPO_TRAMITE","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:long)","NODO_VARIABLE":"$NODO_VARIABLE","VALOR":"$VALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NODO_VARIABLE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="variablesdetramites">
		<call-query href="getVariablesdetramitesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NODO_VARIABLE" query-param="NODO_VARIABLE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVariablesdetramitesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, PROCESOS, TIPO_TRAMITE, NUMERO, CONSECUTIVO, NODO_VARIABLE, VALOR  FROM VARIABLES_DE_TRAMITES WHERE COMPANIA = :COMPANIA AND PROCESOS = :PROCESO AND TIPO_TRAMITE = :TIPO_TRAMITE AND NUMERO = :NUMERO AND CONSECUTIVO = :CONSECUTIVO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN NODO_VARIABLE IS NULL THEN ' ' ELSE UPPER(NODO_VARIABLE) END)  LIKE UPPER(:NODO_VARIABLE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NODO_VARIABLE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="variablesdetramites/numero">
		<call-query href="getVariablesdetramitesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NODO_VARIABLE" query-param="NODO_VARIABLE"/>
			<with-param name="VALOR" query-param="VALOR"/>

		</call-query>
	</resource>
	<query id="updateVariablesdetramites" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VARIABLES_DE_TRAMITES SET NODO_VARIABLE=:NODO_VARIABLE, VALOR=:VALOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VARIABLES_DE_TRAMITES.COMPANIA= :KEY_COMPANIA AND VARIABLES_DE_TRAMITES.PROCESOS= :KEY_PROCESOS AND VARIABLES_DE_TRAMITES.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND VARIABLES_DE_TRAMITES.NUMERO= :KEY_NUMERO AND VARIABLES_DE_TRAMITES.CONSECUTIVO= :KEY_CONSECUTIVO AND VARIABLES_DE_TRAMITES.NODO_VARIABLE= :KEY_NODO_VARIABLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NODO_VARIABLE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCESOS" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NODO_VARIABLE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="variablesdetramites">
		<call-query href="updateVariablesdetramites">
			<with-param name="NODO_VARIABLE" query-param="NODO_VARIABLE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCESOS" query-param="KEY_PROCESOS"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NODO_VARIABLE" query-param="KEY_NODO_VARIABLE"/>

		</call-query>
	</resource>

</data>