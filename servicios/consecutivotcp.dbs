<data name="consecutivotcp" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConsecutivotcpTodosPorCompaniaTipoComprobanteAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO, CONSECUTIVO  FROM CONSECUTIVOTCP WHERE COMPANIA = :COMPANIA AND TIPOCOMPROBANTE = :STRTIPOCOMPROBANTE AND ANO = :ANO ORDER BY COMPANIA, TIPOCOMPROBANTE, ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="consecutivotcp/todosporcompaniatipocomprobanteano">
		<call-query href="getConsecutivotcpTodosPorCompaniaTipoComprobanteAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="STRTIPOCOMPROBANTE" query-param="STRTIPOCOMPROBANTE"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertConsecutivotcpAgregarCompaniaTipoComprobanteConsecutiovoAno" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONSECUTIVOTCP (COMPANIA,TIPOCOMPROBANTE,ANO,CONSECUTIVO) VALUES (:COMPANIA,:STRTIPOCOMPROBANTE,:ANO,1)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="consecutivotcp/agregarcompaniatipocomprobanteconsecutiovoano">
		<call-query href="insertConsecutivotcpAgregarCompaniaTipoComprobanteConsecutiovoAno">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="STRTIPOCOMPROBANTE" query-param="STRTIPOCOMPROBANTE"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertConsecutivotcp" keyColumns="COMPANIA,TIPOCOMPROBANTE,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONSECUTIVOTCP (COMPANIA, TIPOCOMPROBANTE, ANO, CONSECUTIVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOCOMPROBANTE, :ANO, :CONSECUTIVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCOMPROBANTE":"$TIPOCOMPROBANTE","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="consecutivotcp">
		<call-query href="insertConsecutivotcp">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConsecutivotcp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONSECUTIVOTCP WHERE CONSECUTIVOTCP.COMPANIA= :KEY_COMPANIA AND CONSECUTIVOTCP.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND CONSECUTIVOTCP.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="consecutivotcp">
		<call-query href="deleteConsecutivotcp">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOMPROBANTE" query-param="KEY_TIPOCOMPROBANTE"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getConsecutivotcpPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONSECUTIVOTCP.COMPANIA,CONSECUTIVOTCP.ANO,CONSECUTIVOTCP.CONSECUTIVO  FROM CONSECUTIVOTCP WHERE CONSECUTIVOTCP.COMPANIA = :COMPANIA AND TIPOCOMPROBANTE= :TIPO_CPTE) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="consecutivotcp">
		<call-query href="getConsecutivotcpPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConsecutivotcpNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONSECUTIVOTCP.COMPANIA,CONSECUTIVOTCP.ANO,CONSECUTIVOTCP.CONSECUTIVO  FROM CONSECUTIVOTCP WHERE CONSECUTIVOTCP.COMPANIA = :COMPANIA AND TIPOCOMPROBANTE= :TIPO_CPTE) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="consecutivotcp/numero">
		<call-query href="getConsecutivotcpNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateConsecutivotcp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONSECUTIVOTCP SET ANO=:ANO, CONSECUTIVO=:CONSECUTIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONSECUTIVOTCP.COMPANIA= :KEY_COMPANIA AND CONSECUTIVOTCP.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND CONSECUTIVOTCP.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="consecutivotcp">
		<call-query href="updateConsecutivotcp">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOMPROBANTE" query-param="KEY_TIPOCOMPROBANTE"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>

</data>