<data name="proveedor" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getProveedorPagElementosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROVEEDOR.COMPANIA, PROVEEDOR.ELEMENTO, PROVEEDOR.TERCERO, PROVEEDOR.SUCURSAL,(TO_CHAR(PROVEEDOR.FULTCOMPRA,'DD/MM/YYYY HH24:MI:SS')) FULTCOMPRA, PROVEEDOR.CULTCOMPRA, PROVEEDOR.PULTCOMPRA, PROVEEDOR.PDULTCOMPRA, PROVEEDOR.PIULTCOMPRA,(TO_CHAR(PROVEEDOR.FPENCOMPRA,'DD/MM/YYYY HH24:MI:SS')) FPENCOMPRA, PROVEEDOR.CPENCOMPRA, PROVEEDOR.PPENCOMPRA, PROVEEDOR.PDPENCOMPRA, PROVEEDOR.PIPENCOMPRA,(TO_CHAR(PROVEEDOR.FULTCOTIZACION,'DD/MM/YYYY HH24:MI:SS')) FULTCOTIZACION, PROVEEDOR.CULTCOTIZACION, PROVEEDOR.PRULTCOTIZACION, PROVEEDOR.PDULTCOTIZACION, PROVEEDOR.PIULTCOTIZACION  FROM PROVEEDOR WHERE SUCURSAL= :SUCURSAL AND TERCERO= :TERCERO AND COMPANIA= :COMPANIA ORDER BY PROVEEDOR.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN FULTCOMPRA IS NULL THEN ' ' ELSE UPPER(FULTCOMPRA) END)  LIKE UPPER( '%' || :FULTCOMPRA || '%')  AND (CASE WHEN CULTCOMPRA IS NULL THEN ' ' ELSE UPPER(CULTCOMPRA) END)  LIKE UPPER( '%' || :CULTCOMPRA || '%')  AND (CASE WHEN PULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PULTCOMPRA) END)  LIKE UPPER( '%' || :PULTCOMPRA || '%')  AND (CASE WHEN PDULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PDULTCOMPRA) END)  LIKE UPPER( '%' || :PDULTCOMPRA || '%')  AND (CASE WHEN PIULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PIULTCOMPRA) END)  LIKE UPPER( '%' || :PIULTCOMPRA || '%')  AND (CASE WHEN FPENCOMPRA IS NULL THEN ' ' ELSE UPPER(FPENCOMPRA) END)  LIKE UPPER( '%' || :FPENCOMPRA || '%')  AND (CASE WHEN CPENCOMPRA IS NULL THEN ' ' ELSE UPPER(CPENCOMPRA) END)  LIKE UPPER( '%' || :CPENCOMPRA || '%')  AND (CASE WHEN PPENCOMPRA IS NULL THEN ' ' ELSE UPPER(PPENCOMPRA) END)  LIKE UPPER( '%' || :PPENCOMPRA || '%')  AND (CASE WHEN PDPENCOMPRA IS NULL THEN ' ' ELSE UPPER(PDPENCOMPRA) END)  LIKE UPPER( '%' || :PDPENCOMPRA || '%')  AND (CASE WHEN PIPENCOMPRA IS NULL THEN ' ' ELSE UPPER(PIPENCOMPRA) END)  LIKE UPPER( '%' || :PIPENCOMPRA || '%')  AND (CASE WHEN FULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(FULTCOTIZACION) END)  LIKE UPPER( '%' || :FULTCOTIZACION || '%')  AND (CASE WHEN CULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(CULTCOTIZACION) END)  LIKE UPPER( '%' || :CULTCOTIZACION || '%')  AND (CASE WHEN PRULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(PRULTCOTIZACION) END)  LIKE UPPER( '%' || :PRULTCOTIZACION || '%')  AND (CASE WHEN PDULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(PDULTCOTIZACION) END)  LIKE UPPER( '%' || :PDULTCOTIZACION || '%')  AND (CASE WHEN PIULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(PIULTCOTIZACION) END)  LIKE UPPER( '%' || :PIULTCOTIZACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","FULTCOMPRA":"$FULTCOMPRA","CULTCOMPRA":"$CULTCOMPRA","PULTCOMPRA":"$PULTCOMPRA","PDULTCOMPRA":"$PDULTCOMPRA(type:integer)","PIULTCOMPRA":"$PIULTCOMPRA(type:integer)","FPENCOMPRA":"$FPENCOMPRA","CPENCOMPRA":"$CPENCOMPRA","PPENCOMPRA":"$PPENCOMPRA","PDPENCOMPRA":"$PDPENCOMPRA(type:integer)","PIPENCOMPRA":"$PIPENCOMPRA(type:integer)","FULTCOTIZACION":"$FULTCOTIZACION","CULTCOTIZACION":"$CULTCOTIZACION","PRULTCOTIZACION":"$PRULTCOTIZACION","PDULTCOTIZACION":"$PDULTCOTIZACION(type:integer)","PIULTCOTIZACION":"$PIULTCOTIZACION(type:integer)"}]}}		</result>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="FULTCOMPRA" sqlType="STRING"/>
		<param name="CULTCOMPRA" sqlType="STRING"/>
		<param name="PULTCOMPRA" sqlType="STRING"/>
		<param name="PDULTCOMPRA" sqlType="STRING"/>
		<param name="PIULTCOMPRA" sqlType="STRING"/>
		<param name="FPENCOMPRA" sqlType="STRING"/>
		<param name="CPENCOMPRA" sqlType="STRING"/>
		<param name="PPENCOMPRA" sqlType="STRING"/>
		<param name="PDPENCOMPRA" sqlType="STRING"/>
		<param name="PIPENCOMPRA" sqlType="STRING"/>
		<param name="FULTCOTIZACION" sqlType="STRING"/>
		<param name="CULTCOTIZACION" sqlType="STRING"/>
		<param name="PRULTCOTIZACION" sqlType="STRING"/>
		<param name="PDULTCOTIZACION" sqlType="STRING"/>
		<param name="PIULTCOTIZACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="proveedor/elementosporcompania/pag">
		<call-query href="getProveedorPagElementosPorCompaniaQuery">
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="FULTCOMPRA" query-param="FULTCOMPRA"/>
			<with-param name="CULTCOMPRA" query-param="CULTCOMPRA"/>
			<with-param name="PULTCOMPRA" query-param="PULTCOMPRA"/>
			<with-param name="PDULTCOMPRA" query-param="PDULTCOMPRA"/>
			<with-param name="PIULTCOMPRA" query-param="PIULTCOMPRA"/>
			<with-param name="FPENCOMPRA" query-param="FPENCOMPRA"/>
			<with-param name="CPENCOMPRA" query-param="CPENCOMPRA"/>
			<with-param name="PPENCOMPRA" query-param="PPENCOMPRA"/>
			<with-param name="PDPENCOMPRA" query-param="PDPENCOMPRA"/>
			<with-param name="PIPENCOMPRA" query-param="PIPENCOMPRA"/>
			<with-param name="FULTCOTIZACION" query-param="FULTCOTIZACION"/>
			<with-param name="CULTCOTIZACION" query-param="CULTCOTIZACION"/>
			<with-param name="PRULTCOTIZACION" query-param="PRULTCOTIZACION"/>
			<with-param name="PDULTCOTIZACION" query-param="PDULTCOTIZACION"/>
			<with-param name="PIULTCOTIZACION" query-param="PIULTCOTIZACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProveedorNumElementosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROVEEDOR.COMPANIA, PROVEEDOR.ELEMENTO, PROVEEDOR.TERCERO, PROVEEDOR.SUCURSAL,(TO_CHAR(PROVEEDOR.FULTCOMPRA,'DD/MM/YYYY HH24:MI:SS')) FULTCOMPRA, PROVEEDOR.CULTCOMPRA, PROVEEDOR.PULTCOMPRA, PROVEEDOR.PDULTCOMPRA, PROVEEDOR.PIULTCOMPRA,(TO_CHAR(PROVEEDOR.FPENCOMPRA,'DD/MM/YYYY HH24:MI:SS')) FPENCOMPRA, PROVEEDOR.CPENCOMPRA, PROVEEDOR.PPENCOMPRA, PROVEEDOR.PDPENCOMPRA, PROVEEDOR.PIPENCOMPRA,(TO_CHAR(PROVEEDOR.FULTCOTIZACION,'DD/MM/YYYY HH24:MI:SS')) FULTCOTIZACION, PROVEEDOR.CULTCOTIZACION, PROVEEDOR.PRULTCOTIZACION, PROVEEDOR.PDULTCOTIZACION, PROVEEDOR.PIULTCOTIZACION  FROM PROVEEDOR WHERE SUCURSAL= :SUCURSAL AND TERCERO= :TERCERO AND COMPANIA= :COMPANIA ORDER BY PROVEEDOR.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN FULTCOMPRA IS NULL THEN ' ' ELSE UPPER(FULTCOMPRA) END)  LIKE UPPER( '%' || :FULTCOMPRA || '%')  AND (CASE WHEN CULTCOMPRA IS NULL THEN ' ' ELSE UPPER(CULTCOMPRA) END)  LIKE UPPER( '%' || :CULTCOMPRA || '%')  AND (CASE WHEN PULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PULTCOMPRA) END)  LIKE UPPER( '%' || :PULTCOMPRA || '%')  AND (CASE WHEN PDULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PDULTCOMPRA) END)  LIKE UPPER( '%' || :PDULTCOMPRA || '%')  AND (CASE WHEN PIULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PIULTCOMPRA) END)  LIKE UPPER( '%' || :PIULTCOMPRA || '%')  AND (CASE WHEN FPENCOMPRA IS NULL THEN ' ' ELSE UPPER(FPENCOMPRA) END)  LIKE UPPER( '%' || :FPENCOMPRA || '%')  AND (CASE WHEN CPENCOMPRA IS NULL THEN ' ' ELSE UPPER(CPENCOMPRA) END)  LIKE UPPER( '%' || :CPENCOMPRA || '%')  AND (CASE WHEN PPENCOMPRA IS NULL THEN ' ' ELSE UPPER(PPENCOMPRA) END)  LIKE UPPER( '%' || :PPENCOMPRA || '%')  AND (CASE WHEN PDPENCOMPRA IS NULL THEN ' ' ELSE UPPER(PDPENCOMPRA) END)  LIKE UPPER( '%' || :PDPENCOMPRA || '%')  AND (CASE WHEN PIPENCOMPRA IS NULL THEN ' ' ELSE UPPER(PIPENCOMPRA) END)  LIKE UPPER( '%' || :PIPENCOMPRA || '%')  AND (CASE WHEN FULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(FULTCOTIZACION) END)  LIKE UPPER( '%' || :FULTCOTIZACION || '%')  AND (CASE WHEN CULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(CULTCOTIZACION) END)  LIKE UPPER( '%' || :CULTCOTIZACION || '%')  AND (CASE WHEN PRULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(PRULTCOTIZACION) END)  LIKE UPPER( '%' || :PRULTCOTIZACION || '%')  AND (CASE WHEN PDULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(PDULTCOTIZACION) END)  LIKE UPPER( '%' || :PDULTCOTIZACION || '%')  AND (CASE WHEN PIULTCOTIZACION IS NULL THEN ' ' ELSE UPPER(PIULTCOTIZACION) END)  LIKE UPPER( '%' || :PIULTCOTIZACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="FULTCOMPRA" sqlType="STRING"/>
		<param name="CULTCOMPRA" sqlType="STRING"/>
		<param name="PULTCOMPRA" sqlType="STRING"/>
		<param name="PDULTCOMPRA" sqlType="STRING"/>
		<param name="PIULTCOMPRA" sqlType="STRING"/>
		<param name="FPENCOMPRA" sqlType="STRING"/>
		<param name="CPENCOMPRA" sqlType="STRING"/>
		<param name="PPENCOMPRA" sqlType="STRING"/>
		<param name="PDPENCOMPRA" sqlType="STRING"/>
		<param name="PIPENCOMPRA" sqlType="STRING"/>
		<param name="FULTCOTIZACION" sqlType="STRING"/>
		<param name="CULTCOTIZACION" sqlType="STRING"/>
		<param name="PRULTCOTIZACION" sqlType="STRING"/>
		<param name="PDULTCOTIZACION" sqlType="STRING"/>
		<param name="PIULTCOTIZACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="proveedor/elementosporcompania/num">
		<call-query href="getProveedorNumElementosPorCompaniaQuery">
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="FULTCOMPRA" query-param="FULTCOMPRA"/>
			<with-param name="CULTCOMPRA" query-param="CULTCOMPRA"/>
			<with-param name="PULTCOMPRA" query-param="PULTCOMPRA"/>
			<with-param name="PDULTCOMPRA" query-param="PDULTCOMPRA"/>
			<with-param name="PIULTCOMPRA" query-param="PIULTCOMPRA"/>
			<with-param name="FPENCOMPRA" query-param="FPENCOMPRA"/>
			<with-param name="CPENCOMPRA" query-param="CPENCOMPRA"/>
			<with-param name="PPENCOMPRA" query-param="PPENCOMPRA"/>
			<with-param name="PDPENCOMPRA" query-param="PDPENCOMPRA"/>
			<with-param name="PIPENCOMPRA" query-param="PIPENCOMPRA"/>
			<with-param name="FULTCOTIZACION" query-param="FULTCOTIZACION"/>
			<with-param name="CULTCOTIZACION" query-param="CULTCOTIZACION"/>
			<with-param name="PRULTCOTIZACION" query-param="PRULTCOTIZACION"/>
			<with-param name="PDULTCOTIZACION" query-param="PDULTCOTIZACION"/>
			<with-param name="PIULTCOTIZACION" query-param="PIULTCOTIZACION"/>

		</call-query>
	</resource>

</data>