	<query id="getDevolutivosPagElemSerieDescripIniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, (CONCAT(NOMBRELARGO , DEVOLUTIVO.DESCRIPCION )) DESCRIPCION FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO AND DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA WHERE INVENTARIO.COMPANIA =:COMPANIA AND DEVOLUTIVO.PLACAANULADA IN (0) ORDER BY DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, INVENTARIO.COMPANIA) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
