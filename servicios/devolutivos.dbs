<data name="devolutivos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDevolutivosPagSeriesDevolutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TO_CHAR(DEVOLUTIVO.SERIE) SERIE, DEVOLUTIVO.SERIE SERIE1, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.RESPONSABLE, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, ESTADODEVOLUTIVO.DESCRIPCION NOMBREESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.MODELO, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(NOMBRELARGO, CONCAT(' ', DEVOLUTIVO.DESCRIPCION)) TXTNOM, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_RESPONSABLE, CASE WHEN DEVOLUTIVO.CIUDAD IS NOT NULL THEN CONCAT(DEPARTAMENTO.NOMBRE, CONCAT(',', CIUDAD.NOMBRE)) ELSE '' END UBICACION, DEVOLUTIVO.DIRECCION, U.CODIGO CODIGO_UBICACION, U.NOMBRE NOMBRE_UBICACION, '' PLACA_NIIF, DEVOLUTIVO.CENTRODECOSTO,DEVOLUTIVO.REFERENCIA_CNT FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL INNER JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO LEFT JOIN DEPARTAMENTO ON DEVOLUTIVO.PAIS = DEPARTAMENTO.PAIS AND DEVOLUTIVO.DEPARTAMENTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON DEVOLUTIVO.PAIS = CIUDAD.PAIS AND DEVOLUTIVO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND DEVOLUTIVO.CIUDAD = CIUDAD.CODIGO LEFT JOIN UBICACIONES U ON DEVOLUTIVO.COMPANIA = U.COMPANIA aNd DEVOLUTIVO.UBICACION = U.CODIGO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND INVENTARIO.IDENTIFICADOR IN ('P') ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.SERIEANTERIOR) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN SERIE1 IS NULL THEN ' ' ELSE UPPER(SERIE1) END) LIKE UPPER(CONCAT(:SERIE1, '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(:SERIEDEVOLUTIVO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","SERIE1":"$SERIE1","ELEMENTO":"$ELEMENTO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","VALOR":"$VALOR","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO","SERIEANTERIOR":"$SERIEANTERIOR","PLACAANULADA":"$PLACAANULADA(type:boolean)","MARCA":"$MARCA","MODELO":"$MODELO","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","TXTNOM":"$TXTNOM","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","UBICACION":"$UBICACION","DIRECCION":"$DIRECCION","CODIGO_UBICACION":"$CODIGO_UBICACION","NOMBRE_UBICACION":"$NOMBRE_UBICACION","PLACA_NIIF":"$PLACA_NIIF","CENTRODECOSTO":"$CENTRODECOSTO","REFERENCIA_CNT":"$REFERENCIA_CNT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="SERIE1" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/seriesdevolutivo/pag">
		<call-query href="getDevolutivosPagSeriesDevolutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="SERIE1" query-param="SERIE1"/>
			<with-param name="SERIEDEVOLUTIVO" query-param="SERIEDEVOLUTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumSeriesDevolutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TO_CHAR(DEVOLUTIVO.SERIE) SERIE, DEVOLUTIVO.SERIE SERIE1, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.RESPONSABLE, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, ESTADODEVOLUTIVO.DESCRIPCION NOMBREESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.MODELO, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(NOMBRELARGO, CONCAT(' ', DEVOLUTIVO.DESCRIPCION)) TXTNOM, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_RESPONSABLE, CASE WHEN DEVOLUTIVO.CIUDAD IS NOT NULL THEN CONCAT(DEPARTAMENTO.NOMBRE, CONCAT(',', CIUDAD.NOMBRE)) ELSE '' END UBICACION, DEVOLUTIVO.DIRECCION, U.CODIGO CODIGO_UBICACION, U.NOMBRE NOMBRE_UBICACION, '' PLACA_NIIF, DEVOLUTIVO.CENTRODECOSTO,DEVOLUTIVO.REFERENCIA_CNT FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL INNER JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO LEFT JOIN DEPARTAMENTO ON DEVOLUTIVO.PAIS = DEPARTAMENTO.PAIS AND DEVOLUTIVO.DEPARTAMENTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON DEVOLUTIVO.PAIS = CIUDAD.PAIS AND DEVOLUTIVO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND DEVOLUTIVO.CIUDAD = CIUDAD.CODIGO LEFT JOIN UBICACIONES U ON DEVOLUTIVO.COMPANIA = U.COMPANIA aNd DEVOLUTIVO.UBICACION = U.CODIGO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND INVENTARIO.IDENTIFICADOR IN ('P') ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.SERIEANTERIOR) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN SERIE1 IS NULL THEN ' ' ELSE UPPER(SERIE1) END) LIKE UPPER(CONCAT(:SERIE1, '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(:SERIEDEVOLUTIVO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="SERIE1" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/seriesdevolutivo/num">
		<call-query href="getDevolutivosNumSeriesDevolutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="SERIE1" query-param="SERIE1"/>
			<with-param name="SERIEDEVOLUTIVO" query-param="SERIEDEVOLUTIVO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagConSerieAnteriorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TO_CHAR(DEVOLUTIVO.SERIE) SERIE, DEVOLUTIVO.SERIE SERIE1, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.RESPONSABLE, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, ESTADODEVOLUTIVO.DESCRIPCION NOMBREESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(NOMBRELARGO, CONCAT(' ', DEVOLUTIVO.DESCRIPCION)) TXTNOM, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_RESPONSABLE, CASE WHEN DEVOLUTIVO.CIUDAD IS NOT NULL THEN CONCAT(DEPARTAMENTO.NOMBRE , CONCAT(',', CIUDAD.NOMBRE)) ELSE '' END UBICACION, DEVOLUTIVO.DIRECCION, '' PLACA_NIIF,DEVOLUTIVO.CENTRODECOSTO,DEVOLUTIVO.REFERENCIA_CNT FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL INNER JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO LEFT JOIN DEPARTAMENTO ON DEVOLUTIVO.PAIS = DEPARTAMENTO.PAIS AND DEVOLUTIVO.DEPARTAMENTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON DEVOLUTIVO.PAIS = CIUDAD.PAIS AND DEVOLUTIVO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND DEVOLUTIVO.CIUDAD = CIUDAD.CODIGO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.SERIEANTERIOR IS NOT NULL ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.SERIEANTERIOR) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN SERIE1 IS NULL THEN ' ' ELSE UPPER(SERIE1) END) LIKE UPPER(CONCAT(:SERIE1, '%')) AND (CASE WHEN SERIEANTERIOR IS NULL THEN ' ' ELSE UPPER(SERIEANTERIOR) END) LIKE UPPER(CONCAT(:SERIEANTERIOR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","SERIE1":"$SERIE1","ELEMENTO":"$ELEMENTO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","VALOR":"$VALOR","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO","SERIEANTERIOR":"$SERIEANTERIOR","PLACAANULADA":"$PLACAANULADA(type:boolean)","MARCA":"$MARCA","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","TXTNOM":"$TXTNOM","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","UBICACION":"$UBICACION","DIRECCION":"$DIRECCION","PLACA_NIIF":"$PLACA_NIIF","CENTRODECOSTO":"$CENTRODECOSTO","REFERENCIA_CNT":"$REFERENCIA_CNT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="SERIE1" sqlType="STRING"/>
		<param name="SERIEANTERIOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
