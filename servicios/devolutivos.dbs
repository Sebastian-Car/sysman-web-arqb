	<query id="getDevolutivosPagTodosPorSerieYElementoHijosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT (CONCAT(DEVOLUTIVO.SERIE,CONCAT( '-' , DEVOLUTIVO.ELEMENTO ))) EXPR1, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, INVENTARIO.NOMBRELARGO DESCRIPCION, ( COUNT(DEVOLUTIVO_1.COMPANIA) ) HIJOS FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEVOLUTIVO DEVOLUTIVO_1 ON DEVOLUTIVO.SERIE = DEVOLUTIVO_1.SERIE_PADRE AND DEVOLUTIVO.ELEMENTO = DEVOLUTIVO_1.ELEMENTO_PADRE AND DEVOLUTIVO.COMPANIA = DEVOLUTIVO_1.COMPANIA WHERE DEVOLUTIVO.COMPANIA =:COMPANIA AND DEVOLUTIVO.SE_PRESTA NOT IN (0) GROUP BY CONCAT(DEVOLUTIVO.SERIE,CONCAT( '-' , DEVOLUTIVO.ELEMENTO )), DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO) INI WHERE (CASE WHEN EXPR1 IS NULL THEN ' ' ELSE UPPER(EXPR1) END) LIKE UPPER(CONCAT(CONCAT('%',:EXPR1), '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN HIJOS IS NULL THEN ' ' ELSE UPPER(HIJOS) END) LIKE UPPER(CONCAT(:HIJOS, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXPR1":"$EXPR1","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","DESCRIPCION":"$DESCRIPCION","HIJOS":"$HIJOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EXPR1" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="HIJOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
