	<query id="updateDevolutivosPrestaElementoPadre" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET ELEMENTO_PADRE=:ELEMENTO_PADRE, SE_PRESTA=:SE_PRESTA, SERIE_PADRE=:SERIE_PADRE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE DEVOLUTIVO.COMPANIA= :KEY_COMPANIA AND DEVOLUTIVO.ELEMENTO= :KEY_ELEMENTO AND DEVOLUTIVO.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ELEMENTO_PADRE" sqlType="STRING"/>
		<param name="SE_PRESTA" sqlType="STRING"/>
		<param name="SERIE_PADRE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
