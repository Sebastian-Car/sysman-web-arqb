			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumListaPlacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEVOLUTIVO.SERIE, DEVOLUTIVO.VALOR, DEVOLUTIVO.SERIEDEVOLUTIVO  FROM DEVOLUTIVO WHERE DEVOLUTIVO.SERIE NOT IN (NVL(:PLACAUNO,-1),NVL(:PLACADOS,-1),NVL(:PLACATRES,-1))) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="PLACAUNO" sqlType="STRING"/>
