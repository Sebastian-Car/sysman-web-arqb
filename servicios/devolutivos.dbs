	<query id="getDevolutivosNumPordependenciaresponsablesinplacaanuladayauxQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) AS TOTAL FROM (SELECT DISTINCT D.SERIE, D.ELEMENTO, I.NOMBRELARGO, D.VALOR, D.SERIEDEVOLUTIVO, D.MARCA, D.DESCRIPCION, D.MODELO, D.DEPENDENCIA, D.RESPONSABLE, D.SUCURSAL_RESPONSABLE FROM D_MOVIMIENTO DM INNER JOIN DEVOLUTIVO D ON DM.COMPANIA = D.COMPANIA AND DM.ELEMENTO = D.ELEMENTO INNER JOIN INVENTARIO I ON DM.COMPANIA = I.COMPANIA AND DM.ELEMENTO = I.CODIGOELEMENTO INNER JOIN MOVIMIENTO M ON DM.COMPANIA = M.COMPANIA AND DM.TIPOMOVIMIENTO = M.TIPOMOVIMIENTO AND DM.MOVIMIENTO = M.NUMERO INNER JOIN TIPOMOVIMIENTO TM ON M.COMPANIA = TM.COMPANIA AND M.TIPOMOVIMIENTO = TM.CODIGO LEFT JOIN INVENTARIO_BODEGA IB ON DM.COMPANIA = IB.COMPANIA AND DM.ELEMENTO = IB.ELEMENTO AND DM.FUENTEDERECURSO = IB.FUENTEDERECURSO AND DM.REFERENCIA_CNT = IB.REFERENCIA AND DM.AUXILIAR = IB.AUXILIAR AND DM.CODIGOPROYECTO = IB.PROYECTO AND DM.CENTRODECOSTO = IB.CENTRODECOSTO AND DM.LOTE = IB.LOTE AND IB.BODEGA = :CAMP_BODEGA WHERE I.COMPANIA = :CAMP_COMPANIA AND I.TIENEMOVIMIENTO &lt;&gt; 0 AND I.INACTIVO = 0 AND TM.CLASE = 'E'AND TM.TIPOELEMENTO = :CAMP_TIPO AND DM.SALDO_PEPS > 0 AND DM.CODIGOPROYECTO = :CAMP_PROYECTO AND DM.FUENTEDERECURSO = :CAMP_FUENTER AND DM.REFERENCIA_CNT = :CAMP_REFERENCIA AND DM.AUXILIAR = :CAMP_AUXILIAR AND DM.CENTRODECOSTO = :CAMP_CENTRODECOSTO AND D.PLACAANULADA = 0 AND (D.ELEMENTO = :CAMP_ELEMENTO OR :CAMP_ELEMENTO IS NULL) AND (I.TIPO = :CAMP_TIPO OR :CAMP_CLASE_MOVIMIENTO NOT IN ('S','D','T')) AND M.RESPONSABLE_DESTINO = :CAMP_RESPONSABLE AND M.SUCURSAL_RESDESTINO = :CAMP_SUCURSAL_RESPONSABLE AND M.BODEGA_DESTINO = :CAMP_BODEGA AND (D.SERIE LIKE :SERIE || '%'OR D.ELEMENTO LIKE :ELEMENTO || '%'OR I.NOMBRELARGO LIKE :NOMBRELARGO || '%'OR D.VALOR LIKE :VALOR || '%'OR D.SERIEDEVOLUTIVO LIKE :SERIEDEVOLUTIVO || '%'OR D.DESCRIPCION LIKE :DESCRIPCION || '%'OR D.MODELO LIKE :MODELO || '%'OR D.RESPONSABLE LIKE :RESPONSABLE || '%'OR D.SUCURSAL_RESPONSABLE LIKE :SUCURSAL_RESPONSABLE || '%') )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CAMP_BODEGA" sqlType="STRING"/>
		<param name="CAMP_COMPANIA" sqlType="STRING"/>
		<param name="CAMP_TIPO" sqlType="STRING"/>
		<param name="CAMP_PROYECTO" sqlType="STRING"/>
		<param name="CAMP_FUENTER" sqlType="STRING"/>
		<param name="CAMP_REFERENCIA" sqlType="STRING"/>
		<param name="CAMP_AUXILIAR" sqlType="STRING"/>
		<param name="CAMP_CENTRODECOSTO" sqlType="STRING"/>
		<param name="CAMP_ELEMENTO" sqlType="STRING"/>
		<param name="CAMP_CLASE_MOVIMIENTO" sqlType="STRING"/>
		<param name="CAMP_RESPONSABLE" sqlType="STRING"/>
		<param name="CAMP_SUCURSAL_RESPONSABLE" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>

	</query>
