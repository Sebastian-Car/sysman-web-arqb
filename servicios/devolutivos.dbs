		<call-query href="getDevolutivosNumConserieanteriorcctoyrefinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="SERIE1" query-param="SERIE1"/>
			<with-param name="SERIEANTERIOR" query-param="SERIEANTERIOR"/>
			<with-param name="NOMBRECENTRO" query-param="NOMBRECENTRO"/>
			<with-param name="NOMBREREF" query-param="NOMBREREF"/>
			<with-param name="VALORIZACION" query-param="VALORIZACION"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagConseriedevolutivocctoyrefinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TO_CHAR(DEVOLUTIVO.SERIE) SERIE, DEVOLUTIVO.SERIE SERIE1, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.RESPONSABLE, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, ESTADODEVOLUTIVO.DESCRIPCION NOMBREESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(NOMBRELARGO , CONCAT( ' ' , DEVOLUTIVO.DESCRIPCION)) TXTNOM, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_RESPONSABLE, CASE WHEN DEVOLUTIVO.CIUDAD IS NOT NULL THEN CONCAT(DEPARTAMENTO.NOMBRE , CONCAT(', ' , CIUDAD.NOMBRE)) ELSE '' END UBICACION, DEVOLUTIVO.DIRECCION, '' PLACA_NIIF, D_MOVIMIENTO.CENTRODECOSTO, D_MOVIMIENTO.REFERENCIA_CNT,CENTRO_COSTO.NOMBRE NOMBRECENTRO, REFERENCIA.NOMBRE NOMBREREF, VALORIZACION FROM DEVOLUTIVO INNER JOIN D_MOVIMIENTO ON DEVOLUTIVO.COMPANIA = D_MOVIMIENTO.COMPANIA AND DEVOLUTIVO.ELEMENTO = D_MOVIMIENTO.ELEMENTO AND DEVOLUTIVO.SERIE = D_MOVIMIENTO.SERIE AND DEVOLUTIVO.MOVIMIENTOI = D_MOVIMIENTO.MOVIMIENTO AND DEVOLUTIVO.TIPOMOVIMIENTOI = D_MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL INNER JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO LEFT JOIN DEPARTAMENTO ON DEVOLUTIVO.PAIS = DEPARTAMENTO.PAIS AND DEVOLUTIVO.DEPARTAMENTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON DEVOLUTIVO.PAIS = CIUDAD.PAIS AND DEVOLUTIVO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND DEVOLUTIVO.CIUDAD = CIUDAD.CODIGO LEFT JOIN CENTRO_COSTO ON D_MOVIMIENTO.COMPANIA = CENTRO_COSTO.COMPANIA AND D_MOVIMIENTO.CENTRODECOSTO = CENTRO_COSTO.CODIGO AND EXTRACT(YEAR FROM D_MOVIMIENTO.FECHA) = CENTRO_COSTO.ANO LEFT JOIN REFERENCIA ON D_MOVIMIENTO.COMPANIA = REFERENCIA.COMPANIA AND D_MOVIMIENTO.REFERENCIA_CNT = REFERENCIA.CODIGO AND EXTRACT(YEAR FROM D_MOVIMIENTO.FECHA) = REFERENCIA.ANO WHERE DEVOLUTIVO.COMPANIA =:COMPANIA AND INVENTARIO.IDENTIFICADOR IN ('C') ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.SERIEANTERIOR) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN SERIE1 IS NULL THEN ' ' ELSE UPPER(SERIE1) END) LIKE UPPER(CONCAT(:SERIE1, '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(:SERIEDEVOLUTIVO, '%')) AND (CASE WHEN NOMBRECENTRO IS NULL THEN ' ' ELSE UPPER(NOMBRECENTRO) END) LIKE UPPER(CONCAT(:NOMBRECENTRO, '%')) AND (CASE WHEN NOMBREREF IS NULL THEN ' ' ELSE UPPER(NOMBREREF) END) LIKE UPPER(CONCAT(:NOMBREREF, '%')) AND (CASE WHEN VALORIZACION IS NULL THEN ' ' ELSE UPPER(VALORIZACION) END) LIKE UPPER(CONCAT(:VALORIZACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","SERIE1":"$SERIE1","ELEMENTO":"$ELEMENTO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","VALOR":"$VALOR","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO","SERIEANTERIOR":"$SERIEANTERIOR","PLACAANULADA":"$PLACAANULADA(type:boolean)","MARCA":"$MARCA","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","TXTNOM":"$TXTNOM","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","UBICACION":"$UBICACION","DIRECCION":"$DIRECCION","PLACA_NIIF":"$PLACA_NIIF","CENTRODECOSTO":"$CENTRODECOSTO","REFERENCIA_CNT":"$REFERENCIA_CNT","NOMBRECENTRO":"$NOMBRECENTRO","NOMBREREF":"$NOMBREREF","VALORIZACION":"$VALORIZACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="SERIE1" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
