			<with-param name="NIIF_VALOR_TOTAL" query-param="NIIF_VALOR_TOTAL"/>
			<with-param name="SALVAMENTO" query-param="SALVAMENTO"/>
			<with-param name="DETERIORO" query-param="DETERIORO"/>
			<with-param name="FDETERIOROEXTERNA" query-param="FDETERIOROEXTERNA"/>
			<with-param name="FDETERIOROINTERNA" query-param="FDETERIOROINTERNA"/>
			<with-param name="NIIF_VALOR_BASE" query-param="NIIF_VALOR_BASE"/>
			<with-param name="NIIF_VIDA_UTIL" query-param="NIIF_VIDA_UTIL"/>
			<with-param name="NIIF_FECHAFUNCIONAMIENTO" query-param="NIIF_FECHAFUNCIONAMIENTO"/>
			<with-param name="NIIF_TIPO_ACTIVO" query-param="NIIF_TIPO_ACTIVO"/>
			<with-param name="APLICA_NIIF" query-param="APLICA_NIIF"/>
			<with-param name="CUANTIAMIN" query-param="CUANTIAMIN"/>
