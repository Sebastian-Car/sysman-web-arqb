		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D.ELEMENTO ,D.SERIE ,I.NOMBRELARGO  FROM DEVOLUTIVO D INNER JOIN INVENTARIO I ON D.COMPANIA = I.COMPANIA AND D.ELEMENTO = I.CODIGOELEMENTO WHERE D.COMPANIA = :COMPANIA) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ))</sql>
