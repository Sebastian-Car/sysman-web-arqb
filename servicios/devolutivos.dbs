	<query id="getDevolutivosInnerInventarioActdepreciablePorSerieQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEVOLUTIVO.MESESVIDAUTILPLACA, ACTDEPRECIABLE.CODIGO, ACTDEPRECIABLE.MESESVIDAUTIL  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN ACTDEPRECIABLE ON INVENTARIO.TIPOACTIVO = ACTDEPRECIABLE.CODIGO WHERE DEVOLUTIVO.COMPANIA=:COMPANIA AND DEVOLUTIVO.SERIE =:SERIE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MESESVIDAUTILPLACA":"$MESESVIDAUTILPLACA","CODIGO":"$CODIGO","MESESVIDAUTIL":"$MESESVIDAUTIL(type:integer)"}]}}		</result>
