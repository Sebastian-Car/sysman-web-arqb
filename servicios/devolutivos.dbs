			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="updateDevolutivosEspecificacionPlacas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET SERIEDEVOLUTIVO=:SERIEDEVOLUTIVO, MARCA=:MARCA, MODELO=:MODELO, DESCRIPCION=:DESCRIPCION, ESTADO=:ESTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEVOLUTIVO.COMPANIA= :KEY_COMPANIA AND DEVOLUTIVO.ELEMENTO= :KEY_ELEMENTO AND DEVOLUTIVO.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/especificacionplacas">
		<call-query href="updateDevolutivosEspecificacionPlacas">
			<with-param name="SERIEDEVOLUTIVO" query-param="SERIEDEVOLUTIVO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="MODELO" query-param="MODELO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPorElementoYSeriePadreQuery"  useConfig="sysmandsunist">
