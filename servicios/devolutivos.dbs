	<query id="getDevolutivosPagTodosPorCompaniaPrestamoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEVOLUTIVO.COMPANIA, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, DEVOLUTIVO.PLACA, DEVOLUTIVO.DESCRIPCION, INVENTARIO.NOMBRELARGO, DEPENDENCIA.NOMBRE DEPENDENCIA,(CASE DEVOLUTIVO.SE_PRESTA WHEN 0 THEN 'false' ELSE 'true' END) SE_PRESTA, DEVOLUTIVO.ELEMENTO_PADRE, DEVOLUTIVO.SERIE_PADRE  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON(DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO) INNER JOIN DEPENDENCIA ON(DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO) WHERE DEVOLUTIVO.COMPANIA = :COMPANIA ORDER BY DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN SE_PRESTA IS NULL THEN ' ' ELSE UPPER(SE_PRESTA) END)  LIKE UPPER(:SE_PRESTA || '%')  AND (CASE WHEN ELEMENTO_PADRE IS NULL THEN ' ' ELSE UPPER(ELEMENTO_PADRE) END)  LIKE UPPER(:ELEMENTO_PADRE || '%')  AND (CASE WHEN SERIE_PADRE IS NULL THEN ' ' ELSE UPPER(SERIE_PADRE) END)  LIKE UPPER(:SERIE_PADRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","PLACA":"$PLACA","DESCRIPCION":"$DESCRIPCION","NOMBRELARGO":"$NOMBRELARGO","DEPENDENCIA":"$DEPENDENCIA","SE_PRESTA":"$SE_PRESTA(type:boolean)","ELEMENTO_PADRE":"$ELEMENTO_PADRE","SERIE_PADRE":"$SERIE_PADRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="SE_PRESTA" sqlType="STRING"/>
		<param name="ELEMENTO_PADRE" sqlType="STRING"/>
		<param name="SERIE_PADRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
