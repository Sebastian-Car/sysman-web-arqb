	<query id="updateDevolutivosCambiarestado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET ESTADO = :ESTADO,  MODIFIED_BY=:MODIFIED_BY,  DATE_MODIFIED = :DATE_MODIFIED  WHERE COMPANIA = :COMPANIA  AND ELEMENTO = :ELEMENTO AND SERIE = :SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/cambiarestado">
