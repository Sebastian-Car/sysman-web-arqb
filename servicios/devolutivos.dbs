	<query id="getDevolutivosNumVertrazabilidadplacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT D_MOVIMIENTO.COMPANIA, CONCAT(CONCAT(D_MOVIMIENTO.TIPOMOVIMIENTO, ' / '), TIPOMOVIMIENTO.NOMBRE) TIPO_MOVIMIENTO, D_MOVIMIENTO.MOVIMIENTO, D_MOVIMIENTO.ELEMENTO, D_MOVIMIENTO.SERIE, TO_CHAR(D_MOVIMIENTO.FECHA, 'DD/MM/YYYY') FECHA, TO_CHAR(D_MOVIMIENTO.HORA, 'HH24:MI:SS') HORA, (CASE D_MOVIMIENTO.IND_REG WHEN 0 THEN 'No' ELSE 'Si' END) REG, MOVIMIENTO.RESPONSABLE_DESTINO RESPONSABLE, TERCERO.NOMBRE NOMBRE_RESPONSABLE, MOVIMIENTO.DEPENDENCIA_DESTINO DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, D_MOVIMIENTO.VALORUNITARIO, MOVIMIENTO.DESCRIPCION FROM DEVOLUTIVO INNER JOIN D_MOVIMIENTO ON DEVOLUTIVO.COMPANIA = D_MOVIMIENTO.COMPANIA AND DEVOLUTIVO.SERIE = D_MOVIMIENTO.SERIE AND DEVOLUTIVO.ELEMENTO = D_MOVIMIENTO.ELEMENTO INNER JOIN MOVIMIENTO ON D_MOVIMIENTO.COMPANIA = MOVIMIENTO.COMPANIA AND D_MOVIMIENTO.MOVIMIENTO = MOVIMIENTO.NUMERO AND D_MOVIMIENTO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON D_MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO LEFT JOIN DEPENDENCIA ON MOVIMIENTO.COMPANIA = DEPENDENCIA.COMPANIA AND MOVIMIENTO.DEPENDENCIA_DESTINO = DEPENDENCIA.CODIGO LEFT JOIN TERCERO ON MOVIMIENTO.COMPANIA = TERCERO.COMPANIA AND MOVIMIENTO.RESPONSABLE_DESTINO = TERCERO.NIT AND MOVIMIENTO.SUCURSAL_RESDESTINO = TERCERO.SUCURSAL WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND D_MOVIMIENTO.SERIE = :PLACA AND TIPOMOVIMIENTO.TIPOELEMENTO &lt;&gt; 'C' ORDER BY D_MOVIMIENTO.COMPANIA, TO_DATE(CONCAT(CONCAT(TO_CHAR(D_MOVIMIENTO.FECHA, 'DD/MM/YYYY'), ' '), TO_CHAR(D_MOVIMIENTO.HORA, ' HH24:MI:SS')), 'DD/MM/YYYY HH24:MI:SS')) INI WHERE (CASE WHEN TIPO_MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPO_MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_MOVIMIENTO), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END) LIKE UPPER(CONCAT(:HORA, '%')) AND (CASE WHEN REG IS NULL THEN ' ' ELSE UPPER(REG) END) LIKE UPPER(CONCAT(:REG, '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(:RESPONSABLE, '%')) AND (CASE WHEN NOMBRE_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RESPONSABLE), '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEPENDENCIA), '%')) AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END) LIKE UPPER(CONCAT(:VALORUNITARIO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
