	<query id="updateDevolutivosVidaUtil" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET MESESVIDAUTILPLACA = :MESESVIDAUTILPLACA ,NIIF_VALOR_TOTAL = :NIIF_VALOR_TOTAL ,SALVAMENTO = :SALVAMENTO ,DETERIORO = :DETERIORO, FDETERIOROEXTERNA = :FDETERIOROEXTERNA, FDETERIOROINTERNA = :FDETERIOROINTERNA,NIIF_VALOR_BASE = :NIIF_VALOR_BASE , NIIF_VALORBASE = :NIIF_VALOR_TOTAL , NIIF_VIDA_UTIL = :NIIF_VIDA_UTIL ,NIIF_FECHAFUNCIONAMIENTO = TO_DATE(:NIIF_FECHAFUNCIONAMIENTO,'DD/MM/YYYY HH24:MI:SS') ,NIIF_TIPO_ACTIVO = :NIIF_TIPO_ACTIVO ,APLICA_NIIF = :APLICA_NIIF , CUANTIAMIN = :CUANTIAMIN, DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') ,MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :KEY_COMPANIA AND ELEMENTO = :KEY_ELEMENTO AND SERIE = :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MESESVIDAUTILPLACA" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="SALVAMENTO" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="FDETERIOROEXTERNA" sqlType="STRING"/>
		<param name="FDETERIOROINTERNA" sqlType="STRING"/>
		<param name="NIIF_VALOR_BASE" sqlType="STRING"/>
		<param name="NIIF_VIDA_UTIL" sqlType="STRING"/>
		<param name="NIIF_FECHAFUNCIONAMIENTO" sqlType="STRING"/>
		<param name="NIIF_TIPO_ACTIVO" sqlType="STRING"/>
		<param name="APLICA_NIIF" sqlType="STRING"/>
		<param name="CUANTIAMIN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
