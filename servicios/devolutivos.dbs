	<query id="getDevolutivosConsultaporplacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT U.NIIF_VLRDEPRECIACION, DEVOLUTIVO.NIIF_DEPACUMULADA, DEVOLUTIVO.DETERIORO, DEVOLUTIVO.NIIF_VIDA_UTIL, DEVOLUTIVO.NIIF_VLRLIBROS, NVL(C.VALOR_CORRECION,0) VALOR_CORRECION, VALORIZACION FROM DEVOLUTIVO INNER JOIN INVENTARIO I ON DEVOLUTIVO.COMPANIA = I.COMPANIA AND DEVOLUTIVO.ELEMENTO = I.CODIGOELEMENTO LEFT JOIN ( SELECT * FROM ( SELECT D.*, ROW_NUMBER() OVER ( PARTITION BY COMPANIA, ELEMENTO, SERIE ORDER BY PERIODO DESC ) AS RN FROM DEPRECIAR D WHERE COMPANIA = :COMPANIA AND SERIE = :PLACA AND ELEMENTO = :ELEMENTO ) X WHERE RN = 1 ) U ON U.COMPANIA = DEVOLUTIVO.COMPANIA AND U.ELEMENTO = DEVOLUTIVO.ELEMENTO AND U.SERIE = DEVOLUTIVO.SERIE LEFT JOIN ( SELECT DM.COMPANIA, DM.ELEMENTO, DM.SERIE, SUM(NVL(DM.VALORUNITARIO,0)) AS VALOR_CORRECION FROM D_MOVIMIENTO DM INNER JOIN MOVIMIENTO M ON DM.COMPANIA = M.COMPANIA AND DM.MOVIMIENTO = M.NUMERO AND DM.TIPOMOVIMIENTO = M.TIPOMOVIMIENTO INNER JOIN TIPOMOVIMIENTO TM ON DM.COMPANIA = TM.COMPANIA AND DM.TIPOMOVIMIENTO = TM.CODIGO WHERE DM.COMPANIA = :COMPANIA AND DM.SERIE = :PLACA AND DM.ELEMENTO = :ELEMENTO AND TM.CONCEPTO IN ('CR') GROUP BY DM.COMPANIA, DM.ELEMENTO, DM.SERIE ) C ON C.COMPANIA = DEVOLUTIVO.COMPANIA AND C.ELEMENTO = DEVOLUTIVO.ELEMENTO AND C.SERIE = DEVOLUTIVO.SERIE WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.SERIE = :PLACA AND DEVOLUTIVO.ELEMENTO = :ELEMENTO AND I.IDENTIFICADOR IN ('P')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIIF_VLRDEPRECIACION":"$NIIF_VLRDEPRECIACION","NIIF_DEPACUMULADA":"$NIIF_DEPACUMULADA","DETERIORO":"$DETERIORO","NIIF_VIDA_UTIL":"$NIIF_VIDA_UTIL","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS","VALOR_CORRECION":"$VALOR_CORRECION(type:integer)","VALORIZACION":"$VALORIZACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/consultaporplaca">
		<call-query href="getDevolutivosConsultaporplacaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagVertrazabilidadplacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D_MOVIMIENTO.COMPANIA, CONCAT(CONCAT(D_MOVIMIENTO.TIPOMOVIMIENTO, ' / '), TIPOMOVIMIENTO.NOMBRE) TIPO_MOVIMIENTO, D_MOVIMIENTO.MOVIMIENTO, D_MOVIMIENTO.ELEMENTO, D_MOVIMIENTO.SERIE, TO_CHAR(D_MOVIMIENTO.FECHA, 'DD/MM/YYYY') FECHA, TO_CHAR(D_MOVIMIENTO.HORA, 'HH24:MI:SS') HORA, (CASE D_MOVIMIENTO.IND_REG WHEN 0 THEN 'No' ELSE 'Si' END) REG, MOVIMIENTO.RESPONSABLE_DESTINO RESPONSABLE, TERCERO.NOMBRE NOMBRE_RESPONSABLE, MOVIMIENTO.DEPENDENCIA_DESTINO DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, D_MOVIMIENTO.VALORUNITARIO, MOVIMIENTO.DESCRIPCION FROM DEVOLUTIVO INNER JOIN D_MOVIMIENTO ON DEVOLUTIVO.COMPANIA = D_MOVIMIENTO.COMPANIA AND DEVOLUTIVO.SERIE = D_MOVIMIENTO.SERIE AND DEVOLUTIVO.ELEMENTO = D_MOVIMIENTO.ELEMENTO INNER JOIN MOVIMIENTO ON D_MOVIMIENTO.COMPANIA = MOVIMIENTO.COMPANIA AND D_MOVIMIENTO.MOVIMIENTO = MOVIMIENTO.NUMERO AND D_MOVIMIENTO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON D_MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO LEFT JOIN DEPENDENCIA ON MOVIMIENTO.COMPANIA = DEPENDENCIA.COMPANIA AND MOVIMIENTO.DEPENDENCIA_DESTINO = DEPENDENCIA.CODIGO LEFT JOIN TERCERO ON MOVIMIENTO.COMPANIA = TERCERO.COMPANIA AND MOVIMIENTO.RESPONSABLE_DESTINO = TERCERO.NIT AND MOVIMIENTO.SUCURSAL_RESDESTINO = TERCERO.SUCURSAL WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND D_MOVIMIENTO.SERIE = :PLACA AND TIPOMOVIMIENTO.TIPOELEMENTO &lt;&gt; 'C' ORDER BY D_MOVIMIENTO.COMPANIA, TO_DATE(CONCAT(CONCAT(TO_CHAR(D_MOVIMIENTO.FECHA, 'DD/MM/YYYY'), ' '), TO_CHAR(D_MOVIMIENTO.HORA, ' HH24:MI:SS')), 'DD/MM/YYYY HH24:MI:SS')) INI WHERE (CASE WHEN TIPO_MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPO_MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_MOVIMIENTO), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END) LIKE UPPER(CONCAT(:HORA, '%')) AND (CASE WHEN REG IS NULL THEN ' ' ELSE UPPER(REG) END) LIKE UPPER(CONCAT(:REG, '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(:RESPONSABLE, '%')) AND (CASE WHEN NOMBRE_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RESPONSABLE), '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEPENDENCIA), '%')) AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END) LIKE UPPER(CONCAT(:VALORUNITARIO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%'))  ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_MOVIMIENTO":"$TIPO_MOVIMIENTO","MOVIMIENTO":"$MOVIMIENTO","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","FECHA":"$FECHA","HORA":"$HORA","REG":"$REG","RESPONSABLE":"$RESPONSABLE","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","VALORUNITARIO":"$VALORUNITARIO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="TIPO_MOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="REG" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE_RESPONSABLE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
