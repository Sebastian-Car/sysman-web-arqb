	<query id="getDevolutivosPagTodosPorplacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, TRIM(CONCAT(NOMBRELARGO , DEVOLUTIVO.DESCRIPCION)) DESCRIPCION, DEVOLUTIVO.PLACA FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE INVENTARIO.COMPANIA =:COMPANIA AND DEVOLUTIVO.PLACAANULADA IN (0) ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.COMPANIA) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END) LIKE UPPER(CONCAT(CONCAT('%',:PLACA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","DESCRIPCION":"$DESCRIPCION","PLACA":"$PLACA"}]}}		</result>
