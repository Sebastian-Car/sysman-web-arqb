	<query id="getDevolutivosPagElementonombreporcompaniafinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO NOMBRE  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.ELEMENTO &gt;= :CODIGOELEMENTO GROUP BY ELEMENTO, INVENTARIO.NOMBRELARGO ORDER BY ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
