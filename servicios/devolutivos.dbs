	<query id="updateDevolutivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET ESTADO=:ESTADO, REFERENCIA=:REFERENCIA, MARCA=:MARCA, MODELO=:MODELO, SERIEDEVOLUTIVO=:SERIEDEVOLUTIVO, SERIEANTERIOR=:SERIEANTERIOR, MEDIDA=:MEDIDA, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEVOLUTIVO.COMPANIA= :KEY_COMPANIA AND DEVOLUTIVO.ELEMENTO= :KEY_ELEMENTO AND DEVOLUTIVO.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="SERIEANTERIOR" sqlType="STRING"/>
		<param name="MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos">
		<call-query href="updateDevolutivos">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="MODELO" query-param="MODELO"/>
			<with-param name="SERIEDEVOLUTIVO" query-param="SERIEDEVOLUTIVO"/>
			<with-param name="SERIEANTERIOR" query-param="SERIEANTERIOR"/>
			<with-param name="MEDIDA" query-param="MEDIDA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagElementosNombreCortoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRECORTO NOMELEMENTO  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND INVENTARIO.TIPO NOT IN 'C' ORDER BY INVENTARIO.NOMBRECORTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMELEMENTO) END)  LIKE UPPER( '%' || :NOMELEMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","NOMELEMENTO":"$NOMELEMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMELEMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/elementosnombrecorto/pag">
		<call-query href="getDevolutivosPagElementosNombreCortoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMELEMENTO" query-param="NOMELEMENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumElementosNombreCortoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRECORTO NOMELEMENTO  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND INVENTARIO.TIPO NOT IN 'C' ORDER BY INVENTARIO.NOMBRECORTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMELEMENTO) END)  LIKE UPPER( '%' || :NOMELEMENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/elementosnombrecorto/num">
