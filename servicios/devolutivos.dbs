	<query id="getDevolutivosPagEspecificacionPlacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.COMPANIA , DEVOLUTIVO.ELEMENTO , DEVOLUTIVO.SERIE , DEVOLUTIVO.SERIE PLACASERIE , INVENTARIO.NOMBRELARGO NOMBELEMENTO , DEVOLUTIVO.VALOR , DEVOLUTIVO.SERIEDEVOLUTIVO , DEVOLUTIVO.MARCA , DEVOLUTIVO.MODELO , DEVOLUTIVO.DESCRIPCION , DEVOLUTIVO.ESTADO , ESTADODEVOLUTIVO.DESCRIPCION DESCESTADO FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO LEFT JOIN ESTADODEVOLUTIVO ON ESTADODEVOLUTIVO.ESTADO = DEVOLUTIVO.ESTADO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.PLACAANULADA IN(0)) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN PLACASERIE IS NULL THEN ' ' ELSE UPPER(PLACASERIE) END) LIKE UPPER(CONCAT(CONCAT('%',:PLACASERIE), '%')) AND (CASE WHEN NOMBELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBELEMENTO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIEDEVOLUTIVO), '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(CONCAT('%',:MARCA), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODELO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","PLACASERIE":"$PLACASERIE","NOMBELEMENTO":"$NOMBELEMENTO","VALOR":"$VALOR","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","MARCA":"$MARCA","MODELO":"$MODELO","DESCRIPCION":"$DESCRIPCION","ESTADO":"$ESTADO","DESCESTADO":"$DESCESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="PLACASERIE" sqlType="STRING"/>
		<param name="NOMBELEMENTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/especificacionplacas/pag">
		<call-query href="getDevolutivosPagEspecificacionPlacasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="PLACASERIE" query-param="PLACASERIE"/>
			<with-param name="NOMBELEMENTO" query-param="NOMBELEMENTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="SERIEDEVOLUTIVO" query-param="SERIEDEVOLUTIVO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="MODELO" query-param="MODELO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumEspecificacionPlacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEVOLUTIVO.COMPANIA , DEVOLUTIVO.ELEMENTO , DEVOLUTIVO.SERIE , DEVOLUTIVO.SERIE PLACASERIE , INVENTARIO.NOMBRELARGO NOMBELEMENTO , DEVOLUTIVO.VALOR , DEVOLUTIVO.SERIEDEVOLUTIVO , DEVOLUTIVO.MARCA , DEVOLUTIVO.MODELO , DEVOLUTIVO.DESCRIPCION , DEVOLUTIVO.ESTADO , ESTADODEVOLUTIVO.DESCRIPCION DESCESTADO FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO LEFT JOIN ESTADODEVOLUTIVO ON ESTADODEVOLUTIVO.ESTADO = DEVOLUTIVO.ESTADO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.PLACAANULADA IN(0)) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN PLACASERIE IS NULL THEN ' ' ELSE UPPER(PLACASERIE) END) LIKE UPPER(CONCAT(CONCAT('%',:PLACASERIE), '%')) AND (CASE WHEN NOMBELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBELEMENTO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIEDEVOLUTIVO), '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(CONCAT('%',:MARCA), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODELO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="PLACASERIE" sqlType="STRING"/>
		<param name="NOMBELEMENTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/especificacionplacas/num">
