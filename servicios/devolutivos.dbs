	<query id="getDevolutivosPagTodosPorSerieYSePrestaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DESCRIPCION, COUNT(DEVOLUTIVO_1.COMPANIA) HIJOS  FROM DEVOLUTIVO LEFT JOIN DEVOLUTIVO DEVOLUTIVO_1 ON DEVOLUTIVO.COMPANIA = DEVOLUTIVO_1.COMPANIA AND DEVOLUTIVO.ELEMENTO = DEVOLUTIVO_1.ELEMENTO_PADRE AND DEVOLUTIVO.SERIE = DEVOLUTIVO_1.SERIE_PADRE WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.SE_PRESTA NOT IN (0) GROUP BY DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DESCRIPCION) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN HIJOS IS NULL THEN ' ' ELSE UPPER(HIJOS) END)  LIKE UPPER(:HIJOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
