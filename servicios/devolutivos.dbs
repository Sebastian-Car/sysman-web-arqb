	<query id="updateDevolutivosValorBaseNiif" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET NIIF_VALOR_BASE = NIIF_VALOR_TOTAL, NIIF_VALORBASE = NIIF_VALOR_TOTAL, DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA AND FECHAADQUISICION &lt; TO_DATE(:FECHACORTE,'DD/MM/YYYY HH24:MI:SS') AND NIIF_VALORBASE&lt;&gt;NIIF_VALOR_TOTAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/valorbaseniif">
		<call-query href="updateDevolutivosValorBaseNiif">
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>

		</call-query>
	</resource>
	<query id="updateDevolutivosFechaFuncionamientoNiif" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET NIIF_FECHAFUNCIONAMIENTO = CASE WHEN FECHAADQUISICION &lt;= TO_DATE(:FECHACORTE,'DD/MM/YYYY HH24:MI:SS') THEN TO_DATE(:FECHACORTE,'DD/MM/YYYY HH24:MI:SS')+1  ELSE FECHAADQUISICION END, DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA AND NIIF_FECHAFUNCIONAMIENTO IS NULL OR NIIF_FECHAFUNCIONAMIENTO &lt;= TO_DATE(:FECHACORTE,'DD/MM/YYYY HH24:MI:SS')</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/fechafuncionamientoniif">
		<call-query href="updateDevolutivosFechaFuncionamientoNiif">
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagVidaUtilQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.COMPANIA , DEVOLUTIVO.ELEMENTO , DEVOLUTIVO.SERIE , DEVOLUTIVO.VALOR ,(TO_CHAR(DEVOLUTIVO.FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS')) FECHAADQUISICION, DEVOLUTIVO.TIPOMOVIMIENTOI , DEVOLUTIVO.MOVIMIENTOI , DEVOLUTIVO.MESESVIDAUTILPLACA , DEVOLUTIVO.DEPACUMULADA , DEVOLUTIVO.VLRLIBROS , INVENTARIO.NOMBRELARGO FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN (SELECT DEPRECIAR.COMPANIA, DEPRECIAR.ELEMENTO, DEPRECIAR.SERIE, MAX(DEPRECIAR.PERIODO) PERIODO FROM DEVOLUTIVO INNER JOIN DEPRECIAR ON DEVOLUTIVO.COMPANIA = DEPRECIAR.COMPANIA AND DEVOLUTIVO.ELEMENTO = DEPRECIAR.ELEMENTO AND DEVOLUTIVO.SERIE = DEPRECIAR.SERIE WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEPRECIAR.PERIODO &lt;= TO_DATE(:FECHACORTE, 'DD/MM/YYYY') GROUP BY DEPRECIAR.COMPANIA, DEPRECIAR.ELEMENTO, DEPRECIAR.SERIE) DEPRECIAR ON DEVOLUTIVO.COMPANIA = DEPRECIAR.COMPANIA AND DEVOLUTIVO.ELEMENTO = DEPRECIAR.ELEMENTO AND DEVOLUTIVO.SERIE = DEPRECIAR.SERIE WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.FECHAADQUISICION &lt; TO_DATE(:FECHACORTE,'DD/MM/YYYY') AND DEVOLUTIVO.PLACAANULADA IN (0) ORDER BY DEVOLUTIVO.COMPANIA, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN FECHAADQUISICION IS NULL THEN ' ' ELSE UPPER(FECHAADQUISICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAADQUISICION), '%')) AND (CASE WHEN TIPOMOVIMIENTOI IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTOI) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTOI, '%')) AND (CASE WHEN MOVIMIENTOI IS NULL THEN ' ' ELSE UPPER(MOVIMIENTOI) END) LIKE UPPER(CONCAT(:MOVIMIENTOI, '%')) AND (CASE WHEN MESESVIDAUTILPLACA IS NULL THEN ' ' ELSE UPPER(MESESVIDAUTILPLACA) END) LIKE UPPER(CONCAT(:MESESVIDAUTILPLACA, '%')) AND (CASE WHEN DEPACUMULADA IS NULL THEN ' ' ELSE UPPER(DEPACUMULADA) END) LIKE UPPER(CONCAT(:DEPACUMULADA, '%')) AND (CASE WHEN VLRLIBROS IS NULL THEN ' ' ELSE UPPER(VLRLIBROS) END) LIKE UPPER(CONCAT(:VLRLIBROS, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","VALOR":"$VALOR","FECHAADQUISICION":"$FECHAADQUISICION","TIPOMOVIMIENTOI":"$TIPOMOVIMIENTOI","MOVIMIENTOI":"$MOVIMIENTOI","MESESVIDAUTILPLACA":"$MESESVIDAUTILPLACA","DEPACUMULADA":"$DEPACUMULADA","VLRLIBROS":"$VLRLIBROS","NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHAADQUISICION" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTOI" sqlType="STRING"/>
		<param name="MOVIMIENTOI" sqlType="STRING"/>
		<param name="MESESVIDAUTILPLACA" sqlType="STRING"/>
		<param name="DEPACUMULADA" sqlType="STRING"/>
		<param name="VLRLIBROS" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
