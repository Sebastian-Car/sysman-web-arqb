	<query id="getDevolutivosTodosPorCompaniaSucursalNitTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT DEVOLUTIVO.RESPONSABLE, TERCERO.NOMBRE  FROM DEVOLUTIVO LEFT JOIN RESPONSABLE ON DEVOLUTIVO.COMPANIA = RESPONSABLE.COMPANIA AND DEVOLUTIVO.RESPONSABLE = RESPONSABLE.CEDULA AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = RESPONSABLE.SUCURSAL INNER JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL WHERE DEVOLUTIVO.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRE":"$NOMBRE"}]}}		</result>
