	<query id="getDevolutivosPagSeriesDeElementosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRECORTO NOMSERIE  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO AND DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.ELEMENTO = :ELEMENTO AND INVENTARIO.TIPO NOT IN 'C' ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER( '%' || :SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN NOMSERIE IS NULL THEN ' ' ELSE UPPER(NOMSERIE) END)  LIKE UPPER( '%' || :NOMSERIE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","NOMSERIE":"$NOMSERIE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NOMSERIE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
