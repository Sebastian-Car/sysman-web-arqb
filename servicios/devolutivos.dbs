	<query id="getDevolutivosPagListaPlacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEVOLUTIVO.SERIE, DEVOLUTIVO.VALOR, DEVOLUTIVO.SERIEDEVOLUTIVO  FROM DEVOLUTIVO WHERE DEVOLUTIVO.SERIE NOT IN (NVL(:PLACAUNO,-1),NVL(:PLACADOS,-1),NVL(:PLACATRES,-1))) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","VALOR":"$VALOR","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO"}]}}		</result>
		<param name="PLACAUNO" sqlType="STRING"/>
		<param name="PLACADOS" sqlType="STRING"/>
		<param name="PLACATRES" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
