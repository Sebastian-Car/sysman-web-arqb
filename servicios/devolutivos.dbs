	<query id="getDevolutivosNumSeleccionplacaspormovQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIEDEVOLUTIVO, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.VALOR, DEVOLUTIVO.MARCA, PLACA, DEVOLUTIVO.DESCRIPCION, DEVOLUTIVO.MODELO FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.DEPENDENCIA = :DEPENDENCIA AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = :SUCURSAL AND DEVOLUTIVO.RESPONSABLE = :RESPONSABLE AND DEVOLUTIVO.PLACAANULADA IN ( 0) AND (CASE WHEN :CLASE IN ( 'E' ) OR :CLASE NOT IN ( 'D', 'T' ) THEN INVENTARIO.TIPO ELSE :TIPOELEMENTO END ) = :TIPOELEMENTO ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO) INI WHERE (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(:SERIEDEVOLUTIVO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(:NOMBRELARGO, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(:MARCA, '%')) AND (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END) LIKE UPPER(CONCAT(:PLACA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(:MODELO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
