			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, (CONCAT(INVENTARIO.NOMBRELARGO, DEVOLUTIVO.DESCRIPCION )) DESCRIPCION FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO AND DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA WHERE INVENTARIO.COMPANIA =:COMPANIA AND DEVOLUTIVO.PLACAANULADA IN ( 0 ) ORDER BY DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, INVENTARIO.COMPANIA) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
