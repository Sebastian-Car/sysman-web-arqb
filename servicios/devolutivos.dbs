	<query id="updateDevolutivosPlacaPorElemento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET PLACA = :PLACA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED = :DATE_MODIFIED WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PLACA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/placaporelemento">
		<call-query href="updateDevolutivosPlacaPorElemento">
			<with-param name="PLACA" query-param="PLACA"/>
