	<query id="getDevolutivosPagDepreciacionacumuladaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT D.SERIE, D.VALOR, D.NIIF_VIDA_UTIL, DP.NIIF_VLRLIBROS FROM DEVOLUTIVO D INNER JOIN DEPRECIAR DP ON D.COMPANIA = DP.COMPANIA AND D.ELEMENTO = DP.ELEMENTO AND D.SERIE = DP.SERIE WHERE D.COMPANIA = :COMPANIA AND D.ELEMENTO = :ELEMENTO AND D.PLACAANULADA IN (0) AND DP.NIIF_VLRACUMULADO = 0 UNION ALL SELECT DISTINCT D.SERIE, D.VALOR, D.NIIF_VIDA_UTIL, DP.NIIF_VLRLIBROS FROM DEVOLUTIVO D LEFT JOIN DEPRECIAR DP ON D.COMPANIA = DP.COMPANIA AND D.ELEMENTO = DP.ELEMENTO AND D.SERIE = DP.SERIE WHERE D.COMPANIA = :COMPANIA AND D.ELEMENTO = :ELEMENTO AND D.PLACAANULADA IN (0) AND D.APLICA_NIIF = -1 AND D.NIIF_VIDA_UTIL &gt; 0 AND DP.COMPANIA IS NULL) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN NIIF_VIDA_UTIL IS NULL THEN ' ' ELSE UPPER(NIIF_VIDA_UTIL) END) LIKE UPPER(CONCAT(:NIIF_VIDA_UTIL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","VALOR":"$VALOR","NIIF_VIDA_UTIL":"$NIIF_VIDA_UTIL","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="NIIF_VIDA_UTIL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
