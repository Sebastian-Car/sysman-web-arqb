	<query id="getDevolutivosPagPorserieymarcaQuery"  useConfig="sysmandsunist">
                <sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT TO_CHAR(SERIE) SERIE, MARCA FROM DEVOLUTIVO WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND PLACAANULADA = 0 ORDER BY SERIE) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(:MARCA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
                <result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","MARCA":"$MARCA"}]}}                </result>
                <param name="COMPANIA" sqlType="STRING"/>
                <param name="ELEMENTO" sqlType="STRING"/>
                <param name="SERIE" sqlType="STRING"/>
                <param name="MARCA" sqlType="STRING"/>
                <param name="PAGINICIO" sqlType="INTEGER"/>
                <param name="PAGTAMANIO" sqlType="INTEGER"/>
        </query>
        <resource method="GET" path="devolutivos/porserieymarca/pag">
                <call-query href="getDevolutivosPagPorserieymarcaQuery">
                        <with-param name="COMPANIA" query-param="COMPANIA"/>
                        <with-param name="ELEMENTO" query-param="ELEMENTO"/>
                        <with-param name="SERIE" query-param="SERIE"/>
                        <with-param name="MARCA" query-param="MARCA"/>
                        <with-param name="PAGINICIO" query-param="PAGINICIO"/>
                        <with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>
                </call-query>
        </resource>
        <query id="getDevolutivosNumPorserieymarcaQuery"  useConfig="sysmandsunist">
                <sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT TO_CHAR(SERIE) SERIE, MARCA FROM DEVOLUTIVO WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND PLACAANULADA = 0 ORDER BY SERIE) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(:MARCA, '%')) ) A) FIN</sql>
                <result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}                </result>
                <param name="COMPANIA" sqlType="STRING"/>
                <param name="ELEMENTO" sqlType="STRING"/>
                <param name="SERIE" sqlType="STRING"/>
                <param name="MARCA" sqlType="STRING"/>
        </query>
        <resource method="GET" path="devolutivos/porserieymarca/num">
                <call-query href="getDevolutivosNumPorserieymarcaQuery">
                        <with-param name="COMPANIA" query-param="COMPANIA"/>
                        <with-param name="ELEMENTO" query-param="ELEMENTO"/>
                        <with-param name="SERIE" query-param="SERIE"/>
                        <with-param name="MARCA" query-param="MARCA"/>
                </call-query>
        </resource>
</data>