	<query id="updateDevolutivosUpdateindicadordeterioro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET APLICA_DETERIORO=:APLICA_DETERIORO, APLICA_REEXPRESION=:APLICA_REEXPRESION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEVOLUTIVO.COMPANIA= :KEY_COMPANIA AND DEVOLUTIVO.ELEMENTO= :KEY_ELEMENTO AND DEVOLUTIVO.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="APLICA_DETERIORO" sqlType="STRING"/>
		<param name="APLICA_REEXPRESION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/updateindicadordeterioro">
		<call-query href="updateDevolutivosUpdateindicadordeterioro">
			<with-param name="APLICA_DETERIORO" query-param="APLICA_DETERIORO"/>
			<with-param name="APLICA_REEXPRESION" query-param="APLICA_REEXPRESION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getDevolutivosDevolutivoinvQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEVOLUTIVO.COMPANIA, TERCERO.TIPOID TIPO_IDENTIFICACION, DEVOLUTIVO.RESPONSABLE DOCUMENTO_RESPONSABLE, TERCERO.NOMBRE RESPONSABLE, DEVOLUTIVO.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, SUBSTR(DEVOLUTIVO.ELEMENTO,0,5) ID_GRUPO, PCK_ALMACEN.FC_NOMBREINVENTARIO(DEVOLUTIVO.COMPANIA,SUBSTR(DEVOLUTIVO.ELEMENTO,0,3),0) GRUPO, DEVOLUTIVO.SERIE PLACA, DEVOLUTIVO.MARCA, INVENTARIO.NOMBRELARGO NOMBRE, DEVOLUTIVO.SERIEDEVOLUTIVO SERIAL, DEVOLUTIVO.DESCRIPCION, DEVOLUTIVO.VALOR VALOR_TOTAL , ALMACENCONTABILIDAD.CUENTADEBITO, ALMACENCONTABILIDAD.CUENTACREDITO  FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL LEFT JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN ALMACENCONTABILIDAD ON DEVOLUTIVO.COMPANIA = ALMACENCONTABILIDAD.COMPANIA AND SUBSTR(DEVOLUTIVO.ELEMENTO,0,5) = ALMACENCONTABILIDAD.CODIGOELEMENTO AND TO_NUMBER(TO_CHAR(DEVOLUTIVO.FECHAULTMOV,'YYYY')) = ALMACENCONTABILIDAD.ANO AND DEVOLUTIVO.TIPOMOVIMIENTOF = ALMACENCONTABILIDAD.TIPOMOVIMIENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.RESPONSABLE = :RESPONSABLE AND DEVOLUTIVO.PLACAANULADA IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_IDENTIFICACION":"$TIPO_IDENTIFICACION","DOCUMENTO_RESPONSABLE":"$DOCUMENTO_RESPONSABLE","RESPONSABLE":"$RESPONSABLE","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","ID_GRUPO":"$ID_GRUPO","GRUPO":"$GRUPO","PLACA":"$PLACA","MARCA":"$MARCA","NOMBRE":"$NOMBRE","SERIAL":"$SERIAL","DESCRIPCION":"$DESCRIPCION","VALOR_TOTAL":"$VALOR_TOTAL","CUENTADEBITO":"$CUENTADEBITO","CUENTACREDITO":"$CUENTACREDITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/devolutivoinv">
		<call-query href="getDevolutivosDevolutivoinvQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>

		</call-query>
	</resource>
	<query id="updateDevolutivosTodosactubicacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET UBICACION =:CODIGO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTOI = :TIPOMOVIMIENTOI AND MOVIMIENTOI = :MOVIMIENTOI</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTOI" sqlType="STRING"/>
		<param name="MOVIMIENTOI" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/todosactubicacion">
		<call-query href="updateDevolutivosTodosactubicacion">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTOI" query-param="TIPOMOVIMIENTOI"/>
			<with-param name="MOVIMIENTOI" query-param="MOVIMIENTOI"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagSeriesdevolutivocctoyrefinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TO_CHAR(DEVOLUTIVO.SERIE) SERIE, DEVOLUTIVO.SERIE SERIE1, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.RESPONSABLE, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, ESTADODEVOLUTIVO.DESCRIPCION NOMBREESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.MODELO, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(NOMBRELARGO, CONCAT(' ', DEVOLUTIVO.DESCRIPCION)) TXTNOM, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_RESPONSABLE, CASE WHEN DEVOLUTIVO.CIUDAD IS NOT NULL THEN CONCAT(DEPARTAMENTO.NOMBRE, CONCAT(', ', CIUDAD.NOMBRE)) ELSE '' END UBICACION, DEVOLUTIVO.DIRECCION, U.CODIGO CODIGO_UBICACION, U.NOMBRE NOMBRE_UBICACION, '' PLACA_NIIF, D_MOVIMIENTO.CENTRODECOSTO, D_MOVIMIENTO.REFERENCIA_CNT, CENTRO_COSTO.NOMBRE NOMBRECENTRO, REFERENCIA.NOMBRE NOMBREREF,VALORIZACION FROM DEVOLUTIVO INNER JOIN D_MOVIMIENTO ON DEVOLUTIVO.COMPANIA = D_MOVIMIENTO.COMPANIA AND DEVOLUTIVO.ELEMENTO = D_MOVIMIENTO.ELEMENTO AND DEVOLUTIVO.SERIE = D_MOVIMIENTO.SERIE AND DEVOLUTIVO.MOVIMIENTOI = D_MOVIMIENTO.MOVIMIENTO AND DEVOLUTIVO.TIPOMOVIMIENTOI = D_MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL INNER JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO LEFT JOIN DEPARTAMENTO ON DEVOLUTIVO.PAIS = DEPARTAMENTO.PAIS AND DEVOLUTIVO.DEPARTAMENTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON DEVOLUTIVO.PAIS = CIUDAD.PAIS AND DEVOLUTIVO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND DEVOLUTIVO.CIUDAD = CIUDAD.CODIGO LEFT JOIN UBICACIONES U ON DEVOLUTIVO.COMPANIA = U.COMPANIA aNd DEVOLUTIVO.UBICACION = U.CODIGO LEFT JOIN CENTRO_COSTO ON D_MOVIMIENTO.COMPANIA = CENTRO_COSTO.COMPANIA AND D_MOVIMIENTO.CENTRODECOSTO = CENTRO_COSTO.CODIGO AND EXTRACT(YEAR FROM D_MOVIMIENTO.FECHA) = CENTRO_COSTO.ANO LEFT JOIN REFERENCIA ON D_MOVIMIENTO.COMPANIA = REFERENCIA.COMPANIA AND D_MOVIMIENTO.REFERENCIA_CNT = REFERENCIA.CODIGO AND EXTRACT(YEAR FROM D_MOVIMIENTO.FECHA) = REFERENCIA.ANO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND INVENTARIO.IDENTIFICADOR IN ('P') ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.SERIEANTERIOR) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN SERIE1 IS NULL THEN ' ' ELSE UPPER(SERIE1) END) LIKE UPPER(CONCAT(:SERIE1, '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(:SERIEDEVOLUTIVO, '%')) AND (CASE WHEN NOMBRECENTRO IS NULL THEN ' ' ELSE UPPER(NOMBRECENTRO) END) LIKE UPPER(CONCAT(:NOMBRECENTRO, '%')) AND (CASE WHEN NOMBREREF IS NULL THEN ' ' ELSE UPPER(NOMBREREF) END) LIKE UPPER(CONCAT(:NOMBREREF, '%')) AND (CASE WHEN VALORIZACION IS NULL THEN ' ' ELSE UPPER(VALORIZACION) END) LIKE UPPER(CONCAT(:VALORIZACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","SERIE1":"$SERIE1","ELEMENTO":"$ELEMENTO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","VALOR":"$VALOR","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO","SERIEANTERIOR":"$SERIEANTERIOR","PLACAANULADA":"$PLACAANULADA(type:boolean)","MARCA":"$MARCA","MODELO":"$MODELO","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","TXTNOM":"$TXTNOM","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","UBICACION":"$UBICACION","DIRECCION":"$DIRECCION","CODIGO_UBICACION":"$CODIGO_UBICACION","NOMBRE_UBICACION":"$NOMBRE_UBICACION","PLACA_NIIF":"$PLACA_NIIF","CENTRODECOSTO":"$CENTRODECOSTO","REFERENCIA_CNT":"$REFERENCIA_CNT","NOMBRECENTRO":"$NOMBRECENTRO","NOMBREREF":"$NOMBREREF","VALORIZACION":"$VALORIZACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="SERIE1" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="NOMBRECENTRO" sqlType="STRING"/>
		<param name="NOMBREREF" sqlType="STRING"/>
		<param name="VALORIZACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/seriesdevolutivocctoyrefinicial/pag">
