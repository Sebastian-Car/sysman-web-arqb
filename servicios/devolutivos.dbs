	<query id="getDevolutivosPagDepreciacionacumuladainicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT D.SERIE, D.ELEMENTO, D.VALOR, D.NIIF_VIDA_UTIL,(TO_CHAR(D.NIIF_FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS')) NIIF_FECHAADQUISICION, DP.NIIF_VLRDEPRECIACION, DP.NIIF_VLRLIBROS, DP.NIIF_VLRACUMULADO FROM DEVOLUTIVO D INNER JOIN DEPRECIAR DP ON D.COMPANIA = DP.COMPANIA AND D.ELEMENTO = DP.ELEMENTO AND D.SERIE = DP.SERIE WHERE D.COMPANIA = :COMPANIA AND D.ELEMENTO = :ELEMENTO AND D.PLACAANULADA IN (0) AND DP.MES = :MES AND DP.ANO = :ANO AND D.NIIF_FECHAADQUISICION &lt;= :FECHA ORDER BY SERIE, ELEMENTO) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN NIIF_VIDA_UTIL IS NULL THEN ' ' ELSE UPPER(NIIF_VIDA_UTIL) END) LIKE UPPER(CONCAT(:NIIF_VIDA_UTIL, '%')) AND (CASE WHEN NIIF_FECHAADQUISICION IS NULL THEN ' ' ELSE UPPER(NIIF_FECHAADQUISICION) END) LIKE UPPER(CONCAT(:NIIF_FECHAADQUISICION, '%')) AND (CASE WHEN NIIF_VLRDEPRECIACION IS NULL THEN ' ' ELSE UPPER(NIIF_VLRDEPRECIACION) END) LIKE UPPER(CONCAT(:NIIF_VLRDEPRECIACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","VALOR":"$VALOR","NIIF_VIDA_UTIL":"$NIIF_VIDA_UTIL","NIIF_FECHAADQUISICION":"$NIIF_FECHAADQUISICION","NIIF_VLRDEPRECIACION":"$NIIF_VLRDEPRECIACION","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS","NIIF_VLRACUMULADO":"$NIIF_VLRACUMULADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
