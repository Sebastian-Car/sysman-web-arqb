	<query id="getDevolutivosNumConseriedevolutivocctoyrefinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TO_CHAR(DEVOLUTIVO.SERIE) SERIE, DEVOLUTIVO.SERIE SERIE1, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.RESPONSABLE, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, ESTADODEVOLUTIVO.DESCRIPCION NOMBREESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(NOMBRELARGO , CONCAT( ' ' , DEVOLUTIVO.DESCRIPCION)) TXTNOM, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_RESPONSABLE, CASE WHEN DEVOLUTIVO.CIUDAD IS NOT NULL THEN CONCAT(DEPARTAMENTO.NOMBRE , CONCAT(', ' , CIUDAD.NOMBRE)) ELSE '' END UBICACION, DEVOLUTIVO.DIRECCION, '' PLACA_NIIF, D_MOVIMIENTO.CENTRODECOSTO, D_MOVIMIENTO.REFERENCIA_CNT,CENTRO_COSTO.NOMBRE NOMBRECENTRO, REFERENCIA.NOMBRE NOMBREREF, VALORIZACION FROM DEVOLUTIVO INNER JOIN D_MOVIMIENTO ON DEVOLUTIVO.COMPANIA = D_MOVIMIENTO.COMPANIA AND DEVOLUTIVO.ELEMENTO = D_MOVIMIENTO.ELEMENTO AND DEVOLUTIVO.SERIE = D_MOVIMIENTO.SERIE AND DEVOLUTIVO.MOVIMIENTOI = D_MOVIMIENTO.MOVIMIENTO AND DEVOLUTIVO.TIPOMOVIMIENTOI = D_MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL INNER JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO LEFT JOIN DEPARTAMENTO ON DEVOLUTIVO.PAIS = DEPARTAMENTO.PAIS AND DEVOLUTIVO.DEPARTAMENTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON DEVOLUTIVO.PAIS = CIUDAD.PAIS AND DEVOLUTIVO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND DEVOLUTIVO.CIUDAD = CIUDAD.CODIGO LEFT JOIN CENTRO_COSTO ON D_MOVIMIENTO.COMPANIA = CENTRO_COSTO.COMPANIA AND D_MOVIMIENTO.CENTRODECOSTO = CENTRO_COSTO.CODIGO AND EXTRACT(YEAR FROM D_MOVIMIENTO.FECHA) = CENTRO_COSTO.ANO LEFT JOIN REFERENCIA ON D_MOVIMIENTO.COMPANIA = REFERENCIA.COMPANIA AND D_MOVIMIENTO.REFERENCIA_CNT = REFERENCIA.CODIGO AND EXTRACT(YEAR FROM D_MOVIMIENTO.FECHA) = REFERENCIA.ANO WHERE DEVOLUTIVO.COMPANIA =:COMPANIA AND INVENTARIO.IDENTIFICADOR IN ('C') ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.SERIEANTERIOR) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN SERIE1 IS NULL THEN ' ' ELSE UPPER(SERIE1) END) LIKE UPPER(CONCAT(:SERIE1, '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(:SERIEDEVOLUTIVO, '%')) AND (CASE WHEN NOMBRECENTRO IS NULL THEN ' ' ELSE UPPER(NOMBRECENTRO) END) LIKE UPPER(CONCAT(:NOMBRECENTRO, '%')) AND (CASE WHEN NOMBREREF IS NULL THEN ' ' ELSE UPPER(NOMBREREF) END) LIKE UPPER(CONCAT(:NOMBREREF, '%')) AND (CASE WHEN VALORIZACION IS NULL THEN ' ' ELSE UPPER(VALORIZACION) END) LIKE UPPER(CONCAT(:VALORIZACION, '%')) ) A) FIN</sql>
