	<query id="getDevolutivosPagPorDependenciaResponsableYSinPlacaAnuladaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.VALOR, DEVOLUTIVO.SERIEDEVOLUTIVO, DEVOLUTIVO.MARCA, DEVOLUTIVO.DESCRIPCION, DEVOLUTIVO.MODELO FROM INVENTARIO INNER JOIN DEVOLUTIVO ON INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.DEPENDENCIA = :DEPENDENCIA AND DEVOLUTIVO.RESPONSABLE = :RESPONSABLE AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = :SUCURSAL_RESPONSABLE AND DEVOLUTIVO.PLACAANULADA IN (0) AND ( CASE WHEN :ELEMENTO IS NOT NULL THEN DEVOLUTIVO.ELEMENTO ELSE NVL(:ELEMENTO, 'X') END) = NVL(:ELEMENTO, 'X') AND ( CASE WHEN :CLASE_MOVIMIENTO IN ('E') OR :CLASE_MOVIMIENTO NOT IN ('D','T') THEN INVENTARIO.TIPO ELSE :TIPO END) = :TIPO ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(:SERIEDEVOLUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(:MODELO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","VALOR":"$VALOR","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","MARCA":"$MARCA","DESCRIPCION":"$DESCRIPCION","MODELO":"$MODELO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="CLASE_MOVIMIENTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/pordependenciaresponsableysinplacaanulada/pag">
