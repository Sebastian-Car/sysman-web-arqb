	<query id="updateDevolutivosUbicacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEVOLUTIVO SET PAIS                     = :PAIS,   DEPARTAMENTO               = :DEPARTAMENTO,   CIUDAD                     = :MUNICIPIO,   DIRECCION                  = :DIRECCION, TIPOESTACIONADIC = :TIPOESTACIONADIC WHERE COMPANIA               = :COMPANIA AND DEVOLUTIVO.ELEMENTO= :ELEMENTO AND DEVOLUTIVO.SERIE    = :SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="MUNICIPIO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TIPOESTACIONADIC" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="devolutivos/ubicacion">
		<call-query href="updateDevolutivosUbicacion">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="MUNICIPIO" query-param="MUNICIPIO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TIPOESTACIONADIC" query-param="TIPOESTACIONADIC"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>

		</call-query>
	</resource>
	<query id="getDevolutivosGrupoestacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT CIUDAD.NOMBRE, SUBSTR(DEVOLUTIVO.ELEMENTO,1,3) GRUPO, CONCAT(TRIM(SUBSTR(DE.NOMBRE,1,30) ),CONCAT( '/', TRIM(SUBSTR(INVENTARIO.NOMBRELARGO,1,30) ))) NOMBREGRUPO, COUNT(DEVOLUTIVO.ELEMENTO) CANTIDAD FROM DEVOLUTIVO INNER JOIN INVENTARIO ON ( DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA ) AND ( SUBSTR(DEVOLUTIVO.ELEMENTO,1,3) = INVENTARIO.CODIGOELEMENTO ) LEFT JOIN CIUDAD ON ( DEVOLUTIVO.PAIS = CIUDAD.PAIS ) AND ( DEVOLUTIVO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO ) AND ( DEVOLUTIVO.CIUDAD = CIUDAD.CODIGO ) LEFT JOIN DETALLE_ELEMENTOSCOMPONENTES DD ON ( DEVOLUTIVO.COMPANIA = DD.COMPANIA ) AND ( DEVOLUTIVO.ELEMENTO = DD.CODIGO_COMPONENTE ) AND ( DEVOLUTIVO.SERIE = DD.SERIE_COMPONENTE ) LEFT JOIN ELEMENTOSCOMPONENTES DE ON ( DE.COMPANIA = DD.COMPANIA ) AND ( DE.CONSECUTIVO = DD.CODIGO_ELEMENTO ) WHERE DEVOLUTIVO.PLACAANULADA IN (0) GROUP BY CIUDAD.NOMBRE, SUBSTR(DEVOLUTIVO.ELEMENTO,1,3), CONCAT(TRIM(SUBSTR(DE.NOMBRE,1,30) ),CONCAT( '/', TRIM(SUBSTR(INVENTARIO.NOMBRELARGO,1,30) ))) ORDER BY CIUDAD.NOMBRE, SUBSTR(DEVOLUTIVO.ELEMENTO,1,3), CONCAT(TRIM(SUBSTR(DE.NOMBRE,1,30) ),CONCAT( '/', TRIM(SUBSTR(INVENTARIO.NOMBRELARGO,1,30) )))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","GRUPO":"$GRUPO","NOMBREGRUPO":"$NOMBREGRUPO","CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
 
	</query>
	<resource method="GET" path="devolutivos/grupoestacion">
		<call-query href="getDevolutivosGrupoestacionQuery">
 
		</call-query>
	</resource>
	<query id="getDevolutivosPorGruposInventarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUBSTR(DEVOLUTIVO.ELEMENTO,1,3) CODIGO, CONCAT(TRIM(SUBSTR(INVENTARIO.NOMBRELARGO,1,30) ),CONCAT('_', SUBSTR(DEVOLUTIVO.ELEMENTO,1,3))) NOMBRE FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND SUBSTR(DEVOLUTIVO.ELEMENTO,1,3) = INVENTARIO.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA =:COMPANIA AND DEVOLUTIVO.PLACAANULADA IN (0) GROUP BY SUBSTR(DEVOLUTIVO.ELEMENTO,1,3), CONCAT(TRIM(SUBSTR(INVENTARIO.NOMBRELARGO,1,30) ),CONCAT('_', SUBSTR(DEVOLUTIVO.ELEMENTO,1,3))) ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/porgruposinventario">
		<call-query href="getDevolutivosPorGruposInventarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagElesernomlarinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA ORDER BY DEVOLUTIVO.SERIE) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/elesernomlarinicial/pag">
		<call-query href="getDevolutivosPagElesernomlarinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumElesernomlarinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA ORDER BY DEVOLUTIVO.SERIE) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
