	<query id="getDevolutivosPagPordependenciaresponsablesinplacaanuladayauxQuery"  useConfig="sysmandsunist">
		<sql>WITH BASE_QUERY AS (SELECT DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.VALOR, DEVOLUTIVO.SERIEDEVOLUTIVO, DEVOLUTIVO.MARCA, DEVOLUTIVO.DESCRIPCION, DEVOLUTIVO.MODELO, DEVOLUTIVO.DEPENDENCIA, DEVOLUTIVO.RESPONSABLE, DEVOLUTIVO.SUCURSAL_RESPONSABLE, ROW_NUMBER() OVER (ORDER BY DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO) AS RNUM FROM D_MOVIMIENTO INNER JOIN DEVOLUTIVO ON D_MOVIMIENTO.COMPANIA = DEVOLUTIVO.COMPANIA AND D_MOVIMIENTO.ELEMENTO = DEVOLUTIVO.ELEMENTO LEFT JOIN INVENTARIO ON D_MOVIMIENTO.COMPANIA = INVENTARIO.COMPANIA AND D_MOVIMIENTO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN MOVIMIENTO ON D_MOVIMIENTO.COMPANIA = MOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO = MOVIMIENTO.NUMERO LEFT JOIN TIPOMOVIMIENTO ON MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO LEFT JOIN INVENTARIO_BODEGA ON D_MOVIMIENTO.COMPANIA = INVENTARIO_BODEGA.COMPANIA AND D_MOVIMIENTO.ELEMENTO = INVENTARIO_BODEGA.ELEMENTO AND D_MOVIMIENTO.FUENTEDERECURSO = INVENTARIO_BODEGA.FUENTEDERECURSO AND D_MOVIMIENTO.REFERENCIA_CNT = INVENTARIO_BODEGA.REFERENCIA AND D_MOVIMIENTO.AUXILIAR = INVENTARIO_BODEGA.AUXILIAR AND D_MOVIMIENTO.CODIGOPROYECTO = INVENTARIO_BODEGA.PROYECTO AND D_MOVIMIENTO.CENTRODECOSTO = INVENTARIO_BODEGA.CENTRODECOSTO AND D_MOVIMIENTO.LOTE = INVENTARIO_BODEGA.LOTE AND INVENTARIO_BODEGA.BODEGA = :CAMP_BODEGA WHERE INVENTARIO.COMPANIA = :CAMP_COMPANIA AND INVENTARIO.TIENEMOVIMIENTO &lt;&gt; 0 AND INVENTARIO.INACTIVO = 0 AND TIPOMOVIMIENTO.CLASE = 'E'AND TIPOMOVIMIENTO.TIPOELEMENTO = :CAMP_TIPO AND D_MOVIMIENTO.SALDO_PEPS &gt; 0 AND D_MOVIMIENTO.CODIGOPROYECTO = :CAMP_PROYECTO AND D_MOVIMIENTO.FUENTEDERECURSO = :CAMP_FUENTER AND D_MOVIMIENTO.REFERENCIA_CNT = :CAMP_REFERENCIA AND D_MOVIMIENTO.AUXILIAR = :CAMP_AUXILIAR AND D_MOVIMIENTO.CENTRODECOSTO = :CAMP_CENTRODECOSTO AND DEVOLUTIVO.PLACAANULADA = 0 AND MOVIMIENTO.RESPONSABLE_DESTINO = :CAMP_RESPONSABLE AND MOVIMIENTO.SUCURSAL_RESDESTINO = :CAMP_SUCURSAL_RESPONSABLE AND MOVIMIENTO.BODEGA_DESTINO = :CAMP_BODEGA ) SELECT * FROM BASE_QUERY WHERE RNUM BETWEEN (:PAGINICIO + 1) AND (:PAGINICIO + :PAGTAMANIO) AND SERIE LIKE :SERIE || '%'AND ELEMENTO LIKE :ELEMENTO || '%'AND NOMBRELARGO LIKE :NOMBRELARGO || '%'AND VALOR LIKE :VALOR || '%'AND SERIEDEVOLUTIVO LIKE :SERIEDEVOLUTIVO || '%'AND DESCRIPCION LIKE :DESCRIPCION || '%'AND MODELO LIKE :MODELO || '%'AND RESPONSABLE LIKE :RESPONSABLE || '%'AND SUCURSAL_RESPONSABLE LIKE :SUCURSAL_RESPONSABLE || '%'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","VALOR":"$VALOR","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","MARCA":"$MARCA","DESCRIPCION":"$DESCRIPCION","MODELO":"$MODELO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL_RESPONSABLE":"$SUCURSAL_RESPONSABLE"}]}}		</result>
		<param name="CAMP_BODEGA" sqlType="STRING"/>
		<param name="CAMP_COMPANIA" sqlType="STRING"/>
		<param name="CAMP_TIPO" sqlType="STRING"/>
		<param name="CAMP_PROYECTO" sqlType="STRING"/>
		<param name="CAMP_FUENTER" sqlType="STRING"/>
		<param name="CAMP_REFERENCIA" sqlType="STRING"/>
		<param name="CAMP_AUXILIAR" sqlType="STRING"/>
		<param name="CAMP_CENTRODECOSTO" sqlType="STRING"/>
		<param name="CAMP_ELEMENTO" sqlType="STRING"/>
		<param name="CAMP_CLASE_MOVIMIENTO" sqlType="STRING"/>
		<param name="CAMP_RESPONSABLE" sqlType="STRING"/>
		<param name="CAMP_SUCURSAL_RESPONSABLE" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/pordependenciaresponsablesinplacaanuladayaux/pag">
		<call-query href="getDevolutivosPagPordependenciaresponsablesinplacaanuladayauxQuery">
			<with-param name="CAMP_BODEGA" query-param="CAMP_BODEGA"/>
			<with-param name="CAMP_COMPANIA" query-param="CAMP_COMPANIA"/>
			<with-param name="CAMP_TIPO" query-param="CAMP_TIPO"/>
			<with-param name="CAMP_PROYECTO" query-param="CAMP_PROYECTO"/>
			<with-param name="CAMP_FUENTER" query-param="CAMP_FUENTER"/>
			<with-param name="CAMP_REFERENCIA" query-param="CAMP_REFERENCIA"/>
			<with-param name="CAMP_AUXILIAR" query-param="CAMP_AUXILIAR"/>
			<with-param name="CAMP_CENTRODECOSTO" query-param="CAMP_CENTRODECOSTO"/>
			<with-param name="CAMP_ELEMENTO" query-param="CAMP_ELEMENTO"/>
			<with-param name="CAMP_CLASE_MOVIMIENTO" query-param="CAMP_CLASE_MOVIMIENTO"/>
			<with-param name="CAMP_RESPONSABLE" query-param="CAMP_RESPONSABLE"/>
			<with-param name="CAMP_SUCURSAL_RESPONSABLE" query-param="CAMP_SUCURSAL_RESPONSABLE"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="VALOR" query-param="VALOR"/>
