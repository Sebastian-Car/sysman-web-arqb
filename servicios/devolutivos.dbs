	<query id="getDevolutivosTodosPorCompaniaSeriePlacaAnuladaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEVOLUTIVO.SERIE,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA FROM DEVOLUTIVO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.SERIE = :SERIE_PLACA AND DEVOLUTIVO.PLACAANULADA = -1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","PLACAANULADA":"$PLACAANULADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>

	</query>
