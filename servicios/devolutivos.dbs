			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="PLACA" query-param="PLACA"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagDepreciacionPorPlacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, CONCAT(DEPENDENCIA.NOMBRE ,CONCAT( ' (' ,CONCAT(DEPENDENCIA.CODIGO , ')'))) DEPENDENCIA, CONCAT( TERCERO.NOMBRE ,CONCAT( ' (' ,CONCAT(RESPONSABLE.CEDULA , ')'))) RESPONSABLE, DEVOLUTIVO.VALOR, ESTADODEVOLUTIVO.DESCRIPCION ESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(INVENTARIO.NOMBRELARGO,CONCAT(' ', DEVOLUTIVO.DESCRIPCION)) TXTNOM FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN RESPONSABLE ON DEVOLUTIVO.COMPANIA = RESPONSABLE.COMPANIA AND DEVOLUTIVO.RESPONSABLE = RESPONSABLE.CEDULA AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO WHERE DEVOLUTIVO.COMPANIA =:COMPANIA ORDER BY DEVOLUTIVO.SERIE) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","VALOR":"$VALOR","ESTADO":"$ESTADO","SERIEANTERIOR":"$SERIEANTERIOR","PLACAANULADA":"$PLACAANULADA(type:boolean)","MARCA":"$MARCA","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","TXTNOM":"$TXTNOM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/depreciacionporplacas/pag">
		<call-query href="getDevolutivosPagDepreciacionPorPlacasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumDepreciacionPorPlacasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, CONCAT(DEPENDENCIA.NOMBRE ,CONCAT( ' (' ,CONCAT(DEPENDENCIA.CODIGO , ')'))) DEPENDENCIA, CONCAT( TERCERO.NOMBRE ,CONCAT( ' (' ,CONCAT(RESPONSABLE.CEDULA , ')'))) RESPONSABLE, DEVOLUTIVO.VALOR, ESTADODEVOLUTIVO.DESCRIPCION ESTADO, DEVOLUTIVO.SERIEANTERIOR,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.MARCA, DEVOLUTIVO.SERIEDEVOLUTIVO, CONCAT(INVENTARIO.NOMBRELARGO,CONCAT(' ', DEVOLUTIVO.DESCRIPCION)) TXTNOM FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN RESPONSABLE ON DEVOLUTIVO.COMPANIA = RESPONSABLE.COMPANIA AND DEVOLUTIVO.RESPONSABLE = RESPONSABLE.CEDULA AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN ESTADODEVOLUTIVO ON DEVOLUTIVO.ESTADO = ESTADODEVOLUTIVO.ESTADO WHERE DEVOLUTIVO.COMPANIA =:COMPANIA ORDER BY DEVOLUTIVO.SERIE) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/depreciacionporplacas/num">
		<call-query href="getDevolutivosNumDepreciacionPorPlacasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.COMPANIA, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, DEVOLUTIVO.PLACA, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, DEVOLUTIVO.REFERENCIA, DEVOLUTIVO.MARCA, DEVOLUTIVO.MODELO, DEVOLUTIVO.SERIEDEVOLUTIVO, DEVOLUTIVO.SERIEANTERIOR, DEVOLUTIVO.MEDIDA, DEVOLUTIVO.DESCRIPCION FROM DEVOLUTIVO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.ELEMENTO = :ELEMENTO ORDER BY DEVOLUTIVO.COMPANIA, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(CONCAT('%',:MARCA), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODELO), '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIEDEVOLUTIVO), '%')) AND (CASE WHEN SERIEANTERIOR IS NULL THEN ' ' ELSE UPPER(SERIEANTERIOR) END) LIKE UPPER(CONCAT(:SERIEANTERIOR, '%')) AND (CASE WHEN MEDIDA IS NULL THEN ' ' ELSE UPPER(MEDIDA) END) LIKE UPPER(CONCAT(:MEDIDA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","PLACA":"$PLACA","VALOR":"$VALOR","ESTADO":"$ESTADO","REFERENCIA":"$REFERENCIA","MARCA":"$MARCA","MODELO":"$MODELO","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","SERIEANTERIOR":"$SERIEANTERIOR","MEDIDA":"$MEDIDA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="SERIEANTERIOR" sqlType="STRING"/>
		<param name="MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos">
		<call-query href="getDevolutivosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
