	<query id="getDevolutivosPagResponsablesLeftTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT DEVOLUTIVO.RESPONSABLE, TERCERO.NOMBRE, TERCERO.SUCURSAL  FROM DEVOLUTIVO LEFT JOIN TERCERO ON DEVOLUTIVO.COMPANIA = TERCERO.COMPANIA AND DEVOLUTIVO.RESPONSABLE = TERCERO.NIT AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = TERCERO.SUCURSAL WHERE DEVOLUTIVO.COMPANIA = :COMPANIA) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
