	<query id="getDevolutivosNumIndicadordevolutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT D.SERIE, D.ELEMENTO, I.NOMBRELARGO, D.NIIF_VALOR_TOTAL VALOR, D.SERIEDEVOLUTIVO, D.DESCRIPCION,(CASE D.APLICA_DETERIORO WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DETERIORO,(CASE D.APLICA_REEXPRESION WHEN 0 THEN 'false' ELSE 'true' END) APLICA_REEXPRESION, D.COMPANIA,(TO_CHAR(D.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(D.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, D.CREATED_BY, D.MODIFIED_BY FROM DEVOLUTIVO D INNER JOIN INVENTARIO I ON D.ELEMENTO = I.CODIGOELEMENTO AND D.COMPANIA = I.COMPANIA WHERE D.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIE), '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIEDEVOLUTIVO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN APLICA_DETERIORO IS NULL THEN ' ' ELSE UPPER(APLICA_DETERIORO) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICA_DETERIORO), '%')) AND (CASE WHEN APLICA_REEXPRESION IS NULL THEN ' ' ELSE UPPER(APLICA_REEXPRESION) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICA_REEXPRESION), '%')) AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_CREATED), '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_MODIFIED), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:CREATED_BY), '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFIED_BY), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
