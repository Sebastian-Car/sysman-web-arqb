	<query id="getDevolutivosPagTodosPorCompaniaPlacaAnuladaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEVOLUTIVO.COMPANIA, DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.DESCRIPCION,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.NIIF_TIPO_ACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO, DEVOLUTIVO.NIIF_VALOR_BASE, DEVOLUTIVO.NIIF_VALOR_TOTAL  FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN TIPO_ACTIVO ON DEVOLUTIVO.COMPANIA = TIPO_ACTIVO.COMPANIA AND DEVOLUTIVO.NIIF_TIPO_ACTIVO = TIPO_ACTIVO.CODIGO_TIPOACTIVO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.PLACAANULADA = 0) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOACTIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","DESCRIPCION":"$DESCRIPCION","PLACAANULADA":"$PLACAANULADA(type:boolean)","NIIF_TIPO_ACTIVO":"$NIIF_TIPO_ACTIVO","NOMBRE_TIPOACTIVO":"$NOMBRE_TIPOACTIVO","NIIF_VALOR_BASE":"$NIIF_VALOR_BASE","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="devolutivos/todosporcompaniaplacaanulada/pag">
		<call-query href="getDevolutivosPagTodosPorCompaniaPlacaAnuladaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumTodosPorCompaniaPlacaAnuladaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEVOLUTIVO.COMPANIA, DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.DESCRIPCION,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA, DEVOLUTIVO.NIIF_TIPO_ACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO, DEVOLUTIVO.NIIF_VALOR_BASE, DEVOLUTIVO.NIIF_VALOR_TOTAL  FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN TIPO_ACTIVO ON DEVOLUTIVO.COMPANIA = TIPO_ACTIVO.COMPANIA AND DEVOLUTIVO.NIIF_TIPO_ACTIVO = TIPO_ACTIVO.CODIGO_TIPOACTIVO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.PLACAANULADA = 0) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOACTIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/todosporcompaniaplacaanulada/num">
		<call-query href="getDevolutivosNumTodosPorCompaniaPlacaAnuladaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosVerificarExistenciasPorNumeroOrigenQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) NUMERO FROM DEVOLUTIVO WHERE COMPANIA =:COMPANIA AND NUMEROORIGEN =:NUMERO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:ORIGEN,' ','') ),CONCAT('',CONCAT(ORIGEN, '')),1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ORIGEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/verificarexistenciaspornumeroorigen">
		<call-query href="getDevolutivosVerificarExistenciasPorNumeroOrigenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ORIGEN" query-param="ORIGEN"/>

