			<with-param name="MEDIDA" query-param="MEDIDA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEVOLUTIVO.COMPANIA, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, DEVOLUTIVO.PLACA, DEVOLUTIVO.VALOR, DEVOLUTIVO.ESTADO, DEVOLUTIVO.REFERENCIA, DEVOLUTIVO.MARCA, DEVOLUTIVO.MODELO, DEVOLUTIVO.SERIEDEVOLUTIVO, DEVOLUTIVO.SERIEANTERIOR, DEVOLUTIVO.MEDIDA, DEVOLUTIVO.DESCRIPCION FROM DEVOLUTIVO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.ELEMENTO = :ELEMENTO ORDER BY DEVOLUTIVO.COMPANIA, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(CONCAT('%',:MARCA), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODELO), '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIEDEVOLUTIVO), '%')) AND (CASE WHEN SERIEANTERIOR IS NULL THEN ' ' ELSE UPPER(SERIEANTERIOR) END) LIKE UPPER(CONCAT(:SERIEANTERIOR, '%')) AND (CASE WHEN MEDIDA IS NULL THEN ' ' ELSE UPPER(MEDIDA) END) LIKE UPPER(CONCAT(:MEDIDA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="SERIEDEVOLUTIVO" sqlType="STRING"/>
		<param name="SERIEANTERIOR" sqlType="STRING"/>
		<param name="MEDIDA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
