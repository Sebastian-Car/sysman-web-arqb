	</resource>
	<query id="getDevolutivosInventarioDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT INVENTARIO2.CODIGOELEMENTO GRUPO, INVENTARIO2.NOMBRELARGO NOMBRE_GRUPO, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO NOMBRE_ELEMENTO, DEVOLUTIVO.SERIE PLACA_DE_INVENTARIO, DEVOLUTIVO.MARCA, DEVOLUTIVO.SERIEDEVOLUTIVO, DEVOLUTIVO.MODELO, DEVOLUTIVO.DESCRIPCION,(TO_CHAR(DEVOLUTIVO.FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_INSTALACION, DEVOLUTIVO.ACTA_INSTALACION FROM DEVOLUTIVO INNER JOIN DEPENDENCIA ON DEVOLUTIVO.COMPANIA = DEPENDENCIA.COMPANIA AND DEVOLUTIVO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN INVENTARIO INVENTARIO2 ON DEVOLUTIVO.COMPANIA = INVENTARIO2.COMPANIA AND SUBSTR(DEVOLUTIVO.ELEMENTO,1,PCK_SYSMAN_UTL.FC_PAR('001','DIGITOS AGRUPACION INVENTARIO',10,SYSDATE,0)) = INVENTARIO2.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEPENDENCIA.CODIGO_EQUIVALENTE = :CODIGO AND DEVOLUTIVO.RESPONSABLE = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"GRUPO":"$GRUPO","NOMBRE_GRUPO":"$NOMBRE_GRUPO","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRE_ELEMENTO":"$NOMBRE_ELEMENTO","PLACA_DE_INVENTARIO":"$PLACA_DE_INVENTARIO","MARCA":"$MARCA","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","MODELO":"$MODELO","DESCRIPCION":"$DESCRIPCION","FECHA_INSTALACION":"$FECHA_INSTALACION","ACTA_INSTALACION":"$ACTA_INSTALACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="devolutivos/inventariodependencia">
		<call-query href="getDevolutivosInventarioDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getDevolutivosPagDevolutivobienesporelementoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D.SERIE, TO_CHAR(D.FECHAADQUISICION,'DD/MM/YYYY')FECHAADQUISICION FROM DEVOLUTIVO D LEFT JOIN BIENES_INMUEBLES B ON D.COMPANIA = B.COMPANIA AND D.ELEMENTO = B.ELEMENTO AND D.SERIE = B.SERIE WHERE D.COMPANIA = :COMPANIA AND D.ELEMENTO = :ELEMENTO ORDER BY D.SERIE) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIE), '%')) AND (CASE WHEN FECHAADQUISICION IS NULL THEN ' ' ELSE UPPER(FECHAADQUISICION) END) LIKE UPPER(CONCAT(:FECHAADQUISICION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","FECHAADQUISICION":"$FECHAADQUISICION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHAADQUISICION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
