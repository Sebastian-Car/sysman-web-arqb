		<param name="NIIF_FECHAADQUISICION" sqlType="STRING"/>
		<param name="NIIF_VLRDEPRECIACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
