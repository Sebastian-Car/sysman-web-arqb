		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO NOMBRE  FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA GROUP BY ELEMENTO, INVENTARIO.NOMBRELARGO ORDER BY ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
