	<query id="getDevolutivosNumVidaUtilDepreciarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEVOLUTIVO.COMPANIA , DEVOLUTIVO.ELEMENTO , DEVOLUTIVO.SERIE , DEVOLUTIVO.VALOR ,(TO_CHAR(DEVOLUTIVO.FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS')) FECHAADQUISICION,(TO_CHAR(DEVOLUTIVO.FECHASALIDASERVICIO,'DD/MM/YYYY HH24:MI:SS')) FECHASALIDASERVICIO, DEVOLUTIVO.TIPOMOVIMIENTOI , DEVOLUTIVO.MOVIMIENTOI , DEVOLUTIVO.MESESVIDAUTILPLACA , DEVOLUTIVO.NIIF_VALOR_BASE , DEVOLUTIVO.SALVAMENTO , DEVOLUTIVO.DETERIORO , DEVOLUTIVO.NIIF_VIDA_UTIL , DEVOLUTIVO.NIIF_TIPO_ACTIVO , DEVOLUTIVO.NIIF_VALOR_TOTAL ,(TO_CHAR(CASE WHEN DEVOLUTIVO.FECHAADQUISICION &lt; (TO_DATE(:FECHACORTENIIF,'DD/MM/YYYY') + 1) THEN (TO_DATE(:FECHACORTENIIF,'DD/MM/YYYY') + 1) ELSE DEVOLUTIVO.NIIF_FECHAFUNCIONAMIENTO END,'DD/MM/YYYY HH24:MI:SS')) NIIF_FECHAFUNCIONAMIENTO,(CASE DEVOLUTIVO.APLICA_NIIF WHEN 0 THEN 'false' ELSE 'true' END) APLICA_NIIF, DEPRECIAR2.VLRLIBROS, DEPRECIAR2.DEPACUMULADA, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.FDETERIOROINTERNA, DEVOLUTIVO.FDETERIOROEXTERNA, INDICIOSINTERNA.NOMBRE NDETERIOROINTERNA, INDICIOSEXTERNA.NOMBRE NDETERIOROEXTERNA, CASE WHEN MESESVIDAUTIL IS NULL OR DEVOLUTIVO.FECHASALIDASERVICIO IS NULL THEN 0 ELSE CASE WHEN (DEVOLUTIVO.NIIF_VIDA_UTIL - ROUND(MONTHS_BETWEEN(TO_DATE(:FECHACORTE, 'DD/MM/YYYY'), DEVOLUTIVO.NIIF_FECHAADQUISICION))) &lt; 0 THEN 0 ELSE GREATEST(DEVOLUTIVO.NIIF_VIDA_UTIL - ROUND(MONTHS_BETWEEN(TO_DATE(:FECHACORTE, 'DD/MM/YYYY'), DEVOLUTIVO.NIIF_FECHAADQUISICION)),0) END END AS MESESVIDAUTREST, CASE WHEN VALORIZA.VALORIZACION IS NULL THEN 0 ELSE VALORIZA.VALORIZACION END VLRVALORIZACION,(CASE DEVOLUTIVO.CUANTIAMIN WHEN 0 THEN 'false' ELSE 'true' END) CUANTIAMIN FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN (SELECT COMPANIA, ELEMENTO, SERIE, SUM(VALORIZACION) VALORIZACION FROM VALORIZACIONDEVOLUTIVO WHERE COMPANIA = :COMPANIA AND PERIODO &lt; TO_DATE(:FECHACORTE,'DD/MM/YYYY') GROUP BY COMPANIA, ELEMENTO, SERIE ) VALORIZA ON DEVOLUTIVO.COMPANIA = VALORIZA.COMPANIA AND DEVOLUTIVO.ELEMENTO = VALORIZA.ELEMENTO AND DEVOLUTIVO.SERIE = VALORIZA.SERIE LEFT JOIN INDICIOSDETERIORO INDICIOSINTERNA ON DEVOLUTIVO.COMPANIA = INDICIOSINTERNA.COMPANIA AND DEVOLUTIVO.FDETERIOROINTERNA = INDICIOSINTERNA.CODIGO LEFT JOIN INDICIOSDETERIORO INDICIOSEXTERNA ON DEVOLUTIVO.COMPANIA = INDICIOSEXTERNA.COMPANIA AND DEVOLUTIVO.FDETERIOROEXTERNA = INDICIOSEXTERNA.CODIGO LEFT JOIN ACTDEPRECIABLE A ON INVENTARIO.TIPOACTIVO = A.CODIGO LEFT JOIN (SELECT MAX(DEPRECIAR.PERIODO) PERIODO , DEPRECIAR.ELEMENTO , DEPRECIAR.SERIE , DEPRECIAR.COMPANIA, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10, MAX(DEPRECIAR.PERIODO))='SI' THEN MAX(DEPRECIAR.NIIF_VLRLIBROS) KEEP (DENSE_RANK LAST ORDER BY DEPRECIAR.PERIODO) ELSE MAX(DEPRECIAR.VLRLIBROS) KEEP (DENSE_RANK LAST ORDER BY DEPRECIAR.PERIODO) END VLRLIBROS, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,MAX(DEPRECIAR.PERIODO))='SI' THEN MAX(DEPRECIAR.NIIF_DEPACUMULADA) KEEP (DENSE_RANK LAST ORDER BY DEPRECIAR.PERIODO) ELSE MAX(DEPRECIAR.DEPACUMULADA) KEEP (DENSE_RANK LAST ORDER BY DEPRECIAR.PERIODO) END DEPACUMULADA FROM DEVOLUTIVO INNER JOIN DEPRECIAR ON DEVOLUTIVO.COMPANIA = DEPRECIAR.COMPANIA AND DEVOLUTIVO.ELEMENTO = DEPRECIAR.ELEMENTO AND DEVOLUTIVO.SERIE = DEPRECIAR.SERIE GROUP BY DEPRECIAR.ELEMENTO, DEPRECIAR.SERIE, DEPRECIAR.COMPANIA ) DEPRECIAR2 ON DEVOLUTIVO.COMPANIA = DEPRECIAR2.COMPANIA AND DEVOLUTIVO.ELEMENTO = DEPRECIAR2.ELEMENTO AND DEVOLUTIVO.SERIE = DEPRECIAR2.SERIE WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.FECHAADQUISICION &lt;= TO_DATE(:FECHACORTE,'DD/MM/YYYY') AND (DEVOLUTIVO.FECHAANULADA &gt; TO_DATE(:FECHACORTE,'DD/MM/YYYY') OR DEVOLUTIVO.FECHAANULADA IS NULL) ORDER BY DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN FECHAADQUISICION IS NULL THEN ' ' ELSE UPPER(FECHAADQUISICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAADQUISICION), '%')) AND (CASE WHEN FECHASALIDASERVICIO IS NULL THEN ' ' ELSE UPPER(FECHASALIDASERVICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHASALIDASERVICIO), '%')) AND (CASE WHEN TIPOMOVIMIENTOI IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTOI) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTOI, '%')) AND (CASE WHEN MOVIMIENTOI IS NULL THEN ' ' ELSE UPPER(MOVIMIENTOI) END) LIKE UPPER(CONCAT(:MOVIMIENTOI, '%')) AND (CASE WHEN MESESVIDAUTILPLACA IS NULL THEN ' ' ELSE UPPER(MESESVIDAUTILPLACA) END) LIKE UPPER(CONCAT(:MESESVIDAUTILPLACA, '%')) AND (CASE WHEN NIIF_VALOR_BASE IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_BASE) END) LIKE UPPER(CONCAT(:NIIF_VALOR_BASE, '%')) AND (CASE WHEN SALVAMENTO IS NULL THEN ' ' ELSE UPPER(SALVAMENTO) END) LIKE UPPER(CONCAT(:SALVAMENTO, '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(:DETERIORO, '%')) AND (CASE WHEN NIIF_VIDA_UTIL IS NULL THEN ' ' ELSE UPPER(NIIF_VIDA_UTIL) END) LIKE UPPER(CONCAT(:NIIF_VIDA_UTIL, '%')) AND (CASE WHEN NIIF_TIPO_ACTIVO IS NULL THEN ' ' ELSE UPPER(NIIF_TIPO_ACTIVO) END) LIKE UPPER(CONCAT(:NIIF_TIPO_ACTIVO, '%')) AND (CASE WHEN NIIF_VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_TOTAL) END) LIKE UPPER(CONCAT(:NIIF_VALOR_TOTAL, '%')) AND (CASE WHEN NIIF_FECHAFUNCIONAMIENTO IS NULL THEN ' ' ELSE UPPER(NIIF_FECHAFUNCIONAMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NIIF_FECHAFUNCIONAMIENTO), '%')) AND (CASE WHEN APLICA_NIIF IS NULL THEN ' ' ELSE UPPER(APLICA_NIIF) END) LIKE UPPER(CONCAT(:APLICA_NIIF, '%')) AND (CASE WHEN VLRLIBROS IS NULL THEN ' ' ELSE UPPER(VLRLIBROS) END) LIKE UPPER(CONCAT(:VLRLIBROS, '%')) AND (CASE WHEN DEPACUMULADA IS NULL THEN ' ' ELSE UPPER(DEPACUMULADA) END) LIKE UPPER(CONCAT(:DEPACUMULADA, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN NDETERIOROINTERNA IS NULL THEN ' ' ELSE UPPER(NDETERIOROINTERNA) END) LIKE UPPER(CONCAT(:NDETERIOROINTERNA, '%')) AND (CASE WHEN NDETERIOROEXTERNA IS NULL THEN ' ' ELSE UPPER(NDETERIOROEXTERNA) END) LIKE UPPER(CONCAT(:NDETERIOROEXTERNA, '%')) AND (CASE WHEN MESESVIDAUTREST IS NULL THEN ' ' ELSE UPPER(MESESVIDAUTREST) END) LIKE UPPER(CONCAT(:MESESVIDAUTREST, '%')) AND (CASE WHEN VLRVALORIZACION IS NULL THEN ' ' ELSE UPPER(VLRVALORIZACION) END) LIKE UPPER(CONCAT(:VLRVALORIZACION, '%')) AND (CASE WHEN CUANTIAMIN IS NULL THEN ' ' ELSE UPPER(CUANTIAMIN) END) LIKE UPPER(CONCAT(:CUANTIAMIN, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="FECHACORTENIIF" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHAADQUISICION" sqlType="STRING"/>
		<param name="FECHASALIDASERVICIO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTOI" sqlType="STRING"/>
		<param name="MOVIMIENTOI" sqlType="STRING"/>
		<param name="MESESVIDAUTILPLACA" sqlType="STRING"/>
		<param name="NIIF_VALOR_BASE" sqlType="STRING"/>
		<param name="SALVAMENTO" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="NIIF_VIDA_UTIL" sqlType="STRING"/>
		<param name="NIIF_TIPO_ACTIVO" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIIF_FECHAFUNCIONAMIENTO" sqlType="STRING"/>
		<param name="APLICA_NIIF" sqlType="STRING"/>
		<param name="VLRLIBROS" sqlType="STRING"/>
		<param name="DEPACUMULADA" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="NDETERIOROINTERNA" sqlType="STRING"/>
		<param name="NDETERIOROEXTERNA" sqlType="STRING"/>
		<param name="MESESVIDAUTREST" sqlType="STRING"/>
		<param name="VLRVALORIZACION" sqlType="STRING"/>
		<param name="CUANTIAMIN" sqlType="STRING"/>

	</query>
