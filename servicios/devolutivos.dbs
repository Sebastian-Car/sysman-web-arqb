	<query id="getDevolutivosExistenciasTotalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) NUMERO, NUMEROORIGEN FROM DEVOLUTIVO WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:ORIGEN,' ','') ),CONCAT('',CONCAT(ORIGEN, '')),1) &gt; 0 GROUP BY NUMEROORIGEN ORDER BY NUMEROORIGEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","NUMEROORIGEN":"$NUMEROORIGEN"}]}}		</result>
