	<query id="getDevolutivosPagTodosPorelementoiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, (CONCAT(INVENTARIO.NOMBRELARGO , DEVOLUTIVO.DESCRIPCION )) DESCRIPCION FROM DEVOLUTIVO LEFT JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE INVENTARIO.COMPANIA =:COMPANIA AND DEVOLUTIVO.ELEMENTO &gt;=:ELEMENTOINICIAL AND DEVOLUTIVO.PLACAANULADA = 0 ORDER BY DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE DESC, INVENTARIO.COMPANIA) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
