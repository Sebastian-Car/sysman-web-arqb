<data name="factoresformulador" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFactoresformuladorPagListafactoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ID_DE_CONCEPTO,ALIAS_CONCEPTO FROM FACTORES_CALCULO_FORMULADOR WHERE COMPANIA = :COMPANIA AND PROCEDIMIENTO = :PROCEDIMIENTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN ALIAS_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ALIAS_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ALIAS_CONCEPTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","ALIAS_CONCEPTO":"$ALIAS_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCEDIMIENTO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="ALIAS_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="factoresformulador/listafactores/pag">
		<call-query href="getFactoresformuladorPagListafactoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCEDIMIENTO" query-param="PROCEDIMIENTO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="ALIAS_CONCEPTO" query-param="ALIAS_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFactoresformuladorNumListafactoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ID_DE_CONCEPTO,ALIAS_CONCEPTO FROM FACTORES_CALCULO_FORMULADOR WHERE COMPANIA = :COMPANIA AND PROCEDIMIENTO = :PROCEDIMIENTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN ALIAS_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ALIAS_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ALIAS_CONCEPTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCEDIMIENTO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="ALIAS_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="factoresformulador/listafactores/num">
		<call-query href="getFactoresformuladorNumListafactoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCEDIMIENTO" query-param="PROCEDIMIENTO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="ALIAS_CONCEPTO" query-param="ALIAS_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="insertFactoresformulador" keyColumns="COMPANIA,ID_DE_FACTOR,PROCEDIMIENTO,ID_DE_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FACTORES_CALCULO_FORMULADOR (COMPANIA, ID_DE_FACTOR, PROCEDIMIENTO, ACUMULADO, PERIODICIDAD, ID_DE_CONCEPTO, DOCEAVA, TIPO_DOCEAVA, ALIAS_CONCEPTO, CONCEPTO_RESULTANTE, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ID_DE_FACTOR, :PROCEDIMIENTO, :ACUMULADO, :PERIODICIDAD, :ID_DE_CONCEPTO, :DOCEAVA, :TIPO_DOCEAVA, :ALIAS_CONCEPTO, :CONCEPTO_RESULTANTE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_FACTOR":"$ID_DE_FACTOR","KEY_PROCEDIMIENTO":"$PROCEDIMIENTO(type:integer)","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_FACTOR" sqlType="STRING"/>
		<param name="PROCEDIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="ACUMULADO" sqlType="STRING"/>
		<param defaultValue="" name="PERIODICIDAD" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="DOCEAVA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_DOCEAVA" sqlType="STRING"/>
		<param defaultValue="" name="ALIAS_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO_RESULTANTE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="factoresformulador">
		<call-query href="insertFactoresformulador">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_FACTOR" query-param="ID_DE_FACTOR"/>
			<with-param name="PROCEDIMIENTO" query-param="PROCEDIMIENTO"/>
			<with-param name="ACUMULADO" query-param="ACUMULADO"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="DOCEAVA" query-param="DOCEAVA"/>
			<with-param name="TIPO_DOCEAVA" query-param="TIPO_DOCEAVA"/>
			<with-param name="ALIAS_CONCEPTO" query-param="ALIAS_CONCEPTO"/>
			<with-param name="CONCEPTO_RESULTANTE" query-param="CONCEPTO_RESULTANTE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>

</data>