<data name="viareamisional" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertViareamisional" keyColumns="COMPANIA,CODAMISIONAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VI_AREAMISIONAL (COMPANIA, CODAMISIONAL, DESCRIPCION, FUNCIONARIO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODAMISIONAL, :DESCRIPCION, :FUNCIONARIO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODAMISIONAL":"$CODAMISIONAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODAMISIONAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FUNCIONARIO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="viareamisional">
		<call-query href="insertViareamisional">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODAMISIONAL" query-param="CODAMISIONAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FUNCIONARIO" query-param="FUNCIONARIO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteViareamisional" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VI_AREAMISIONAL WHERE VI_AREAMISIONAL.COMPANIA= :KEY_COMPANIA AND VI_AREAMISIONAL.CODAMISIONAL= :KEY_CODAMISIONAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODAMISIONAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="viareamisional">
		<call-query href="deleteViareamisional">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODAMISIONAL" query-param="KEY_CODAMISIONAL"/>

		</call-query>
	</resource>
	<query id="getViareamisionalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  AR.COMPANIA, AR.CODAMISIONAL , AR.DESCRIPCION , AR.FUNCIONARIO, P.NOMBRECOMPLETO AS NOMBRE  FROM VI_AREAMISIONAL AR INNER JOIN PERSONAL P ON P.COMPANIA = AR.COMPANIA AND P.ID_DE_EMPLEADO = AR.FUNCIONARIO WHERE AR.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODAMISIONAL IS NULL THEN ' ' ELSE UPPER(CODAMISIONAL) END)  LIKE UPPER(:CODAMISIONAL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODAMISIONAL":"$CODAMISIONAL","DESCRIPCION":"$DESCRIPCION","FUNCIONARIO":"$FUNCIONARIO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODAMISIONAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viareamisional">
		<call-query href="getViareamisionalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODAMISIONAL" query-param="CODAMISIONAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViareamisionalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  AR.COMPANIA, AR.CODAMISIONAL , AR.DESCRIPCION , AR.FUNCIONARIO, P.NOMBRECOMPLETO AS NOMBRE  FROM VI_AREAMISIONAL AR INNER JOIN PERSONAL P ON P.COMPANIA = AR.COMPANIA AND P.ID_DE_EMPLEADO = AR.FUNCIONARIO WHERE AR.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODAMISIONAL IS NULL THEN ' ' ELSE UPPER(CODAMISIONAL) END)  LIKE UPPER(:CODAMISIONAL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODAMISIONAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viareamisional/numero">
		<call-query href="getViareamisionalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODAMISIONAL" query-param="CODAMISIONAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateViareamisional" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_AREAMISIONAL SET CODAMISIONAL=:CODAMISIONAL, DESCRIPCION=:DESCRIPCION, FUNCIONARIO=:FUNCIONARIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VI_AREAMISIONAL.COMPANIA= :KEY_COMPANIA AND VI_AREAMISIONAL.CODAMISIONAL= :KEY_CODAMISIONAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODAMISIONAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FUNCIONARIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODAMISIONAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="viareamisional">
		<call-query href="updateViareamisional">
			<with-param name="CODAMISIONAL" query-param="CODAMISIONAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FUNCIONARIO" query-param="FUNCIONARIO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODAMISIONAL" query-param="KEY_CODAMISIONAL"/>

		</call-query>
	</resource>

</data>