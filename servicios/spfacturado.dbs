	<query id="getSpfacturadoSumaFdeudaFperiodoYTotalFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CASE WHEN :DETFACT = 1 THEN TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALORFINANT),0),'9G999G999G999G999G990D99')) ELSE TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.DEUDAIN),0),'9G999G999G999G999G990D99')) END FDEUDA, CASE WHEN :DETFACT = 1 THEN TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALORFINACT),0),'9G999G999G999G999G990D99')) ELSE TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALOR_FACTURADOIN),0),'9G999G999G999G999G990D99')) END FPERIODO, CASE WHEN :DETFACT = 1 THEN TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALORFINANT + SP_FACTURADO.VALORFINACT),0),'9G999G999G999G999G990D99')) ELSE TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.DEUDAIN + SP_FACTURADO.VALOR_FACTURADOIN),0),'9G999G999G999G999G990D99')) END TOTALFIN  FROM SP_FACTURADO INNER JOIN SP_CONCEPTOS ON SP_FACTURADO.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_FACTURADO.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_FACTURADO.COMPANIA = :COMPANIA AND SP_FACTURADO.CICLO = :CICLO AND SP_FACTURADO.CODIGORUTA = :CODIGORUTA AND SP_FACTURADO.ANO = :ANO AND SP_FACTURADO.PERIODO = :PERIODO AND (SP_FACTURADO.CONCEPTO BETWEEN 1 AND 49 OR SP_FACTURADO.CONCEPTO IN(201,202,203,204,205,206,207,246,247,248,249)) ORDER BY SP_FACTURADO.COMPANIA, SP_FACTURADO.CICLO, SP_FACTURADO.CODIGORUTA, SP_FACTURADO.CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FDEUDA":"$FDEUDA","FPERIODO":"$FPERIODO","TOTALFIN":"$TOTALFIN"}]}}		</result>
		<param name="DETFACT" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/sumafdeudafperiodoytotalfin">
		<call-query href="getSpfacturadoSumaFdeudaFperiodoYTotalFinQuery">
			<with-param name="DETFACT" query-param="DETFACT"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoSumaFdeudaFperiodoYTotalfinCondMarcaDetalleQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CASE WHEN :DETFACT = 1 THEN TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALORFINANT),0),'9G999G999G999G999G990D99')) ELSE TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.DEUDAIN),0),'9G999G999G999G999G990D99')) END FDEUDA, CASE WHEN :DETFACT = 1 THEN TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALORFINACT),0),'9G999G999G999G999G990D99')) ELSE TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALOR_FACTURADOIN),0),'9G999G999G999G999G990D99')) END FPERIODO, CASE WHEN :DETFACT = 1 THEN TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.VALORFINANT + SP_FACTURADO.VALORFINACT),0),'9G999G999G999G999G990D99')) ELSE TRIM(TO_CHAR(NVL(SUM(SP_FACTURADO.DEUDAIN + SP_FACTURADO.VALOR_FACTURADOIN),0),'9G999G999G999G999G990D99')) END TOTALFIN  FROM SP_FACTURADO INNER JOIN SP_CONCEPTOS ON SP_FACTURADO.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_FACTURADO.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_FACTURADO.COMPANIA = :COMPANIA AND SP_FACTURADO.CICLO = :CICLO AND SP_FACTURADO.CODIGORUTA = :CODIGORUTA AND SP_FACTURADO.ANO = :ANO AND SP_FACTURADO.PERIODO = :PERIODO AND (SP_FACTURADO.CONCEPTO BETWEEN 1 AND 49 OR SP_FACTURADO.CONCEPTO IN(201,202,203,204,205,206,207,246,247,248,249)) AND (SP_FACTURADO.DEUDAIN NOT IN (0) OR SP_FACTURADO.VALOR_FACTURADOIN NOT IN (0)) ORDER BY SP_FACTURADO.COMPANIA, SP_FACTURADO.CICLO, SP_FACTURADO.CODIGORUTA, SP_FACTURADO.CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FDEUDA":"$FDEUDA","FPERIODO":"$FPERIODO","TOTALFIN":"$TOTALFIN"}]}}		</result>
		<param name="DETFACT" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/sumafdeudafperiodoytotalfincondmarcadetalle">
		<call-query href="getSpfacturadoSumaFdeudaFperiodoYTotalfinCondMarcaDetalleQuery">
			<with-param name="DETFACT" query-param="DETFACT"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>

</data>