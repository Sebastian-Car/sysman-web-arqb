	<query id="getSpfacturadoNumDetalleFinanciableDeudaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_FACTURADO.COMPANIA, SP_FACTURADO.CICLO, SP_FACTURADO.CODIGORUTA, SP_FACTURADO.ANO, SP_FACTURADO.PERIODO, SP_FACTURADO.CONCEPTO, SP_CONCEPTOS.NOMBRE NOMBRECONCEPTO, CASE WHEN :DETFACT = 1 THEN SP_FACTURADO.VALORFINANT ELSE SP_FACTURADO.DEUDAIN END FDEUDA, CASE WHEN :DETFACT = 1 THEN SP_FACTURADO.VALORFINACT ELSE SP_FACTURADO.VALOR_FACTURADOIN END FPERIODO, CASE WHEN :DETFACT = 1 THEN SP_FACTURADO.VALORFINANT + SP_FACTURADO.VALORFINACT ELSE SP_FACTURADO.DEUDAIN + SP_FACTURADO.VALOR_FACTURADOIN END TOTALFIN  FROM SP_FACTURADO INNER JOIN SP_CONCEPTOS ON SP_FACTURADO.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_FACTURADO.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_FACTURADO.COMPANIA = :COMPANIA AND SP_FACTURADO.CICLO = :CICLO AND SP_FACTURADO.CODIGORUTA = :CODIGORUTA AND SP_FACTURADO.ANO = :ANO AND SP_FACTURADO.PERIODO = :PERIODO AND (SP_FACTURADO.CONCEPTO BETWEEN 1 AND 49 OR SP_FACTURADO.CONCEPTO IN(201,202,203,204,205,206,207,246,247,248,249)) ORDER BY SP_FACTURADO.COMPANIA, SP_FACTURADO.CICLO, SP_FACTURADO.CODIGORUTA, SP_FACTURADO.CONCEPTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER( '%' || :CICLO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN FDEUDA IS NULL THEN ' ' ELSE UPPER(FDEUDA) END)  LIKE UPPER( '%' || :FDEUDA || '%')  AND (CASE WHEN FPERIODO IS NULL THEN ' ' ELSE UPPER(FPERIODO) END)  LIKE UPPER( '%' || :FPERIODO || '%')  AND (CASE WHEN TOTALFIN IS NULL THEN ' ' ELSE UPPER(TOTALFIN) END)  LIKE UPPER( '%' || :TOTALFIN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="DETFACT" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
