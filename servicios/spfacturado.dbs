	<query id="getSpfacturadoPoranoyperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT ANO, PERIODO, CICLO FROM SP_FACTURADO WHERE COMPANIA =:COMPANIA AND CONCAT(ANO,PERIODO) &gt;= CONCAT(:ANO,:PERIODO) ORDER BY ANO, PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
