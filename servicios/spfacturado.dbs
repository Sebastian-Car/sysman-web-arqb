<data name="spfacturado" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpfacturadoListaSubFacturadosCreditoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  F.COMPANIA, F.CICLO, F.CODIGORUTA, F.ANO, F.PERIODO, F.CONCEPTO, F.SALDOCREDITO, F.CREDITOABONADO, C.NOMBRE NOMBRECONCEPTO  FROM SP_FACTURADO F LEFT JOIN SP_CONCEPTOS C ON F.CONCEPTO = C.CODIGO AND F.COMPANIA = C.COMPANIA WHERE F.COMPANIA = :COMPANIA AND F.CICLO = :CICLO AND F.CODIGORUTA = :CODIGORUTA AND F.ANO = :ANO AND F.PERIODO = :PERIODO AND (F.CONCEPTO BETWEEN 1 AND 48 OR F.CONCEPTO IN(201, 202, 203, 204, 205, 206, 207, 246, 247, 248, 249)) AND F.SALDOCREDITO + F.CREDITOABONADO &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CONCEPTO":"$CONCEPTO(type:integer)","SALDOCREDITO":"$SALDOCREDITO","CREDITOABONADO":"$CREDITOABONADO","NOMBRECONCEPTO":"$NOMBRECONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/listasubfacturadoscredito">
		<call-query href="getSpfacturadoListaSubFacturadosCreditoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoFacturalistasubfacturadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FACTURADO.COMPANIA, FACTURADO.CICLO, FACTURADO.CODIGORUTA, FACTURADO.ANO, FACTURADO.PERIODO, FACTURADO.CONCEPTO, FACTURADO.VALOR_FACTURADO, FACTURADO.DEUDA, SP_CONCEPTOS.NOMBRE, CASE WHEN FACTURADO.CONCEPTO IN (1,2,3,4,5,10,12,14,17,18,20,21,22,23,33,49,TO_NUMBER(:NUMERO),TO_NUMBER(:NUMERO)-1) THEN 0 ELSE 1 END MODIFICA  FROM SP_FACTURADO FACTURADO LEFT JOIN SP_CONCEPTOS ON FACTURADO.COMPANIA = SP_CONCEPTOS.COMPANIA AND FACTURADO.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE FACTURADO.COMPANIA = :COMPANIA AND FACTURADO.CICLO = :CICLOACTUAL AND FACTURADO.CODIGORUTA = :CODIGORUTA2 AND FACTURADO.ANO = :ANO AND FACTURADO.PERIODO = :PERIODO AND (FACTURADO.CONCEPTO BETWEEN 0 AND 50 OR FACTURADO.CONCEPTO IN(246, 247, 248, 249, 250) OR FACTURADO.CONCEPTO BETWEEN 208 AND 220 OR FACTURADO.CONCEPTO BETWEEN 201 AND 207) AND ((ABS(NVL(VALOR_FACTURADO, 0)) + ABS(NVL(DEUDA, 0))) NOT IN(0)) ORDER BY FACTURADO.CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CONCEPTO":"$CONCEPTO(type:integer)","VALOR_FACTURADO":"$VALOR_FACTURADO","DEUDA":"$DEUDA","NOMBRE":"$NOMBRE","MODIFICA":"$MODIFICA(type:integer)"}]}}		</result>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA2" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/facturalistasubfacturado">
		<call-query href="getSpfacturadoFacturalistasubfacturadoQuery">
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTA2" query-param="CODIGORUTA2"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoFacturalistasubfacturadoantQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FACTURADO.COMPANIA, FACTURADO.CICLO, FACTURADO.CODIGORUTA, FACTURADO.ANO, FACTURADO.PERIODO, FACTURADO.CONCEPTO, FACTURADO.VALOR_FACTURADOANT, FACTURADO.DEUDAANT, SP_CONCEPTOS.NOMBRE  FROM SP_FACTURADO FACTURADO LEFT JOIN SP_CONCEPTOS ON FACTURADO.COMPANIA = SP_CONCEPTOS.COMPANIA AND FACTURADO.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE FACTURADO.COMPANIA = :COMPANIA AND FACTURADO.CICLO = :CICLOACTUAL AND FACTURADO.CODIGORUTA = :CODIGORUTA2 AND FACTURADO.ANO = :ANO AND FACTURADO.PERIODO = :PERIODO AND ((FACTURADO.CONCEPTO BETWEEN 1 AND 49) OR (FACTURADO.CONCEPTO IN(201, 202, 203, 204, 205, 206, 207, 246, 247, 248, 249))) ORDER BY FACTURADO.CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CONCEPTO":"$CONCEPTO(type:integer)","VALOR_FACTURADOANT":"$VALOR_FACTURADOANT","DEUDAANT":"$DEUDAANT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA2" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/facturalistasubfacturadoant">
		<call-query href="getSpfacturadoFacturalistasubfacturadoantQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTA2" query-param="CODIGORUTA2"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoConsultarTotalSaldoCreditoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(F.SALDOCREDITO),0) VALOR  FROM SP_FACTURADO F LEFT JOIN SP_CONCEPTOS C ON F.CONCEPTO = C.CODIGO AND F.COMPANIA = C.COMPANIA WHERE F.COMPANIA = :COMPANIA AND F.CICLO = :CICLO AND F.CODIGORUTA = :CODIGORUTA AND F.ANO = :ANO AND F.PERIODO = :PERIODO AND (F.CONCEPTO BETWEEN 1 AND 48 OR F.CONCEPTO IN(201, 202, 203, 204, 205, 206, 207, 246, 247, 248, 249) ) AND F.SALDOCREDITO + F.CREDITOABONADO &lt;&gt; 0 ORDER BY F.CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/consultartotalsaldocredito">
		<call-query href="getSpfacturadoConsultarTotalSaldoCreditoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoConsultarTotalSaldoAbonadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(F.CREDITOABONADO),0) VALOR  FROM SP_FACTURADO F LEFT JOIN SP_CONCEPTOS C ON F.CONCEPTO = C.CODIGO AND F.COMPANIA = C.COMPANIA WHERE F.COMPANIA = :COMPANIA AND F.CICLO = :CICLO AND F.CODIGORUTA = :CODIGORUTA AND F.ANO = :ANO AND F.PERIODO = :PERIODO AND ( F.CONCEPTO BETWEEN 1 AND 48 OR F.CONCEPTO IN(201, 202, 203, 204, 205, 206, 207, 246, 247, 248, 249) ) AND F.SALDOCREDITO + F.CREDITOABONADO &lt;&gt; 0 ORDER BY F.CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/consultartotalsaldoabonado">
		<call-query href="getSpfacturadoConsultarTotalSaldoAbonadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoConsultarTotalValorFacturadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(VALOR_FACTURADO),0) VALOR_FACTURADO  FROM SP_FACTURADO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA= :CODIGORUTA AND PERIODO = :PERIODO AND ANO = :ANO AND (CONCEPTO BETWEEN 0 AND 50 OR CONCEPTO IN (246,247,248,249,250) OR CONCEPTO BETWEEN 201 AND 207 ) AND ABS(VALOR_FACTURADO) + ABS(DEUDA) &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_FACTURADO":"$VALOR_FACTURADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/consultartotalvalorfacturado">
		<call-query href="getSpfacturadoConsultarTotalValorFacturadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoTotalesperiodoactualQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(FACTURADO.VALOR_FACTURADO) TOTAL_FACTURADO, SUM(FACTURADO.DEUDA) TOTAL_DEUDA  FROM SP_FACTURADO FACTURADO WHERE FACTURADO.COMPANIA = :COMPANIA AND FACTURADO.CICLO = :CICLOACTUAL AND FACTURADO.CODIGORUTA = :CODIGORUTA AND FACTURADO.ANO = :ANO AND FACTURADO.PERIODO = :PERIODO AND (FACTURADO.CONCEPTO BETWEEN 0 AND 50 OR FACTURADO.CONCEPTO IN(246, 247, 248, 249, 250) OR FACTURADO.CONCEPTO BETWEEN 208 AND 220 OR FACTURADO.CONCEPTO BETWEEN 201 AND 207) AND ((ABS(NVL(VALOR_FACTURADO, 0)) + ABS(NVL(DEUDA, 0))) NOT IN(0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_FACTURADO":"$TOTAL_FACTURADO(type:integer)","TOTAL_DEUDA":"$TOTAL_DEUDA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/totalesperiodoactual">
		<call-query href="getSpfacturadoTotalesperiodoactualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoTotalesperiodoanteriorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(FACTURADO.VALOR_FACTURADOANT) TOTAL_FACTURADO_ANT, SUM(FACTURADO.DEUDAANT) TOTAL_DEUDA_ANT  FROM SP_FACTURADO FACTURADO WHERE FACTURADO.COMPANIA = :COMPANIA AND FACTURADO.CICLO = :CICLOACTUAL AND FACTURADO.CODIGORUTA = :CODIGORUTA AND FACTURADO.ANO = :ANO AND FACTURADO.PERIODO = :PERIODO AND (FACTURADO.CONCEPTO BETWEEN 0 AND 50 OR FACTURADO.CONCEPTO IN(246, 247, 248, 249, 250) OR FACTURADO.CONCEPTO BETWEEN 208 AND 220 OR FACTURADO.CONCEPTO BETWEEN 201 AND 207) AND ((ABS(NVL(VALOR_FACTURADO, 0)) + ABS(NVL(DEUDA, 0))) NOT IN(0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_FACTURADO_ANT":"$TOTAL_FACTURADO_ANT(type:integer)","TOTAL_DEUDA_ANT":"$TOTAL_DEUDA_ANT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/totalesperiodoanterior">
		<call-query href="getSpfacturadoTotalesperiodoanteriorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="updateSpfacturadoActualizarDeudas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_FACTURADO SET DEUDA = :DEUDA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND SP_FACTURADO.ANO  = :ANO AND SP_FACTURADO.PERIODO = :PERIODO AND SP_FACTURADO.CONCEPTO = :CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DEUDA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spfacturado/actualizardeudas">
		<call-query href="updateSpfacturadoActualizarDeudas">
			<with-param name="DEUDA" query-param="DEUDA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getSpfacturadoConsultarTotalesFacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(FACTURADO.VALOR_FACTURADO),0) AS SVF, NVL(SUM(FACTURADO.DEUDA),0) AS SD  FROM SP_FACTURADO FACTURADO WHERE COMPANIA= :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND ( CONCEPTO BETWEEN 1 AND 49 OR CONCEPTO IN(201,202,203,204,205,206,207,246,247,248,249,250))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SVF":"$SVF(type:integer)","SD":"$SD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfacturado/consultartotalesfactura">
		<call-query href="getSpfacturadoConsultarTotalesFacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="insertSpfacturadoInsertarcptosubfacturado" keyColumns="COMPANIA,CICLO,CODIGORUTA,ANO,PERIODO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_FACTURADO (COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, CONCEPTO, VALOR_FACTURADO, DEUDA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CICLO, :CODIGORUTA, :ANO, :PERIODO, :CONCEPTO, :VALOR_FACTURADO, :DEUDA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_CONCEPTO":"$CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_FACTURADO" sqlType="STRING"/>
		<param defaultValue="0" name="DEUDA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spfacturado/insertarcptosubfacturado">
		<call-query href="insertSpfacturadoInsertarcptosubfacturado">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="VALOR_FACTURADO" query-param="VALOR_FACTURADO"/>
			<with-param name="DEUDA" query-param="DEUDA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateSpfacturadoActualizarcptosubfacturado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_FACTURADO SET CONCEPTO=:CONCEPTO, VALOR_FACTURADO=:VALOR_FACTURADO, DEUDA=:DEUDA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_FACTURADO.COMPANIA= :KEY_COMPANIA AND SP_FACTURADO.CICLO= :KEY_CICLO AND SP_FACTURADO.CODIGORUTA= :KEY_CODIGORUTA AND SP_FACTURADO.ANO= :KEY_ANO AND SP_FACTURADO.PERIODO= :KEY_PERIODO AND SP_FACTURADO.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="VALOR_FACTURADO" sqlType="STRING"/>
		<param name="DEUDA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spfacturado/actualizarcptosubfacturado">
		<call-query href="updateSpfacturadoActualizarcptosubfacturado">
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="VALOR_FACTURADO" query-param="VALOR_FACTURADO"/>
			<with-param name="DEUDA" query-param="DEUDA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

