	<query id="getSpcertificadosestratificacionActafinancQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_CERTIFICADOSESTRATIFICACION.COMPANIA, SP_CERTIFICADOSESTRATIFICACION.IDACTA, SP_CERTIFICADOSESTRATIFICACION.CLASE, SP_CERTIFICADOSESTRATIFICACION.CICLO, SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA,(TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.FECHAACTA,'DD/MM/YYYY HH24:MI:SS')) FECHAACTA,(CASE SP_CERTIFICADOSESTRATIFICACION.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, SP_CERTIFICADOSESTRATIFICACION.CONCEPTO_INI, SP_CERTIFICADOSESTRATIFICACION.CONCEPTO_FIN, SP_CERTIFICADOSESTRATIFICACION.TOTFACTURAPERACTUAL, SP_CERTIFICADOSESTRATIFICACION.ANOFINANCIABLE, SP_CERTIFICADOSESTRATIFICACION.PERIODOFINANCIABLE, SP_CERTIFICADOSESTRATIFICACION.CREATED_BY,(TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_CERTIFICADOSESTRATIFICACION.MODIFIED_BY,(TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CONCAT(USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',USUARIO.NOMBRES) ) ) ) NOMBRE FROM SP_CERTIFICADOSESTRATIFICACION INNER JOIN SP_USUARIO USUARIO ON SP_CERTIFICADOSESTRATIFICACION.COMPANIA = USUARIO.COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.CICLO = USUARIO.CICLO AND SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA = USUARIO.CODIGORUTA WHERE SP_CERTIFICADOSESTRATIFICACION.COMPANIA =:KEY_COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.IDACTA =:KEY_IDACTA AND SP_CERTIFICADOSESTRATIFICACION.CLASE =:KEY_CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDACTA":"$IDACTA","CLASE":"$CLASE","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","FECHAACTA":"$FECHAACTA","IMPRESO":"$IMPRESO(type:boolean)","CONCEPTO_INI":"$CONCEPTO_INI(type:integer)","CONCEPTO_FIN":"$CONCEPTO_FIN(type:integer)","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","ANOFINANCIABLE":"$ANOFINANCIABLE(type:integer)","PERIODOFINANCIABLE":"$PERIODOFINANCIABLE","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDACTA" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>

	</query>
