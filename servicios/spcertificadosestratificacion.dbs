	<query id="getSpcertificadosestratificacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_CERTIFICADOSESTRATIFICACION.COMPANIA,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, SP_CERTIFICADOSESTRATIFICACION.CLASE,SP_CERTIFICADOSESTRATIFICACION.IdActa, SP_CERTIFICADOSESTRATIFICACION.CICLO, SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA, TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.FECHAACTA, 'DD/MM/YYYY') AS FECHAACTA, SP_CERTIFICADOSESTRATIFICACION.DESTINO  FROM SP_CERTIFICADOSESTRATIFICACION WHERE SP_CERTIFICADOSESTRATIFICACION.COMPANIA = :COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.CLASE = 'CDES' ORDER BY TO_NUMBER(SP_CERTIFICADOSESTRATIFICACION.IDACTA)) WHERE (CASE WHEN IDACTA IS NULL THEN ' ' ELSE UPPER(IDACTA) END)  LIKE UPPER(:IDACTA || '%')  AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER(:CICLO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN FECHAACTA IS NULL THEN ' ' ELSE UPPER(FECHAACTA) END)  LIKE UPPER( '%' || :FECHAACTA || '%')  AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END)  LIKE UPPER(:DESTINO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IMPRESO":"$IMPRESO(type:boolean)","CLASE":"$CLASE","IDACTA":"$IDACTA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","FECHAACTA":"$FECHAACTA","DESTINO":"$DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDACTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="FECHAACTA" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
