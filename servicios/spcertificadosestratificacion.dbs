<data name="spcertificadosestratificacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpcertificadosestratificacionPagOrigenActasFinanciablesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_CERTIFICADOSESTRATIFICACION.COMPANIA, SP_CERTIFICADOSESTRATIFICACION.IDACTA, SP_CERTIFICADOSESTRATIFICACION.CLASE, SP_CERTIFICADOSESTRATIFICACION.CICLO, TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.FECHAACTA,'DD/MM/YYYY') FECHAACTA, SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA, CONCAT(USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',USUARIO.NOMBRES) ) ) ) NOMBRE,(CASE SP_CERTIFICADOSESTRATIFICACION.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO FROM SP_CERTIFICADOSESTRATIFICACION INNER JOIN SP_USUARIO USUARIO ON SP_CERTIFICADOSESTRATIFICACION.COMPANIA = USUARIO.COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.CICLO = USUARIO.CICLO AND SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA = USUARIO.CODIGORUTA WHERE SP_CERTIFICADOSESTRATIFICACION.COMPANIA =:COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.CLASE = '37' ORDER BY TO_NUMBER(SP_CERTIFICADOSESTRATIFICACION.IDACTA)) INI WHERE (CASE WHEN IDACTA IS NULL THEN ' ' ELSE UPPER(IDACTA) END) LIKE UPPER(CONCAT(:IDACTA, '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN FECHAACTA IS NULL THEN ' ' ELSE UPPER(FECHAACTA) END) LIKE UPPER(CONCAT(:FECHAACTA, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(:IMPRESO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDACTA":"$IDACTA","CLASE":"$CLASE","CICLO":"$CICLO(type:integer)","FECHAACTA":"$FECHAACTA","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","IMPRESO":"$IMPRESO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDACTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="FECHAACTA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spcertificadosestratificacion/origenactasfinanciables/pag">
		<call-query href="getSpcertificadosestratificacionPagOrigenActasFinanciablesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDACTA" query-param="IDACTA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="FECHAACTA" query-param="FECHAACTA"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpcertificadosestratificacionNumOrigenActasFinanciablesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_CERTIFICADOSESTRATIFICACION.COMPANIA, SP_CERTIFICADOSESTRATIFICACION.IDACTA, SP_CERTIFICADOSESTRATIFICACION.CLASE, SP_CERTIFICADOSESTRATIFICACION.CICLO, TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.FECHAACTA,'DD/MM/YYYY') FECHAACTA, SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA, CONCAT(USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',USUARIO.NOMBRES) ) ) ) NOMBRE,(CASE SP_CERTIFICADOSESTRATIFICACION.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO FROM SP_CERTIFICADOSESTRATIFICACION INNER JOIN SP_USUARIO USUARIO ON SP_CERTIFICADOSESTRATIFICACION.COMPANIA = USUARIO.COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.CICLO = USUARIO.CICLO AND SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA = USUARIO.CODIGORUTA WHERE SP_CERTIFICADOSESTRATIFICACION.COMPANIA =:COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.CLASE = '37' ORDER BY TO_NUMBER(SP_CERTIFICADOSESTRATIFICACION.IDACTA)) INI WHERE (CASE WHEN IDACTA IS NULL THEN ' ' ELSE UPPER(IDACTA) END) LIKE UPPER(CONCAT(:IDACTA, '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN FECHAACTA IS NULL THEN ' ' ELSE UPPER(FECHAACTA) END) LIKE UPPER(CONCAT(:FECHAACTA, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(:IMPRESO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDACTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="FECHAACTA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spcertificadosestratificacion/origenactasfinanciables/num">
		<call-query href="getSpcertificadosestratificacionNumOrigenActasFinanciablesQuery">
