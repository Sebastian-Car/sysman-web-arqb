	<query id="deleteSpcertificadosestratificacionBorraActaFinanciable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE  FROM SP_CERTIFICADOSESTRATIFICACION   WHERE SP_CERTIFICADOSESTRATIFICACION.COMPANIA = :KEY_COMPANIA               AND SP_CERTIFICADOSESTRATIFICACION.CLASE    = :KEY_CLASE AND  SP_CERTIFICADOSESTRATIFICACION.IDACTA = :KEY_IDACTA</sql>
