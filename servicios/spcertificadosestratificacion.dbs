	<query id="updateSpcertificadosestratificacionActFinan" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_CERTIFICADOSESTRATIFICACION SET ANOFINANCIABLE=:ANOFINANCIABLE, FECHAACTA=TO_DATE(:FECHAACTA,'DD/MM/YYYY HH24:MI:SS'), CICLO=:CICLO, CONCEPTO_INI=:CONCEPTO_INI, IMPRESO=:IMPRESO, CODIGORUTA=:CODIGORUTA, TOTFACTURAPERACTUAL=:TOTFACTURAPERACTUAL, PERIODOFINANCIABLE=:PERIODOFINANCIABLE, CONCEPTO_FIN=:CONCEPTO_FIN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_CERTIFICADOSESTRATIFICACION.COMPANIA= :KEY_COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.IDACTA= :KEY_IDACTA AND SP_CERTIFICADOSESTRATIFICACION.CLASE= :KEY_CLASE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
