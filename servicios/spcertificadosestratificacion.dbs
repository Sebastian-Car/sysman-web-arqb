	<query id="getSpcertificadosestratificacionpazYsalvoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_CERTIFICADOSESTRATIFICACION.COMPANIA, SP_CERTIFICADOSESTRATIFICACION.IDACTA, SP_CERTIFICADOSESTRATIFICACION.CLASE, SP_CERTIFICADOSESTRATIFICACION.CICLO, SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA,(TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.FECHAACTA,'DD/MM/YYYY HH24:MI:SS')) FECHAACTA, SP_CERTIFICADOSESTRATIFICACION.DESTINO,(TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.VALIDOHASTA,'DD/MM/YYYY HH24:MI:SS')) VALIDOHASTA,(CASE SP_CERTIFICADOSESTRATIFICACION.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, SP_CERTIFICADOSESTRATIFICACION.CREATED_BY,(TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_CERTIFICADOSESTRATIFICACION.MODIFIED_BY,(TO_CHAR(SP_CERTIFICADOSESTRATIFICACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE FROM SP_USUARIO INNER JOIN SP_CERTIFICADOSESTRATIFICACION ON SP_USUARIO.COMPANIA = SP_CERTIFICADOSESTRATIFICACION.COMPANIA AND SP_USUARIO.CICLO = SP_CERTIFICADOSESTRATIFICACION.CICLO AND SP_USUARIO.CODIGORUTA = SP_CERTIFICADOSESTRATIFICACION.CODIGORUTA WHERE SP_CERTIFICADOSESTRATIFICACION.COMPANIA =:KEY_COMPANIA AND SP_CERTIFICADOSESTRATIFICACION.IDACTA =:KEY_IDACTA AND SP_CERTIFICADOSESTRATIFICACION.CLASE =:KEY_CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDACTA":"$IDACTA","CLASE":"$CLASE","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","FECHAACTA":"$FECHAACTA","DESTINO":"$DESTINO","VALIDOHASTA":"$VALIDOHASTA","IMPRESO":"$IMPRESO(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDACTA" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>

	</query>
