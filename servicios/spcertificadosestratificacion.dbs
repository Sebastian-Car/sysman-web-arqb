	</resource>
	<query id="insertSpcertificadosestratificacionActaFinanciable" keyColumns="COMPANIA,IDACTA,CLASE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_CERTIFICADOSESTRATIFICACION (COMPANIA, CICLO, FECHAACTA, IDACTA, CLASE, CODIGORUTA, CONCEPTO_INI, CONCEPTO_FIN, TOTFACTURAPERACTUAL, PERIODOFINANCIABLE, ANOFINANCIABLE, IMPRESO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CICLO, TO_DATE(:FECHAACTA,'DD/MM/YYYY HH24:MI:SS'), :IDACTA, :CLASE, :CODIGORUTA, :CONCEPTO_INI, :CONCEPTO_FIN, :TOTFACTURAPERACTUAL, :PERIODOFINANCIABLE, :ANOFINANCIABLE, :IMPRESO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDACTA":"$IDACTA","KEY_CLASE":"$CLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAACTA" sqlType="STRING"/>
		<param name="IDACTA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param defaultValue="NULL" name="CONCEPTO_INI" sqlType="STRING"/>
		<param defaultValue="NULL" name="CONCEPTO_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="TOTFACTURAPERACTUAL" sqlType="STRING"/>
		<param defaultValue="" name="PERIODOFINANCIABLE" sqlType="STRING"/>
		<param defaultValue="" name="ANOFINANCIABLE" sqlType="STRING"/>
		<param defaultValue="0" name="IMPRESO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
