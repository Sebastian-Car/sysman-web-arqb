	<query id="insertSpcertificadosestratificacion" keyColumns="COMPANIA,IDACTA,CLASE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_CERTIFICADOSESTRATIFICACION (COMPANIA, CLASE, IDACTA, CICLO, CODIGORUTA, FECHAACTA, DESTINO, CREATED_BY, DATE_CREATED, IMPRESO) VALUES (:COMPANIA, :CLASE, :IDACTA, :CICLO, :CODIGORUTA, TO_DATE(:FECHAACTA,'DD/MM/YYYY HH24:MI:SS'), :DESTINO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :IMPRESO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDACTA":"$IDACTA","KEY_CLASE":"$CLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
