		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDACTA":"$IDACTA","CLASE":"$CLASE","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","FECHAACTA":"$FECHAACTA","IMPRESO":"$IMPRESO(type:boolean)","DESTINO":"$DESTINO"}]}}		</result>
