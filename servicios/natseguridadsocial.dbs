	<query id="insertNatseguridadsocialRegistrarsegsoci" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,SS_REGIMEN" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_SEGURIDAD_SOCIAL (COMPANIA, DP_NUMEDOCU, SUCURSAL, ID_DE_EMPLEADO, SS_REGIMEN, SS_FECHVINC, SS_ENTIDAD, SS_NOVEDAD, SS_NRORADICACION, SS_FECHARADICACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :ID_DE_EMPLEADO, :SS_REGIMEN, TO_DATE(:SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS'), :SS_ENTIDAD, :SS_NOVEDAD, :SS_NRORADICACION, TO_DATE(:SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_SS_REGIMEN":"$SS_REGIMEN","KEY_SS_FECHVINC":"$SS_FECHVINC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="DP_NUMEDOCU" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="SS_REGIMEN" sqlType="STRING"/>
		<param name="SS_FECHVINC" sqlType="STRING"/>
		<param defaultValue="" name="SS_ENTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="SS_NOVEDAD" sqlType="STRING"/>
		<param defaultValue="" name="SS_NRORADICACION" sqlType="STRING"/>
		<param defaultValue="" name="SS_FECHARADICACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
