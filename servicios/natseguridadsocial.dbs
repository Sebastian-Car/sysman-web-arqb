	</resource>
	<query id="getNatseguridadsocialNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_SEGURIDAD_SOCIAL.COMPANIA, NAT_SEGURIDAD_SOCIAL.SUCURSAL, NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU, NAT_SEGURIDAD_SOCIAL.SS_REGIMEN, NAT_SEGURIDAD_SOCIAL.ID_DE_EMPLEADO,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS')) SS_FECHVINC, NAT_SEGURIDAD_SOCIAL.DP_TIPODOCU, NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD, NAT_SEGURIDAD_SOCIAL.SS_NOVEDAD, NAT_SEGURIDAD_SOCIAL.SS_NRORADICACION,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS')) SS_FECHARADICACION, CASE (:CODIGO) WHEN '0' THEN V_FONDO_DE_RIESGOS.NOMBRE_FONDO_RIESGOS WHEN '1' THEN V_FONDO_DE_SALUD.NOMBRE_FONDO_SALUD WHEN '2' THEN V_FONDO_DE_CESANTIAS.NOMBRE_FONDO_CESANTIAS END NOMBRE_FONDO  FROM NAT_SEGURIDAD_SOCIAL LEFT JOIN V_FONDO_DE_RIESGOS ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_FONDO_DE_RIESGOS.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_FONDO_DE_RIESGOS.FONDO_RIESGOS AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = V_FONDO_DE_RIESGOS.SUCURSAL LEFT JOIN V_FONDO_DE_SALUD ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_FONDO_DE_SALUD.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_FONDO_DE_SALUD.FONDO_SALUD AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = V_FONDO_DE_SALUD.SUCURSAL LEFT JOIN V_FONDO_DE_CESANTIAS ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_FONDO_DE_CESANTIAS.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_FONDO_DE_CESANTIAS.FONDO_CESANTIAS WHERE NAT_SEGURIDAD_SOCIAL.COMPANIA = :COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU = :DP_NUMEDOCU AND NAT_SEGURIDAD_SOCIAL.SS_REGIMEN = :REGIMEN AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN SS_FECHVINC IS NULL THEN ' ' ELSE UPPER(SS_FECHVINC) END)  LIKE UPPER( '%' || :SS_FECHVINC || '%')  AND (CASE WHEN SS_NRORADICACION IS NULL THEN ' ' ELSE UPPER(SS_NRORADICACION) END)  LIKE UPPER( '%' || :SS_NRORADICACION || '%')  AND (CASE WHEN SS_FECHARADICACION IS NULL THEN ' ' ELSE UPPER(SS_FECHARADICACION) END)  LIKE UPPER( '%' || :SS_FECHARADICACION || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="SS_FECHVINC" sqlType="STRING"/>
		<param name="SS_NRORADICACION" sqlType="STRING"/>
		<param name="SS_FECHARADICACION" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natseguridadsocial/numero">
		<call-query href="getNatseguridadsocialNumeroQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="REGIMEN" query-param="REGIMEN"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="SS_FECHVINC" query-param="SS_FECHVINC"/>
			<with-param name="SS_NRORADICACION" query-param="SS_NRORADICACION"/>
			<with-param name="SS_FECHARADICACION" query-param="SS_FECHARADICACION"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>

		</call-query>
	</resource>
	<query id="updateNatseguridadsocial" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_SEGURIDAD_SOCIAL SET SS_REGIMEN=:SS_REGIMEN, SS_FECHVINC=TO_DATE(:SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS'), DP_TIPODOCU=:DP_TIPODOCU, SS_ENTIDAD=:SS_ENTIDAD, SS_NOVEDAD=:SS_NOVEDAD, SS_NRORADICACION=:SS_NRORADICACION, SS_FECHARADICACION=TO_DATE(:SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_SEGURIDAD_SOCIAL.COMPANIA= :KEY_COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_SEGURIDAD_SOCIAL.SUCURSAL= :KEY_SUCURSAL AND NAT_SEGURIDAD_SOCIAL.SS_REGIMEN= :KEY_SS_REGIMEN AND NAT_SEGURIDAD_SOCIAL.SS_FECHVINC= TO_DATE(:KEY_SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SS_REGIMEN" sqlType="STRING"/>
		<param name="SS_FECHVINC" sqlType="STRING"/>
		<param name="DP_TIPODOCU" sqlType="STRING"/>
		<param name="SS_ENTIDAD" sqlType="STRING"/>
		<param name="SS_NOVEDAD" sqlType="STRING"/>
		<param name="SS_NRORADICACION" sqlType="STRING"/>
		<param name="SS_FECHARADICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_SS_REGIMEN" sqlType="STRING"/>
		<param name="KEY_SS_FECHVINC" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natseguridadsocial">
		<call-query href="updateNatseguridadsocial">
			<with-param name="SS_REGIMEN" query-param="SS_REGIMEN"/>
			<with-param name="SS_FECHVINC" query-param="SS_FECHVINC"/>
			<with-param name="DP_TIPODOCU" query-param="DP_TIPODOCU"/>
			<with-param name="SS_ENTIDAD" query-param="SS_ENTIDAD"/>
			<with-param name="SS_NOVEDAD" query-param="SS_NOVEDAD"/>
			<with-param name="SS_NRORADICACION" query-param="SS_NRORADICACION"/>
			<with-param name="SS_FECHARADICACION" query-param="SS_FECHARADICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_SS_REGIMEN" query-param="KEY_SS_REGIMEN"/>
			<with-param name="KEY_SS_FECHVINC" query-param="KEY_SS_FECHVINC"/>

		</call-query>
	</resource>

