	<query id="getNatseguridadsocialNumGrilaNatcajascompQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_SEGURIDAD_SOCIAL.COMPANIA, NAT_SEGURIDAD_SOCIAL.SUCURSAL, NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU, TERCERO.NOMBRE, NAT_SEGURIDAD_SOCIAL.SS_REGIMEN,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS')) SS_FECHVINC, V_CAJA_COMPENSACION.NOMBRE_CAJA NOM_ENTIDAD, NAT_SEGURIDAD_SOCIAL.SS_NRORADICACION,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS')) SS_FECHARADICACION FROM NAT_SEGURIDAD_SOCIAL LEFT JOIN V_CAJA_COMPENSACION ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_CAJA_COMPENSACION.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_CAJA_COMPENSACION.CAJA_COMPENSACION LEFT JOIN TERCERO ON NAT_SEGURIDAD_SOCIAL.COMPANIA = TERCERO.COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU = TERCERO.NIT AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = TERCERO.SUCURSAL WHERE NAT_SEGURIDAD_SOCIAL.COMPANIA = :KEY_COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU = :KEY_DP_NUMEDOCU AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = :KEY_SUCURSAL AND NAT_SEGURIDAD_SOCIAL.SS_REGIMEN = :REGIMEN) WHERE (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SS_REGIMEN IS NULL THEN ' ' ELSE UPPER(SS_REGIMEN) END)  LIKE UPPER( '%' || :SS_REGIMEN || '%')  AND (CASE WHEN SS_FECHVINC IS NULL THEN ' ' ELSE UPPER(SS_FECHVINC) END)  LIKE UPPER(:SS_FECHVINC || '%')  AND (CASE WHEN NOM_ENTIDAD IS NULL THEN ' ' ELSE UPPER(NOM_ENTIDAD) END)  LIKE UPPER( '%' || :NOM_ENTIDAD || '%')  AND (CASE WHEN SS_NRORADICACION IS NULL THEN ' ' ELSE UPPER(SS_NRORADICACION) END)  LIKE UPPER(:SS_NRORADICACION || '%')  AND (CASE WHEN SS_FECHARADICACION IS NULL THEN ' ' ELSE UPPER(SS_FECHARADICACION) END)  LIKE UPPER( '%' || :SS_FECHARADICACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
