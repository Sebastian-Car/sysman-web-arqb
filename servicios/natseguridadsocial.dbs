	<query id="getNatseguridadsocialPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_SEGURIDAD_SOCIAL.COMPANIA, NAT_SEGURIDAD_SOCIAL.SUCURSAL, NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU, NAT_SEGURIDAD_SOCIAL.SS_REGIMEN, NAT_SEGURIDAD_SOCIAL.ID_DE_EMPLEADO,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS')) SS_FECHVINC, NAT_SEGURIDAD_SOCIAL.DP_TIPODOCU, NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD, NAT_SEGURIDAD_SOCIAL.SS_NOVEDAD, NAT_SEGURIDAD_SOCIAL.SS_NRORADICACION,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS')) SS_FECHARADICACION, CASE (:CODIGO) WHEN '0' THEN V_FONDO_DE_RIESGOS.NOMBRE_FONDO_RIESGOS WHEN '1' THEN V_FONDO_DE_SALUD.NOMBRE_FONDO_SALUD WHEN '2' THEN V_FONDO_DE_CESANTIAS.NOMBRE_FONDO_CESANTIAS END NOMBRE_FONDO  FROM NAT_SEGURIDAD_SOCIAL LEFT JOIN V_FONDO_DE_RIESGOS ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_FONDO_DE_RIESGOS.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_FONDO_DE_RIESGOS.FONDO_RIESGOS AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = V_FONDO_DE_RIESGOS.SUCURSAL LEFT JOIN V_FONDO_DE_SALUD ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_FONDO_DE_SALUD.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_FONDO_DE_SALUD.FONDO_SALUD AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = V_FONDO_DE_SALUD.SUCURSAL LEFT JOIN V_FONDO_DE_CESANTIAS ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_FONDO_DE_CESANTIAS.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_FONDO_DE_CESANTIAS.FONDO_CESANTIAS WHERE NAT_SEGURIDAD_SOCIAL.COMPANIA = :COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU = :DP_NUMEDOCU AND NAT_SEGURIDAD_SOCIAL.SS_REGIMEN = :REGIMEN AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN SS_FECHVINC IS NULL THEN ' ' ELSE UPPER(SS_FECHVINC) END)  LIKE UPPER( '%' || :SS_FECHVINC || '%')  AND (CASE WHEN SS_NRORADICACION IS NULL THEN ' ' ELSE UPPER(SS_NRORADICACION) END)  LIKE UPPER( '%' || :SS_NRORADICACION || '%')  AND (CASE WHEN SS_FECHARADICACION IS NULL THEN ' ' ELSE UPPER(SS_FECHARADICACION) END)  LIKE UPPER( '%' || :SS_FECHARADICACION || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","DP_NUMEDOCU":"$DP_NUMEDOCU","SS_REGIMEN":"$SS_REGIMEN","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","SS_FECHVINC":"$SS_FECHVINC","DP_TIPODOCU":"$DP_TIPODOCU","SS_ENTIDAD":"$SS_ENTIDAD","SS_NOVEDAD":"$SS_NOVEDAD","SS_NRORADICACION":"$SS_NRORADICACION","SS_FECHARADICACION":"$SS_FECHARADICACION","NOMBRE_FONDO":"$NOMBRE_FONDO"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="SS_FECHVINC" sqlType="STRING"/>
		<param name="SS_NRORADICACION" sqlType="STRING"/>
		<param name="SS_FECHARADICACION" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
