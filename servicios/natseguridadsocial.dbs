	<query id="getNatseguridadsocialDatasegsociQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_SEGURIDAD_SOCIAL.COMPANIA, NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU, NAT_SEGURIDAD_SOCIAL.SUCURSAL, NAT_SEGURIDAD_SOCIAL.ID_DE_EMPLEADO, NAT_SEGURIDAD_SOCIAL.SS_REGIMEN,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS')) SS_FECHVINC, NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD, NAT_SEGURIDAD_SOCIAL.SS_NOVEDAD, NAT_SEGURIDAD_SOCIAL.SS_NRORADICACION,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS')) SS_FECHARADICACION, V_CAJA_COMPENSACION.NOMBRE_CAJA NOM_ENTIDAD,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, NAT_SEGURIDAD_SOCIAL.MODIFIED_BY, NAT_SEGURIDAD_SOCIAL.CREATED_BY  FROM NAT_SEGURIDAD_SOCIAL LEFT JOIN V_CAJA_COMPENSACION ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_CAJA_COMPENSACION.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_CAJA_COMPENSACION.CAJA_COMPENSACION WHERE NAT_SEGURIDAD_SOCIAL.COMPANIA = :KEY_COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU = :KEY_DP_NUMEDOCU AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = :KEY_SUCURSAL AND NAT_SEGURIDAD_SOCIAL.SS_REGIMEN = :KEY_SS_REGIMEN AND NAT_SEGURIDAD_SOCIAL.SS_FECHVINC = :KEY_SS_FECHVINC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","SS_REGIMEN":"$SS_REGIMEN","SS_FECHVINC":"$SS_FECHVINC","SS_ENTIDAD":"$SS_ENTIDAD","SS_NOVEDAD":"$SS_NOVEDAD","SS_NRORADICACION":"$SS_NRORADICACION","SS_FECHARADICACION":"$SS_FECHARADICACION","NOM_ENTIDAD":"$NOM_ENTIDAD","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","CREATED_BY":"$CREATED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_SS_REGIMEN" sqlType="STRING"/>
		<param name="KEY_SS_FECHVINC" sqlType="STRING"/>

	</query>
