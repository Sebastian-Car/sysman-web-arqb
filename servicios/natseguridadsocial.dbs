			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_SS_REGIMEN" query-param="KEY_SS_REGIMEN"/>
			<with-param name="KEY_SS_FECHVINC" query-param="KEY_SS_FECHVINC"/>

		</call-query>
	</resource>
	<query id="getNatseguridadsocialPagActualizarnatseguridadsocialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_SEGURIDAD_SOCIAL.COMPANIA, NAT_SEGURIDAD_SOCIAL.SUCURSAL, NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU, NAT_SEGURIDAD_SOCIAL.SS_REGIMEN, NAT_SEGURIDAD_SOCIAL.ID_DE_EMPLEADO,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS')) SS_FECHVINC, NAT_SEGURIDAD_SOCIAL.DP_TIPODOCU, NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD, NAT_SEGURIDAD_SOCIAL.SS_NOVEDAD, NAT_SEGURIDAD_SOCIAL.SS_NRORADICACION,(TO_CHAR(NAT_SEGURIDAD_SOCIAL.SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS')) SS_FECHARADICACION, V_FONDO_DE_PENSIONES.NOMBRE_DEL_FONDO  FROM NAT_SEGURIDAD_SOCIAL LEFT JOIN V_FONDO_DE_PENSIONES ON NAT_SEGURIDAD_SOCIAL.COMPANIA = V_FONDO_DE_PENSIONES.COMPANIA AND NAT_SEGURIDAD_SOCIAL.SS_ENTIDAD = V_FONDO_DE_PENSIONES.ID_DEL_FONDO AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = V_FONDO_DE_PENSIONES.SUCURSAL WHERE NAT_SEGURIDAD_SOCIAL.COMPANIA = :COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU = :DP_NUMEDOCU AND NAT_SEGURIDAD_SOCIAL.SS_REGIMEN = :REGIMEN AND NAT_SEGURIDAD_SOCIAL.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%')  AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER( '%' || :DP_NUMEDOCU || '%')  AND (CASE WHEN SS_REGIMEN IS NULL THEN ' ' ELSE UPPER(SS_REGIMEN) END)  LIKE UPPER(:SS_REGIMEN || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER( '%' || :ID_DE_EMPLEADO || '%')  AND (CASE WHEN SS_FECHVINC IS NULL THEN ' ' ELSE UPPER(SS_FECHVINC) END)  LIKE UPPER( '%' || :SS_FECHVINC || '%')  AND (CASE WHEN DP_TIPODOCU IS NULL THEN ' ' ELSE UPPER(DP_TIPODOCU) END)  LIKE UPPER( '%' || :DP_TIPODOCU || '%')  AND (CASE WHEN SS_ENTIDAD IS NULL THEN ' ' ELSE UPPER(SS_ENTIDAD) END)  LIKE UPPER( '%' || :SS_ENTIDAD || '%')  AND (CASE WHEN SS_NOVEDAD IS NULL THEN ' ' ELSE UPPER(SS_NOVEDAD) END)  LIKE UPPER( '%' || :SS_NOVEDAD || '%')  AND (CASE WHEN SS_NRORADICACION IS NULL THEN ' ' ELSE UPPER(SS_NRORADICACION) END)  LIKE UPPER( '%' || :SS_NRORADICACION || '%')  AND (CASE WHEN SS_FECHARADICACION IS NULL THEN ' ' ELSE UPPER(SS_FECHARADICACION) END)  LIKE UPPER( '%' || :SS_FECHARADICACION || '%')  AND (CASE WHEN NOMBRE_DEL_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_FONDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","DP_NUMEDOCU":"$DP_NUMEDOCU","SS_REGIMEN":"$SS_REGIMEN","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","SS_FECHVINC":"$SS_FECHVINC","DP_TIPODOCU":"$DP_TIPODOCU","SS_ENTIDAD":"$SS_ENTIDAD","SS_NOVEDAD":"$SS_NOVEDAD","SS_NRORADICACION":"$SS_NRORADICACION","SS_FECHARADICACION":"$SS_FECHARADICACION","NOMBRE_DEL_FONDO":"$NOMBRE_DEL_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="SS_REGIMEN" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="SS_FECHVINC" sqlType="STRING"/>
		<param name="DP_TIPODOCU" sqlType="STRING"/>
		<param name="SS_ENTIDAD" sqlType="STRING"/>
		<param name="SS_NOVEDAD" sqlType="STRING"/>
		<param name="SS_NRORADICACION" sqlType="STRING"/>
		<param name="SS_FECHARADICACION" sqlType="STRING"/>
		<param name="NOMBRE_DEL_FONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
