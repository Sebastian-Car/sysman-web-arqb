	<query id="updateNatseguridadsocialActualizarsegsoci" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_SEGURIDAD_SOCIAL SET COMPANIA=:COMPANIA, DP_NUMEDOCU=:DP_NUMEDOCU, SUCURSAL=:SUCURSAL, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, SS_REGIMEN=:SS_REGIMEN, SS_FECHVINC=TO_DATE(:SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS'), SS_ENTIDAD=:SS_ENTIDAD, SS_NOVEDAD=:SS_NOVEDAD, SS_NRORADICACION=:SS_NRORADICACION, SS_FECHARADICACION=TO_DATE(:SS_FECHARADICACION,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_SEGURIDAD_SOCIAL.COMPANIA= :KEY_COMPANIA AND NAT_SEGURIDAD_SOCIAL.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_SEGURIDAD_SOCIAL.SUCURSAL= :KEY_SUCURSAL AND NAT_SEGURIDAD_SOCIAL.SS_REGIMEN= :KEY_SS_REGIMEN AND NAT_SEGURIDAD_SOCIAL.SS_FECHVINC= TO_DATE(:KEY_SS_FECHVINC,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
