<data name="consorciados" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertConsorciados" keyColumns="COMPANIA,NIT,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONSORCIADOS (NOMBRE, SUCURSAL, COMPANIA, NITCONSORCIO, PORCPARTICIPACION, NIT, DATE_CREATED, CREATED_BY) VALUES (:NOMBRE, :SUCURSAL, :COMPANIA, :NITCONSORCIO, :PORCPARTICIPACION, :NIT, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NITCONSORCIO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCPARTICIPACION" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="consorciados">
		<call-query href="insertConsorciados">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITCONSORCIO" query-param="NITCONSORCIO"/>
			<with-param name="PORCPARTICIPACION" query-param="PORCPARTICIPACION"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConsorciados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONSORCIADOS WHERE CONSORCIADOS.COMPANIA= :KEY_COMPANIA AND CONSORCIADOS.NIT= :KEY_NIT AND CONSORCIADOS.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="consorciados">
		<call-query href="deleteConsorciados">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getConsorciadosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CONSORCIADOS.COMPANIA, CONSORCIADOS.NIT, CONSORCIADOS.SUCURSAL, CONSORCIADOS.NOMBRE, CONSORCIADOS.PORCPARTICIPACION, CONSORCIADOS.NITCONSORCIO  FROM CONSORCIADOS WHERE NITCONSORCIO=:NIT AND COMPANIA=:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","PORCPARTICIPACION":"$PORCPARTICIPACION","NITCONSORCIO":"$NITCONSORCIO"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="consorciados">
		<call-query href="getConsorciadosPaginaQuery">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateConsorciados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONSORCIADOS SET NOMBRE=:NOMBRE, PORCPARTICIPACION=:PORCPARTICIPACION, NITCONSORCIO=:NITCONSORCIO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE CONSORCIADOS.COMPANIA= :KEY_COMPANIA AND CONSORCIADOS.NIT= :KEY_NIT AND CONSORCIADOS.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PORCPARTICIPACION" sqlType="STRING"/>
		<param name="NITCONSORCIO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="consorciados">
		<call-query href="updateConsorciados">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PORCPARTICIPACION" query-param="PORCPARTICIPACION"/>
			<with-param name="NITCONSORCIO" query-param="NITCONSORCIO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>