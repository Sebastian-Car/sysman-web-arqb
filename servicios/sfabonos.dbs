		<param name="APLICACONDONACION" sqlType="STRING"/>
		<param name="CONDONACION" sqlType="STRING"/>
		<param name="OBSERVACION_CONDONACION" sqlType="STRING"/>
		<param name="TASA_INTERES" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="TIPO_FACT" sqlType="STRING"/>
		<param name="NRO_FACT" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
