<data name="pbpoblacionbeneficiada" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPbpoblacionbeneficiadaTraerdatosregistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPO, NUMERO, ID_PLAN, VIGENCIA_INICIAL, VALOR_PRIMINFANCIA, VALOR_ADOLESCENCIA, VALOR_JUVENTUD, VALOR_ADULTO, VALOR_ADULTO_MAYOR, VALOR_TOTAL, VALOR_MUJERES, VALOR_HOMBRES, VALOR_TOTGENERO, VALOR_VCA, VALOR_LGTB, VALOR_DISCAP, VALOR_AFRO, VALOR_INDIG, VALOR_INFANCIA, VALOR_TOTAL_COND FROM PB_POBLACION_BENEFICIADA WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND NUMERO = :NUMERO AND ID_PLAN = :ID_PLAN AND VIGENCIA_INICIAL = :VIGENCIA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:integer)","ID_PLAN":"$ID_PLAN","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:long)","VALOR_PRIMINFANCIA":"$VALOR_PRIMINFANCIA(type:integer)","VALOR_ADOLESCENCIA":"$VALOR_ADOLESCENCIA(type:integer)","VALOR_JUVENTUD":"$VALOR_JUVENTUD(type:integer)","VALOR_ADULTO":"$VALOR_ADULTO(type:integer)","VALOR_ADULTO_MAYOR":"$VALOR_ADULTO_MAYOR(type:integer)","VALOR_TOTAL":"$VALOR_TOTAL(type:integer)","VALOR_MUJERES":"$VALOR_MUJERES(type:integer)","VALOR_HOMBRES":"$VALOR_HOMBRES(type:integer)","VALOR_TOTGENERO":"$VALOR_TOTGENERO(type:integer)","VALOR_VCA":"$VALOR_VCA(type:integer)","VALOR_LGTB":"$VALOR_LGTB(type:integer)","VALOR_DISCAP":"$VALOR_DISCAP(type:integer)","VALOR_AFRO":"$VALOR_AFRO(type:integer)","VALOR_INDIG":"$VALOR_INDIG(type:integer)","VALOR_INFANCIA":"$VALOR_INFANCIA(type:integer)","VALOR_TOTAL_COND":"$VALOR_TOTAL_COND(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pbpoblacionbeneficiada/traerdatosregistro">
		<call-query href="getPbpoblacionbeneficiadaTraerdatosregistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="insertPbpoblacionbeneficiada" keyColumns="COMPANIA,TIPO,NUMERO,ID_PLAN,VIGENCIA_INICIAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PB_POBLACION_BENEFICIADA (COMPANIA, TIPO, NUMERO, ID_PLAN, VIGENCIA_INICIAL, VALOR_PRIMINFANCIA, VALOR_ADOLESCENCIA, VALOR_JUVENTUD, VALOR_ADULTO, VALOR_ADULTO_MAYOR, VALOR_TOTAL, VALOR_MUJERES, VALOR_HOMBRES, VALOR_TOTGENERO, VALOR_VCA, VALOR_LGTB, VALOR_DISCAP, VALOR_AFRO, VALOR_INDIG, VALOR_INFANCIA, VALOR_TOTAL_COND, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :NUMERO, :ID_PLAN, :VIGENCIA_INICIAL, :VALOR_PRIMINFANCIA, :VALOR_ADOLESCENCIA, :VALOR_JUVENTUD, :VALOR_ADULTO, :VALOR_ADULTO_MAYOR, :VALOR_TOTAL, :VALOR_MUJERES, :VALOR_HOMBRES, :VALOR_TOTGENERO, :VALOR_VCA, :VALOR_LGTB, :VALOR_DISCAP, :VALOR_AFRO, :VALOR_INDIG, :VALOR_INFANCIA, :VALOR_TOTAL_COND, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_PRIMINFANCIA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_ADOLESCENCIA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_JUVENTUD" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_ADULTO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_ADULTO_MAYOR" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_TOTAL" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_MUJERES" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_HOMBRES" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_TOTGENERO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_VCA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_LGTB" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_DISCAP" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_AFRO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_INDIG" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_INFANCIA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_TOTAL_COND" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="pbpoblacionbeneficiada">
		<call-query href="insertPbpoblacionbeneficiada">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VALOR_PRIMINFANCIA" query-param="VALOR_PRIMINFANCIA"/>
			<with-param name="VALOR_ADOLESCENCIA" query-param="VALOR_ADOLESCENCIA"/>
			<with-param name="VALOR_JUVENTUD" query-param="VALOR_JUVENTUD"/>
			<with-param name="VALOR_ADULTO" query-param="VALOR_ADULTO"/>
			<with-param name="VALOR_ADULTO_MAYOR" query-param="VALOR_ADULTO_MAYOR"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="VALOR_MUJERES" query-param="VALOR_MUJERES"/>
			<with-param name="VALOR_HOMBRES" query-param="VALOR_HOMBRES"/>
