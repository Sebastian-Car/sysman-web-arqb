	<query id="updatePbpoblacionbeneficiada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PB_POBLACION_BENEFICIADA SET COMPANIA=:COMPANIA, TIPO=:TIPO, NUMERO=:NUMERO, ID_PLAN=:ID_PLAN, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, VALOR_PRIMINFANCIA=:VALOR_PRIMINFANCIA, VALOR_ADOLESCENCIA=:VALOR_ADOLESCENCIA, VALOR_JUVENTUD=:VALOR_JUVENTUD, VALOR_ADULTO=:VALOR_ADULTO, VALOR_ADULTO_MAYOR=:VALOR_ADULTO_MAYOR, VALOR_TOTAL=:VALOR_TOTAL, VALOR_MUJERES=:VALOR_MUJERES, VALOR_HOMBRES=:VALOR_HOMBRES, VALOR_TOTGENERO=:VALOR_TOTGENERO, VALOR_VCA=:VALOR_VCA, VALOR_LGTB=:VALOR_LGTB, VALOR_DISCAP=:VALOR_DISCAP, VALOR_AFRO=:VALOR_AFRO, VALOR_INDIG=:VALOR_INDIG, VALOR_INFANCIA=:VALOR_INFANCIA, VALOR_TOTAL_COND=:VALOR_TOTAL_COND, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PB_POBLACION_BENEFICIADA.COMPANIA= :KEY_COMPANIA AND PB_POBLACION_BENEFICIADA.TIPO= :KEY_TIPO AND PB_POBLACION_BENEFICIADA.NUMERO= :KEY_NUMERO AND PB_POBLACION_BENEFICIADA.ID_PLAN= :KEY_ID_PLAN AND PB_POBLACION_BENEFICIADA.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VALOR_PRIMINFANCIA" sqlType="STRING"/>
		<param name="VALOR_ADOLESCENCIA" sqlType="STRING"/>
		<param name="VALOR_JUVENTUD" sqlType="STRING"/>
		<param name="VALOR_ADULTO" sqlType="STRING"/>
		<param name="VALOR_ADULTO_MAYOR" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="VALOR_MUJERES" sqlType="STRING"/>
		<param name="VALOR_HOMBRES" sqlType="STRING"/>
		<param name="VALOR_TOTGENERO" sqlType="STRING"/>
		<param name="VALOR_VCA" sqlType="STRING"/>
		<param name="VALOR_LGTB" sqlType="STRING"/>
		<param name="VALOR_DISCAP" sqlType="STRING"/>
		<param name="VALOR_AFRO" sqlType="STRING"/>
		<param name="VALOR_INDIG" sqlType="STRING"/>
		<param name="VALOR_INFANCIA" sqlType="STRING"/>
		<param name="VALOR_TOTAL_COND" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
