	<query id="getPbpoblacionbeneficiadaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, TIPO, NUMERO, ID_PLAN, VIGENCIA_INICIAL, ABREV_PRIMINFANCIA, ABREV_INFANCIA, ABREV_ADOLESCENCIA, ABREV_JUVENTUD, ABREV_ADULTO , ABREV_ADULTO_MAYOR, ABREV_TOTAL , ABREV_MUJERES, ABREV_HOMBRES, ABREV_TOTGENERO, ABREV_VCA , ABREV_LGTB, ABREV_DISCAP , ABREV_AFRO, ABREV_INDIG , VALOR_PRIMINFANCIA , VALOR_ADOLESCENCIA , VALOR_JUVENTUD , VALOR_ADULTO , VALOR_ADULTO_MAYOR, VALOR_TOTAL, VALOR_MUJERES, VALOR_HOMBRES, VALOR_TOTGENERO, VALOR_VCA , VALOR_LGTB, VALOR_DISCAP , VALOR_AFRO, VALOR_INDIG , VALOR_INFANCIA FROM PB_POBLACION_BENEFICIADA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_PLAN), '%')) AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIA_INICIAL), '%')) AND (CASE WHEN ABREV_PRIMINFANCIA IS NULL THEN ' ' ELSE UPPER(ABREV_PRIMINFANCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_PRIMINFANCIA), '%')) AND (CASE WHEN ABREV_INFANCIA IS NULL THEN ' ' ELSE UPPER(ABREV_INFANCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_INFANCIA), '%')) AND (CASE WHEN ABREV_ADOLESCENCIA IS NULL THEN ' ' ELSE UPPER(ABREV_ADOLESCENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_ADOLESCENCIA), '%')) AND (CASE WHEN ABREV_JUVENTUD IS NULL THEN ' ' ELSE UPPER(ABREV_JUVENTUD) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_JUVENTUD), '%')) AND (CASE WHEN ABREV_ADULTO IS NULL THEN ' ' ELSE UPPER(ABREV_ADULTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_ADULTO), '%')) AND (CASE WHEN ABREV_ADULTO_MAYOR IS NULL THEN ' ' ELSE UPPER(ABREV_ADULTO_MAYOR) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_ADULTO_MAYOR), '%')) AND (CASE WHEN ABREV_TOTAL IS NULL THEN ' ' ELSE UPPER(ABREV_TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_TOTAL), '%')) AND (CASE WHEN ABREV_MUJERES IS NULL THEN ' ' ELSE UPPER(ABREV_MUJERES) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_MUJERES), '%')) AND (CASE WHEN ABREV_HOMBRES IS NULL THEN ' ' ELSE UPPER(ABREV_HOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_HOMBRES), '%')) AND (CASE WHEN ABREV_TOTGENERO IS NULL THEN ' ' ELSE UPPER(ABREV_TOTGENERO) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_TOTGENERO), '%')) AND (CASE WHEN ABREV_VCA IS NULL THEN ' ' ELSE UPPER(ABREV_VCA) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_VCA), '%')) AND (CASE WHEN ABREV_LGTB IS NULL THEN ' ' ELSE UPPER(ABREV_LGTB) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_LGTB), '%')) AND (CASE WHEN ABREV_DISCAP IS NULL THEN ' ' ELSE UPPER(ABREV_DISCAP) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_DISCAP), '%')) AND (CASE WHEN ABREV_AFRO IS NULL THEN ' ' ELSE UPPER(ABREV_AFRO) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_AFRO), '%')) AND (CASE WHEN ABREV_INDIG IS NULL THEN ' ' ELSE UPPER(ABREV_INDIG) END) LIKE UPPER(CONCAT(CONCAT('%',:ABREV_INDIG), '%')) AND (CASE WHEN VALOR_PRIMINFANCIA IS NULL THEN ' ' ELSE UPPER(VALOR_PRIMINFANCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_PRIMINFANCIA), '%')) AND (CASE WHEN VALOR_ADOLESCENCIA IS NULL THEN ' ' ELSE UPPER(VALOR_ADOLESCENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_ADOLESCENCIA), '%')) AND (CASE WHEN VALOR_JUVENTUD IS NULL THEN ' ' ELSE UPPER(VALOR_JUVENTUD) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_JUVENTUD), '%')) AND (CASE WHEN VALOR_ADULTO IS NULL THEN ' ' ELSE UPPER(VALOR_ADULTO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_ADULTO), '%')) AND (CASE WHEN VALOR_ADULTO_MAYOR IS NULL THEN ' ' ELSE UPPER(VALOR_ADULTO_MAYOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_ADULTO_MAYOR), '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_TOTAL), '%')) AND (CASE WHEN VALOR_MUJERES IS NULL THEN ' ' ELSE UPPER(VALOR_MUJERES) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_MUJERES), '%')) AND (CASE WHEN VALOR_HOMBRES IS NULL THEN ' ' ELSE UPPER(VALOR_HOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_HOMBRES), '%')) AND (CASE WHEN VALOR_TOTGENERO IS NULL THEN ' ' ELSE UPPER(VALOR_TOTGENERO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_TOTGENERO), '%')) AND (CASE WHEN VALOR_VCA IS NULL THEN ' ' ELSE UPPER(VALOR_VCA) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_VCA), '%')) AND (CASE WHEN VALOR_LGTB IS NULL THEN ' ' ELSE UPPER(VALOR_LGTB) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_LGTB), '%')) AND (CASE WHEN VALOR_DISCAP IS NULL THEN ' ' ELSE UPPER(VALOR_DISCAP) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DISCAP), '%')) AND (CASE WHEN VALOR_AFRO IS NULL THEN ' ' ELSE UPPER(VALOR_AFRO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_AFRO), '%')) AND (CASE WHEN VALOR_INDIG IS NULL THEN ' ' ELSE UPPER(VALOR_INDIG) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_INDIG), '%')) AND (CASE WHEN VALOR_INFANCIA IS NULL THEN ' ' ELSE UPPER(VALOR_INFANCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_INFANCIA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ABREV_PRIMINFANCIA" sqlType="STRING"/>
		<param name="ABREV_INFANCIA" sqlType="STRING"/>
		<param name="ABREV_ADOLESCENCIA" sqlType="STRING"/>
		<param name="ABREV_JUVENTUD" sqlType="STRING"/>
		<param name="ABREV_ADULTO" sqlType="STRING"/>
		<param name="ABREV_ADULTO_MAYOR" sqlType="STRING"/>
		<param name="ABREV_TOTAL" sqlType="STRING"/>
		<param name="ABREV_MUJERES" sqlType="STRING"/>
		<param name="ABREV_HOMBRES" sqlType="STRING"/>
		<param name="ABREV_TOTGENERO" sqlType="STRING"/>
		<param name="ABREV_VCA" sqlType="STRING"/>
		<param name="ABREV_LGTB" sqlType="STRING"/>
		<param name="ABREV_DISCAP" sqlType="STRING"/>
		<param name="ABREV_AFRO" sqlType="STRING"/>
		<param name="ABREV_INDIG" sqlType="STRING"/>
		<param name="VALOR_PRIMINFANCIA" sqlType="STRING"/>
		<param name="VALOR_ADOLESCENCIA" sqlType="STRING"/>
		<param name="VALOR_JUVENTUD" sqlType="STRING"/>
		<param name="VALOR_ADULTO" sqlType="STRING"/>
		<param name="VALOR_ADULTO_MAYOR" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="VALOR_MUJERES" sqlType="STRING"/>
		<param name="VALOR_HOMBRES" sqlType="STRING"/>
		<param name="VALOR_TOTGENERO" sqlType="STRING"/>
		<param name="VALOR_VCA" sqlType="STRING"/>
		<param name="VALOR_LGTB" sqlType="STRING"/>
		<param name="VALOR_DISCAP" sqlType="STRING"/>
		<param name="VALOR_AFRO" sqlType="STRING"/>
		<param name="VALOR_INDIG" sqlType="STRING"/>
		<param name="VALOR_INFANCIA" sqlType="STRING"/>

	</query>
