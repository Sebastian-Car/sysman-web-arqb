<data name="detreclasificarniifmensual" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDetreclasificarniifmensual" keyColumns="COMPANIA,ANO,NUMERO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_RECLASIFICAR_NIIF_MENSUAL (COMPANIA, ANO, NUMERO, CONSECUTIVO, CODIGOANTERIOR, NOMBREANTERIOR, CODIGONUEVO, NOMBRENUEVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :NUMERO, :CONSECUTIVO, :CODIGOANTERIOR, :NOMBREANTERIOR, :CODIGONUEVO, :NOMBRENUEVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_NUMERO":"$NUMERO(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGOANTERIOR" sqlType="STRING"/>
		<param name="NOMBREANTERIOR" sqlType="STRING"/>
		<param name="CODIGONUEVO" sqlType="STRING"/>
		<param name="NOMBRENUEVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detreclasificarniifmensual">
		<call-query href="insertDetreclasificarniifmensual">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGOANTERIOR" query-param="CODIGOANTERIOR"/>
			<with-param name="NOMBREANTERIOR" query-param="NOMBREANTERIOR"/>
			<with-param name="CODIGONUEVO" query-param="CODIGONUEVO"/>
			<with-param name="NOMBRENUEVO" query-param="NOMBRENUEVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDetreclasificarniifmensual" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_RECLASIFICAR_NIIF_MENSUAL WHERE D_RECLASIFICAR_NIIF_MENSUAL.COMPANIA= :KEY_COMPANIA AND D_RECLASIFICAR_NIIF_MENSUAL.ANO= :KEY_ANO AND D_RECLASIFICAR_NIIF_MENSUAL.NUMERO= :KEY_NUMERO AND D_RECLASIFICAR_NIIF_MENSUAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="detreclasificarniifmensual">
		<call-query href="deleteDetreclasificarniifmensual">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDetreclasificarniifmensualPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, NUMERO, CONSECUTIVO, CODIGOANTERIOR, NOMBREANTERIOR, CODIGONUEVO, NOMBRENUEVO FROM D_RECLASIFICAR_NIIF_MENSUAL WHERE COMPANIA=:COMPANIA AND ANO=:ANO AND NUMERO=:STRNUMERO) INI WHERE (CASE WHEN CODIGOANTERIOR IS NULL THEN ' ' ELSE UPPER(CODIGOANTERIOR) END) LIKE UPPER(CONCAT(:CODIGOANTERIOR, '%')) AND (CASE WHEN NOMBREANTERIOR IS NULL THEN ' ' ELSE UPPER(NOMBREANTERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREANTERIOR), '%')) AND (CASE WHEN CODIGONUEVO IS NULL THEN ' ' ELSE UPPER(CODIGONUEVO) END) LIKE UPPER(CONCAT(:CODIGONUEVO, '%')) AND (CASE WHEN NOMBRENUEVO IS NULL THEN ' ' ELSE UPPER(NOMBRENUEVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRENUEVO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:long)","CODIGOANTERIOR":"$CODIGOANTERIOR","NOMBREANTERIOR":"$NOMBREANTERIOR","CODIGONUEVO":"$CODIGONUEVO","NOMBRENUEVO":"$NOMBRENUEVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="STRNUMERO" sqlType="STRING"/>
		<param name="CODIGOANTERIOR" sqlType="STRING"/>
		<param name="NOMBREANTERIOR" sqlType="STRING"/>
		<param name="CODIGONUEVO" sqlType="STRING"/>
		<param name="NOMBRENUEVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detreclasificarniifmensual">
		<call-query href="getDetreclasificarniifmensualPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="STRNUMERO" query-param="STRNUMERO"/>
			<with-param name="CODIGOANTERIOR" query-param="CODIGOANTERIOR"/>
			<with-param name="NOMBREANTERIOR" query-param="NOMBREANTERIOR"/>
			<with-param name="CODIGONUEVO" query-param="CODIGONUEVO"/>
			<with-param name="NOMBRENUEVO" query-param="NOMBRENUEVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetreclasificarniifmensualNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, NUMERO, CONSECUTIVO, CODIGOANTERIOR, NOMBREANTERIOR, CODIGONUEVO, NOMBRENUEVO FROM D_RECLASIFICAR_NIIF_MENSUAL WHERE COMPANIA=:COMPANIA AND ANO=:ANO AND NUMERO=:STRNUMERO) INI WHERE (CASE WHEN CODIGOANTERIOR IS NULL THEN ' ' ELSE UPPER(CODIGOANTERIOR) END) LIKE UPPER(CONCAT(:CODIGOANTERIOR, '%')) AND (CASE WHEN NOMBREANTERIOR IS NULL THEN ' ' ELSE UPPER(NOMBREANTERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREANTERIOR), '%')) AND (CASE WHEN CODIGONUEVO IS NULL THEN ' ' ELSE UPPER(CODIGONUEVO) END) LIKE UPPER(CONCAT(:CODIGONUEVO, '%')) AND (CASE WHEN NOMBRENUEVO IS NULL THEN ' ' ELSE UPPER(NOMBRENUEVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRENUEVO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="STRNUMERO" sqlType="STRING"/>
		<param name="CODIGOANTERIOR" sqlType="STRING"/>
		<param name="NOMBREANTERIOR" sqlType="STRING"/>
		<param name="CODIGONUEVO" sqlType="STRING"/>
		<param name="NOMBRENUEVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detreclasificarniifmensual/numero">
		<call-query href="getDetreclasificarniifmensualNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="STRNUMERO" query-param="STRNUMERO"/>
			<with-param name="CODIGOANTERIOR" query-param="CODIGOANTERIOR"/>
			<with-param name="NOMBREANTERIOR" query-param="NOMBREANTERIOR"/>
			<with-param name="CODIGONUEVO" query-param="CODIGONUEVO"/>
			<with-param name="NOMBRENUEVO" query-param="NOMBRENUEVO"/>

		</call-query>
	</resource>
	<query id="getDetreclasificarniifmensualRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA,ANO,NUMERO,CONSECUTIVO,CODIGOANTERIOR,NOMBREANTERIOR,CODIGONUEVO,NOMBRENUEVO FROM D_RECLASIFICAR_NIIF_MENSUAL WHERE D_RECLASIFICAR_NIIF_MENSUAL.COMPANIA= :KEY_COMPANIA AND D_RECLASIFICAR_NIIF_MENSUAL.ANO= :KEY_ANO AND D_RECLASIFICAR_NIIF_MENSUAL.NUMERO= :KEY_NUMERO AND D_RECLASIFICAR_NIIF_MENSUAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:long)","CODIGOANTERIOR":"$CODIGOANTERIOR","NOMBREANTERIOR":"$NOMBREANTERIOR","CODIGONUEVO":"$CODIGONUEVO","NOMBRENUEVO":"$NOMBRENUEVO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detreclasificarniifmensual/data">
		<call-query href="getDetreclasificarniifmensualRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateDetreclasificarniifmensual" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_RECLASIFICAR_NIIF_MENSUAL SET CONSECUTIVO=:CONSECUTIVO, CODIGOANTERIOR=:CODIGOANTERIOR, NOMBREANTERIOR=:NOMBREANTERIOR, CODIGONUEVO=:CODIGONUEVO, NOMBRENUEVO=:NOMBRENUEVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_RECLASIFICAR_NIIF_MENSUAL.COMPANIA= :KEY_COMPANIA AND D_RECLASIFICAR_NIIF_MENSUAL.ANO= :KEY_ANO AND D_RECLASIFICAR_NIIF_MENSUAL.NUMERO= :KEY_NUMERO AND D_RECLASIFICAR_NIIF_MENSUAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGOANTERIOR" sqlType="STRING"/>
		<param name="NOMBREANTERIOR" sqlType="STRING"/>
		<param name="CODIGONUEVO" sqlType="STRING"/>
		<param name="NOMBRENUEVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detreclasificarniifmensual">
		<call-query href="updateDetreclasificarniifmensual">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGOANTERIOR" query-param="CODIGOANTERIOR"/>
			<with-param name="NOMBREANTERIOR" query-param="NOMBREANTERIOR"/>
			<with-param name="CODIGONUEVO" query-param="CODIGONUEVO"/>
			<with-param name="NOMBRENUEVO" query-param="NOMBRENUEVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>