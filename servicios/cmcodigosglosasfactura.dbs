<data name="cmcodigosglosasfactura" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertCmcodigosglosasfactura" keyColumns="COMPANIA,CONSECUTIVO_ARCHIVO,CONSECUTIVO_FACTURA,NUM_FACTURA,ID_GLOSA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CM_CODIGOS_GLOSAS_FACTURA (COMPANIA, CONSECUTIVO_ARCHIVO, CONSECUTIVO_FACTURA, NUM_FACTURA, COD_PREST_SERV_SALUD, COD_GEN_GLOSA, COD_ESP_GLOSA, ID_GLOSA, OBSERVACIONES, CONCEPTO_APLICACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONSECUTIVO_ARCHIVO, :CONSECUTIVO_FACTURA, :NUM_FACTURA, :COD_PREST_SERV_SALUD, :COD_GEN_GLOSA, :COD_ESP_GLOSA, :ID_GLOSA, :OBSERVACIONES, :CONCEPTO_APLICACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO_ARCHIVO":"$CONSECUTIVO_ARCHIVO(type:integer)","KEY_CONSECUTIVO_FACTURA":"$CONSECUTIVO_FACTURA(type:integer)","KEY_NUM_FACTURA":"$NUM_FACTURA","KEY_ID_GLOSA":"$ID_GLOSA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="NUM_FACTURA" sqlType="STRING"/>
		<param name="COD_PREST_SERV_SALUD" sqlType="STRING"/>
		<param name="COD_GEN_GLOSA" sqlType="STRING"/>
		<param name="COD_ESP_GLOSA" sqlType="STRING"/>
		<param name="ID_GLOSA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO_APLICACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cmcodigosglosasfactura">
		<call-query href="insertCmcodigosglosasfactura">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO_ARCHIVO" query-param="CONSECUTIVO_ARCHIVO"/>
			<with-param name="CONSECUTIVO_FACTURA" query-param="CONSECUTIVO_FACTURA"/>
			<with-param name="NUM_FACTURA" query-param="NUM_FACTURA"/>
			<with-param name="COD_PREST_SERV_SALUD" query-param="COD_PREST_SERV_SALUD"/>
			<with-param name="COD_GEN_GLOSA" query-param="COD_GEN_GLOSA"/>
			<with-param name="COD_ESP_GLOSA" query-param="COD_ESP_GLOSA"/>
			<with-param name="ID_GLOSA" query-param="ID_GLOSA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="CONCEPTO_APLICACION" query-param="CONCEPTO_APLICACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteCmcodigosglosasfactura" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CM_CODIGOS_GLOSAS_FACTURA WHERE CM_CODIGOS_GLOSAS_FACTURA.COMPANIA= :KEY_COMPANIA AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_ARCHIVO= :KEY_CONSECUTIVO_ARCHIVO AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_FACTURA= :KEY_CONSECUTIVO_FACTURA AND CM_CODIGOS_GLOSAS_FACTURA.NUM_FACTURA= :KEY_NUM_FACTURA AND CM_CODIGOS_GLOSAS_FACTURA.ID_GLOSA= :KEY_ID_GLOSA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_ARCHIVO" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO_FACTURA" sqlType="INTEGER"/>
		<param name="KEY_NUM_FACTURA" sqlType="STRING"/>
		<param name="KEY_ID_GLOSA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="cmcodigosglosasfactura">
		<call-query href="deleteCmcodigosglosasfactura">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO_ARCHIVO" query-param="KEY_CONSECUTIVO_ARCHIVO"/>
			<with-param name="KEY_CONSECUTIVO_FACTURA" query-param="KEY_CONSECUTIVO_FACTURA"/>
			<with-param name="KEY_NUM_FACTURA" query-param="KEY_NUM_FACTURA"/>
			<with-param name="KEY_ID_GLOSA" query-param="KEY_ID_GLOSA"/>

		</call-query>
	</resource>
	<query id="getCmcodigosglosasfacturaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CM_CODIGOS_GLOSAS_FACTURA.COMPANIA,CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_ARCHIVO, CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_FACTURA, CM_CODIGOS_GLOSAS_FACTURA.NUM_FACTURA,CM_CODIGOS_GLOSAS_FACTURA.COD_PREST_SERV_SALUD,CM_CODIGOS_GLOSAS_FACTURA.COD_GEN_GLOSA,CM_CODIGOS_GLOSAS_FACTURA.COD_ESP_GLOSA, CM_CODIGOS_GLOSAS_FACTURA.ID_GLOSA, CM_CODIFICACION_GLOSAS.NOMBRE, CM_CODIGOS_GLOSAS_FACTURA.OBSERVACIONES,CM_CODIGOS_GLOSAS_FACTURA.CONCEPTO_APLICACION FROM CM_CODIGOS_GLOSAS_FACTURA INNER JOIN CM_CODIFICACION_GLOSAS ON ID_GLOSA = ID WHERE CM_CODIGOS_GLOSAS_FACTURA.COMPANIA = :COMPANIA AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_ARCHIVO = :CONSECUTIVO_ARCHIVO AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_FACTURA = :CONSECUTIVO_FACTURA AND CM_CODIGOS_GLOSAS_FACTURA.NUM_FACTURA = :NUM_FACTURA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO_ARCHIVO":"$CONSECUTIVO_ARCHIVO(type:integer)","CONSECUTIVO_FACTURA":"$CONSECUTIVO_FACTURA(type:integer)","NUM_FACTURA":"$NUM_FACTURA","COD_PREST_SERV_SALUD":"$COD_PREST_SERV_SALUD","COD_GEN_GLOSA":"$COD_GEN_GLOSA","COD_ESP_GLOSA":"$COD_ESP_GLOSA","ID_GLOSA":"$ID_GLOSA","NOMBRE":"$NOMBRE","OBSERVACIONES":"$OBSERVACIONES","CONCEPTO_APLICACION":"$CONCEPTO_APLICACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="NUM_FACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmcodigosglosasfactura">
		<call-query href="getCmcodigosglosasfacturaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO_ARCHIVO" query-param="CONSECUTIVO_ARCHIVO"/>
			<with-param name="CONSECUTIVO_FACTURA" query-param="CONSECUTIVO_FACTURA"/>
			<with-param name="NUM_FACTURA" query-param="NUM_FACTURA"/>

		</call-query>
	</resource>
	<query id="getCmcodigosglosasfacturaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CM_CODIGOS_GLOSAS_FACTURA.COMPANIA,CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_ARCHIVO, CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_FACTURA, CM_CODIGOS_GLOSAS_FACTURA.NUM_FACTURA,CM_CODIGOS_GLOSAS_FACTURA.COD_PREST_SERV_SALUD,CM_CODIGOS_GLOSAS_FACTURA.COD_GEN_GLOSA,CM_CODIGOS_GLOSAS_FACTURA.COD_ESP_GLOSA, CM_CODIGOS_GLOSAS_FACTURA.ID_GLOSA, CM_CODIFICACION_GLOSAS.NOMBRE, CM_CODIGOS_GLOSAS_FACTURA.OBSERVACIONES FROM CM_CODIGOS_GLOSAS_FACTURA INNER JOIN CM_CODIFICACION_GLOSAS ON ID_GLOSA = ID WHERE CM_CODIGOS_GLOSAS_FACTURA.COMPANIA = :COMPANIA AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_ARCHIVO = :CONSECUTIVO_ARCHIVO AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_FACTURA = :CONSECUTIVO_FACTURA AND CM_CODIGOS_GLOSAS_FACTURA.NUM_FACTURA = :NUM_FACTURA) INI WHERE (CASE WHEN CONSECUTIVO_ARCHIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_ARCHIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO_ARCHIVO, '%')) AND (CASE WHEN CONSECUTIVO_FACTURA IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_FACTURA) END) LIKE UPPER(CONCAT(:CONSECUTIVO_FACTURA, '%')) AND (CASE WHEN NUM_FACTURA IS NULL THEN ' ' ELSE UPPER(NUM_FACTURA) END) LIKE UPPER(CONCAT(:NUM_FACTURA, '%')) AND (CASE WHEN COD_PREST_SERV_SALUD IS NULL THEN ' ' ELSE UPPER(COD_PREST_SERV_SALUD) END) LIKE UPPER(CONCAT(:COD_PREST_SERV_SALUD, '%')) AND (CASE WHEN COD_GEN_GLOSA IS NULL THEN ' ' ELSE UPPER(COD_GEN_GLOSA) END) LIKE UPPER(CONCAT(:COD_GEN_GLOSA, '%')) AND (CASE WHEN COD_ESP_GLOSA IS NULL THEN ' ' ELSE UPPER(COD_ESP_GLOSA) END) LIKE UPPER(CONCAT(:COD_ESP_GLOSA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="NUM_FACTURA" sqlType="STRING"/>
		<param name="COD_PREST_SERV_SALUD" sqlType="STRING"/>
		<param name="COD_GEN_GLOSA" sqlType="STRING"/>
		<param name="COD_ESP_GLOSA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmcodigosglosasfactura/numero">
		<call-query href="getCmcodigosglosasfacturaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO_ARCHIVO" query-param="CONSECUTIVO_ARCHIVO"/>
			<with-param name="CONSECUTIVO_FACTURA" query-param="CONSECUTIVO_FACTURA"/>
			<with-param name="NUM_FACTURA" query-param="NUM_FACTURA"/>
			<with-param name="COD_PREST_SERV_SALUD" query-param="COD_PREST_SERV_SALUD"/>
			<with-param name="COD_GEN_GLOSA" query-param="COD_GEN_GLOSA"/>
			<with-param name="COD_ESP_GLOSA" query-param="COD_ESP_GLOSA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="updateCmcodigosglosasfactura" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_CODIGOS_GLOSAS_FACTURA SET COD_GEN_GLOSA=:COD_GEN_GLOSA, COD_ESP_GLOSA=:COD_ESP_GLOSA, ID_GLOSA=:ID_GLOSA, OBSERVACIONES=:OBSERVACIONES, CONCEPTO_APLICACION=:CONCEPTO_APLICACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CM_CODIGOS_GLOSAS_FACTURA.COMPANIA= :KEY_COMPANIA AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_ARCHIVO= :KEY_CONSECUTIVO_ARCHIVO AND CM_CODIGOS_GLOSAS_FACTURA.CONSECUTIVO_FACTURA= :KEY_CONSECUTIVO_FACTURA AND CM_CODIGOS_GLOSAS_FACTURA.NUM_FACTURA= :KEY_NUM_FACTURA AND CM_CODIGOS_GLOSAS_FACTURA.ID_GLOSA= :KEY_ID_GLOSA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COD_GEN_GLOSA" sqlType="STRING"/>
		<param name="COD_ESP_GLOSA" sqlType="STRING"/>
		<param name="ID_GLOSA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="CONCEPTO_APLICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="KEY_NUM_FACTURA" sqlType="STRING"/>
		<param name="KEY_ID_GLOSA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmcodigosglosasfactura">
		<call-query href="updateCmcodigosglosasfactura">
			<with-param name="COD_GEN_GLOSA" query-param="COD_GEN_GLOSA"/>
			<with-param name="COD_ESP_GLOSA" query-param="COD_ESP_GLOSA"/>
			<with-param name="ID_GLOSA" query-param="ID_GLOSA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="CONCEPTO_APLICACION" query-param="CONCEPTO_APLICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO_ARCHIVO" query-param="KEY_CONSECUTIVO_ARCHIVO"/>
			<with-param name="KEY_CONSECUTIVO_FACTURA" query-param="KEY_CONSECUTIVO_FACTURA"/>
			<with-param name="KEY_NUM_FACTURA" query-param="KEY_NUM_FACTURA"/>
			<with-param name="KEY_ID_GLOSA" query-param="KEY_ID_GLOSA"/>

		</call-query>
	</resource>

</data>