	</resource>
	<query id="updateEquivalentecntpresupuestales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EQUIVALENTECNT_PRESUPUESTAL SET COMPANIA=:COMPANIA, ANO=:ANO, RUBRO_PPTAL=:RUBRO_PPTAL, CUENTA_DEBITO=:CUENTA_DEBITO, CUENTA_CREDITO=:CUENTA_CREDITO, CENTRO_COSTO=:CENTRO_COSTO, TERCERO=:TERCERO, AUXILIAR=:AUXILIAR, REFERENCIA=:REFERENCIA, FUENTE_RECURSO=:FUENTE_RECURSO, CONSECUTIVO=:CONSECUTIVO, SUCURSAL=:SUCURSAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EQUIVALENTECNT_PRESUPUESTAL.COMPANIA= :KEY_COMPANIA AND EQUIVALENTECNT_PRESUPUESTAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="RUBRO_PPTAL" sqlType="STRING"/>
		<param name="CUENTA_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="equivalentecntpresupuestales">
		<call-query href="updateEquivalentecntpresupuestales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="RUBRO_PPTAL" query-param="RUBRO_PPTAL"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
