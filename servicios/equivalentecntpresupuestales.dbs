<data name="equivalentecntpresupuestales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEquivalentecntpresupuestalesPagCuentasEquivalentesRubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL, EQUIVALENTECNT_PRESUPUESTAL.CUENTA_DEBITO, EQUIVALENTECNT_PRESUPUESTAL.CUENTA_CREDITO  FROM EQUIVALENTECNT_PRESUPUESTAL WHERE EQUIVALENTECNT_PRESUPUESTAL.COMPANIA =:COMPANIA AND EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL = :RUBRO AND EQUIVALENTECNT_PRESUPUESTAL.ANO = :ANO AND EQUIVALENTECNT_PRESUPUESTAL.AUXILIAR = :AUXILIAR AND EQUIVALENTECNT_PRESUPUESTAL.CENTRO_COSTO = :CENTRO_COSTO AND EQUIVALENTECNT_PRESUPUESTAL.FUENTE_RECURSO = :FUENTE_RECURSO AND EQUIVALENTECNT_PRESUPUESTAL.REFERENCIA = :REFERENCIA ORDER BY EQUIVALENTECNT_PRESUPUESTAL.COMPANIA, EQUIVALENTECNT_PRESUPUESTAL.ANO) WHERE (CASE WHEN RUBRO_PPTAL IS NULL THEN ' ' ELSE UPPER(RUBRO_PPTAL) END)  LIKE UPPER(:RUBRO_PPTAL || '%')  AND (CASE WHEN CUENTA_DEBITO IS NULL THEN ' ' ELSE UPPER(CUENTA_DEBITO) END)  LIKE UPPER(:CUENTA_DEBITO || '%')  AND (CASE WHEN CUENTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CUENTA_CREDITO) END)  LIKE UPPER(:CUENTA_CREDITO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUBRO_PPTAL":"$RUBRO_PPTAL","CUENTA_DEBITO":"$CUENTA_DEBITO","CUENTA_CREDITO":"$CUENTA_CREDITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="RUBRO_PPTAL" sqlType="STRING"/>
		<param name="CUENTA_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="equivalentecntpresupuestales/cuentasequivalentesrubro/pag">
		<call-query href="getEquivalentecntpresupuestalesPagCuentasEquivalentesRubroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="RUBRO_PPTAL" query-param="RUBRO_PPTAL"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEquivalentecntpresupuestalesNumCuentasEquivalentesRubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL, EQUIVALENTECNT_PRESUPUESTAL.CUENTA_DEBITO, EQUIVALENTECNT_PRESUPUESTAL.CUENTA_CREDITO  FROM EQUIVALENTECNT_PRESUPUESTAL WHERE EQUIVALENTECNT_PRESUPUESTAL.COMPANIA =:COMPANIA AND EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL = :RUBRO AND EQUIVALENTECNT_PRESUPUESTAL.ANO = :ANO AND EQUIVALENTECNT_PRESUPUESTAL.AUXILIAR = :AUXILIAR AND EQUIVALENTECNT_PRESUPUESTAL.CENTRO_COSTO = :CENTRO_COSTO AND EQUIVALENTECNT_PRESUPUESTAL.FUENTE_RECURSO = :FUENTE_RECURSO AND EQUIVALENTECNT_PRESUPUESTAL.REFERENCIA = :REFERENCIA ORDER BY EQUIVALENTECNT_PRESUPUESTAL.COMPANIA, EQUIVALENTECNT_PRESUPUESTAL.ANO) WHERE (CASE WHEN RUBRO_PPTAL IS NULL THEN ' ' ELSE UPPER(RUBRO_PPTAL) END)  LIKE UPPER(:RUBRO_PPTAL || '%')  AND (CASE WHEN CUENTA_DEBITO IS NULL THEN ' ' ELSE UPPER(CUENTA_DEBITO) END)  LIKE UPPER(:CUENTA_DEBITO || '%')  AND (CASE WHEN CUENTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CUENTA_CREDITO) END)  LIKE UPPER(:CUENTA_CREDITO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="RUBRO_PPTAL" sqlType="STRING"/>
		<param name="CUENTA_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="equivalentecntpresupuestales/cuentasequivalentesrubro/num">
		<call-query href="getEquivalentecntpresupuestalesNumCuentasEquivalentesRubroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="RUBRO_PPTAL" query-param="RUBRO_PPTAL"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>

		</call-query>
	</resource>
	<query id="insertEquivalentecntpresupuestales" keyColumns="COMPANIA,ANO,RUBRO_PPTAL,CONSECUTIVO,CENTRO_COSTO,TERCERO,AUXILIAR,REFERENCIA,FUENTE_RECURSO,CUENTA_CREDITO,CUENTA_DEBITO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EQUIVALENTECNT_PRESUPUESTAL (CONSECUTIVO, COMPANIA, ANO, RUBRO_PPTAL, CUENTA_DEBITO, CUENTA_CREDITO, CENTRO_COSTO, TERCERO, AUXILIAR, REFERENCIA, FUENTE_RECURSO, SUCURSAL, DATE_CREATED, CREATED_BY) VALUES (:CONSECUTIVO, :COMPANIA, :ANO, :RUBRO_PPTAL, :CUENTA_DEBITO, :CUENTA_CREDITO, :CENTRO_COSTO, :TERCERO, :AUXILIAR, :REFERENCIA, :FUENTE_RECURSO, :SUCURSAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_RUBRO_PPTAL":"$RUBRO_PPTAL","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)","KEY_CENTRO_COSTO":"$CENTRO_COSTO","KEY_TERCERO":"$TERCERO","KEY_AUXILIAR":"$AUXILIAR","KEY_REFERENCIA":"$REFERENCIA","KEY_FUENTE_RECURSO":"$FUENTE_RECURSO","KEY_CUENTA_CREDITO":"$CUENTA_CREDITO","KEY_CUENTA_DEBITO":"$CUENTA_DEBITO"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="ANO" sqlType="STRING"/>
		<param name="RUBRO_PPTAL" sqlType="STRING"/>
		<param name="CUENTA_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_RECURSO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="equivalentecntpresupuestales">
		<call-query href="insertEquivalentecntpresupuestales">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="RUBRO_PPTAL" query-param="RUBRO_PPTAL"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEquivalentecntpresupuestales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EQUIVALENTECNT_PRESUPUESTAL WHERE EQUIVALENTECNT_PRESUPUESTAL.COMPANIA= :KEY_COMPANIA AND EQUIVALENTECNT_PRESUPUESTAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="equivalentecntpresupuestales">
		<call-query href="deleteEquivalentecntpresupuestales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEquivalentecntpresupuestalesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EQUIVALENTECNT_PRESUPUESTAL.COMPANIA , CONSECUTIVO, EQUIVALENTECNT_PRESUPUESTAL.ANO, EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL , PLAN_PRESUPUESTAL.NOMBRE, EQUIVALENTECNT_PRESUPUESTAL.CUENTA_DEBITO , EQUIVALENTECNT_PRESUPUESTAL.CUENTA_CREDITO, EQUIVALENTECNT_PRESUPUESTAL.CENTRO_COSTO, EQUIVALENTECNT_PRESUPUESTAL.TERCERO, EQUIVALENTECNT_PRESUPUESTAL.AUXILIAR, EQUIVALENTECNT_PRESUPUESTAL.REFERENCIA, EQUIVALENTECNT_PRESUPUESTAL.FUENTE_RECURSO, EQUIVALENTECNT_PRESUPUESTAL.SUCURSAL  FROM EQUIVALENTECNT_PRESUPUESTAL INNER JOIN PLAN_PRESUPUESTAL ON EQUIVALENTECNT_PRESUPUESTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND EQUIVALENTECNT_PRESUPUESTAL.ANO = PLAN_PRESUPUESTAL.ANO AND EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL = PLAN_PRESUPUESTAL.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANIO ORDER BY EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL) WHERE (CASE WHEN RUBRO_PPTAL IS NULL THEN ' ' ELSE UPPER(RUBRO_PPTAL) END)  LIKE UPPER(:RUBRO_PPTAL || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CUENTA_DEBITO IS NULL THEN ' ' ELSE UPPER(CUENTA_DEBITO) END)  LIKE UPPER(:CUENTA_DEBITO || '%')  AND (CASE WHEN CUENTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CUENTA_CREDITO) END)  LIKE UPPER(:CUENTA_CREDITO || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END)  LIKE UPPER(:REFERENCIA || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER(:FUENTE_RECURSO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","ANO":"$ANO(type:integer)","RUBRO_PPTAL":"$RUBRO_PPTAL","NOMBRE":"$NOMBRE","CUENTA_DEBITO":"$CUENTA_DEBITO","CUENTA_CREDITO":"$CUENTA_CREDITO","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="RUBRO_PPTAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CUENTA_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="equivalentecntpresupuestales">
		<call-query href="getEquivalentecntpresupuestalesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="RUBRO_PPTAL" query-param="RUBRO_PPTAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
