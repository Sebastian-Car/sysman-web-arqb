			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEquivalentecntpresupuestalesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EQUIVALENTECNT_PRESUPUESTAL.COMPANIA , CONSECUTIVO, EQUIVALENTECNT_PRESUPUESTAL.ANO, EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL , PLAN_PRESUPUESTAL.NOMBRE, EQUIVALENTECNT_PRESUPUESTAL.CUENTA_DEBITO , EQUIVALENTECNT_PRESUPUESTAL.CUENTA_CREDITO, EQUIVALENTECNT_PRESUPUESTAL.CENTRO_COSTO, EQUIVALENTECNT_PRESUPUESTAL.TERCERO, EQUIVALENTECNT_PRESUPUESTAL.AUXILIAR, EQUIVALENTECNT_PRESUPUESTAL.REFERENCIA, EQUIVALENTECNT_PRESUPUESTAL.FUENTE_RECURSO, EQUIVALENTECNT_PRESUPUESTAL.SUCURSAL  FROM EQUIVALENTECNT_PRESUPUESTAL INNER JOIN PLAN_PRESUPUESTAL ON EQUIVALENTECNT_PRESUPUESTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND EQUIVALENTECNT_PRESUPUESTAL.ANO = PLAN_PRESUPUESTAL.ANO AND EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL = PLAN_PRESUPUESTAL.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANIO ORDER BY EQUIVALENTECNT_PRESUPUESTAL.RUBRO_PPTAL) WHERE (CASE WHEN RUBRO_PPTAL IS NULL THEN ' ' ELSE UPPER(RUBRO_PPTAL) END)  LIKE UPPER(:RUBRO_PPTAL || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CUENTA_DEBITO IS NULL THEN ' ' ELSE UPPER(CUENTA_DEBITO) END)  LIKE UPPER(:CUENTA_DEBITO || '%')  AND (CASE WHEN CUENTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CUENTA_CREDITO) END)  LIKE UPPER(:CUENTA_CREDITO || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END)  LIKE UPPER(:REFERENCIA || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER(:FUENTE_RECURSO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="RUBRO_PPTAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CUENTA_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="equivalentecntpresupuestales/numero">
		<call-query href="getEquivalentecntpresupuestalesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="RUBRO_PPTAL" query-param="RUBRO_PPTAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CUENTA_DEBITO" query-param="CUENTA_DEBITO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
