<data name="spdatosbasicospqr" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpdatosbasicospqrTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, DIRECCION, PAIS, DEPARTAMENTO, CIUDAD, REPLEGAL, CARGO, NUIRSSP, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED FROM SP_DATOSBASICOSPQR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DIRECCION":"$DIRECCION","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","REPLEGAL":"$REPLEGAL","CARGO":"$CARGO","NUIRSSP":"$NUIRSSP","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
 
	</query>
	<resource method="GET" path="spdatosbasicospqr/todos">
		<call-query href="getSpdatosbasicospqrTodosQuery">
 
		</call-query>
	</resource>
	<query id="updateSpdatosbasicospqrTodos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_DATOSBASICOSPQR SET COMPANIA=:COMPANIA, DIRECCION=:DIRECCION, PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, CIUDAD=:CIUDAD, REPLEGAL=:REPLEGAL, CARGO=:CARGO, NUIRSSP=:NUIRSSP, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_DATOSBASICOSPQR.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="REPLEGAL" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="NUIRSSP" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spdatosbasicospqr/todos">
		<call-query href="updateSpdatosbasicospqrTodos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CIUDAD" query-param="CIUDAD"/>
			<with-param name="REPLEGAL" query-param="REPLEGAL"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="NUIRSSP" query-param="NUIRSSP"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpdatosbasicospqrExisteCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) NUM  FROM SP_DATOSBASICOSPQR WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUM":"$NUM(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdatosbasicospqr/existecompania">
		<call-query href="getSpdatosbasicospqrExisteCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertSpdatosbasicospqrPorCompania" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_DATOSBASICOSPQR   (     COMPANIA,     DIRECCION,     CIUDAD,     DEPARTAMENTO,     PAIS,     NUIRSSP, CREATED_BY, DATE_CREATED) SELECT CODIGO,   DIRECCION,   CIUDAD,   DEPARTAMENTO,   PAIS,   NITCOMPANIA, :CREATED_BY ,SYSDATE FROM COMPANIA WHERE CODIGO = :COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spdatosbasicospqr/porcompania">
		<call-query href="insertSpdatosbasicospqrPorCompania">
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>