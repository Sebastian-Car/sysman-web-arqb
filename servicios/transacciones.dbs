		<call-query href="getTransaccionesPagTodosPorCompaniaYEstadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTransaccionesNumTodosPorCompaniaYEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TRANSACCION.CONSECUTIVO, TO_CHAR(TRANSACCION.FECHA,'DD/MM/YYYY') FECHA, TRANSACCION.ANO, TRANSACCION.ESTADO  FROM TRANSACCION WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.ESTADO = :ESTADO AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO ORDER BY TRANSACCION.NUMERO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transacciones/todosporcompaniayestado/num">
