	<query id="getTransaccionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TRANSACCION.COMPANIA, TRANSACCION.TIPOCONTRATO, LPAD(TRANSACCION.CONSECUTIVO,8,'0') CONSECUTIVO, TIPOCONTRATO_PR.DESCRIPCION NOM_TIPO, TO_CHAR(TRANSACCION.FECHA, 'DD/MM/YYYY') FECHA, TRANSACCION.ANO, ES_ESTPREVIO.NOMBRE_ESTUDIO, CASE TRANSACCION.ESTADO WHEN 'AC' THEN 'Abierta' WHEN 'CE' THEN 'Cerrado' WHEN 'CA' THEN 'Cancelada' END NOM_ESTADO, TRANSACCION.OBSERVACION, TRANSACCION.NUM_PROCESO FROM TRANSACCION INNER JOIN TIPOCONTRATO_PR ON TRANSACCION.COMPANIA = TIPOCONTRATO_PR.COMPANIA AND TRANSACCION.TIPOCONTRATO = TIPOCONTRATO_PR.TIPOCONTRATO LEFT JOIN ES_ESTPREVIO ON TRANSACCION.COMPANIA = ES_ESTPREVIO.COMPANIA AND TRANSACCION.ESTUDIOPREVIO = ES_ESTPREVIO.COD_ESTUDIO WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO AND TRANSACCION.ANO = :ANOTX AND TRANSACCION.CONSECUTIVO = CASE WHEN :TRANSACCION IS NULL THEN TRANSACCION.CONSECUTIVO ELSE TO_NUMBER(:TRANSACCION) END ORDER BY CONSECUTIVO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO), '%')) AND (CASE WHEN NOM_TIPO IS NULL THEN ' ' ELSE UPPER(NOM_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_TIPO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ESTUDIO), '%')) AND (CASE WHEN NOM_ESTADO IS NULL THEN ' ' ELSE UPPER(NOM_ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_ESTADO), '%')) AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACION), '%')) AND (CASE WHEN NUM_PROCESO IS NULL THEN ' ' ELSE UPPER(NUM_PROCESO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUM_PROCESO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ANOTX" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NOM_TIPO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>
		<param name="NOM_ESTADO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="NUM_PROCESO" sqlType="STRING"/>

	</query>
