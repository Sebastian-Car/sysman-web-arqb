			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getTransaccionesPagTodosPorContratoiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TRANSACCION.CONSECUTIVO, TO_CHAR(TRANSACCION.FECHA,'DD/MM/YYYY') FECHA, TRANSACCION.ANO, TRANSACCION.ESTADO  FROM TRANSACCION WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.ESTADO = :ESTADO AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO AND TRANSACCION.CONSECUTIVO &gt;= :CONTRATOINICIAL ORDER BY TRANSACCION.NUMERO DESC) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","FECHA":"$FECHA","ANO":"$ANO(type:integer)","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONTRATOINICIAL" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="transacciones/todosporcontratoini/pag">
		<call-query href="getTransaccionesPagTodosPorContratoiniQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CONTRATOINICIAL" query-param="CONTRATOINICIAL"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTransaccionesNumTodosPorContratoiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TRANSACCION.CONSECUTIVO, TO_CHAR(TRANSACCION.FECHA,'DD/MM/YYYY') FECHA, TRANSACCION.ANO, TRANSACCION.ESTADO  FROM TRANSACCION WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.ESTADO = :ESTADO AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO AND TRANSACCION.CONSECUTIVO &gt;= :CONTRATOINICIAL ORDER BY TRANSACCION.NUMERO DESC) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONTRATOINICIAL" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transacciones/todosporcontratoini/num">
		<call-query href="getTransaccionesNumTodosPorContratoiniQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CONTRATOINICIAL" query-param="CONTRATOINICIAL"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getTransaccionesPagPorCompaniaTipocontYEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONSECUTIVO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, ANO, ESTADO, ESTUDIOPREVIO  FROM TRANSACCION WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPOCONTRATO AND ESTADO = :ESTADO ORDER BY NUMERO, CONSECUTIVO, FECHA) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","FECHA":"$FECHA","ANO":"$ANO(type:integer)","ESTADO":"$ESTADO","ESTUDIOPREVIO":"$ESTUDIOPREVIO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="transacciones/porcompaniatipocontyestado/pag">
		<call-query href="getTransaccionesPagPorCompaniaTipocontYEstadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertTransacciones" keyColumns="COMPANIA,TIPOCONTRATO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TRANSACCION (COMPANIA, CONSECUTIVO, TIPOCONTRATO, FECHA, ANO, ESTUDIOPREVIO, ESTADO, OBSERVACION, NUM_PROCESO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONSECUTIVO, :TIPOCONTRATO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :ANO, :ESTUDIOPREVIO, :ESTADO, :OBSERVACION, :NUM_PROCESO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCONTRATO":"$TIPOCONTRATO","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="ESTUDIOPREVIO" sqlType="STRING"/>
		<param defaultValue="0" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION" sqlType="STRING"/>
		<param defaultValue="" name="NUM_PROCESO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="transacciones">
		<call-query href="insertTransacciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESTUDIOPREVIO" query-param="ESTUDIOPREVIO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="NUM_PROCESO" query-param="NUM_PROCESO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTransacciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TRANSACCION WHERE TRANSACCION.COMPANIA= :KEY_COMPANIA AND TRANSACCION.TIPOCONTRATO= :KEY_TIPOCONTRATO AND TRANSACCION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="transacciones">
		<call-query href="deleteTransacciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getTransaccionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TRANSACCION.COMPANIA, TRANSACCION.TIPOCONTRATO, LPAD(TRANSACCION.CONSECUTIVO,8,'0') CONSECUTIVO, TIPOCONTRATO_PR.DESCRIPCION NOM_TIPO, TO_CHAR(TRANSACCION.FECHA, 'DD/MM/YYYY') FECHA, TRANSACCION.ANO, ES_ESTPREVIO.NOMBRE_ESTUDIO, CASE TRANSACCION.ESTADO WHEN 'AC' THEN 'Abierta' WHEN 'CE' THEN 'Cerrado' WHEN 'CA' THEN 'Cancelada' END NOM_ESTADO, TRANSACCION.OBSERVACION, TRANSACCION.NUM_PROCESO FROM TRANSACCION INNER JOIN TIPOCONTRATO_PR ON TRANSACCION.COMPANIA = TIPOCONTRATO_PR.COMPANIA AND TRANSACCION.TIPOCONTRATO = TIPOCONTRATO_PR.TIPOCONTRATO LEFT JOIN ES_ESTPREVIO ON TRANSACCION.COMPANIA = ES_ESTPREVIO.COMPANIA AND TRANSACCION.ESTUDIOPREVIO = ES_ESTPREVIO.COD_ESTUDIO WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO AND TRANSACCION.ANO = :ANOTX AND TRANSACCION.CONSECUTIVO = CASE WHEN :TRANSACCION IS NULL THEN TRANSACCION.CONSECUTIVO ELSE TO_NUMBER(:TRANSACCION) END ORDER BY CONSECUTIVO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO), '%')) AND (CASE WHEN NOM_TIPO IS NULL THEN ' ' ELSE UPPER(NOM_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_TIPO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ESTUDIO), '%')) AND (CASE WHEN NOM_ESTADO IS NULL THEN ' ' ELSE UPPER(NOM_ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_ESTADO), '%')) AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACION), '%')) AND (CASE WHEN NUM_PROCESO IS NULL THEN ' ' ELSE UPPER(NUM_PROCESO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUM_PROCESO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCONTRATO":"$TIPOCONTRATO","CONSECUTIVO":"$CONSECUTIVO","NOM_TIPO":"$NOM_TIPO","FECHA":"$FECHA","ANO":"$ANO(type:integer)","NOMBRE_ESTUDIO":"$NOMBRE_ESTUDIO","NOM_ESTADO":"$NOM_ESTADO","OBSERVACION":"$OBSERVACION","NUM_PROCESO":"$NUM_PROCESO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ANOTX" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NOM_TIPO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>
		<param name="NOM_ESTADO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="NUM_PROCESO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
