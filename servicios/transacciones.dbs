<data name="transacciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTransaccionesPagporTipoContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TRANSACCION.CONSECUTIVO, TRANSACCION.NUM_PROCESO, TRANSACCION.TIPOCONTRATO, TIPOCONTRATO_PR.DESCRIPCION, ES_ESTPREVIO.OBJETO_CONTRATO, TRANSACCION.ESTUDIOPREVIO FROM TRANSACCION INNER JOIN TIPOCONTRATO_PR ON TRANSACCION.COMPANIA = TIPOCONTRATO_PR.COMPANIA AND TRANSACCION.TIPOCONTRATO = TIPOCONTRATO_PR.TIPOCONTRATO INNER JOIN ES_ESTPREVIO ON TRANSACCION.ESTUDIOPREVIO = ES_ESTPREVIO.COD_ESTUDIO AND TRANSACCION.COMPANIA = ES_ESTPREVIO.COMPANIA WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO) INI WHERE (CASE WHEN NUM_PROCESO IS NULL THEN ' ' ELSE UPPER(NUM_PROCESO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUM_PROCESO), '%')) AND (CASE WHEN OBJETO_CONTRATO IS NULL THEN ' ' ELSE UPPER(TO_CHAR(OBJETO_CONTRATO)) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO_CONTRATO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","NUM_PROCESO":"$NUM_PROCESO","TIPOCONTRATO":"$TIPOCONTRATO","DESCRIPCION":"$DESCRIPCION","OBJETO_CONTRATO":"$OBJETO_CONTRATO","ESTUDIOPREVIO":"$ESTUDIOPREVIO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUM_PROCESO" sqlType="STRING"/>
		<param name="OBJETO_CONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="transacciones/portipocontrato/pag">
		<call-query href="getTransaccionesPagporTipoContratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUM_PROCESO" query-param="NUM_PROCESO"/>
			<with-param name="OBJETO_CONTRATO" query-param="OBJETO_CONTRATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTransaccionesNumporTipoContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TRANSACCION.CONSECUTIVO, TRANSACCION.NUM_PROCESO, TRANSACCION.TIPOCONTRATO, TIPOCONTRATO_PR.DESCRIPCION, ES_ESTPREVIO.OBJETO_CONTRATO, TRANSACCION.ESTUDIOPREVIO FROM TRANSACCION INNER JOIN TIPOCONTRATO_PR ON TRANSACCION.COMPANIA = TIPOCONTRATO_PR.COMPANIA AND TRANSACCION.TIPOCONTRATO = TIPOCONTRATO_PR.TIPOCONTRATO INNER JOIN ES_ESTPREVIO ON TRANSACCION.ESTUDIOPREVIO = ES_ESTPREVIO.COD_ESTUDIO AND TRANSACCION.COMPANIA = ES_ESTPREVIO.COMPANIA WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO) INI WHERE (CASE WHEN NUM_PROCESO IS NULL THEN ' ' ELSE UPPER(NUM_PROCESO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUM_PROCESO), '%')) AND (CASE WHEN OBJETO_CONTRATO IS NULL THEN ' ' ELSE UPPER(TO_CHAR(OBJETO_CONTRATO)) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO_CONTRATO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUM_PROCESO" sqlType="STRING"/>
		<param name="OBJETO_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transacciones/portipocontrato/num">
		<call-query href="getTransaccionesNumporTipoContratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUM_PROCESO" query-param="NUM_PROCESO"/>
			<with-param name="OBJETO_CONTRATO" query-param="OBJETO_CONTRATO"/>

		</call-query>
	</resource>
	<query id="getTransaccionesPagPorestadoytipocontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONSECUTIVO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, ANO, ESTADO, OBSERVACION  FROM TRANSACCION WHERE COMPANIA = :COMPANIA AND ESTADO = :ESTADOPAR AND TIPOCONTRATO = :TIPOCONTRATO ORDER BY CONSECUTIVO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","FECHA":"$FECHA","ANO":"$ANO(type:integer)","ESTADO":"$ESTADO","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADOPAR" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="transacciones/porestadoytipocontrato/pag">
		<call-query href="getTransaccionesPagPorestadoytipocontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADOPAR" query-param="ESTADOPAR"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTransaccionesNumPorestadoytipocontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONSECUTIVO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, ANO, ESTADO, OBSERVACION  FROM TRANSACCION WHERE COMPANIA = :COMPANIA AND ESTADO = :ESTADOPAR AND TIPOCONTRATO = :TIPOCONTRATO ORDER BY CONSECUTIVO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADOPAR" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transacciones/porestadoytipocontrato/num">
		<call-query href="getTransaccionesNumPorestadoytipocontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADOPAR" query-param="ESTADOPAR"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getTransaccionesPagTodosPorCompaniaYEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TRANSACCION.CONSECUTIVO, TO_CHAR(TRANSACCION.FECHA,'DD/MM/YYYY') FECHA, TRANSACCION.ANO, TRANSACCION.ESTADO  FROM TRANSACCION WHERE TRANSACCION.COMPANIA = :COMPANIA AND TRANSACCION.ESTADO = :ESTADO AND TRANSACCION.TIPOCONTRATO = :TIPOCONTRATO ORDER BY TRANSACCION.NUMERO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","FECHA":"$FECHA","ANO":"$ANO(type:integer)","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
