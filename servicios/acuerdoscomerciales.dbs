<data name="acuerdoscomerciales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getAcuerdoscomercialesPagTodosporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ACUERDOS_COMERCIALES.CODIGO, PAISES.NOMBRE PAIS, ACUERDOS_COMERCIALES.DESCRIPCION_ACUERDO  FROM ACUERDOS_COMERCIALES INNER JOIN PAISES ON ACUERDOS_COMERCIALES.PAIS = PAISES.PAIS WHERE ACUERDOS_COMERCIALES.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%')  AND (CASE WHEN DESCRIPCION_ACUERDO IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_ACUERDO) END)  LIKE UPPER( '%' || :DESCRIPCION_ACUERDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","PAIS":"$PAIS","DESCRIPCION_ACUERDO":"$DESCRIPCION_ACUERDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="acuerdoscomerciales/todosporcompania/pag">
		<call-query href="getAcuerdoscomercialesPagTodosporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAcuerdoscomercialesNumTodosporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ACUERDOS_COMERCIALES.CODIGO, PAISES.NOMBRE PAIS, ACUERDOS_COMERCIALES.DESCRIPCION_ACUERDO  FROM ACUERDOS_COMERCIALES INNER JOIN PAISES ON ACUERDOS_COMERCIALES.PAIS = PAISES.PAIS WHERE ACUERDOS_COMERCIALES.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%')  AND (CASE WHEN DESCRIPCION_ACUERDO IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_ACUERDO) END)  LIKE UPPER( '%' || :DESCRIPCION_ACUERDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="acuerdoscomerciales/todosporcompania/num">
		<call-query href="getAcuerdoscomercialesNumTodosporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>

		</call-query>
	</resource>
	<query id="getAcuerdoscomercialesPagTodosporcompaniap3Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ACUERDOS_COMERCIALES.CODIGO, PAISES.NOMBRE NOMBRE_PAIS, ACUERDOS_COMERCIALES.DESCRIPCION_ACUERDO, ACUERDOS_COMERCIALES.PAIS  FROM ACUERDOS_COMERCIALES INNER JOIN PAISES ON ACUERDOS_COMERCIALES.PAIS = PAISES.PAIS WHERE ACUERDOS_COMERCIALES.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE_PAIS IS NULL THEN ' ' ELSE UPPER(NOMBRE_PAIS) END)  LIKE UPPER( '%' || :NOMBRE_PAIS || '%')  AND (CASE WHEN DESCRIPCION_ACUERDO IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_ACUERDO) END)  LIKE UPPER( '%' || :DESCRIPCION_ACUERDO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER(:PAIS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE_PAIS":"$NOMBRE_PAIS","DESCRIPCION_ACUERDO":"$DESCRIPCION_ACUERDO","PAIS":"$PAIS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="acuerdoscomerciales/todosporcompaniap3/pag">
		<call-query href="getAcuerdoscomercialesPagTodosporcompaniap3Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_PAIS" query-param="NOMBRE_PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAcuerdoscomercialesNumTodosporcompaniap3Query"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ACUERDOS_COMERCIALES.CODIGO, PAISES.NOMBRE NOMBRE_PAIS, ACUERDOS_COMERCIALES.DESCRIPCION_ACUERDO, ACUERDOS_COMERCIALES.PAIS  FROM ACUERDOS_COMERCIALES INNER JOIN PAISES ON ACUERDOS_COMERCIALES.PAIS = PAISES.PAIS WHERE ACUERDOS_COMERCIALES.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE_PAIS IS NULL THEN ' ' ELSE UPPER(NOMBRE_PAIS) END)  LIKE UPPER( '%' || :NOMBRE_PAIS || '%')  AND (CASE WHEN DESCRIPCION_ACUERDO IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_ACUERDO) END)  LIKE UPPER( '%' || :DESCRIPCION_ACUERDO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER(:PAIS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="acuerdoscomerciales/todosporcompaniap3/num">
		<call-query href="getAcuerdoscomercialesNumTodosporcompaniap3Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_PAIS" query-param="NOMBRE_PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="insertAcuerdoscomerciales" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ACUERDOS_COMERCIALES (COMPANIA, CODIGO, PAIS, DESCRIPCION_ACUERDO, PLAZO_GENERAL, PLAZO_BIENES_SERVICIOS, PLAZO_PUBLICIDAD, VIGENCIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :PAIS, :DESCRIPCION_ACUERDO, :PLAZO_GENERAL, :PLAZO_BIENES_SERVICIOS, :PLAZO_PUBLICIDAD, :VIGENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>
		<param defaultValue="" name="PLAZO_GENERAL" sqlType="STRING"/>
		<param defaultValue="" name="PLAZO_BIENES_SERVICIOS" sqlType="STRING"/>
		<param defaultValue="" name="PLAZO_PUBLICIDAD" sqlType="STRING"/>
		<param defaultValue="" name="VIGENCIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="acuerdoscomerciales">
		<call-query href="insertAcuerdoscomerciales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>
			<with-param name="PLAZO_GENERAL" query-param="PLAZO_GENERAL"/>
			<with-param name="PLAZO_BIENES_SERVICIOS" query-param="PLAZO_BIENES_SERVICIOS"/>
			<with-param name="PLAZO_PUBLICIDAD" query-param="PLAZO_PUBLICIDAD"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteAcuerdoscomerciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ACUERDOS_COMERCIALES WHERE ACUERDOS_COMERCIALES.COMPANIA= :KEY_COMPANIA AND ACUERDOS_COMERCIALES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="acuerdoscomerciales">
		<call-query href="deleteAcuerdoscomerciales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getAcuerdoscomercialesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ACUERDOS_COMERCIALES.COMPANIA,ACUERDOS_COMERCIALES.CODIGO, PAISES.NOMBRE PAIS, ACUERDOS_COMERCIALES.DESCRIPCION_ACUERDO, PLAZO_GENERAL,PLAZO_BIENES_SERVICIOS,PLAZO_PUBLICIDAD,(CASE VIGENCIA WHEN 0 THEN 'false' ELSE 'true' END) VIGENCIA FROM ACUERDOS_COMERCIALES INNER JOIN PAISES ON ACUERDOS_COMERCIALES.PAIS = PAISES.PAIS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%')  AND (CASE WHEN DESCRIPCION_ACUERDO IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_ACUERDO) END)  LIKE UPPER( '%' || :DESCRIPCION_ACUERDO || '%')  AND (CASE WHEN PLAZO_GENERAL IS NULL THEN ' ' ELSE UPPER(PLAZO_GENERAL) END)  LIKE UPPER(:PLAZO_GENERAL || '%')  AND (CASE WHEN PLAZO_BIENES_SERVICIOS IS NULL THEN ' ' ELSE UPPER(PLAZO_BIENES_SERVICIOS) END)  LIKE UPPER(:PLAZO_BIENES_SERVICIOS || '%')  AND (CASE WHEN PLAZO_PUBLICIDAD IS NULL THEN ' ' ELSE UPPER(PLAZO_PUBLICIDAD) END)  LIKE UPPER(:PLAZO_PUBLICIDAD || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","PAIS":"$PAIS","DESCRIPCION_ACUERDO":"$DESCRIPCION_ACUERDO","PLAZO_GENERAL":"$PLAZO_GENERAL","PLAZO_BIENES_SERVICIOS":"$PLAZO_BIENES_SERVICIOS","PLAZO_PUBLICIDAD":"$PLAZO_PUBLICIDAD","VIGENCIA":"$VIGENCIA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>
		<param name="PLAZO_GENERAL" sqlType="STRING"/>
		<param name="PLAZO_BIENES_SERVICIOS" sqlType="STRING"/>
		<param name="PLAZO_PUBLICIDAD" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="acuerdoscomerciales">
		<call-query href="getAcuerdoscomercialesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>
			<with-param name="PLAZO_GENERAL" query-param="PLAZO_GENERAL"/>
			<with-param name="PLAZO_BIENES_SERVICIOS" query-param="PLAZO_BIENES_SERVICIOS"/>
			<with-param name="PLAZO_PUBLICIDAD" query-param="PLAZO_PUBLICIDAD"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAcuerdoscomercialesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ACUERDOS_COMERCIALES.COMPANIA,ACUERDOS_COMERCIALES.CODIGO, PAISES.NOMBRE PAIS, ACUERDOS_COMERCIALES.DESCRIPCION_ACUERDO, PLAZO_GENERAL,PLAZO_BIENES_SERVICIOS,PLAZO_PUBLICIDAD,(CASE VIGENCIA WHEN 0 THEN 'false' ELSE 'true' END) VIGENCIA FROM ACUERDOS_COMERCIALES INNER JOIN PAISES ON ACUERDOS_COMERCIALES.PAIS = PAISES.PAIS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%')  AND (CASE WHEN DESCRIPCION_ACUERDO IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_ACUERDO) END)  LIKE UPPER( '%' || :DESCRIPCION_ACUERDO || '%')  AND (CASE WHEN PLAZO_GENERAL IS NULL THEN ' ' ELSE UPPER(PLAZO_GENERAL) END)  LIKE UPPER(:PLAZO_GENERAL || '%')  AND (CASE WHEN PLAZO_BIENES_SERVICIOS IS NULL THEN ' ' ELSE UPPER(PLAZO_BIENES_SERVICIOS) END)  LIKE UPPER(:PLAZO_BIENES_SERVICIOS || '%')  AND (CASE WHEN PLAZO_PUBLICIDAD IS NULL THEN ' ' ELSE UPPER(PLAZO_PUBLICIDAD) END)  LIKE UPPER(:PLAZO_PUBLICIDAD || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>
		<param name="PLAZO_GENERAL" sqlType="STRING"/>
		<param name="PLAZO_BIENES_SERVICIOS" sqlType="STRING"/>
		<param name="PLAZO_PUBLICIDAD" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="acuerdoscomerciales/numero">
		<call-query href="getAcuerdoscomercialesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>
			<with-param name="PLAZO_GENERAL" query-param="PLAZO_GENERAL"/>
			<with-param name="PLAZO_BIENES_SERVICIOS" query-param="PLAZO_BIENES_SERVICIOS"/>
			<with-param name="PLAZO_PUBLICIDAD" query-param="PLAZO_PUBLICIDAD"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="updateAcuerdoscomerciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ACUERDOS_COMERCIALES SET PAIS=:PAIS, DESCRIPCION_ACUERDO=:DESCRIPCION_ACUERDO, PLAZO_GENERAL=:PLAZO_GENERAL, PLAZO_BIENES_SERVICIOS=:PLAZO_BIENES_SERVICIOS, PLAZO_PUBLICIDAD=:PLAZO_PUBLICIDAD, VIGENCIA=:VIGENCIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ACUERDOS_COMERCIALES.COMPANIA= :KEY_COMPANIA AND ACUERDOS_COMERCIALES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="DESCRIPCION_ACUERDO" sqlType="STRING"/>
		<param name="PLAZO_GENERAL" sqlType="STRING"/>
		<param name="PLAZO_BIENES_SERVICIOS" sqlType="STRING"/>
		<param name="PLAZO_PUBLICIDAD" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="acuerdoscomerciales">
		<call-query href="updateAcuerdoscomerciales">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DESCRIPCION_ACUERDO" query-param="DESCRIPCION_ACUERDO"/>
			<with-param name="PLAZO_GENERAL" query-param="PLAZO_GENERAL"/>
			<with-param name="PLAZO_BIENES_SERVICIOS" query-param="PLAZO_BIENES_SERVICIOS"/>
			<with-param name="PLAZO_PUBLICIDAD" query-param="PLAZO_PUBLICIDAD"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>