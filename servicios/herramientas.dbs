<data name="herramientas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getHerramientasPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  HERRAMIENTAS.COMPANIA, HERRAMIENTAS.CODIGOELEMENTO, HERRAMIENTAS.NOMBRELEMENTO, HERRAMIENTAS.SERIE  FROM HERRAMIENTAS WHERE HERRAMIENTAS.COMPANIA = :COMPANIA ORDER BY HERRAMIENTAS.COMPANIA, HERRAMIENTAS.CODIGOELEMENTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBRELEMENTO) END)  LIKE UPPER( '%' || :NOMBRELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELEMENTO":"$NOMBRELEMENTO","SERIE":"$SERIE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="herramientas/todosporcompania/pag">
		<call-query href="getHerramientasPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELEMENTO" query-param="NOMBRELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getHerramientasNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  HERRAMIENTAS.COMPANIA, HERRAMIENTAS.CODIGOELEMENTO, HERRAMIENTAS.NOMBRELEMENTO, HERRAMIENTAS.SERIE  FROM HERRAMIENTAS WHERE HERRAMIENTAS.COMPANIA = :COMPANIA ORDER BY HERRAMIENTAS.COMPANIA, HERRAMIENTAS.CODIGOELEMENTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBRELEMENTO) END)  LIKE UPPER( '%' || :NOMBRELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="herramientas/todosporcompania/num">
		<call-query href="getHerramientasNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELEMENTO" query-param="NOMBRELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>

		</call-query>
	</resource>
	<query id="insertHerramientas" keyColumns="COMPANIA,CODIGOELEMENTO,SERIE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO HERRAMIENTAS (COMPANIA, NOMBRELEMENTO, SERIE, CODIGOELEMENTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NOMBRELEMENTO, :SERIE, :CODIGOELEMENTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOELEMENTO":"$CODIGOELEMENTO","KEY_SERIE":"$SERIE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRELEMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="SERIE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="herramientas">
		<call-query href="insertHerramientas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRELEMENTO" query-param="NOMBRELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteHerramientas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM HERRAMIENTAS WHERE HERRAMIENTAS.COMPANIA= :KEY_COMPANIA AND HERRAMIENTAS.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND HERRAMIENTAS.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="herramientas">
		<call-query href="deleteHerramientas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getHerramientasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NOMBRELEMENTO, SERIE, CODIGOELEMENTO  FROM HERRAMIENTAS WHERE HERRAMIENTAS.COMPANIA=:COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN NOMBRELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBRELEMENTO) END)  LIKE UPPER( '%' || :NOMBRELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NOMBRELEMENTO":"$NOMBRELEMENTO","SERIE":"$SERIE","CODIGOELEMENTO":"$CODIGOELEMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="herramientas">
		<call-query href="getHerramientasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRELEMENTO" query-param="NOMBRELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getHerramientasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NOMBRELEMENTO, SERIE, CODIGOELEMENTO  FROM HERRAMIENTAS WHERE HERRAMIENTAS.COMPANIA=:COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN NOMBRELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBRELEMENTO) END)  LIKE UPPER( '%' || :NOMBRELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="herramientas/numero">
		<call-query href="getHerramientasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRELEMENTO" query-param="NOMBRELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>

		</call-query>
	</resource>
	<query id="updateHerramientas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE HERRAMIENTAS SET COMPANIA=:COMPANIA, NOMBRELEMENTO=:NOMBRELEMENTO, SERIE=:SERIE, CODIGOELEMENTO=:CODIGOELEMENTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE HERRAMIENTAS.COMPANIA= :KEY_COMPANIA AND HERRAMIENTAS.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND HERRAMIENTAS.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="herramientas">
		<call-query href="updateHerramientas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRELEMENTO" query-param="NOMBRELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>

</data>