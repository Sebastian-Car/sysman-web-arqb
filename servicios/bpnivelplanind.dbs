	</resource>
	<query id="getBpnivelplanindPagTodosPorCompaniaNivelQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  *  FROM (SELECT DISTINCT '0' DIGITOS, 'Todos' DESCRIPCION FROM BP_NIVEL_PLAN_IND UNION SELECT TO_CHAR(BP_NIVEL_PLAN_IND.DIGITOS) DIGITOS, BP_NIVEL_PLAN_IND.DESCRIPCION FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA = :COMPANIA ) ORDER BY DIGITOS ASC) WHERE (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER(:DIGITOS || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIGITOS":"$DIGITOS","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
