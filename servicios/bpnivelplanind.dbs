	<query id="getBpnivelplanindTodoasLosProgramasPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT '99999999999' AS ID, 'TODAS' AS DESCRIPCION, TO_NUMBER(TO_CHAR(SYSDATE, 'YYYY')) VIGENCIA  FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","DESCRIPCION":"$DESCRIPCION","VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
 
	</query>
