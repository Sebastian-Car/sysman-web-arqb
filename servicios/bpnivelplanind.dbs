<data name="bpnivelplanind" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpnivelplanindTodosOrDigitosQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE META_RESUL WHEN 0 THEN 'false' ELSE 'true' END) META_RESUL,(CASE META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC,(CASE MANEJA_DEPEN WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_DEPEN FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = :COMPANIA AND VIGENCIA = :VIGENCIA AND DIGITOS = LENGTH(NVL( :ID ,0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"META_RESUL":"$META_RESUL(type:boolean)","META_PRODUC":"$META_PRODUC(type:boolean)","MANEJA_DEPEN":"$MANEJA_DEPEN(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/todosordigitos">
		<call-query href="getBpnivelplanindTodosOrDigitosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindCantiadaRegistrosMetresulQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE META_RESUL WHEN 0 THEN 'false' ELSE 'true' END) META_RESUL FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = :COMPANIA AND VIGENCIA = :VIGENCIA AND META_RESUL = -1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"META_RESUL":"$META_RESUL(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/cantiadaregistrosmetresul">
		<call-query href="getBpnivelplanindCantiadaRegistrosMetresulQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindCantiadaRegistrosMetproduQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = :COMPANIA AND VIGENCIA = :VIGENCIA AND META_PRODUC = -1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"META_PRODUC":"$META_PRODUC(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/cantiadaregistrosmetprodu">
		<call-query href="getBpnivelplanindCantiadaRegistrosMetproduQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindTodasPorVigenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT VIGENCIA  FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/todasporvigencias">
		<call-query href="getBpnivelplanindTodasPorVigenciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindMetaresulporvigQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_NIVEL_PLAN_IND.COMPANIA, BP_NIVEL_PLAN_IND.VIGENCIA, BP_NIVEL_PLAN_IND.DIGITOS, BP_NIVEL_PLAN_IND.DESCRIPCION,(CASE BP_NIVEL_PLAN_IND.META_RESUL WHEN 0 THEN 'false' ELSE 'true' END) META_RESUL,(CASE BP_NIVEL_PLAN_IND.META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA =:COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA =:VIGENCIA ORDER BY BP_NIVEL_PLAN_IND.COMPANIA, BP_NIVEL_PLAN_IND.VIGENCIA, BP_NIVEL_PLAN_IND.DIGITOS ASC, BP_NIVEL_PLAN_IND.DESCRIPCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA":"$VIGENCIA(type:integer)","DIGITOS":"$DIGITOS(type:integer)","DESCRIPCION":"$DESCRIPCION","META_RESUL":"$META_RESUL(type:boolean)","META_PRODUC":"$META_PRODUC(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/metaresulporvig">
		<call-query href="getBpnivelplanindMetaresulporvigQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindDigitosYDescripcionPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_NIVEL_PLAN_IND.DIGITOS, BP_NIVEL_PLAN_IND.DESCRIPCION  FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA = :COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = :VIGENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIGITOS":"$DIGITOS(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/digitosydescripcionporvigencia">
		<call-query href="getBpnivelplanindDigitosYDescripcionPorVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindPorCompaniaYMetaresulQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DIGITOS  FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = :COMPANIA AND VIGENCIA = :VIGENCIA AND META_RESUL NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/porcompaniaymetaresul">
		<call-query href="getBpnivelplanindPorCompaniaYMetaresulQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindPorCompaniaYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_NIVEL_PLAN_IND.DIGITOS  FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA = :COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','')),BP_NIVEL_PLAN_IND.VIGENCIA,1) &gt;0 ORDER BY BP_NIVEL_PLAN_IND.COMPANIA, BP_NIVEL_PLAN_IND.VIGENCIA, BP_NIVEL_PLAN_IND.DIGITOS ASC, BP_NIVEL_PLAN_IND.DESCRIPCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/porcompaniayvigencia">
		<call-query href="getBpnivelplanindPorCompaniaYVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindTodosPorVigenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT BP_NIVEL_PLAN_IND.DIGITOS FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','') ),CONCAT( '', CONCAT(TO_CHAR(BP_NIVEL_PLAN_IND.VIGENCIA), '')),1) &gt; 0 ORDER BY BP_NIVEL_PLAN_IND.COMPANIA, BP_NIVEL_PLAN_IND.VIGENCIA, BP_NIVEL_PLAN_IND.DIGITOS ASC, BP_NIVEL_PLAN_IND.DESCRIPCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/todosporvigencias">
		<call-query href="getBpnivelplanindTodosPorVigenciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
<query id="insertBpnivelplanind" keyColumns="COMPANIA,VIGENCIA,DIGITOS" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_NIVEL_PLAN_IND (COMPANIA, VIGENCIA, DIGITOS, DESCRIPCION, META_RESUL, META_PRODUC, MANEJA_DEPEN, ACCION, MANEJA_TRAZADOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :VIGENCIA, :DIGITOS, :DESCRIPCION, :META_RESUL, :META_PRODUC, :MANEJA_DEPEN, :ACCION, :MANEJA_TRAZADOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_VIGENCIA":"$VIGENCIA(type:integer)","KEY_DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="DIGITOS" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="META_RESUL" sqlType="STRING"/>
		<param defaultValue="0" name="META_PRODUC" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_DEPEN" sqlType="STRING"/>
		<param defaultValue="0" name="ACCION" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_TRAZADOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpnivelplanind">
		<call-query href="insertBpnivelplanind">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="META_RESUL" query-param="META_RESUL"/>
			<with-param name="META_PRODUC" query-param="META_PRODUC"/>
			<with-param name="MANEJA_DEPEN" query-param="MANEJA_DEPEN"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="MANEJA_TRAZADOR" query-param="MANEJA_TRAZADOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpnivelplanind" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA= :KEY_COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA= :KEY_VIGENCIA AND BP_NIVEL_PLAN_IND.DIGITOS= :KEY_DIGITOS</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>
		<param name="KEY_DIGITOS" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="bpnivelplanind">
		<call-query href="deleteBpnivelplanind">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_DIGITOS" query-param="KEY_DIGITOS"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, VIGENCIA, DIGITOS, DESCRIPCION,(CASE META_RESUL WHEN 0 THEN 'false' ELSE 'true' END) META_RESUL,(CASE META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC,(CASE MANEJA_DEPEN WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_DEPEN,(CASE ACCION WHEN 0 THEN 'false' ELSE 'true' END) ACCION,(CASE MANEJA_TRAZADOR WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_TRAZADOR FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = :COMPANIA AND VIGENCIA = :ANO) INI WHERE (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END) LIKE UPPER(CONCAT(:DIGITOS, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN META_RESUL IS NULL THEN ' ' ELSE UPPER(META_RESUL) END) LIKE UPPER(CONCAT(:META_RESUL, '%')) AND (CASE WHEN META_PRODUC IS NULL THEN ' ' ELSE UPPER(META_PRODUC) END) LIKE UPPER(CONCAT(:META_PRODUC, '%')) AND (CASE WHEN MANEJA_DEPEN IS NULL THEN ' ' ELSE UPPER(MANEJA_DEPEN) END) LIKE UPPER(CONCAT(:MANEJA_DEPEN, '%')) AND (CASE WHEN ACCION IS NULL THEN ' ' ELSE UPPER(ACCION) END) LIKE UPPER(CONCAT(:ACCION, '%')) AND (CASE WHEN MANEJA_TRAZADOR IS NULL THEN ' ' ELSE UPPER(MANEJA_TRAZADOR) END) LIKE UPPER(CONCAT(:MANEJA_TRAZADOR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA":"$VIGENCIA(type:integer)","DIGITOS":"$DIGITOS(type:integer)","DESCRIPCION":"$DESCRIPCION","META_RESUL":"$META_RESUL(type:boolean)","META_PRODUC":"$META_PRODUC(type:boolean)","MANEJA_DEPEN":"$MANEJA_DEPEN(type:boolean)","ACCION":"$ACCION(type:boolean)","MANEJA_TRAZADOR":"$MANEJA_TRAZADOR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="META_RESUL" sqlType="STRING"/>
		<param name="META_PRODUC" sqlType="STRING"/>
		<param name="MANEJA_DEPEN" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="MANEJA_TRAZADOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnivelplanind">
		<call-query href="getBpnivelplanindPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="META_RESUL" query-param="META_RESUL"/>
			<with-param name="META_PRODUC" query-param="META_PRODUC"/>
			<with-param name="MANEJA_DEPEN" query-param="MANEJA_DEPEN"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="MANEJA_TRAZADOR" query-param="MANEJA_TRAZADOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, VIGENCIA, DIGITOS, DESCRIPCION,(CASE META_RESUL WHEN 0 THEN 'false' ELSE 'true' END) META_RESUL,(CASE META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC,(CASE MANEJA_DEPEN WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_DEPEN,(CASE ACCION WHEN 0 THEN 'false' ELSE 'true' END) ACCION,(CASE MANEJA_TRAZADOR WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_TRAZADOR FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = :COMPANIA AND VIGENCIA = :ANO) INI WHERE (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END) LIKE UPPER(CONCAT(:DIGITOS, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN META_RESUL IS NULL THEN ' ' ELSE UPPER(META_RESUL) END) LIKE UPPER(CONCAT(:META_RESUL, '%')) AND (CASE WHEN META_PRODUC IS NULL THEN ' ' ELSE UPPER(META_PRODUC) END) LIKE UPPER(CONCAT(:META_PRODUC, '%')) AND (CASE WHEN MANEJA_DEPEN IS NULL THEN ' ' ELSE UPPER(MANEJA_DEPEN) END) LIKE UPPER(CONCAT(:MANEJA_DEPEN, '%')) AND (CASE WHEN ACCION IS NULL THEN ' ' ELSE UPPER(ACCION) END) LIKE UPPER(CONCAT(:ACCION, '%')) AND (CASE WHEN MANEJA_TRAZADOR IS NULL THEN ' ' ELSE UPPER(MANEJA_TRAZADOR) END) LIKE UPPER(CONCAT(:MANEJA_TRAZADOR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="META_RESUL" sqlType="STRING"/>
		<param name="META_PRODUC" sqlType="STRING"/>
		<param name="MANEJA_DEPEN" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="MANEJA_TRAZADOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnivelplanind/numero">
		<call-query href="getBpnivelplanindNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="META_RESUL" query-param="META_RESUL"/>
			<with-param name="META_PRODUC" query-param="META_PRODUC"/>
			<with-param name="MANEJA_DEPEN" query-param="MANEJA_DEPEN"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="MANEJA_TRAZADOR" query-param="MANEJA_TRAZADOR"/>

		</call-query>
	</resource>
	<query id="updateBpnivelplanind" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_NIVEL_PLAN_IND SET DIGITOS=:DIGITOS, DESCRIPCION=:DESCRIPCION, META_RESUL=:META_RESUL, META_PRODUC=:META_PRODUC, MANEJA_DEPEN=:MANEJA_DEPEN, ACCION=:ACCION, MANEJA_TRAZADOR=:MANEJA_TRAZADOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_NIVEL_PLAN_IND.COMPANIA= :KEY_COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA= :KEY_VIGENCIA AND BP_NIVEL_PLAN_IND.DIGITOS= :KEY_DIGITOS</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DIGITOS" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="META_RESUL" sqlType="STRING"/>
		<param name="META_PRODUC" sqlType="STRING"/>
		<param name="MANEJA_DEPEN" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="MANEJA_TRAZADOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_DIGITOS" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpnivelplanind">
		<call-query href="updateBpnivelplanind">
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="META_RESUL" query-param="META_RESUL"/>
			<with-param name="META_PRODUC" query-param="META_PRODUC"/>
			<with-param name="MANEJA_DEPEN" query-param="MANEJA_DEPEN"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="MANEJA_TRAZADOR" query-param="MANEJA_TRAZADOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_DIGITOS" query-param="KEY_DIGITOS"/>

		</call-query>
	</resource>
	<query id="getBpnivelplanindTodosPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_NIVEL_PLAN_IND.COMPANIA, BP_NIVEL_PLAN_IND.VIGENCIA, BP_NIVEL_PLAN_IND.DESCRIPCION, BP_NIVEL_PLAN_IND.DIGITOS,(CASE BP_NIVEL_PLAN_IND.META_RESUL WHEN 0 THEN 'false' ELSE 'true' END) META_RESUL,(CASE BP_NIVEL_PLAN_IND.META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC FROM BP_NIVEL_PLAN_IND WHERE BP_NIVEL_PLAN_IND.COMPANIA= :COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = :VIGENCIA ORDER BY BP_NIVEL_PLAN_IND.DIGITOS DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA":"$VIGENCIA(type:integer)","DESCRIPCION":"$DESCRIPCION","DIGITOS":"$DIGITOS(type:integer)","META_RESUL":"$META_RESUL(type:boolean)","META_PRODUC":"$META_PRODUC(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
