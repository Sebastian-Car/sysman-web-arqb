	<query id="getAlmacenescontabilidadPagContabilizartraniiflistadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.NIIF_CUENTADEBITO, ALMACENCONTABILIDAD.NIIF_CUENTACREDITO, TIPOMOVIMIENTO.NOMBRE, ALMACENCONTABILIDAD.NIIF_DEBITO_BASE, ALMACENCONTABILIDAD.NIIF_CREDITO_BASE, ALMACENCONTABILIDAD.NIIF_CREDITO_IVA, ALMACENCONTABILIDAD.NIIF_DEBITO_IVA  FROM ALMACENCONTABILIDAD LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA AND ALMACENCONTABILIDAD.CODIGOELEMENTO = :CODIGOELEMENTO AND ALMACENCONTABILIDAD.ANO = :ANO ORDER BY ALMACENCONTABILIDAD.TIPOMOVIMIENTO) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER(:TIPOMOVIMIENTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN NIIF_CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTADEBITO) END)  LIKE UPPER(:NIIF_CUENTADEBITO || '%')  AND (CASE WHEN NIIF_CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTACREDITO) END)  LIKE UPPER(:NIIF_CUENTACREDITO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN NIIF_DEBITO_BASE IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_BASE) END)  LIKE UPPER(:NIIF_DEBITO_BASE || '%')  AND (CASE WHEN NIIF_CREDITO_BASE IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_BASE) END)  LIKE UPPER( '%' || :NIIF_CREDITO_BASE || '%')  AND (CASE WHEN NIIF_CREDITO_IVA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_IVA) END)  LIKE UPPER(:NIIF_CREDITO_IVA || '%')  AND (CASE WHEN NIIF_DEBITO_IVA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_IVA) END)  LIKE UPPER(:NIIF_DEBITO_IVA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","ANO":"$ANO(type:integer)","NIIF_CUENTADEBITO":"$NIIF_CUENTADEBITO","NIIF_CUENTACREDITO":"$NIIF_CUENTACREDITO","NOMBRE":"$NOMBRE","NIIF_DEBITO_BASE":"$NIIF_DEBITO_BASE","NIIF_CREDITO_BASE":"$NIIF_CREDITO_BASE","NIIF_CREDITO_IVA":"$NIIF_CREDITO_IVA","NIIF_DEBITO_IVA":"$NIIF_DEBITO_IVA"}]}}		</result>
