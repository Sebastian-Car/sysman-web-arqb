	<query id="getAlmacenescontabilidadNumListaAlmacenBajaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, TIPOMOVIMIENTO.NOMBRE, ALMACENCONTABILIDAD.DEBITO_HISTORICO_BAJA, ALMACENCONTABILIDAD.CREDITO_HISTORICO_BAJA, ALMACENCONTABILIDAD.DEBITO_ACUMULADA_BAJA, ALMACENCONTABILIDAD.CREDITO_ACUMULADA_BAJA, ALMACENCONTABILIDAD.DEBITO_LIBROS_BAJA, ALMACENCONTABILIDAD.CREDITO_LIBROS_BAJA, ALMACENCONTABILIDAD.DEBITO_RETIRADOS_BAJA, ALMACENCONTABILIDAD.CREDITO_RETIRADOS_BAJA FROM ALMACENCONTABILIDAD LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO AND ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA AND ALMACENCONTABILIDAD.CODIGOELEMENTO= :CODIGOELEMENTO AND ALMACENCONTABILIDAD.ANO = :ANO AND (TIPOMOVIMIENTO.CONCEPTO IN ('CM','DS','L','DT','T') AND TIPOMOVIMIENTO.CLASE NOT IN ('E') OR ( TIPOMOVIMIENTO.CLASE NOT IN ( 'T','E' ) AND TIPOMOVIMIENTO.CONCEPTO NOT IN ( 'T' ,'II','N') ))ORDER BY ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.ANO, TIPOMOVIMIENTO.NOMBRE) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DEBITO_HISTORICO_BAJA IS NULL THEN ' ' ELSE UPPER(DEBITO_HISTORICO_BAJA) END) LIKE UPPER(CONCAT(:DEBITO_HISTORICO_BAJA, '%')) AND (CASE WHEN CREDITO_HISTORICO_BAJA IS NULL THEN ' ' ELSE UPPER(CREDITO_HISTORICO_BAJA) END) LIKE UPPER(CONCAT(:CREDITO_HISTORICO_BAJA, '%')) AND (CASE WHEN DEBITO_ACUMULADA_BAJA IS NULL THEN ' ' ELSE UPPER(DEBITO_ACUMULADA_BAJA) END) LIKE UPPER(CONCAT(:DEBITO_ACUMULADA_BAJA, '%')) AND (CASE WHEN CREDITO_ACUMULADA_BAJA IS NULL THEN ' ' ELSE UPPER(CREDITO_ACUMULADA_BAJA) END) LIKE UPPER(CONCAT(:CREDITO_ACUMULADA_BAJA, '%')) AND (CASE WHEN DEBITO_LIBROS_BAJA IS NULL THEN ' ' ELSE UPPER(DEBITO_LIBROS_BAJA) END) LIKE UPPER(CONCAT(:DEBITO_LIBROS_BAJA, '%')) AND (CASE WHEN CREDITO_LIBROS_BAJA IS NULL THEN ' ' ELSE UPPER(CREDITO_LIBROS_BAJA) END) LIKE UPPER(CONCAT(:CREDITO_LIBROS_BAJA, '%')) AND (CASE WHEN DEBITO_RETIRADOS_BAJA IS NULL THEN ' ' ELSE UPPER(DEBITO_RETIRADOS_BAJA) END) LIKE UPPER(CONCAT(:DEBITO_RETIRADOS_BAJA, '%')) AND (CASE WHEN CREDITO_RETIRADOS_BAJA IS NULL THEN ' ' ELSE UPPER(CREDITO_RETIRADOS_BAJA) END) LIKE UPPER(CONCAT(:CREDITO_RETIRADOS_BAJA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEBITO_HISTORICO_BAJA" sqlType="STRING"/>
		<param name="CREDITO_HISTORICO_BAJA" sqlType="STRING"/>
		<param name="DEBITO_ACUMULADA_BAJA" sqlType="STRING"/>
		<param name="CREDITO_ACUMULADA_BAJA" sqlType="STRING"/>
		<param name="DEBITO_LIBROS_BAJA" sqlType="STRING"/>
		<param name="CREDITO_LIBROS_BAJA" sqlType="STRING"/>
		<param name="DEBITO_RETIRADOS_BAJA" sqlType="STRING"/>
		<param name="CREDITO_RETIRADOS_BAJA" sqlType="STRING"/>

	</query>
