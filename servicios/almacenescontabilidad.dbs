	<query id="getAlmacenescontabilidadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.CUENTADEBITO, ALMACENCONTABILIDAD.CUENTACREDITO, TIPOMOVIMIENTO.NOMBRE  FROM ALMACENCONTABILIDAD INNER JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA AND ALMACENCONTABILIDAD.CODIGOELEMENTO = :CODIGO AND ALMACENCONTABILIDAD.ANO = :ANIO ORDER BY TIPOMOVIMIENTO.NOMBRE) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER( '%' || :CUENTADEBITO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER( '%' || :CUENTACREDITO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","ANO":"$ANO(type:integer)","CUENTADEBITO":"$CUENTADEBITO","CUENTACREDITO":"$CUENTACREDITO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="almacenescontabilidad">
		<call-query href="getAlmacenescontabilidadPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAlmacenescontabilidadNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.CUENTADEBITO, ALMACENCONTABILIDAD.CUENTACREDITO, TIPOMOVIMIENTO.NOMBRE  FROM ALMACENCONTABILIDAD INNER JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA AND ALMACENCONTABILIDAD.CODIGOELEMENTO = :CODIGO AND ALMACENCONTABILIDAD.ANO = :ANIO ORDER BY TIPOMOVIMIENTO.NOMBRE) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER( '%' || :CUENTADEBITO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER( '%' || :CUENTACREDITO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
