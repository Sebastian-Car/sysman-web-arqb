<data name="almacenescontabilidad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateAlmacenescontabilidadMergeInventarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>MERGE INTO ALMACENCONTABILIDAD TABLA USING ( SELECT    TIPOMOVIMIENTO.COMPANIA COMPANIA,    :CODIGO CODIGOELEMENTO,   TIPOMOVIMIENTO.CODIGO TIPOMOVIMIENTO,   :ANO ANO, CASE WHEN TIPOMOVIMIENTO.CLASE = 'E' THEN :CUENTAACT ELSE NULL END CUENTADEBITO, CASE WHEN TIPOMOVIMIENTO.CLASE = 'S' THEN :CUENTAACT ELSE NULL END CUENTACREDITO FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.TIPOELEMENTO = :TIPO)VISTA ON( TABLA.COMPANIA=VISTA.COMPANIA      AND TABLA.TIPOMOVIMIENTO=VISTA.TIPOMOVIMIENTO      AND TABLA.CODIGOELEMENTO=VISTA.CODIGOELEMENTO      AND TABLA.ANO=VISTA.ANO)     WHEN NOT MATCHED THEN      INSERT (COMPANIA, CODIGOELEMENTO, TIPOMOVIMIENTO, ANO, CUENTADEBITO, CUENTACREDITO) VALUES     (VISTA.COMPANIA,VISTA.CODIGOELEMENTO,VISTA.TIPOMOVIMIENTO,VISTA.ANO,VISTA.CUENTADEBITO,VISTA.CUENTACREDITO)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTAACT" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="almacenescontabilidad/mergeinventarios">
		<call-query href="updateAlmacenescontabilidadMergeInventarios">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTAACT" query-param="CUENTAACT"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="updateAlmacenescontabilidadMergeActInventarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>MERGE INTO ALMACENCONTABILIDAD TABLA USING ( SELECT    COMPANIA,   CODIGO,   CASE WHEN CLASE='E' OR CLASE='S' THEN :CUENTAACT ELSE '' END CLASE FROM TIPOMOVIMIENTO WHERE COMPANIA= :COMPANIA) VISTA ON (TABLA.COMPANIA=VISTA.COMPANIA     AND TABLA.TIPOMOVIMIENTO=VISTA.CODIGO) WHEN MATCHED THEN UPDATE SET     TABLA.CUENTADEBITO=VISTA.CLASE,   TABLA.CUENTACREDITO=VISTA.CLASE WHERE TABLA.COMPANIA = :COMPANIA   AND TABLA.CODIGOELEMENTO = :ELEMENTO   AND TABLA.ANO = :ANO   AND TABLA.CUENTADEBITO IS NULL   AND TABLA.CUENTACREDITO IS NULL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CUENTAACT" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="almacenescontabilidad/mergeactinventarios">
		<call-query href="updateAlmacenescontabilidadMergeActInventarios">
			<with-param name="CUENTAACT" query-param="CUENTAACT"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAlmacenescontabilidadCuentaCreditoYDebitoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CUENTACREDITO, CUENTADEBITO  FROM ALMACENCONTABILIDAD WHERE COMPANIA = :COMPANIA AND CODIGOELEMENTO = :ELEMENTO AND TIPOMOVIMIENTO IN (:TIPO) AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTACREDITO":"$CUENTACREDITO","CUENTADEBITO":"$CUENTADEBITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="almacenescontabilidad/cuentacreditoydebito">
		<call-query href="getAlmacenescontabilidadCuentaCreditoYDebitoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAlmacenescontabilidadPagListaInterfacesAlmacenQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.CUENTADEBITO, ALMACENCONTABILIDAD.CUENTACREDITO, ALMACENCONTABILIDAD.CUENTADEBITOAJUSTE, ALMACENCONTABILIDAD.CUENTACREDITOAJUSTE, TIPOMOVIMIENTO.NOMBRE, INVENTARIO.NOMBRELARGO, ALMACENCONTABILIDAD.NIIF_CUENTADEBITO, ALMACENCONTABILIDAD.NIIF_CUENTACREDITO  FROM ALMACENCONTABILIDAD LEFT JOIN INVENTARIO ON ALMACENCONTABILIDAD.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO AND ALMACENCONTABILIDAD.COMPANIA = INVENTARIO.COMPANIA LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO AND ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA ORDER BY ALMACENCONTABILIDAD.ANO DESC, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER(:TIPOMOVIMIENTO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER(:CUENTADEBITO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER(:CUENTACREDITO || '%')  AND (CASE WHEN CUENTADEBITOAJUSTE IS NULL THEN ' ' ELSE UPPER(CUENTADEBITOAJUSTE) END)  LIKE UPPER(:CUENTADEBITOAJUSTE || '%')  AND (CASE WHEN CUENTACREDITOAJUSTE IS NULL THEN ' ' ELSE UPPER(CUENTACREDITOAJUSTE) END)  LIKE UPPER(:CUENTACREDITOAJUSTE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN NIIF_CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTADEBITO) END)  LIKE UPPER(:NIIF_CUENTADEBITO || '%')  AND (CASE WHEN NIIF_CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTACREDITO) END)  LIKE UPPER(:NIIF_CUENTACREDITO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","CODIGOELEMENTO":"$CODIGOELEMENTO","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","CUENTADEBITO":"$CUENTADEBITO","CUENTACREDITO":"$CUENTACREDITO","CUENTADEBITOAJUSTE":"$CUENTADEBITOAJUSTE","CUENTACREDITOAJUSTE":"$CUENTACREDITOAJUSTE","NOMBRE":"$NOMBRE","NOMBRELARGO":"$NOMBRELARGO","NIIF_CUENTADEBITO":"$NIIF_CUENTADEBITO","NIIF_CUENTACREDITO":"$NIIF_CUENTACREDITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="CUENTADEBITOAJUSTE" sqlType="STRING"/>
		<param name="CUENTACREDITOAJUSTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="NIIF_CUENTADEBITO" sqlType="STRING"/>
		<param name="NIIF_CUENTACREDITO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="almacenescontabilidad/listainterfacesalmacen/pag">
		<call-query href="getAlmacenescontabilidadPagListaInterfacesAlmacenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="CUENTADEBITOAJUSTE" query-param="CUENTADEBITOAJUSTE"/>
			<with-param name="CUENTACREDITOAJUSTE" query-param="CUENTACREDITOAJUSTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="NIIF_CUENTADEBITO" query-param="NIIF_CUENTADEBITO"/>
			<with-param name="NIIF_CUENTACREDITO" query-param="NIIF_CUENTACREDITO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAlmacenescontabilidadNumListaInterfacesAlmacenQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.CUENTADEBITO, ALMACENCONTABILIDAD.CUENTACREDITO, ALMACENCONTABILIDAD.CUENTADEBITOAJUSTE, ALMACENCONTABILIDAD.CUENTACREDITOAJUSTE, TIPOMOVIMIENTO.NOMBRE, INVENTARIO.NOMBRELARGO, ALMACENCONTABILIDAD.NIIF_CUENTADEBITO, ALMACENCONTABILIDAD.NIIF_CUENTACREDITO  FROM ALMACENCONTABILIDAD LEFT JOIN INVENTARIO ON ALMACENCONTABILIDAD.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO AND ALMACENCONTABILIDAD.COMPANIA = INVENTARIO.COMPANIA LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO AND ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA ORDER BY ALMACENCONTABILIDAD.ANO DESC, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER(:TIPOMOVIMIENTO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER(:CUENTADEBITO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER(:CUENTACREDITO || '%')  AND (CASE WHEN CUENTADEBITOAJUSTE IS NULL THEN ' ' ELSE UPPER(CUENTADEBITOAJUSTE) END)  LIKE UPPER(:CUENTADEBITOAJUSTE || '%')  AND (CASE WHEN CUENTACREDITOAJUSTE IS NULL THEN ' ' ELSE UPPER(CUENTACREDITOAJUSTE) END)  LIKE UPPER(:CUENTACREDITOAJUSTE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN NIIF_CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTADEBITO) END)  LIKE UPPER(:NIIF_CUENTADEBITO || '%')  AND (CASE WHEN NIIF_CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTACREDITO) END)  LIKE UPPER(:NIIF_CUENTACREDITO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="CUENTADEBITOAJUSTE" sqlType="STRING"/>
		<param name="CUENTACREDITOAJUSTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="NIIF_CUENTADEBITO" sqlType="STRING"/>
		<param name="NIIF_CUENTACREDITO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="almacenescontabilidad/listainterfacesalmacen/num">
		<call-query href="getAlmacenescontabilidadNumListaInterfacesAlmacenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="CUENTADEBITOAJUSTE" query-param="CUENTADEBITOAJUSTE"/>
			<with-param name="CUENTACREDITOAJUSTE" query-param="CUENTACREDITOAJUSTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="NIIF_CUENTADEBITO" query-param="NIIF_CUENTADEBITO"/>
			<with-param name="NIIF_CUENTACREDITO" query-param="NIIF_CUENTACREDITO"/>

		</call-query>
	</resource>
	<query id="getAlmacenescontabilidadPagContabiliadadATransaccionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.CUENTADEBITO, ALMACENCONTABILIDAD.CUENTACREDITO, TIPOMOVIMIENTO.NOMBRE, ALMACENCONTABILIDAD.DEBITO_BASE, ALMACENCONTABILIDAD.CREDITO_BASE, ALMACENCONTABILIDAD.CREDITO_IVA, ALMACENCONTABILIDAD.DEBITO_IVA  FROM ALMACENCONTABILIDAD LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA AND ALMACENCONTABILIDAD.CODIGOELEMENTO = :CODIGOELEMENTO AND ALMACENCONTABILIDAD.ANO = :ANO ORDER BY ALMACENCONTABILIDAD.TIPOMOVIMIENTO) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER(:TIPOMOVIMIENTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER(:CUENTADEBITO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER(:CUENTACREDITO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEBITO_BASE IS NULL THEN ' ' ELSE UPPER(DEBITO_BASE) END)  LIKE UPPER(:DEBITO_BASE || '%')  AND (CASE WHEN CREDITO_BASE IS NULL THEN ' ' ELSE UPPER(CREDITO_BASE) END)  LIKE UPPER(:CREDITO_BASE || '%')  AND (CASE WHEN CREDITO_IVA IS NULL THEN ' ' ELSE UPPER(CREDITO_IVA) END)  LIKE UPPER(:CREDITO_IVA || '%')  AND (CASE WHEN DEBITO_IVA IS NULL THEN ' ' ELSE UPPER(DEBITO_IVA) END)  LIKE UPPER(:DEBITO_IVA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","ANO":"$ANO(type:integer)","CUENTADEBITO":"$CUENTADEBITO","CUENTACREDITO":"$CUENTACREDITO","NOMBRE":"$NOMBRE","DEBITO_BASE":"$DEBITO_BASE","CREDITO_BASE":"$CREDITO_BASE","CREDITO_IVA":"$CREDITO_IVA","DEBITO_IVA":"$DEBITO_IVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEBITO_BASE" sqlType="STRING"/>
		<param name="CREDITO_BASE" sqlType="STRING"/>
		<param name="CREDITO_IVA" sqlType="STRING"/>
		<param name="DEBITO_IVA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="almacenescontabilidad/contabiliadadatransaccion/pag">
		<call-query href="getAlmacenescontabilidadPagContabiliadadATransaccionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CUENTADEBITO" query-param="CUENTADEBITO"/>
			<with-param name="CUENTACREDITO" query-param="CUENTACREDITO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEBITO_BASE" query-param="DEBITO_BASE"/>
			<with-param name="CREDITO_BASE" query-param="CREDITO_BASE"/>
			<with-param name="CREDITO_IVA" query-param="CREDITO_IVA"/>
			<with-param name="DEBITO_IVA" query-param="DEBITO_IVA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAlmacenescontabilidadNumContabiliadadATransaccionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.CUENTADEBITO, ALMACENCONTABILIDAD.CUENTACREDITO, TIPOMOVIMIENTO.NOMBRE, ALMACENCONTABILIDAD.DEBITO_BASE, ALMACENCONTABILIDAD.CREDITO_BASE, ALMACENCONTABILIDAD.CREDITO_IVA, ALMACENCONTABILIDAD.DEBITO_IVA  FROM ALMACENCONTABILIDAD LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA AND ALMACENCONTABILIDAD.CODIGOELEMENTO = :CODIGOELEMENTO AND ALMACENCONTABILIDAD.ANO = :ANO ORDER BY ALMACENCONTABILIDAD.TIPOMOVIMIENTO) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER(:TIPOMOVIMIENTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END)  LIKE UPPER(:CUENTADEBITO || '%')  AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END)  LIKE UPPER(:CUENTACREDITO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEBITO_BASE IS NULL THEN ' ' ELSE UPPER(DEBITO_BASE) END)  LIKE UPPER(:DEBITO_BASE || '%')  AND (CASE WHEN CREDITO_BASE IS NULL THEN ' ' ELSE UPPER(CREDITO_BASE) END)  LIKE UPPER(:CREDITO_BASE || '%')  AND (CASE WHEN CREDITO_IVA IS NULL THEN ' ' ELSE UPPER(CREDITO_IVA) END)  LIKE UPPER(:CREDITO_IVA || '%')  AND (CASE WHEN DEBITO_IVA IS NULL THEN ' ' ELSE UPPER(DEBITO_IVA) END)  LIKE UPPER(:DEBITO_IVA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CUENTADEBITO" sqlType="STRING"/>
		<param name="CUENTACREDITO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEBITO_BASE" sqlType="STRING"/>
		<param name="CREDITO_BASE" sqlType="STRING"/>
		<param name="CREDITO_IVA" sqlType="STRING"/>
		<param name="DEBITO_IVA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="almacenescontabilidad/contabiliadadatransaccion/num">
		<call-query href="getAlmacenescontabilidadNumContabiliadadATransaccionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
