) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_ACUMULADA_BAJA, '%')) AND (CASE WHEN NIIF_CREDITO_ACUMULADA_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_ACUMULADA_BAJA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_ACUMULADA_BAJA, '%')) AND (CASE WHEN NIIF_DEBITO_LIBROS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_LIBROS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_LIBROS_BAJA, '%')) AND (CASE WHEN NIIF_CREDITO_LIBROS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_LIBROS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_LIBROS_BAJA, '%')) AND (CASE WHEN NIIF_DEBITO_RETIRADOS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_RETIRADOS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_RETIRADOS_BAJA, '%')) AND (CASE WHEN NIIF_CREDITO_RETIRADOS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_RETIRADOS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_RETIRADOS_BAJA, '%')) ) A) FIN</sql>
