	<query id="getAlmacenescontabilidadPagListaalmacenbajaniifQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.ANO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, TIPOMOVIMIENTO.NOMBRE, ALMACENCONTABILIDAD.NIIF_DEBITO_HISTORICO_BAJA, ALMACENCONTABILIDAD.NIIF_CREDITO_HISTORICO_BAJA, ALMACENCONTABILIDAD.NIIF_DEBITO_ACUMULADA_BAJA, ALMACENCONTABILIDAD.NIIF_CREDITO_ACUMULADA_BAJA, ALMACENCONTABILIDAD.NIIF_DEBITO_LIBROS_BAJA, ALMACENCONTABILIDAD.NIIF_CREDITO_LIBROS_BAJA, ALMACENCONTABILIDAD.NIIF_DEBITO_RETIRADOS_BAJA, ALMACENCONTABILIDAD.NIIF_CREDITO_RETIRADOS_BAJA FROM ALMACENCONTABILIDAD LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDAD.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO AND ALMACENCONTABILIDAD.COMPANIA = TIPOMOVIMIENTO.COMPANIA WHERE ALMACENCONTABILIDAD.COMPANIA = :COMPANIA AND ALMACENCONTABILIDAD.CODIGOELEMENTO= :CODIGOELEMENTO AND ALMACENCONTABILIDAD.ANO = :ANO AND (TIPOMOVIMIENTO.CONCEPTO IN ('CM','DS','L','DT','T') AND TIPOMOVIMIENTO.CLASE NOT IN ('E') OR ( TIPOMOVIMIENTO.CLASE NOT IN ( 'T','E' ) AND TIPOMOVIMIENTO.CONCEPTO NOT IN ( 'T' ,'II','N') )) ORDER BY ALMACENCONTABILIDAD.COMPANIA, ALMACENCONTABILIDAD.CODIGOELEMENTO, ALMACENCONTABILIDAD.TIPOMOVIMIENTO, ALMACENCONTABILIDAD.ANO, TIPOMOVIMIENTO.NOMBRE) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIIF_DEBITO_HISTORICO_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_HISTORICO_BAJA) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_HISTORICO_BAJA, '%')) AND (CASE WHEN NIIF_CREDITO_HISTORICO_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_HISTORICO_BAJA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_HISTORICO_BAJA, '%')) AND (CASE WHEN NIIF_DEBITO_ACUMULADA_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_ACUMULADA_BAJA) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_ACUMULADA_BAJA, '%')) AND (CASE WHEN NIIF_CREDITO_ACUMULADA_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_ACUMULADA_BAJA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_ACUMULADA_BAJA, '%')) AND (CASE WHEN NIIF_DEBITO_LIBROS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_LIBROS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_LIBROS_BAJA, '%')) AND (CASE WHEN NIIF_CREDITO_LIBROS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_LIBROS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_LIBROS_BAJA, '%')) AND (CASE WHEN NIIF_DEBITO_RETIRADOS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_RETIRADOS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_RETIRADOS_BAJA, '%')) AND (CASE WHEN NIIF_CREDITO_RETIRADOS_BAJA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_RETIRADOS_BAJA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_RETIRADOS_BAJA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","ANO":"$ANO(type:integer)","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","NOMBRE":"$NOMBRE","NIIF_DEBITO_HISTORICO_BAJA":"$NIIF_DEBITO_HISTORICO_BAJA","NIIF_CREDITO_HISTORICO_BAJA":"$NIIF_CREDITO_HISTORICO_BAJA","NIIF_DEBITO_ACUMULADA_BAJA":"$NIIF_DEBITO_ACUMULADA_BAJA","NIIF_CREDITO_ACUMULADA_BAJA":"$NIIF_CREDITO_ACUMULADA_BAJA","NIIF_DEBITO_LIBROS_BAJA":"$NIIF_DEBITO_LIBROS_BAJA","NIIF_CREDITO_LIBROS_BAJA":"$NIIF_CREDITO_LIBROS_BAJA","NIIF_DEBITO_RETIRADOS_BAJA":"$NIIF_DEBITO_RETIRADOS_BAJA","NIIF_CREDITO_RETIRADOS_BAJA":"$NIIF_CREDITO_RETIRADOS_BAJA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIIF_DEBITO_HISTORICO_BAJA" sqlType="STRING"/>
		<param name="NIIF_CREDITO_HISTORICO_BAJA" sqlType="STRING"/>
		<param name="NIIF_DEBITO_ACUMULADA_BAJA" sqlType="STRING"/>
		<param name="NIIF_CREDITO_ACUMULADA_BAJA" sqlType="STRING"/>
		<param name="NIIF_DEBITO_LIBROS_BAJA" sqlType="STRING"/>
		<param name="NIIF_CREDITO_LIBROS_BAJA" sqlType="STRING"/>
		<param name="NIIF_DEBITO_RETIRADOS_BAJA" sqlType="STRING"/>
