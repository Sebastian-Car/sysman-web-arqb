<data name="sfacuerdopago" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfacuerdopagoOrigendatosconsultaapQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_ACUERDO_PAGO.COMPANIA, SF_ACUERDO_PAGO.TIPO, SF_ACUERDO_PAGO.CODIGO, SF_ACUERDO_PAGO.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, SF_ACUERDO_PAGO.CENTRO_COSTO, CENTRO_COSTO.NOMBRE NOMBRECENTRO, SF_ACUERDO_PAGO.AUXILIAR, AUXILIAR.NOMBRE NOMBREAUXILIAR,(TO_CHAR(SF_ACUERDO_PAGO.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_ACUERDO_PAGO.FECHA_FIN,'DD/MM/YYYY HH24:MI:SS')) FECHA_FIN, SF_DETALLE_ACUERDO.ESTADO, SF_ACUERDO_PAGO.DEUDA_CAPITAL, SF_ACUERDO_PAGO.DEUDA_INTERES, SF_ACUERDO_PAGO.DEUDA_TOTAL, SF_ACUERDO_PAGO.TASA_INTERES,(CASE SF_ACUERDO_PAGO.APLICACONDONACION WHEN 0 THEN 'false' ELSE 'true' END) APLICACONDONACION, SF_ACUERDO_PAGO.CONDONACION, SF_ACUERDO_PAGO.OBSERVACION_CONDONACION, SF_ACUERDO_PAGO.CREATED_BY,(TO_CHAR(SF_ACUERDO_PAGO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_ACUERDO_PAGO.MODIFIED_BY,(TO_CHAR(SF_ACUERDO_PAGO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SF_TIPO_COBRO.FORMATO_PLANTILLA FROM SF_ACUERDO_PAGO INNER JOIN SF_DETALLE_ACUERDO ON SF_ACUERDO_PAGO.COMPANIA = SF_DETALLE_ACUERDO.COMPANIA AND SF_ACUERDO_PAGO.TIPO = SF_DETALLE_ACUERDO.TIPO_AP AND SF_ACUERDO_PAGO.CODIGO = SF_DETALLE_ACUERDO.CODIGO_AP INNER JOIN TERCERO ON SF_ACUERDO_PAGO.COMPANIA = TERCERO.COMPANIA AND SF_ACUERDO_PAGO.TERCERO = TERCERO.NIT AND SF_ACUERDO_PAGO.SUCURSAL = TERCERO.SUCURSAL INNER JOIN CENTRO_COSTO ON SF_ACUERDO_PAGO.COMPANIA = CENTRO_COSTO.COMPANIA AND EXTRACT(YEAR FROM SF_ACUERDO_PAGO.DATE_CREATED) = CENTRO_COSTO.ANO AND SF_ACUERDO_PAGO.CENTRO_COSTO = CENTRO_COSTO.CODIGO INNER JOIN AUXILIAR ON SF_ACUERDO_PAGO.COMPANIA = AUXILIAR.COMPANIA AND EXTRACT(YEAR FROM SF_ACUERDO_PAGO.DATE_CREATED) = AUXILIAR.ANO AND SF_ACUERDO_PAGO.AUXILIAR = AUXILIAR.CODIGO INNER JOIN SF_TIPO_COBRO ON SF_ACUERDO_PAGO.COMPANIA = SF_TIPO_COBRO.COMPANIA AND SF_ACUERDO_PAGO.TIPO = SF_TIPO_COBRO.CODIGO AND EXTRACT(YEAR FROM SF_ACUERDO_PAGO.DATE_CREATED) = SF_TIPO_COBRO.ANO WHERE SF_ACUERDO_PAGO.COMPANIA = :KEY_COMPANIA AND SF_ACUERDO_PAGO.TIPO = :KEY_TIPO AND SF_ACUERDO_PAGO.CODIGO = :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","CODIGO":"$CODIGO(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRECENTRO":"$NOMBRECENTRO","AUXILIAR":"$AUXILIAR","NOMBREAUXILIAR":"$NOMBREAUXILIAR","FECHA_INICIO":"$FECHA_INICIO","FECHA_FIN":"$FECHA_FIN","ESTADO":"$ESTADO","DEUDA_CAPITAL":"$DEUDA_CAPITAL","DEUDA_INTERES":"$DEUDA_INTERES","DEUDA_TOTAL":"$DEUDA_TOTAL","TASA_INTERES":"$TASA_INTERES","APLICACONDONACION":"$APLICACONDONACION(type:boolean)","CONDONACION":"$CONDONACION","OBSERVACION_CONDONACION":"$OBSERVACION_CONDONACION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","FORMATO_PLANTILLA":"$FORMATO_PLANTILLA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfacuerdopago/origendatosconsultaap">
		<call-query href="getSfacuerdopagoOrigendatosconsultaapQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSfacuerdopagoPagOrigengrillaconsultaapQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_ACUERDO_PAGO.COMPANIA, SF_ACUERDO_PAGO.TIPO, SF_ACUERDO_PAGO.CODIGO, SF_ACUERDO_PAGO.TERCERO, TERCERO.NOMBRE NOMBRETERCERO,(TO_CHAR(SF_ACUERDO_PAGO.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO, DECODE(SF_ACUERDO_PAGO.ESTADO,'A','ACTIVO','C','CANCELADO',' ') ESTADO  FROM SF_ACUERDO_PAGO INNER JOIN TERCERO ON SF_ACUERDO_PAGO.COMPANIA = TERCERO.COMPANIA AND SF_ACUERDO_PAGO.TERCERO = TERCERO.NIT AND SF_ACUERDO_PAGO.SUCURSAL = TERCERO.SUCURSAL WHERE SF_ACUERDO_PAGO.COMPANIA = :COMPANIA AND SF_ACUERDO_PAGO.TIPO = :TIPOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER( '%' || :TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","CODIGO":"$CODIGO(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","FECHA_INICIO":"$FECHA_INICIO","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfacuerdopago/origengrillaconsultaap/pag">
		<call-query href="getSfacuerdopagoPagOrigengrillaconsultaapQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfacuerdopagoNumOrigengrillaconsultaapQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_ACUERDO_PAGO.COMPANIA, SF_ACUERDO_PAGO.TIPO, SF_ACUERDO_PAGO.CODIGO, SF_ACUERDO_PAGO.TERCERO, TERCERO.NOMBRE NOMBRETERCERO,(TO_CHAR(SF_ACUERDO_PAGO.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO, DECODE(SF_ACUERDO_PAGO.ESTADO,'A','ACTIVO','C','CANCELADO',' ') ESTADO  FROM SF_ACUERDO_PAGO INNER JOIN TERCERO ON SF_ACUERDO_PAGO.COMPANIA = TERCERO.COMPANIA AND SF_ACUERDO_PAGO.TERCERO = TERCERO.NIT AND SF_ACUERDO_PAGO.SUCURSAL = TERCERO.SUCURSAL WHERE SF_ACUERDO_PAGO.COMPANIA = :COMPANIA AND SF_ACUERDO_PAGO.TIPO = :TIPOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER( '%' || :TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfacuerdopago/origengrillaconsultaap/num">
		<call-query href="getSfacuerdopagoNumOrigengrillaconsultaapQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>

</data>