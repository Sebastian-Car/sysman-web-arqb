			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasNumIdNombreSucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IDEVENTO, NOMBREEVENTO,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL FROM NAT_ACTIVIDADESPROGRAMADAS WHERE COMPANIA = :COMPANIA AND TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER( '%' || :NOMBREEVENTO || '%')  AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER(:FECHAINICIAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/idnombresucursal/num">
		<call-query href="getNatactividadesprogramadasNumIdNombreSucursalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="NOMBREEVENTO" query-param="NOMBREEVENTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>

		</call-query>
	</resource>

</data>