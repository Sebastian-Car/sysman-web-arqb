<data name="natactividadesprogramadas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatactividadesprogramadasPagIdNombreEventoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IDEVENTO, NOMBREEVENTO, TIPOEVENTO,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL FROM NAT_ACTIVIDADESPROGRAMADAS WHERE COMPANIA = :COMPANIA AND TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER( '%' || :NOMBREEVENTO || '%')  AND (CASE WHEN TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(TIPOEVENTO) END)  LIKE UPPER(:TIPOEVENTO || '%')  AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER(:FECHAINICIAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDEVENTO":"$IDEVENTO","NOMBREEVENTO":"$NOMBREEVENTO","TIPOEVENTO":"$TIPOEVENTO","FECHAINICIAL":"$FECHAINICIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/idnombreevento/pag">
		<call-query href="getNatactividadesprogramadasPagIdNombreEventoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="NOMBREEVENTO" query-param="NOMBREEVENTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasNumIdNombreEventoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IDEVENTO, NOMBREEVENTO, TIPOEVENTO,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL FROM NAT_ACTIVIDADESPROGRAMADAS WHERE COMPANIA = :COMPANIA AND TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER( '%' || :NOMBREEVENTO || '%')  AND (CASE WHEN TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(TIPOEVENTO) END)  LIKE UPPER(:TIPOEVENTO || '%')  AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER(:FECHAINICIAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/idnombreevento/num">
		<call-query href="getNatactividadesprogramadasNumIdNombreEventoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="NOMBREEVENTO" query-param="NOMBREEVENTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasPagTipoynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  AP.IDEVENTO, AP.TIPOEVENTO, AP.NOMBREEVENTO, TIAC.NOMBRE NOMBRE_TIPOEVENTO  FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_TIPOACTIVIDADES TIAC ON TIAC.COMPANIA = AP.COMPANIA AND TIAC.CODIGO = AP.TIPOEVENTO WHERE AP.COMPANIA = :COMPANIA AND AP.TIPOEVENTO = :TIPO_EVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER(:NOMBREEVENTO || '%')  AND (CASE WHEN NOMBRE_TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOEVENTO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOEVENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","NOMBREEVENTO":"$NOMBREEVENTO","NOMBRE_TIPOEVENTO":"$NOMBRE_TIPOEVENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_EVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOEVENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/tipoynombre/pag">
		<call-query href="getNatactividadesprogramadasPagTipoynombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_EVENTO" query-param="TIPO_EVENTO"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="NOMBREEVENTO" query-param="NOMBREEVENTO"/>
			<with-param name="NOMBRE_TIPOEVENTO" query-param="NOMBRE_TIPOEVENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasNumTipoynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  AP.IDEVENTO, AP.TIPOEVENTO, AP.NOMBREEVENTO, TIAC.NOMBRE NOMBRE_TIPOEVENTO  FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_TIPOACTIVIDADES TIAC ON TIAC.COMPANIA = AP.COMPANIA AND TIAC.CODIGO = AP.TIPOEVENTO WHERE AP.COMPANIA = :COMPANIA AND AP.TIPOEVENTO = :TIPO_EVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER(:NOMBREEVENTO || '%')  AND (CASE WHEN NOMBRE_TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOEVENTO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOEVENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_EVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOEVENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/tipoynombre/num">
		<call-query href="getNatactividadesprogramadasNumTipoynombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_EVENTO" query-param="TIPO_EVENTO"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="NOMBREEVENTO" query-param="NOMBREEVENTO"/>
			<with-param name="NOMBRE_TIPOEVENTO" query-param="NOMBRE_TIPOEVENTO"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasPagDctoynombreybeneficiariocalifiQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  AI.NUMERO_DCTO, F.NOMBRE,(CASE AI.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL  FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN FAMILIARES F ON F.COMPANIA =AI.COMPANIA AND AI.NUMERO_DCTO = F.IDENTIFICACION WHERE AI.BENEFICIARIO NOT IN (0) AND AP.COMPANIA = :COMPANIA UNION SELECT AI.NUMERO_DCTO, DP.NOMBRES, (CASE AI.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN NAT_DATOS_PERSONALES DP ON AI.COMPANIA = DP.COMPANIA AND AI.NUMERO_DCTO = DP.NUMERO_DCTO WHERE AI.BENEFICIARIO IN (0) AND AP.COMPANIA = :COMPANIA) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END)  LIKE UPPER( '%' || :BENEFICIARIO || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","BENEFICIARIO":"$BENEFICIARIO(type:boolean)","CALIFICACION":"$CALIFICACION(type:integer)","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/dctoynombreybeneficiariocalifi/pag">
		<call-query href="getNatactividadesprogramadasPagDctoynombreybeneficiariocalifiQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasNumDctoynombreybeneficiariocalifiQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  AI.NUMERO_DCTO, F.NOMBRE,(CASE AI.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL  FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN FAMILIARES F ON F.COMPANIA =AI.COMPANIA AND AI.NUMERO_DCTO = F.IDENTIFICACION WHERE AI.BENEFICIARIO NOT IN (0) AND AP.COMPANIA = :COMPANIA UNION SELECT AI.NUMERO_DCTO, DP.NOMBRES, (CASE AI.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN NAT_DATOS_PERSONALES DP ON AI.COMPANIA = DP.COMPANIA AND AI.NUMERO_DCTO = DP.NUMERO_DCTO WHERE AI.BENEFICIARIO IN (0) AND AP.COMPANIA = :COMPANIA) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END)  LIKE UPPER( '%' || :BENEFICIARIO || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/dctoynombreybeneficiariocalifi/num">
		<call-query href="getNatactividadesprogramadasNumDctoynombreybeneficiariocalifiQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasPagDctonombrebeneficiarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO_DCTO, NOMBRE,(CASE BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, CALIFICACION, SUCURSAL FROM ( SELECT AI.NUMERO_DCTO, CONCAT(F.NOMBRE,CONCAT(' ',CONCAT(F.APELLIDO1,CONCAT(' ',F.APELLIDO2) ) ) ) NOMBRE, AI.BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN FAMILIARES F ON F.COMPANIA = AI.COMPANIA AND AI.NUMERO_DCTO = F.IDENTIFICACION WHERE AI.BENEFICIARIO NOT IN (0) AND AP.COMPANIA =:COMPANIA AND AI.IDEVENTO =:IDEVENTO UNION SELECT AI.NUMERO_DCTO, CONCAT(DP.NOMBRES,CONCAT(' ',CONCAT(DP.APELLIDO1,CONCAT(' ',DP.APELLIDO2) ) ) ) NOMBRE, AI.BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN NAT_DATOS_PERSONALES DP ON AI.COMPANIA = DP.COMPANIA AND AI.NUMERO_DCTO = DP.NUMERO_DCTO WHERE AI.BENEFICIARIO IN (0) AND AP.COMPANIA =:COMPANIA AND AI.IDEVENTO =:IDEVENTO )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:BENEFICIARIO), '%')) AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END) LIKE UPPER(CONCAT(:CALIFICACION, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","BENEFICIARIO":"$BENEFICIARIO(type:boolean)","CALIFICACION":"$CALIFICACION(type:integer)","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/dctonombrebeneficiario/pag">
		<call-query href="getNatactividadesprogramadasPagDctonombrebeneficiarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasNumDctonombrebeneficiarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUMERO_DCTO, NOMBRE,(CASE BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, CALIFICACION, SUCURSAL FROM ( SELECT AI.NUMERO_DCTO, CONCAT(F.NOMBRE,CONCAT(' ',CONCAT(F.APELLIDO1,CONCAT(' ',F.APELLIDO2) ) ) ) NOMBRE, AI.BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN FAMILIARES F ON F.COMPANIA = AI.COMPANIA AND AI.NUMERO_DCTO = F.IDENTIFICACION WHERE AI.BENEFICIARIO NOT IN (0) AND AP.COMPANIA =:COMPANIA AND AI.IDEVENTO =:IDEVENTO UNION SELECT AI.NUMERO_DCTO, CONCAT(DP.NOMBRES,CONCAT(' ',CONCAT(DP.APELLIDO1,CONCAT(' ',DP.APELLIDO2) ) ) ) NOMBRE, AI.BENEFICIARIO, AI.CALIFICACION, AI.SUCURSAL FROM NAT_ACTIVIDADESPROGRAMADAS AP INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AP.COMPANIA = AI.COMPANIA AND AP.IDEVENTO = AI.IDEVENTO AND AP.TIPOEVENTO = AI.TIPOEVENTO AND AP.FECHAINICIAL = AI.FECHAINICIAL INNER JOIN NAT_DATOS_PERSONALES DP ON AI.COMPANIA = DP.COMPANIA AND AI.NUMERO_DCTO = DP.NUMERO_DCTO WHERE AI.BENEFICIARIO IN (0) AND AP.COMPANIA =:COMPANIA AND AI.IDEVENTO =:IDEVENTO )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:BENEFICIARIO), '%')) AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END) LIKE UPPER(CONCAT(:CALIFICACION, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natactividadesprogramadas/dctonombrebeneficiario/num">
		<call-query href="getNatactividadesprogramadasNumDctonombrebeneficiarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
