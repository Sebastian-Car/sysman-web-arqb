	<query id="updateNatactividadesprogramadas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_ACTIVIDADESPROGRAMADAS SET IDEVENTO=:IDEVENTO, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), NOMBREEVENTO=:NOMBREEVENTO, NUMEROHORAS=:NUMEROHORAS, FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA=:DEPENDENCIA, ESCALAFON=:ESCALAFON, ENTIDAD=:ENTIDAD, NUMERODOCUMENTO=:NUMERODOCUMENTO, SUCURSAL=:SUCURSAL, TIPODOCUMENTO=:TIPODOCUMENTO, NUMEROAPROBACIONCOMITE=:NUMEROAPROBACIONCOMITE, NIVELPROFESIONAL=:NIVELPROFESIONAL, AREA=:AREA, FECHAAPROBACIONCOMITE=TO_DATE(:FECHAAPROBACIONCOMITE,'DD/MM/YYYY HH24:MI:SS'), COORDEVENTO=:COORDEVENTO, SUCURSALCOOR=:SUCURSALCOOR, ESTADO=:ESTADO, NUMEROCUPOS=:NUMEROCUPOS, NITESTABLECIMIENTO=:NITESTABLECIMIENTO, VALOR=:VALOR, DIRECCIONEVENTO=:DIRECCIONEVENTO, HORARIO=:HORARIO, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_ACTIVIDADESPROGRAMADAS.COMPANIA= :KEY_COMPANIA AND NAT_ACTIVIDADESPROGRAMADAS.IDEVENTO= :KEY_IDEVENTO AND NAT_ACTIVIDADESPROGRAMADAS.TIPOEVENTO= :KEY_TIPOEVENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

