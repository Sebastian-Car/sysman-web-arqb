	<query id="insertNatactividadesprogramadas" keyColumns="COMPANIA,IDEVENTO,TIPOEVENTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_ACTIVIDADESPROGRAMADAS (COMPANIA, IDEVENTO, TIPOEVENTO, FECHAINICIAL, NOMBREEVENTO, NUMEROHORAS, FECHAFINAL, ENTIDAD, NUMERODOCUMENTO, SUCURSAL, TIPODOCUMENTO, NUMEROAPROBACIONCOMITE, NIVELPROFESIONAL, AREA, FECHAAPROBACIONCOMITE, COORDEVENTO, DEPENDENCIA, ESCALAFON, SUCURSALCOOR, ESTADO, NUMEROCUPOS, NITESTABLECIMIENTO, VALOR, DIRECCIONEVENTO, HORARIO, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :IDEVENTO, :TIPOEVENTO, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), :NOMBREEVENTO, :NUMEROHORAS, TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), :ENTIDAD, :NUMERODOCUMENTO, :SUCURSAL, :TIPODOCUMENTO, :NUMEROAPROBACIONCOMITE, :NIVELPROFESIONAL, :AREA, TO_DATE(:FECHAAPROBACIONCOMITE,'DD/MM/YYYY HH24:MI:SS'), :COORDEVENTO, :DEPENDENCIA, :ESCALAFON, :SUCURSALCOOR, :ESTADO, :NUMEROCUPOS, :NITESTABLECIMIENTO, :VALOR, :DIRECCIONEVENTO, :HORARIO, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDEVENTO":"$IDEVENTO","KEY_TIPOEVENTO":"$TIPOEVENTO"}]}}		</result>
