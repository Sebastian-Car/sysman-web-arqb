	<query id="getNatactividadesprogramadasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , IDEVENTO , TIPOEVENTO,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, NOMBREEVENTO , NUMEROHORAS  FROM NAT_ACTIVIDADESPROGRAMADAS WHERE COMPANIA = :COMPANIA AND TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER( '%' || :FECHAINICIAL || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER( '%' || :NOMBREEVENTO || '%')  AND (CASE WHEN NUMEROHORAS IS NULL THEN ' ' ELSE UPPER(NUMEROHORAS) END)  LIKE UPPER(:NUMEROHORAS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="NUMEROHORAS" sqlType="STRING"/>

	</query>
