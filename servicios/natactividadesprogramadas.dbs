	<query id="getNatactividadesprogramadasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_ACTIVIDADESPROGRAMADAS.COMPANIA , TERCERO.NOMBRE, NAT_ACTIVIDADESPROGRAMADAS.IDEVENTO , NAT_ACTIVIDADESPROGRAMADAS.TIPOEVENTO ,(TO_CHAR(NAT_ACTIVIDADESPROGRAMADAS.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, NAT_ACTIVIDADESPROGRAMADAS.NOMBREEVENTO , NAT_ACTIVIDADESPROGRAMADAS.NUMEROHORAS ,(TO_CHAR(NAT_ACTIVIDADESPROGRAMADAS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, NAT_ACTIVIDADESPROGRAMADAS.ENTIDAD , NAT_ACTIVIDADESPROGRAMADAS.NUMERODOCUMENTO , NAT_ACTIVIDADESPROGRAMADAS.SUCURSAL , NAT_ACTIVIDADESPROGRAMADAS.TIPODOCUMENTO , NAT_ACTIVIDADESPROGRAMADAS.NUMEROAPROBACIONCOMITE , NAT_ACTIVIDADESPROGRAMADAS.NIVELPROFESIONAL , NAT_ACTIVIDADESPROGRAMADAS.AREA ,(TO_CHAR(NAT_ACTIVIDADESPROGRAMADAS.FECHAAPROBACIONCOMITE,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONCOMITE, NAT_ACTIVIDADESPROGRAMADAS.COORDEVENTO , NAT_ACTIVIDADESPROGRAMADAS.SUCURSALCOOR , NAT_ACTIVIDADESPROGRAMADAS.ESTADO , NAT_ACTIVIDADESPROGRAMADAS.NUMEROCUPOS , NAT_ACTIVIDADESPROGRAMADAS.NITESTABLECIMIENTO , NAT_ACTIVIDADESPROGRAMADAS.VALOR , NAT_ACTIVIDADESPROGRAMADAS.ESCALAFON, ESCALAFON.NOMBRE AS NOMBREES, NAT_ACTIVIDADESPROGRAMADAS.DEPENDENCIA, DEPENDENCIA.NOMBRE AS NOMBREDEP, NAT_ACTIVIDADESPROGRAMADAS.DIRECCIONEVENTO , NAT_ACTIVIDADESPROGRAMADAS.HORARIO , NAT_ACTIVIDADESPROGRAMADAS.OBSERVACIONES ,(TO_CHAR(NAT_ACTIVIDADESPROGRAMADAS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(NAT_ACTIVIDADESPROGRAMADAS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, NAT_ACTIVIDADESPROGRAMADAS.CREATED_BY , NAT_ACTIVIDADESPROGRAMADAS.MODIFIED_BY  FROM NAT_ACTIVIDADESPROGRAMADAS INNER JOIN TERCERO ON NAT_ACTIVIDADESPROGRAMADAS.COMPANIA = TERCERO.COMPANIA AND NAT_ACTIVIDADESPROGRAMADAS.COORDEVENTO = TERCERO.NIT AND NAT_ACTIVIDADESPROGRAMADAS.SUCURSALCOOR = TERCERO.SUCURSAL LEFT JOIN DEPENDENCIA ON NAT_ACTIVIDADESPROGRAMADAS.COMPANIA = DEPENDENCIA.COMPANIA AND NAT_ACTIVIDADESPROGRAMADAS.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN ESCALAFON ON NAT_ACTIVIDADESPROGRAMADAS.COMPANIA = ESCALAFON.COMPANIA AND NAT_ACTIVIDADESPROGRAMADAS.ESCALAFON = ESCALAFON.CODIGO WHERE NAT_ACTIVIDADESPROGRAMADAS.COMPANIA= :KEY_COMPANIA AND NAT_ACTIVIDADESPROGRAMADAS.IDEVENTO= :KEY_IDEVENTO AND NAT_ACTIVIDADESPROGRAMADAS.TIPOEVENTO= :KEY_TIPOEVENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NOMBRE":"$NOMBRE","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","FECHAINICIAL":"$FECHAINICIAL","NOMBREEVENTO":"$NOMBREEVENTO","NUMEROHORAS":"$NUMEROHORAS(type:integer)","FECHAFINAL":"$FECHAFINAL","ENTIDAD":"$ENTIDAD","NUMERODOCUMENTO":"$NUMERODOCUMENTO","SUCURSAL":"$SUCURSAL","TIPODOCUMENTO":"$TIPODOCUMENTO","NUMEROAPROBACIONCOMITE":"$NUMEROAPROBACIONCOMITE","NIVELPROFESIONAL":"$NIVELPROFESIONAL","AREA":"$AREA","FECHAAPROBACIONCOMITE":"$FECHAAPROBACIONCOMITE","COORDEVENTO":"$COORDEVENTO","SUCURSALCOOR":"$SUCURSALCOOR","ESTADO":"$ESTADO","NUMEROCUPOS":"$NUMEROCUPOS(type:integer)","NITESTABLECIMIENTO":"$NITESTABLECIMIENTO","VALOR":"$VALOR","ESCALAFON":"$ESCALAFON","NOMBREES":"$NOMBREES","DEPENDENCIA":"$DEPENDENCIA","NOMBREDEP":"$NOMBREDEP","DIRECCIONEVENTO":"$DIRECCIONEVENTO","HORARIO":"$HORARIO","OBSERVACIONES":"$OBSERVACIONES","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>

	</query>
