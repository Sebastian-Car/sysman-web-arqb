			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatactividadesprogramadasPagIdNombreSucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IDEVENTO, NOMBREEVENTO,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL FROM NAT_ACTIVIDADESPROGRAMADAS WHERE COMPANIA = :COMPANIA AND TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER( '%' || :NOMBREEVENTO || '%')  AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER(:FECHAINICIAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDEVENTO":"$IDEVENTO","NOMBREEVENTO":"$NOMBREEVENTO","FECHAINICIAL":"$FECHAINICIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
