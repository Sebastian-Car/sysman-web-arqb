	<query id="getNatactividadesprogramadasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , IDEVENTO , TIPOEVENTO,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, NOMBREEVENTO , NUMEROHORAS  FROM NAT_ACTIVIDADESPROGRAMADAS WHERE COMPANIA = :COMPANIA AND TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END)  LIKE UPPER(:IDEVENTO || '%')  AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER( '%' || :FECHAINICIAL || '%')  AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END)  LIKE UPPER( '%' || :NOMBREEVENTO || '%')  AND (CASE WHEN NUMEROHORAS IS NULL THEN ' ' ELSE UPPER(NUMEROHORAS) END)  LIKE UPPER(:NUMEROHORAS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","FECHAINICIAL":"$FECHAINICIAL","NOMBREEVENTO":"$NOMBREEVENTO","NUMEROHORAS":"$NUMEROHORAS(type:integer)"}]}}		</result>
