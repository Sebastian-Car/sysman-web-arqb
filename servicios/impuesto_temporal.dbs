<data name="impuesto_temporal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertImpuesto_temporal" keyColumns="COMPANIA,ANO,LIMITE_INFERIOR,LIMITE_SUPERIOR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IMPUESTO_TEMPORAL (COMPANIA, ANO, LIMITE_INFERIOR, LIMITE_SUPERIOR, TARIFA, DESCRIPCION, OBLIGATORIO, VALOR_EXENTO, VALOR_A_ADICIONAR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :LIMITE_INFERIOR, :LIMITE_SUPERIOR, :TARIFA, :DESCRIPCION, :OBLIGATORIO, :VALOR_EXENTO, :VALOR_A_ADICIONAR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_LIMITE_INFERIOR":"$LIMITE_INFERIOR","KEY_LIMITE_SUPERIOR":"$LIMITE_SUPERIOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="0" name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param defaultValue="0" name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param defaultValue="0" name="TARIFA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGATORIO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_EXENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_A_ADICIONAR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="impuesto_temporal">
		<call-query href="insertImpuesto_temporal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="VALOR_EXENTO" query-param="VALOR_EXENTO"/>
			<with-param name="VALOR_A_ADICIONAR" query-param="VALOR_A_ADICIONAR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteImpuesto_temporal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IMPUESTO_TEMPORAL WHERE IMPUESTO_TEMPORAL.COMPANIA= :KEY_COMPANIA AND IMPUESTO_TEMPORAL.ANO= :KEY_ANO AND IMPUESTO_TEMPORAL.LIMITE_INFERIOR= :KEY_LIMITE_INFERIOR AND IMPUESTO_TEMPORAL.LIMITE_SUPERIOR= :KEY_LIMITE_SUPERIOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="KEY_LIMITE_SUPERIOR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="impuesto_temporal">
		<call-query href="deleteImpuesto_temporal">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_LIMITE_INFERIOR" query-param="KEY_LIMITE_INFERIOR"/>
			<with-param name="KEY_LIMITE_SUPERIOR" query-param="KEY_LIMITE_SUPERIOR"/>

		</call-query>
	</resource>
	<query id="getImpuesto_temporalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, LIMITE_INFERIOR, LIMITE_SUPERIOR, TARIFA, DESCRIPCION,(CASE OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGATORIO, VALOR_EXENTO, VALOR_A_ADICIONAR FROM IMPUESTO_TEMPORAL WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC, LIMITE_INFERIOR DESC, LIMITE_SUPERIOR DESC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN LIMITE_INFERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_INFERIOR) END) LIKE UPPER(CONCAT(:LIMITE_INFERIOR, '%')) AND (CASE WHEN LIMITE_SUPERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_SUPERIOR) END) LIKE UPPER(CONCAT(:LIMITE_SUPERIOR, '%')) AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END) LIKE UPPER(CONCAT(:TARIFA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN OBLIGATORIO IS NULL THEN ' ' ELSE UPPER(OBLIGATORIO) END) LIKE UPPER(CONCAT(:OBLIGATORIO, '%')) AND (CASE WHEN VALOR_EXENTO IS NULL THEN ' ' ELSE UPPER(VALOR_EXENTO) END) LIKE UPPER(CONCAT(:VALOR_EXENTO, '%')) AND (CASE WHEN VALOR_A_ADICIONAR IS NULL THEN ' ' ELSE UPPER(VALOR_A_ADICIONAR) END) LIKE UPPER(CONCAT(:VALOR_A_ADICIONAR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","LIMITE_INFERIOR":"$LIMITE_INFERIOR","LIMITE_SUPERIOR":"$LIMITE_SUPERIOR","TARIFA":"$TARIFA(type:integer)","DESCRIPCION":"$DESCRIPCION","OBLIGATORIO":"$OBLIGATORIO(type:boolean)","VALOR_EXENTO":"$VALOR_EXENTO","VALOR_A_ADICIONAR":"$VALOR_A_ADICIONAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="OBLIGATORIO" sqlType="STRING"/>
		<param name="VALOR_EXENTO" sqlType="STRING"/>
		<param name="VALOR_A_ADICIONAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="impuesto_temporal">
		<call-query href="getImpuesto_temporalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="VALOR_EXENTO" query-param="VALOR_EXENTO"/>
			<with-param name="VALOR_A_ADICIONAR" query-param="VALOR_A_ADICIONAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getImpuesto_temporalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, LIMITE_INFERIOR, LIMITE_SUPERIOR, TARIFA, DESCRIPCION,(CASE OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGATORIO, VALOR_EXENTO, VALOR_A_ADICIONAR FROM IMPUESTO_TEMPORAL WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC, LIMITE_INFERIOR DESC, LIMITE_SUPERIOR DESC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN LIMITE_INFERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_INFERIOR) END) LIKE UPPER(CONCAT(:LIMITE_INFERIOR, '%')) AND (CASE WHEN LIMITE_SUPERIOR IS NULL THEN ' ' ELSE UPPER(LIMITE_SUPERIOR) END) LIKE UPPER(CONCAT(:LIMITE_SUPERIOR, '%')) AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END) LIKE UPPER(CONCAT(:TARIFA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN OBLIGATORIO IS NULL THEN ' ' ELSE UPPER(OBLIGATORIO) END) LIKE UPPER(CONCAT(:OBLIGATORIO, '%')) AND (CASE WHEN VALOR_EXENTO IS NULL THEN ' ' ELSE UPPER(VALOR_EXENTO) END) LIKE UPPER(CONCAT(:VALOR_EXENTO, '%')) AND (CASE WHEN VALOR_A_ADICIONAR IS NULL THEN ' ' ELSE UPPER(VALOR_A_ADICIONAR) END) LIKE UPPER(CONCAT(:VALOR_A_ADICIONAR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="OBLIGATORIO" sqlType="STRING"/>
		<param name="VALOR_EXENTO" sqlType="STRING"/>
		<param name="VALOR_A_ADICIONAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="impuesto_temporal/numero">
		<call-query href="getImpuesto_temporalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="VALOR_EXENTO" query-param="VALOR_EXENTO"/>
			<with-param name="VALOR_A_ADICIONAR" query-param="VALOR_A_ADICIONAR"/>

		</call-query>
	</resource>
	<query id="getImpuesto_temporalRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, LIMITE_INFERIOR, LIMITE_SUPERIOR, TARIFA, DESCRIPCION,(CASE OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGATORIO, VALOR_EXENTO, VALOR_A_ADICIONAR FROM IMPUESTO_TEMPORAL WHERE IMPUESTO_TEMPORAL.COMPANIA= :KEY_COMPANIA AND IMPUESTO_TEMPORAL.ANO= :KEY_ANO AND IMPUESTO_TEMPORAL.LIMITE_INFERIOR= :KEY_LIMITE_INFERIOR AND IMPUESTO_TEMPORAL.LIMITE_SUPERIOR= :KEY_LIMITE_SUPERIOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","LIMITE_INFERIOR":"$LIMITE_INFERIOR","LIMITE_SUPERIOR":"$LIMITE_SUPERIOR","TARIFA":"$TARIFA(type:integer)","DESCRIPCION":"$DESCRIPCION","OBLIGATORIO":"$OBLIGATORIO(type:boolean)","VALOR_EXENTO":"$VALOR_EXENTO","VALOR_A_ADICIONAR":"$VALOR_A_ADICIONAR"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="KEY_LIMITE_SUPERIOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="impuesto_temporal/data">
		<call-query href="getImpuesto_temporalRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_LIMITE_INFERIOR" query-param="KEY_LIMITE_INFERIOR"/>
			<with-param name="KEY_LIMITE_SUPERIOR" query-param="KEY_LIMITE_SUPERIOR"/>

		</call-query>
	</resource>
	<query id="updateImpuesto_temporal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IMPUESTO_TEMPORAL SET COMPANIA=:COMPANIA, ANO=:ANO, LIMITE_INFERIOR=:LIMITE_INFERIOR, LIMITE_SUPERIOR=:LIMITE_SUPERIOR, TARIFA=:TARIFA, DESCRIPCION=:DESCRIPCION, OBLIGATORIO=:OBLIGATORIO, VALOR_EXENTO=:VALOR_EXENTO, VALOR_A_ADICIONAR=:VALOR_A_ADICIONAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IMPUESTO_TEMPORAL.COMPANIA= :KEY_COMPANIA AND IMPUESTO_TEMPORAL.ANO= :KEY_ANO AND IMPUESTO_TEMPORAL.LIMITE_INFERIOR= :KEY_LIMITE_INFERIOR AND IMPUESTO_TEMPORAL.LIMITE_SUPERIOR= :KEY_LIMITE_SUPERIOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="LIMITE_SUPERIOR" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="OBLIGATORIO" sqlType="STRING"/>
		<param name="VALOR_EXENTO" sqlType="STRING"/>
		<param name="VALOR_A_ADICIONAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_LIMITE_INFERIOR" sqlType="STRING"/>
		<param name="KEY_LIMITE_SUPERIOR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="impuesto_temporal">
		<call-query href="updateImpuesto_temporal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="LIMITE_INFERIOR" query-param="LIMITE_INFERIOR"/>
			<with-param name="LIMITE_SUPERIOR" query-param="LIMITE_SUPERIOR"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="VALOR_EXENTO" query-param="VALOR_EXENTO"/>
			<with-param name="VALOR_A_ADICIONAR" query-param="VALOR_A_ADICIONAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_LIMITE_INFERIOR" query-param="KEY_LIMITE_INFERIOR"/>
			<with-param name="KEY_LIMITE_SUPERIOR" query-param="KEY_LIMITE_SUPERIOR"/>

		</call-query>
	</resource>

</data>