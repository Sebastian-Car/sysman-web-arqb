<data name="natmodalidadestudios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatmodalidadestudiosOtrosEstudiosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO,NOMBRE  FROM NAT_MODALIDAD_ESTUDIOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="natmodalidadestudios/otrosestudios">
		<call-query href="getNatmodalidadestudiosOtrosEstudiosQuery">
 
		</call-query>
	</resource>

</data>