	<query id="getWspresupuestoPersonalActivoDeNominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT PERSONAL.ID_DE_EMPLEADO, PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES, PERSONAL.NUMERO_DCTO, PERSONAL.EXPEDIDA, TO_CHAR(PERSONAL.FECHANCTO, 'DD/MM/YYYY' )FECHANCTO, TO_CHAR(PERSONAL.FECHA_DE_INGRESO, 'DD/MM/YYYY' ) FECHA_DE_INGRESO, TO_CHAR(PERSONAL.FECHA_DE_RETIRO, 'DD/MM/YYYY' ) FECHA_DE_RETIRO, CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, PERSONAL.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA, PERSONAL.ESCALAFON, ESCALAFON.NOMBRE NOMBREESCALAFON, CATEGORIA.GRADO, PERSONAL.DE_CARRERA, TO_CHAR(PERSONAL.SALARIO_BASE_IBC, 'fm9999999999999990.00') SALARIO_BASE_IBC, DEPENDENCIA.NOMBRE, CATEGORIA.ANO, PERSONAL.COMPANIA, PERSONAL.EMAIL_CORPORATIVO, PERSONAL.EMAIL_PERSONAL, PERSONAL.DIRECCION, PERSONAL.TELEFONOS, TO_CHAR(PERSONAL.FECHA_CUMPLIMIENTO_BONIFICACIO , 'DD/MM/YYYY' )FECHA_CUMPLIMIENTO_BONIFICACIO FROM PERSONAL INNER JOIN CARGOS ON PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO INNER JOIN DEPENDENCIA ON PERSONAL.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN CATEGORIA ON PERSONAL.ESCALAFON = CATEGORIA.ESCALAFON AND PERSONAL.ID_DE_CATEGORIA = CATEGORIA.ID_DE_CATEGORIA INNER JOIN ESCALAFON ON CATEGORIA.COMPANIA = ESCALAFON.COMPANIA AND CATEGORIA.ESCALAFON = ESCALAFON.CODIGO WHERE PERSONAL.FECHA_DE_RETIRO Is Null AND CATEGORIA.ANO=:ANO AND PERSONAL.COMPANIA=:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRES":"$NOMBRES","NUMERO_DCTO":"$NUMERO_DCTO","EXPEDIDA":"$EXPEDIDA","FECHANCTO":"$FECHANCTO","FECHA_DE_INGRESO":"$FECHA_DE_INGRESO","FECHA_DE_RETIRO":"$FECHA_DE_RETIRO","ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","ESCALAFON":"$ESCALAFON","NOMBREESCALAFON":"$NOMBREESCALAFON","GRADO":"$GRADO","DE_CARRERA":"$DE_CARRERA","SALARIO_BASE_IBC":"$SALARIO_BASE_IBC","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)","COMPANIA":"$COMPANIA","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO","EMAIL_PERSONAL":"$EMAIL_PERSONAL","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","FECHA_CUMPLIMIENTO_BONIFICACIO":"$FECHA_CUMPLIMIENTO_BONIFICACIO"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
