<data name="wspresupuesto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getWspresupuestoListadodetercerosQuery"  useConfig="sysmandsunist">
		<sql>SELECT TERCERO.NIT, TERCERO.SUCURSAL TERCEROSUCURSAL, TERCERO.NOMBRE TERCERONOMBRE, TERCERO.DIRECCION, TERCERO.TELEFONOS, TERCERO.FAX, CLASETERCERO.NOMBRE CLASE, DEPARTAMENTO.NOMBRE DEPARTAMENTO, CIUDAD.NOMBRE NOMBRECIUDAD, TERCERO.DIRECCIONEMAIL, TERCEROPAGOS.BANCO, TERCEROPAGOS.CUENTA, TERCEROPAGOS.TIPOCUENTA, TO_CHAR(TERCEROPAGOS.ACTIVA) ACTIVA FROM TERCERO INNER JOIN PAISES ON TERCERO.PAIS = PAISES.PAIS INNER JOIN DEPARTAMENTO ON TERCERO.PAIS = DEPARTAMENTO.PAIS AND TERCERO.DEPARTAMENTO = DEPARTAMENTO.CODIGO INNER JOIN CIUDAD ON TERCERO.PAIS = CIUDAD.PAIS AND TERCERO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND TERCERO.CIUDAD = CIUDAD.CODIGO INNER JOIN CLASETERCERO ON TERCERO.CLASE = CLASETERCERO.CODIGO LEFT JOIN TERCEROPAGOS ON TERCERO.COMPANIA=TERCEROPAGOS.COMPANIA AND TERCERO.NIT = TERCEROPAGOS.NIT WHERE TERCERO.COMPANIA = :COMPANIA ORDER BY TERCERO.NIT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","TERCEROSUCURSAL":"$TERCEROSUCURSAL","TERCERONOMBRE":"$TERCERONOMBRE","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","FAX":"$FAX","CLASE":"$CLASE","DEPARTAMENTO":"$DEPARTAMENTO","NOMBRECIUDAD":"$NOMBRECIUDAD","DIRECCIONEMAIL":"$DIRECCIONEMAIL","BANCO":"$BANCO","CUENTA":"$CUENTA","TIPOCUENTA":"$TIPOCUENTA","ACTIVA":"$ACTIVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="wspresupuesto/listadodeterceros">
		<call-query href="getWspresupuestoListadodetercerosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getWspresupuestoListadoplanpresupuestalanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PPTAL.CODIGO, PPTAL.NOMBRE, CASE WHEN PPTAL.DESTINO = 'F' THEN 'FUNCIONAMIENTO' WHEN PPTAL.DESTINO = 'I' THEN 'INVERSION' ELSE 'SERVICIO DE LA DEUDA' END DESTINO, CASE WHEN PPTAL.NATURALEZA = 'C' THEN 'INGRESOS' ELSE 'GASTOS' END NATURALEZA, CASE WHEN PPTAL.MOVIMIENTO = 0 THEN 'NO' ELSE 'SI' END MOVIMIENTO, TIPOVIGENCIA.NOMBRE TIPOVIGENCIA, NVL(PPTAL.CODIGO_EQUIV,'') CODIGO_EQUIV, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '001' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '001' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT SECTOR TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.SECTOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '001' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) SECTOR, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '002' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '002' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT PROGRAMA TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.PROGRAMA IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '002' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) PROGRAMA, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '003' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '003' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT SUBPROGRAMA TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.SUBPROGRAMA IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '003' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) SUBPROGRAMA, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '004' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '004' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT CODIGOPRODUCTO TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.CODIGOPRODUCTO IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '004' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) CODIGOPRODUCTO, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '005' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '005' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT CODIGOBPIN TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.CODIGOBPIN IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '005' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) CODIGOBPIN, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '006' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL INNER JOIN TIPOCLASIFICADOR TP ON TP.COMPANIA = PL.COMPANIA AND TP.ANO = PL.ANO AND TP.CLASECLASIFICADOR = PL.CLASECLASIFICADOR AND TP.CODIGO = PL.TIPOCLASIFICADOR WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '006' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL AND TP.MOVIMIENTO = - 1 UNION SELECT CODIGOCCPET TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.CODIGOCCPET IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '006' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) CODIGOCCPET, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '007' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '007' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT CODIGOCPCDANE TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.CODIGOCPCDANE IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '007' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) CODIGOCPCDANE, ( SELECT ( CASE WHEN MIN(PL.CLASECLASIFICADOR) = '008' THEN MIN(PL.TIPOCLASIFICADOR) ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '008' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT CODIGOUNIDADEJE TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.CODIGOUNIDADEJE IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '008' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) CODIGOUNIDADEJE, ( SELECT ( CASE WHEN MIN(PL.CLASECLASIFICADOR) = '009' THEN MIN(PL.TIPOCLASIFICADOR) ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '009' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT CODIGOFUENTE TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.CODIGOFUENTE IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '009' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) CODIGOFUENTE, ( SELECT ( CASE WHEN MIN(PL.CLASECLASIFICADOR) = '010' THEN MIN(PL.TIPOCLASIFICADOR) ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '010' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT CODIGOCCPETREGA TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.CODIGOCCPETREGA IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '010' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) CODIGOCCPETREGA, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '011' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '011' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT POLITCA_PUBLICA_CUIPO TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.POLITCA_PUBLICA_CUIPO IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '011' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) POLITCA_PUBLICA_CUIPO, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '012' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '012' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT DETALLE_SECTORIAL TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.DETALLE_SECTORIAL IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '012' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) DETALLE_SECTORIAL, ( SELECT ( CASE WHEN PL.CLASECLASIFICADOR = '013' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(PPTAL.CODIGO, 1, LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '013' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL UNION SELECT TO_CHAR(TIPO_RECURSO) TIPOCLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA = 'VA' AND PL.CODIGO = PPTAL.CODIGO AND PL.TIPO_RECURSO IS NOT NULL AND ( CASE WHEN PL.CLASECLASIFICADOR = '013' THEN PL.TIPOCLASIFICADOR ELSE NULL END ) IS NOT NULL ) TIPO_RECURSO, PPCONF.CODIGO_SIA AS CODIGOSIA,PPTAL.DEPENDENCIAASOCIADA, DP.NOMBRE NOMBRE_DEPENDENCIA FROM PLAN_PRESUPUESTAL PPTAL INNER JOIN TIPOVIGENCIA ON PPTAL.TIPOVIGENCIA = TIPOVIGENCIA.CODIGO LEFT JOIN PLAN_PPTAL_CONFIG PPCONF ON PPTAL.COMPANIA = PPCONF.COMPANIA AND PPTAL.ANO = PPCONF.ANO AND PPTAL.CODIGO = PPCONF.CODIGO LEFT JOIN DEPENDENCIA DP ON PPTAL.COMPANIA = DP.COMPANIA AND PPTAL.DEPENDENCIAASOCIADA = DP.CODIGO WHERE PPTAL.COMPANIA = :COMPANIA AND PPTAL.ANO = :ANIO ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESTINO":"$DESTINO","NATURALEZA":"$NATURALEZA","MOVIMIENTO":"$MOVIMIENTO","TIPOVIGENCIA":"$TIPOVIGENCIA","CODIGO_EQUIV":"$CODIGO_EQUIV","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITCA_PUBLICA_CUIPO":"$POLITCA_PUBLICA_CUIPO","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","TIPO_RECURSO":"$TIPO_RECURSO","CODIGOSIA":"$CODIGOSIA","DEPENDENCIAASOCIADA":"$DEPENDENCIAASOCIADA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="wspresupuesto/listadoplanpresupuestalanio">
		<call-query href="getWspresupuestoListadoplanpresupuestalanioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>
	<query id="getWspresupuestoAuxiliarpresupuestalporcuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT DET.COMPANIA, DET.ANO, COM.NUMERO, PRECEDE.NOMBRE AS NOMBRE_PRED, PRECEDE.PREDECESOR AS ID_PREDE, PLAN.NOMBRE AS NOMBREPLAN, DET.CUENTA AS RUBRO, TO_CHAR(DET.FECHA, 'DD/MM/YYYY') FECHA, DET.TIPO_CPTE, DET.TERCERO, TER_DET.NOMBRE AS NOMBRETERCERO, DET.DESCRIPCION, CASE WHEN COM.NRO_DOCUMENTO IS NULL OR COM.NRO_DOCUMENTO = '0' THEN CONCAT(COM.TIPOCONTRATO, CONCAT(' -', COM.NUMEROCONTRATO)) ELSE COM.NRO_DOCUMENTO END AS NRO_DOCUMENTO, TO_CHAR(DET.VALOR_DEBITO, 'fm9999999999999990.00') AS VALORDEBITO, TO_CHAR(DET.VALOR_CREDITO, 'fm9999999999999990.00') AS VALORCREDITO, TO_CHAR(SUM(NVL(AFEC.SDEBITOS, 0)), 'fm9999999999999990.00') AS DEBITO_AFECTADO, TO_CHAR(SUM(NVL(AFEC.SCREDITOS, 0)), 'fm9999999999999990.00') AS CREDITO_AFECTADO, TO_CHAR(SUM(NVL(AFEC.MDEBITOS, 0)), 'fm9999999999999990.00') AS MODIFICACION_DEBITO, TO_CHAR(SUM(NVL(AFEC.MCREDITOS, 0)), 'fm9999999999999990.00') AS MODIFICACION_CREDITO, TO_CHAR( CASE WHEN CLASECNTPRES.AFECTACION IN( 'A', 'R' ) OR(CLASECNTPRES.CLASEAFECTAR IS NULL AND CLASECNTPRES.CODIGO NOT IN( 'DIS' )) THEN 0 ELSE CASE WHEN PLAN.NATURALEZA = 'D' THEN DET.VALOR_DEBITO - DET.VALOR_CREDITO ELSE - DET.VALOR_DEBITO + DET.VALOR_CREDITO END END + SUM( CASE WHEN PLAN.NATURALEZA = 'D' THEN - NVL(AFEC.SDEBITOS, 0) + NVL(AFEC.SCREDITOS, 0) + NVL(AFEC.MDEBITOS, 0) - NVL(AFEC.MCREDITOS, 0) ELSE NVL(AFEC.SDEBITOS, 0) - NVL(AFEC.SCREDITOS, 0) - NVL(AFEC.MDEBITOS, 0) + NVL(AFEC.MCREDITOS, 0) END ), 'fm9999999999999990.00') AS SALDOPOREJECUTARESP, DET.TIPO_CPTE_AFECT, TO_CHAR(DET.CMPTE_AFECTADO) CMPTE_AFECTADO FROM COMPROBANTE_PPTAL COM INNER JOIN DETALLE_COMPROBANTE_PPTAL DET ON COM.COMPANIA = DET.COMPANIA AND COM.ANO = DET.ANO AND COM.TIPO = DET.TIPO_CPTE AND COM.NUMERO = DET.COMPROBANTE INNER JOIN PLAN_PRESUPUESTAL PLAN ON PLAN.COMPANIA = DET.COMPANIA AND PLAN.ANO = DET.ANO AND PLAN.CODIGO = DET.CUENTA INNER JOIN TERCERO TER_DET ON DET.COMPANIA = TER_DET.COMPANIA AND DET.SUCURSAL = TER_DET.SUCURSAL AND DET.TERCERO = TER_DET.NIT INNER JOIN TIPO_COMPROBPP ON COM.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COM.TIPO = TIPO_COMPROBPP.CODIGO INNER JOIN CLASECNTPRES ON TIPO_COMPROBPP.CLASE = CLASECNTPRES.CODIGO LEFT JOIN ( SELECT AFECTADO.COMPANIA, AFECTADO.ANO_AFECT, AFECTADO.TIPO_CPTE_AFECT, AFECTADO.CMPTE_AFECTADO, AFECTADO.CONSECUTIVOPPTO, SUM( CASE WHEN NOT(CLASECNTPRES.AFECTACION IN( 'A', 'R' )) THEN VALOR_DEBITO + NVL(MODIF.MDEBITOS, 0) ELSE 0 END ) AS SDEBITOS, SUM( CASE WHEN NOT(CLASECNTPRES.AFECTACION IN( 'A', 'R' )) THEN VALOR_CREDITO + NVL(MODIF.MCREDITOS, 0) ELSE 0 END ) AS SCREDITOS, SUM( CASE WHEN(CLASECNTPRES.AFECTACION IN( 'A', 'R' )) THEN VALOR_DEBITO ELSE 0 END ) AS MDEBITOS, SUM( CASE WHEN(CLASECNTPRES.AFECTACION IN( 'A', 'R' )) THEN VALOR_CREDITO ELSE 0 END ) AS MCREDITOS FROM DETALLE_COMPROBANTE_PPTAL AFECTADO INNER JOIN TIPO_COMPROBPP ON AFECTADO.COMPANIA = TIPO_COMPROBPP.COMPANIA AND AFECTADO.TIPO_CPTE = TIPO_COMPROBPP.CODIGO INNER JOIN CLASECNTPRES ON TIPO_COMPROBPP.CLASE = CLASECNTPRES.CODIGO LEFT JOIN ( SELECT MODIFICACION.COMPANIA, MODIFICACION.ANO_AFECT, MODIFICACION.TIPO_CPTE_AFECT, MODIFICACION.CMPTE_AFECTADO, MODIFICACION.CONSECUTIVOPPTO, SUM(VALOR_DEBITO) AS MDEBITOS, SUM(VALOR_CREDITO) AS MCREDITOS FROM DETALLE_COMPROBANTE_PPTAL MODIFICACION INNER JOIN TIPO_COMPROBPP ON MODIFICACION.COMPANIA = TIPO_COMPROBPP.COMPANIA AND MODIFICACION.TIPO_CPTE = TIPO_COMPROBPP.CODIGO INNER JOIN CLASECNTPRES ON TIPO_COMPROBPP.CLASE = CLASECNTPRES.CODIGO WHERE MODIFICACION.COMPANIA = :COMPANIA AND MODIFICACION.ANO = :ANIO AND MODIFICACION.CUENTA BETWEEN '1' AND '3' AND CLASECNTPRES.AFECTACION IN ( 'A', 'R' ) GROUP BY MODIFICACION.COMPANIA, MODIFICACION.ANO_AFECT, MODIFICACION.TIPO_CPTE_AFECT, MODIFICACION.CMPTE_AFECTADO, MODIFICACION.CONSECUTIVOPPTO ) MODIF ON MODIF.COMPANIA = AFECTADO.COMPANIA AND MODIF.ANO_AFECT = AFECTADO.ANO AND MODIF.TIPO_CPTE_AFECT = AFECTADO.TIPO_CPTE AND MODIF.CMPTE_AFECTADO = AFECTADO.COMPROBANTE AND MODIF.CONSECUTIVOPPTO = AFECTADO.CONSECUTIVO WHERE AFECTADO.COMPANIA = :COMPANIA AND AFECTADO.ANO = :ANIO AND AFECTADO.CUENTA BETWEEN '1' AND '3' GROUP BY AFECTADO.COMPANIA, AFECTADO.ANO_AFECT, AFECTADO.TIPO_CPTE_AFECT, AFECTADO.CMPTE_AFECTADO, AFECTADO.CONSECUTIVOPPTO ) AFEC ON AFEC.COMPANIA = DET.COMPANIA AND AFEC.ANO_AFECT = DET.ANO AND AFEC.TIPO_CPTE_AFECT = DET.TIPO_CPTE AND AFEC.CMPTE_AFECTADO = DET.COMPROBANTE AND AFEC.CONSECUTIVOPPTO = DET.CONSECUTIVO LEFT JOIN ( SELECT PLANPRE.COMPANIA, PLANPRE.ANO, PLANPRE.CODIGO, MAX(PRE.CODIGO) AS PREDECESOR, PLANPRE.NOMBRE FROM PLAN_PRESUPUESTAL PLANPRE LEFT JOIN PLAN_PRESUPUESTAL PRE ON PRE.COMPANIA = PLANPRE.COMPANIA AND PRE.ANO = PLANPRE.ANO AND PRE.CODIGO = SUBSTR(PLANPRE.CODIGO, 1, LENGTH(PRE.CODIGO)) AND PRE.CODIGO &lt;&gt; PLANPRE.CODIGO WHERE PLANPRE.COMPANIA = :COMPANIA AND PLANPRE.ANO = :ANIO GROUP BY PLANPRE.COMPANIA, PLANPRE.ANO, PLANPRE.CODIGO, PLANPRE.NOMBRE ) PRECEDE ON PLAN.COMPANIA = PRECEDE.COMPANIA AND PLAN.ANO = PRECEDE.ANO AND PLAN.CODIGO = PRECEDE.CODIGO WHERE COM.COMPANIA = :COMPANIA AND COM.ANO = :ANIO AND DET.CUENTA BETWEEN '1' AND '3' AND TIPO_CPTE= :TIPO_CPTE GROUP BY DET.COMPANIA, DET.ANO, DET.CONSECUTIVO, DET.ID, DET.REFERENCIA, DET.SECTOR, DET.CODIGO_CPC, DET.PROGRAMA, DET.COD_PROD_CUIPO, COM.DEPENDENCIA, DET.CUENTA, PLAN.NOMBRE, DET.FUENTE_RECURSO, DET.FECHA, DET.TIPO_CPTE, COM.NUMERO, TER_DET.NOMBRE, DET.TERCERO, DET.DESCRIPCION, DET.REFERENCIA, DET.SECTOR, DET.CODIGO_CPC, DET.PROGRAMA, DET.DEPENDENCIA, CASE WHEN COM.NRO_DOCUMENTO IS NULL OR COM.NRO_DOCUMENTO = '0' THEN CONCAT(COM.TIPOCONTRATO, CONCAT(' -', COM.NUMEROCONTRATO)) ELSE COM.NRO_DOCUMENTO END, DET.VALOR_DEBITO, DET.VALOR_CREDITO, CASE WHEN CLASECNTPRES.AFECTACION IN ( 'A', 'R' ) OR ( CLASECNTPRES.CLASEAFECTAR IS NULL AND CLASECNTPRES.CODIGO NOT IN ( 'DIS' ) ) THEN 0 ELSE CASE WHEN PLAN.NATURALEZA = 'D' THEN DET.VALOR_DEBITO - DET.VALOR_CREDITO ELSE - DET.VALOR_DEBITO + DET.VALOR_CREDITO END END, DET.TIPO_CPTE_AFECT, DET.CMPTE_AFECTADO, COM.TIPOCONTRATO, COM.NUMEROCONTRATO, PRECEDE.PREDECESOR, PRECEDE.NOMBRE ORDER BY ID_PREDE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","NOMBRE_PRED":"$NOMBRE_PRED","ID_PREDE":"$ID_PREDE","NOMBREPLAN":"$NOMBREPLAN","RUBRO":"$RUBRO","FECHA":"$FECHA","TIPO_CPTE":"$TIPO_CPTE","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","DESCRIPCION":"$DESCRIPCION","NRO_DOCUMENTO":"$NRO_DOCUMENTO","VALORDEBITO":"$VALORDEBITO","VALORCREDITO":"$VALORCREDITO","DEBITO_AFECTADO":"$DEBITO_AFECTADO","CREDITO_AFECTADO":"$CREDITO_AFECTADO","MODIFICACION_DEBITO":"$MODIFICACION_DEBITO","MODIFICACION_CREDITO":"$MODIFICACION_CREDITO","SALDOPOREJECUTARESP":"$SALDOPOREJECUTARESP","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","CMPTE_AFECTADO":"$CMPTE_AFECTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="wspresupuesto/auxiliarpresupuestalporcuentas">
		<call-query href="getWspresupuestoAuxiliarpresupuestalporcuentasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
