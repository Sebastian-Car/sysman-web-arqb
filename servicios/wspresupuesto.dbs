	</resource>
<query id="getWspresupuestoEjecucionpptalingresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID CUENTA, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, CASE WHEN V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) THEN 'SI' ELSE 'NO' END MOVIMIENTO, CASE V_PLAN_PRESUPUESTAL.TIPO_RECURSO WHEN 1 THEN 'RECURSOS CORRIENTES' WHEN 2 THEN 'DISPONIBILIDAD INICIAL' WHEN 3 THEN 'RECURSOS CORRIENTES REGIMEN ANTERIOR' WHEN 4 THEN 'DISPONIBILIDAD INICIAL REGIMEN ANTERIOR' END TIPO_RECURSO, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO, TO_CHAR(SUM(SALDOS.APROPIADO), 'fm9999999999999990.00') APROPIADO, TO_CHAR(SUM(SALDOS.MODIFICACIONES), 'fm9999999999999990.00') MODIFICACIONES, TO_CHAR(SUM(SALDOS.APROPIADO + SALDOS.MODIFICACIONES), 'fm9999999999999990.00') TOTALPRESUPUESTO, TO_CHAR(SUM(SALDOS.RECAUDOSTOTALES - SALDOS.RECAUDOSMES), 'fm9999999999999990.00') RECAUDOSANTERIORES, TO_CHAR(SUM(SALDOS.RECAUDOSMES), 'fm9999999999999990.00') RECAUDOSMES, TO_CHAR(SUM(SALDOS.RECAUDOSTOTALES), 'fm9999999999999990.00') RECAUDOSACUMULADOS, TO_CHAR(SUM(SALDOS.APROPIADO + SALDOS.MODIFICACIONES -SALDOS.RECAUDOSTOTALES), 'fm9999999999999990.00') PORRECAUDAR, TO_CHAR(CASE WHEN SUM(SALDOS.APROPIADO + SALDOS.MODIFICACIONES)&gt;0 THEN SUM(SALDOS.RECAUDOSTOTALES)/SUM(SALDOS.APROPIADO + SALDOS.MODIFICACIONES) ELSE 0 END * 100, 'fm9999999999999990.00') AS PORCRECAUDADO FROM V_PLAN_PRESUPUESTAL INNER JOIN ( SELECT SALDO_AUX_PPTAL.COMPANIA, SALDO_AUX_PPTAL.ANO, SALDO_AUX_PPTAL.ID, SALDO_AUX_PPTAL.FUENTE_RECURSO, SUM(CASE WHEN SALDO_AUX_PPTAL.NATURALEZA='D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END) APROPIADO, SUM(CASE WHEN SALDO_AUX_PPTAL.NATURALEZA='D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END) APLAZAMIENTO, SUM(CASE WHEN SALDO_AUX_PPTAL.NATURALEZA='D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END) TRASLADO, SUM(SALDO_AUX_PPTAL.ADICION) ADICION, SUM(SALDO_AUX_PPTAL.REDUCCION) REDUCCION, SUM(SALDO_AUX_PPTAL.ADICION + SALDO_AUX_PPTAL.REDUCCION + CASE WHEN SALDO_AUX_PPTAL.NATURALEZA='D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END + CASE WHEN SALDO_AUX_PPTAL.NATURALEZA='D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END ) MODIFICACIONES, SUM(CASE WHEN SALDO_AUX_PPTAL.NATURALEZA='D' THEN EJE_PPT_DEBITO-EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO-EJE_PPT_DEBITO END + SALDO_AUX_PPTAL.MODIF_INGRESOS_EFECTIVO + SALDO_AUX_PPTAL.MODIF_INGRESOS_PAPELES) AS RECAUDOSTOTALES, SUM(CASE WHEN SALDO_AUX_PPTAL.MES = :MES THEN (CASE WHEN SALDO_AUX_PPTAL.NATURALEZA='D' THEN EJE_PPT_DEBITO-EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO-EJE_PPT_DEBITO END) + SALDO_AUX_PPTAL.MODIF_INGRESOS_EFECTIVO + SALDO_AUX_PPTAL.MODIF_INGRESOS_PAPELES ELSE 0 END) AS RECAUDOSMES FROM SALDO_AUX_PPTAL WHERE SALDO_AUX_PPTAL.COMPANIA = :COMPANIA AND SALDO_AUX_PPTAL.ANO = :ANIO AND SALDO_AUX_PPTAL.MES &lt;= :MES AND SALDO_AUX_PPTAL.ID LIKE '1%' AND SALDO_AUX_PPTAL.NATURALEZA = 'C' GROUP BY SALDO_AUX_PPTAL.COMPANIA, SALDO_AUX_PPTAL.ANO, SALDO_AUX_PPTAL.ID, SALDO_AUX_PPTAL.FUENTE_RECURSO ) SALDOS ON V_PLAN_PRESUPUESTAL.COMPANIA = SALDOS.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = SALDOS.ANO AND V_PLAN_PRESUPUESTAL.ID = SUBSTR(SALDOS.ID, 1, LENGTH(V_PLAN_PRESUPUESTAL.ID)) GROUP BY V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID , V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, CASE WHEN V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) THEN 'SI' ELSE 'NO' END, CASE V_PLAN_PRESUPUESTAL.TIPO_RECURSO WHEN 1 THEN 'RECURSOS CORRIENTES' WHEN 2 THEN 'DISPONIBILIDAD INICIAL' WHEN 3 THEN 'RECURSOS CORRIENTES REGIMEN ANTERIOR' WHEN 4 THEN 'DISPONIBILIDAD INICIAL REGIMEN ANTERIOR' END, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO ORDER BY V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CUENTA":"$CUENTA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO","TIPO_RECURSO":"$TIPO_RECURSO","FUENTE_RECURSO":"$FUENTE_RECURSO","APROPIADO":"$APROPIADO","MODIFICACIONES":"$MODIFICACIONES","TOTALPRESUPUESTO":"$TOTALPRESUPUESTO","RECAUDOSANTERIORES":"$RECAUDOSANTERIORES","RECAUDOSMES":"$RECAUDOSMES","RECAUDOSACUMULADOS":"$RECAUDOSACUMULADOS","PORRECAUDAR":"$PORRECAUDAR","PORCRECAUDADO":"$PORCRECAUDADO"}]}}		</result>
		<param name="MES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="wspresupuesto/ejecucionpptalingresos">
		<call-query href="getWspresupuestoEjecucionpptalingresosQuery">
			<with-param name="MES" query-param="MES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>
</data>