<data name="detallesplancompras" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDetallesplancomprasPorDependenciaAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, DEPENDENCIA, ANO, SUM(CANTIDAD+ENTRADAS-SALIDAS-COMPRADO) DISPONIBLE  FROM DETALLE_PLAN_COMPRAS WHERE COMPANIA= :COMPANIA AND CODIGO = :CODIGO AND DEPENDENCIA= :DEPENDENCIA AND ANO= :ANO GROUP BY COMPANIA, CODIGO, DEPENDENCIA, ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","ANO":"$ANO(type:integer)","DISPONIBLE":"$DISPONIBLE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplancompras/pordependenciaano">
		<call-query href="getDetallesplancomprasPorDependenciaAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDetallesplancomprasPorDependenciaFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, DEPENDENCIA, ANO, ( CANTIDAD + ENTRADAS - SALIDAS - COMPRADO ) DISPONIBLE FROM DETALLE_PLAN_COMPRAS WHERE COMPANIA =:COMPANIA AND CODIGO =:CODIGO AND DEPENDENCIA =:DEPENDENCIA AND CONCAT( PCK_SYSMAN_UTL.FC_STRZERO(ANO,4), PCK_SYSMAN_UTL.FC_STRZERO(MES,2)) =:FECHA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","ANO":"$ANO(type:integer)","DISPONIBLE":"$DISPONIBLE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplancompras/pordependenciafecha">
		<call-query href="getDetallesplancomprasPorDependenciaFechaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getDetallesplancomprasPagInventariosporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DETALLE.COMPANIA , DETALLE.ANO , DETALLE.RUBRO , DETALLE.CODIGO , DETALLE.DEPENDENCIA , DETALLE.MES , INVENTARIO.CODIGOCUBS , INVENTARIO.NOMBRECORTO , DETALLE.TIPO_CONTRATACION, TIPOADJUDICACION.DESCRIPCION NOMTIPOCONTRATACION  FROM DETALLE_PLAN_COMPRAS DETALLE INNER JOIN INVENTARIO ON DETALLE.COMPANIA = INVENTARIO.COMPANIA AND DETALLE.CODIGO = INVENTARIO.CODIGOELEMENTO LEFT JOIN TIPOADJUDICACION ON DETALLE.COMPANIA = TIPOADJUDICACION.COMPANIA AND DETALLE.TIPO_CONTRATACION = TIPOADJUDICACION.CODIGO WHERE DETALLE.COMPANIA = :COMPANIA AND DETALLE.ANO = :ANO ORDER BY DETALLE.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END)  LIKE UPPER(:CODIGOCUBS || '%')  AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END)  LIKE UPPER( '%' || :NOMBRECORTO || '%')  AND (CASE WHEN NOMTIPOCONTRATACION IS NULL THEN ' ' ELSE UPPER(NOMTIPOCONTRATACION) END)  LIKE UPPER( '%' || :NOMTIPOCONTRATACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","RUBRO":"$RUBRO","CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","MES":"$MES(type:integer)","CODIGOCUBS":"$CODIGOCUBS","NOMBRECORTO":"$NOMBRECORTO","TIPO_CONTRATACION":"$TIPO_CONTRATACION","NOMTIPOCONTRATACION":"$NOMTIPOCONTRATACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="NOMTIPOCONTRATACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallesplancompras/inventariosporanio/pag">
		<call-query href="getDetallesplancomprasPagInventariosporanioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="NOMBRECORTO" query-param="NOMBRECORTO"/>
			<with-param name="NOMTIPOCONTRATACION" query-param="NOMTIPOCONTRATACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetallesplancomprasNumInventariosporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DETALLE.COMPANIA , DETALLE.ANO , DETALLE.RUBRO , DETALLE.CODIGO , DETALLE.DEPENDENCIA , DETALLE.MES , INVENTARIO.CODIGOCUBS , INVENTARIO.NOMBRECORTO , DETALLE.TIPO_CONTRATACION, TIPOADJUDICACION.DESCRIPCION NOMTIPOCONTRATACION  FROM DETALLE_PLAN_COMPRAS DETALLE INNER JOIN INVENTARIO ON DETALLE.COMPANIA = INVENTARIO.COMPANIA AND DETALLE.CODIGO = INVENTARIO.CODIGOELEMENTO LEFT JOIN TIPOADJUDICACION ON DETALLE.COMPANIA = TIPOADJUDICACION.COMPANIA AND DETALLE.TIPO_CONTRATACION = TIPOADJUDICACION.CODIGO WHERE DETALLE.COMPANIA = :COMPANIA AND DETALLE.ANO = :ANO ORDER BY DETALLE.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END)  LIKE UPPER(:CODIGOCUBS || '%')  AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END)  LIKE UPPER( '%' || :NOMBRECORTO || '%')  AND (CASE WHEN NOMTIPOCONTRATACION IS NULL THEN ' ' ELSE UPPER(NOMTIPOCONTRATACION) END)  LIKE UPPER( '%' || :NOMTIPOCONTRATACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="NOMTIPOCONTRATACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplancompras/inventariosporanio/num">
		<call-query href="getDetallesplancomprasNumInventariosporanioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="NOMBRECORTO" query-param="NOMBRECORTO"/>
			<with-param name="NOMTIPOCONTRATACION" query-param="NOMTIPOCONTRATACION"/>

		</call-query>
	</resource>
	<query id="getDetallesplancomprasMesesPorRubroYDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DETALLE_PLAN_COMPRAS.MES, (PCK_SYSMAN_UTL.FC_NOMBRE_MES(MES)) NOMBREMES  FROM DETALLE_PLAN_COMPRAS WHERE DETALLE_PLAN_COMPRAS.COMPANIA = :COMPANIA AND DETALLE_PLAN_COMPRAS.RUBRO = :RUBRO AND DETALLE_PLAN_COMPRAS.CODIGO = :CODIGO AND DETALLE_PLAN_COMPRAS.DEPENDENCIA= :DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBREMES":"$NOMBREMES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplancompras/mesesporrubroydependencia">
		<call-query href="getDetallesplancomprasMesesPorRubroYDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getDetallesplancomprasSumvaloracomprarporanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(DETALLE.VALORACOMPRAR) TOTAL  FROM DETALLE_PLAN_COMPRAS DETALLE INNER JOIN INVENTARIO ON DETALLE.COMPANIA = INVENTARIO.COMPANIA AND DETALLE.CODIGO = INVENTARIO.CODIGOELEMENTO WHERE DETALLE.COMPANIA= :COMPANIA AND DETALLE.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplancompras/sumvaloracomprarporano">
		<call-query href="getDetallesplancomprasSumvaloracomprarporanoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDetallesplancomprasCantidadyvaloracomprarpordetalleQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DETALLE.COMPANIA , DETALLE.ANO , DETALLE.RUBRO , DETALLE.CODIGO , DETALLE.DEPENDENCIA , DETALLE.MES , INVENTARIO.CODIGOCUBS , INVENTARIO.NOMBRECORTO DESCRIPCION , DETALLE.TIPO_CONTRATACION , TO_NUMBER(SUM(DETALLE.CANTIDAD)) CANTIDAD , TO_NUMBER(SUM(DETALLE.VALORACOMPRAR)) VALORACOMPRAR  FROM DETALLE_PLAN_COMPRAS DETALLE INNER JOIN INVENTARIO ON DETALLE.COMPANIA = INVENTARIO.COMPANIA AND DETALLE.CODIGO = INVENTARIO.CODIGOELEMENTO WHERE DETALLE.COMPANIA = :COMPANIA AND DETALLE.ANO = :ANO GROUP BY DETALLE.COMPANIA , DETALLE.ANO , DETALLE.RUBRO , DETALLE.CODIGO , DETALLE.DEPENDENCIA , DETALLE.MES , INVENTARIO.CODIGOCUBS , INVENTARIO.NOMBRECORTO , DETALLE.TIPO_CONTRATACION ORDER BY DETALLE.MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","RUBRO":"$RUBRO","CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","MES":"$MES(type:integer)","CODIGOCUBS":"$CODIGOCUBS","DESCRIPCION":"$DESCRIPCION","TIPO_CONTRATACION":"$TIPO_CONTRATACION","CANTIDAD":"$CANTIDAD","VALORACOMPRAR":"$VALORACOMPRAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplancompras/cantidadyvaloracomprarpordetalle">
		<call-query href="getDetallesplancomprasCantidadyvaloracomprarpordetalleQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDetallesplancomprasVlrProgramadoPorDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(VALORACOMPRAR),0) SUMA FROM DETALLE_PLAN_COMPRAS WHERE COMPANIA = :COMPANIA AND DEPENDENCIA = :DEPENDENCIA AND RUBRO = :RUBRO AND FUENTE_DE_RECURSOS = :FUENTE_RECURSO AND REFERENCIA = :REFERENCIA AND CENTRO_COSTO = :CENTRO_COSTO AND AUXILIAR = :AUXILIAR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMA":"$SUMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplancompras/vlrprogramadopordependencia">
		<call-query href="getDetallesplancomprasVlrProgramadoPorDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>

		</call-query>
	</resource>
	<query id="updateDetallesplancomprasTipocontratacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_PLAN_COMPRAS SET TIPO_CONTRATACION=:TIPO_CONTRATACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_PLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND DETALLE_PLAN_COMPRAS.ANO= :KEY_ANO AND DETALLE_PLAN_COMPRAS.RUBRO= :KEY_RUBRO AND DETALLE_PLAN_COMPRAS.CODIGO= :KEY_CODIGO AND DETALLE_PLAN_COMPRAS.DEPENDENCIA= :KEY_DEPENDENCIA AND DETALLE_PLAN_COMPRAS.MES= :KEY_MES</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO_CONTRATACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_RUBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallesplancompras/tipocontratacion">
		<call-query href="updateDetallesplancomprasTipocontratacion">
			<with-param name="TIPO_CONTRATACION" query-param="TIPO_CONTRATACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_RUBRO" query-param="KEY_RUBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>

		</call-query>
	</resource>
	<query id="insertDetallesplancompras" keyColumns="COMPANIA,ANO,RUBRO,CODIGO,DEPENDENCIA,MES,CONSECUTIVO,FUENTE_DE_RECURSOS,REFERENCIA,CENTRO_COSTO,AUXILIAR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLE_PLAN_COMPRAS (COMPANIA, ANO, RUBRO, CODIGO, CONSECUTIVO, DEPENDENCIA, MES, CANTIDAD, VALOR_UNITARIO, VALORACOMPRAR, COMPRADO, VALORTOTALCOMPRADO, ENTRADAS, SALIDAS, ESPECIFICACION, SALDO_CANTIDAD, SALDO_TOTALACOMPRAR, TIPO_CONTRATACION, DURACION_ESTIMADA_DEL_CONTRATO, RESPONSABLE, SUCURSAL, FUENTE_DE_RECURSOS, REFERENCIA, CENTRO_COSTO, AUXILIAR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :RUBRO, :CODIGO, :CONSECUTIVO, :DEPENDENCIA, :MES, :CANTIDAD, :VALOR_UNITARIO, :VALORACOMPRAR, :COMPRADO, :VALORTOTALCOMPRADO, :ENTRADAS, :SALIDAS, :ESPECIFICACION, :SALDO_CANTIDAD, :SALDO_TOTALACOMPRAR, :TIPO_CONTRATACION, :DURACION_ESTIMADA_DEL_CONTRATO, :RESPONSABLE, :SUCURSAL, :FUENTE_DE_RECURSOS, :REFERENCIA, :CENTRO_COSTO, :AUXILIAR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_RUBRO":"$RUBRO","KEY_CODIGO":"$CODIGO","KEY_DEPENDENCIA":"$DEPENDENCIA","KEY_MES":"$MES(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO","KEY_FUENTE_DE_RECURSOS":"$FUENTE_DE_RECURSOS","KEY_REFERENCIA":"$REFERENCIA","KEY_CENTRO_COSTO":"$CENTRO_COSTO","KEY_AUXILIAR":"$AUXILIAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="ANO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="MES" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORACOMPRAR" sqlType="STRING"/>
		<param defaultValue="0" name="COMPRADO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTALCOMPRADO" sqlType="STRING"/>
		<param defaultValue="0" name="ENTRADAS" sqlType="STRING"/>
		<param defaultValue="0" name="SALIDAS" sqlType="STRING"/>
		<param defaultValue="" name="ESPECIFICACION" sqlType="STRING"/>
		<param defaultValue="0" name="SALDO_CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="SALDO_TOTALACOMPRAR" sqlType="STRING"/>
		<param defaultValue="3" name="TIPO_CONTRATACION" sqlType="STRING"/>
		<param defaultValue="" name="DURACION_ESTIMADA_DEL_CONTRATO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_DE_RECURSOS" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detallesplancompras">
		<call-query href="insertDetallesplancompras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
