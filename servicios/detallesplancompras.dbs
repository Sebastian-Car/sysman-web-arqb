	<query id="getDetallesplancomprasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_PLAN_COMPRAS.COMPANIA, DETALLE_PLAN_COMPRAS.ANO, DETALLE_PLAN_COMPRAS.RUBRO, DETALLE_PLAN_COMPRAS.DEPENDENCIA, DETALLE_PLAN_COMPRAS.CONSECUTIVO,DETALLE_PLAN_COMPRAS.FUENTE_DE_RECURSOS, DETALLE_PLAN_COMPRAS.REFERENCIA, DETALLE_PLAN_COMPRAS.CENTRO_COSTO, DETALLE_PLAN_COMPRAS.AUXILIAR, PCK_SYSMAN_UTL.FC_NOMBRE_MES(DETALLE_PLAN_COMPRAS.MES) NOMBREMES, DETALLE_PLAN_COMPRAS.TIPO_CONTRATACION, DETALLE_PLAN_COMPRAS.RESPONSABLE, DETALLE_PLAN_COMPRAS.SUCURSAL, DETALLE_PLAN_COMPRAS.MES, DETALLE_PLAN_COMPRAS.CODIGO, INVENTARIO.NOMBRELARGO, DETALLE_PLAN_COMPRAS.CANTIDAD, DETALLE_PLAN_COMPRAS.VALOR_UNITARIO, DETALLE_PLAN_COMPRAS.VALORACOMPRAR, DETALLE_PLAN_COMPRAS.COMPRADO, DETALLE_PLAN_COMPRAS.VALORTOTALCOMPRADO, DETALLE_PLAN_COMPRAS.ENTRADAS, DETALLE_PLAN_COMPRAS.SALIDAS, DETALLE_PLAN_COMPRAS.ESPECIFICACION, DETALLE_PLAN_COMPRAS.SALDO_CANTIDAD, DETALLE_PLAN_COMPRAS.SALDO_TOTALACOMPRAR, TIPOADJUDICACION.DESCRIPCION MODALIDAD_CONTRATACION, DETALLE_PLAN_COMPRAS.DURACION_ESTIMADA_DEL_CONTRATO, TRIM(TERCERO.NOMBRE) NOMBRE FROM DETALLE_PLAN_COMPRAS LEFT JOIN INVENTARIO ON DETALLE_PLAN_COMPRAS.COMPANIA = INVENTARIO.COMPANIA AND DETALLE_PLAN_COMPRAS.CODIGO = INVENTARIO.CODIGOELEMENTO LEFT JOIN TERCERO ON DETALLE_PLAN_COMPRAS.COMPANIA = TERCERO.COMPANIA AND DETALLE_PLAN_COMPRAS.RESPONSABLE = TERCERO.NIT AND DETALLE_PLAN_COMPRAS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN TIPOADJUDICACION ON DETALLE_PLAN_COMPRAS.COMPANIA = TIPOADJUDICACION.COMPANIA AND DETALLE_PLAN_COMPRAS.TIPO_CONTRATACION = TIPOADJUDICACION.CODIGO WHERE DETALLE_PLAN_COMPRAS.COMPANIA = :COMPANIA AND DETALLE_PLAN_COMPRAS.ANO = :ANO AND DETALLE_PLAN_COMPRAS.RUBRO = :RUBRO AND DETALLE_PLAN_COMPRAS.DEPENDENCIA = :DEPENDENCIA AND DETALLE_PLAN_COMPRAS.FUENTE_DE_RECURSOS = :FUENTE_RECURSO AND DETALLE_PLAN_COMPRAS.REFERENCIA = :REFERENCIA AND DETALLE_PLAN_COMPRAS.CENTRO_COSTO = :CENTRO_COSTO AND DETALLE_PLAN_COMPRAS.AUXILIAR = :AUXILIAR ORDER BY DETALLE_PLAN_COMPRAS.MES) INI WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(:MES, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(:CANTIDAD, '%')) AND (CASE WHEN VALOR_UNITARIO IS NULL THEN ' ' ELSE UPPER(VALOR_UNITARIO) END) LIKE UPPER(CONCAT(:VALOR_UNITARIO, '%')) AND (CASE WHEN VALORACOMPRAR IS NULL THEN ' ' ELSE UPPER(VALORACOMPRAR) END) LIKE UPPER(CONCAT(:VALORACOMPRAR, '%')) AND (CASE WHEN COMPRADO IS NULL THEN ' ' ELSE UPPER(COMPRADO) END) LIKE UPPER(CONCAT(:COMPRADO, '%')) AND (CASE WHEN VALORTOTALCOMPRADO IS NULL THEN ' ' ELSE UPPER(VALORTOTALCOMPRADO) END) LIKE UPPER(CONCAT(:VALORTOTALCOMPRADO, '%')) AND (CASE WHEN ENTRADAS IS NULL THEN ' ' ELSE UPPER(ENTRADAS) END) LIKE UPPER(CONCAT(:ENTRADAS, '%')) AND (CASE WHEN SALIDAS IS NULL THEN ' ' ELSE UPPER(SALIDAS) END) LIKE UPPER(CONCAT(:SALIDAS, '%')) AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:ESPECIFICACION), '%')) AND (CASE WHEN SALDO_CANTIDAD IS NULL THEN ' ' ELSE UPPER(SALDO_CANTIDAD) END) LIKE UPPER(CONCAT(:SALDO_CANTIDAD, '%')) AND (CASE WHEN SALDO_TOTALACOMPRAR IS NULL THEN ' ' ELSE UPPER(SALDO_TOTALACOMPRAR) END) LIKE UPPER(CONCAT(:SALDO_TOTALACOMPRAR, '%')) AND (CASE WHEN MODALIDAD_CONTRATACION IS NULL THEN ' ' ELSE UPPER(MODALIDAD_CONTRATACION) END) LIKE UPPER(CONCAT(CONCAT('%',:MODALIDAD_CONTRATACION), '%')) AND (CASE WHEN DURACION_ESTIMADA_DEL_CONTRATO IS NULL THEN ' ' ELSE UPPER(DURACION_ESTIMADA_DEL_CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:DURACION_ESTIMADA_DEL_CONTRATO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
