	<query id="updateDetallesplancompras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_PLAN_COMPRAS SET FUENTE_DE_RECURSOS=:FUENTE_DE_RECURSOS, REFERENCIA=:REFERENCIA, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, MES=:MES, CANTIDAD=:CANTIDAD, VALOR_UNITARIO=:VALOR_UNITARIO, VALORACOMPRAR=:VALORACOMPRAR, COMPRADO=:COMPRADO, VALORTOTALCOMPRADO=:VALORTOTALCOMPRADO, ENTRADAS=:ENTRADAS, SALIDAS=:SALIDAS, ESPECIFICACION=:ESPECIFICACION, SALDO_CANTIDAD=:SALDO_CANTIDAD, SALDO_TOTALACOMPRAR=:SALDO_TOTALACOMPRAR, TIPO_CONTRATACION=:TIPO_CONTRATACION, DURACION_ESTIMADA_DEL_CONTRATO=:DURACION_ESTIMADA_DEL_CONTRATO, RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_PLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND DETALLE_PLAN_COMPRAS.ANO= :KEY_ANO AND DETALLE_PLAN_COMPRAS.RUBRO= :KEY_RUBRO AND DETALLE_PLAN_COMPRAS.CODIGO= :KEY_CODIGO AND DETALLE_PLAN_COMPRAS.DEPENDENCIA= :KEY_DEPENDENCIA AND DETALLE_PLAN_COMPRAS.MES= :KEY_MES AND DETALLE_PLAN_COMPRAS.CONSECUTIVO= :KEY_CONSECUTIVO AND DETALLE_PLAN_COMPRAS.FUENTE_DE_RECURSOS= :KEY_FUENTE_DE_RECURSOS AND DETALLE_PLAN_COMPRAS.REFERENCIA= :KEY_REFERENCIA AND DETALLE_PLAN_COMPRAS.CENTRO_COSTO= :KEY_CENTRO_COSTO AND DETALLE_PLAN_COMPRAS.AUXILIAR= :KEY_AUXILIAR</sql>
