		<param name="KEY_AUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="detallesplancompras">
		<call-query href="deleteDetallesplancompras">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_RUBRO" query-param="KEY_RUBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
