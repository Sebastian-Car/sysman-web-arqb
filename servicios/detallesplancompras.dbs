			<with-param name="SALDO_CANTIDAD" query-param="SALDO_CANTIDAD"/>
			<with-param name="SALDO_TOTALACOMPRAR" query-param="SALDO_TOTALACOMPRAR"/>
			<with-param name="TIPO_CONTRATACION" query-param="TIPO_CONTRATACION"/>
			<with-param name="DURACION_ESTIMADA_DEL_CONTRATO" query-param="DURACION_ESTIMADA_DEL_CONTRATO"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FUENTE_DE_RECURSOS" query-param="FUENTE_DE_RECURSOS"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDetallesplancompras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DETALLE_PLAN_COMPRAS WHERE DETALLE_PLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND DETALLE_PLAN_COMPRAS.ANO= :KEY_ANO AND DETALLE_PLAN_COMPRAS.RUBRO= :KEY_RUBRO AND DETALLE_PLAN_COMPRAS.CODIGO= :KEY_CODIGO AND DETALLE_PLAN_COMPRAS.DEPENDENCIA= :KEY_DEPENDENCIA AND DETALLE_PLAN_COMPRAS.MES= :KEY_MES AND DETALLE_PLAN_COMPRAS.CONSECUTIVO= :KEY_CONSECUTIVO AND DETALLE_PLAN_COMPRAS.FUENTE_DE_RECURSOS= :KEY_FUENTE_DE_RECURSOS AND DETALLE_PLAN_COMPRAS.REFERENCIA= :KEY_REFERENCIA AND DETALLE_PLAN_COMPRAS.CENTRO_COSTO= :KEY_CENTRO_COSTO AND DETALLE_PLAN_COMPRAS.AUXILIAR= :KEY_AUXILIAR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_RUBRO" sqlType="STRING"/>
