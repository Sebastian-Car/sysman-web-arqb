<data name="clasepensionado" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getClasepensionadoTodosClasepensioadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASE_PENSIONADO.CODIGO, CLASE_PENSIONADO.NOMBRE  FROM CLASE_PENSIONADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="clasepensionado/todosclasepensioados">
		<call-query href="getClasepensionadoTodosClasepensioadosQuery">
 
		</call-query>
	</resource>

</data>