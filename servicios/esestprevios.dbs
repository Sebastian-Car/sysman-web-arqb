<data name="esestprevios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsestpreviosListaFactoresDesempateQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_ESTPREVIO.COMPANIA, ES_ESTPREVIO.COD_ESTUDIO, ES_ESTPREVIO.C_EVALUACION  FROM ES_ESTPREVIO WHERE ES_ESTPREVIO.COMPANIA = :COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO = :CODIGOESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO","C_EVALUACION":"$C_EVALUACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/listafactoresdesempate">
		<call-query href="getEsestpreviosListaFactoresDesempateQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOESTUDIO" query-param="CODIGOESTUDIO"/>

		</call-query>
	</resource>
	<query id="updateEsestpreviosActualizarEvaluacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ESTPREVIO SET C_EVALUACION = :C_EVALUACION ,   COD_ESTUDIO    = :COD_ESTUDIO,   DATE_MODIFIED  =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY    =:MODIFIED_BY WHERE COMPANIA   = :KEY_COMPANIA AND COD_ESTUDIO  = :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="C_EVALUACION" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esestprevios/actualizarevaluacion">
		<call-query href="updateEsestpreviosActualizarEvaluacion">
			<with-param name="C_EVALUACION" query-param="C_EVALUACION"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="updateEsestpreviosActualizarperfil" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ESTPREVIO SET PYE_CONTRATISTA=:PYE_CONTRATISTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_ESTPREVIO.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PYE_CONTRATISTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esestprevios/actualizarperfil">
		<call-query href="updateEsestpreviosActualizarperfil">
			<with-param name="PYE_CONTRATISTA" query-param="PYE_CONTRATISTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosCodestudioPorTipodiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_ESTPREVIO.COD_ESTUDIO  FROM ES_ESTPREVIO WHERE ES_ESTPREVIO.COMPANIA= :COMPANIA AND ES_ESTPREVIO.TIPO_DIA = :TIPO ORDER BY ES_ESTPREVIO.COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_ESTUDIO":"$COD_ESTUDIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/codestudioportipodia">
		<call-query href="getEsestpreviosCodestudioPorTipodiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosPagTodosPorCompaniaTipoDiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COD_ESTUDIO, NOMBRE_ESTUDIO  FROM ES_ESTPREVIO WHERE COMPANIA = :COMPANIA AND TIPO_DIA = :TIPO_DIA ORDER BY COD_ESTUDIO) WHERE (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END)  LIKE UPPER( '%' || :NOMBRE_ESTUDIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_ESTUDIO":"$COD_ESTUDIO","NOMBRE_ESTUDIO":"$NOMBRE_ESTUDIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_DIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esestprevios/todosporcompaniatipodia/pag">
		<call-query href="getEsestpreviosPagTodosPorCompaniaTipoDiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_DIA" query-param="TIPO_DIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE_ESTUDIO" query-param="NOMBRE_ESTUDIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosNumTodosPorCompaniaTipoDiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COD_ESTUDIO, NOMBRE_ESTUDIO  FROM ES_ESTPREVIO WHERE COMPANIA = :COMPANIA AND TIPO_DIA = :TIPO_DIA ORDER BY COD_ESTUDIO) WHERE (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END)  LIKE UPPER( '%' || :NOMBRE_ESTUDIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_DIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/todosporcompaniatipodia/num">
		<call-query href="getEsestpreviosNumTodosPorCompaniaTipoDiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_DIA" query-param="TIPO_DIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE_ESTUDIO" query-param="NOMBRE_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosPagTodosPorCompaniaTipoDiaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COD_ESTUDIO, NOMBRE_ESTUDIO  FROM ES_ESTPREVIO WHERE COD_ESTUDIO &gt;= :ESTUDIO_INI AND COMPANIA = :COMPANIA AND TIPO_DIA =:TIPO_DIA ORDER BY COD_ESTUDIO) WHERE (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END)  LIKE UPPER( '%' || :NOMBRE_ESTUDIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_ESTUDIO":"$COD_ESTUDIO","NOMBRE_ESTUDIO":"$NOMBRE_ESTUDIO"}]}}		</result>
		<param name="ESTUDIO_INI" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_DIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esestprevios/todosporcompaniatipodiafinal/pag">
		<call-query href="getEsestpreviosPagTodosPorCompaniaTipoDiaFinalQuery">
			<with-param name="ESTUDIO_INI" query-param="ESTUDIO_INI"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_DIA" query-param="TIPO_DIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE_ESTUDIO" query-param="NOMBRE_ESTUDIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosNumTodosPorCompaniaTipoDiaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COD_ESTUDIO, NOMBRE_ESTUDIO  FROM ES_ESTPREVIO WHERE COD_ESTUDIO &gt;= :ESTUDIO_INI AND COMPANIA = :COMPANIA AND TIPO_DIA =:TIPO_DIA ORDER BY COD_ESTUDIO) WHERE (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END)  LIKE UPPER( '%' || :NOMBRE_ESTUDIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ESTUDIO_INI" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_DIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/todosporcompaniatipodiafinal/num">
		<call-query href="getEsestpreviosNumTodosPorCompaniaTipoDiaFinalQuery">
			<with-param name="ESTUDIO_INI" query-param="ESTUDIO_INI"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_DIA" query-param="TIPO_DIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE_ESTUDIO" query-param="NOMBRE_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosDatosBasicosCodestudioQuery"  useConfig="sysmandsunist">
		<sql>SELECT ES_ESTPREVIO.NOMBRE_ESTUDIO, ES_ESTPREVIO.PROPONENTE, ES_ESTPREVIO.TIPO_CONTRATO, ES_ESTPREVIO.ITEMS_CONTRATO,(TO_CHAR(ES_ESTPREVIO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ES_ESTPREVIO.OBJETO_CONTRATO, ES_ESTPREVIO.DEF_NECESIDAD, ES_ESTPREVIO.DESC_NECESIDAD, ES_ESTPREVIO.FUND_JURIDICOS, ES_ESTPREVIO.OBL_CONTRATISTA, ES_ESTPREVIO.OBL_ENTIDAD, ES_ESTPREVIO.ASP_TEC_ESTUDIO, ES_ESTPREVIO.TIPO_DIA, ES_ESTPREVIO.SUPERVISION, ES_ESTPREVIO.LOCALIZACION_EJEC, ES_ESTPREVIO.DEPENDENCIA, ES_ESTPREVIO.RESPONSABLE, ES_ESTPREVIO.ADJUDICACION,(TO_CHAR(ES_ESTPREVIO.PLAZOINICIAL,'DD/MM/YYYY HH24:MI:SS')) PLAZOINICIAL,(TO_CHAR(ES_ESTPREVIO.PLAZOFINAL,'DD/MM/YYYY HH24:MI:SS')) PLAZOFINAL, ES_ESTPREVIO.ANALISIS_RIESGO,(CASE ES_ESTPREVIO.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO, ES_ESTPREVIO.VERIF_ETAPAS, ES_ESTPREVIO.TIPO_GARANTIA, ES_ESTPREVIO.VALOR_CONTRATO, ES_ESTPREVIO.VIGENCIAINICIO, ES_ESTPREVIO.VIGENCIAFIN, ES_ESTPREVIO.RUBRO, ES_ESTPREVIO.ANULADOPOR,(TO_CHAR(ES_ESTPREVIO.FECHAANULADO,'DD/MM/YYYY HH24:MI:SS')) FECHAANULADO,(TO_CHAR(ES_ESTPREVIO.HORAANULADO,'DD/MM/YYYY HH24:MI:SS')) HORAANULADO, ES_ESTPREVIO.CUANTIACONTR, ES_ESTPREVIO.AN_CONVENIENCIA, ES_ESTPREVIO.AN_OPORTUNIDAD, ES_ESTPREVIO.PYE_CONTRATISTA, ES_ESTPREVIO.POBLACION_BENEF, ES_ESTPREVIO.EMPLEODIRECTO, ES_ESTPREVIO.EMPLEOINDIRECTO, ES_ESTPREVIO.COSTOEST, ES_ESTPREVIO.COSTOIVAEST, ES_ESTPREVIO.COSTOTOTALEST, ES_ESTPREVIO.PRODUCTO_ENTREGAR, ES_ESTPREVIO.RESULTADOS_ESP, ES_ESTPREVIO.CANT_PERSONAS,(CASE ES_ESTPREVIO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, ES_ESTPREVIO.CARGO, ES_ESTPREVIO.SUPERVISADO,(CASE ES_ESTPREVIO.VOBO WHEN 0 THEN 'false' ELSE 'true' END) VOBO,(TO_CHAR(ES_ESTPREVIO.FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VOBO,(TO_CHAR(ES_ESTPREVIO.HORA_VOBO,'DD/MM/YYYY HH24:MI:SS')) HORA_VOBO, ES_ESTPREVIO.NUM_CNE,(TO_CHAR(ES_ESTPREVIO.FECHA_CNE,'DD/MM/YYYY HH24:MI:SS')) FECHA_CNE, ES_ESTPREVIO.NOSOLICITUD_CNE,(TO_CHAR(ES_ESTPREVIO.FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD, ES_ESTPREVIO.NUM_PROCESO, ES_ESTPREVIO.CODIGOSUM, ES_ESTPREVIO.CARGO_INTERVENTOR, ES_ESTPREVIO.PLAZO_EJECUCION, ES_ESTPREVIO.CAPITAL, ES_ESTPREVIO.ENDEUDAMIENTO, ES_ESTPREVIO.INDICE_LIQUIDEZ, ES_ESTPREVIO.TIPO_EST_PREVIO,(CASE ES_ESTPREVIO.TIPOEST WHEN 0 THEN 'false' ELSE 'true' END) TIPOEST, ES_ESTPREVIO.FORMA_PAGO, ES_ESTPREVIO.FORMA_PAGOS, ES_ESTPREVIO.COD_ESTUDIO, ES_ESTPREVIO.ALCANCE, SECTOR_ASP_GENERAL, SECTOR_ASP_ECONOMICO, SECTOR_ASP_TECNICO, SECTOR_ASP_REGULATORIO, SECTOR_ESTUDIO_OFERTA, SECTOR_ESTUDIO_DEMANDA, SECTOR_ANALISIS_ESTADISTICO, SECTOR_PERSPECTIVA_LEGAL, SECTOR_CONCLUSIONES, ESPECIFICACION_TEC, OBL_GARANTIAS FROM ES_ESTPREVIO WHERE ES_ESTPREVIO.COMPANIA= :COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO = :COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_ESTUDIO":"$NOMBRE_ESTUDIO","PROPONENTE":"$PROPONENTE","TIPO_CONTRATO":"$TIPO_CONTRATO","ITEMS_CONTRATO":"$ITEMS_CONTRATO","FECHA":"$FECHA","OBJETO_CONTRATO":"$OBJETO_CONTRATO","DEF_NECESIDAD":"$DEF_NECESIDAD","DESC_NECESIDAD":"$DESC_NECESIDAD","FUND_JURIDICOS":"$FUND_JURIDICOS","OBL_CONTRATISTA":"$OBL_CONTRATISTA","OBL_ENTIDAD":"$OBL_ENTIDAD","ASP_TEC_ESTUDIO":"$ASP_TEC_ESTUDIO","TIPO_DIA":"$TIPO_DIA","SUPERVISION":"$SUPERVISION","LOCALIZACION_EJEC":"$LOCALIZACION_EJEC","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","ADJUDICACION":"$ADJUDICACION","PLAZOINICIAL":"$PLAZOINICIAL","PLAZOFINAL":"$PLAZOFINAL","ANALISIS_RIESGO":"$ANALISIS_RIESGO","ESTADO":"$ESTADO(type:boolean)","VERIF_ETAPAS":"$VERIF_ETAPAS","TIPO_GARANTIA":"$TIPO_GARANTIA","VALOR_CONTRATO":"$VALOR_CONTRATO","VIGENCIAINICIO":"$VIGENCIAINICIO","VIGENCIAFIN":"$VIGENCIAFIN","RUBRO":"$RUBRO","ANULADOPOR":"$ANULADOPOR","FECHAANULADO":"$FECHAANULADO","HORAANULADO":"$HORAANULADO","CUANTIACONTR":"$CUANTIACONTR","AN_CONVENIENCIA":"$AN_CONVENIENCIA","AN_OPORTUNIDAD":"$AN_OPORTUNIDAD","PYE_CONTRATISTA":"$PYE_CONTRATISTA","POBLACION_BENEF":"$POBLACION_BENEF","EMPLEODIRECTO":"$EMPLEODIRECTO","EMPLEOINDIRECTO":"$EMPLEOINDIRECTO","COSTOEST":"$COSTOEST","COSTOIVAEST":"$COSTOIVAEST","COSTOTOTALEST":"$COSTOTOTALEST","PRODUCTO_ENTREGAR":"$PRODUCTO_ENTREGAR","RESULTADOS_ESP":"$RESULTADOS_ESP","CANT_PERSONAS":"$CANT_PERSONAS","IMPRESO":"$IMPRESO(type:boolean)","CARGO":"$CARGO","SUPERVISADO":"$SUPERVISADO","VOBO":"$VOBO(type:boolean)","FECHA_VOBO":"$FECHA_VOBO","HORA_VOBO":"$HORA_VOBO","NUM_CNE":"$NUM_CNE","FECHA_CNE":"$FECHA_CNE","NOSOLICITUD_CNE":"$NOSOLICITUD_CNE","FECHA_SOLICITUD":"$FECHA_SOLICITUD","NUM_PROCESO":"$NUM_PROCESO","CODIGOSUM":"$CODIGOSUM","CARGO_INTERVENTOR":"$CARGO_INTERVENTOR","PLAZO_EJECUCION":"$PLAZO_EJECUCION","CAPITAL":"$CAPITAL","ENDEUDAMIENTO":"$ENDEUDAMIENTO","INDICE_LIQUIDEZ":"$INDICE_LIQUIDEZ","TIPO_EST_PREVIO":"$TIPO_EST_PREVIO","TIPOEST":"$TIPOEST(type:boolean)","FORMA_PAGO":"$FORMA_PAGO","FORMA_PAGOS":"$FORMA_PAGOS","COD_ESTUDIO":"$COD_ESTUDIO","ALCANCE":"$ALCANCE","SECTOR_ASP_GENERAL":"$SECTOR_ASP_GENERAL","SECTOR_ASP_ECONOMICO":"$SECTOR_ASP_ECONOMICO","SECTOR_ASP_TECNICO":"$SECTOR_ASP_TECNICO","SECTOR_ASP_REGULATORIO":"$SECTOR_ASP_REGULATORIO","SECTOR_ESTUDIO_OFERTA":"$SECTOR_ESTUDIO_OFERTA","SECTOR_ESTUDIO_DEMANDA":"$SECTOR_ESTUDIO_DEMANDA","SECTOR_ANALISIS_ESTADISTICO":"$SECTOR_ANALISIS_ESTADISTICO","SECTOR_PERSPECTIVA_LEGAL":"$SECTOR_PERSPECTIVA_LEGAL","SECTOR_CONCLUSIONES":"$SECTOR_CONCLUSIONES","ESPECIFICACION_TEC":"$ESPECIFICACION_TEC","OBL_GARANTIAS":"$OBL_GARANTIAS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/datosbasicoscodestudio">
		<call-query href="getEsestpreviosDatosBasicosCodestudioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="insertEsestprevios" keyColumns="COMPANIA,COD_ESTUDIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_ESTPREVIO (ADJUDICACION, ANALISIS_RIESGO, AN_CONVENIENCIA, AN_OPORTUNIDAD, ANULADOPOR, ASP_TEC_ESTUDIO, CANT_PERSONAS, CAPACIDAD_RESIDUAL, CAPITAL, CARGO, CARGO_INTERVENTOR, C_EVALUACION, COD_ESTUDIO, CODIGOSUM, COMPANIA, COSTOEST, COSTOIVAEST, COSTOTOTALEST, CREATED_BY, CUANTIACONTR, DATE_CREATED, DEF_NECESIDAD, DEPENDENCIA, DESC_NECESIDAD, EMPLEODIRECTO, EMPLEOINDIRECTO, ENDEUDAMIENTO, ESPECIFICACION_TEC, ESTADO, FECHA, FECHAANULADO, FECHA_CNE, FECHA_SOLICITUD, FECHA_VOBO, FORMA_PAGO, FORMA_PAGOS, FUND_JURIDICOS, HORAANULADO, HORA_VOBO, IMPRESO, INDICE_LIQUIDEZ, ITEMS_CONTRATO, LOCALIZACION_EJEC, NOMBRE_ESTUDIO, NOSOLICITUD_CNE, NUM_CNE, NUM_PROCESO, OBJETO_CONTRATO, OBL_CONTRATISTA, OBL_ENTIDAD, OBL_GARANTIAS, PLAZO_EJECUCION, PLAZOFINAL, PLAZOINICIAL, POBLACION_BENEF, PRODUCTO_ENTREGAR, PROPONENTE, PYE_CONTRATISTA, RAZON_INTERES, RENT_ACTIVOS, RENT_PATRIMONIO, RESPONSABLE, RESULTADOS_ESP, RUBRO, SECTOR_ANALISIS_ESTADISTICO, SECTOR_ASP_ECONOMICO, SECTOR_ASP_GENERAL, SECTOR_ASP_REGULATORIO, SECTOR_ASP_TECNICO, SECTOR_CONCLUSIONES, SECTOR_ESTUDIO_DEMANDA, SECTOR_ESTUDIO_OFERTA, SECTOR_PERSPECTIVA_LEGAL, SUCURSAL_RESPONSABLE, SUCURSAL_SUPERVISADO, SUCURSAL_SUPERVISION, SUPERVISADO, SUPERVISION, TIPO_CONTRATO, TIPO_DIA, TIPOEST, TIPO_EST_PREVIO, TIPO_GARANTIA, VALOR_CONTRATO, VARIABLES_PPTO, VERIF_ETAPAS, VIGENCIAFIN, VIGENCIAINICIO, VOBO, OTROSINDICADORES, APLICA_BYS, APLICA_PUBLICIDAD, ALCANCE) VALUES (:ADJUDICACION, :ANALISIS_RIESGO, :AN_CONVENIENCIA, :AN_OPORTUNIDAD, :ANULADOPOR, :ASP_TEC_ESTUDIO, :CANT_PERSONAS, :CAPACIDAD_RESIDUAL, :CAPITAL, :CARGO, :CARGO_INTERVENTOR, :C_EVALUACION, :COD_ESTUDIO, :CODIGOSUM, :COMPANIA, :COSTOEST, :COSTOIVAEST, :COSTOTOTALEST, :CREATED_BY, :CUANTIACONTR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :DEF_NECESIDAD, :DEPENDENCIA, :DESC_NECESIDAD, :EMPLEODIRECTO, :EMPLEOINDIRECTO, :ENDEUDAMIENTO, :ESPECIFICACION_TEC, :ESTADO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAANULADO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_CNE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS'), :FORMA_PAGO, :FORMA_PAGOS, :FUND_JURIDICOS, TO_DATE(:HORAANULADO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_VOBO,'DD/MM/YYYY HH24:MI:SS'), :IMPRESO, :INDICE_LIQUIDEZ, :ITEMS_CONTRATO, :LOCALIZACION_EJEC, :NOMBRE_ESTUDIO, :NOSOLICITUD_CNE, :NUM_CNE, :NUM_PROCESO, :OBJETO_CONTRATO, :OBL_CONTRATISTA, :OBL_ENTIDAD, :OBL_GARANTIAS, :PLAZO_EJECUCION, TO_DATE(:PLAZOFINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:PLAZOINICIAL,'DD/MM/YYYY HH24:MI:SS'), :POBLACION_BENEF, :PRODUCTO_ENTREGAR, :PROPONENTE, :PYE_CONTRATISTA, :RAZON_INTERES, :RENT_ACTIVOS, :RENT_PATRIMONIO, :RESPONSABLE, :RESULTADOS_ESP, :RUBRO, :SECTOR_ANALISIS_ESTADISTICO, :SECTOR_ASP_ECONOMICO, :SECTOR_ASP_GENERAL, :SECTOR_ASP_REGULATORIO, :SECTOR_ASP_TECNICO, :SECTOR_CONCLUSIONES, :SECTOR_ESTUDIO_DEMANDA, :SECTOR_ESTUDIO_OFERTA, :SECTOR_PERSPECTIVA_LEGAL, :SUCURSAL_RESPONSABLE, :SUCURSAL_SUPERVISADO, :SUCURSAL_SUPERVISION, :SUPERVISADO, :SUPERVISION, :TIPO_CONTRATO, :TIPO_DIA, :TIPOEST, :TIPO_EST_PREVIO, :TIPO_GARANTIA, :VALOR_CONTRATO, :VARIABLES_PPTO, :VERIF_ETAPAS, :VIGENCIAFIN, :VIGENCIAINICIO, :VOBO, :OTROSINDICADORES, :APLICA_BYS, :APLICA_PUBLICIDAD, :ALCANCE)</sql>
