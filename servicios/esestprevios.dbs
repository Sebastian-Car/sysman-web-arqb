	<query id="deleteEsestprevios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_ESTPREVIO WHERE ES_ESTPREVIO.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="esestprevios">
		<call-query href="deleteEsestprevios">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_ESTPREVIO.COMPANIA, ES_ESTPREVIO.COD_ESTUDIO, ES_ESTPREVIO.NOMBRE_ESTUDIO, ES_ESTPREVIO.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, ES_ESTPREVIO.PROPONENTE, TO_CHAR(ES_ESTPREVIO.FECHA,'DD/MM/YYYY') FECHA, ES_ESTPREVIO.CREATED_BY  FROM ES_ESTPREVIO LEFT JOIN DEPENDENCIA ON ES_ESTPREVIO.COMPANIA = DEPENDENCIA.COMPANIA AND ES_ESTPREVIO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE ES_ESTPREVIO.TIPO_DIA =:TIPODIA AND ES_ESTPREVIO.COMPANIA =:COMPANIA AND TO_CHAR(FECHA,'YYYY') =:VIGENCIA) WHERE (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END)  LIKE UPPER( '%' || :NOMBRE_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END)  LIKE UPPER(:NOMBRE_DEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO","NOMBRE_ESTUDIO":"$NOMBRE_ESTUDIO","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","PROPONENTE":"$PROPONENTE","FECHA":"$FECHA","CREATED_BY":"$CREATED_BY"}]}}		</result>
		<param name="TIPODIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esestprevios">
		<call-query href="getEsestpreviosPaginaQuery">
			<with-param name="TIPODIA" query-param="TIPODIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE_ESTUDIO" query-param="NOMBRE_ESTUDIO"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_ESTPREVIO.COMPANIA, ES_ESTPREVIO.COD_ESTUDIO, ES_ESTPREVIO.NOMBRE_ESTUDIO, ES_ESTPREVIO.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, ES_ESTPREVIO.PROPONENTE, TO_CHAR(ES_ESTPREVIO.FECHA,'DD/MM/YYYY') FECHA, ES_ESTPREVIO.CREATED_BY  FROM ES_ESTPREVIO LEFT JOIN DEPENDENCIA ON ES_ESTPREVIO.COMPANIA = DEPENDENCIA.COMPANIA AND ES_ESTPREVIO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE ES_ESTPREVIO.TIPO_DIA =:TIPODIA AND ES_ESTPREVIO.COMPANIA =:COMPANIA AND TO_CHAR(FECHA,'YYYY') =:VIGENCIA) WHERE (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END)  LIKE UPPER( '%' || :NOMBRE_ESTUDIO || '%')  AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END)  LIKE UPPER(:NOMBRE_DEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPODIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/numero">
		<call-query href="getEsestpreviosNumeroQuery">
			<with-param name="TIPODIA" query-param="TIPODIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE_ESTUDIO" query-param="NOMBRE_ESTUDIO"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT ES_ESTPREVIO.ADJUDICACION , ES_ESTPREVIO.ANALISIS_RIESGO , ES_ESTPREVIO.AN_CONVENIENCIA , ES_ESTPREVIO.AN_OPORTUNIDAD , ES_ESTPREVIO.ANULADOPOR , ES_ESTPREVIO.ASP_TEC_ESTUDIO , ES_ESTPREVIO.CANT_PERSONAS , ES_ESTPREVIO.CAPACIDAD_RESIDUAL , ES_ESTPREVIO.CAPITAL , ES_ESTPREVIO.CARGO , ES_ESTPREVIO.CARGO_INTERVENTOR , ES_ESTPREVIO.C_EVALUACION , ES_ESTPREVIO.COD_ESTUDIO , ES_ESTPREVIO.CODIGOSUM , ES_ESTPREVIO.COMPANIA , ES_ESTPREVIO.COSTOEST , ES_ESTPREVIO.COSTOIVAEST , ES_ESTPREVIO.COSTOTOTALEST , ES_ESTPREVIO.CREATED_BY , ES_ESTPREVIO.CUANTIACONTR ,(TO_CHAR(ES_ESTPREVIO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(ES_ESTPREVIO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ES_ESTPREVIO.DEF_NECESIDAD , ES_ESTPREVIO.DEPENDENCIA , ES_ESTPREVIO.DESC_NECESIDAD , ES_ESTPREVIO.EMPLEODIRECTO , ES_ESTPREVIO.EMPLEOINDIRECTO , ES_ESTPREVIO.ENDEUDAMIENTO , ES_ESTPREVIO.ESPECIFICACION_TEC ,(CASE ES_ESTPREVIO.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO,(TO_CHAR(ES_ESTPREVIO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(ES_ESTPREVIO.FECHAANULADO,'DD/MM/YYYY HH24:MI:SS')) FECHAANULADO,(TO_CHAR(ES_ESTPREVIO.FECHA_CNE,'DD/MM/YYYY HH24:MI:SS')) FECHA_CNE,(TO_CHAR(ES_ESTPREVIO.FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD,(TO_CHAR(ES_ESTPREVIO.FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VOBO, ES_ESTPREVIO.FORMA_PAGO , ES_ESTPREVIO.FORMA_PAGOS , ES_ESTPREVIO.FUND_JURIDICOS ,(TO_CHAR(ES_ESTPREVIO.HORAANULADO,'DD/MM/YYYY HH24:MI:SS')) HORAANULADO,(TO_CHAR(ES_ESTPREVIO.HORA_VOBO,'DD/MM/YYYY HH24:MI:SS')) HORA_VOBO,(CASE ES_ESTPREVIO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, ES_ESTPREVIO.INDICE_LIQUIDEZ , ES_ESTPREVIO.ITEMS_CONTRATO , ES_ESTPREVIO.LOCALIZACION_EJEC , ES_ESTPREVIO.MODIFIED_BY , ES_ESTPREVIO.NOMBRE_ESTUDIO , ES_ESTPREVIO.NOSOLICITUD_CNE , ES_ESTPREVIO.NUM_CNE , TRANSACCION.NUM_PROCESO NUM_PROCESO, ES_ESTPREVIO.OBJETO_CONTRATO , ES_ESTPREVIO.OBL_CONTRATISTA , ES_ESTPREVIO.OBL_ENTIDAD , ES_ESTPREVIO.OBL_GARANTIAS, ES_ESTPREVIO.PLAZO_EJECUCION ,(TO_CHAR(ES_ESTPREVIO.PLAZOFINAL,'DD/MM/YYYY HH24:MI:SS')) PLAZOFINAL,(TO_CHAR(ES_ESTPREVIO.PLAZOINICIAL,'DD/MM/YYYY HH24:MI:SS')) PLAZOINICIAL, ES_ESTPREVIO.POBLACION_BENEF , ES_ESTPREVIO.PRODUCTO_ENTREGAR , ES_ESTPREVIO.PROPONENTE , ES_ESTPREVIO.PYE_CONTRATISTA , ES_ESTPREVIO.RAZON_INTERES , ES_ESTPREVIO.RENT_ACTIVOS , ES_ESTPREVIO.RENT_PATRIMONIO , ES_ESTPREVIO.RESPONSABLE , ES_ESTPREVIO.RESULTADOS_ESP , ES_ESTPREVIO.RUBRO , ES_ESTPREVIO.SECTOR_ANALISIS_ESTADISTICO , ES_ESTPREVIO.SECTOR_ASP_ECONOMICO , ES_ESTPREVIO.SECTOR_ASP_GENERAL , ES_ESTPREVIO.SECTOR_ASP_REGULATORIO , ES_ESTPREVIO.SECTOR_ASP_TECNICO , ES_ESTPREVIO.SECTOR_CONCLUSIONES , ES_ESTPREVIO.SECTOR_ESTUDIO_DEMANDA , ES_ESTPREVIO.SECTOR_ESTUDIO_OFERTA , ES_ESTPREVIO.SECTOR_PERSPECTIVA_LEGAL , ES_ESTPREVIO.SUCURSAL_RESPONSABLE , ES_ESTPREVIO.SUCURSAL_SUPERVISADO , ES_ESTPREVIO.SUCURSAL_SUPERVISION , ES_ESTPREVIO.SUPERVISADO , ES_ESTPREVIO.SUPERVISION , ES_ESTPREVIO.TIPO_CONTRATO , ES_ESTPREVIO.TIPO_DIA ,(CASE ES_ESTPREVIO.TIPOEST WHEN 0 THEN 'false' ELSE 'true' END) TIPOEST, ES_ESTPREVIO.TIPO_EST_PREVIO , ES_ESTPREVIO.TIPO_GARANTIA , ES_ESTPREVIO.VALOR_CONTRATO , ES_ESTPREVIO.VARIABLES_PPTO , ES_ESTPREVIO.VERIF_ETAPAS , ES_ESTPREVIO.VIGENCIAFIN , ES_ESTPREVIO.VIGENCIAINICIO ,(CASE ES_ESTPREVIO.VOBO WHEN 0 THEN 'false' ELSE 'true' END) VOBO, ES_ESTPREVIO.OTROSINDICADORES,(CASE ES_ESTPREVIO.APLICA_BYS WHEN 0 THEN 'false' ELSE 'true' END) APLICA_BYS,(CASE ES_ESTPREVIO.APLICA_PUBLICIDAD WHEN 0 THEN 'false' ELSE 'true' END) APLICA_PUBLICIDAD, ES_ESTPREVIO.ALCANCE FROM ES_ESTPREVIO LEFT JOIN TRANSACCION ON ES_ESTPREVIO.COMPANIA = TRANSACCION.COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO = TRANSACCION.ESTUDIOPREVIO WHERE ES_ESTPREVIO.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ADJUDICACION":"$ADJUDICACION","ANALISIS_RIESGO":"$ANALISIS_RIESGO","AN_CONVENIENCIA":"$AN_CONVENIENCIA","AN_OPORTUNIDAD":"$AN_OPORTUNIDAD","ANULADOPOR":"$ANULADOPOR","ASP_TEC_ESTUDIO":"$ASP_TEC_ESTUDIO","CANT_PERSONAS":"$CANT_PERSONAS","CAPACIDAD_RESIDUAL":"$CAPACIDAD_RESIDUAL","CAPITAL":"$CAPITAL","CARGO":"$CARGO","CARGO_INTERVENTOR":"$CARGO_INTERVENTOR","C_EVALUACION":"$C_EVALUACION","COD_ESTUDIO":"$COD_ESTUDIO","CODIGOSUM":"$CODIGOSUM","COMPANIA":"$COMPANIA","COSTOEST":"$COSTOEST","COSTOIVAEST":"$COSTOIVAEST","COSTOTOTALEST":"$COSTOTOTALEST","CREATED_BY":"$CREATED_BY","CUANTIACONTR":"$CUANTIACONTR","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","DEF_NECESIDAD":"$DEF_NECESIDAD","DEPENDENCIA":"$DEPENDENCIA","DESC_NECESIDAD":"$DESC_NECESIDAD","EMPLEODIRECTO":"$EMPLEODIRECTO","EMPLEOINDIRECTO":"$EMPLEOINDIRECTO","ENDEUDAMIENTO":"$ENDEUDAMIENTO","ESPECIFICACION_TEC":"$ESPECIFICACION_TEC","ESTADO":"$ESTADO(type:boolean)","FECHA":"$FECHA","FECHAANULADO":"$FECHAANULADO","FECHA_CNE":"$FECHA_CNE","FECHA_SOLICITUD":"$FECHA_SOLICITUD","FECHA_VOBO":"$FECHA_VOBO","FORMA_PAGO":"$FORMA_PAGO","FORMA_PAGOS":"$FORMA_PAGOS","FUND_JURIDICOS":"$FUND_JURIDICOS","HORAANULADO":"$HORAANULADO","HORA_VOBO":"$HORA_VOBO","IMPRESO":"$IMPRESO(type:boolean)","INDICE_LIQUIDEZ":"$INDICE_LIQUIDEZ","ITEMS_CONTRATO":"$ITEMS_CONTRATO","LOCALIZACION_EJEC":"$LOCALIZACION_EJEC","MODIFIED_BY":"$MODIFIED_BY","NOMBRE_ESTUDIO":"$NOMBRE_ESTUDIO","NOSOLICITUD_CNE":"$NOSOLICITUD_CNE","NUM_CNE":"$NUM_CNE","NUM_PROCESO":"$NUM_PROCESO","OBJETO_CONTRATO":"$OBJETO_CONTRATO","OBL_CONTRATISTA":"$OBL_CONTRATISTA","OBL_ENTIDAD":"$OBL_ENTIDAD","OBL_GARANTIAS":"$OBL_GARANTIAS","PLAZO_EJECUCION":"$PLAZO_EJECUCION","PLAZOFINAL":"$PLAZOFINAL","PLAZOINICIAL":"$PLAZOINICIAL","POBLACION_BENEF":"$POBLACION_BENEF","PRODUCTO_ENTREGAR":"$PRODUCTO_ENTREGAR","PROPONENTE":"$PROPONENTE","PYE_CONTRATISTA":"$PYE_CONTRATISTA","RAZON_INTERES":"$RAZON_INTERES","RENT_ACTIVOS":"$RENT_ACTIVOS","RENT_PATRIMONIO":"$RENT_PATRIMONIO","RESPONSABLE":"$RESPONSABLE","RESULTADOS_ESP":"$RESULTADOS_ESP","RUBRO":"$RUBRO","SECTOR_ANALISIS_ESTADISTICO":"$SECTOR_ANALISIS_ESTADISTICO","SECTOR_ASP_ECONOMICO":"$SECTOR_ASP_ECONOMICO","SECTOR_ASP_GENERAL":"$SECTOR_ASP_GENERAL","SECTOR_ASP_REGULATORIO":"$SECTOR_ASP_REGULATORIO","SECTOR_ASP_TECNICO":"$SECTOR_ASP_TECNICO","SECTOR_CONCLUSIONES":"$SECTOR_CONCLUSIONES","SECTOR_ESTUDIO_DEMANDA":"$SECTOR_ESTUDIO_DEMANDA","SECTOR_ESTUDIO_OFERTA":"$SECTOR_ESTUDIO_OFERTA","SECTOR_PERSPECTIVA_LEGAL":"$SECTOR_PERSPECTIVA_LEGAL","SUCURSAL_RESPONSABLE":"$SUCURSAL_RESPONSABLE","SUCURSAL_SUPERVISADO":"$SUCURSAL_SUPERVISADO","SUCURSAL_SUPERVISION":"$SUCURSAL_SUPERVISION","SUPERVISADO":"$SUPERVISADO","SUPERVISION":"$SUPERVISION","TIPO_CONTRATO":"$TIPO_CONTRATO","TIPO_DIA":"$TIPO_DIA","TIPOEST":"$TIPOEST(type:boolean)","TIPO_EST_PREVIO":"$TIPO_EST_PREVIO","TIPO_GARANTIA":"$TIPO_GARANTIA","VALOR_CONTRATO":"$VALOR_CONTRATO","VARIABLES_PPTO":"$VARIABLES_PPTO","VERIF_ETAPAS":"$VERIF_ETAPAS","VIGENCIAFIN":"$VIGENCIAFIN","VIGENCIAINICIO":"$VIGENCIAINICIO","VOBO":"$VOBO(type:boolean)","OTROSINDICADORES":"$OTROSINDICADORES","APLICA_BYS":"$APLICA_BYS(type:boolean)","APLICA_PUBLICIDAD":"$APLICA_PUBLICIDAD(type:boolean)","ALCANCE":"$ALCANCE"}]}}		</result>
