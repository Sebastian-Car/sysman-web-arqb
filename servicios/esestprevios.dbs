	<query id="updateEsestprevios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ESTPREVIO SET ADJUDICACION=:ADJUDICACION, ANALISIS_RIESGO=:ANALISIS_RIESGO, AN_CONVENIENCIA=:AN_CONVENIENCIA, AN_OPORTUNIDAD=:AN_OPORTUNIDAD, ANULADOPOR=:ANULADOPOR, ASP_TEC_ESTUDIO=:ASP_TEC_ESTUDIO, CANT_PERSONAS=:CANT_PERSONAS, CAPACIDAD_RESIDUAL=:CAPACIDAD_RESIDUAL, CAPITAL=:CAPITAL, CARGO=:CARGO, CARGO_INTERVENTOR=:CARGO_INTERVENTOR, C_EVALUACION=:C_EVALUACION, COD_ESTUDIO=:COD_ESTUDIO, CODIGOSUM=:CODIGOSUM, COSTOEST=:COSTOEST, COSTOIVAEST=:COSTOIVAEST, COSTOTOTALEST=:COSTOTOTALEST, CUANTIACONTR=:CUANTIACONTR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), DEF_NECESIDAD=:DEF_NECESIDAD, DEPENDENCIA=:DEPENDENCIA, DESC_NECESIDAD=:DESC_NECESIDAD, EMPLEODIRECTO=:EMPLEODIRECTO, EMPLEOINDIRECTO=:EMPLEOINDIRECTO, ENDEUDAMIENTO=:ENDEUDAMIENTO, ESPECIFICACION_TEC=:ESPECIFICACION_TEC, ESTADO=:ESTADO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), FECHAANULADO=TO_DATE(:FECHAANULADO,'DD/MM/YYYY HH24:MI:SS'), FECHA_CNE=TO_DATE(:FECHA_CNE,'DD/MM/YYYY HH24:MI:SS'), FECHA_SOLICITUD=TO_DATE(:FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS'), FECHA_VOBO=TO_DATE(:FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS'), FORMA_PAGO=:FORMA_PAGO, FORMA_PAGOS=:FORMA_PAGOS, FUND_JURIDICOS=:FUND_JURIDICOS, HORAANULADO=TO_DATE(:HORAANULADO,'DD/MM/YYYY HH24:MI:SS'), HORA_VOBO=TO_DATE(:HORA_VOBO,'DD/MM/YYYY HH24:MI:SS'), IMPRESO=:IMPRESO, INDICE_LIQUIDEZ=:INDICE_LIQUIDEZ, ITEMS_CONTRATO=:ITEMS_CONTRATO, LOCALIZACION_EJEC=:LOCALIZACION_EJEC, MODIFIED_BY=:MODIFIED_BY, NOMBRE_ESTUDIO=:NOMBRE_ESTUDIO, NOSOLICITUD_CNE=:NOSOLICITUD_CNE, NUM_CNE=:NUM_CNE, NUM_PROCESO=:NUM_PROCESO, OBJETO_CONTRATO=:OBJETO_CONTRATO, OBL_CONTRATISTA=:OBL_CONTRATISTA, OBL_ENTIDAD=:OBL_ENTIDAD, OBL_GARANTIAS=:OBL_GARANTIAS, PLAZO_EJECUCION=:PLAZO_EJECUCION, PLAZOFINAL=TO_DATE(:PLAZOFINAL,'DD/MM/YYYY HH24:MI:SS'), PLAZOINICIAL=TO_DATE(:PLAZOINICIAL,'DD/MM/YYYY HH24:MI:SS'), POBLACION_BENEF=:POBLACION_BENEF, PRODUCTO_ENTREGAR=:PRODUCTO_ENTREGAR, PROPONENTE=:PROPONENTE, PYE_CONTRATISTA=:PYE_CONTRATISTA, RAZON_INTERES=:RAZON_INTERES, RENT_ACTIVOS=:RENT_ACTIVOS, RENT_PATRIMONIO=:RENT_PATRIMONIO, RESPONSABLE=:RESPONSABLE, RESULTADOS_ESP=:RESULTADOS_ESP, RUBRO=:RUBRO, SECTOR_ANALISIS_ESTADISTICO=:SECTOR_ANALISIS_ESTADISTICO, SECTOR_ASP_ECONOMICO=:SECTOR_ASP_ECONOMICO, SECTOR_ASP_GENERAL=:SECTOR_ASP_GENERAL, SECTOR_ASP_REGULATORIO=:SECTOR_ASP_REGULATORIO, SECTOR_ASP_TECNICO=:SECTOR_ASP_TECNICO, SECTOR_CONCLUSIONES=:SECTOR_CONCLUSIONES, SECTOR_ESTUDIO_DEMANDA=:SECTOR_ESTUDIO_DEMANDA, SECTOR_ESTUDIO_OFERTA=:SECTOR_ESTUDIO_OFERTA, SECTOR_PERSPECTIVA_LEGAL=:SECTOR_PERSPECTIVA_LEGAL, SUCURSAL_RESPONSABLE=:SUCURSAL_RESPONSABLE, SUCURSAL_SUPERVISADO=:SUCURSAL_SUPERVISADO, SUCURSAL_SUPERVISION=:SUCURSAL_SUPERVISION, SUPERVISADO=:SUPERVISADO, SUPERVISION=:SUPERVISION, TIPO_CONTRATO=:TIPO_CONTRATO, TIPO_DIA=:TIPO_DIA, TIPOEST=:TIPOEST, TIPO_EST_PREVIO=:TIPO_EST_PREVIO, TIPO_GARANTIA=:TIPO_GARANTIA, VALOR_CONTRATO=:VALOR_CONTRATO, VARIABLES_PPTO=:VARIABLES_PPTO, VERIF_ETAPAS=:VERIF_ETAPAS, VIGENCIAFIN=:VIGENCIAFIN, VIGENCIAINICIO=:VIGENCIAINICIO, VOBO=:VOBO, OTROSINDICADORES=:OTROSINDICADORES, APLICA_BYS=:APLICA_BYS, APLICA_PUBLICIDAD=:APLICA_PUBLICIDAD, ALCANCE=:ALCANCE WHERE ES_ESTPREVIO.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

