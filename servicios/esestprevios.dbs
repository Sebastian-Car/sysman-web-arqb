	<query id="getEsestpreviosRubrosYAniosPorEstudioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_RUBROS_EST_DIS.CODIGO_CUENTA AS RUBRO_CDP , ES_RUBROS_EST_DIS.ANO AS ANIOESTPREV  FROM ES_ESTPREVIO LEFT JOIN ES_RUBROS_EST_DIS ON ES_ESTPREVIO.COMPANIA = ES_RUBROS_EST_DIS.COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO = ES_RUBROS_EST_DIS.COD_ESTUDIO WHERE ES_ESTPREVIO.COMPANIA = :COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO = :COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUBRO_CDP":"$RUBRO_CDP","ANIOESTPREV":"$ANIOESTPREV(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/rubrosyaniosporestudio">
		<call-query href="getEsestpreviosRubrosYAniosPorEstudioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviosPerfilDelCodigoestudioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PYE_CONTRATISTA  FROM ES_ESTPREVIO WHERE COMPANIA = :COMPANIA AND COD_ESTUDIO = :COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PYE_CONTRATISTA":"$PYE_CONTRATISTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevios/perfildelcodigoestudio">
		<call-query href="getEsestpreviosPerfilDelCodigoestudioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>

