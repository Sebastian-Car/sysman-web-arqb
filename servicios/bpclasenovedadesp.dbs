<data name="bpclasenovedadesp" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpclasenovedadespTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO CLASENOVEDAD, NOMBRE  FROM BPCLASENOVEDADP</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASENOVEDAD":"$CLASENOVEDAD","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="bpclasenovedadesp/todos">
		<call-query href="getBpclasenovedadespTodosQuery">
 
		</call-query>
	</resource>

</data>