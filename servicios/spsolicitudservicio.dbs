		</call-query>
	</resource>
	<query id="getSpsolicitudservicioNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_SOLICITUDSERVICIO.COMPANIA, SP_SOLICITUDPORSERVICIO.NOMBRE NOMBRECLASESOLICITUD, SP_SOLICITUDSERVICIO.CLASESOLICITUD, SP_SOLICITUDSERVICIO.NUMERO, SP_SOLICITUDSERVICIO.NOMBRE, CONCAT(SP_SOLICITUDSERVICIO.NOMBRES,CONCAT(' ',CONCAT(SP_SOLICITUDSERVICIO.PRIMERAPELLIDO,CONCAT(' ',SP_SOLICITUDSERVICIO.SEGUNDOAPELLIDO ) ) ) ) NOMBRES, SP_SOLICITUDSERVICIO.CODIGORUTA, TO_CHAR(FECHASOLICITUD,'DD/MM/YYYY') FECHASOLICITUD FROM SP_SOLICITUDSERVICIO INNER JOIN SP_SOLICITUDPORSERVICIO ON SP_SOLICITUDSERVICIO.COMPANIA = SP_SOLICITUDPORSERVICIO.COMPANIA AND SP_SOLICITUDSERVICIO.CLASESOLICITUD = SP_SOLICITUDPORSERVICIO.CODIGO WHERE SP_SOLICITUDSERVICIO.COMPANIA =:COMPANIA AND SP_SOLICITUDSERVICIO.ANULADA IN ( 0 ) ORDER BY SP_SOLICITUDSERVICIO.FECHASOLICITUD DESC) INI WHERE (CASE WHEN NOMBRECLASESOLICITUD IS NULL THEN ' ' ELSE UPPER(NOMBRECLASESOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECLASESOLICITUD), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN FECHASOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHASOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHASOLICITUD), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRECLASESOLICITUD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="FECHASOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spsolicitudservicio/numero">
		<call-query href="getSpsolicitudservicioNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRECLASESOLICITUD" query-param="NOMBRECLASESOLICITUD"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="FECHASOLICITUD" query-param="FECHASOLICITUD"/>

		</call-query>
	</resource>
	<query id="getSpsolicitudservicioRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA , CLASESOLICITUD , NUMERO , NOMBRE , DIRTECNICA , DIRGUIA , TELEFONO , TIPODOCUMENTO , NIT , SUCURSAL , OBSERVACIONES ,(CASE NECESITAVISITA WHEN 0 THEN 'false' ELSE 'true' END) NECESITAVISITA,(CASE VERIFICAOFICINA WHEN 0 THEN 'false' ELSE 'true' END) VERIFICAOFICINA, CODIGOCATASTRAL , NUMAPARTAMENTO , NUMFAMAPART , NUMPERSONASFAM , NUMPISOSVIVIENDA , TIPODEPREDIO , USO , ESTRATO , AREACONSTRUIDA , AREALIBRE , AREATOTAL , DIAMACUEDUCTO , DIAMALCANTARILLADO ,(CASE EXISTERED WHEN 0 THEN 'false' ELSE 'true' END) EXISTERED,(CASE SERVICIOGRAVEDAD WHEN 0 THEN 'false' ELSE 'true' END) SERVICIOGRAVEDAD,(CASE EXISTEACOMETIDA WHEN 0 THEN 'false' ELSE 'true' END) EXISTEACOMETIDA,(CASE EXISTEALCANTARILLADO WHEN 0 THEN 'false' ELSE 'true' END) EXISTEALCANTARILLADO,(CASE ALCANTARILLADOGRAVE WHEN 0 THEN 'false' ELSE 'true' END) ALCANTARILLADOGRAVE, DISTANREDMEDIDOR , LONGFRENTEPREDIO , LONGFONDOPREDIO , AREACONSTRUIDARED , AREAROTURACONCRETO , AREAROTURAASFALTO , AREAAFIRMACIONTIERRA , DEPENDENCIA , RECIBIDOPOR , OPERADOR , VALORTOTAL , TIPOVIVIENDA , PAIS , DEPARTAMENTO , CIUDAD ,(CASE ACTIVADO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVADO, SOLICITANTE , DIAMETROMATRIZ , PERNOCOBRO , ESTRATOALUMBRADO , DIGITOS ,(CASE INDAC WHEN 0 THEN 'false' ELSE 'true' END) INDAC,(CASE INDALC WHEN 0 THEN 'false' ELSE 'true' END) INDALC,(CASE INDAS WHEN 0 THEN 'false' ELSE 'true' END) INDAS, NUMMEDIDOR ,(CASE EXISTEREDALCANTARILLADO WHEN 0 THEN 'false' ELSE 'true' END) EXISTEREDALCANTARILLADO, PRIMERAPELLIDO , SEGUNDOAPELLIDO , NOMBRES , USUARIO , ESTADOAPROBADO , SECTORHIDRAULICO , CODIGORUTA , SECTHIDRAULICO , SUBSECTOR , REDHIDRAULICA , SECCION , MANZANA , OBS_PRESUPUESTP , CODIGODANE , LADO , SECTOR , TIPONOTIFICACION , CODIGO_RESPUESTA , TIPORESPUESTA , SOLICITANTE_NIT , SOLICITANTE_SUCURSAL , SOLICITANTE_TEL , SOLICITANTE_CEL , SOLICITANTE_EMAIL , SOLICITANTE_DIR , BARRIO , PRESENTACION ,(CASE ANULADA WHEN 0 THEN 'false' ELSE 'true' END) ANULADA, USUARIO_ANUL , CREATED_BY , MODIFIED_BY ,(TO_CHAR(FECHADEPENDENCIA,'DD/MM/YYYY HH24:MI:SS')) FECHADEPENDENCIA,(TO_CHAR(HORASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) HORASOLICITUD,(TO_CHAR(FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD,(TO_CHAR(FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAEXPEDICION,(TO_CHAR(FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO,(TO_CHAR(FECHANOTIFICACION,'DD/MM/YYYY HH24:MI:SS')) FECHANOTIFICACION,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(FECHA_ANUL,'DD/MM/YYYY HH24:MI:SS')) FECHA_ANUL,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED FROM SP_SOLICITUDSERVICIO WHERE SP_SOLICITUDSERVICIO.COMPANIA= :KEY_COMPANIA AND SP_SOLICITUDSERVICIO.CLASESOLICITUD= :KEY_CLASESOLICITUD AND SP_SOLICITUDSERVICIO.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASESOLICITUD":"$CLASESOLICITUD","NUMERO":"$NUMERO(type:long)","NOMBRE":"$NOMBRE","DIRTECNICA":"$DIRTECNICA","DIRGUIA":"$DIRGUIA","TELEFONO":"$TELEFONO","TIPODOCUMENTO":"$TIPODOCUMENTO","NIT":"$NIT","SUCURSAL":"$SUCURSAL","OBSERVACIONES":"$OBSERVACIONES","NECESITAVISITA":"$NECESITAVISITA(type:boolean)","VERIFICAOFICINA":"$VERIFICAOFICINA(type:boolean)","CODIGOCATASTRAL":"$CODIGOCATASTRAL","NUMAPARTAMENTO":"$NUMAPARTAMENTO","NUMFAMAPART":"$NUMFAMAPART","NUMPERSONASFAM":"$NUMPERSONASFAM","NUMPISOSVIVIENDA":"$NUMPISOSVIVIENDA","TIPODEPREDIO":"$TIPODEPREDIO","USO":"$USO","ESTRATO":"$ESTRATO","AREACONSTRUIDA":"$AREACONSTRUIDA","AREALIBRE":"$AREALIBRE","AREATOTAL":"$AREATOTAL","DIAMACUEDUCTO":"$DIAMACUEDUCTO","DIAMALCANTARILLADO":"$DIAMALCANTARILLADO","EXISTERED":"$EXISTERED(type:boolean)","SERVICIOGRAVEDAD":"$SERVICIOGRAVEDAD(type:boolean)","EXISTEACOMETIDA":"$EXISTEACOMETIDA(type:boolean)","EXISTEALCANTARILLADO":"$EXISTEALCANTARILLADO(type:boolean)","ALCANTARILLADOGRAVE":"$ALCANTARILLADOGRAVE(type:boolean)","DISTANREDMEDIDOR":"$DISTANREDMEDIDOR","LONGFRENTEPREDIO":"$LONGFRENTEPREDIO","LONGFONDOPREDIO":"$LONGFONDOPREDIO","AREACONSTRUIDARED":"$AREACONSTRUIDARED","AREAROTURACONCRETO":"$AREAROTURACONCRETO","AREAROTURAASFALTO":"$AREAROTURAASFALTO","AREAAFIRMACIONTIERRA":"$AREAAFIRMACIONTIERRA","DEPENDENCIA":"$DEPENDENCIA","RECIBIDOPOR":"$RECIBIDOPOR","OPERADOR":"$OPERADOR","VALORTOTAL":"$VALORTOTAL","TIPOVIVIENDA":"$TIPOVIVIENDA","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","ACTIVADO":"$ACTIVADO(type:boolean)","SOLICITANTE":"$SOLICITANTE","DIAMETROMATRIZ":"$DIAMETROMATRIZ","PERNOCOBRO":"$PERNOCOBRO(type:integer)","ESTRATOALUMBRADO":"$ESTRATOALUMBRADO","DIGITOS":"$DIGITOS(type:integer)","INDAC":"$INDAC(type:boolean)","INDALC":"$INDALC(type:boolean)","INDAS":"$INDAS(type:boolean)","NUMMEDIDOR":"$NUMMEDIDOR","EXISTEREDALCANTARILLADO":"$EXISTEREDALCANTARILLADO(type:boolean)","PRIMERAPELLIDO":"$PRIMERAPELLIDO","SEGUNDOAPELLIDO":"$SEGUNDOAPELLIDO","NOMBRES":"$NOMBRES","USUARIO":"$USUARIO","ESTADOAPROBADO":"$ESTADOAPROBADO","SECTORHIDRAULICO":"$SECTORHIDRAULICO","CODIGORUTA":"$CODIGORUTA","SECTHIDRAULICO":"$SECTHIDRAULICO","SUBSECTOR":"$SUBSECTOR","REDHIDRAULICA":"$REDHIDRAULICA","SECCION":"$SECCION","MANZANA":"$MANZANA","OBS_PRESUPUESTP":"$OBS_PRESUPUESTP","CODIGODANE":"$CODIGODANE","LADO":"$LADO","SECTOR":"$SECTOR","TIPONOTIFICACION":"$TIPONOTIFICACION","CODIGO_RESPUESTA":"$CODIGO_RESPUESTA","TIPORESPUESTA":"$TIPORESPUESTA","SOLICITANTE_NIT":"$SOLICITANTE_NIT","SOLICITANTE_SUCURSAL":"$SOLICITANTE_SUCURSAL","SOLICITANTE_TEL":"$SOLICITANTE_TEL","SOLICITANTE_CEL":"$SOLICITANTE_CEL","SOLICITANTE_EMAIL":"$SOLICITANTE_EMAIL","SOLICITANTE_DIR":"$SOLICITANTE_DIR","BARRIO":"$BARRIO","PRESENTACION":"$PRESENTACION","ANULADA":"$ANULADA(type:boolean)","USUARIO_ANUL":"$USUARIO_ANUL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","FECHADEPENDENCIA":"$FECHADEPENDENCIA","HORASOLICITUD":"$HORASOLICITUD","FECHASOLICITUD":"$FECHASOLICITUD","FECHAEXPEDICION":"$FECHAEXPEDICION","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","FECHANOTIFICACION":"$FECHANOTIFICACION","DATE_MODIFIED":"$DATE_MODIFIED","FECHA_ANUL":"$FECHA_ANUL","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASESOLICITUD" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
