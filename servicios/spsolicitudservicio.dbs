	<query id="deleteSpsolicitudservicio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_SOLICITUDSERVICIO WHERE SP_SOLICITUDSERVICIO.COMPANIA= :KEY_COMPANIA AND SP_SOLICITUDSERVICIO.CLASESOLICITUD= :KEY_CLASESOLICITUD AND SP_SOLICITUDSERVICIO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASESOLICITUD" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spsolicitudservicio">
		<call-query href="deleteSpsolicitudservicio">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASESOLICITUD" query-param="KEY_CLASESOLICITUD"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getSpsolicitudservicioPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_SOLICITUDSERVICIO.COMPANIA, SP_SOLICITUDPORSERVICIO.NOMBRE NOMBRECLASESOLICITUD, SP_SOLICITUDSERVICIO.CLASESOLICITUD, SP_SOLICITUDSERVICIO.NUMERO, SP_SOLICITUDSERVICIO.NOMBRE, CONCAT(SP_SOLICITUDSERVICIO.NOMBRES,CONCAT(' ',CONCAT(SP_SOLICITUDSERVICIO.PRIMERAPELLIDO,CONCAT(' ',SP_SOLICITUDSERVICIO.SEGUNDOAPELLIDO ) ) ) ) NOMBRES, SP_SOLICITUDSERVICIO.CODIGORUTA, TO_CHAR(FECHASOLICITUD,'DD/MM/YYYY') FECHASOLICITUD FROM SP_SOLICITUDSERVICIO INNER JOIN SP_SOLICITUDPORSERVICIO ON SP_SOLICITUDSERVICIO.COMPANIA = SP_SOLICITUDPORSERVICIO.COMPANIA AND SP_SOLICITUDSERVICIO.CLASESOLICITUD = SP_SOLICITUDPORSERVICIO.CODIGO WHERE SP_SOLICITUDSERVICIO.COMPANIA =:COMPANIA AND SP_SOLICITUDSERVICIO.ANULADA IN ( 0 ) ORDER BY SP_SOLICITUDSERVICIO.FECHASOLICITUD DESC) INI WHERE (CASE WHEN NOMBRECLASESOLICITUD IS NULL THEN ' ' ELSE UPPER(NOMBRECLASESOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECLASESOLICITUD), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN FECHASOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHASOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHASOLICITUD), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NOMBRECLASESOLICITUD":"$NOMBRECLASESOLICITUD","CLASESOLICITUD":"$CLASESOLICITUD","NUMERO":"$NUMERO(type:long)","NOMBRE":"$NOMBRE","NOMBRES":"$NOMBRES","CODIGORUTA":"$CODIGORUTA","FECHASOLICITUD":"$FECHASOLICITUD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRECLASESOLICITUD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="FECHASOLICITUD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spsolicitudservicio">
		<call-query href="getSpsolicitudservicioPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRECLASESOLICITUD" query-param="NOMBRECLASESOLICITUD"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
