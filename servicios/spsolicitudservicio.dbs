	<query id="updateSpsolicitudservicio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_SOLICITUDSERVICIO SET CLASESOLICITUD=:CLASESOLICITUD, NUMERO=:NUMERO, NOMBRE=:NOMBRE, DIRTECNICA=:DIRTECNICA, DIRGUIA=:DIRGUIA, TELEFONO=:TELEFONO, TIPODOCUMENTO=:TIPODOCUMENTO, NIT=:NIT, SUCURSAL=:SUCURSAL, OBSERVACIONES=:OBSERVACIONES, NECESITAVISITA=:NECESITAVISITA, VERIFICAOFICINA=:VERIFICAOFICINA, CODIGOCATASTRAL=:CODIGOCATASTRAL, NUMAPARTAMENTO=:NUMAPARTAMENTO, NUMFAMAPART=:NUMFAMAPART, NUMPERSONASFAM=:NUMPERSONASFAM, NUMPISOSVIVIENDA=:NUMPISOSVIVIENDA, TIPODEPREDIO=:TIPODEPREDIO, USO=:USO, ESTRATO=:ESTRATO, AREACONSTRUIDA=:AREACONSTRUIDA, AREALIBRE=:AREALIBRE, AREATOTAL=:AREATOTAL, DIAMACUEDUCTO=:DIAMACUEDUCTO, DIAMALCANTARILLADO=:DIAMALCANTARILLADO, EXISTERED=:EXISTERED, SERVICIOGRAVEDAD=:SERVICIOGRAVEDAD, EXISTEACOMETIDA=:EXISTEACOMETIDA, EXISTEALCANTARILLADO=:EXISTEALCANTARILLADO, ALCANTARILLADOGRAVE=:ALCANTARILLADOGRAVE, DISTANREDMEDIDOR=:DISTANREDMEDIDOR, LONGFRENTEPREDIO=:LONGFRENTEPREDIO, LONGFONDOPREDIO=:LONGFONDOPREDIO, AREACONSTRUIDARED=:AREACONSTRUIDARED, AREAROTURACONCRETO=:AREAROTURACONCRETO, AREAROTURAASFALTO=:AREAROTURAASFALTO, AREAAFIRMACIONTIERRA=:AREAAFIRMACIONTIERRA, DEPENDENCIA=:DEPENDENCIA, RECIBIDOPOR=:RECIBIDOPOR, OPERADOR=:OPERADOR, VALORTOTAL=:VALORTOTAL, TIPOVIVIENDA=:TIPOVIVIENDA, PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, CIUDAD=:CIUDAD, ACTIVADO=:ACTIVADO, SOLICITANTE=:SOLICITANTE, DIAMETROMATRIZ=:DIAMETROMATRIZ, PERNOCOBRO=:PERNOCOBRO, ESTRATOALUMBRADO=:ESTRATOALUMBRADO, DIGITOS=:DIGITOS, INDAC=:INDAC, INDALC=:INDALC, INDAS=:INDAS, NUMMEDIDOR=:NUMMEDIDOR, EXISTEREDALCANTARILLADO=:EXISTEREDALCANTARILLADO, PRIMERAPELLIDO=:PRIMERAPELLIDO, SEGUNDOAPELLIDO=:SEGUNDOAPELLIDO, NOMBRES=:NOMBRES, USUARIO=:USUARIO, ESTADOAPROBADO=:ESTADOAPROBADO, SECTORHIDRAULICO=:SECTORHIDRAULICO, CODIGORUTA=:CODIGORUTA, SECTHIDRAULICO=:SECTHIDRAULICO, SUBSECTOR=:SUBSECTOR, REDHIDRAULICA=:REDHIDRAULICA, SECCION=:SECCION, MANZANA=:MANZANA, OBS_PRESUPUESTP=:OBS_PRESUPUESTP, CODIGODANE=:CODIGODANE, LADO=:LADO, SECTOR=:SECTOR, TIPONOTIFICACION=:TIPONOTIFICACION, CODIGO_RESPUESTA=:CODIGO_RESPUESTA, TIPORESPUESTA=:TIPORESPUESTA, SOLICITANTE_NIT=:SOLICITANTE_NIT, SOLICITANTE_SUCURSAL=:SOLICITANTE_SUCURSAL, SOLICITANTE_TEL=:SOLICITANTE_TEL, SOLICITANTE_CEL=:SOLICITANTE_CEL, SOLICITANTE_EMAIL=:SOLICITANTE_EMAIL, SOLICITANTE_DIR=:SOLICITANTE_DIR, BARRIO=:BARRIO, PRESENTACION=:PRESENTACION, ANULADA=:ANULADA, USUARIO_ANUL=:USUARIO_ANUL, MODIFIED_BY=:MODIFIED_BY, FECHADEPENDENCIA=TO_DATE(:FECHADEPENDENCIA,'DD/MM/YYYY HH24:MI:SS'), HORASOLICITUD=TO_DATE(:HORASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), FECHASOLICITUD=TO_DATE(:FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), FECHAEXPEDICION=TO_DATE(:FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS'), FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), FECHANOTIFICACION=TO_DATE(:FECHANOTIFICACION,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHA_ANUL=TO_DATE(:FECHA_ANUL,'DD/MM/YYYY HH24:MI:SS') WHERE SP_SOLICITUDSERVICIO.COMPANIA= :KEY_COMPANIA AND SP_SOLICITUDSERVICIO.CLASESOLICITUD= :KEY_CLASESOLICITUD AND SP_SOLICITUDSERVICIO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

