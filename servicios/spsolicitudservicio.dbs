		<param defaultValue="0" name="INDALC" sqlType="STRING"/>
		<param defaultValue="0" name="INDAS" sqlType="STRING"/>
		<param defaultValue="" name="NUMMEDIDOR" sqlType="STRING"/>
		<param defaultValue="0" name="EXISTEREDALCANTARILLADO" sqlType="STRING"/>
		<param defaultValue="" name="PRIMERAPELLIDO" sqlType="STRING"/>
		<param defaultValue="" name="SEGUNDOAPELLIDO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRES" sqlType="STRING"/>
		<param defaultValue="" name="USUARIO" sqlType="STRING"/>
		<param defaultValue="" name="ESTADOAPROBADO" sqlType="STRING"/>
		<param defaultValue="" name="SECTORHIDRAULICO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGORUTA" sqlType="STRING"/>
		<param defaultValue="" name="SECTHIDRAULICO" sqlType="STRING"/>
		<param defaultValue="" name="SUBSECTOR" sqlType="STRING"/>
		<param defaultValue="" name="REDHIDRAULICA" sqlType="STRING"/>
		<param defaultValue="" name="SECCION" sqlType="STRING"/>
