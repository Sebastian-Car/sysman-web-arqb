<data name="tipobeneficios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipobeneficiosListatodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT ID_DE_TIPO, DESCRIPCION FROM TIPOS_BENEFICIOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_TIPO":"$ID_DE_TIPO(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
 
	</query>
	<resource method="GET" path="tipobeneficios/listatodos">
		<call-query href="getTipobeneficiosListatodosQuery">
 
		</call-query>
	</resource>

</data>