			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetformatotipocomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT FORMATO FROM TIPO_COMPROBANTE WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND DOCSOPORTE NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FORMATO":"$FORMATO"}]}}		</result>
