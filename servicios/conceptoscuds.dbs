	<query id="getConceptoscudsGetmaxconsecutivodianQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(MAX(CONSECUTIVODIAN), 0) MAXCONSECUTIVO FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANIO</sql>
