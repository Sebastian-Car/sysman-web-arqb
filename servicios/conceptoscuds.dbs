	</resource>
	<query id="getConceptoscudsGetinfocomplementarianotasinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT F.TIPO, F.CREATED_BY, F.COMPANIA, F.TERCERO AS NUMTERCERO, (TO_CHAR(F.FECHA,'DD/MM/YYYY HH24:MI:SS')) AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS VALORUNITARIO, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS TOTALITEM, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, TER.CIUDAD CIUDADTERCERO, TER.DEPARTAMENTO DEPTOTERCERO, TER.REGIMEN REGIMENTERCERO, TER.NOMBRE1 RAZONSOCIAL, TER.NATURALEZA NATURALEZATERCERO, TER.NOMBRE NOMBRETERCERO, TER.APELLIDO1 APELLIDO1TERCERO, TER.APELLIDO2 APELLIDO2TERCERO, TER.DIRECCION DIRECCIONTERCERO, TER.CODIGOPOSTAL CODIGOPOSTALTERCERO, TER.DIRECCIONEMAIL EMAILTERCERO, TER.DIGITOVERIFICACION DIGITOVERIFICACIONTERCERO, P.CODIGODIAN PAISTERCERO, (TO_CHAR(F.FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, T.CODIGO AS TIPOCOBRO, RET.NOM_TIPORETENCION, RET.NOMBRE_RETENCION, RET.TIPORETENCION, RET.CODIGORETENCION, RET.VALOR, RET.VALORBASE, CPN.DIRECCION DIRECCIONCOMPANIA, CPN.CIUDAD CIUDADCOMPANIA, CPN.DEPARTAMENTO DEPTOCOMPANIA, F.PREFIJODIAN, F.CONSECUTIVODIAN, (CASE WHEN INSTR(CPN.NITCOMPANIA,'-', 1) &gt; 0 THEN SUBSTR(CPN.NITCOMPANIA,INSTR(CPN.NITCOMPANIA,'-', 1)+1, LENGTH(CPN.NITCOMPANIA)) ELSE '0' END) DIGITOVERIFICACIONCOMPANIA FROM ( ( ( ( TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON ( T.COMPANIA = F.COMPANIA ) AND ( T.CODIGO = F.TIPO ) ) INNER JOIN DETALLE_COMPROBANTE_CNT D ON ( F.COMPANIA = D.COMPANIA ) AND ( F.ANO = D.ANO ) AND ( F.TIPO = D.TIPO_CPTE ) AND ( F.NUMERO = D.COMPROBANTE ) ) INNER JOIN TERCERO TER ON ( F.COMPANIA = TER.COMPANIA ) AND ( F.TERCERO = TER.NIT ) AND ( F.SUCURSAL = TER.SUCURSAL ) INNER JOIN PAISES P ON (P.PAIS = TER.PAIS) INNER JOIN COMPANIA CPN ON ( F.COMPANIA = CPN.CODIGO ) ) LEFT JOIN V_QRY_RETENCIONES_DS RET ON ( D.CUENTA = RET.CUENTA_CREDITO ) AND ( D.COMPROBANTE = RET.NUMERO ) AND ( D.TIPO_CPTE = RET.TIPO ) AND ( D.ANO = RET.ANO ) AND ( D.COMPANIA = RET.COMPANIA ) ) LEFT JOIN CONCEPTOS_CUDS C ON ( D.COMPANIA = C.COMPANIA ) AND ( D.ANO = C.ANO ) AND ( D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO ) WHERE F.COMPANIA = :COMPANIA AND F.NUMERO = :NUMEROFACTURA AND F.TIPO = :TIPOCOMPROBANTE AND NOT C.CODIGO_CONCEPTO IS NULL GROUP BY F.TIPO, F.CREATED_BY, F.COMPANIA, F.TERCERO, F.FECHA, F.NUMERO, C.CODIGO_CONCEPTO, C.NOMBRE_CONCEPTO, F.DESCRIPCION, TER.TELEFONOS, TER.CIUDAD , TER.DEPARTAMENTO , TER.REGIMEN , TER.NOMBRE1 , TER.NATURALEZA , TER.NOMBRE , TER.APELLIDO1 , TER.APELLIDO2, TER.DIRECCION , TER.CODIGOPOSTAL , TER.DIRECCIONEMAIL , TER.DIGITOVERIFICACION, P.CODIGODIAN , F.FECHA_VCN_DOC, T.CODIGO, RET.NOM_TIPORETENCION, RET.NOMBRE_RETENCION, RET.TIPORETENCION, RET.CODIGORETENCION, RET.VALOR, RET.VALORBASE, CPN.DIRECCION , CPN.CIUDAD , CPN.DEPARTAMENTO , F.PREFIJODIAN, F.CONSECUTIVODIAN, (CASE WHEN INSTR(CPN.NITCOMPANIA,'-', 1) &gt; 0 THEN SUBSTR(CPN.NITCOMPANIA,INSTR(CPN.NITCOMPANIA,'-', 1)+1, LENGTH(CPN.NITCOMPANIA)) ELSE '0' END) ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","CREATED_BY":"$CREATED_BY","COMPANIA":"$COMPANIA","NUMTERCERO":"$NUMTERCERO","FECHAFACTURA":"$FECHAFACTURA","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CANTIDAD":"$CANTIDAD","DESCRIPCIONPRODUCTO":"$DESCRIPCIONPRODUCTO","VALORUNITARIO":"$VALORUNITARIO(type:integer)","TOTALITEM":"$TOTALITEM(type:integer)","SUBTOTAL":"$SUBTOTAL(type:integer)","PORCENTAJEIVAX":"$PORCENTAJEIVAX(type:double)","VALORIMPUESTO":"$VALORIMPUESTO(type:double)","PORCENTAJERETEFUENTEX":"$PORCENTAJERETEFUENTEX(type:double)","VALOR_RETEFUENTE":"$VALOR_RETEFUENTE(type:double)","PORCENTAJEICAX":"$PORCENTAJEICAX(type:double)","VALOR_ICA":"$VALOR_ICA(type:double)","PORCENTAJERETEIVADX":"$PORCENTAJERETEIVADX(type:double)","RETEIVA":"$RETEIVA(type:double)","PORCENTAJERETEICAX":"$PORCENTAJERETEICAX(type:double)","RETEICA":"$RETEICA(type:double)","PORCENTAJEINCX":"$PORCENTAJEINCX(type:double)","IMPUESTO_INC":"$IMPUESTO_INC(type:double)","DESCUENTOFACTURA":"$DESCUENTOFACTURA(type:double)","VALOR_DESCUENTO":"$VALOR_DESCUENTO(type:double)","OBSERVACIONES":"$OBSERVACIONES","DESCUENTO":"$DESCUENTO(type:double)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO(type:double)","TELEFONOS":"$TELEFONOS","CIUDADTERCERO":"$CIUDADTERCERO","DEPTOTERCERO":"$DEPTOTERCERO","REGIMENTERCERO":"$REGIMENTERCERO","RAZONSOCIAL":"$RAZONSOCIAL","NATURALEZATERCERO":"$NATURALEZATERCERO","NOMBRETERCERO":"$NOMBRETERCERO","APELLIDO1TERCERO":"$APELLIDO1TERCERO","APELLIDO2TERCERO":"$APELLIDO2TERCERO","DIRECCIONTERCERO":"$DIRECCIONTERCERO","CODIGOPOSTALTERCERO":"$CODIGOPOSTALTERCERO","EMAILTERCERO":"$EMAILTERCERO","DIGITOVERIFICACIONTERCERO":"$DIGITOVERIFICACIONTERCERO(type:long)","PAISTERCERO":"$PAISTERCERO","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","BASEIMPUESTO":"$BASEIMPUESTO(type:double)","BASEIMPUESTOIVA":"$BASEIMPUESTOIVA(type:double)","BASEIMPUESTORETEFUENTE":"$BASEIMPUESTORETEFUENTE(type:double)","BASEIMPUESTOICA":"$BASEIMPUESTOICA(type:double)","BASEIMPUESTORETEIVA":"$BASEIMPUESTORETEIVA(type:double)","BASEIMPUESTOINC":"$BASEIMPUESTOINC(type:double)","BASEIMPUESTORETEICA":"$BASEIMPUESTORETEICA(type:double)","TIPOCOBRO":"$TIPOCOBRO","NOM_TIPORETENCION":"$NOM_TIPORETENCION","NOMBRE_RETENCION":"$NOMBRE_RETENCION","TIPORETENCION":"$TIPORETENCION","CODIGORETENCION":"$CODIGORETENCION","VALOR":"$VALOR","VALORBASE":"$VALORBASE","DIRECCIONCOMPANIA":"$DIRECCIONCOMPANIA","CIUDADCOMPANIA":"$CIUDADCOMPANIA","DEPTOCOMPANIA":"$DEPTOCOMPANIA","PREFIJODIAN":"$PREFIJODIAN","CONSECUTIVODIAN":"$CONSECUTIVODIAN","DIGITOVERIFICACIONCOMPANIA":"$DIGITOVERIFICACIONCOMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getinfocomplementarianotasinvoway">
		<call-query href="getConceptoscudsGetinfocomplementarianotasinvowayQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsTipocomprobantenotaajusteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPROBANTE_CNT.TIPO ,NUMERO FROM TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNT ON COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO AND COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA WHERE NUMERO = :COMPROBANTE AND TIPO_COMPROBANTE.NOTAAJUSTE_CUDS &lt;&gt;0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/tipocomprobantenotaajuste">
		<call-query href="getConceptoscudsTipocomprobantenotaajusteQuery">
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGettodosnotasajusteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  F.TERCERO AS NUMTERCERO, F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, F.CONSECUTIVODIAN, F.PREFIJODIAN AS PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, C.CODIGO_EQUIVALENTE_DIAN AS CODIGOPRODUCTODIAN, T.CODIGO AS TIPOCOBRO  FROM COMPROBANTE_CNT F INNER JOIN TIPO_COMPROBANTE T ON T.CODIGO = F.TIPO AND T.COMPANIA = F.COMPANIA INNER JOIN DETALLE_COMPROBANTE_CNT D ON F.NUMERO = D.COMPROBANTE AND F.TIPO = D.TIPO_CPTE AND F.ANO = D.ANO AND F.COMPANIA = D.COMPANIA AND D.CONCEPTO_CUDS IS NOT NULL LEFT JOIN CONCEPTOS_CUDS C ON D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO AND D.ANO = C.ANO AND D.COMPANIA = C.COMPANIA WHERE F.COMPANIA = :COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.NOTAAJUSTE_CUDS NOT IN(0) ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMTERCERO":"$NUMTERCERO","FECHAFACTURA":"$FECHAFACTURA","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","CONSECUTIVODIAN":"$CONSECUTIVODIAN","PREFIJO":"$PREFIJO","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOPRODUCTODIAN":"$CODIGOPRODUCTODIAN","TIPOCOBRO":"$TIPOCOBRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/gettodosnotasajuste">
		<call-query href="getConceptoscudsGettodosnotasajusteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetitemsfacturaaenviarnotasQuery"  useConfig="sysmandsunist">
		<sql>SELECT C.CODIGO_CONCEPTO CODIGOPRODUCTO, C.NOMBRE_CONCEPTO DESCRIPCIONPRODUCTO, D2.BASE_IVA BASEIMPUESTOIVA, 0 AS VALOR_DESCUENTO, CASE WHEN F2.VLR_BASEIVA &gt; 0 THEN F2.PORCIVA ELSE 0 END PORCENTAJEIVAX, (REPLACE(D2.VALOR_DEBITO, '.', ',') - REPLACE(D2.BASE_IVA, '.', ',')) VALORUNITARIO, REPLACE(D2.VALOR_DEBITO, ',', '.') TOTALITEM, TO_CHAR(F.FECHA, 'dd/MM/yyyy') FECHA FROM ( ( ( RESOLUCIONDIAN_CT R INNER JOIN ( ( TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON ( T.COMPANIA = F.COMPANIA ) AND ( T.CODIGO = F.TIPO ) ) INNER JOIN DETALLE_COMPROBANTE_CNT D ON ( F.COMPANIA = D.COMPANIA ) AND ( F.ANO = D.ANO ) AND ( F.TIPO = D.TIPO_CPTE ) AND ( F.NUMERO = D.COMPROBANTE ) ) ON ( R.COMPANIA = T.COMPANIA ) AND ( R.TIPOCOMPROBANTE = T.CODIGO ) AND F.FECHA BETWEEN R.FECHAINICIAL AND R.FECHAFINAL) INNER JOIN TERCERO TER ON ( F.COMPANIA = TER.COMPANIA ) AND ( F.TERCERO = TER.NIT ) AND ( F.SUCURSAL = TER.SUCURSAL ) ) LEFT JOIN CONCEPTOS_CUDS C ON (D.COMPANIA = C.COMPANIA) AND ( D.ANO = C.ANO ) AND ( D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO ) LEFT JOIN COMPROBANTE_CNT F2 ON F2.COMPANIA = D.COMPANIA AND F2.TIPO = D.TIPO_CPTE_AFECT AND F2.NUMERO = D.CMPTE_AFECTADO AND F2.ANO = D.ANO_AFECT LEFT JOIN DETALLE_COMPROBANTE_CNT D2 ON D2.COMPANIA = F2.COMPANIA AND D2.ANO = F2.ANO AND D2.TIPO_CPTE = F2.TIPO AND D2.COMPROBANTE = F2.NUMERO AND D2.CONCEPTO_CUDS = D.CONCEPTO_CUDS ) WHERE F.COMPANIA = :COMPANIA AND T.NOTAAJUSTE_CUDS NOT IN ( 0 ) AND F.NUMERO = :NUMEROFACTURA AND T.CODIGO = :TIPOCOBRO AND C.CODIGO_CONCEPTO IS NOT NULL ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOPRODUCTO":"$CODIGOPRODUCTO","DESCRIPCIONPRODUCTO":"$DESCRIPCIONPRODUCTO","BASEIMPUESTOIVA":"$BASEIMPUESTOIVA","VALOR_DESCUENTO":"$VALOR_DESCUENTO(type:double)","PORCENTAJEIVAX":"$PORCENTAJEIVAX(type:double)","VALORUNITARIO":"$VALORUNITARIO(type:integer)","TOTALITEM":"$TOTALITEM","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getitemsfacturaaenviarnotas">
		<call-query href="getConceptoscudsGetitemsfacturaaenviarnotasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>

</data>