<data name="conceptoscuds" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertConceptoscudsInsertprepararaniosiguiente" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONCEPTOS_CUDS ( COMPANIA, ANO, CODIGO_CONCEPTO, NOMBRE_CONCEPTO, CODIGO_EQUIVALENTE_DIAN, CUENTA_CONTABLE, CREATED_BY, DATE_CREATED ) SELECT COMPANIA, :ANOPREPARAR, CODIGO_CONCEPTO, NOMBRE_CONCEPTO, CODIGO_EQUIVALENTE_DIAN, CUENTA_CONTABLE, :CREATED_BY, TO_DATE(:DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS') FROM CONCEPTOS_CUDS WHERE COMPANIA = :COMPANIA AND ANO = :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANOPREPARAR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="conceptoscuds/insertprepararaniosiguiente">
		<call-query href="insertConceptoscudsInsertprepararaniosiguiente">
			<with-param name="ANOPREPARAR" query-param="ANOPREPARAR"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsPreparconsultafacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT F.TERCERO AS NUMTERCERO, F.NUMERO AS NUMEROFACTURA, R.PREFIJO, C.CODIGO_EQUIVALENTE_DIAN AS CODIGOPRODUCTODIAN FROM (((RESOLUCIONDIAN_CT R INNER JOIN ((TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON (T.CODIGO = F.TIPO) AND (T.COMPANIA = F.COMPANIA)) INNER JOIN DETALLE_COMPROBANTE_CNT D ON (F.NUMERO = D.COMPROBANTE) AND (F.TIPO = D.TIPO_CPTE) AND (F.ANO = D.ANO) AND (F.COMPANIA = D.COMPANIA) AND (D.CONCEPTO_CUDS IS NOT NULL)) ON (R.TIPOCOMPROBANTE = T.CODIGO) AND (R.COMPANIA = T.COMPANIA)) INNER JOIN TERCERO TER ON (F.SUCURSAL = TER.SUCURSAL) AND (F.TERCERO = TER.NIT) AND (F.COMPANIA = TER.COMPANIA)) LEFT JOIN (SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ((TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON (TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA) AND (TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO)) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO) INNER JOIN RETENCIONES ON (COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA) AND (COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO) AND (COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO) AND (COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO) WHERE (((TIPO_COMPROBANTE.DOCSOPORTE) NOT IN (0)))) QRY_RETENCIONES_DS ON (D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA) AND (D.ANO = QRY_RETENCIONES_DS.ANO) AND (D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO) AND (D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO) AND (D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO)) LEFT JOIN CONCEPTOS_CUDS C ON (D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO) AND (D.ANO = C.ANO) AND (D.COMPANIA = C.COMPANIA) WHERE F.COMPANIA=:COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN (0) AND F.NUMERO = :NUMEROFACTURA ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMTERCERO":"$NUMTERCERO","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","PREFIJO":"$PREFIJO","CODIGOPRODUCTODIAN":"$CODIGOPRODUCTODIAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/preparconsultafactura">
		<call-query href="getConceptoscudsPreparconsultafacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetfacturasverificacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT 'SYSMAN' AS CREATEDBY, '830005370' AS NUMEROCONTRIBUYENTE, F.TERCERO AS NUMTERCERO, F.CONSECUTIVODIAN AS NUMEROFACTURA, R.TIPO_MEDIOPAGO AS MEDIOPAGO, F.PREFIJODIAN AS PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO FROM (((RESOLUCIONDIAN_CT R INNER JOIN ((TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON (T.COMPANIA = F.COMPANIA) AND (T.CODIGO = F.TIPO)) INNER JOIN DETALLE_COMPROBANTE_CNT D ON (F.COMPANIA = D.COMPANIA) AND (F.ANO = D.ANO) AND (F.TIPO = D.TIPO_CPTE) AND (F.NUMERO = D.COMPROBANTE)) ON (R.COMPANIA = T.COMPANIA) AND (R.TIPOCOMPROBANTE = T.CODIGO)) INNER JOIN TERCERO TER ON (F.COMPANIA = TER.COMPANIA) AND (F.TERCERO = TER.NIT) AND (F.SUCURSAL = TER.SUCURSAL)) LEFT JOIN ( SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ( ( TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON ( TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA ) AND ( TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO ) ) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO ) INNER JOIN RETENCIONES ON ( COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA ) AND ( COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO ) AND ( COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO ) AND ( COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO ) WHERE ( ( ( TIPO_COMPROBANTE.DOCSOPORTE ) NOT IN ( 0 ) ) )) QRY_RETENCIONES_DS ON (D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO) AND (D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO) AND (D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO) AND (D.ANO = QRY_RETENCIONES_DS.ANO) AND (D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA)) LEFT JOIN CONCEPTOS_CUDS C ON (D.COMPANIA = C.COMPANIA) AND (D.ANO = C.ANO) AND (D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO) WHERE F.COMPANIA=:COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN ( 0 ) ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREATEDBY":"$CREATEDBY","NUMEROCONTRIBUYENTE":"$NUMEROCONTRIBUYENTE","NUMTERCERO":"$NUMTERCERO","NUMEROFACTURA":"$NUMEROFACTURA","MEDIOPAGO":"$MEDIOPAGO","PREFIJO":"$PREFIJO","CODIGOPRODUCTO":"$CODIGOPRODUCTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getfacturasverificacion">
		<call-query href="getConceptoscudsGetfacturasverificacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsPagGetconceptoscudspaginadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCEPTOS_CUDS.CODIGO_CONCEPTO, CONCEPTOS_CUDS.NOMBRE_CONCEPTO, CONCEPTOS_CUDS.CODIGO_EQUIVALENTE_DIAN FROM CONCEPTOS_CUDS WHERE CONCEPTOS_CUDS.COMPANIA = :COMPANIA AND CONCEPTOS_CUDS.ANO = :ANIO AND CONCEPTOS_CUDS.CUENTA_CONTABLE =:CODIGOCUENTA ORDER BY CONCEPTOS_CUDS.CODIGO_CONCEPTO) INI WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END) LIKE UPPER(CONCAT(:CODIGO_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN CODIGO_EQUIVALENTE_DIAN IS NULL THEN ' ' ELSE UPPER(CODIGO_EQUIVALENTE_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_EQUIVALENTE_DIAN), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CODIGO_EQUIVALENTE_DIAN":"$CODIGO_EQUIVALENTE_DIAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGOCUENTA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CODIGO_EQUIVALENTE_DIAN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptoscuds/getconceptoscudspaginado/pag">
		<call-query href="getConceptoscudsPagGetconceptoscudspaginadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGOCUENTA" query-param="CODIGOCUENTA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODIGO_EQUIVALENTE_DIAN" query-param="CODIGO_EQUIVALENTE_DIAN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsNumGetconceptoscudspaginadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCEPTOS_CUDS.CODIGO_CONCEPTO, CONCEPTOS_CUDS.NOMBRE_CONCEPTO, CONCEPTOS_CUDS.CODIGO_EQUIVALENTE_DIAN FROM CONCEPTOS_CUDS WHERE CONCEPTOS_CUDS.COMPANIA = :COMPANIA AND CONCEPTOS_CUDS.ANO = :ANIO AND CONCEPTOS_CUDS.CUENTA_CONTABLE =:CODIGOCUENTA ORDER BY CONCEPTOS_CUDS.CODIGO_CONCEPTO) INI WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END) LIKE UPPER(CONCAT(:CODIGO_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN CODIGO_EQUIVALENTE_DIAN IS NULL THEN ' ' ELSE UPPER(CODIGO_EQUIVALENTE_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_EQUIVALENTE_DIAN), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGOCUENTA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CODIGO_EQUIVALENTE_DIAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getconceptoscudspaginado/num">
		<call-query href="getConceptoscudsNumGetconceptoscudspaginadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGOCUENTA" query-param="CODIGOCUENTA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODIGO_EQUIVALENTE_DIAN" query-param="CODIGO_EQUIVALENTE_DIAN"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetdatosfactdocsoporteQuery"  useConfig="sysmandsunist">
		<sql>SELECT FACT_SYSMAN.CREATEDBY CREATED_BY,(TO_CHAR(FACT_SYSMAN.FECHAFACTURA,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURA, FACT_SYSMAN.NUMEROFACTURA, FACT_SYSMAN.MEDIOPAGO, FACT_SYSMAN.NUMTERCERO, FACT_SYSMAN.PREFIJO,(TO_CHAR(FACT_SYSMAN.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, FACT_SYSMAN.TELEFONOS, FACT_SYSMAN.DESCUENTOFACTURA, FACT_SYSMAN.TIPO_MONEDA, FACT_SYSMAN.OBSERVACIONES, FACT_SYSMAN.TIPO_PAGO, FACT_SYSMAN.TIPOFACDIAN, FACT_SYSMAN.TIPODOCDIAN FROM (SELECT F.CREATED_BY AS CREATEDBY, :NITCOMPANIA AS NUMEROCONTRIBUYENTE, F.TERCERO AS NUMTERCERO, F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, R.TIPO_MEDIOPAGO AS MEDIOPAGO, R.PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, D.VALOR_DEBITO + D.VALOR_CREDITO AS VALORUNITARIO, D.VALOR_DEBITO + D.VALOR_CREDITO AS TOTALITEM, D.VALOR_DEBITO + D.VALOR_CREDITO AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, R.TIPO_PAGO, R.TIPO_MONEDA, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VCN_DOC AS FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, R.TIPOFACDIAN, T.CODIGO AS TIPOCOBRO, '05' AS TIPODOCDIAN, QRY_RETENCIONES_DS.NOM_TIPORETENCION, QRY_RETENCIONES_DS.NOMBRE_RETENCION, QRY_RETENCIONES_DS.TIPORETENCION, QRY_RETENCIONES_DS.CODIGORETENCION, QRY_RETENCIONES_DS.VALOR, QRY_RETENCIONES_DS.VALORBASE FROM (((RESOLUCIONDIAN_CT R INNER JOIN ((TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON (T.COMPANIA = F.COMPANIA) AND (T.CODIGO = F.TIPO)) INNER JOIN DETALLE_COMPROBANTE_CNT D ON (F.COMPANIA = D.COMPANIA) AND (F.ANO = D.ANO) AND (F.TIPO = D.TIPO_CPTE) AND (F.NUMERO = D.COMPROBANTE)) ON (R.COMPANIA = T.COMPANIA) AND (R.TIPOCOMPROBANTE = T.CODIGO)) INNER JOIN TERCERO TER ON (F.COMPANIA = TER.COMPANIA) AND (F.TERCERO = TER.NIT) AND (F.SUCURSAL = TER.SUCURSAL)) LEFT JOIN ( SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ( ( TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON ( TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA ) AND ( TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO ) ) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO ) INNER JOIN RETENCIONES ON ( COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA ) AND ( COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO ) AND ( COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO ) AND ( COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO ) WHERE ( ( ( TIPO_COMPROBANTE.DOCSOPORTE ) NOT IN ( 0 ) ) )) QRY_RETENCIONES_DS ON (D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO) AND (D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO) AND (D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO) AND (D.ANO = QRY_RETENCIONES_DS.ANO) AND (D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA)) LEFT JOIN CONCEPTOS_CUDS C ON (D.COMPANIA = C.COMPANIA) AND (D.ANO = C.ANO) AND (D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO) WHERE F.COMPANIA=:COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN ( 0 ) ORDER BY F.NUMERO) FACT_SYSMAN WHERE NUMEROCONTRIBUYENTE= :NITCOMPANIA AND TIPOCOBRO = :TIPOCOBRO AND FACT_SYSMAN.NUMEROFACTURA= :NUMEROFACTURA AND FECHAFACTURA BETWEEN :FECHAINI AND :FECHAFIN GROUP BY FACT_SYSMAN.CREATEDBY, FACT_SYSMAN.FECHAFACTURA, FACT_SYSMAN.NUMEROFACTURA, FACT_SYSMAN.NUMTERCERO,FACT_SYSMAN.PREFIJO,FACT_SYSMAN.FECHA_VENCIMIENTO,FACT_SYSMAN.TELEFONOS, FACT_SYSMAN.DESCUENTOFACTURA,TIPO_MONEDA,OBSERVACIONES,TIPO_PAGO,MEDIOPAGO,FACT_SYSMAN.TIPOFACDIAN, FACT_SYSMAN.TIPODOCDIAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREATED_BY":"$CREATED_BY","FECHAFACTURA":"$FECHAFACTURA","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","MEDIOPAGO":"$MEDIOPAGO","NUMTERCERO":"$NUMTERCERO","PREFIJO":"$PREFIJO","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","TELEFONOS":"$TELEFONOS","DESCUENTOFACTURA":"$DESCUENTOFACTURA(type:double)","TIPO_MONEDA":"$TIPO_MONEDA","OBSERVACIONES":"$OBSERVACIONES","TIPO_PAGO":"$TIPO_PAGO","TIPOFACDIAN":"$TIPOFACDIAN","TIPODOCDIAN":"$TIPODOCDIAN"}]}}		</result>
		<param name="NITCOMPANIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getdatosfactdocsoporte">
		<call-query href="getConceptoscudsGetdatosfactdocsoporteQuery">
			<with-param name="NITCOMPANIA" query-param="NITCOMPANIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetitemsfacturaaenviarQuery"  useConfig="sysmandsunist">
		<sql>SELECT C.CODIGO_CONCEPTO CODIGOPRODUCTO, C.NOMBRE_CONCEPTO DESCRIPCIONPRODUCTO, D.BASE_IVA BASEIMPUESTOIVA, CASE WHEN F.VLR_BASEIVA &gt; 0 THEN F.PORCIVA ELSE 0 END PORCIVA, (D.VALOR_DEBITO - D.BASE_IVA) VALORUNITARIO, REPLACE(D.VALOR_DEBITO,',','.') TOTALITEM, TO_CHAR(F.FECHA, 'dd/MM/yyyy') FECHA FROM ( ( ( RESOLUCIONDIAN_CT R INNER JOIN ( ( TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON ( T.COMPANIA = F.COMPANIA ) AND ( T.CODIGO = F.TIPO ) ) INNER JOIN DETALLE_COMPROBANTE_CNT D ON ( F.COMPANIA = D.COMPANIA ) AND ( F.ANO = D.ANO ) AND ( F.TIPO = D.TIPO_CPTE ) AND ( F.NUMERO = D.COMPROBANTE ) ) ON ( R.COMPANIA = T.COMPANIA ) AND ( R.TIPOCOMPROBANTE = T.CODIGO ) AND F.FECHA BETWEEN R.FECHAINICIAL AND R.FECHAFINAL) INNER JOIN TERCERO TER ON ( F.COMPANIA = TER.COMPANIA ) AND ( F.TERCERO = TER.NIT ) AND ( F.SUCURSAL = TER.SUCURSAL ) ) LEFT JOIN CONCEPTOS_CUDS C ON (D.COMPANIA = C.COMPANIA) AND ( D.ANO = C.ANO ) AND ( D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO )) WHERE F.COMPANIA = :COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN ( 0 ) AND F.NUMERO = :NUMEROFACTURA AND T.CODIGO = :TIPOCOBRO AND C.CODIGO_CONCEPTO IS NOT NULL ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOPRODUCTO":"$CODIGOPRODUCTO","DESCRIPCIONPRODUCTO":"$DESCRIPCIONPRODUCTO","BASEIMPUESTOIVA":"$BASEIMPUESTOIVA","PORCIVA":"$PORCIVA","VALORUNITARIO":"$VALORUNITARIO","TOTALITEM":"$TOTALITEM","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getitemsfacturaaenviar">
		<call-query href="getConceptoscudsGetitemsfacturaaenviarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetinpuestoscargosafacturarQuery"  useConfig="sysmandsunist">
		<sql>SELECT REPLACE(SUM(NVL(SUBTOTAL,0)-NVL(VALOR_DESCUENTO,0)),',','.') AS SUBTOTALFACTURA , SUM(VALORIMPUESTO) AS IVA, SUM(VALOR_RETEFUENTE) AS RETE, SUM(NVL(VALOR_ICA,0)) AS ICA, SUM(NVL(RETEIVA,0)) AS RETE_IVA, SUM(NVL(RETEICA,0)) AS RETE_ICA, SUM(NVL(IMPUESTO_INC,0)) AS INC, SUM(NVL(VALOR_DESCUENTO,0)) AS DESCUENTOPARCIAL, SUM(NVL(DESCUENTOFACTURA,0)) AS DESCUENTO_FACTURA, REPLACE(SUM(NVL(TOTALITEM,0)),',','.') AS TOTAL, SUM(FACT_SYSMAN.BASEIMPUESTOIVA) AS BASEGRAVABLEIVA, SUM(FACT_SYSMAN.BASEIMPUESTORETEFUENTE) AS BASEGRAVABLERETE, SUM(FACT_SYSMAN.BASEIMPUESTOICA) AS BASEGRAVABLEICA, SUM(FACT_SYSMAN.BASEIMPUESTORETEIVA) AS BASEGRAVABLERETEIVA, SUM(FACT_SYSMAN.BASEIMPUESTORETEICA) AS BASEGRAVABLERETEICA, SUM(FACT_SYSMAN.BASEIMPUESTOINC) AS BASEGRAVABLEINC, SUM(NVL(FACT_SYSMAN.BASEIMPUESTOIVA,0)+NVL(FACT_SYSMAN.BASEIMPUESTORETEFUENTE,0)+NVL(FACT_SYSMAN.BASEIMPUESTOICA,0)+NVL(FACT_SYSMAN.BASEIMPUESTORETEIVA,0)+NVL(FACT_SYSMAN.BASEIMPUESTORETEICA,0)+NVL(FACT_SYSMAN.BASEIMPUESTOINC,0)) AS BASEIMPONIBLE FROM (SELECT 'SYSMAN' AS CREATEDBY, '830005370' AS NUMEROCONTRIBUYENTE, F.TERCERO AS NUMTERCERO, F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, R.TIPO_MEDIOPAGO AS MEDIOPAGO, R.PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, D.VALOR_DEBITO + D.VALOR_CREDITO AS VALORUNITARIO, D.VALOR_DEBITO + D.VALOR_CREDITO AS TOTALITEM, ((D.VALOR_DEBITO + D.VALOR_CREDITO)-D.BASE_IVA) AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, R.TIPO_PAGO, R.TIPO_MONEDA, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VCN_DOC AS FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, R.TIPOFACDIAN, T.CODIGO AS TIPOCOBRO, '05' AS TIPODOCDIAN, QRY_RETENCIONES_DS.NOM_TIPORETENCION, QRY_RETENCIONES_DS.NOMBRE_RETENCION, QRY_RETENCIONES_DS.TIPORETENCION, QRY_RETENCIONES_DS.CODIGORETENCION, QRY_RETENCIONES_DS.VALOR, QRY_RETENCIONES_DS.VALORBASE FROM (((RESOLUCIONDIAN_CT R INNER JOIN ((TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON (T.COMPANIA = F.COMPANIA) AND (T.CODIGO = F.TIPO)) INNER JOIN DETALLE_COMPROBANTE_CNT D ON (F.COMPANIA = D.COMPANIA) AND (F.ANO = D.ANO) AND (F.TIPO = D.TIPO_CPTE) AND (F.NUMERO = D.COMPROBANTE)) ON (R.COMPANIA = T.COMPANIA) AND (R.TIPOCOMPROBANTE = T.CODIGO) AND F.FECHA BETWEEN R.FECHAINICIAL AND R.FECHAFINAL ) INNER JOIN TERCERO TER ON (F.COMPANIA = TER.COMPANIA) AND (F.TERCERO = TER.NIT) AND (F.SUCURSAL = TER.SUCURSAL)) LEFT JOIN ( SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ( ( TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON ( TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA ) AND ( TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO ) ) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO ) INNER JOIN RETENCIONES ON ( COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA ) AND ( COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO ) AND ( COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO ) AND ( COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO ) WHERE ( ( ( TIPO_COMPROBANTE.DOCSOPORTE ) NOT IN ( 0 ) ) )) QRY_RETENCIONES_DS ON (D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO) AND (D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO) AND (D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO) AND (D.ANO = QRY_RETENCIONES_DS.ANO) AND (D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA)) LEFT JOIN CONCEPTOS_CUDS C ON (D.COMPANIA = C.COMPANIA) AND (D.ANO = C.ANO) AND (D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO) WHERE F.COMPANIA=:COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN ( 0 ) AND T.CODIGO = :TIPOCOBRO ORDER BY F.NUMERO) FACT_SYSMAN WHERE NUMEROFACTURA = :NUMEROFACTURA AND FECHAFACTURA BETWEEN :FECHAINI AND :FECHAFIN AND NOT CODIGOPRODUCTO IS NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUBTOTALFACTURA":"$SUBTOTALFACTURA","IVA":"$IVA(type:integer)","RETE":"$RETE(type:integer)","ICA":"$ICA(type:integer)","RETE_IVA":"$RETE_IVA(type:integer)","RETE_ICA":"$RETE_ICA(type:integer)","INC":"$INC(type:integer)","DESCUENTOPARCIAL":"$DESCUENTOPARCIAL(type:integer)","DESCUENTO_FACTURA":"$DESCUENTO_FACTURA(type:integer)","TOTAL":"$TOTAL","BASEGRAVABLEIVA":"$BASEGRAVABLEIVA(type:integer)","BASEGRAVABLERETE":"$BASEGRAVABLERETE(type:integer)","BASEGRAVABLEICA":"$BASEGRAVABLEICA(type:integer)","BASEGRAVABLERETEIVA":"$BASEGRAVABLERETEIVA(type:integer)","BASEGRAVABLERETEICA":"$BASEGRAVABLERETEICA(type:integer)","BASEGRAVABLEINC":"$BASEGRAVABLEINC(type:integer)","BASEIMPONIBLE":"$BASEIMPONIBLE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getinpuestoscargosafacturar">
		<call-query href="getConceptoscudsGetinpuestoscargosafacturarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetinpuestosretencionafacturarQuery"  useConfig="sysmandsunist">
		<sql>SELECT NOM_TIPORETENCION, TIPORETENCION, REPLACE(SUM(VALORBASE), ',','.') VALORBASE, REPLACE(SUM(VALOR), ',','.') VALOR, PCT_APLICAR FROM (SELECT 'SYSMAN' AS CREATEDBY, '830005370' AS NUMEROCONTRIBUYENTE, F.TERCERO AS NUMTERCERO, F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, R.TIPO_MEDIOPAGO AS MEDIOPAGO, R.PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, REPLACE(D.VALOR_DEBITO + D.VALOR_CREDITO,',','.') AS VALORUNITARIO, REPLACE(D.VALOR_DEBITO + D.VALOR_CREDITO, ',','.') AS TOTALITEM, REPLACE(D.VALOR_DEBITO + D.VALOR_CREDITO, ',' ,'.') AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, R.TIPO_PAGO, R.TIPO_MONEDA, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VCN_DOC AS FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, R.TIPOFACDIAN, T.CODIGO AS TIPOCOBRO, '05' AS TIPODOCDIAN, QRY_RETENCIONES_DS.PCT_APLICAR, QRY_RETENCIONES_DS.NOM_TIPORETENCION, QRY_RETENCIONES_DS.NOMBRE_RETENCION, QRY_RETENCIONES_DS.TIPORETENCION, QRY_RETENCIONES_DS.CODIGORETENCION, QRY_RETENCIONES_DS.VALOR, QRY_RETENCIONES_DS.VALORBASE FROM (((RESOLUCIONDIAN_CT R INNER JOIN ((TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON (T.COMPANIA = F.COMPANIA) AND (T.CODIGO = F.TIPO)) INNER JOIN DETALLE_COMPROBANTE_CNT D ON (F.COMPANIA = D.COMPANIA) AND (F.ANO = D.ANO) AND (F.TIPO = D.TIPO_CPTE) AND (F.NUMERO = D.COMPROBANTE)) ON (R.COMPANIA = T.COMPANIA) AND (R.TIPOCOMPROBANTE = T.CODIGO) AND F.FECHA BETWEEN R.FECHAINICIAL AND R.FECHAFINAL) INNER JOIN TERCERO TER ON (F.COMPANIA = TER.COMPANIA) AND (F.TERCERO = TER.NIT) AND (F.SUCURSAL = TER.SUCURSAL)) LEFT JOIN ( SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ( ( TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON ( TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA ) AND ( TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO ) ) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO ) INNER JOIN RETENCIONES ON ( COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA ) AND ( COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO ) AND ( COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO ) AND ( COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO ) WHERE ( ( ( TIPO_COMPROBANTE.DOCSOPORTE ) NOT IN ( 0 ) ) )) QRY_RETENCIONES_DS ON (D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO) AND (D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO) AND (D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO) AND (D.ANO = QRY_RETENCIONES_DS.ANO) AND (D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA)) LEFT JOIN CONCEPTOS_CUDS C ON (D.COMPANIA = C.COMPANIA) AND (D.ANO = C.ANO) AND (D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO) WHERE F.COMPANIA=:COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN ( 0 ) AND T.CODIGO = :TIPOCOBRO ORDER BY F.NUMERO) FACT_SYSMAN WHERE NUMEROFACTURA= :NUMEROFACTURA AND FECHAFACTURA BETWEEN :FECHAINI AND :FECHAFIN AND NOT TIPORETENCION IS NULL GROUP BY NOM_TIPORETENCION, TIPORETENCION,PCT_APLICAR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOM_TIPORETENCION":"$NOM_TIPORETENCION","TIPORETENCION":"$TIPORETENCION","VALORBASE":"$VALORBASE","VALOR":"$VALOR","PCT_APLICAR":"$PCT_APLICAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getinpuestosretencionafacturar">
		<call-query href="getConceptoscudsGetinpuestosretencionafacturarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>

		</call-query>
	</resource>
	<query id="insertConceptoscuds" keyColumns="ANO,COMPANIA,CODIGO_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONCEPTOS_CUDS (ANO, COMPANIA, CODIGO_CONCEPTO, NOMBRE_CONCEPTO, CODIGO_EQUIVALENTE_DIAN, CUENTA_CONTABLE, DATE_CREATED, CREATED_BY) VALUES (:ANO, :COMPANIA, :CODIGO_CONCEPTO, :NOMBRE_CONCEPTO, :CODIGO_EQUIVALENTE_DIAN, :CUENTA_CONTABLE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ANO":"$ANO","KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_CONCEPTO":"$CODIGO_CONCEPTO"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_EQUIVALENTE_DIAN" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="conceptoscuds">
		<call-query href="insertConceptoscuds">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODIGO_EQUIVALENTE_DIAN" query-param="CODIGO_EQUIVALENTE_DIAN"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConceptoscuds" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONCEPTOS_CUDS WHERE CONCEPTOS_CUDS.ANO= :KEY_ANO AND CONCEPTOS_CUDS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_CUDS.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="conceptoscuds">
		<call-query href="deleteConceptoscuds">
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONCEPTO" query-param="KEY_CODIGO_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TO_CHAR(ANO) ANO, COMPANIA, CODIGO_CONCEPTO, NOMBRE_CONCEPTO, CODIGO_EQUIVALENTE_DIAN, CUENTA_CONTABLE FROM CONCEPTOS_CUDS ORDER BY CODIGO_CONCEPTO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CONCEPTO), '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN CODIGO_EQUIVALENTE_DIAN IS NULL THEN ' ' ELSE UPPER(CODIGO_EQUIVALENTE_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_EQUIVALENTE_DIAN), '%')) AND (CASE WHEN CUENTA_CONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTA_CONTABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA_CONTABLE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO","COMPANIA":"$COMPANIA","CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CODIGO_EQUIVALENTE_DIAN":"$CODIGO_EQUIVALENTE_DIAN","CUENTA_CONTABLE":"$CUENTA_CONTABLE"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CODIGO_EQUIVALENTE_DIAN" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptoscuds">
		<call-query href="getConceptoscudsPaginaQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODIGO_EQUIVALENTE_DIAN" query-param="CODIGO_EQUIVALENTE_DIAN"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TO_CHAR(ANO) ANO, COMPANIA, CODIGO_CONCEPTO, NOMBRE_CONCEPTO, CODIGO_EQUIVALENTE_DIAN, CUENTA_CONTABLE FROM CONCEPTOS_CUDS ORDER BY CODIGO_CONCEPTO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CONCEPTO), '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN CODIGO_EQUIVALENTE_DIAN IS NULL THEN ' ' ELSE UPPER(CODIGO_EQUIVALENTE_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_EQUIVALENTE_DIAN), '%')) AND (CASE WHEN CUENTA_CONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTA_CONTABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA_CONTABLE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CODIGO_EQUIVALENTE_DIAN" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/numero">
		<call-query href="getConceptoscudsNumeroQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODIGO_EQUIVALENTE_DIAN" query-param="CODIGO_EQUIVALENTE_DIAN"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT ANO, COMPANIA, CODIGO_CONCEPTO, NOMBRE_CONCEPTO, CODIGO_EQUIVALENTE_DIAN, CUENTA_CONTABLE FROM CONCEPTOS_CUDS WHERE CONCEPTOS_CUDS.ANO= :KEY_ANO AND CONCEPTOS_CUDS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_CUDS.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:double)","COMPANIA":"$COMPANIA","CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CODIGO_EQUIVALENTE_DIAN":"$CODIGO_EQUIVALENTE_DIAN","CUENTA_CONTABLE":"$CUENTA_CONTABLE"}]}}		</result>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/data">
		<call-query href="getConceptoscudsRegistroQuery">
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONCEPTO" query-param="KEY_CODIGO_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateConceptoscuds" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONCEPTOS_CUDS SET ANO=:ANO, COMPANIA=:COMPANIA, CODIGO_CONCEPTO=:CODIGO_CONCEPTO, NOMBRE_CONCEPTO=:NOMBRE_CONCEPTO, CODIGO_EQUIVALENTE_DIAN=:CODIGO_EQUIVALENTE_DIAN, CUENTA_CONTABLE=:CUENTA_CONTABLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONCEPTOS_CUDS.ANO= :KEY_ANO AND CONCEPTOS_CUDS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS_CUDS.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CODIGO_EQUIVALENTE_DIAN" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="conceptoscuds">
		<call-query href="updateConceptoscuds">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CODIGO_EQUIVALENTE_DIAN" query-param="CODIGO_EQUIVALENTE_DIAN"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONCEPTO" query-param="KEY_CODIGO_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetinformacioncomplementariaafacturarQuery"  useConfig="sysmandsunist">
		<sql>SELECT REPLACE(SUM(NVL(SUBTOTAL,0)-NVL(VALOR_DESCUENTO,0)),',','.') AS SUBTOTALFACTURA , SUM(VALORIMPUESTO) AS IVA, SUM(VALOR_RETEFUENTE) AS RETE, SUM(NVL(VALOR_ICA,0)) AS ICA, SUM(NVL(RETEIVA,0)) AS RETE_IVA, SUM(NVL(RETEICA,0)) AS RETE_ICA, SUM(NVL(IMPUESTO_INC,0)) AS INC, SUM(NVL(VALOR_DESCUENTO,0)) AS DESCUENTOPARCIAL, SUM(NVL(DESCUENTOFACTURA,0)) AS DESCUENTO_FACTURA, REPLACE(SUM(NVL(TOTALITEM,0)),',','.') AS TOTAL, SUM(FACT_SYSMAN.BASEIMPUESTOIVA) AS BASEGRAVABLEIVA, SUM(FACT_SYSMAN.BASEIMPUESTORETEFUENTE) AS BASEGRAVABLERETE, SUM(FACT_SYSMAN.BASEIMPUESTOICA) AS BASEGRAVABLEICA, SUM(FACT_SYSMAN.BASEIMPUESTORETEIVA) AS BASEGRAVABLERETEIVA, SUM(FACT_SYSMAN.BASEIMPUESTORETEICA) AS BASEGRAVABLERETEICA, SUM(FACT_SYSMAN.BASEIMPUESTOINC) AS BASEGRAVABLEINC, SUM(NVL(FACT_SYSMAN.BASEIMPUESTO,0)) AS BASEIMPONIBLE FROM (SELECT 'SYSMAN' AS CREATEDBY, '830005370' AS NUMEROCONTRIBUYENTE, F.TERCERO AS NUMTERCERO, F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, R.TIPO_MEDIOPAGO AS MEDIOPAGO, R.PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, D.VALOR_DEBITO + D.VALOR_CREDITO AS VALORUNITARIO, D.VALOR_DEBITO + D.VALOR_CREDITO AS TOTALITEM, D.VALOR_DEBITO + D.VALOR_CREDITO AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, R.TIPO_PAGO, R.TIPO_MONEDA, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VCN_DOC AS FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, R.TIPOFACDIAN, T.CODIGO AS TIPOCOBRO, '05' AS TIPODOCDIAN, QRY_RETENCIONES_DS.NOM_TIPORETENCION, QRY_RETENCIONES_DS.NOMBRE_RETENCION, QRY_RETENCIONES_DS.TIPORETENCION, QRY_RETENCIONES_DS.CODIGORETENCION, QRY_RETENCIONES_DS.VALOR, QRY_RETENCIONES_DS.VALORBASE FROM (((RESOLUCIONDIAN_CT R INNER JOIN ((TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON (T.COMPANIA = F.COMPANIA) AND (T.CODIGO = F.TIPO)) INNER JOIN DETALLE_COMPROBANTE_CNT D ON (F.COMPANIA = D.COMPANIA) AND (F.ANO = D.ANO) AND (F.TIPO = D.TIPO_CPTE) AND (F.NUMERO = D.COMPROBANTE)) ON (R.COMPANIA = T.COMPANIA) AND (R.TIPOCOMPROBANTE = T.CODIGO) AND F.FECHA BETWEEN R.FECHAINICIAL AND R.FECHAFINAL ) INNER JOIN TERCERO TER ON (F.COMPANIA = TER.COMPANIA) AND (F.TERCERO = TER.NIT) AND (F.SUCURSAL = TER.SUCURSAL)) LEFT JOIN ( SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ( ( TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON ( TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA ) AND ( TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO ) ) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO ) INNER JOIN RETENCIONES ON ( COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA ) AND ( COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO ) AND ( COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO ) AND ( COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO ) WHERE ( ( ( TIPO_COMPROBANTE.DOCSOPORTE ) NOT IN ( 0 ) ) )) QRY_RETENCIONES_DS ON (D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO) AND (D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO) AND (D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO) AND (D.ANO = QRY_RETENCIONES_DS.ANO) AND (D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA)) LEFT JOIN CONCEPTOS_CUDS C ON (D.COMPANIA = C.COMPANIA) AND (D.ANO = C.ANO) AND (D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO) WHERE F.COMPANIA=:COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN ( 0 ) AND T.CODIGO = :TIPOCOBRO ORDER BY F.NUMERO) FACT_SYSMAN WHERE NUMEROFACTURA= :NUMEROFACTURA AND FECHAFACTURA BETWEEN :FECHAINI AND :FECHAFIN AND CODIGOPRODUCTO IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUBTOTALFACTURA":"$SUBTOTALFACTURA","IVA":"$IVA(type:integer)","RETE":"$RETE(type:integer)","ICA":"$ICA(type:integer)","RETE_IVA":"$RETE_IVA(type:integer)","RETE_ICA":"$RETE_ICA(type:integer)","INC":"$INC(type:integer)","DESCUENTOPARCIAL":"$DESCUENTOPARCIAL(type:integer)","DESCUENTO_FACTURA":"$DESCUENTO_FACTURA(type:integer)","TOTAL":"$TOTAL","BASEGRAVABLEIVA":"$BASEGRAVABLEIVA(type:integer)","BASEGRAVABLERETE":"$BASEGRAVABLERETE(type:integer)","BASEGRAVABLEICA":"$BASEGRAVABLEICA(type:integer)","BASEGRAVABLERETEIVA":"$BASEGRAVABLERETEIVA(type:integer)","BASEGRAVABLERETEICA":"$BASEGRAVABLERETEICA(type:integer)","BASEGRAVABLEINC":"$BASEGRAVABLEINC(type:integer)","BASEIMPONIBLE":"$BASEIMPONIBLE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getinformacioncomplementariaafacturar">
		<call-query href="getConceptoscudsGetinformacioncomplementariaafacturarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetexistecomprobantesoporteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(0) EXISTE FROM TIPO_COMPROBANTE CODIGO WHERE COMPANIA = :COMPANIA AND CODIGO = :TIPOCPTE AND CODIGO = :TIPOCPTE AND (DOCSOPORTE NOT IN(0) OR NOTAAJUSTE_CUDS NOT IN(0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCPTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getexistecomprobantesoporte">
		<call-query href="getConceptoscudsGetexistecomprobantesoporteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCPTE" query-param="TIPOCPTE"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetdetallesprodcutodocsoporteQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO_CONCEPTO, NOMBRE_CONCEPTO AS descripcionProducto, CODIGO_EQUIVALENTE_DIAN AS codigoProducto, '94' AS unidadMedida, 0 AS valorItem FROM CONCEPTOS_CUDS WHERE COMPANIA= :COMPANIA AND ANO = :ANO AND CODIGO_EQUIVALENTE_DIAN = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","DESCRIPCIONPRODUCTO":"$DESCRIPCIONPRODUCTO","CODIGOPRODUCTO":"$CODIGOPRODUCTO","UNIDADMEDIDA":"$UNIDADMEDIDA","VALORITEM":"$VALORITEM(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getdetallesprodcutodocsoporte">
		<call-query href="getConceptoscudsGetdetallesprodcutodocsoporteQuery">
