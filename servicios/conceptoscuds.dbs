	<query id="getConceptoscudsGetexisteconsecutivodianresacutalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(NUMERO) EXISTE FROM RESOLUCIONDIAN_CT WHERE COMPANIA = :COMPANIA AND NUMERO = :NUMERO AND CONSECUTIVOFIN &gt;= :CONSECUTIVOUSAR AND :FECHARESO BETWEEN FECHAINICIAL AND FECHAFINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVOUSAR" sqlType="STRING"/>
		<param name="FECHARESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getexisteconsecutivodianresacutal">
		<call-query href="getConceptoscudsGetexisteconsecutivodianresacutalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVOUSAR" query-param="CONSECUTIVOUSAR"/>
			<with-param name="FECHARESO" query-param="FECHARESO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGettodosdocsoporteQuery"  useConfig="sysmandsunist">
		<sql>SELECT F.TERCERO NUMTERCERO,F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, F.CONSECUTIVODIAN, F.PREFIJODIAN AS PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, C.CODIGO_EQUIVALENTE_DIAN AS CODIGOPRODUCTODIAN, T.CODIGO AS TIPOCOBRO FROM (((RESOLUCIONDIAN_CT R INNER JOIN ((TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON (T.CODIGO = F.TIPO) AND (T.COMPANIA = F.COMPANIA)) INNER JOIN DETALLE_COMPROBANTE_CNT D ON (F.NUMERO = D.COMPROBANTE) AND (F.TIPO = D.TIPO_CPTE) AND (F.ANO = D.ANO) AND (F.COMPANIA = D.COMPANIA) AND ( D.CONCEPTO_CUDS IS NOT NULL)) ON (R.TIPOCOMPROBANTE = T.CODIGO) AND (R.COMPANIA = T.COMPANIA) AND F.FECHA BETWEEN R.FECHAINICIAL AND R.FECHAFINAL) INNER JOIN TERCERO TER ON (F.SUCURSAL = TER.SUCURSAL) AND (F.TERCERO = TER.NIT) AND (F.COMPANIA = TER.COMPANIA)) LEFT JOIN (SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ((TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON (TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA) AND (TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO)) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO) INNER JOIN RETENCIONES ON (COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA) AND (COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO) AND (COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO) AND (COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO) WHERE (((TIPO_COMPROBANTE.DOCSOPORTE) NOT IN (0)))) QRY_RETENCIONES_DS ON (D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA) AND (D.ANO = QRY_RETENCIONES_DS.ANO) AND (D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO) AND (D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO) AND (D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO)) LEFT JOIN CONCEPTOS_CUDS C ON (D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO) AND (D.ANO = C.ANO) AND (D.COMPANIA = C.COMPANIA) WHERE F.COMPANIA=:COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN (0) ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMTERCERO":"$NUMTERCERO","FECHAFACTURA":"$FECHAFACTURA","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","CONSECUTIVODIAN":"$CONSECUTIVODIAN","PREFIJO":"$PREFIJO","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOPRODUCTODIAN":"$CODIGOPRODUCTODIAN","TIPOCOBRO":"$TIPOCOBRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/gettodosdocsoporte">
		<call-query href="getConceptoscudsGettodosdocsoporteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGettipocomprobantecudsQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,(CASE DOCSOPORTE WHEN 0 THEN 'false' ELSE 'true' END) DOCSOPORTE,(CASE NOTAAJUSTE_CUDS WHEN 0 THEN 'false' ELSE 'true' END) NOTAAJUSTE_CUDS FROM TIPO_COMPROBANTE WHERE DOCSOPORTE NOT IN (0) OR NOTAAJUSTE_CUDS NOT IN (0) AND COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DOCSOPORTE":"$DOCSOPORTE(type:boolean)","NOTAAJUSTE_CUDS":"$NOTAAJUSTE_CUDS(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/gettipocomprobantecuds">
		<call-query href="getConceptoscudsGettipocomprobantecudsQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsGetinfodocsoporteimprimirQuery"  useConfig="sysmandsunist">
		<sql>SELECT :NITCOMPANIA AS NUMEROCONTRIBUYENTE, CONSECUTIVODIAN AS NUMEROFACTURA, PREFIJODIAN, NUMERO FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND FECHA BETWEEN :FECHAINI AND :FECHAFIN AND NUMERO = :NUMEROFACTURA AND TIPO = :TIPOCOBRO ORDER BY NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMEROCONTRIBUYENTE":"$NUMEROCONTRIBUYENTE","NUMEROFACTURA":"$NUMEROFACTURA","PREFIJODIAN":"$PREFIJODIAN","NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="NITCOMPANIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getinfodocsoporteimprimir">
		<call-query href="getConceptoscudsGetinfodocsoporteimprimirQuery">
			<with-param name="NITCOMPANIA" query-param="NITCOMPANIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsPagGetcuentasconmovQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CLASECONTABLE), PLAN_CONTABLE.CLASECUENTA, 1) &gt; 0 ORDER BY PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CLASECUENTA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECONTABLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptoscuds/getcuentasconmov/pag">
		<call-query href="getConceptoscudsPagGetcuentasconmovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASECONTABLE" query-param="CLASECONTABLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsNumGetcuentasconmovQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CLASECONTABLE), PLAN_CONTABLE.CLASECUENTA, 1) &gt; 0 ORDER BY PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CLASECUENTA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECONTABLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getcuentasconmov/num">
		<call-query href="getConceptoscudsNumGetcuentasconmovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASECONTABLE" query-param="CLASECONTABLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsInformacioncomplementarianotasQuery"  useConfig="sysmandsunist">
        <sql>SELECT F.TIPO, F.CREATED_BY, F.COMPANIA, F.TERCERO AS NUMTERCERO, TO_CHAR(F.FECHA, 'YYYY-MM-DD') AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS VALORUNITARIO, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS TOTALITEM, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, TO_CHAR(F.FECHA_VCN_DOC, 'YYYY-MM-DD') AS FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, T.CODIGO AS TIPOCOBRO, RET.NOM_TIPORETENCION, RET.NOMBRE_RETENCION, RET.TIPORETENCION, RET.CODIGORETENCION, RET.VALOR, RET.VALORBASE FROM ( ( ( ( TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON ( T.COMPANIA = F.COMPANIA ) AND ( T.CODIGO = F.TIPO ) ) INNER JOIN DETALLE_COMPROBANTE_CNT D ON ( F.COMPANIA = D.COMPANIA ) AND ( F.ANO = D.ANO ) AND ( F.TIPO = D.TIPO_CPTE ) AND ( F.NUMERO = D.COMPROBANTE ) ) INNER JOIN TERCERO TER ON ( F.COMPANIA = TER.COMPANIA ) AND ( F.TERCERO = TER.NIT ) AND ( F.SUCURSAL = TER.SUCURSAL ) ) LEFT JOIN V_QRY_RETENCIONES_DS RET ON ( D.CUENTA = RET.CUENTA_CREDITO ) AND ( D.COMPROBANTE = RET.NUMERO ) AND ( D.TIPO_CPTE = RET.TIPO ) AND ( D.ANO = RET.ANO ) AND ( D.COMPANIA = RET.COMPANIA ) ) LEFT JOIN CONCEPTOS_CUDS C ON ( D.COMPANIA = C.COMPANIA ) AND ( D.ANO = C.ANO ) AND ( D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO ) WHERE F.COMPANIA = :COMPANIA AND F.NUMERO = :NUMEROFACTURA AND F.TIPO= :TIPOCOMPROBANTE AND NOT C.CODIGO_CONCEPTO IS NULL GROUP BY F.TIPO, F.CREATED_BY, F.COMPANIA, F.TERCERO, F.FECHA, F.NUMERO, C.CODIGO_CONCEPTO, C.NOMBRE_CONCEPTO, F.DESCRIPCION, TER.TELEFONOS, F.FECHA_VCN_DOC, T.CODIGO, RET.NOM_TIPORETENCION, RET.NOMBRE_RETENCION, RET.TIPORETENCION, RET.CODIGORETENCION, RET.VALOR, RET.VALORBASE ORDER BY F.NUMERO</sql>
        <result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","CREATED_BY":"$CREATED_BY","COMPANIA":"$COMPANIA","NUMTERCERO":"$NUMTERCERO","FECHAFACTURA":"$FECHAFACTURA","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CANTIDAD":"$CANTIDAD","DESCRIPCIONPRODUCTO":"$DESCRIPCIONPRODUCTO","VALORUNITARIO":"$VALORUNITARIO","TOTALITEM":"$TOTALITEM","SUBTOTAL":"$SUBTOTAL","PORCENTAJEIVAX":"$PORCENTAJEIVAX(type:double)","VALORIMPUESTO":"$VALORIMPUESTO(type:double)","PORCENTAJERETEFUENTEX":"$PORCENTAJERETEFUENTEX(type:double)","VALOR_RETEFUENTE":"$VALOR_RETEFUENTE(type:double)","PORCENTAJEICAX":"$PORCENTAJEICAX(type:double)","VALOR_ICA":"$VALOR_ICA(type:double)","PORCENTAJERETEIVADX":"$PORCENTAJERETEIVADX(type:double)","RETEIVA":"$RETEIVA(type:double)","PORCENTAJERETEICAX":"$PORCENTAJERETEICAX(type:double)","RETEICA":"$RETEICA(type:double)","PORCENTAJEINCX":"$PORCENTAJEINCX(type:double)","IMPUESTO_INC":"$IMPUESTO_INC(type:double)","DESCUENTOFACTURA":"$DESCUENTOFACTURA(type:double)","VALOR_DESCUENTO":"$VALOR_DESCUENTO(type:double)","OBSERVACIONES":"$OBSERVACIONES","DESCUENTO":"$DESCUENTO(type:double)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO(type:double)","TELEFONOS":"$TELEFONOS","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","BASEIMPUESTO":"$BASEIMPUESTO(type:double)","BASEIMPUESTOIVA":"$BASEIMPUESTOIVA(type:double)","BASEIMPUESTORETEFUENTE":"$BASEIMPUESTORETEFUENTE(type:double)","BASEIMPUESTOICA":"$BASEIMPUESTOICA(type:double)","BASEIMPUESTORETEIVA":"$BASEIMPUESTORETEIVA(type:double)","BASEIMPUESTOINC":"$BASEIMPUESTOINC(type:double)","BASEIMPUESTORETEICA":"$BASEIMPUESTORETEICA(type:double)","TIPOCOBRO":"$TIPOCOBRO","NOM_TIPORETENCION":"$NOM_TIPORETENCION","NOMBRE_RETENCION":"$NOMBRE_RETENCION","TIPORETENCION":"$TIPORETENCION","CODIGORETENCION":"$CODIGORETENCION","VALOR":"$VALOR","VALORBASE":"$VALORBASE"}]}}       </result>
        <param name="COMPANIA" sqlType="STRING"/>
        <param name="NUMEROFACTURA" sqlType="STRING"/>
        <param name="TIPOCOMPROBANTE" sqlType="STRING"/>

    </query>
    <resource method="GET" path="conceptoscuds/informacioncomplementarianotas">
        <call-query href="getConceptoscudsInformacioncomplementarianotasQuery">
            <with-param name="COMPANIA" query-param="COMPANIA"/>
            <with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
            <with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>

        </call-query>
    </resource>
	<query id="getConceptoscudsInformacionvaloresnotasQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(NVL(SUBTOTAL,0)-NVL(VALOR_DESCUENTO,0)) AS SUBTOTALFACTURA, SUM(VALORIMPUESTO) AS IVA, SUM(VALOR_RETEFUENTE) AS RETE, SUM(NVL(VALOR_ICA,0)) AS ICA, SUM(NVL(RETEIVA,0)) AS RETE_IVA, SUM(NVL(RETEICA,0)) AS RETE_ICA, SUM(NVL(IMPUESTO_INC,0)) AS INC, SUM(NVL(VALOR_DESCUENTO,0)) AS DESCUENTOPARCIAL, SUM(NVL(DESCUENTOFACTURA,0)) AS DESCUENTO_FACTURA, SUM(NVL(TOTALITEM,0)) AS TOTAL, SUM(BASEIMPUESTOIVA) AS BASEGRAVABLEIVA, SUM(BASEIMPUESTORETEFUENTE) AS BASEGRAVABLERETE, SUM(BASEIMPUESTOICA) AS BASEGRAVABLEICA, SUM(BASEIMPUESTORETEIVA) AS BASEGRAVABLERETEIVA, SUM(BASEIMPUESTORETEICA) AS BASEGRAVABLERETEICA, SUM(BASEIMPUESTOINC) AS BASEGRAVABLEINC, SUM( NVL(BASEIMPUESTOIVA,0) + NVL(BASEIMPUESTORETEFUENTE,0) + NVL(BASEIMPUESTOICA,0) + NVL(BASEIMPUESTORETEIVA,0) + NVL(BASEIMPUESTORETEICA,0) + NVL(BASEIMPUESTOINC,0) ) AS BASEIMPONIBLE FROM (SELECT F.TIPO, F.CREATED_BY, F.COMPANIA, F.TERCERO AS NUMTERCERO, F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS VALORUNITARIO, SUM(D.VALOR_DEBITO + D.VALOR_CREDITO) AS TOTALITEM, (SUM(D.VALOR_DEBITO + D.VALOR_CREDITO)- SUM(D.BASE_IVA)) AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VCN_DOC AS FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, T.CODIGO AS TIPOCOBRO, RET.NOM_TIPORETENCION, RET.NOMBRE_RETENCION, RET.TIPORETENCION, RET.CODIGORETENCION, RET.VALOR, RET.VALORBASE FROM ( ( ( ( TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON ( T.COMPANIA = F.COMPANIA ) AND ( T.CODIGO = F.TIPO ) ) INNER JOIN DETALLE_COMPROBANTE_CNT D ON ( F.COMPANIA = D.COMPANIA ) AND ( F.ANO = D.ANO ) AND ( F.TIPO = D.TIPO_CPTE ) AND ( F.NUMERO = D.COMPROBANTE ) ) INNER JOIN TERCERO TER ON ( F.COMPANIA = TER.COMPANIA ) AND ( F.TERCERO = TER.NIT ) AND ( F.SUCURSAL = TER.SUCURSAL ) ) LEFT JOIN V_QRY_RETENCIONES_DS RET ON ( D.CUENTA = RET.CUENTA_CREDITO ) AND ( D.COMPROBANTE = RET.NUMERO ) AND ( D.TIPO_CPTE = RET.TIPO ) AND ( D.ANO = RET.ANO ) AND ( D.COMPANIA = RET.COMPANIA ) ) LEFT JOIN CONCEPTOS_CUDS C ON ( D.COMPANIA = C.COMPANIA ) AND ( D.ANO = C.ANO ) AND ( D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO ) WHERE F.COMPANIA = :COMPANIA AND F.NUMERO = :NUMEROFACTURA AND NOT C.CODIGO_CONCEPTO IS NULL GROUP BY F.TIPO, F.CREATED_BY, F.COMPANIA, F.TERCERO, F.FECHA, F.NUMERO, C.CODIGO_CONCEPTO, C.NOMBRE_CONCEPTO, F.DESCRIPCION, TER.TELEFONOS, F.FECHA_VCN_DOC, T.CODIGO, RET.NOM_TIPORETENCION, RET.NOMBRE_RETENCION, RET.TIPORETENCION, RET.CODIGORETENCION, RET.VALOR, RET.VALORBASE ORDER BY F.NUMERO) WHERE NUMEROFACTURA = :NUMEROFACTURA AND TIPOCOBRO = :TIPONOTA AND NOT CODIGOPRODUCTO IS NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUBTOTALFACTURA":"$SUBTOTALFACTURA","IVA":"$IVA(type:integer)","RETE":"$RETE(type:integer)","ICA":"$ICA(type:integer)","RETE_IVA":"$RETE_IVA(type:integer)","RETE_ICA":"$RETE_ICA(type:integer)","INC":"$INC(type:integer)","DESCUENTOPARCIAL":"$DESCUENTOPARCIAL(type:integer)","DESCUENTO_FACTURA":"$DESCUENTO_FACTURA(type:integer)","TOTAL":"$TOTAL","BASEGRAVABLEIVA":"$BASEGRAVABLEIVA(type:integer)","BASEGRAVABLERETE":"$BASEGRAVABLERETE(type:integer)","BASEGRAVABLEICA":"$BASEGRAVABLEICA(type:integer)","BASEGRAVABLERETEIVA":"$BASEGRAVABLERETEIVA(type:integer)","BASEGRAVABLERETEICA":"$BASEGRAVABLERETEICA(type:integer)","BASEGRAVABLEINC":"$BASEGRAVABLEINC(type:integer)","BASEIMPONIBLE":"$BASEIMPONIBLE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPONOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/informacionvaloresnotas">
		<call-query href="getConceptoscudsInformacionvaloresnotasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPONOTA" query-param="TIPONOTA"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsPrepararconsultanotasQuery"  useConfig="sysmandsunist">
		<sql>SELECT F.TERCERO AS NUMTERCERO, F.NUMERO AS NUMEROFACTURA, F.TIPO, F.PREFIJODIAN, C.CODIGO_CONCEPTO AS CODIGOPRODUCTODIAN,D.CMPTE_AFECTADO FROM ( ( ( ( TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON ( T.COMPANIA = F.COMPANIA ) AND ( T.CODIGO = F.TIPO ) ) INNER JOIN DETALLE_COMPROBANTE_CNT D ON ( F.COMPANIA = D.COMPANIA ) AND ( F.ANO = D.ANO ) AND ( F.TIPO = D.TIPO_CPTE ) AND ( F.NUMERO = D.COMPROBANTE ) ) INNER JOIN TERCERO TER ON ( F.COMPANIA = TER.COMPANIA ) AND ( F.TERCERO = TER.NIT ) AND ( F.SUCURSAL = TER.SUCURSAL ) ) LEFT JOIN V_QRY_RETENCIONES_DS RET ON ( D.CUENTA = RET.CUENTA_CREDITO ) AND ( D.COMPROBANTE = RET.NUMERO ) AND ( D.TIPO_CPTE = RET.TIPO ) AND ( D.ANO = RET.ANO ) AND ( D.COMPANIA = RET.COMPANIA ) ) LEFT JOIN CONCEPTOS_CUDS C ON ( D.COMPANIA = C.COMPANIA ) AND ( D.ANO = C.ANO ) AND ( D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO ) WHERE F.COMPANIA = :COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND F.NUMERO = :NUMEROFACTURA AND T.NOTAAJUSTE_CUDS NOT IN (0) AND NOT C.CODIGO_CONCEPTO IS NULL GROUP BY F.TIPO, F.TERCERO, F.NUMERO, C.CODIGO_CONCEPTO, F.PREFIJODIAN, D.CMPTE_AFECTADO ORDER BY F.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMTERCERO":"$NUMTERCERO","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","TIPO":"$TIPO","PREFIJODIAN":"$PREFIJODIAN","CODIGOPRODUCTODIAN":"$CODIGOPRODUCTODIAN","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/prepararconsultanotas">
		<call-query href="getConceptoscudsPrepararconsultanotasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>

		</call-query>
	</resource>
	<query id="getConceptoscudsNotasverificacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT 'SYSMAN' AS CREATEDBY, '830005370' AS NUMEROCONTRIBUYENTE, M.ANO, M.TIPO_CPTE, M.COMPROBANTE, M.VALOR, M.TIPO_NOTA, M.CODIGO_NOTA, M.PREFIJO, M.TIPO_CPTE_AFECT, M.CMPTE_AFECTADO, M.NUM_DS AS NUMERO_FACTURA,(TO_CHAR(M.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, M.TIPO_MEDIOPAGO, M.TIPO_PAGO, M.TIPO_MONEDA, M.TIPOFACDIAN, TT.DESCRIPCION FROM ( SELECT D.COMPANIA, D.ANO, DS_CNT.TIPO, D.COMPROBANTE, SUM(D.VALOR_CREDITO) + SUM(D.VALOR_DEBITO) AS VALOR, D.TIPO_NOTA, D.CODIGO_NOTA, D.CMPTE_AFECTADO, D.TIPO_CPTE_AFECT, D.TIPO_CPTE, DS_CNT.CONSECUTIVODIAN AS NUM_DS, D.FECHA, T.ID AS IDD, R.PREFIJO, R.TIPO_MEDIOPAGO, R.TIPO_PAGO, R.TIPO_MONEDA, R.TIPOFACDIAN FROM RESOLUCIONDIAN_CT R LEFT JOIN COMPROBANTE_CNT DS_CNT ON R.TIPOCOMPROBANTE = DS_CNT.TIPO AND R.COMPANIA = DS_CNT.COMPANIA LEFT JOIN DETALLE_COMPROBANTE_CNT D ON DS_CNT.NUMERO = D.CMPTE_AFECTADO AND DS_CNT.TIPO = D.TIPO_CPTE_AFECT AND DS_CNT.COMPANIA = D.COMPANIA LEFT JOIN ( SELECT ID, CODIGO FROM TIPOS_FE WHERE CODIGO IN ( 'NDS' ) ) T ON D.TIPO_NOTA = T.CODIGO LEFT JOIN TIPO_COMPROBANTE ON D.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO AND D.COMPANIA = TIPO_COMPROBANTE.COMPANIA LEFT JOIN CARTERA_CUENTA C ON D.CUENTA = C.CUENTA AND D.TIPO_CPTE = C.TIPO_COMPROBANTE AND D.ANO = C.ANO AND D.COMPANIA = C.COMPANIA WHERE D.TIPO_NOTA IS NOT NULL AND D.CODIGO_NOTA IS NOT NULL AND TIPO_COMPROBANTE.NOTAAJUSTE_CUDS NOT IN ( 0 ) GROUP BY D.COMPANIA, D.ANO, DS_CNT.TIPO, D.COMPROBANTE, D.TIPO_NOTA, D.CODIGO_NOTA, D.CMPTE_AFECTADO, D.TIPO_CPTE_AFECT, D.TIPO_CPTE, DS_CNT.CONSECUTIVODIAN, D.FECHA, T.ID, R.PREFIJO, R.TIPO_MEDIOPAGO, R.TIPO_PAGO, R.TIPO_MONEDA, R.TIPOFACDIAN ) M, TIPOS_FE TT WHERE M.CODIGO_NOTA = TT.CODIGO AND TT.ID_TIPOS IS NOT NULL AND M.IDD = TO_NUMBER(TT.ID_TIPOS) AND M.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND M.COMPROBANTE = :COMPROBANTE AND M.TIPO_CPTE = :TIPOCOMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREATEDBY":"$CREATEDBY","NUMEROCONTRIBUYENTE":"$NUMEROCONTRIBUYENTE","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","VALOR":"$VALOR","TIPO_NOTA":"$TIPO_NOTA","CODIGO_NOTA":"$CODIGO_NOTA","PREFIJO":"$PREFIJO","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","NUMERO_FACTURA":"$NUMERO_FACTURA","FECHA":"$FECHA","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_PAGO":"$TIPO_PAGO","TIPO_MONEDA":"$TIPO_MONEDA","TIPOFACDIAN":"$TIPOFACDIAN","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>

	</query>
