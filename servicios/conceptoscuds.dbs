	<query id="getConceptoscudsGetconceptoscudsgetdatadocsoporteenvioinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT FACT_SYSMAN.FECHA_PAGO_RETENCION AS FECHA_PAGO,FACT_SYSMAN.ANO_AFECT, FACT_SYSMAN.TIPO_CPTE_AFECT, FACT_SYSMAN.CMPTE_AFECTADO, FACT_SYSMAN.CREATEDBY CREATED_BY,(TO_CHAR(FACT_SYSMAN.FECHAFACTURA,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURA, FACT_SYSMAN.NUMEROFACTURA, FACT_SYSMAN.MEDIOPAGO, FACT_SYSMAN.NUMTERCERO, FACT_SYSMAN.NUMDOC, FACT_SYSMAN.PREFIJO,(TO_CHAR(FACT_SYSMAN.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, FACT_SYSMAN.TELEFONOS, FACT_SYSMAN.DESCUENTOFACTURA, FACT_SYSMAN.TIPO_MONEDA, FACT_SYSMAN.OBSERVACIONES, FACT_SYSMAN.TIPO_PAGO, FACT_SYSMAN.TIPOFACDIAN, FACT_SYSMAN.TIPODOCDIAN, FACT_SYSMAN.DIRECCIONCOMPANIA, FACT_SYSMAN.CIUDADCOMPANIA, FACT_SYSMAN.DEPTOCOMPANIA, FACT_SYSMAN.CIUDADTERCERO, FACT_SYSMAN.DEPTOTERCERO, FACT_SYSMAN.REGIMENTERCERO, FACT_SYSMAN.RAZONSOCIAL, FACT_SYSMAN.NATURALEZATERCERO, FACT_SYSMAN.NOMBRETERCERO, FACT_SYSMAN.DIRECCIONTERCERO, FACT_SYSMAN.CODIGOPOSTALTERCERO, FACT_SYSMAN.PAISTERCERO, FACT_SYSMAN.EMAILTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONCOMPANIA, REPLACE(SUM(NVL(SUBTOTAL,0) - NVL(VALOR_DESCUENTO,0)),',','.') AS SUBTOTAL,REPLACE(SUM(NVL(TOTALITEM,0)),',','.')AS VALOR_TOTAL,FACT_SYSMAN.PREFIJO_DIAN_AFECT, FACT_SYSMAN.CONSECUTIVO_DIAN_AFECT FROM ( SELECT F.CREATED_BY AS CREATEDBY, :NITCOMPANIA AS NUMEROCONTRIBUYENTE, F.TERCERO AS NUMTERCERO, F.FECHA AS FECHAFACTURA, F.NUMERO AS NUMEROFACTURA, R.TIPO_MEDIOPAGO AS MEDIOPAGO, R.NUMERO AS NUMDOC, R.PREFIJO, C.CODIGO_CONCEPTO AS CODIGOPRODUCTO, '1' AS CANTIDAD, C.NOMBRE_CONCEPTO AS DESCRIPCIONPRODUCTO, D.ANO_AFECT, D.TIPO_CPTE_AFECT, D.CMPTE_AFECTADO, D.FECHA_PAGO_RETENCION, D.VALOR_DEBITO + D.VALOR_CREDITO AS VALORUNITARIO, D.VALOR_DEBITO + D.VALOR_CREDITO AS TOTALITEM, D.VALOR_DEBITO + D.VALOR_CREDITO AS SUBTOTAL, 0 AS PORCENTAJEIVAX, 0 AS VALORIMPUESTO, 0 AS PORCENTAJERETEFUENTEX, 0 AS VALOR_RETEFUENTE, 0 AS PORCENTAJEICAX, 0 AS VALOR_ICA, 0 AS PORCENTAJERETEIVADX, 0 AS RETEIVA, 0 AS PORCENTAJERETEICAX, 0 AS RETEICA, 0 AS PORCENTAJEINCX, 0 AS IMPUESTO_INC, 0 AS DESCUENTOFACTURA, 0 AS VALOR_DESCUENTO, F.DESCRIPCION AS OBSERVACIONES, R.TIPO_PAGO, R.TIPO_MONEDA, 0 AS DESCUENTO, 0 AS PORCENTAJEDESCUENTO, TER.TELEFONOS, TER.CIUDAD CIUDADTERCERO, TER.DEPARTAMENTO DEPTOTERCERO, TER.REGIMEN REGIMENTERCERO, TER.NOMBRE1 RAZONSOCIAL, TER.NATURALEZA NATURALEZATERCERO, TER.NOMBRE NOMBRETERCERO, TER.DIRECCION DIRECCIONTERCERO, TER.CODIGOPOSTAL CODIGOPOSTALTERCERO, TER.DIRECCIONEMAIL EMAILTERCERO, TER.DIGITOVERIFICACION DIGITOVERIFICACIONTERCERO, ( SELECT CODIGODIAN FROM PAISES WHERE PAIS = TER.PAIS ) PAISTERCERO, F.FECHA_VCN_DOC AS FECHA_VENCIMIENTO, 0 AS BASEIMPUESTO, 0 AS BASEIMPUESTOIVA, 0 AS BASEIMPUESTORETEFUENTE, 0 AS BASEIMPUESTOICA, 0 AS BASEIMPUESTORETEIVA, 0 AS BASEIMPUESTOINC, 0 AS BASEIMPUESTORETEICA, R.TIPOFACDIAN, T.CODIGO AS TIPOCOBRO, '05' AS TIPODOCDIAN, QRY_RETENCIONES_DS.NOM_TIPORETENCION, QRY_RETENCIONES_DS.NOMBRE_RETENCION, QRY_RETENCIONES_DS.TIPORETENCION, QRY_RETENCIONES_DS.CODIGORETENCION, QRY_RETENCIONES_DS.VALOR, QRY_RETENCIONES_DS.VALORBASE, CPN.DIRECCION DIRECCIONCOMPANIA, CPN.CIUDAD CIUDADCOMPANIA, CPN.DEPARTAMENTO DEPTOCOMPANIA, (CASE WHEN INSTR(CPN.NITCOMPANIA,'-', 1) &gt; 0 THEN SUBSTR(CPN.NITCOMPANIA,INSTR(CPN.NITCOMPANIA,'-', 1)+1, LENGTH(CPN.NITCOMPANIA)) ELSE '0' END) DIGITOVERIFICACIONCOMPANIA, F2.PREFIJODIAN AS PREFIJO_DIAN_AFECT, F2.CONSECUTIVODIAN AS CONSECUTIVO_DIAN_AFECT FROM ( ( ( RESOLUCIONDIAN_CT R INNER JOIN ( ( TIPO_COMPROBANTE T INNER JOIN COMPROBANTE_CNT F ON ( T.COMPANIA = F.COMPANIA ) AND ( T.CODIGO = F.TIPO ) ) INNER JOIN DETALLE_COMPROBANTE_CNT D ON ( F.COMPANIA = D.COMPANIA ) AND ( F.ANO = D.ANO ) AND ( F.TIPO = D.TIPO_CPTE ) AND ( F.NUMERO = D.COMPROBANTE ) ) ON ( R.COMPANIA = T.COMPANIA ) AND ( R.TIPOCOMPROBANTE = T.CODIGO ) ) INNER JOIN TERCERO TER ON ( F.COMPANIA = TER.COMPANIA ) AND ( F.TERCERO = TER.NIT ) AND ( F.SUCURSAL = TER.SUCURSAL ) INNER JOIN COMPANIA CPN ON ( F.COMPANIA = CPN.CODIGO ) ) LEFT JOIN ( SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, TIPORETENCION.NOMBRE AS NOM_TIPORETENCION, RETENCIONES.NOMBRE AS NOMBRE_RETENCION, RETENCIONES.CUENTA_DEBITO, RETENCIONES.CUENTA_CREDITO, RETENCIONES.PCT_APLICAR FROM ( ( TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNTRETENCION ON ( TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA ) AND ( TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNTRETENCION.TIPO ) ) INNER JOIN TIPORETENCION ON COMPROBANTE_CNTRETENCION.TIPORETENCION = TIPORETENCION.CODIGO ) INNER JOIN RETENCIONES ON ( COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA ) AND ( COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO ) AND ( COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO ) AND ( COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO ) WHERE ( ( ( TIPO_COMPROBANTE.DOCSOPORTE ) NOT IN ( 0 ) ) ) ) QRY_RETENCIONES_DS ON ( D.CUENTA = QRY_RETENCIONES_DS.CUENTA_CREDITO ) AND ( D.COMPROBANTE = QRY_RETENCIONES_DS.NUMERO ) AND ( D.TIPO_CPTE = QRY_RETENCIONES_DS.TIPO ) AND ( D.ANO = QRY_RETENCIONES_DS.ANO ) AND ( D.COMPANIA = QRY_RETENCIONES_DS.COMPANIA ) ) LEFT JOIN CONCEPTOS_CUDS C ON ( D.COMPANIA = C.COMPANIA ) AND ( D.ANO = C.ANO ) AND ( D.CONCEPTO_CUDS = C.CODIGO_CONCEPTO ) LEFT JOIN COMPROBANTE_CNT F2 ON F2.COMPANIA = D.COMPANIA AND F2.TIPO = D.TIPO_CPTE_AFECT AND F2.NUMERO = D.CMPTE_AFECTADO AND F2.ANO = D.ANO_AFECT WHERE F.COMPANIA = :COMPANIA AND F.FECHA BETWEEN :FECHAINI AND :FECHAFIN AND T.DOCSOPORTE NOT IN ( 0 ) ORDER BY F.NUMERO ) FACT_SYSMAN WHERE NUMEROCONTRIBUYENTE = :NITCOMPANIA AND TIPOCOBRO = :TIPOCOBRO AND FACT_SYSMAN.NUMEROFACTURA = :NUMEROFACTURA AND FECHAFACTURA BETWEEN :FECHAINI AND :FECHAFIN AND NOT CODIGOPRODUCTO IS NULL GROUP BY FACT_SYSMAN.FECHA_PAGO_RETENCION, FACT_SYSMAN.CREATEDBY, FACT_SYSMAN.FECHAFACTURA, FACT_SYSMAN.NUMEROFACTURA, FACT_SYSMAN.MEDIOPAGO, FACT_SYSMAN.NUMTERCERO, FACT_SYSMAN.NUMDOC, FACT_SYSMAN.PREFIJO, FACT_SYSMAN.FECHA_VENCIMIENTO, FACT_SYSMAN.TELEFONOS, FACT_SYSMAN.DESCUENTOFACTURA, FACT_SYSMAN.TIPO_MONEDA, FACT_SYSMAN.OBSERVACIONES, FACT_SYSMAN.TIPO_PAGO, FACT_SYSMAN.TIPOFACDIAN, FACT_SYSMAN.TIPODOCDIAN, FACT_SYSMAN.DIRECCIONCOMPANIA, FACT_SYSMAN.CIUDADCOMPANIA, FACT_SYSMAN.DEPTOCOMPANIA, FACT_SYSMAN.CIUDADTERCERO, FACT_SYSMAN.DEPTOTERCERO, FACT_SYSMAN.REGIMENTERCERO, FACT_SYSMAN.RAZONSOCIAL, FACT_SYSMAN.NATURALEZATERCERO, FACT_SYSMAN.NOMBRETERCERO, FACT_SYSMAN.DIRECCIONTERCERO, FACT_SYSMAN.CODIGOPOSTALTERCERO, FACT_SYSMAN.PAISTERCERO, FACT_SYSMAN.EMAILTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONCOMPANIA,FACT_SYSMAN.ANO_AFECT, FACT_SYSMAN.TIPO_CPTE_AFECT, FACT_SYSMAN.CMPTE_AFECTADO, FACT_SYSMAN.PREFIJO_DIAN_AFECT, FACT_SYSMAN.CONSECUTIVO_DIAN_AFECT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA_PAGO":"$FECHA_PAGO","ANO_AFECT":"$ANO_AFECT(type:integer)","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","CREATED_BY":"$CREATED_BY","FECHAFACTURA":"$FECHAFACTURA","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","MEDIOPAGO":"$MEDIOPAGO","NUMTERCERO":"$NUMTERCERO","NUMDOC":"$NUMDOC","PREFIJO":"$PREFIJO","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","TELEFONOS":"$TELEFONOS","DESCUENTOFACTURA":"$DESCUENTOFACTURA(type:double)","TIPO_MONEDA":"$TIPO_MONEDA","OBSERVACIONES":"$OBSERVACIONES","TIPO_PAGO":"$TIPO_PAGO","TIPOFACDIAN":"$TIPOFACDIAN","TIPODOCDIAN":"$TIPODOCDIAN","DIRECCIONCOMPANIA":"$DIRECCIONCOMPANIA","CIUDADCOMPANIA":"$CIUDADCOMPANIA","DEPTOCOMPANIA":"$DEPTOCOMPANIA","CIUDADTERCERO":"$CIUDADTERCERO","DEPTOTERCERO":"$DEPTOTERCERO","REGIMENTERCERO":"$REGIMENTERCERO","RAZONSOCIAL":"$RAZONSOCIAL","NATURALEZATERCERO":"$NATURALEZATERCERO","NOMBRETERCERO":"$NOMBRETERCERO","DIRECCIONTERCERO":"$DIRECCIONTERCERO","CODIGOPOSTALTERCERO":"$CODIGOPOSTALTERCERO","PAISTERCERO":"$PAISTERCERO","EMAILTERCERO":"$EMAILTERCERO","DIGITOVERIFICACIONTERCERO":"$DIGITOVERIFICACIONTERCERO(type:long)","DIGITOVERIFICACIONCOMPANIA":"$DIGITOVERIFICACIONCOMPANIA","SUBTOTAL":"$SUBTOTAL","VALOR_TOTAL":"$VALOR_TOTAL","PREFIJO_DIAN_AFECT":"$PREFIJO_DIAN_AFECT","CONSECUTIVO_DIAN_AFECT":"$CONSECUTIVO_DIAN_AFECT"}]}}		</result>
		<param name="NITCOMPANIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscuds/getconceptoscudsgetdatadocsoporteenvioinvoway">
		<call-query href="getConceptoscudsGetconceptoscudsgetdatadocsoporteenvioinvowayQuery">
			<with-param name="NITCOMPANIA" query-param="NITCOMPANIA"/>
