	<query id="getConceptoscudsGetnotasverificacionsinfechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT 'SYSMAN' AS CREATEDBY, '830005370' AS NUMEROCONTRIBUYENTE, M.ANO, M.TIPO_CPTE, M.COMPROBANTE, M.VALOR, M.TIPO_NOTA, M.CODIGO_NOTA, M.PREFIJO, M.TIPO_CPTE_AFECT, M.CMPTE_AFECTADO, M.NUM_DS AS NUMERO_FACTURA,(TO_CHAR(M.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, M.TIPO_MEDIOPAGO, M.TIPO_PAGO, M.TIPO_MONEDA, M.TIPOFACDIAN, TT.DESCRIPCION FROM ( SELECT D.COMPANIA, D.ANO, DS_CNT.TIPO, D.COMPROBANTE, SUM(D.VALOR_CREDITO) + SUM(D.VALOR_DEBITO) AS VALOR, D.TIPO_NOTA, D.CODIGO_NOTA, D.CMPTE_AFECTADO, D.TIPO_CPTE_AFECT, D.TIPO_CPTE, DS_CNT.CONSECUTIVODIAN AS NUM_DS, D.FECHA, T.ID AS IDD, R.PREFIJO, R.TIPO_MEDIOPAGO, R.TIPO_PAGO, R.TIPO_MONEDA, R.TIPOFACDIAN FROM RESOLUCIONDIAN_CT R LEFT JOIN COMPROBANTE_CNT DS_CNT ON R.TIPOCOMPROBANTE = DS_CNT.TIPO AND R.COMPANIA = DS_CNT.COMPANIA LEFT JOIN DETALLE_COMPROBANTE_CNT D ON DS_CNT.NUMERO = D.CMPTE_AFECTADO AND DS_CNT.TIPO = D.TIPO_CPTE_AFECT AND DS_CNT.COMPANIA = D.COMPANIA LEFT JOIN ( SELECT ID, CODIGO FROM TIPOS_FE WHERE CODIGO IN ( 'NDS' ) ) T ON D.TIPO_NOTA = T.CODIGO LEFT JOIN TIPO_COMPROBANTE ON D.TIPO_CPTE = TIPO_COMPROBANTE.CODIGO AND D.COMPANIA = TIPO_COMPROBANTE.COMPANIA LEFT JOIN CARTERA_CUENTA C ON D.CUENTA = C.CUENTA AND D.TIPO_CPTE = C.TIPO_COMPROBANTE AND D.ANO = C.ANO AND D.COMPANIA = C.COMPANIA WHERE D.TIPO_NOTA IS NOT NULL AND D.CODIGO_NOTA IS NOT NULL AND TIPO_COMPROBANTE.NOTAAJUSTE_CUDS NOT IN ( 0 ) GROUP BY D.COMPANIA, D.ANO, DS_CNT.TIPO, D.COMPROBANTE, D.TIPO_NOTA, D.CODIGO_NOTA, D.CMPTE_AFECTADO, D.TIPO_CPTE_AFECT, D.TIPO_CPTE, DS_CNT.CONSECUTIVODIAN, D.FECHA, T.ID, R.PREFIJO, R.TIPO_MEDIOPAGO, R.TIPO_PAGO, R.TIPO_MONEDA, R.TIPOFACDIAN ) M, TIPOS_FE TT WHERE M.CODIGO_NOTA = TT.CODIGO AND TT.ID_TIPOS IS NOT NULL AND M.IDD = TO_NUMBER(TT.ID_TIPOS) AND M.COMPROBANTE = :COMPROBANTE AND M.TIPO_CPTE = :TIPOCOMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREATEDBY":"$CREATEDBY","NUMEROCONTRIBUYENTE":"$NUMEROCONTRIBUYENTE","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","VALOR":"$VALOR","TIPO_NOTA":"$TIPO_NOTA","CODIGO_NOTA":"$CODIGO_NOTA","PREFIJO":"$PREFIJO","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","NUMERO_FACTURA":"$NUMERO_FACTURA","FECHA":"$FECHA","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_PAGO":"$TIPO_PAGO","TIPO_MONEDA":"$TIPO_MONEDA","TIPOFACDIAN":"$TIPOFACDIAN","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>

	</query>
