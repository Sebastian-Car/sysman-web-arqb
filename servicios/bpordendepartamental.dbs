<data name="bpordendepartamental" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBpordendepartamental" keyColumns="COMPANIA,COD_PLAN,VIGENCIA,CODIGO_EJE,CODIGO_MEDIDA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_ORDENDEPARTAMENTAL (COMPANIA, COD_PLAN, VIGENCIA, CODIGO_EJE, CODIGO_MEDIDA, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :COD_PLAN, :VIGENCIA, :CODIGO_EJE, :CODIGO_MEDIDA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_PLAN":"$COD_PLAN","KEY_VIGENCIA":"$VIGENCIA(type:integer)","KEY_CODIGO_EJE":"$CODIGO_EJE(type:integer)","KEY_CODIGO_MEDIDA":"$CODIGO_MEDIDA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="CODIGO_MEDIDA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpordendepartamental">
		<call-query href="insertBpordendepartamental">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="CODIGO_MEDIDA" query-param="CODIGO_MEDIDA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteBpordendepartamental" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_ORDENDEPARTAMENTAL WHERE BP_ORDENDEPARTAMENTAL.COMPANIA= :KEY_COMPANIA AND BP_ORDENDEPARTAMENTAL.COD_PLAN= :KEY_COD_PLAN AND BP_ORDENDEPARTAMENTAL.VIGENCIA= :KEY_VIGENCIA AND BP_ORDENDEPARTAMENTAL.CODIGO_EJE= :KEY_CODIGO_EJE AND BP_ORDENDEPARTAMENTAL.CODIGO_MEDIDA= :KEY_CODIGO_MEDIDA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_EJE" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_MEDIDA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="bpordendepartamental">
		<call-query href="deleteBpordendepartamental">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_PLAN" query-param="KEY_COD_PLAN"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>
			<with-param name="KEY_CODIGO_MEDIDA" query-param="KEY_CODIGO_MEDIDA"/>

		</call-query>
	</resource>
	<query id="getBpordendepartamentalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BP_ORDENDEPARTAMENTAL.COMPANIA, BP_ORDENDEPARTAMENTAL.COD_PLAN, BP_ORDENDEPARTAMENTAL.VIGENCIA, BP_ORDENDEPARTAMENTAL.CODIGO_EJE, BP_ORDENDEPARTAMENTAL.CODIGO_MEDIDA, EJE_ESTRUCTURAL.DESCRIPCION_EJE DESC_EJE, MEDIDA_PIGCCT.DESCRIPCION_MEDIDA DESC_MEDIDA FROM BP_ORDENDEPARTAMENTAL INNER JOIN EJE_ESTRUCTURAL ON BP_ORDENDEPARTAMENTAL.COMPANIA = EJE_ESTRUCTURAL.COMPANIA AND BP_ORDENDEPARTAMENTAL.CODIGO_EJE = EJE_ESTRUCTURAL.CODIGO_EJE INNER JOIN MEDIDA_PIGCCT ON BP_ORDENDEPARTAMENTAL.COMPANIA = MEDIDA_PIGCCT.COMPANIA AND BP_ORDENDEPARTAMENTAL.CODIGO_MEDIDA = MEDIDA_PIGCCT.CODIGO_MEDIDA AND BP_ORDENDEPARTAMENTAL.CODIGO_EJE = MEDIDA_PIGCCT.CODIGO_EJE WHERE BP_ORDENDEPARTAMENTAL.COMPANIA = :COMPANIA AND BP_ORDENDEPARTAMENTAL.VIGENCIA = :VIGENCIA AND BP_ORDENDEPARTAMENTAL.COD_PLAN = :COD_PLAN) INI WHERE (CASE WHEN DESC_EJE IS NULL THEN ' ' ELSE UPPER(DESC_EJE) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_EJE), '%')) AND (CASE WHEN DESC_MEDIDA IS NULL THEN ' ' ELSE UPPER(DESC_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_MEDIDA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PLAN":"$COD_PLAN","VIGENCIA":"$VIGENCIA(type:integer)","CODIGO_EJE":"$CODIGO_EJE(type:integer)","CODIGO_MEDIDA":"$CODIGO_MEDIDA(type:integer)","DESC_EJE":"$DESC_EJE","DESC_MEDIDA":"$DESC_MEDIDA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param name="DESC_EJE" sqlType="STRING"/>
		<param name="DESC_MEDIDA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpordendepartamental">
		<call-query href="getBpordendepartamentalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="DESC_EJE" query-param="DESC_EJE"/>
			<with-param name="DESC_MEDIDA" query-param="DESC_MEDIDA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpordendepartamentalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BP_ORDENDEPARTAMENTAL.COMPANIA, BP_ORDENDEPARTAMENTAL.COD_PLAN, BP_ORDENDEPARTAMENTAL.VIGENCIA, BP_ORDENDEPARTAMENTAL.CODIGO_EJE, BP_ORDENDEPARTAMENTAL.CODIGO_MEDIDA, EJE_ESTRUCTURAL.DESCRIPCION_EJE DESC_EJE, MEDIDA_PIGCCT.DESCRIPCION_MEDIDA DESC_MEDIDA FROM BP_ORDENDEPARTAMENTAL INNER JOIN EJE_ESTRUCTURAL ON BP_ORDENDEPARTAMENTAL.COMPANIA = EJE_ESTRUCTURAL.COMPANIA AND BP_ORDENDEPARTAMENTAL.CODIGO_EJE = EJE_ESTRUCTURAL.CODIGO_EJE INNER JOIN MEDIDA_PIGCCT ON BP_ORDENDEPARTAMENTAL.COMPANIA = MEDIDA_PIGCCT.COMPANIA AND BP_ORDENDEPARTAMENTAL.CODIGO_MEDIDA = MEDIDA_PIGCCT.CODIGO_MEDIDA AND BP_ORDENDEPARTAMENTAL.CODIGO_EJE = MEDIDA_PIGCCT.CODIGO_EJE WHERE BP_ORDENDEPARTAMENTAL.COMPANIA = :COMPANIA AND BP_ORDENDEPARTAMENTAL.VIGENCIA = :VIGENCIA AND BP_ORDENDEPARTAMENTAL.COD_PLAN = :COD_PLAN) INI WHERE (CASE WHEN DESC_EJE IS NULL THEN ' ' ELSE UPPER(DESC_EJE) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_EJE), '%')) AND (CASE WHEN DESC_MEDIDA IS NULL THEN ' ' ELSE UPPER(DESC_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_MEDIDA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param name="DESC_EJE" sqlType="STRING"/>
		<param name="DESC_MEDIDA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpordendepartamental/numero">
		<call-query href="getBpordendepartamentalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="DESC_EJE" query-param="DESC_EJE"/>
			<with-param name="DESC_MEDIDA" query-param="DESC_MEDIDA"/>

		</call-query>
	</resource>

</data>