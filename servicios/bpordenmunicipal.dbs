<data name="bpordenmunicipal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBpordenmunicipal" keyColumns="COMPANIA,COD_PLAN,VIGENCIA,COD_POLITICA,TIPOP,COD_CATEGORIA,TIPOC,COD_SUBCATEGORIA,TIPOSUB" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_ORDENMUNICIPAL (COMPANIA, COD_PLAN, VIGENCIA, COD_POLITICA, TIPOP, COD_CATEGORIA, TIPOC, COD_SUBCATEGORIA, TIPOSUB, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :COD_PLAN, :VIGENCIA, :COD_POLITICA, :TIPOP, :COD_CATEGORIA, :TIPOC, :COD_SUBCATEGORIA, :TIPOSUB, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_PLAN":"$COD_PLAN","KEY_VIGENCIA":"$VIGENCIA(type:integer)","KEY_COD_POLITICA":"$COD_POLITICA","KEY_TIPOP":"$TIPOP","KEY_COD_CATEGORIA":"$COD_CATEGORIA","KEY_TIPOC":"$TIPOC","KEY_COD_SUBCATEGORIA":"$COD_SUBCATEGORIA","KEY_TIPOSUB":"$TIPOSUB"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_POLITICA" sqlType="STRING"/>
		<param name="TIPOP" sqlType="STRING"/>
		<param name="COD_CATEGORIA" sqlType="STRING"/>
		<param name="TIPOC" sqlType="STRING"/>
		<param name="COD_SUBCATEGORIA" sqlType="STRING"/>
		<param name="TIPOSUB" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpordenmunicipal">
		<call-query href="insertBpordenmunicipal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_POLITICA" query-param="COD_POLITICA"/>
			<with-param name="TIPOP" query-param="TIPOP"/>
			<with-param name="COD_CATEGORIA" query-param="COD_CATEGORIA"/>
			<with-param name="TIPOC" query-param="TIPOC"/>
			<with-param name="COD_SUBCATEGORIA" query-param="COD_SUBCATEGORIA"/>
			<with-param name="TIPOSUB" query-param="TIPOSUB"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteBpordenmunicipal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_ORDENMUNICIPAL WHERE BP_ORDENMUNICIPAL.COMPANIA= :KEY_COMPANIA AND BP_ORDENMUNICIPAL.COD_PLAN= :KEY_COD_PLAN AND BP_ORDENMUNICIPAL.VIGENCIA= :KEY_VIGENCIA AND BP_ORDENMUNICIPAL.COD_POLITICA= :KEY_COD_POLITICA AND BP_ORDENMUNICIPAL.TIPOP= :KEY_TIPOP AND BP_ORDENMUNICIPAL.COD_CATEGORIA= :KEY_COD_CATEGORIA AND BP_ORDENMUNICIPAL.TIPOC= :KEY_TIPOC AND BP_ORDENMUNICIPAL.COD_SUBCATEGORIA= :KEY_COD_SUBCATEGORIA AND BP_ORDENMUNICIPAL.TIPOSUB= :KEY_TIPOSUB</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>
		<param name="KEY_COD_POLITICA" sqlType="STRING"/>
		<param name="KEY_TIPOP" sqlType="STRING"/>
		<param name="KEY_COD_CATEGORIA" sqlType="STRING"/>
		<param name="KEY_TIPOC" sqlType="STRING"/>
		<param name="KEY_COD_SUBCATEGORIA" sqlType="STRING"/>
		<param name="KEY_TIPOSUB" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpordenmunicipal">
		<call-query href="deleteBpordenmunicipal">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_PLAN" query-param="KEY_COD_PLAN"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_COD_POLITICA" query-param="KEY_COD_POLITICA"/>
			<with-param name="KEY_TIPOP" query-param="KEY_TIPOP"/>
			<with-param name="KEY_COD_CATEGORIA" query-param="KEY_COD_CATEGORIA"/>
			<with-param name="KEY_TIPOC" query-param="KEY_TIPOC"/>
			<with-param name="KEY_COD_SUBCATEGORIA" query-param="KEY_COD_SUBCATEGORIA"/>
			<with-param name="KEY_TIPOSUB" query-param="KEY_TIPOSUB"/>

		</call-query>
	</resource>
	<query id="getBpordenmunicipalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BP_ORDENMUNICIPAL.COMPANIA, BP_ORDENMUNICIPAL.COD_PLAN, BP_ORDENMUNICIPAL.VIGENCIA, BP_ORDENMUNICIPAL.COD_POLITICA, BP_ORDENMUNICIPAL.TIPOP, BP_ORDENMUNICIPAL.COD_CATEGORIA, BP_ORDENMUNICIPAL.TIPOC, BP_ORDENMUNICIPAL.COD_SUBCATEGORIA, BP_ORDENMUNICIPAL.TIPOSUB, ORDENMUNICIPALP.DESCRIPCION DESC_POLITICA, ORDENMUNICIPALC.DESCRIPCION DESC_CATEGORIA, ORDENMUNICIPALS.DESCRIPCION DESC_SUBCATEGORIA FROM BP_ORDENMUNICIPAL INNER JOIN ORDENMUNICIPAL ORDENMUNICIPALP ON BP_ORDENMUNICIPAL.COMPANIA = ORDENMUNICIPALP.COMPANIA AND BP_ORDENMUNICIPAL.COD_POLITICA = ORDENMUNICIPALP.CODIGO AND BP_ORDENMUNICIPAL.TIPOP = ORDENMUNICIPALP.TIPO INNER JOIN ORDENMUNICIPAL ORDENMUNICIPALC ON BP_ORDENMUNICIPAL.COMPANIA = ORDENMUNICIPALC.COMPANIA AND BP_ORDENMUNICIPAL.COD_CATEGORIA = ORDENMUNICIPALC.CODIGO AND BP_ORDENMUNICIPAL.TIPOC = ORDENMUNICIPALC.TIPO INNER JOIN ORDENMUNICIPAL ORDENMUNICIPALS ON BP_ORDENMUNICIPAL.COMPANIA = ORDENMUNICIPALS.COMPANIA AND BP_ORDENMUNICIPAL.COD_SUBCATEGORIA = ORDENMUNICIPALS.CODIGO AND BP_ORDENMUNICIPAL.TIPOSUB = ORDENMUNICIPALS.TIPO WHERE BP_ORDENMUNICIPAL.COMPANIA = :COMPANIA AND BP_ORDENMUNICIPAL.VIGENCIA = :VIGENCIA AND BP_ORDENMUNICIPAL.COD_PLAN = :COD_PLAN) INI WHERE (CASE WHEN DESC_POLITICA IS NULL THEN ' ' ELSE UPPER(DESC_POLITICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_POLITICA), '%')) AND (CASE WHEN DESC_CATEGORIA IS NULL THEN ' ' ELSE UPPER(DESC_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_CATEGORIA), '%')) AND (CASE WHEN DESC_SUBCATEGORIA IS NULL THEN ' ' ELSE UPPER(DESC_SUBCATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_SUBCATEGORIA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PLAN":"$COD_PLAN","VIGENCIA":"$VIGENCIA(type:integer)","COD_POLITICA":"$COD_POLITICA","TIPOP":"$TIPOP","COD_CATEGORIA":"$COD_CATEGORIA","TIPOC":"$TIPOC","COD_SUBCATEGORIA":"$COD_SUBCATEGORIA","TIPOSUB":"$TIPOSUB","DESC_POLITICA":"$DESC_POLITICA","DESC_CATEGORIA":"$DESC_CATEGORIA","DESC_SUBCATEGORIA":"$DESC_SUBCATEGORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param name="DESC_POLITICA" sqlType="STRING"/>
		<param name="DESC_CATEGORIA" sqlType="STRING"/>
		<param name="DESC_SUBCATEGORIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpordenmunicipal">
		<call-query href="getBpordenmunicipalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="DESC_POLITICA" query-param="DESC_POLITICA"/>
			<with-param name="DESC_CATEGORIA" query-param="DESC_CATEGORIA"/>
			<with-param name="DESC_SUBCATEGORIA" query-param="DESC_SUBCATEGORIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpordenmunicipalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BP_ORDENMUNICIPAL.COMPANIA, BP_ORDENMUNICIPAL.COD_PLAN, BP_ORDENMUNICIPAL.VIGENCIA, BP_ORDENMUNICIPAL.COD_POLITICA, BP_ORDENMUNICIPAL.TIPOP, BP_ORDENMUNICIPAL.COD_CATEGORIA, BP_ORDENMUNICIPAL.TIPOC, BP_ORDENMUNICIPAL.COD_SUBCATEGORIA, BP_ORDENMUNICIPAL.TIPOSUB, ORDENMUNICIPALP.DESCRIPCION DESC_POLITICA, ORDENMUNICIPALC.DESCRIPCION DESC_CATEGORIA, ORDENMUNICIPALS.DESCRIPCION DESC_SUBCATEGORIA FROM BP_ORDENMUNICIPAL INNER JOIN ORDENMUNICIPAL ORDENMUNICIPALP ON BP_ORDENMUNICIPAL.COMPANIA = ORDENMUNICIPALP.COMPANIA AND BP_ORDENMUNICIPAL.COD_POLITICA = ORDENMUNICIPALP.CODIGO AND BP_ORDENMUNICIPAL.TIPOP = ORDENMUNICIPALP.TIPO INNER JOIN ORDENMUNICIPAL ORDENMUNICIPALC ON BP_ORDENMUNICIPAL.COMPANIA = ORDENMUNICIPALC.COMPANIA AND BP_ORDENMUNICIPAL.COD_CATEGORIA = ORDENMUNICIPALC.CODIGO AND BP_ORDENMUNICIPAL.TIPOC = ORDENMUNICIPALC.TIPO INNER JOIN ORDENMUNICIPAL ORDENMUNICIPALS ON BP_ORDENMUNICIPAL.COMPANIA = ORDENMUNICIPALS.COMPANIA AND BP_ORDENMUNICIPAL.COD_SUBCATEGORIA = ORDENMUNICIPALS.CODIGO AND BP_ORDENMUNICIPAL.TIPOSUB = ORDENMUNICIPALS.TIPO WHERE BP_ORDENMUNICIPAL.COMPANIA = :COMPANIA AND BP_ORDENMUNICIPAL.VIGENCIA = :VIGENCIA AND BP_ORDENMUNICIPAL.COD_PLAN = :COD_PLAN) INI WHERE (CASE WHEN DESC_POLITICA IS NULL THEN ' ' ELSE UPPER(DESC_POLITICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_POLITICA), '%')) AND (CASE WHEN DESC_CATEGORIA IS NULL THEN ' ' ELSE UPPER(DESC_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_CATEGORIA), '%')) AND (CASE WHEN DESC_SUBCATEGORIA IS NULL THEN ' ' ELSE UPPER(DESC_SUBCATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_SUBCATEGORIA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param name="DESC_POLITICA" sqlType="STRING"/>
		<param name="DESC_CATEGORIA" sqlType="STRING"/>
		<param name="DESC_SUBCATEGORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpordenmunicipal/numero">
		<call-query href="getBpordenmunicipalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="DESC_POLITICA" query-param="DESC_POLITICA"/>
			<with-param name="DESC_CATEGORIA" query-param="DESC_CATEGORIA"/>
			<with-param name="DESC_SUBCATEGORIA" query-param="DESC_SUBCATEGORIA"/>

		</call-query>
	</resource>

</data>