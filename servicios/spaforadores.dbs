<data name="spaforadores" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpaforadoresCodigonombreporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  AFORADORES.CODIGO, TERCERO.NOMBRE  FROM SP_AFORADORES AFORADORES INNER JOIN TERCERO ON AFORADORES.COMPANIA = TERCERO.COMPANIA AND AFORADORES.NIT = TERCERO.NIT AND AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE AFORADORES.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spaforadores/codigonombreporcompania">
		<call-query href="getSpaforadoresCodigonombreporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresPagPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SP_AFORADORES.CODIGO, TERCERO.NOMBRE  FROM SP_AFORADORES LEFT JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_AFORADORES.COMPANIA = :COMPANIA ORDER BY SP_AFORADORES.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spaforadores/porcompania/pag">
		<call-query href="getSpaforadoresPagPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresNumPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SP_AFORADORES.CODIGO, TERCERO.NOMBRE  FROM SP_AFORADORES LEFT JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_AFORADORES.COMPANIA = :COMPANIA ORDER BY SP_AFORADORES.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spaforadores/porcompania/num">
		<call-query href="getSpaforadoresNumPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresPagCodynominnerterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  A.CODIGO, T.NOMBRE  FROM SP_AFORADORES A INNER JOIN TERCERO T ON A.COMPANIA = T.COMPANIA AND A.NIT = T.NIT AND A.SUCURSAL = T.SUCURSAL WHERE A.COMPANIA = :COMPANIA ORDER BY A.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spaforadores/codynominnertercero/pag">
		<call-query href="getSpaforadoresPagCodynominnerterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresNumCodynominnerterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  A.CODIGO, T.NOMBRE  FROM SP_AFORADORES A INNER JOIN TERCERO T ON A.COMPANIA = T.COMPANIA AND A.NIT = T.NIT AND A.SUCURSAL = T.SUCURSAL WHERE A.COMPANIA = :COMPANIA ORDER BY A.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spaforadores/codynominnertercero/num">
		<call-query href="getSpaforadoresNumCodynominnerterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresPagTodosInnerInfotipooperacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  '000' CODIGO, 'TODOS' NOMBRE  FROM DUAL UNION SELECT DISTINCT A.CODIGO, T.NOMBRE FROM SP_AFORADORES A INNER JOIN TERCERO T ON A.COMPANIA = T.COMPANIA AND A.NIT = T.NIT AND A.SUCURSAL = T.SUCURSAL INNER JOIN SP_INFO_TIPO_OPERACION ITO ON A.COMPANIA = ITO.COMPANIA AND A.CODIGO = ITO.AFORADOR WHERE ITO.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spaforadores/todosinnerinfotipooperacion/pag">
		<call-query href="getSpaforadoresPagTodosInnerInfotipooperacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresNumTodosInnerInfotipooperacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  '000' CODIGO, 'TODOS' NOMBRE  FROM DUAL UNION SELECT DISTINCT A.CODIGO, T.NOMBRE FROM SP_AFORADORES A INNER JOIN TERCERO T ON A.COMPANIA = T.COMPANIA AND A.NIT = T.NIT AND A.SUCURSAL = T.SUCURSAL INNER JOIN SP_INFO_TIPO_OPERACION ITO ON A.COMPANIA = ITO.COMPANIA AND A.CODIGO = ITO.AFORADOR WHERE ITO.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spaforadores/todosinnerinfotipooperacion/num">
		<call-query href="getSpaforadoresNumTodosInnerInfotipooperacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresNombreSegunCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TERCERO.NOMBRE  FROM SP_AFORADORES INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = SP_AFORADORES.SUCURSAL WHERE SP_AFORADORES.COMPANIA = :COMPANIA AND SP_AFORADORES.CODIGO = :AFORADOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="AFORADOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spaforadores/nombreseguncodigo">
		<call-query href="getSpaforadoresNombreSegunCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="AFORADOR" query-param="AFORADOR"/>

		</call-query>
	</resource>
	<query id="insertSpaforadores" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_AFORADORES (COMPANIA, CODIGO, NIT, SUCURSAL, IDPUSH, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO, :NIT, :SUCURSAL, :IDPUSH, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="IDPUSH" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spaforadores">
		<call-query href="insertSpaforadores">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="IDPUSH" query-param="IDPUSH"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteSpaforadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_AFORADORES WHERE SP_AFORADORES.COMPANIA= :KEY_COMPANIA AND SP_AFORADORES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spaforadores">
		<call-query href="deleteSpaforadores">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_AFORADORES.COMPANIA, SP_AFORADORES.CODIGO, SP_AFORADORES.NIT, TERCERO.APELLIDO1, TERCERO.APELLIDO2, CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) NOMBRES, SP_AFORADORES.SUCURSAL, SP_AFORADORES.IDPUSH, SP_AFORADORES.CREATED_BY,(TO_CHAR(SP_AFORADORES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_AFORADORES.MODIFIED_BY,(TO_CHAR(SP_AFORADORES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_AFORADORES INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_AFORADORES.COMPANIA =:COMPANIA ORDER BY SP_AFORADORES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDO1), '%')) AND (CASE WHEN APELLIDO2 IS NULL THEN ' ' ELSE UPPER(APELLIDO2) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDO2), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NIT":"$NIT","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRES":"$NOMBRES","SUCURSAL":"$SUCURSAL","IDPUSH":"$IDPUSH","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="APELLIDO1" sqlType="STRING"/>
		<param name="APELLIDO2" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spaforadores">
		<call-query href="getSpaforadoresPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="APELLIDO1" query-param="APELLIDO1"/>
			<with-param name="APELLIDO2" query-param="APELLIDO2"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_AFORADORES.COMPANIA, SP_AFORADORES.CODIGO, SP_AFORADORES.NIT, TERCERO.APELLIDO1, TERCERO.APELLIDO2, CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) NOMBRES, SP_AFORADORES.SUCURSAL, SP_AFORADORES.IDPUSH, SP_AFORADORES.CREATED_BY,(TO_CHAR(SP_AFORADORES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_AFORADORES.MODIFIED_BY,(TO_CHAR(SP_AFORADORES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_AFORADORES INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_AFORADORES.COMPANIA =:COMPANIA ORDER BY SP_AFORADORES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDO1), '%')) AND (CASE WHEN APELLIDO2 IS NULL THEN ' ' ELSE UPPER(APELLIDO2) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDO2), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="APELLIDO1" sqlType="STRING"/>
		<param name="APELLIDO2" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spaforadores/numero">
		<call-query href="getSpaforadoresNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="APELLIDO1" query-param="APELLIDO1"/>
			<with-param name="APELLIDO2" query-param="APELLIDO2"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateSpaforadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_AFORADORES SET CODIGO=:CODIGO, NIT=:NIT, SUCURSAL=:SUCURSAL, IDPUSH=:IDPUSH, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_AFORADORES.COMPANIA= :KEY_COMPANIA AND SP_AFORADORES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="IDPUSH" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spaforadores">
		<call-query href="updateSpaforadores">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="IDPUSH" query-param="IDPUSH"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresPagTodosporcodigonombrecompletoaforadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT SP_AFORADORES.CODIGO, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBREAFORADOR FROM SP_AFORADORES INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_AFORADORES.COMPANIA =:COMPANIA ORDER BY SP_AFORADORES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBREAFORADOR IS NULL THEN ' ' ELSE UPPER(NOMBREAFORADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAFORADOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREAFORADOR":"$NOMBREAFORADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREAFORADOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spaforadores/todosporcodigonombrecompletoaforador/pag">
		<call-query href="getSpaforadoresPagTodosporcodigonombrecompletoaforadorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREAFORADOR" query-param="NOMBREAFORADOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpaforadoresNumTodosporcodigonombrecompletoaforadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT SP_AFORADORES.CODIGO, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBREAFORADOR FROM SP_AFORADORES INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_AFORADORES.COMPANIA =:COMPANIA ORDER BY SP_AFORADORES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBREAFORADOR IS NULL THEN ' ' ELSE UPPER(NOMBREAFORADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAFORADOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREAFORADOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spaforadores/todosporcodigonombrecompletoaforador/num">
		<call-query href="getSpaforadoresNumTodosporcodigonombrecompletoaforadorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREAFORADOR" query-param="NOMBREAFORADOR"/>

		</call-query>
	</resource>

</data>