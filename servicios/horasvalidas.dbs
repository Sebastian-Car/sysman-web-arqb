<data name="horasvalidas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getHorasvalidasTodosPorHoraCompletaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(HORASVALIDAS.HORA, 'HH24:MI') HORA  FROM HORASVALIDAS WHERE HORASVALIDAS.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"HORA":"$HORA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="horasvalidas/todosporhoracompleta">
		<call-query href="getHorasvalidasTodosPorHoraCompletaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getHorasvalidasTodosPorHoraFinalCompletaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(HORASVALIDAS.HORAFINAL, 'HH24:MI') HORA  FROM HORASVALIDAS WHERE HORASVALIDAS.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"HORA":"$HORA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="horasvalidas/todosporhorafinalcompleta">
		<call-query href="getHorasvalidasTodosPorHoraFinalCompletaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>