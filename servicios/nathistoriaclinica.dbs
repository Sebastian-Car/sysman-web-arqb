	<query id="insertNathistoriaclinica" keyColumns="COMPANIA,CONSECUTIVO,NUMERO_DCTO,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_HISTORIA_CLINICA (ANTEC_GINECOBS, ANTEC_PER_FAM, ANTEC_QUIRURG, ANTEC_TRABAJO, ANTEC_TRAUMATIC, APTITUDES, COMPANIA, CONCEPTO, CONSECUTIVO, DIAGN_CONDUCTA, ENFER_PROFES, ESTADO_MENTAL, EVAL_AUIDIOMET, EVAL_EGRESO, EVAL_PARACLINICO, EVAL_VISUAL, EXAMEN_FISICO, FECHA_EXAMEN, HABIT_TOXIC, HALLAZGOS, ID_DE_EMPLEADO, INMUNIZACIONES, NUMERO_DCTO, RECOMENDACIONES, REMIS_MEDICAS, SECUELAS, SUCURSAL, TIPO_EXAMEN, TRATAMIENTOS, VACUNAS, VAL_AREA_TRABAJO, DATE_CREATED, CREATED_BY) VALUES (:ANTEC_GINECOBS, :ANTEC_PER_FAM, :ANTEC_QUIRURG, :ANTEC_TRABAJO, :ANTEC_TRAUMATIC, :APTITUDES, :COMPANIA, :CONCEPTO, :CONSECUTIVO, :DIAGN_CONDUCTA, :ENFER_PROFES, :ESTADO_MENTAL, :EVAL_AUIDIOMET, :EVAL_EGRESO, :EVAL_PARACLINICO, :EVAL_VISUAL, :EXAMEN_FISICO, TO_DATE(:FECHA_EXAMEN,'DD/MM/YYYY HH24:MI:SS'), :HABIT_TOXIC, :HALLAZGOS, :ID_DE_EMPLEADO, :INMUNIZACIONES, :NUMERO_DCTO, :RECOMENDACIONES, :REMIS_MEDICAS, :SECUELAS, :SUCURSAL, :TIPO_EXAMEN, :TRATAMIENTOS, :VACUNAS, :VAL_AREA_TRABAJO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_FECHA_EXAMEN":"$FECHA_EXAMEN"}]}}		</result>
		<param defaultValue="" name="ANTEC_GINECOBS" sqlType="STRING"/>
		<param defaultValue="" name="ANTEC_PER_FAM" sqlType="STRING"/>
		<param defaultValue="" name="ANTEC_QUIRURG" sqlType="STRING"/>
