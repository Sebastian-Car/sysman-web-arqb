	<query id="updateNathistoriaclinica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_HISTORIA_CLINICA SET ANTEC_GINECOBS=:ANTEC_GINECOBS, ANTEC_PER_FAM=:ANTEC_PER_FAM, ANTEC_QUIRURG=:ANTEC_QUIRURG, ANTEC_TRABAJO=:ANTEC_TRABAJO, ANTEC_TRAUMATIC=:ANTEC_TRAUMATIC, APTITUDES=:APTITUDES, CONCEPTO=:CONCEPTO, DIAGN_CONDUCTA=:DIAGN_CONDUCTA, ENFER_PROFES=:ENFER_PROFES, ESTADO_MENTAL=:ESTADO_MENTAL, EVAL_AUIDIOMET=:EVAL_AUIDIOMET, EVAL_EGRESO=:EVAL_EGRESO, EVAL_PARACLINICO=:EVAL_PARACLINICO, EVAL_VISUAL=:EVAL_VISUAL, EXAMEN_FISICO=:EXAMEN_FISICO, FECHA_EXAMEN=TO_DATE(:FECHA_EXAMEN,'DD/MM/YYYY HH24:MI:SS'), HABIT_TOXIC=:HABIT_TOXIC, HALLAZGOS=:HALLAZGOS, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, INMUNIZACIONES=:INMUNIZACIONES, NUMERO_DCTO=:NUMERO_DCTO, RECOMENDACIONES=:RECOMENDACIONES, REMIS_MEDICAS=:REMIS_MEDICAS, SECUELAS=:SECUELAS, SUCURSAL=:SUCURSAL, TIPO_EXAMEN=:TIPO_EXAMEN, TRATAMIENTOS=:TRATAMIENTOS, VACUNAS=:VACUNAS, VAL_AREA_TRABAJO=:VAL_AREA_TRABAJO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_HISTORIA_CLINICA.COMPANIA= :KEY_COMPANIA AND NAT_HISTORIA_CLINICA.CONSECUTIVO= :KEY_CONSECUTIVO AND NAT_HISTORIA_CLINICA.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_HISTORIA_CLINICA.SUCURSAL= :KEY_SUCURSAL AND NAT_HISTORIA_CLINICA.FECHA_EXAMEN= TO_DATE(:KEY_FECHA_EXAMEN,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

