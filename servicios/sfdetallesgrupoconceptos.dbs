<data name="sfdetallesgrupoconceptos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfdetallesgrupoconceptosPorCompaniaYTipoCobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SF_DETALLE_GRUPOS_CONCEPTOS.COMPANIA, SF_DETALLE_GRUPOS_CONCEPTOS.TIPOCOBRO, SF_DETALLE_GRUPOS_CONCEPTOS.GRUPO, SF_DETALLE_GRUPOS_CONCEPTOS.CONCEPTO, SF_CONCEPTOS.NOMBRE NOMCONCEPTO  FROM SF_DETALLE_GRUPOS_CONCEPTOS INNER JOIN SF_CONCEPTOS ON SF_CONCEPTOS.COMPANIA = SF_DETALLE_GRUPOS_CONCEPTOS.COMPANIA AND SF_CONCEPTOS.TIPOCOBRO = SF_DETALLE_GRUPOS_CONCEPTOS.TIPOCOBRO AND SF_CONCEPTOS.CODIGO = SF_DETALLE_GRUPOS_CONCEPTOS.CONCEPTO WHERE SF_DETALLE_GRUPOS_CONCEPTOS.COMPANIA = :COMPANIA AND SF_DETALLE_GRUPOS_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO AND SF_CONCEPTOS.ANO = :ANO AND SF_DETALLE_GRUPOS_CONCEPTOS.GRUPO = :GRUPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOBRO":"$TIPOCOBRO","GRUPO":"$GRUPO(type:integer)","CONCEPTO":"$CONCEPTO","NOMCONCEPTO":"$NOMCONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallesgrupoconceptos/porcompaniaytipocobro">
		<call-query href="getSfdetallesgrupoconceptosPorCompaniaYTipoCobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="GRUPO" query-param="GRUPO"/>

		</call-query>
	</resource>
	<query id="insertSfdetallesgrupoconceptos" keyColumns="COMPANIA,TIPOCOBRO,GRUPO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_DETALLE_GRUPOS_CONCEPTOS (COMPANIA, TIPOCOBRO, GRUPO, CONCEPTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOCOBRO, :GRUPO, :CONCEPTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_GRUPO":"$GRUPO(type:integer)","KEY_CONCEPTO":"$CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param defaultValue="0" name="GRUPO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfdetallesgrupoconceptos">
		<call-query href="insertSfdetallesgrupoconceptos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSfdetallesgrupoconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_DETALLE_GRUPOS_CONCEPTOS WHERE SF_DETALLE_GRUPOS_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_GRUPOS_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_DETALLE_GRUPOS_CONCEPTOS.GRUPO= :KEY_GRUPO AND SF_DETALLE_GRUPOS_CONCEPTOS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="INTEGER"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfdetallesgrupoconceptos">
		<call-query href="deleteSfdetallesgrupoconceptos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateSfdetallesgrupoconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_GRUPOS_CONCEPTOS SET TIPOCOBRO=:TIPOCOBRO, GRUPO=:GRUPO, CONCEPTO=:CONCEPTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_DETALLE_GRUPOS_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_GRUPOS_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_DETALLE_GRUPOS_CONCEPTOS.GRUPO= :KEY_GRUPO AND SF_DETALLE_GRUPOS_CONCEPTOS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfdetallesgrupoconceptos">
		<call-query href="updateSfdetallesgrupoconceptos">
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>

</data>