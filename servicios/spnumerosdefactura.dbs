<data name="spnumerosdefactura" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpnumerosdefacturaConsultarConsecutivorealQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CONSECUTIVOREAL  FROM SP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA ORDER BY SECUENCIA DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVOREAL":"$CONSECUTIVOREAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spnumerosdefactura/consultarconsecutivoreal">
		<call-query href="getSpnumerosdefacturaConsultarConsecutivorealQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpnumerosdefacturaConsultarUltimaSecuencuaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(SECUENCIA) ULTIMONUMERO  FROM SP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ULTIMONUMERO":"$ULTIMONUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spnumerosdefactura/consultarultimasecuencua">
		<call-query href="getSpnumerosdefacturaConsultarUltimaSecuencuaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpnumerosdefacturaCalcularElUltimoConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(CONSECUTIVO) KEEP (DENSE_RANK LAST ORDER BY ROWNUM) ULTIMOCON  FROM SP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA AND SECUENCIA &lt;&gt; :SECUENCIA AND LPAD(CONSECUTIVO,10,'0') &gt; :CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ULTIMOCON":"$ULTIMOCON"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spnumerosdefactura/calcularelultimoconsecutivo">
		<call-query href="getSpnumerosdefacturaCalcularElUltimoConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSpnumerosdefacturaMaximoconsecutivorealQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(CONSECUTIVOREAL) REAL  FROM SP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"REAL":"$REAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spnumerosdefactura/maximoconsecutivoreal">
		<call-query href="getSpnumerosdefacturaMaximoconsecutivorealQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertSpnumerosdefactura" keyColumns="COMPANIA,SECUENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_NUMEROSDEFACTURA (COMPANIA, SECUENCIA, CONSECUTIVO, USUARIO, CONSECUTIVOREAL, FECHA, HORA, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :SECUENCIA, :CONSECUTIVO, :USUARIO, :CONSECUTIVOREAL, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_SECUENCIA":"$SECUENCIA(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="CONSECUTIVOREAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="HORA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spnumerosdefactura">
		<call-query href="insertSpnumerosdefactura">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="CONSECUTIVOREAL" query-param="CONSECUTIVOREAL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteSpnumerosdefactura" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_NUMEROSDEFACTURA WHERE SP_NUMEROSDEFACTURA.COMPANIA= :KEY_COMPANIA AND SP_NUMEROSDEFACTURA.SECUENCIA= :KEY_SECUENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_SECUENCIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spnumerosdefactura">
		<call-query href="deleteSpnumerosdefactura">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_SECUENCIA" query-param="KEY_SECUENCIA"/>

		</call-query>
	</resource>
	<query id="getSpnumerosdefacturaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, SECUENCIA, CONSECUTIVO, USUARIO, CONSECUTIVOREAL, TO_CHAR(FECHA,'DD/MM/YYY') FECHA, TO_CHAR(HORA,'HH24:MI:SS') HORA, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN SECUENCIA IS NULL THEN ' ' ELSE UPPER(SECUENCIA) END)  LIKE UPPER(:SECUENCIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN CONSECUTIVOREAL IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOREAL) END)  LIKE UPPER( '%' || :CONSECUTIVOREAL || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END)  LIKE UPPER( '%' || :HORA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SECUENCIA":"$SECUENCIA(type:long)","CONSECUTIVO":"$CONSECUTIVO","USUARIO":"$USUARIO","CONSECUTIVOREAL":"$CONSECUTIVOREAL","FECHA":"$FECHA","HORA":"$HORA","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="CONSECUTIVOREAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spnumerosdefactura">
		<call-query href="getSpnumerosdefacturaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="CONSECUTIVOREAL" query-param="CONSECUTIVOREAL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpnumerosdefacturaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, SECUENCIA, CONSECUTIVO, USUARIO, CONSECUTIVOREAL, TO_CHAR(FECHA,'DD/MM/YYY') FECHA, TO_CHAR(HORA,'HH24:MI:SS') HORA, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_NUMEROSDEFACTURA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN SECUENCIA IS NULL THEN ' ' ELSE UPPER(SECUENCIA) END)  LIKE UPPER(:SECUENCIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN CONSECUTIVOREAL IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOREAL) END)  LIKE UPPER( '%' || :CONSECUTIVOREAL || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END)  LIKE UPPER( '%' || :HORA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="CONSECUTIVOREAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spnumerosdefactura/numero">
		<call-query href="getSpnumerosdefacturaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="CONSECUTIVOREAL" query-param="CONSECUTIVOREAL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA" query-param="HORA"/>

		</call-query>
	</resource>
	<query id="updateSpnumerosdefactura" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_NUMEROSDEFACTURA SET SECUENCIA=:SECUENCIA, CONSECUTIVO=:CONSECUTIVO, USUARIO=:USUARIO, CONSECUTIVOREAL=:CONSECUTIVOREAL, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), HORA=TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_NUMEROSDEFACTURA.COMPANIA= :KEY_COMPANIA AND SP_NUMEROSDEFACTURA.SECUENCIA= :KEY_SECUENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="CONSECUTIVOREAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_SECUENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spnumerosdefactura">
		<call-query href="updateSpnumerosdefactura">
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="CONSECUTIVOREAL" query-param="CONSECUTIVOREAL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_SECUENCIA" query-param="KEY_SECUENCIA"/>

		</call-query>
	</resource>

</data>