<data name="acdetallesplanescompra" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getAcdetallesplanescompraPorCompaniaYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ACTDETPLAN_COMPRAS.ACTUALIZACION, ACTDETPLAN_COMPRAS.COD_DETALLE, ACTDETPLAN_COMPRAS.RUBRO, ACTDETPLAN_COMPRAS.CODIGO, ACTDETPLAN_COMPRAS.ANO, ACTDETPLAN_COMPRAS.TIPO, CASE ACTDETPLAN_COMPRAS.TIPO WHEN 'A' THEN 'Aumento' WHEN 'D' THEN 'Disminución' END NOMBRETIPO, INVENTARIO.NOMBRECORTO NOMBRECORTO, ACTDETPLAN_COMPRAS.DEPENDENCIA, ACTDETPLAN_COMPRAS.MES, ACTDETPLAN_COMPRAS.CANTIDAD, ACTDETPLAN_COMPRAS.VALOR_UNITARIO, ACTDETPLAN_COMPRAS.VALORTOTAL,(CASE ACTDETPLAN_COMPRAS.REALIZADA WHEN 0 THEN 'false' ELSE 'true' END) REALIZADA, ACTDETPLAN_COMPRAS.OBSERVACIONES, ACTDETPLAN_COMPRAS.SUBPROYECTO, ACTDETPLAN_COMPRAS.DESCRIPCION, ACTDETPLAN_COMPRAS.AUXILIAR, ACTDETPLAN_COMPRAS.CENTRO_COSTO, DEPENDENCIA.NOMBRE, MES.NOMBRE NOMBREMES, ACTDETPLAN_COMPRAS.COMPANIA, ACTDETPLAN_COMPRAS.REFERENCIA, ACTDETPLAN_COMPRAS.FUENTE_DE_RECURSOS, SUBPROYECTO.NOMBRE NOMBRESUBPROYECTO  FROM ACTDETPLAN_COMPRAS LEFT JOIN INVENTARIO ON ACTDETPLAN_COMPRAS.COMPANIA = INVENTARIO.COMPANIA AND ACTDETPLAN_COMPRAS.CODIGO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEPENDENCIA ON ACTDETPLAN_COMPRAS.COMPANIA = DEPENDENCIA.COMPANIA AND ACTDETPLAN_COMPRAS.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN MES ON ACTDETPLAN_COMPRAS.COMPANIA = MES.COMPANIA AND ACTDETPLAN_COMPRAS.ANO = MES.ANO AND ACTDETPLAN_COMPRAS.MES = MES.NUMERO LEFT JOIN SUBPROYECTO ON ACTDETPLAN_COMPRAS.COMPANIA = SUBPROYECTO.COMPANIA AND ACTDETPLAN_COMPRAS.SUBPROYECTO = SUBPROYECTO.CODIGOSUBPROYECTO WHERE ACTDETPLAN_COMPRAS.ACTUALIZACION = :ACTUALIZACION AND ACTDETPLAN_COMPRAS.COMPANIA = :COMPANIA AND ACTDETPLAN_COMPRAS.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ACTUALIZACION":"$ACTUALIZACION(type:long)","COD_DETALLE":"$COD_DETALLE(type:long)","RUBRO":"$RUBRO","CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NOMBRETIPO":"$NOMBRETIPO","NOMBRECORTO":"$NOMBRECORTO","DEPENDENCIA":"$DEPENDENCIA","MES":"$MES(type:integer)","CANTIDAD":"$CANTIDAD","VALOR_UNITARIO":"$VALOR_UNITARIO","VALORTOTAL":"$VALORTOTAL","REALIZADA":"$REALIZADA(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","SUBPROYECTO":"$SUBPROYECTO(type:long)","DESCRIPCION":"$DESCRIPCION","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRE":"$NOMBRE","NOMBREMES":"$NOMBREMES","COMPANIA":"$COMPANIA","REFERENCIA":"$REFERENCIA","FUENTE_DE_RECURSOS":"$FUENTE_DE_RECURSOS","NOMBRESUBPROYECTO":"$NOMBRESUBPROYECTO"}]}}		</result>
		<param name="ACTUALIZACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="acdetallesplanescompra/porcompaniayanio">
		<call-query href="getAcdetallesplanescompraPorCompaniaYAnioQuery">
			<with-param name="ACTUALIZACION" query-param="ACTUALIZACION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertAcdetallesplanescompra" keyColumns="COMPANIA,ANO,ACTUALIZACION,COD_DETALLE,RUBRO,CODIGO,CENTRO_COSTO,AUXILIAR,REFERENCIA,FUENTE_DE_RECURSOS" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ACTDETPLAN_COMPRAS (COMPANIA, ACTUALIZACION, COD_DETALLE, RUBRO, CODIGO, ANO, TIPO, DEPENDENCIA, MES, CANTIDAD, VALOR_UNITARIO, VALORTOTAL, REALIZADA, OBSERVACIONES, SUBPROYECTO, DESCRIPCION, AUXILIAR, CENTRO_COSTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ACTUALIZACION, :COD_DETALLE, :RUBRO, :CODIGO, :ANO, :TIPO, :DEPENDENCIA, :MES, :CANTIDAD, :VALOR_UNITARIO, :VALORTOTAL, :REALIZADA, :OBSERVACIONES, :SUBPROYECTO, :DESCRIPCION, :AUXILIAR, :CENTRO_COSTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_ACTUALIZACION":"$ACTUALIZACION(type:long)","KEY_COD_DETALLE":"$COD_DETALLE(type:long)","KEY_RUBRO":"$RUBRO","KEY_CODIGO":"$CODIGO","KEY_CENTRO_COSTO":"$CENTRO_COSTO","KEY_AUXILIAR":"$AUXILIAR","KEY_REFERENCIA":"$REFERENCIA","KEY_FUENTE_DE_RECURSOS":"$FUENTE_DE_RECURSOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="ACTUALIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="COD_DETALLE" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="0" name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="MES" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="REALIZADA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="SUBPROYECTO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="acdetallesplanescompra">
		<call-query href="insertAcdetallesplanescompra">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACTUALIZACION" query-param="ACTUALIZACION"/>
			<with-param name="COD_DETALLE" query-param="COD_DETALLE"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALOR_UNITARIO" query-param="VALOR_UNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="REALIZADA" query-param="REALIZADA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="SUBPROYECTO" query-param="SUBPROYECTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteAcdetallesplanescompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ACTDETPLAN_COMPRAS WHERE ACTDETPLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND ACTDETPLAN_COMPRAS.ANO= :KEY_ANO AND ACTDETPLAN_COMPRAS.ACTUALIZACION= :KEY_ACTUALIZACION AND ACTDETPLAN_COMPRAS.COD_DETALLE= :KEY_COD_DETALLE AND ACTDETPLAN_COMPRAS.RUBRO= :KEY_RUBRO AND ACTDETPLAN_COMPRAS.CODIGO= :KEY_CODIGO AND ACTDETPLAN_COMPRAS.CENTRO_COSTO= :KEY_CENTRO_COSTO AND ACTDETPLAN_COMPRAS.AUXILIAR= :KEY_AUXILIAR AND ACTDETPLAN_COMPRAS.REFERENCIA= :KEY_REFERENCIA AND ACTDETPLAN_COMPRAS.FUENTE_DE_RECURSOS= :KEY_FUENTE_DE_RECURSOS</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_ACTUALIZACION" sqlType="STRING"/>
		<param name="KEY_COD_DETALLE" sqlType="STRING"/>
		<param name="KEY_RUBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>
		<param name="KEY_AUXILIAR" sqlType="STRING"/>
		<param name="KEY_REFERENCIA" sqlType="STRING"/>
		<param name="KEY_FUENTE_DE_RECURSOS" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="acdetallesplanescompra">
		<call-query href="deleteAcdetallesplanescompra">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_ACTUALIZACION" query-param="KEY_ACTUALIZACION"/>
			<with-param name="KEY_COD_DETALLE" query-param="KEY_COD_DETALLE"/>
			<with-param name="KEY_RUBRO" query-param="KEY_RUBRO"/>
