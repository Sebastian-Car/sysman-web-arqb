			<with-param name="KEY_AUXILIAR" query-param="KEY_AUXILIAR"/>
			<with-param name="KEY_REFERENCIA" query-param="KEY_REFERENCIA"/>
			<with-param name="KEY_FUENTE_DE_RECURSOS" query-param="KEY_FUENTE_DE_RECURSOS"/>

		</call-query>
	</resource>
	<query id="getAcdetallesplanescompraPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ACTDETPLAN_COMPRAS.ACTUALIZACION, ACTDETPLAN_COMPRAS.COD_DETALLE, ACTDETPLAN_COMPRAS.RUBRO, ACTDETPLAN_COMPRAS.CODIGO, ACTDETPLAN_COMPRAS.ANO, ACTDETPLAN_COMPRAS.TIPO, CASE ACTDETPLAN_COMPRAS.TIPO WHEN 'A' THEN 'Aumento' WHEN 'D' THEN 'Disminución' END NOMBRETIPO, INVENTARIO.NOMBRECORTO NOMBRECORTO, ACTDETPLAN_COMPRAS.DEPENDENCIA, ACTDETPLAN_COMPRAS.MES, ACTDETPLAN_COMPRAS.CANTIDAD, ACTDETPLAN_COMPRAS.VALOR_UNITARIO, ACTDETPLAN_COMPRAS.VALORTOTAL,(CASE ACTDETPLAN_COMPRAS.REALIZADA WHEN 0 THEN 'false' ELSE 'true' END) REALIZADA, ACTDETPLAN_COMPRAS.OBSERVACIONES, ACTDETPLAN_COMPRAS.SUBPROYECTO, ACTDETPLAN_COMPRAS.DESCRIPCION, ACTDETPLAN_COMPRAS.AUXILIAR, ACTDETPLAN_COMPRAS.CENTRO_COSTO, DEPENDENCIA.NOMBRE, MES.NOMBRE NOMBREMES  FROM ACTDETPLAN_COMPRAS LEFT JOIN INVENTARIO ON ACTDETPLAN_COMPRAS.COMPANIA = INVENTARIO.COMPANIA AND ACTDETPLAN_COMPRAS.CODIGO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEPENDENCIA ON ACTDETPLAN_COMPRAS.COMPANIA = DEPENDENCIA.COMPANIA AND ACTDETPLAN_COMPRAS.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN MES ON ACTDETPLAN_COMPRAS.COMPANIA = MES.COMPANIA AND ACTDETPLAN_COMPRAS.ANO = MES.ANO AND ACTDETPLAN_COMPRAS.MES = MES.NUMERO WHERE ACTDETPLAN_COMPRAS.ACTUALIZACION = :ACTUALIZACION AND ACTDETPLAN_COMPRAS.COMPANIA = :COMPANIA AND ACTDETPLAN_COMPRAS.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ACTUALIZACION":"$ACTUALIZACION(type:long)","COD_DETALLE":"$COD_DETALLE(type:long)","RUBRO":"$RUBRO","CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NOMBRETIPO":"$NOMBRETIPO","NOMBRECORTO":"$NOMBRECORTO","DEPENDENCIA":"$DEPENDENCIA","MES":"$MES(type:integer)","CANTIDAD":"$CANTIDAD","VALOR_UNITARIO":"$VALOR_UNITARIO","VALORTOTAL":"$VALORTOTAL","REALIZADA":"$REALIZADA(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","SUBPROYECTO":"$SUBPROYECTO(type:long)","DESCRIPCION":"$DESCRIPCION","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRE":"$NOMBRE","NOMBREMES":"$NOMBREMES"}]}}		</result>
		<param name="ACTUALIZACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="acdetallesplanescompra">
		<call-query href="getAcdetallesplanescompraPaginaQuery">
			<with-param name="ACTUALIZACION" query-param="ACTUALIZACION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateAcdetallesplanescompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ACTDETPLAN_COMPRAS SET ACTUALIZACION=:ACTUALIZACION, COD_DETALLE=:COD_DETALLE, RUBRO=:RUBRO, CODIGO=:CODIGO, ANO=:ANO, TIPO=:TIPO, DEPENDENCIA=:DEPENDENCIA, MES=:MES, CANTIDAD=:CANTIDAD, VALOR_UNITARIO=:VALOR_UNITARIO, VALORTOTAL=:VALORTOTAL, REALIZADA=:REALIZADA, OBSERVACIONES=:OBSERVACIONES, SUBPROYECTO=:SUBPROYECTO, DESCRIPCION=:DESCRIPCION, AUXILIAR=:AUXILIAR, CENTRO_COSTO=:CENTRO_COSTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ACTDETPLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND ACTDETPLAN_COMPRAS.ANO= :KEY_ANO AND ACTDETPLAN_COMPRAS.ACTUALIZACION= :KEY_ACTUALIZACION AND ACTDETPLAN_COMPRAS.COD_DETALLE= :KEY_COD_DETALLE AND ACTDETPLAN_COMPRAS.RUBRO= :KEY_RUBRO AND ACTDETPLAN_COMPRAS.CODIGO= :KEY_CODIGO AND ACTDETPLAN_COMPRAS.CENTRO_COSTO= :KEY_CENTRO_COSTO AND ACTDETPLAN_COMPRAS.AUXILIAR= :KEY_AUXILIAR AND ACTDETPLAN_COMPRAS.REFERENCIA= :KEY_REFERENCIA AND ACTDETPLAN_COMPRAS.FUENTE_DE_RECURSOS= :KEY_FUENTE_DE_RECURSOS</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ACTUALIZACION" sqlType="STRING"/>
		<param name="COD_DETALLE" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALOR_UNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="REALIZADA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="SUBPROYECTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_ACTUALIZACION" sqlType="STRING"/>
		<param name="KEY_COD_DETALLE" sqlType="STRING"/>
		<param name="KEY_RUBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>
		<param name="KEY_AUXILIAR" sqlType="STRING"/>
		<param name="KEY_REFERENCIA" sqlType="STRING"/>
		<param name="KEY_FUENTE_DE_RECURSOS" sqlType="STRING"/>

	</query>
