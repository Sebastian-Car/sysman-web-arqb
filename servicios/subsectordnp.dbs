<data name="subsectordnp" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSubsectordnpTodosPorCodigoDnpYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUBSECTORDNP.CODIGODNP, SUBSECTORDNP.NOMBRE  FROM SUBSECTORDNP WHERE SUBSECTORDNP.COMPANIA = :COMPANIA AND SUBSECTORDNP.CODIGOSECTORDNP = :CODIGOSECTORDNP</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGODNP":"$CODIGODNP","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOSECTORDNP" sqlType="STRING"/>

	</query>
	<resource method="GET" path="subsectordnp/todosporcodigodnpynombre">
		<call-query href="getSubsectordnpTodosPorCodigoDnpYNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOSECTORDNP" query-param="CODIGOSECTORDNP"/>

		</call-query>
	</resource>

</data>