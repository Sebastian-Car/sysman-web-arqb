	<query id="deleteNatnombramiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_NOMBRAMIENTO WHERE NAT_NOMBRAMIENTO.COMPANIA= :KEY_COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_NOMBRAMIENTO.SUCURSAL= :KEY_SUCURSAL AND NAT_NOMBRAMIENTO.NO_NUME= :KEY_NO_NUME AND NAT_NOMBRAMIENTO.NO_FECHRESODECR= TO_DATE(:KEY_NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NO_NUME" sqlType="STRING"/>
		<param name="KEY_NO_FECHRESODECR" sqlType="STRING"/>

	</query>
