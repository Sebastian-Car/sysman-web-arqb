		<sql>UPDATE NAT_NOMBRAMIENTO SET DP_NUMEDOCU=:DP_NUMEDOCU, SUCURSAL=:SUCURSAL, NO_TIPODOCUACTO=:NO_TIPODOCUACTO, NO_NUME=:NO_NUME, NO_FECHRESODECR=TO_DATE(:NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), NO_CARGOA=:NO_CARGOA, NO_SALARIOA=:NO_SALARIOA, NO_CARGON=:NO_CARGON, NO_SALARION=:NO_SALARION, NO_ACTAPOSE=:NO_ACTAPOSE, NO_FECHACTAPOSE=TO_DATE(:NO_FECHACTAPOSE,'DD/MM/YYYY HH24:MI:SS'), NO_TIPO=:NO_TIPO, NO_CAUSA=:NO_CAUSA, NO_DEPEANTE=:NO_DEPEANTE, NO_DEPENUEV=:NO_DEPENUEV, EN_FECHDESDE=TO_DATE(:EN_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), EN_FECHHASTA=TO_DATE(:EN_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), NO_FECHAEFECTIVIDAD=TO_DATE(:NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS'), NO_CODIGOCARGO=:NO_CODIGOCARGO, NO_GRADOCARGO=:NO_GRADOCARGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_NOMBRAMIENTO.COMPANIA= :KEY_COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_NOMBRAMIENTO.SUCURSAL= :KEY_SUCURSAL AND NAT_NOMBRAMIENTO.NO_NUME= :KEY_NO_NUME AND NAT_NOMBRAMIENTO.NO_FECHRESODECR= TO_DATE(:KEY_NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
