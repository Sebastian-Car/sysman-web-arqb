	<query id="updateNatnombramiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_NOMBRAMIENTO SET COMPANIA=:COMPANIA, SUCURSAL=:SUCURSAL, DP_NUMEDOCU=:DP_NUMEDOCU, NO_TIPODOCUACTO=:NO_TIPODOCUACTO, NO_NUME=:NO_NUME, NO_FECHRESODECR=TO_DATE(:NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), NO_ESCALAFON=:NO_ESCALAFON, NO_ID_DE_CARGO=:NO_ID_DE_CARGO, NO_CATEGORIA=:NO_CATEGORIA, NO_GRADOCARGO=:NO_GRADOCARGO, NO_FECHACARGO=TO_DATE(:NO_FECHACARGO,'DD/MM/YYYY HH24:MI:SS'), NO_SALARION=:NO_SALARION, PRIMATECNICAFACTOR=:PRIMATECNICAFACTOR, PRIMATECNICANFACTOR=:PRIMATECNICANFACTOR, GASTOSREPRESENTACION=:GASTOSREPRESENTACION, NO_DEPENUEV=:NO_DEPENUEV, NO_TIPO=:NO_TIPO, NO_DEPEANTE=:NO_DEPEANTE, NO_CARGOA=:NO_CARGOA, NO_SALARIOA=:NO_SALARIOA, EN_FECHDESDE=TO_DATE(:EN_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), EN_FECHHASTA=TO_DATE(:EN_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), NO_FECHAEFECTIVIDAD=TO_DATE(:NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS'), NO_FECHACTAPOSE=TO_DATE(:NO_FECHACTAPOSE,'DD/MM/YYYY HH24:MI:SS'), NO_ACTAPOSE=:NO_ACTAPOSE, CODAREA=:CODAREA, ANOFUNCION=:ANOFUNCION, PRIMAALTAGESTION=:PRIMAALTAGESTION, NO_AUXT=:NO_AUXT, NO_AUXA=:NO_AUXA, ESTADO_VINCULACION=:ESTADO_VINCULACION, ULT_CARGO=:ULT_CARGO, NO_CAUSA=:NO_CAUSA, NO_CARGON=:NO_CARGON, RETIRO_O_NOMBRAMIENTO=:RETIRO_O_NOMBRAMIENTO, NB_CODIGOPERSONA=:NB_CODIGOPERSONA, NO_CODIGOCARGO=:NO_CODIGOCARGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_NOMBRAMIENTO.COMPANIA= :KEY_COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_NOMBRAMIENTO.SUCURSAL= :KEY_SUCURSAL AND NAT_NOMBRAMIENTO.NO_NUME= :KEY_NO_NUME AND NAT_NOMBRAMIENTO.NO_FECHRESODECR= TO_DATE(:KEY_NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
