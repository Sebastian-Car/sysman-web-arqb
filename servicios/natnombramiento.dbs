			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NO_NUME" query-param="KEY_NO_NUME"/>
			<with-param name="KEY_NO_FECHRESODECR" query-param="KEY_NO_FECHRESODECR"/>

		</call-query>
	</resource>
	<query id="getNatnombramientoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , SUCURSAL, DP_NUMEDOCU, NO_TIPODOCUACTO, NO_NUME,(TO_CHAR(NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) NO_FECHRESODECR, NO_ESCALAFON, NO_ID_DE_CARGO, NO_CATEGORIA, NO_GRADOCARGO,(TO_CHAR(NO_FECHACARGO,'DD/MM/YYYY HH24:MI:SS')) NO_FECHACARGO, NO_SALARION, PRIMATECNICAFACTOR, PRIMATECNICANFACTOR, NO_DEPENUEV, NO_TIPO, NO_DEPEANTE, NO_CARGOA, NO_SALARIOA,(TO_CHAR(EN_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) EN_FECHDESDE,(TO_CHAR(EN_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) EN_FECHHASTA,(TO_CHAR(NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS')) NO_FECHAEFECTIVIDAD,(TO_CHAR(NO_FECHACTAPOSE,'DD/MM/YYYY HH24:MI:SS')) NO_FECHACTAPOSE, NO_ACTAPOSE, CODAREA, ANOFUNCION, PRIMAALTAGESTION, NO_AUXT, NO_AUXA,(CASE ESTADO_VINCULACION WHEN 0 THEN 'false' ELSE 'true' END) ESTADO_VINCULACION,(CASE ULT_CARGO WHEN 0 THEN 'false' ELSE 'true' END) ULT_CARGO, NO_CAUSA, NO_CARGON, RETIRO_O_NOMBRAMIENTO, NB_CODIGOPERSONA, NO_CODIGOCARGO  FROM NAT_NOMBRAMIENTO WHERE NAT_NOMBRAMIENTO.COMPANIA = :COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU = :CODIGO AND NAT_NOMBRAMIENTO.SUCURSAL = :SUCURSAL AND NAT_NOMBRAMIENTO.RETIRO_O_NOMBRAMIENTO = 'N' ORDER BY NAT_NOMBRAMIENTO.NO_FECHRESODECR DESC) WHERE (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN NO_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(NO_TIPODOCUACTO) END)  LIKE UPPER(:NO_TIPODOCUACTO || '%')  AND (CASE WHEN NO_NUME IS NULL THEN ' ' ELSE UPPER(NO_NUME) END)  LIKE UPPER(:NO_NUME || '%')  AND (CASE WHEN NO_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(NO_FECHRESODECR) END)  LIKE UPPER(:NO_FECHRESODECR || '%')  AND (CASE WHEN NO_ESCALAFON IS NULL THEN ' ' ELSE UPPER(NO_ESCALAFON) END)  LIKE UPPER(:NO_ESCALAFON || '%')  AND (CASE WHEN NO_ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(NO_ID_DE_CARGO) END)  LIKE UPPER(:NO_ID_DE_CARGO || '%')  AND (CASE WHEN NO_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NO_CATEGORIA) END)  LIKE UPPER(:NO_CATEGORIA || '%')  AND (CASE WHEN NO_GRADOCARGO IS NULL THEN ' ' ELSE UPPER(NO_GRADOCARGO) END)  LIKE UPPER(:NO_GRADOCARGO || '%')  AND (CASE WHEN NO_FECHACARGO IS NULL THEN ' ' ELSE UPPER(NO_FECHACARGO) END)  LIKE UPPER(:NO_FECHACARGO || '%')  AND (CASE WHEN NO_SALARION IS NULL THEN ' ' ELSE UPPER(NO_SALARION) END)  LIKE UPPER(:NO_SALARION || '%')  AND (CASE WHEN PRIMATECNICAFACTOR IS NULL THEN ' ' ELSE UPPER(PRIMATECNICAFACTOR) END)  LIKE UPPER(:PRIMATECNICAFACTOR || '%')  AND (CASE WHEN PRIMATECNICANFACTOR IS NULL THEN ' ' ELSE UPPER(PRIMATECNICANFACTOR) END)  LIKE UPPER(:PRIMATECNICANFACTOR || '%')  AND (CASE WHEN NO_DEPENUEV IS NULL THEN ' ' ELSE UPPER(NO_DEPENUEV) END)  LIKE UPPER(:NO_DEPENUEV || '%')  AND (CASE WHEN NO_TIPO IS NULL THEN ' ' ELSE UPPER(NO_TIPO) END)  LIKE UPPER(:NO_TIPO || '%')  AND (CASE WHEN NO_DEPEANTE IS NULL THEN ' ' ELSE UPPER(NO_DEPEANTE) END)  LIKE UPPER(:NO_DEPEANTE || '%')  AND (CASE WHEN NO_CARGOA IS NULL THEN ' ' ELSE UPPER(NO_CARGOA) END)  LIKE UPPER(:NO_CARGOA || '%')  AND (CASE WHEN NO_SALARIOA IS NULL THEN ' ' ELSE UPPER(NO_SALARIOA) END)  LIKE UPPER(:NO_SALARIOA || '%')  AND (CASE WHEN EN_FECHDESDE IS NULL THEN ' ' ELSE UPPER(EN_FECHDESDE) END)  LIKE UPPER(:EN_FECHDESDE || '%')  AND (CASE WHEN EN_FECHHASTA IS NULL THEN ' ' ELSE UPPER(EN_FECHHASTA) END)  LIKE UPPER(:EN_FECHHASTA || '%')  AND (CASE WHEN NO_FECHAEFECTIVIDAD IS NULL THEN ' ' ELSE UPPER(NO_FECHAEFECTIVIDAD) END)  LIKE UPPER(:NO_FECHAEFECTIVIDAD || '%')  AND (CASE WHEN NO_FECHACTAPOSE IS NULL THEN ' ' ELSE UPPER(NO_FECHACTAPOSE) END)  LIKE UPPER(:NO_FECHACTAPOSE || '%')  AND (CASE WHEN NO_ACTAPOSE IS NULL THEN ' ' ELSE UPPER(NO_ACTAPOSE) END)  LIKE UPPER(:NO_ACTAPOSE || '%')  AND (CASE WHEN CODAREA IS NULL THEN ' ' ELSE UPPER(CODAREA) END)  LIKE UPPER(:CODAREA || '%')  AND (CASE WHEN ANOFUNCION IS NULL THEN ' ' ELSE UPPER(ANOFUNCION) END)  LIKE UPPER(:ANOFUNCION || '%')  AND (CASE WHEN PRIMAALTAGESTION IS NULL THEN ' ' ELSE UPPER(PRIMAALTAGESTION) END)  LIKE UPPER(:PRIMAALTAGESTION || '%')  AND (CASE WHEN NO_AUXT IS NULL THEN ' ' ELSE UPPER(NO_AUXT) END)  LIKE UPPER(:NO_AUXT || '%')  AND (CASE WHEN NO_AUXA IS NULL THEN ' ' ELSE UPPER(NO_AUXA) END)  LIKE UPPER(:NO_AUXA || '%')  AND (CASE WHEN ESTADO_VINCULACION IS NULL THEN ' ' ELSE UPPER(ESTADO_VINCULACION) END)  LIKE UPPER(:ESTADO_VINCULACION || '%')  AND (CASE WHEN ULT_CARGO IS NULL THEN ' ' ELSE UPPER(ULT_CARGO) END)  LIKE UPPER(:ULT_CARGO || '%')  AND (CASE WHEN NO_CAUSA IS NULL THEN ' ' ELSE UPPER(NO_CAUSA) END)  LIKE UPPER(:NO_CAUSA || '%')  AND (CASE WHEN NO_CARGON IS NULL THEN ' ' ELSE UPPER(NO_CARGON) END)  LIKE UPPER(:NO_CARGON || '%')  AND (CASE WHEN RETIRO_O_NOMBRAMIENTO IS NULL THEN ' ' ELSE UPPER(RETIRO_O_NOMBRAMIENTO) END)  LIKE UPPER(:RETIRO_O_NOMBRAMIENTO || '%')  AND (CASE WHEN NB_CODIGOPERSONA IS NULL THEN ' ' ELSE UPPER(NB_CODIGOPERSONA) END)  LIKE UPPER(:NB_CODIGOPERSONA || '%')  AND (CASE WHEN NO_CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(NO_CODIGOCARGO) END)  LIKE UPPER(:NO_CODIGOCARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","DP_NUMEDOCU":"$DP_NUMEDOCU","NO_TIPODOCUACTO":"$NO_TIPODOCUACTO(type:integer)","NO_NUME":"$NO_NUME","NO_FECHRESODECR":"$NO_FECHRESODECR","NO_ESCALAFON":"$NO_ESCALAFON","NO_ID_DE_CARGO":"$NO_ID_DE_CARGO","NO_CATEGORIA":"$NO_CATEGORIA","NO_GRADOCARGO":"$NO_GRADOCARGO","NO_FECHACARGO":"$NO_FECHACARGO","NO_SALARION":"$NO_SALARION","PRIMATECNICAFACTOR":"$PRIMATECNICAFACTOR","PRIMATECNICANFACTOR":"$PRIMATECNICANFACTOR","NO_DEPENUEV":"$NO_DEPENUEV","NO_TIPO":"$NO_TIPO","NO_DEPEANTE":"$NO_DEPEANTE","NO_CARGOA":"$NO_CARGOA","NO_SALARIOA":"$NO_SALARIOA","EN_FECHDESDE":"$EN_FECHDESDE","EN_FECHHASTA":"$EN_FECHHASTA","NO_FECHAEFECTIVIDAD":"$NO_FECHAEFECTIVIDAD","NO_FECHACTAPOSE":"$NO_FECHACTAPOSE","NO_ACTAPOSE":"$NO_ACTAPOSE","CODAREA":"$CODAREA","ANOFUNCION":"$ANOFUNCION(type:integer)","PRIMAALTAGESTION":"$PRIMAALTAGESTION","NO_AUXT":"$NO_AUXT","NO_AUXA":"$NO_AUXA","ESTADO_VINCULACION":"$ESTADO_VINCULACION(type:boolean)","ULT_CARGO":"$ULT_CARGO(type:boolean)","NO_CAUSA":"$NO_CAUSA","NO_CARGON":"$NO_CARGON","RETIRO_O_NOMBRAMIENTO":"$RETIRO_O_NOMBRAMIENTO","NB_CODIGOPERSONA":"$NB_CODIGOPERSONA","NO_CODIGOCARGO":"$NO_CODIGOCARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="NO_TIPODOCUACTO" sqlType="STRING"/>
