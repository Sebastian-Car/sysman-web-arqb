		<param defaultValue="" name="EN_FECHDESDE" sqlType="STRING"/>
		<param defaultValue="" name="EN_FECHHASTA" sqlType="STRING"/>
		<param defaultValue="" name="NO_FECHAEFECTIVIDAD" sqlType="STRING"/>
		<param defaultValue="" name="NO_FECHACTAPOSE" sqlType="STRING"/>
