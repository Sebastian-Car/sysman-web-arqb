	</resource>
	<query id="insertNatnombramientoNombramientoPrueba" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,NO_NUME" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_NOMBRAMIENTO (COMPANIA, DP_NUMEDOCU, SUCURSAL, NO_TIPODOCUACTO, NO_NUME, NO_FECHRESODECR, NO_CARGOA, NO_SALARIOA, NO_CARGON, NO_SALARION, NO_ACTAPOSE, NO_FECHACTAPOSE, NO_TIPO, NO_CAUSA, NO_DEPEANTE, NO_DEPENUEV, EN_FECHDESDE, EN_FECHHASTA, NO_FECHAEFECTIVIDAD, NO_CODIGOCARGO, NO_GRADOCARGO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :NO_TIPODOCUACTO, :NO_NUME, TO_DATE(:NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), :NO_CARGOA, :NO_SALARIOA, :NO_CARGON, :NO_SALARION, :NO_ACTAPOSE, TO_DATE(:NO_FECHACTAPOSE,'DD/MM/YYYY HH24:MI:SS'), :NO_TIPO, :NO_CAUSA, :NO_DEPEANTE, :NO_DEPENUEV, TO_DATE(:EN_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:EN_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS'), :NO_CODIGOCARGO, :NO_GRADOCARGO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_NO_NUME":"$NO_NUME","KEY_NO_FECHRESODECR":"$NO_FECHRESODECR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NO_TIPODOCUACTO" sqlType="STRING"/>
