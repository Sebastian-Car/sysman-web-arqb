	<query id="insertNatnombramiento" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,NO_NUME" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_NOMBRAMIENTO (COMPANIA, SUCURSAL, DP_NUMEDOCU, NO_TIPODOCUACTO, NO_NUME, NO_FECHRESODECR, NO_ESCALAFON, NO_ID_DE_CARGO, NO_CATEGORIA, NO_GRADOCARGO, NO_FECHACARGO, NO_SALARION, PRIMATECNICAFACTOR, PRIMATECNICANFACTOR, GASTOSREPRESENTACION, NO_DEPENUEV, NO_TIPO, NO_DEPEANTE, NO_CARGOA, NO_SALARIOA, EN_FECHDESDE, EN_FECHHASTA, NO_FECHAEFECTIVIDAD, NO_FECHACTAPOSE, NO_ACTAPOSE, CODAREA, ANOFUNCION, PRIMAALTAGESTION, NO_AUXT, NO_AUXA, ESTADO_VINCULACION, ULT_CARGO, NO_CAUSA, NO_CARGON, RETIRO_O_NOMBRAMIENTO, NB_CODIGOPERSONA, NO_CODIGOCARGO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :SUCURSAL, :DP_NUMEDOCU, :NO_TIPODOCUACTO, :NO_NUME, TO_DATE(:NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), :NO_ESCALAFON, :NO_ID_DE_CARGO, :NO_CATEGORIA, :NO_GRADOCARGO, TO_DATE(:NO_FECHACARGO,'DD/MM/YYYY HH24:MI:SS'), :NO_SALARION, :PRIMATECNICAFACTOR, :PRIMATECNICANFACTOR, :GASTOSREPRESENTACION, :NO_DEPENUEV, :NO_TIPO, :NO_DEPEANTE, :NO_CARGOA, :NO_SALARIOA, TO_DATE(:EN_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:EN_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:NO_FECHACTAPOSE,'DD/MM/YYYY HH24:MI:SS'), :NO_ACTAPOSE, :CODAREA, :ANOFUNCION, :PRIMAALTAGESTION, :NO_AUXT, :NO_AUXA, :ESTADO_VINCULACION, :ULT_CARGO, :NO_CAUSA, :NO_CARGON, :RETIRO_O_NOMBRAMIENTO, :NB_CODIGOPERSONA, :NO_CODIGOCARGO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_NO_NUME":"$NO_NUME","KEY_NO_FECHRESODECR":"$NO_FECHRESODECR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="NO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="NO_NUME" sqlType="STRING"/>
		<param name="NO_FECHRESODECR" sqlType="STRING"/>
