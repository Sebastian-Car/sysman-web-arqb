<data name="natnombramiento" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatnombramientoPagRetirosPorEmpleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_TIPO_ACTO_ADTIVO.TIPOACTOADTIVO, NAT_TIPO_ACTO_ADTIVO.CODIGO, CAUSARETIRO.CODIGO CODIGOCAUSA, CAUSARETIRO.NOMBRE, NAT_NOMBRAMIENTO.NO_NUME,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) NO_FECHRESODECR,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS')) NO_FECHAEFECTIVIDAD, NAT_NOMBRAMIENTO.NO_CARGOA, NAT_NOMBRAMIENTO.NO_CAUSA, CARGOS.NOMBRE_DEL_CARGO  FROM NAT_NOMBRAMIENTO LEFT JOIN CAUSARETIRO ON NAT_NOMBRAMIENTO.COMPANIA = CAUSARETIRO.COMPANIA AND NAT_NOMBRAMIENTO.NO_TIPO = CAUSARETIRO.CODIGO LEFT JOIN NAT_TIPO_ACTO_ADTIVO ON NAT_NOMBRAMIENTO.NO_TIPODOCUACTO = NAT_TIPO_ACTO_ADTIVO.CODIGO LEFT JOIN CARGOS ON CARGOS.COMPANIA = NAT_NOMBRAMIENTO.COMPANIA AND CARGOS.ID_DE_CARGO = NAT_NOMBRAMIENTO.NO_CARGOA WHERE NAT_NOMBRAMIENTO.COMPANIA = :COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU = :DP_NUMEDOCU AND NAT_NOMBRAMIENTO.RETIRO_O_NOMBRAMIENTO = 'R' ORDER BY NAT_NOMBRAMIENTO.NO_FECHRESODECR DESC) WHERE (CASE WHEN TIPOACTOADTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTOADTIVO) END)  LIKE UPPER(:TIPOACTOADTIVO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NO_NUME IS NULL THEN ' ' ELSE UPPER(NO_NUME) END)  LIKE UPPER( '%' || :NO_NUME || '%')  AND (CASE WHEN NO_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(NO_FECHRESODECR) END)  LIKE UPPER( '%' || :NO_FECHRESODECR || '%')  AND (CASE WHEN NO_FECHAEFECTIVIDAD IS NULL THEN ' ' ELSE UPPER(NO_FECHAEFECTIVIDAD) END)  LIKE UPPER( '%' || :NO_FECHAEFECTIVIDAD || '%')  AND (CASE WHEN NO_CARGOA IS NULL THEN ' ' ELSE UPPER(NO_CARGOA) END)  LIKE UPPER( '%' || :NO_CARGOA || '%')  AND (CASE WHEN NO_CAUSA IS NULL THEN ' ' ELSE UPPER(NO_CAUSA) END)  LIKE UPPER( '%' || :NO_CAUSA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","DP_NUMEDOCU":"$DP_NUMEDOCU","TIPOACTOADTIVO":"$TIPOACTOADTIVO","CODIGO":"$CODIGO(type:integer)","CODIGOCAUSA":"$CODIGOCAUSA","NOMBRE":"$NOMBRE","NO_NUME":"$NO_NUME","NO_FECHRESODECR":"$NO_FECHRESODECR","NO_FECHAEFECTIVIDAD":"$NO_FECHAEFECTIVIDAD","NO_CARGOA":"$NO_CARGOA","NO_CAUSA":"$NO_CAUSA","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="TIPOACTOADTIVO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NO_NUME" sqlType="STRING"/>
		<param name="NO_FECHRESODECR" sqlType="STRING"/>
		<param name="NO_FECHAEFECTIVIDAD" sqlType="STRING"/>
		<param name="NO_CARGOA" sqlType="STRING"/>
		<param name="NO_CAUSA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natnombramiento/retirosporempleado/pag">
		<call-query href="getNatnombramientoPagRetirosPorEmpleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="TIPOACTOADTIVO" query-param="TIPOACTOADTIVO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NO_NUME" query-param="NO_NUME"/>
			<with-param name="NO_FECHRESODECR" query-param="NO_FECHRESODECR"/>
			<with-param name="NO_FECHAEFECTIVIDAD" query-param="NO_FECHAEFECTIVIDAD"/>
			<with-param name="NO_CARGOA" query-param="NO_CARGOA"/>
			<with-param name="NO_CAUSA" query-param="NO_CAUSA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatnombramientoNumRetirosPorEmpleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_TIPO_ACTO_ADTIVO.TIPOACTOADTIVO, NAT_TIPO_ACTO_ADTIVO.CODIGO, CAUSARETIRO.CODIGO CODIGOCAUSA, CAUSARETIRO.NOMBRE, NAT_NOMBRAMIENTO.NO_NUME,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) NO_FECHRESODECR,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS')) NO_FECHAEFECTIVIDAD, NAT_NOMBRAMIENTO.NO_CARGOA, NAT_NOMBRAMIENTO.NO_CAUSA, CARGOS.NOMBRE_DEL_CARGO  FROM NAT_NOMBRAMIENTO LEFT JOIN CAUSARETIRO ON NAT_NOMBRAMIENTO.COMPANIA = CAUSARETIRO.COMPANIA AND NAT_NOMBRAMIENTO.NO_TIPO = CAUSARETIRO.CODIGO LEFT JOIN NAT_TIPO_ACTO_ADTIVO ON NAT_NOMBRAMIENTO.NO_TIPODOCUACTO = NAT_TIPO_ACTO_ADTIVO.CODIGO LEFT JOIN CARGOS ON CARGOS.COMPANIA = NAT_NOMBRAMIENTO.COMPANIA AND CARGOS.ID_DE_CARGO = NAT_NOMBRAMIENTO.NO_CARGOA WHERE NAT_NOMBRAMIENTO.COMPANIA = :COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU = :DP_NUMEDOCU AND NAT_NOMBRAMIENTO.RETIRO_O_NOMBRAMIENTO = 'R' ORDER BY NAT_NOMBRAMIENTO.NO_FECHRESODECR DESC) WHERE (CASE WHEN TIPOACTOADTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTOADTIVO) END)  LIKE UPPER(:TIPOACTOADTIVO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NO_NUME IS NULL THEN ' ' ELSE UPPER(NO_NUME) END)  LIKE UPPER( '%' || :NO_NUME || '%')  AND (CASE WHEN NO_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(NO_FECHRESODECR) END)  LIKE UPPER( '%' || :NO_FECHRESODECR || '%')  AND (CASE WHEN NO_FECHAEFECTIVIDAD IS NULL THEN ' ' ELSE UPPER(NO_FECHAEFECTIVIDAD) END)  LIKE UPPER( '%' || :NO_FECHAEFECTIVIDAD || '%')  AND (CASE WHEN NO_CARGOA IS NULL THEN ' ' ELSE UPPER(NO_CARGOA) END)  LIKE UPPER( '%' || :NO_CARGOA || '%')  AND (CASE WHEN NO_CAUSA IS NULL THEN ' ' ELSE UPPER(NO_CAUSA) END)  LIKE UPPER( '%' || :NO_CAUSA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="TIPOACTOADTIVO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NO_NUME" sqlType="STRING"/>
		<param name="NO_FECHRESODECR" sqlType="STRING"/>
		<param name="NO_FECHAEFECTIVIDAD" sqlType="STRING"/>
		<param name="NO_CARGOA" sqlType="STRING"/>
		<param name="NO_CAUSA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natnombramiento/retirosporempleado/num">
		<call-query href="getNatnombramientoNumRetirosPorEmpleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="TIPOACTOADTIVO" query-param="TIPOACTOADTIVO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NO_NUME" query-param="NO_NUME"/>
			<with-param name="NO_FECHRESODECR" query-param="NO_FECHRESODECR"/>
			<with-param name="NO_FECHAEFECTIVIDAD" query-param="NO_FECHAEFECTIVIDAD"/>
			<with-param name="NO_CARGOA" query-param="NO_CARGOA"/>
			<with-param name="NO_CAUSA" query-param="NO_CAUSA"/>

		</call-query>
	</resource>
	<query id="insertNatnombramientoRetirosPorEmpleado" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,NO_NUME" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_NOMBRAMIENTO (COMPANIA, SUCURSAL, DP_NUMEDOCU, NO_TIPODOCUACTO, NO_NUME, NO_CAUSA, NO_FECHRESODECR, NO_FECHAEFECTIVIDAD, NO_CARGOA, NO_TIPO, RETIRO_O_NOMBRAMIENTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :SUCURSAL, :DP_NUMEDOCU, :NO_TIPODOCUACTO, :NO_NUME, :NO_CAUSA, TO_DATE(:NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS'), :NO_CARGOA, :NO_TIPO, :RETIRO_O_NOMBRAMIENTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_NO_NUME":"$NO_NUME","KEY_NO_FECHRESODECR":"$NO_FECHRESODECR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="NO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="NO_NUME" sqlType="STRING"/>
		<param defaultValue="" name="NO_CAUSA" sqlType="STRING"/>
		<param name="NO_FECHRESODECR" sqlType="STRING"/>
		<param defaultValue="" name="NO_FECHAEFECTIVIDAD" sqlType="STRING"/>
		<param defaultValue="" name="NO_CARGOA" sqlType="STRING"/>
		<param defaultValue="" name="NO_TIPO" sqlType="STRING"/>
		<param defaultValue="" name="RETIRO_O_NOMBRAMIENTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natnombramiento/retirosporempleado">
		<call-query href="insertNatnombramientoRetirosPorEmpleado">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="NO_TIPODOCUACTO" query-param="NO_TIPODOCUACTO"/>
			<with-param name="NO_NUME" query-param="NO_NUME"/>
			<with-param name="NO_CAUSA" query-param="NO_CAUSA"/>
			<with-param name="NO_FECHRESODECR" query-param="NO_FECHRESODECR"/>
			<with-param name="NO_FECHAEFECTIVIDAD" query-param="NO_FECHAEFECTIVIDAD"/>
			<with-param name="NO_CARGOA" query-param="NO_CARGOA"/>
			<with-param name="NO_TIPO" query-param="NO_TIPO"/>
			<with-param name="RETIRO_O_NOMBRAMIENTO" query-param="RETIRO_O_NOMBRAMIENTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateNatnombramientoRetirosPorEmpleado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_NOMBRAMIENTO SET NO_TIPODOCUACTO=:NO_TIPODOCUACTO, NO_NUME=:NO_NUME, NO_FECHRESODECR=TO_DATE(:NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), NO_FECHAEFECTIVIDAD=TO_DATE(:NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS'), NO_CARGOA=:NO_CARGOA, NO_TIPO=:NO_TIPO, NO_CAUSA=:NO_CAUSA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_NOMBRAMIENTO.COMPANIA= :KEY_COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_NOMBRAMIENTO.SUCURSAL= :KEY_SUCURSAL AND NAT_NOMBRAMIENTO.NO_NUME= :KEY_NO_NUME AND NAT_NOMBRAMIENTO.NO_FECHRESODECR= TO_DATE(:KEY_NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="NO_NUME" sqlType="STRING"/>
		<param name="NO_FECHRESODECR" sqlType="STRING"/>
		<param name="NO_FECHAEFECTIVIDAD" sqlType="STRING"/>
		<param name="NO_CARGOA" sqlType="STRING"/>
		<param name="NO_TIPO" sqlType="STRING"/>
		<param name="NO_CAUSA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NO_NUME" sqlType="STRING"/>
		<param name="KEY_NO_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natnombramiento/retirosporempleado">
		<call-query href="updateNatnombramientoRetirosPorEmpleado">
			<with-param name="NO_TIPODOCUACTO" query-param="NO_TIPODOCUACTO"/>
			<with-param name="NO_NUME" query-param="NO_NUME"/>
			<with-param name="NO_FECHRESODECR" query-param="NO_FECHRESODECR"/>
			<with-param name="NO_FECHAEFECTIVIDAD" query-param="NO_FECHAEFECTIVIDAD"/>
			<with-param name="NO_CARGOA" query-param="NO_CARGOA"/>
			<with-param name="NO_TIPO" query-param="NO_TIPO"/>
			<with-param name="NO_CAUSA" query-param="NO_CAUSA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NO_NUME" query-param="KEY_NO_NUME"/>
			<with-param name="KEY_NO_FECHRESODECR" query-param="KEY_NO_FECHRESODECR"/>

		</call-query>
	</resource>
	<query id="deleteNatnombramientoRetirosPorEmpleado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_NOMBRAMIENTO WHERE NAT_NOMBRAMIENTO.COMPANIA     = :KEY_COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU    = :KEY_DP_NUMEDOCU AND NAT_NOMBRAMIENTO.SUCURSAL       = :KEY_SUCURSAL AND NAT_NOMBRAMIENTO.NO_NUME        = :KEY_NO_NUME AND NAT_NOMBRAMIENTO.NO_FECHRESODECR= TO_DATE(:KEY_NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NO_NUME" sqlType="STRING"/>
		<param name="KEY_NO_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natnombramiento/retirosporempleado">
		<call-query href="deleteNatnombramientoRetirosPorEmpleado">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NO_NUME" query-param="KEY_NO_NUME"/>
			<with-param name="KEY_NO_FECHRESODECR" query-param="KEY_NO_FECHRESODECR"/>

		</call-query>
	</resource>
	<query id="getNatnombramientoPagUltimaFuncionAreasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.NO_NUME,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) NO_FECHRESODECR, NAT_NOMBRAMIENTO.NO_CODIGOCARGO, NAT_NOMBRAMIENTO.NO_GRADOCARGO, NAT_NOMBRAMIENTO.NO_TIPO, NAT_FUNCIONES_AREAS.IDFUNCION, NAT_FUNCIONES_AREAS.DESCRIPCION_FUNCION_AREAS,(TO_CHAR(NAT_FUNCIONES_AREAS.FECHA_CREACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_CREACION, NAT_FUNCIONES_AREAS.ANO  FROM NAT_NOMBRAMIENTO INNER JOIN FORMANOMBRAMIENTO ON NAT_NOMBRAMIENTO.COMPANIA = FORMANOMBRAMIENTO.COMPANIA AND NAT_NOMBRAMIENTO.NO_TIPO = FORMANOMBRAMIENTO.IDFORMA LEFT JOIN NAT_FUNCIONES_AREAS ON NAT_NOMBRAMIENTO.COMPANIA = NAT_FUNCIONES_AREAS.COMPANIA AND NAT_NOMBRAMIENTO.NO_CODIGOCARGO = NAT_FUNCIONES_AREAS.IDCARGO WHERE NAT_NOMBRAMIENTO.COMPANIA = :COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU = :NUMERO AND NAT_NOMBRAMIENTO.SUCURSAL = :SUCURSAL AND FORMANOMBRAMIENTO.TIPO IN('A') GROUP BY NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.NO_NUME, NAT_NOMBRAMIENTO.NO_FECHRESODECR, NAT_NOMBRAMIENTO.NO_CODIGOCARGO, NAT_NOMBRAMIENTO.NO_GRADOCARGO, NAT_NOMBRAMIENTO.NO_TIPO, NAT_NOMBRAMIENTO.NB_CODIGOPERSONA, NAT_FUNCIONES_AREAS.CODIGOAREA, NAT_FUNCIONES_AREAS.IDCARGO, NAT_FUNCIONES_AREAS.IDFUNCION, NAT_FUNCIONES_AREAS.DESCRIPCION_FUNCION_AREAS, NAT_FUNCIONES_AREAS.FECHA_CREACION, NAT_FUNCIONES_AREAS.ANO ORDER BY NAT_NOMBRAMIENTO.NO_FECHRESODECR DESC) WHERE (CASE WHEN NO_CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(NO_CODIGOCARGO) END)  LIKE UPPER(:NO_CODIGOCARGO || '%')  AND (CASE WHEN NO_GRADOCARGO IS NULL THEN ' ' ELSE UPPER(NO_GRADOCARGO) END)  LIKE UPPER( '%' || :NO_GRADOCARGO || '%')  AND (CASE WHEN NO_TIPO IS NULL THEN ' ' ELSE UPPER(NO_TIPO) END)  LIKE UPPER(:NO_TIPO || '%')  AND (CASE WHEN IDFUNCION IS NULL THEN ' ' ELSE UPPER(IDFUNCION) END)  LIKE UPPER(:IDFUNCION || '%')  AND (CASE WHEN DESCRIPCION_FUNCION_AREAS IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_FUNCION_AREAS) END)  LIKE UPPER( '%' || :DESCRIPCION_FUNCION_AREAS || '%')  AND (CASE WHEN FECHA_CREACION IS NULL THEN ' ' ELSE UPPER(FECHA_CREACION) END)  LIKE UPPER( '%' || :FECHA_CREACION || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","NO_NUME":"$NO_NUME","NO_FECHRESODECR":"$NO_FECHRESODECR","NO_CODIGOCARGO":"$NO_CODIGOCARGO","NO_GRADOCARGO":"$NO_GRADOCARGO","NO_TIPO":"$NO_TIPO","IDFUNCION":"$IDFUNCION","DESCRIPCION_FUNCION_AREAS":"$DESCRIPCION_FUNCION_AREAS","FECHA_CREACION":"$FECHA_CREACION","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NO_CODIGOCARGO" sqlType="STRING"/>
		<param name="NO_GRADOCARGO" sqlType="STRING"/>
		<param name="NO_TIPO" sqlType="STRING"/>
		<param name="IDFUNCION" sqlType="STRING"/>
		<param name="DESCRIPCION_FUNCION_AREAS" sqlType="STRING"/>
		<param name="FECHA_CREACION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natnombramiento/ultimafuncionareas/pag">
		<call-query href="getNatnombramientoPagUltimaFuncionAreasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NO_CODIGOCARGO" query-param="NO_CODIGOCARGO"/>
			<with-param name="NO_GRADOCARGO" query-param="NO_GRADOCARGO"/>
			<with-param name="NO_TIPO" query-param="NO_TIPO"/>
			<with-param name="IDFUNCION" query-param="IDFUNCION"/>
			<with-param name="DESCRIPCION_FUNCION_AREAS" query-param="DESCRIPCION_FUNCION_AREAS"/>
			<with-param name="FECHA_CREACION" query-param="FECHA_CREACION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatnombramientoNumUltimaFuncionAreasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.NO_NUME,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) NO_FECHRESODECR, NAT_NOMBRAMIENTO.NO_CODIGOCARGO, NAT_NOMBRAMIENTO.NO_GRADOCARGO, NAT_NOMBRAMIENTO.NO_TIPO, NAT_FUNCIONES_AREAS.IDFUNCION, NAT_FUNCIONES_AREAS.DESCRIPCION_FUNCION_AREAS,(TO_CHAR(NAT_FUNCIONES_AREAS.FECHA_CREACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_CREACION, NAT_FUNCIONES_AREAS.ANO  FROM NAT_NOMBRAMIENTO INNER JOIN FORMANOMBRAMIENTO ON NAT_NOMBRAMIENTO.COMPANIA = FORMANOMBRAMIENTO.COMPANIA AND NAT_NOMBRAMIENTO.NO_TIPO = FORMANOMBRAMIENTO.IDFORMA LEFT JOIN NAT_FUNCIONES_AREAS ON NAT_NOMBRAMIENTO.COMPANIA = NAT_FUNCIONES_AREAS.COMPANIA AND NAT_NOMBRAMIENTO.NO_CODIGOCARGO = NAT_FUNCIONES_AREAS.IDCARGO WHERE NAT_NOMBRAMIENTO.COMPANIA = :COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU = :NUMERO AND NAT_NOMBRAMIENTO.SUCURSAL = :SUCURSAL AND FORMANOMBRAMIENTO.TIPO IN('A') GROUP BY NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.NO_NUME, NAT_NOMBRAMIENTO.NO_FECHRESODECR, NAT_NOMBRAMIENTO.NO_CODIGOCARGO, NAT_NOMBRAMIENTO.NO_GRADOCARGO, NAT_NOMBRAMIENTO.NO_TIPO, NAT_NOMBRAMIENTO.NB_CODIGOPERSONA, NAT_FUNCIONES_AREAS.CODIGOAREA, NAT_FUNCIONES_AREAS.IDCARGO, NAT_FUNCIONES_AREAS.IDFUNCION, NAT_FUNCIONES_AREAS.DESCRIPCION_FUNCION_AREAS, NAT_FUNCIONES_AREAS.FECHA_CREACION, NAT_FUNCIONES_AREAS.ANO ORDER BY NAT_NOMBRAMIENTO.NO_FECHRESODECR DESC) WHERE (CASE WHEN NO_CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(NO_CODIGOCARGO) END)  LIKE UPPER(:NO_CODIGOCARGO || '%')  AND (CASE WHEN NO_GRADOCARGO IS NULL THEN ' ' ELSE UPPER(NO_GRADOCARGO) END)  LIKE UPPER( '%' || :NO_GRADOCARGO || '%')  AND (CASE WHEN NO_TIPO IS NULL THEN ' ' ELSE UPPER(NO_TIPO) END)  LIKE UPPER(:NO_TIPO || '%')  AND (CASE WHEN IDFUNCION IS NULL THEN ' ' ELSE UPPER(IDFUNCION) END)  LIKE UPPER(:IDFUNCION || '%')  AND (CASE WHEN DESCRIPCION_FUNCION_AREAS IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_FUNCION_AREAS) END)  LIKE UPPER( '%' || :DESCRIPCION_FUNCION_AREAS || '%')  AND (CASE WHEN FECHA_CREACION IS NULL THEN ' ' ELSE UPPER(FECHA_CREACION) END)  LIKE UPPER( '%' || :FECHA_CREACION || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NO_CODIGOCARGO" sqlType="STRING"/>
		<param name="NO_GRADOCARGO" sqlType="STRING"/>
		<param name="NO_TIPO" sqlType="STRING"/>
		<param name="IDFUNCION" sqlType="STRING"/>
		<param name="DESCRIPCION_FUNCION_AREAS" sqlType="STRING"/>
		<param name="FECHA_CREACION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
