	<query id="getNatnombramientoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_NOMBRAMIENTO.NO_TIPODOCUACTO, NAT_NOMBRAMIENTO.NO_NUME,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) NO_FECHRESODECR, NAT_NOMBRAMIENTO.NO_ESCALAFON, NAT_NOMBRAMIENTO.NO_ID_DE_CARGO, NAT_NOMBRAMIENTO.NO_CATEGORIA, NAT_NOMBRAMIENTO.NO_GRADOCARGO,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHACARGO,'DD/MM/YYYY HH24:MI:SS')) NO_FECHACARGO, NAT_NOMBRAMIENTO.NO_SALARION, NAT_NOMBRAMIENTO.PRIMATECNICAFACTOR, NAT_NOMBRAMIENTO.PRIMATECNICANFACTOR, NAT_NOMBRAMIENTO.GASTOSREPRESENTACION, NAT_NOMBRAMIENTO.NO_DEPENUEV, NAT_NOMBRAMIENTO.NO_TIPO, NAT_NOMBRAMIENTO.NO_DEPEANTE, NAT_NOMBRAMIENTO.NO_CARGOA, NAT_NOMBRAMIENTO.NO_SALARIOA,(TO_CHAR(NAT_NOMBRAMIENTO.EN_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) EN_FECHDESDE,(TO_CHAR(NAT_NOMBRAMIENTO.EN_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) EN_FECHHASTA,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS')) NO_FECHAEFECTIVIDAD,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHACTAPOSE,'DD/MM/YYYY HH24:MI:SS')) NO_FECHACTAPOSE, NAT_NOMBRAMIENTO.NO_ACTAPOSE, NAT_NOMBRAMIENTO.CODAREA, NAT_NOMBRAMIENTO.ANOFUNCION, NAT_NOMBRAMIENTO.PRIMAALTAGESTION, NAT_NOMBRAMIENTO.NO_AUXT, NAT_NOMBRAMIENTO.NO_AUXA,(CASE NAT_NOMBRAMIENTO.ESTADO_VINCULACION WHEN 0 THEN 'false' ELSE 'true' END) ESTADO_VINCULACION,(CASE NAT_NOMBRAMIENTO.ULT_CARGO WHEN 0 THEN 'false' ELSE 'true' END) ULT_CARGO, NAT_NOMBRAMIENTO.NO_CAUSA, NAT_NOMBRAMIENTO.NO_CARGON, NAT_NOMBRAMIENTO.RETIRO_O_NOMBRAMIENTO, NAT_NOMBRAMIENTO.NB_CODIGOPERSONA, NAT_NOMBRAMIENTO.NO_CODIGOCARGO, CARGOS.NOMBRE_DEL_CARGO NOMBRECARGO, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA  FROM NAT_NOMBRAMIENTO LEFT JOIN CARGOS ON NAT_NOMBRAMIENTO.COMPANIA = CARGOS.COMPANIA AND NAT_NOMBRAMIENTO.NO_ID_DE_CARGO = CARGOS.ID_DE_CARGO LEFT JOIN DEPENDENCIA ON NAT_NOMBRAMIENTO.COMPANIA = DEPENDENCIA.COMPANIA AND NAT_NOMBRAMIENTO.NO_DEPENUEV = DEPENDENCIA.CODIGO WHERE NAT_NOMBRAMIENTO.COMPANIA= :KEY_COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_NOMBRAMIENTO.SUCURSAL= :KEY_SUCURSAL AND NAT_NOMBRAMIENTO.NO_NUME= :KEY_NO_NUME AND NAT_NOMBRAMIENTO.NO_FECHRESODECR= TO_DATE(:KEY_NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","DP_NUMEDOCU":"$DP_NUMEDOCU","NO_TIPODOCUACTO":"$NO_TIPODOCUACTO(type:integer)","NO_NUME":"$NO_NUME","NO_FECHRESODECR":"$NO_FECHRESODECR","NO_ESCALAFON":"$NO_ESCALAFON","NO_ID_DE_CARGO":"$NO_ID_DE_CARGO","NO_CATEGORIA":"$NO_CATEGORIA","NO_GRADOCARGO":"$NO_GRADOCARGO","NO_FECHACARGO":"$NO_FECHACARGO","NO_SALARION":"$NO_SALARION","PRIMATECNICAFACTOR":"$PRIMATECNICAFACTOR","PRIMATECNICANFACTOR":"$PRIMATECNICANFACTOR","GASTOSREPRESENTACION":"$GASTOSREPRESENTACION","NO_DEPENUEV":"$NO_DEPENUEV","NO_TIPO":"$NO_TIPO","NO_DEPEANTE":"$NO_DEPEANTE","NO_CARGOA":"$NO_CARGOA","NO_SALARIOA":"$NO_SALARIOA","EN_FECHDESDE":"$EN_FECHDESDE","EN_FECHHASTA":"$EN_FECHHASTA","NO_FECHAEFECTIVIDAD":"$NO_FECHAEFECTIVIDAD","NO_FECHACTAPOSE":"$NO_FECHACTAPOSE","NO_ACTAPOSE":"$NO_ACTAPOSE","CODAREA":"$CODAREA","ANOFUNCION":"$ANOFUNCION(type:integer)","PRIMAALTAGESTION":"$PRIMAALTAGESTION","NO_AUXT":"$NO_AUXT","NO_AUXA":"$NO_AUXA","ESTADO_VINCULACION":"$ESTADO_VINCULACION(type:boolean)","ULT_CARGO":"$ULT_CARGO(type:boolean)","NO_CAUSA":"$NO_CAUSA","NO_CARGON":"$NO_CARGON","RETIRO_O_NOMBRAMIENTO":"$RETIRO_O_NOMBRAMIENTO","NB_CODIGOPERSONA":"$NB_CODIGOPERSONA","NO_CODIGOCARGO":"$NO_CODIGOCARGO","NOMBRECARGO":"$NOMBRECARGO","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NO_NUME" sqlType="STRING"/>
		<param name="KEY_NO_FECHRESODECR" sqlType="STRING"/>

	</query>
