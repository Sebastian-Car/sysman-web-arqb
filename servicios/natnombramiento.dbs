	<query id="getNatnombramientoInscripcionCarreraQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_NOMBRAMIENTO.COMPANIA, NAT_NOMBRAMIENTO.DP_NUMEDOCU, NAT_NOMBRAMIENTO.SUCURSAL, NAT_NOMBRAMIENTO.NO_TIPODOCUACTO, NAT_NOMBRAMIENTO.NO_NUME,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) NO_FECHRESODECR, NAT_NOMBRAMIENTO.NO_CARGOA, NAT_NOMBRAMIENTO.NO_SALARIOA, NAT_NOMBRAMIENTO.NO_CARGON, NAT_NOMBRAMIENTO.NO_SALARION, NAT_NOMBRAMIENTO.NO_ACTAPOSE,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHACTAPOSE,'DD/MM/YYYY HH24:MI:SS')) NO_FECHACTAPOSE, NAT_NOMBRAMIENTO.NO_TIPO, NAT_NOMBRAMIENTO.NO_CAUSA, NAT_NOMBRAMIENTO.NO_DEPEANTE, NAT_NOMBRAMIENTO.NO_DEPENUEV,(TO_CHAR(NAT_NOMBRAMIENTO.EN_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) EN_FECHDESDE,(TO_CHAR(NAT_NOMBRAMIENTO.EN_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) EN_FECHHASTA,(TO_CHAR(NAT_NOMBRAMIENTO.NO_FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS')) NO_FECHAEFECTIVIDAD, NAT_NOMBRAMIENTO.NO_CODIGOCARGO, NAT_NOMBRAMIENTO.NO_GRADOCARGO  FROM NAT_NOMBRAMIENTO WHERE NAT_NOMBRAMIENTO.COMPANIA = :KEY_COMPANIA AND NAT_NOMBRAMIENTO.DP_NUMEDOCU = :KEY_DP_NUMEDOCU AND NAT_NOMBRAMIENTO.SUCURSAL = :KEY_SUCURSAL AND NAT_NOMBRAMIENTO.NO_CAUSA = 'INSCRIPCION'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","NO_TIPODOCUACTO":"$NO_TIPODOCUACTO(type:integer)","NO_NUME":"$NO_NUME","NO_FECHRESODECR":"$NO_FECHRESODECR","NO_CARGOA":"$NO_CARGOA","NO_SALARIOA":"$NO_SALARIOA","NO_CARGON":"$NO_CARGON","NO_SALARION":"$NO_SALARION","NO_ACTAPOSE":"$NO_ACTAPOSE","NO_FECHACTAPOSE":"$NO_FECHACTAPOSE","NO_TIPO":"$NO_TIPO","NO_CAUSA":"$NO_CAUSA","NO_DEPEANTE":"$NO_DEPEANTE","NO_DEPENUEV":"$NO_DEPENUEV","EN_FECHDESDE":"$EN_FECHDESDE","EN_FECHHASTA":"$EN_FECHHASTA","NO_FECHAEFECTIVIDAD":"$NO_FECHAEFECTIVIDAD","NO_CODIGOCARGO":"$NO_CODIGOCARGO","NO_GRADOCARGO":"$NO_GRADOCARGO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natnombramiento/inscripcioncarrera">
		<call-query href="getNatnombramientoInscripcionCarreraQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatnombramientoExisteInscripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM NAT_NOMBRAMIENTO WHERE COMPANIA = :COMPANIA AND DP_NUMEDOCU = :NUMERO_DCTO AND SUCURSAL = :SUCURSAL AND NAT_NOMBRAMIENTO.NO_CAUSA = 'INSCRIPCION'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natnombramiento/existeinscripcion">
