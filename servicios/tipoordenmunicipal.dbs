<data name="tipoordenmunicipal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoordenmunicipalTipoordenmunicipalQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,NOMBRE FROM TIPO_ORDENMUNICIPAL WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenmunicipal/tipoordenmunicipal">
		<call-query href="getTipoordenmunicipalTipoordenmunicipalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>