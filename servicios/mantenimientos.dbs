	</resource>
	<query id="getMantenimientosContarPorTipoYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT ('X') EXISTE  FROM MANTENIMIENTO WHERE COMPANIA=:COMPANIA AND TIPO = :TIPO_CPTE AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/contarportipoyanio">
		<call-query href="getMantenimientosContarPorTipoYAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="ANO" query-param="ANO"/>

