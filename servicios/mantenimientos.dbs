<data name="mantenimientos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateMantenimientosActualizarValortotal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MANTENIMIENTO SET VALORTOTAL = :VALORTOTAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY  WHERE COMPANIA = :COMPANIA  AND ANO = :ANO AND TIPO = :TIPO AND NUMERO = :NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="mantenimientos/actualizarvalortotal">
		<call-query href="updateMantenimientosActualizarValortotal">
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosTodosPorInventarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, TAREAMANTENI.CODIGO, CONCAT(D_MANTENIMIENTO.PLACA ,CONCAT( ' ' , INVENTARIO.MARCA)) MARCA1, '' FRECUENCIA, TAREAMANTENI.NOMBRE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 1 THEN 1 ELSE 0 END ELSE 0 END) ENEROP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 2 THEN 1 ELSE 0 END ELSE 0 END) FEBREROP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 3 THEN 1 ELSE 0 END ELSE 0 END) MARZOP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 4 THEN 1 ELSE 0 END ELSE 0 END) ABRILP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 5 THEN 1 ELSE 0 END ELSE 0 END) MAYOP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 6 THEN 1 ELSE 0 END ELSE 0 END) JUNIOP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 7 THEN 1 ELSE 0 END ELSE 0 END) JULIOP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 8 THEN 1 ELSE 0 END ELSE 0 END) AGOSTOP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 9 THEN 1 ELSE 0 END ELSE 0 END) SEPTIEMBREP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 10 THEN 1 ELSE 0 END ELSE 0 END) OCTUBREP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 11 THEN 1 ELSE 0 END ELSE 0 END) NOVIEMBREP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'AUT' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 12 THEN 1 ELSE 0 END ELSE 0 END) DICIEMBREP, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 1 THEN 1 ELSE 0 END ELSE 0 END) ENEROE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 2 THEN 1 ELSE 0 END ELSE 0 END) FEBREROE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 3 THEN 1 ELSE 0 END ELSE 0 END) MARZOE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 4 THEN 1 ELSE 0 END ELSE 0 END) ABRILE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 5 THEN 1 ELSE 0 END ELSE 0 END) MAYOE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 6 THEN 1 ELSE 0 END ELSE 0 END) JUNIOE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 7 THEN 1 ELSE 0 END ELSE 0 END) JULIOE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 8 THEN 1 ELSE 0 END ELSE 0 END) AGOSTOE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 9 THEN 1 ELSE 0 END ELSE 0 END) SEPTIEMBREE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 10 THEN 1 ELSE 0 END ELSE 0 END) OCTUBREE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 11 THEN 1 ELSE 0 END ELSE 0 END) NOVIEMBREE, SUM(CASE WHEN MANTENIMIENTO.TIPO = 'EJE' THEN CASE WHEN EXTRACT(MONTH FROM FECHA) = 12 THEN 1 ELSE 0 END ELSE 0 END) DICIEMBREE FROM MANTENIMIENTO INNER JOIN D_MANTENIMIENTO ON MANTENIMIENTO.COMPANIA = D_MANTENIMIENTO.COMPANIA AND MANTENIMIENTO.ANO = D_MANTENIMIENTO.ANO AND MANTENIMIENTO.TIPO = D_MANTENIMIENTO.TIPO_CPTE AND MANTENIMIENTO.NUMERO = D_MANTENIMIENTO.COMPROBANTE LEFT JOIN TAREAMANTENI ON D_MANTENIMIENTO.TAREAMANTENIMIENTO = TAREAMANTENI.CODIGO AND D_MANTENIMIENTO.COMPANIA = TAREAMANTENI.COMPANIA INNER JOIN INVENTARIO ON D_MANTENIMIENTO.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO AND D_MANTENIMIENTO.COMPANIA = INVENTARIO.COMPANIA WHERE MANTENIMIENTO.COMPANIA =:COMPANIA AND D_MANTENIMIENTO.CODIGOELEMENTO BETWEEN :ELEMENTODESDE AND :ELEMENTOHASTA AND TRUNC(MANTENIMIENTO.FECHA) BETWEEN TRUNC(TO_DATE(:FECHADESDEAUX,'DD/MM/YYYY HH24:MI:SS') ) AND TRUNC(TO_DATE(:FECHAHASTAAUX ,'DD/MM/YYYY HH24:MI:SS') ) AND MANTENIMIENTO.TIPO IN ( 'AUT', 'EJE' ) GROUP BY INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, TAREAMANTENI.CODIGO, D_MANTENIMIENTO.PLACA, INVENTARIO.MARCA, TAREAMANTENI.NOMBRE ORDER BY INVENTARIO.CODIGOELEMENTO, CONCAT(D_MANTENIMIENTO.PLACA ,CONCAT( ' ' , INVENTARIO.MARCA))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","CODIGO":"$CODIGO","MARCA1":"$MARCA1","FRECUENCIA":"$FRECUENCIA","NOMBRE":"$NOMBRE","ENEROP":"$ENEROP(type:integer)","FEBREROP":"$FEBREROP(type:integer)","MARZOP":"$MARZOP(type:integer)","ABRILP":"$ABRILP(type:integer)","MAYOP":"$MAYOP(type:integer)","JUNIOP":"$JUNIOP(type:integer)","JULIOP":"$JULIOP(type:integer)","AGOSTOP":"$AGOSTOP(type:integer)","SEPTIEMBREP":"$SEPTIEMBREP(type:integer)","OCTUBREP":"$OCTUBREP(type:integer)","NOVIEMBREP":"$NOVIEMBREP(type:integer)","DICIEMBREP":"$DICIEMBREP(type:integer)","ENEROE":"$ENEROE(type:integer)","FEBREROE":"$FEBREROE(type:integer)","MARZOE":"$MARZOE(type:integer)","ABRILE":"$ABRILE(type:integer)","MAYOE":"$MAYOE(type:integer)","JUNIOE":"$JUNIOE(type:integer)","JULIOE":"$JULIOE(type:integer)","AGOSTOE":"$AGOSTOE(type:integer)","SEPTIEMBREE":"$SEPTIEMBREE(type:integer)","OCTUBREE":"$OCTUBREE(type:integer)","NOVIEMBREE":"$NOVIEMBREE(type:integer)","DICIEMBREE":"$DICIEMBREE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTODESDE" sqlType="STRING"/>
		<param name="ELEMENTOHASTA" sqlType="STRING"/>
		<param name="FECHADESDEAUX" sqlType="STRING"/>
		<param name="FECHAHASTAAUX" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/todosporinventario">
		<call-query href="getMantenimientosTodosPorInventarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTODESDE" query-param="ELEMENTODESDE"/>
			<with-param name="ELEMENTOHASTA" query-param="ELEMENTOHASTA"/>
			<with-param name="FECHADESDEAUX" query-param="FECHADESDEAUX"/>
			<with-param name="FECHAHASTAAUX" query-param="FECHAHASTAAUX"/>

		</call-query>
	</resource>
	<query id="getMantenimientosTodosPorcompaniaAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MANTENIMIENTO.NUMERO  FROM MANTENIMIENTO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND EXTRACT(MONTH FROM FECHA)= :MES AND TIPO = :TIPO ORDER BY MANTENIMIENTO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/todosporcompaniaano">
		<call-query href="getMantenimientosTodosPorcompaniaAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosTodosPorNoaprobadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MANTENIMIENTO.NUMERO, MANTENIMIENTO.DEPENDENCIA, MANTENIMIENTO.RESPONSABLE  FROM MANTENIMIENTO WHERE MANTENIMIENTO.COMPANIA= :COMPANIA AND MANTENIMIENTO.TIPO = :TIPO AND MANTENIMIENTO.APROBADO IN (0) ORDER BY MANTENIMIENTO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/todospornoaprobado">
		<call-query href="getMantenimientosTodosPorNoaprobadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosTodosPorNoRechazadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MANTENIMIENTO.NUMERO, MANTENIMIENTO.DEPENDENCIA, MANTENIMIENTO.RESPONSABLE  FROM MANTENIMIENTO WHERE MANTENIMIENTO.COMPANIA = :COMPANIA AND MANTENIMIENTO.TIPO = :TIPO AND MANTENIMIENTO.ANO = :ANO AND MANTENIMIENTO.APROBADO IN (0) AND MANTENIMIENTO.RECHAZADO IN (0) ORDER BY MANTENIMIENTO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/todospornorechazado">
		<call-query href="getMantenimientosTodosPorNoRechazadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosTodosPorAprobadiQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MANTENIMIENTO.NUMERO, MANTENIMIENTO.DEPENDENCIA, MANTENIMIENTO.RESPONSABLE  FROM MANTENIMIENTO WHERE MANTENIMIENTO.COMPANIA = :COMPANIA AND MANTENIMIENTO.TIPO = :TIPO AND MANTENIMIENTO.ANO = :ANO AND MANTENIMIENTO.APROBADO NOT IN (0) AND MANTENIMIENTO.EJECUTADO IN(0) ORDER BY MANTENIMIENTO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/todosporaprobadi">
		<call-query href="getMantenimientosTodosPorAprobadiQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateMantenimientosValorTotal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MANTENIMIENTO SET VALORTOTAL=:VALORTOTAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE MANTENIMIENTO.COMPANIA= :KEY_COMPANIA AND MANTENIMIENTO.ANO= :KEY_ANO AND MANTENIMIENTO.TIPO= :KEY_TIPO AND MANTENIMIENTO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="mantenimientos/valortotal">
		<call-query href="updateMantenimientosValorTotal">
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosFechaPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT (TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MANTENIMIENTO WHERE COMPANIA= :COMPANIA AND ANO = :ANO AND TIPO = :TIPO AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/fechaporcompania">
		<call-query href="getMantenimientosFechaPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosFechaPorComprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  D_MANTENIMIENTO.CONSECUTIVO,(TO_CHAR(D_MANTENIMIENTO.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(D_MANTENIMIENTO.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, D_MANTENIMIENTO.CANTIDAD, D_MANTENIMIENTO.VALORUNITARIO, D_MANTENIMIENTO.NIT_TALLER  FROM D_MANTENIMIENTO LEFT JOIN TAREAMANTENI ON D_MANTENIMIENTO.TAREAMANTENIMIENTO=TAREAMANTENI.CODIGO WHERE D_MANTENIMIENTO.COMPANIA = :COMPANIA AND D_MANTENIMIENTO.ANO = :ANO AND D_MANTENIMIENTO.TIPO_CPTE = :TIPO AND D_MANTENIMIENTO.COMPROBANTE = :COMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","CANTIDAD":"$CANTIDAD","VALORUNITARIO":"$VALORUNITARIO","NIT_TALLER":"$NIT_TALLER"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/fechaporcomprobante">
		<call-query href="getMantenimientosFechaPorComprobanteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="insertMantenimientos" keyColumns="COMPANIA,ANO,TIPO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO MANTENIMIENTO (COMPANIA, ANO, TIPO, NUMERO, SOLICITUD, FECHA, DEPENDENCIA, RESPONSABLE, SUCURSAL, VALORTOTAL, APROBADO, IMPRESO, EJECUTADO, RECHAZADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO, :NUMERO, :SOLICITUD, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :DEPENDENCIA, :RESPONSABLE, :SUCURSAL, :VALORTOTAL, :APROBADO, :IMPRESO, :EJECUTADO, :RECHAZADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="SOLICITUD" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="APROBADO" sqlType="STRING"/>
		<param defaultValue="0" name="IMPRESO" sqlType="STRING"/>
		<param defaultValue="0" name="EJECUTADO" sqlType="STRING"/>
		<param defaultValue="0" name="RECHAZADO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="mantenimientos">
		<call-query href="insertMantenimientos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="SOLICITUD" query-param="SOLICITUD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="APROBADO" query-param="APROBADO"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="EJECUTADO" query-param="EJECUTADO"/>
			<with-param name="RECHAZADO" query-param="RECHAZADO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteMantenimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM MANTENIMIENTO WHERE MANTENIMIENTO.COMPANIA= :KEY_COMPANIA AND MANTENIMIENTO.ANO= :KEY_ANO AND MANTENIMIENTO.TIPO= :KEY_TIPO AND MANTENIMIENTO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="mantenimientos">
		<call-query href="deleteMantenimientos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT MANTENIMIENTO.COMPANIA, MANTENIMIENTO.ANO, MANTENIMIENTO.TIPO, MANTENIMIENTO.NUMERO, MANTENIMIENTO.SOLICITUD, TO_CHAR(MANTENIMIENTO.FECHA,'dd/MM/YYYY') FECHA, DEPENDENCIA.NOMBRE DEPENDENCIA, TERCERO.NOMBRE RESPONSABLE, MANTENIMIENTO.VALORTOTAL,(CASE MANTENIMIENTO.APROBADO WHEN 0 THEN 'false' ELSE 'true' END) APROBADO,(CASE MANTENIMIENTO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE MANTENIMIENTO.EJECUTADO WHEN 0 THEN 'false' ELSE 'true' END) EJECUTADO FROM MANTENIMIENTO INNER JOIN DEPENDENCIA_RESPONSABLE ON MANTENIMIENTO.COMPANIA =DEPENDENCIA_RESPONSABLE.COMPANIA AND MANTENIMIENTO.DEPENDENCIA=DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND MANTENIMIENTO.RESPONSABLE=DEPENDENCIA_RESPONSABLE.RESPONSABLE AND MANTENIMIENTO.SUCURSAL =DEPENDENCIA_RESPONSABLE.SUCURSAL INNER JOIN DEPENDENCIA ON DEPENDENCIA_RESPONSABLE.COMPANIA =DEPENDENCIA.COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA=DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEPENDENCIA_RESPONSABLE.COMPANIA =TERCERO.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE =TERCERO.NIT AND DEPENDENCIA_RESPONSABLE.SUCURSAL =TERCERO.SUCURSAL WHERE MANTENIMIENTO.COMPANIA = :COMPANIA AND MANTENIMIENTO.ANO = :ANO AND EXTRACT(MONTH FROM MANTENIMIENTO.FECHA) = :MES AND MANTENIMIENTO.TIPO = :TIPO ORDER BY MANTENIMIENTO.NUMERO) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN SOLICITUD IS NULL THEN ' ' ELSE UPPER(SOLICITUD) END)  LIKE UPPER(:SOLICITUD || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER( '%' || :RESPONSABLE || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%')  AND (CASE WHEN APROBADO IS NULL THEN ' ' ELSE UPPER(APROBADO) END)  LIKE UPPER(:APROBADO || '%')  AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END)  LIKE UPPER(:IMPRESO || '%')  AND (CASE WHEN EJECUTADO IS NULL THEN ' ' ELSE UPPER(EJECUTADO) END)  LIKE UPPER(:EJECUTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO","SOLICITUD":"$SOLICITUD","FECHA":"$FECHA","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","VALORTOTAL":"$VALORTOTAL","APROBADO":"$APROBADO(type:boolean)","IMPRESO":"$IMPRESO(type:boolean)","EJECUTADO":"$EJECUTADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="SOLICITUD" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="APROBADO" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="EJECUTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="mantenimientos">
		<call-query href="getMantenimientosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="SOLICITUD" query-param="SOLICITUD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="APROBADO" query-param="APROBADO"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="EJECUTADO" query-param="EJECUTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT MANTENIMIENTO.COMPANIA, MANTENIMIENTO.ANO, MANTENIMIENTO.TIPO, MANTENIMIENTO.NUMERO, MANTENIMIENTO.SOLICITUD, TO_CHAR(MANTENIMIENTO.FECHA,'dd/MM/YYYY') FECHA, DEPENDENCIA.NOMBRE DEPENDENCIA, TERCERO.NOMBRE RESPONSABLE, MANTENIMIENTO.VALORTOTAL,(CASE MANTENIMIENTO.APROBADO WHEN 0 THEN 'false' ELSE 'true' END) APROBADO,(CASE MANTENIMIENTO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE MANTENIMIENTO.EJECUTADO WHEN 0 THEN 'false' ELSE 'true' END) EJECUTADO FROM MANTENIMIENTO INNER JOIN DEPENDENCIA_RESPONSABLE ON MANTENIMIENTO.COMPANIA =DEPENDENCIA_RESPONSABLE.COMPANIA AND MANTENIMIENTO.DEPENDENCIA=DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND MANTENIMIENTO.RESPONSABLE=DEPENDENCIA_RESPONSABLE.RESPONSABLE AND MANTENIMIENTO.SUCURSAL =DEPENDENCIA_RESPONSABLE.SUCURSAL INNER JOIN DEPENDENCIA ON DEPENDENCIA_RESPONSABLE.COMPANIA =DEPENDENCIA.COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA=DEPENDENCIA.CODIGO INNER JOIN TERCERO ON DEPENDENCIA_RESPONSABLE.COMPANIA =TERCERO.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE =TERCERO.NIT AND DEPENDENCIA_RESPONSABLE.SUCURSAL =TERCERO.SUCURSAL WHERE MANTENIMIENTO.COMPANIA = :COMPANIA AND MANTENIMIENTO.ANO = :ANO AND EXTRACT(MONTH FROM MANTENIMIENTO.FECHA) = :MES AND MANTENIMIENTO.TIPO = :TIPO ORDER BY MANTENIMIENTO.NUMERO) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN SOLICITUD IS NULL THEN ' ' ELSE UPPER(SOLICITUD) END)  LIKE UPPER(:SOLICITUD || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER( '%' || :RESPONSABLE || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%')  AND (CASE WHEN APROBADO IS NULL THEN ' ' ELSE UPPER(APROBADO) END)  LIKE UPPER(:APROBADO || '%')  AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END)  LIKE UPPER(:IMPRESO || '%')  AND (CASE WHEN EJECUTADO IS NULL THEN ' ' ELSE UPPER(EJECUTADO) END)  LIKE UPPER(:EJECUTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="SOLICITUD" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="APROBADO" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="EJECUTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/numero">
		<call-query href="getMantenimientosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="SOLICITUD" query-param="SOLICITUD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="APROBADO" query-param="APROBADO"/>
