	</resource>
	<query id="getMantenimientosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MANTENIMIENTO.COMPANIA, MANTENIMIENTO.ANO, MANTENIMIENTO.TIPO, MANTENIMIENTO.NUMERO, MANTENIMIENTO.SOLICITUD,(TO_CHAR(MANTENIMIENTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, MANTENIMIENTO.DEPENDENCIA, MANTENIMIENTO.RESPONSABLE, MANTENIMIENTO.SUCURSAL, MANTENIMIENTO.VALORTOTAL,(CASE MANTENIMIENTO.APROBADO WHEN 0 THEN 'false' ELSE 'true' END) APROBADO,(CASE MANTENIMIENTO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE MANTENIMIENTO.EJECUTADO WHEN 0 THEN 'false' ELSE 'true' END) EJECUTADO,(CASE MANTENIMIENTO.RECHAZADO WHEN 0 THEN 'false' ELSE 'true' END) RECHAZADO,(TO_CHAR(MANTENIMIENTO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MANTENIMIENTO.CREATED_BY,(TO_CHAR(MANTENIMIENTO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, MANTENIMIENTO.MODIFIED_BY  FROM MANTENIMIENTO WHERE MANTENIMIENTO.COMPANIA= :KEY_COMPANIA AND MANTENIMIENTO.ANO= :KEY_ANO AND MANTENIMIENTO.TIPO= :KEY_TIPO AND MANTENIMIENTO.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO","SOLICITUD":"$SOLICITUD","FECHA":"$FECHA","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","VALORTOTAL":"$VALORTOTAL","APROBADO":"$APROBADO(type:boolean)","IMPRESO":"$IMPRESO(type:boolean)","EJECUTADO":"$EJECUTADO(type:boolean)","RECHAZADO":"$RECHAZADO(type:boolean)","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/data">
		<call-query href="getMantenimientosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateMantenimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MANTENIMIENTO SET COMPANIA=:COMPANIA, ANO=:ANO, TIPO=:TIPO, NUMERO=:NUMERO, SOLICITUD=:SOLICITUD, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA=:DEPENDENCIA, RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, VALORTOTAL=:VALORTOTAL, APROBADO=:APROBADO, IMPRESO=:IMPRESO, EJECUTADO=:EJECUTADO, RECHAZADO=:RECHAZADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE MANTENIMIENTO.COMPANIA= :KEY_COMPANIA AND MANTENIMIENTO.ANO= :KEY_ANO AND MANTENIMIENTO.TIPO= :KEY_TIPO AND MANTENIMIENTO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="SOLICITUD" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="APROBADO" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="EJECUTADO" sqlType="STRING"/>
		<param name="RECHAZADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="mantenimientos">
		<call-query href="updateMantenimientos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="SOLICITUD" query-param="SOLICITUD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="APROBADO" query-param="APROBADO"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="EJECUTADO" query-param="EJECUTADO"/>
			<with-param name="RECHAZADO" query-param="RECHAZADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getMantenimientosSolicitudNoaprobadaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM MANTENIMIENTO WHERE COMPANIA=:COMPANIA AND TIPO = :TIPO AND ANO = :ANO AND NUMERO = :NUMERO AND APROBADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="mantenimientos/solicitudnoaprobada">
		<call-query href="getMantenimientosSolicitudNoaprobadaQuery">
