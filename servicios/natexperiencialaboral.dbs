	<query id="deleteNatexperiencialaboral" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_EXPERIENCIA_LABORAL WHERE NAT_EXPERIENCIA_LABORAL.COMPANIA= :KEY_COMPANIA AND NAT_EXPERIENCIA_LABORAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_EXPERIENCIA_LABORAL.SUCURSAL= :KEY_SUCURSAL AND NAT_EXPERIENCIA_LABORAL.NUMERO= :KEY_NUMERO AND NAT_EXPERIENCIA_LABORAL.NEL_CODIGOPERSONA= :KEY_NEL_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_NEL_CODIGOPERSONA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natexperiencialaboral">
		<call-query href="deleteNatexperiencialaboral">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_NEL_CODIGOPERSONA" query-param="KEY_NEL_CODIGOPERSONA"/>

		</call-query>
	</resource>
	<query id="getNatexperiencialaboralPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NUMERO_DCTO, SUCURSAL, NUMERO, NEL_CODIGOPERSONA, NOMBRE,(TO_CHAR(FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHAINGRESO,(TO_CHAR(FECHARETIRO,'DD/MM/YYYY HH24:MI:SS')) FECHARETIRO, CARGO  FROM NAT_EXPERIENCIA_LABORAL WHERE COMPANIA = :COMPANIA AND NUMERO_DCTO = :NUMERO_DCTO AND SUCURSAL = :SUCURSAL AND NEL_CODIGOPERSONA = :CODIGO ORDER BY TO_DATE(FECHARETIRO) DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHAINGRESO IS NULL THEN ' ' ELSE UPPER(FECHAINGRESO) END)  LIKE UPPER( '%' || :FECHAINGRESO || '%')  AND (CASE WHEN FECHARETIRO IS NULL THEN ' ' ELSE UPPER(FECHARETIRO) END)  LIKE UPPER( '%' || :FECHARETIRO || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NUMERO":"$NUMERO","NEL_CODIGOPERSONA":"$NEL_CODIGOPERSONA","NOMBRE":"$NOMBRE","FECHAINGRESO":"$FECHAINGRESO","FECHARETIRO":"$FECHARETIRO","CARGO":"$CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAINGRESO" sqlType="STRING"/>
		<param name="FECHARETIRO" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natexperiencialaboral">
		<call-query href="getNatexperiencialaboralPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHAINGRESO" query-param="FECHAINGRESO"/>
			<with-param name="FECHARETIRO" query-param="FECHARETIRO"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatexperiencialaboralNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NUMERO_DCTO, SUCURSAL, NUMERO, NEL_CODIGOPERSONA, NOMBRE,(TO_CHAR(FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHAINGRESO,(TO_CHAR(FECHARETIRO,'DD/MM/YYYY HH24:MI:SS')) FECHARETIRO, CARGO  FROM NAT_EXPERIENCIA_LABORAL WHERE COMPANIA = :COMPANIA AND NUMERO_DCTO = :NUMERO_DCTO AND SUCURSAL = :SUCURSAL AND NEL_CODIGOPERSONA = :CODIGO ORDER BY TO_DATE(FECHARETIRO) DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHAINGRESO IS NULL THEN ' ' ELSE UPPER(FECHAINGRESO) END)  LIKE UPPER( '%' || :FECHAINGRESO || '%')  AND (CASE WHEN FECHARETIRO IS NULL THEN ' ' ELSE UPPER(FECHARETIRO) END)  LIKE UPPER( '%' || :FECHARETIRO || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAINGRESO" sqlType="STRING"/>
		<param name="FECHARETIRO" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>

	</query>
