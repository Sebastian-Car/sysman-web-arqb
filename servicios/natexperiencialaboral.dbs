	<query id="updateNatexperiencialaboral" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_EXPERIENCIA_LABORAL SET NOMBRE=:NOMBRE, CLASE=:CLASE, PAIS=:PAIS, DEPTO=:DEPTO, MUNICIPIO=:MUNICIPIO, DIRECCION=:DIRECCION, TELEFONOS=:TELEFONOS, FECHAINGRESO=TO_DATE(:FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS'), FECHARETIRO=TO_DATE(:FECHARETIRO,'DD/MM/YYYY HH24:MI:SS'), ANOSERVICIO=:ANOSERVICIO, MESESERVICIO=:MESESERVICIO, DIASERVICIO=:DIASERVICIO, DEDICACION=:DEDICACION, OTRADEDICACION=:OTRADEDICACION, CARGO=:CARGO, DEPENDENCIA=:DEPENDENCIA, INTERNO=:INTERNO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_EXPERIENCIA_LABORAL.COMPANIA= :KEY_COMPANIA AND NAT_EXPERIENCIA_LABORAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_EXPERIENCIA_LABORAL.SUCURSAL= :KEY_SUCURSAL AND NAT_EXPERIENCIA_LABORAL.NUMERO= :KEY_NUMERO AND NAT_EXPERIENCIA_LABORAL.NEL_CODIGOPERSONA= :KEY_NEL_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

