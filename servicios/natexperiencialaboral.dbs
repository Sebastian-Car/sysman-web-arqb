		</call-query>
	</resource>
	<query id="getNatexperiencialaboralRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, NUMERO_DCTO, SUCURSAL, NUMERO, NEL_CODIGOPERSONA, NOMBRE, CLASE, PAIS, DEPTO, MUNICIPIO, DIRECCION, TELEFONOS,(TO_CHAR(FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHAINGRESO,(TO_CHAR(FECHARETIRO,'DD/MM/YYYY HH24:MI:SS')) FECHARETIRO, ANOSERVICIO, MESESERVICIO, DIASERVICIO, DEDICACION, OTRADEDICACION, CARGO, DEPENDENCIA, INTERNO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM NAT_EXPERIENCIA_LABORAL WHERE NAT_EXPERIENCIA_LABORAL.COMPANIA= :KEY_COMPANIA AND NAT_EXPERIENCIA_LABORAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_EXPERIENCIA_LABORAL.SUCURSAL= :KEY_SUCURSAL AND NAT_EXPERIENCIA_LABORAL.NUMERO= :KEY_NUMERO AND NAT_EXPERIENCIA_LABORAL.NEL_CODIGOPERSONA= :KEY_NEL_CODIGOPERSONA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NUMERO":"$NUMERO","NEL_CODIGOPERSONA":"$NEL_CODIGOPERSONA","NOMBRE":"$NOMBRE","CLASE":"$CLASE","PAIS":"$PAIS","DEPTO":"$DEPTO","MUNICIPIO":"$MUNICIPIO","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","FECHAINGRESO":"$FECHAINGRESO","FECHARETIRO":"$FECHARETIRO","ANOSERVICIO":"$ANOSERVICIO(type:integer)","MESESERVICIO":"$MESESERVICIO(type:integer)","DIASERVICIO":"$DIASERVICIO(type:integer)","DEDICACION":"$DEDICACION","OTRADEDICACION":"$OTRADEDICACION","CARGO":"$CARGO","DEPENDENCIA":"$DEPENDENCIA","INTERNO":"$INTERNO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_NEL_CODIGOPERSONA" sqlType="STRING"/>

	</query>
