<data name="natexperiencialaboral" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatexperiencialaboral" keyColumns="COMPANIA,NUMERO_DCTO,SUCURSAL,NUMERO,NEL_CODIGOPERSONA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_EXPERIENCIA_LABORAL (COMPANIA, NUMERO_DCTO, SUCURSAL, NUMERO, NEL_CODIGOPERSONA, NOMBRE, CLASE, PAIS, DEPTO, MUNICIPIO, DIRECCION, TELEFONOS, FECHAINGRESO, FECHARETIRO, ANOSERVICIO, MESESERVICIO, DIASERVICIO, DEDICACION, OTRADEDICACION, CARGO, DEPENDENCIA, INTERNO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_DCTO, :SUCURSAL, :NUMERO, :NEL_CODIGOPERSONA, :NOMBRE, :CLASE, :PAIS, :DEPTO, :MUNICIPIO, :DIRECCION, :TELEFONOS, TO_DATE(:FECHAINGRESO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHARETIRO,'DD/MM/YYYY HH24:MI:SS'), :ANOSERVICIO, :MESESERVICIO, :DIASERVICIO, :DEDICACION, :OTRADEDICACION, :CARGO, :DEPENDENCIA, :INTERNO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_NUMERO":"$NUMERO","KEY_NEL_CODIGOPERSONA":"$NEL_CODIGOPERSONA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NEL_CODIGOPERSONA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CLASE" sqlType="STRING"/>
		<param defaultValue="" name="PAIS" sqlType="STRING"/>
		<param defaultValue="" name="DEPTO" sqlType="STRING"/>
		<param defaultValue="" name="MUNICIPIO" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONOS" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINGRESO" sqlType="STRING"/>
		<param defaultValue="" name="FECHARETIRO" sqlType="STRING"/>
		<param defaultValue="0" name="ANOSERVICIO" sqlType="STRING"/>
		<param defaultValue="0" name="MESESERVICIO" sqlType="STRING"/>
		<param defaultValue="0" name="DIASERVICIO" sqlType="STRING"/>
		<param defaultValue="" name="DEDICACION" sqlType="STRING"/>
		<param defaultValue="" name="OTRADEDICACION" sqlType="STRING"/>
		<param defaultValue="" name="CARGO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="INTERNO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natexperiencialaboral">
		<call-query href="insertNatexperiencialaboral">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
