	<query id="updateIpdescuentosespeciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_DESCUENTOS_ESPECIALES SET COMPANIA=:COMPANIA, ANO=:ANO, MES=:MES, CONSECUTIVO=:CONSECUTIVO, AREA_CONST_ACTUAL=:AREA_CONST_ACTUAL, NUMERO_ORDENF=:NUMERO_ORDENF, PORC_DSCTO=:PORC_DSCTO, CODIGO_FINAL=:CODIGO_FINAL, INCREM_FINAL=:INCREM_FINAL, TITULO_RANGO=:TITULO_RANGO, IND_PRIORIDAD=:IND_PRIORIDAD, AREA_CONST_ANT=:AREA_CONST_ANT, CODIGO_INICIAL=:CODIGO_INICIAL, FECHA_LIMITE=TO_DATE(:FECHA_LIMITE,'DD/MM/YYYY HH24:MI:SS'), CLASE_PREDIO=:CLASE_PREDIO, INCREM_INICIAL=:INCREM_INICIAL, NUMERO_ORDENI=:NUMERO_ORDENI, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_DESCUENTOS_ESPECIALES.COMPANIA= :KEY_COMPANIA AND IP_DESCUENTOS_ESPECIALES.ANO= :KEY_ANO AND IP_DESCUENTOS_ESPECIALES.MES= :KEY_MES AND IP_DESCUENTOS_ESPECIALES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
