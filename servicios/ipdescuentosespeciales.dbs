<data name="ipdescuentosespeciales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpdescuentosespecialesTodosPorPeriodoBaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT ( CONCAT(ANO,TO_CHAR(MES,'00') ) ) PERIODO, ( CONCAT(ANO,CONCAT(' - ',TO_CHAR(MES,'00') ) ) ) PER FROM IP_DESCUENTOS_ESPECIALES GROUP BY CONCAT(ANO,TO_CHAR(MES,'00') ), CONCAT(ANO,CONCAT(' - ',TO_CHAR(MES,'00') ) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO","PER":"$PER"}]}}		</result>
 
	</query>
	<resource method="GET" path="ipdescuentosespeciales/todosporperiodobase">
		<call-query href="getIpdescuentosespecialesTodosPorPeriodoBaseQuery">
 
		</call-query>
	</resource>
	<query id="insertIpdescuentosespeciales" keyColumns="COMPANIA,ANO,MES,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_DESCUENTOS_ESPECIALES (DATE_CREATED, CREATED_BY, COMPANIA, MES, ANO, CONSECUTIVO, CODIGO_INICIAL, CODIGO_FINAL, CLASE_PREDIO, INCREM_INICIAL, INCREM_FINAL, IND_PRIORIDAD, PORC_DSCTO, FECHA_LIMITE, TITULO_RANGO, AREA_CONST_ACTUAL, NUMERO_ORDENF, AREA_CONST_ANT, NUMERO_ORDENI) VALUES (TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, :COMPANIA, :MES, :ANO, :CONSECUTIVO, :CODIGO_INICIAL, :CODIGO_FINAL, :CLASE_PREDIO, :INCREM_INICIAL, :INCREM_FINAL, :IND_PRIORIDAD, :PORC_DSCTO, TO_DATE(:FECHA_LIMITE,'DD/MM/YYYY HH24:MI:SS'), :TITULO_RANGO, :AREA_CONST_ACTUAL, :NUMERO_ORDENF, :AREA_CONST_ANT, :NUMERO_ORDENI)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO_INICIAL" sqlType="STRING"/>
		<param name="CODIGO_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_PREDIO" sqlType="STRING"/>
		<param defaultValue="0" name="INCREM_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="INCREM_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="IND_PRIORIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_DSCTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_LIMITE" sqlType="STRING"/>
		<param defaultValue="" name="TITULO_RANGO" sqlType="STRING"/>
		<param name="AREA_CONST_ACTUAL" sqlType="STRING"/>
		<param name="NUMERO_ORDENF" sqlType="STRING"/>
		<param name="AREA_CONST_ANT" sqlType="STRING"/>
		<param name="NUMERO_ORDENI" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ipdescuentosespeciales">
		<call-query href="insertIpdescuentosespeciales">
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO_INICIAL" query-param="CODIGO_INICIAL"/>
			<with-param name="CODIGO_FINAL" query-param="CODIGO_FINAL"/>
			<with-param name="CLASE_PREDIO" query-param="CLASE_PREDIO"/>
			<with-param name="INCREM_INICIAL" query-param="INCREM_INICIAL"/>
			<with-param name="INCREM_FINAL" query-param="INCREM_FINAL"/>
			<with-param name="IND_PRIORIDAD" query-param="IND_PRIORIDAD"/>
			<with-param name="PORC_DSCTO" query-param="PORC_DSCTO"/>
			<with-param name="FECHA_LIMITE" query-param="FECHA_LIMITE"/>
			<with-param name="TITULO_RANGO" query-param="TITULO_RANGO"/>
			<with-param name="AREA_CONST_ACTUAL" query-param="AREA_CONST_ACTUAL"/>
			<with-param name="NUMERO_ORDENF" query-param="NUMERO_ORDENF"/>
			<with-param name="AREA_CONST_ANT" query-param="AREA_CONST_ANT"/>
			<with-param name="NUMERO_ORDENI" query-param="NUMERO_ORDENI"/>

		</call-query>
	</resource>
	<query id="deleteIpdescuentosespeciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_DESCUENTOS_ESPECIALES WHERE IP_DESCUENTOS_ESPECIALES.COMPANIA= :KEY_COMPANIA AND IP_DESCUENTOS_ESPECIALES.ANO= :KEY_ANO AND IP_DESCUENTOS_ESPECIALES.MES= :KEY_MES AND IP_DESCUENTOS_ESPECIALES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ipdescuentosespeciales">
		<call-query href="deleteIpdescuentosespeciales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getIpdescuentosespecialesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_DESCUENTOS_ESPECIALES.COMPANIA, IP_DESCUENTOS_ESPECIALES.ANO, IP_DESCUENTOS_ESPECIALES.MES, IP_DESCUENTOS_ESPECIALES.CONSECUTIVO, IP_DESCUENTOS_ESPECIALES.CODIGO_INICIAL, IP_DESCUENTOS_ESPECIALES.NUMERO_ORDENI, IP_DESCUENTOS_ESPECIALES.CODIGO_FINAL, IP_DESCUENTOS_ESPECIALES.NUMERO_ORDENF, IP_DESCUENTOS_ESPECIALES.INCREM_INICIAL, IP_DESCUENTOS_ESPECIALES.INCREM_FINAL, IP_DESCUENTOS_ESPECIALES.AREA_CONST_ANT, IP_DESCUENTOS_ESPECIALES.AREA_CONST_ACTUAL, IP_DESCUENTOS_ESPECIALES.IND_PRIORIDAD, IP_DESCUENTOS_ESPECIALES.PORC_DSCTO,(TO_CHAR(IP_DESCUENTOS_ESPECIALES.FECHA_LIMITE,'DD/MM/YYYY HH24:MI:SS')) FECHA_LIMITE, IP_DESCUENTOS_ESPECIALES.TITULO_RANGO, MES.NOMBRE NOMBREMES, IP_DESCUENTOS_ESPECIALES.CLASE_PREDIO, IP_DESCUENTOS_ESPECIALES.CREATED_BY,(TO_CHAR(IP_DESCUENTOS_ESPECIALES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, IP_DESCUENTOS_ESPECIALES.MODIFIED_BY,(TO_CHAR(IP_DESCUENTOS_ESPECIALES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM IP_DESCUENTOS_ESPECIALES INNER JOIN MES ON IP_DESCUENTOS_ESPECIALES.COMPANIA = MES.COMPANIA AND IP_DESCUENTOS_ESPECIALES.ANO = MES.ANO AND IP_DESCUENTOS_ESPECIALES.MES = MES.NUMERO WHERE IP_DESCUENTOS_ESPECIALES.COMPANIA = :COMPANIA ORDER BY IP_DESCUENTOS_ESPECIALES.ANO, IP_DESCUENTOS_ESPECIALES.MES, IP_DESCUENTOS_ESPECIALES.CONSECUTIVO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CODIGO_INICIAL IS NULL THEN ' ' ELSE UPPER(CODIGO_INICIAL) END)  LIKE UPPER(:CODIGO_INICIAL || '%')  AND (CASE WHEN NUMERO_ORDENI IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDENI) END)  LIKE UPPER(:NUMERO_ORDENI || '%')  AND (CASE WHEN CODIGO_FINAL IS NULL THEN ' ' ELSE UPPER(CODIGO_FINAL) END)  LIKE UPPER(:CODIGO_FINAL || '%')  AND (CASE WHEN NUMERO_ORDENF IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDENF) END)  LIKE UPPER(:NUMERO_ORDENF || '%')  AND (CASE WHEN INCREM_INICIAL IS NULL THEN ' ' ELSE UPPER(INCREM_INICIAL) END)  LIKE UPPER(:INCREM_INICIAL || '%')  AND (CASE WHEN INCREM_FINAL IS NULL THEN ' ' ELSE UPPER(INCREM_FINAL) END)  LIKE UPPER(:INCREM_FINAL || '%')  AND (CASE WHEN AREA_CONST_ANT IS NULL THEN ' ' ELSE UPPER(AREA_CONST_ANT) END)  LIKE UPPER(:AREA_CONST_ANT || '%')  AND (CASE WHEN AREA_CONST_ACTUAL IS NULL THEN ' ' ELSE UPPER(AREA_CONST_ACTUAL) END)  LIKE UPPER(:AREA_CONST_ACTUAL || '%')  AND (CASE WHEN IND_PRIORIDAD IS NULL THEN ' ' ELSE UPPER(IND_PRIORIDAD) END)  LIKE UPPER(:IND_PRIORIDAD || '%')  AND (CASE WHEN PORC_DSCTO IS NULL THEN ' ' ELSE UPPER(PORC_DSCTO) END)  LIKE UPPER(:PORC_DSCTO || '%')  AND (CASE WHEN FECHA_LIMITE IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE) END)  LIKE UPPER(:FECHA_LIMITE || '%')  AND (CASE WHEN TITULO_RANGO IS NULL THEN ' ' ELSE UPPER(TITULO_RANGO) END)  LIKE UPPER(:TITULO_RANGO || '%')  AND (CASE WHEN NOMBREMES IS NULL THEN ' ' ELSE UPPER(NOMBREMES) END)  LIKE UPPER(:NOMBREMES || '%')  AND (CASE WHEN CLASE_PREDIO IS NULL THEN ' ' ELSE UPPER(CLASE_PREDIO) END)  LIKE UPPER(:CLASE_PREDIO || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER(:CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER(:DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER(:MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER(:DATE_MODIFIED || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:long)","CODIGO_INICIAL":"$CODIGO_INICIAL","NUMERO_ORDENI":"$NUMERO_ORDENI","CODIGO_FINAL":"$CODIGO_FINAL","NUMERO_ORDENF":"$NUMERO_ORDENF","INCREM_INICIAL":"$INCREM_INICIAL","INCREM_FINAL":"$INCREM_FINAL","AREA_CONST_ANT":"$AREA_CONST_ANT","AREA_CONST_ACTUAL":"$AREA_CONST_ACTUAL","IND_PRIORIDAD":"$IND_PRIORIDAD","PORC_DSCTO":"$PORC_DSCTO","FECHA_LIMITE":"$FECHA_LIMITE","TITULO_RANGO":"$TITULO_RANGO","NOMBREMES":"$NOMBREMES","CLASE_PREDIO":"$CLASE_PREDIO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO_INICIAL" sqlType="STRING"/>
		<param name="NUMERO_ORDENI" sqlType="STRING"/>
		<param name="CODIGO_FINAL" sqlType="STRING"/>
		<param name="NUMERO_ORDENF" sqlType="STRING"/>
		<param name="INCREM_INICIAL" sqlType="STRING"/>
		<param name="INCREM_FINAL" sqlType="STRING"/>
		<param name="AREA_CONST_ANT" sqlType="STRING"/>
		<param name="AREA_CONST_ACTUAL" sqlType="STRING"/>
		<param name="IND_PRIORIDAD" sqlType="STRING"/>
		<param name="PORC_DSCTO" sqlType="STRING"/>
		<param name="FECHA_LIMITE" sqlType="STRING"/>
		<param name="TITULO_RANGO" sqlType="STRING"/>
		<param name="NOMBREMES" sqlType="STRING"/>
		<param name="CLASE_PREDIO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipdescuentosespeciales">
		<call-query href="getIpdescuentosespecialesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
