	<query id="getIpdescuentosespecialesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_DESCUENTOS_ESPECIALES.COMPANIA, IP_DESCUENTOS_ESPECIALES.ANO, IP_DESCUENTOS_ESPECIALES.MES, IP_DESCUENTOS_ESPECIALES.CONSECUTIVO, IP_DESCUENTOS_ESPECIALES.CODIGO_INICIAL, IP_DESCUENTOS_ESPECIALES.NUMERO_ORDENI, IP_DESCUENTOS_ESPECIALES.CODIGO_FINAL, IP_DESCUENTOS_ESPECIALES.NUMERO_ORDENF, IP_DESCUENTOS_ESPECIALES.INCREM_INICIAL, IP_DESCUENTOS_ESPECIALES.INCREM_FINAL, IP_DESCUENTOS_ESPECIALES.AREA_CONST_ANT, IP_DESCUENTOS_ESPECIALES.AREA_CONST_ACTUAL, IP_DESCUENTOS_ESPECIALES.IND_PRIORIDAD, IP_DESCUENTOS_ESPECIALES.PORC_DSCTO,(TO_CHAR(IP_DESCUENTOS_ESPECIALES.FECHA_LIMITE,'DD/MM/YYYY HH24:MI:SS')) FECHA_LIMITE, IP_DESCUENTOS_ESPECIALES.TITULO_RANGO, MES.NOMBRE NOMBREMES, IP_DESCUENTOS_ESPECIALES.CLASE_PREDIO, IP_DESCUENTOS_ESPECIALES.CREATED_BY,(TO_CHAR(IP_DESCUENTOS_ESPECIALES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, IP_DESCUENTOS_ESPECIALES.MODIFIED_BY,(TO_CHAR(IP_DESCUENTOS_ESPECIALES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM IP_DESCUENTOS_ESPECIALES INNER JOIN MES ON IP_DESCUENTOS_ESPECIALES.COMPANIA = MES.COMPANIA AND IP_DESCUENTOS_ESPECIALES.ANO = MES.ANO AND IP_DESCUENTOS_ESPECIALES.MES = MES.NUMERO WHERE IP_DESCUENTOS_ESPECIALES.COMPANIA = :COMPANIA ORDER BY IP_DESCUENTOS_ESPECIALES.ANO, IP_DESCUENTOS_ESPECIALES.MES, IP_DESCUENTOS_ESPECIALES.CONSECUTIVO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN CODIGO_INICIAL IS NULL THEN ' ' ELSE UPPER(CODIGO_INICIAL) END)  LIKE UPPER( '%' || :CODIGO_INICIAL || '%')  AND (CASE WHEN NUMERO_ORDENI IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDENI) END)  LIKE UPPER( '%' || :NUMERO_ORDENI || '%')  AND (CASE WHEN CODIGO_FINAL IS NULL THEN ' ' ELSE UPPER(CODIGO_FINAL) END)  LIKE UPPER( '%' || :CODIGO_FINAL || '%')  AND (CASE WHEN NUMERO_ORDENF IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDENF) END)  LIKE UPPER( '%' || :NUMERO_ORDENF || '%')  AND (CASE WHEN INCREM_INICIAL IS NULL THEN ' ' ELSE UPPER(INCREM_INICIAL) END)  LIKE UPPER( '%' || :INCREM_INICIAL || '%')  AND (CASE WHEN INCREM_FINAL IS NULL THEN ' ' ELSE UPPER(INCREM_FINAL) END)  LIKE UPPER( '%' || :INCREM_FINAL || '%')  AND (CASE WHEN AREA_CONST_ANT IS NULL THEN ' ' ELSE UPPER(AREA_CONST_ANT) END)  LIKE UPPER( '%' || :AREA_CONST_ANT || '%')  AND (CASE WHEN AREA_CONST_ACTUAL IS NULL THEN ' ' ELSE UPPER(AREA_CONST_ACTUAL) END)  LIKE UPPER( '%' || :AREA_CONST_ACTUAL || '%')  AND (CASE WHEN IND_PRIORIDAD IS NULL THEN ' ' ELSE UPPER(IND_PRIORIDAD) END)  LIKE UPPER( '%' || :IND_PRIORIDAD || '%')  AND (CASE WHEN PORC_DSCTO IS NULL THEN ' ' ELSE UPPER(PORC_DSCTO) END)  LIKE UPPER( '%' || :PORC_DSCTO || '%')  AND (CASE WHEN FECHA_LIMITE IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE) END)  LIKE UPPER( '%' || :FECHA_LIMITE || '%')  AND (CASE WHEN TITULO_RANGO IS NULL THEN ' ' ELSE UPPER(TITULO_RANGO) END)  LIKE UPPER( '%' || :TITULO_RANGO || '%')  AND (CASE WHEN NOMBREMES IS NULL THEN ' ' ELSE UPPER(NOMBREMES) END)  LIKE UPPER( '%' || :NOMBREMES || '%')  AND (CASE WHEN CLASE_PREDIO IS NULL THEN ' ' ELSE UPPER(CLASE_PREDIO) END)  LIKE UPPER( '%' || :CLASE_PREDIO || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER( '%' || :DATE_MODIFIED || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO_INICIAL" sqlType="STRING"/>
		<param name="NUMERO_ORDENI" sqlType="STRING"/>
		<param name="CODIGO_FINAL" sqlType="STRING"/>
		<param name="NUMERO_ORDENF" sqlType="STRING"/>
		<param name="INCREM_INICIAL" sqlType="STRING"/>
		<param name="INCREM_FINAL" sqlType="STRING"/>
		<param name="AREA_CONST_ANT" sqlType="STRING"/>
		<param name="AREA_CONST_ACTUAL" sqlType="STRING"/>
