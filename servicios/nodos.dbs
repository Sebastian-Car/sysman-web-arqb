	<query id="updateNodos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NODOS SET CODIGO_PROCESO=:CODIGO_PROCESO, CODIGO=:CODIGO, ARCHIVO=:ARCHIVO, RADICADO=:RADICADO, NOMBRE=:NOMBRE, DESCRIPCION=:DESCRIPCION, NODO_FINAL=:NODO_FINAL, TIEMPO_MINIMO=:TIEMPO_MINIMO, TIEMPO_MAXIMO=:TIEMPO_MAXIMO, TIEMPO_ESTIMADO=:TIEMPO_ESTIMADO, TIPO_CALIDAD=:TIPO_CALIDAD, TIPO_OPERACION=:TIPO_OPERACION, TIPO_DIA=:TIPO_DIA, MOVIMIENTO=:MOVIMIENTO, DEPENDENCIA=:DEPENDENCIA, MANEJA_RADICADO=:MANEJA_RADICADO, TIPO_RADICADO=:TIPO_RADICADO, ARCHIVA_DOCUMENTO=:ARCHIVA_DOCUMENTO, SERIE_DOCUMENTAL=:SERIE_DOCUMENTAL, RUTA=:RUTA, ESTADO=:ESTADO, PREFIJO=:PREFIJO, FECHA_CREACION=TO_DATE(:FECHA_CREACION,'DD/MM/YYYY HH24:MI:SS'), VERSION=:VERSION, ELABORO_FECHA=TO_DATE(:ELABORO_FECHA,'DD/MM/YYYY HH24:MI:SS'), ELABORO_CARGO=:ELABORO_CARGO, ELABORO_NOMBRE=:ELABORO_NOMBRE, REVISO_FECHA=TO_DATE(:REVISO_FECHA,'DD/MM/YYYY HH24:MI:SS'), REVISO_CARGO=:REVISO_CARGO, REVISO_NOMBRE=:REVISO_NOMBRE, MODIFICO_FECHA=TO_DATE(:MODIFICO_FECHA,'DD/MM/YYYY HH24:MI:SS'), MODIFICO_CARGO=:MODIFICO_CARGO, MODIFICO_NOMBRE=:MODIFICO_NOMBRE, TITULO_CALIDAD=:TITULO_CALIDAD, FORMATO=:FORMATO, MODULO=:MODULO, MENU=:MENU, FORMATO_FECHA=TO_DATE(:FORMATO_FECHA,'DD/MM/YYYY HH24:MI:SS'), REQUIERE_FIRMA=:REQUIERE_FIRMA, IND_ARCHIVO_CENTRAL=:IND_ARCHIVO_CENTRAL, PROCEDENCIA_AUT=:PROCEDENCIA_AUT, ENVIA_CORREO=:ENVIA_CORREO, RECEPCION_CORRES=:RECEPCION_CORRES, ENVIO_CORRES=:ENVIO_CORRES, PRORROGA=:PRORROGA, VALIDA_AL_TRAMITAR=:VALIDA_AL_TRAMITAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NODOS.COMPANIA= :KEY_COMPANIA AND NODOS.CODIGO_PROCESO= :KEY_CODIGO_PROCESO AND NODOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO_PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ARCHIVO" sqlType="STRING"/>
		<param name="RADICADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NODO_FINAL" sqlType="STRING"/>
