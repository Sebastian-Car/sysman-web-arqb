		<query id="getNodosNodoprorrogaQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE PRORROGA WHEN 0 THEN 'false' ELSE 'true' END) PRORROGA FROM NODOS WHERE NODOS.COMPANIA = :COMPANIA AND      CODIGO_PROCESO = :PROCESO AND CODIGO = :NODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRORROGA":"$PRORROGA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>

	</query>
