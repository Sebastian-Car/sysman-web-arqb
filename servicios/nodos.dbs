<data name="nodos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNodosCodnombreporprocesocodQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, CONCAT('(',CONCAT(CODIGO,CONCAT(') ',NOMBRE) ) ) NOMBRE FROM NODOS WHERE COMPANIA =:COMPANIA AND CODIGO_PROCESO =:PROCESO AND ESTADO =:ESTADO ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/codnombreporprocesocod">
		<call-query href="getNodosCodnombreporprocesocodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getNodosPagCodnombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO , NOMBRE  FROM NODOS WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND ESTADO = :ESTADO AND NODO_FINAL IN(0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nodos/codnombre/pag">
		<call-query href="getNodosPagCodnombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNodosNumCodnombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO , NOMBRE  FROM NODOS WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND ESTADO = :ESTADO AND NODO_FINAL IN(0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/codnombre/num">
		<call-query href="getNodosNumCodnombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getNodosMincodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,NOMBRE FROM NODOS WHERE COMPANIA =:COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO in (SELECT MIN(CODIGO) MINI FROM NODOS WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/mincodigo">
		<call-query href="getNodosMincodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>

		</call-query>
	</resource>
	<query id="getNodosTodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MENU  FROM NODOS WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO = :NODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MENU":"$MENU(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/todo">
		<call-query href="getNodosTodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>

		</call-query>
	</resource>
	<query id="getNodosPagPrepararplantillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE FROM MODELO_PLANTILLA WHERE TIPO = :TIPO AND CODIGO IN ( SELECT TRIM(REGEXP_SUBSTR(FORMATO, '[^,]+', 1, LEVEL)) STR FROM ( SELECT FORMATO FROM NODOS WHERE COMPANIA =:COMPANIA AND CODIGO_PROCESO =:PROCESO AND CODIGO =:NODO ) DATA CONNECT BY INSTR(FORMATO, ',', 1, LEVEL - 1) &gt; 0 )) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nodos/prepararplantilla/pag">
		<call-query href="getNodosPagPrepararplantillaQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNodosNumPrepararplantillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT MODELO_PLANTILLA.CODIGO, MODELO_PLANTILLA.NOMBRE FROM MODELO_PLANTILLA WHERE TIPO = :TIPO AND CODIGO IN ( SELECT TRIM(REGEXP_SUBSTR(FORMATO, '[^,]+', 1, LEVEL)) STR FROM ( SELECT FORMATO FROM NODOS WHERE COMPANIA =:COMPANIA AND CODIGO_PROCESO =:PROCESO AND CODIGO =:NODO ) DATA CONNECT BY INSTR(FORMATO, ',', 1, LEVEL - 1) &gt; 0 )) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/prepararplantilla/num">
		<call-query href="getNodosNumPrepararplantillaQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getNodosPagCodnombreporcompaniayprocesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE FROM NODOS WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nodos/codnombreporcompaniayproceso/pag">
		<call-query href="getNodosPagCodnombreporcompaniayprocesoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNodosNumCodnombreporcompaniayprocesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE FROM NODOS WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/codnombreporcompaniayproceso/num">
		<call-query href="getNodosNumCodnombreporcompaniayprocesoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertNodos" keyColumns="COMPANIA,CODIGO_PROCESO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NODOS (COMPANIA, CODIGO_PROCESO, CODIGO, ARCHIVO, RADICADO, NOMBRE, DESCRIPCION, NODO_FINAL, TIEMPO_MINIMO, TIEMPO_MAXIMO, TIEMPO_ESTIMADO, TIPO_CALIDAD, TIPO_OPERACION, TIPO_DIA, MOVIMIENTO, DEPENDENCIA, MANEJA_RADICADO, TIPO_RADICADO, ARCHIVA_DOCUMENTO, SERIE_DOCUMENTAL, RUTA, ESTADO, PREFIJO, FECHA_CREACION, VERSION, ELABORO_FECHA, ELABORO_CARGO, ELABORO_NOMBRE, REVISO_FECHA, REVISO_CARGO, REVISO_NOMBRE, MODIFICO_FECHA, MODIFICO_CARGO, MODIFICO_NOMBRE, TITULO_CALIDAD, FORMATO, MODULO, MENU, FORMATO_FECHA, REQUIERE_FIRMA, IND_ARCHIVO_CENTRAL, PROCEDENCIA_AUT, ENVIA_CORREO, RECEPCION_CORRES, ENVIO_CORRES, PRORROGA, VALIDA_AL_TRAMITAR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_PROCESO, :CODIGO, :ARCHIVO, :RADICADO, :NOMBRE, :DESCRIPCION, :NODO_FINAL, :TIEMPO_MINIMO, :TIEMPO_MAXIMO, :TIEMPO_ESTIMADO, :TIPO_CALIDAD, :TIPO_OPERACION, :TIPO_DIA, :MOVIMIENTO, :DEPENDENCIA, :MANEJA_RADICADO, :TIPO_RADICADO, :ARCHIVA_DOCUMENTO, :SERIE_DOCUMENTAL, :RUTA, :ESTADO, :PREFIJO, TO_DATE(:FECHA_CREACION,'DD/MM/YYYY HH24:MI:SS'), :VERSION, TO_DATE(:ELABORO_FECHA,'DD/MM/YYYY HH24:MI:SS'), :ELABORO_CARGO, :ELABORO_NOMBRE, TO_DATE(:REVISO_FECHA,'DD/MM/YYYY HH24:MI:SS'), :REVISO_CARGO, :REVISO_NOMBRE, TO_DATE(:MODIFICO_FECHA,'DD/MM/YYYY HH24:MI:SS'), :MODIFICO_CARGO, :MODIFICO_NOMBRE, :TITULO_CALIDAD, :FORMATO, :MODULO, :MENU, TO_DATE(:FORMATO_FECHA,'DD/MM/YYYY HH24:MI:SS'), :REQUIERE_FIRMA, :IND_ARCHIVO_CENTRAL, :PROCEDENCIA_AUT, :ENVIA_CORREO, :RECEPCION_CORRES, :ENVIO_CORRES, :PRORROGA, :VALIDA_AL_TRAMITAR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_PROCESO":"$CODIGO_PROCESO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="ARCHIVO" sqlType="STRING"/>
		<param defaultValue="" name="RADICADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="NODO_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="TIEMPO_MINIMO" sqlType="STRING"/>
		<param defaultValue="0" name="TIEMPO_MAXIMO" sqlType="STRING"/>
		<param defaultValue="0" name="TIEMPO_ESTIMADO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CALIDAD" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_OPERACION" sqlType="STRING"/>
		<param defaultValue="28" name="TIPO_DIA" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_RADICADO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_RADICADO" sqlType="STRING"/>
		<param defaultValue="0" name="ARCHIVA_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="SERIE_DOCUMENTAL" sqlType="STRING"/>
		<param defaultValue="" name="RUTA" sqlType="STRING"/>
		<param defaultValue="4" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="PREFIJO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CREACION" sqlType="STRING"/>
		<param defaultValue="" name="VERSION" sqlType="STRING"/>
		<param name="ELABORO_FECHA" sqlType="STRING"/>
		<param defaultValue="" name="ELABORO_CARGO" sqlType="STRING"/>
		<param defaultValue="" name="ELABORO_NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="REVISO_FECHA" sqlType="STRING"/>
		<param defaultValue="" name="REVISO_CARGO" sqlType="STRING"/>
		<param defaultValue="" name="REVISO_NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="MODIFICO_FECHA" sqlType="STRING"/>
		<param defaultValue="" name="MODIFICO_CARGO" sqlType="STRING"/>
		<param defaultValue="" name="MODIFICO_NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="TITULO_CALIDAD" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO" sqlType="STRING"/>
		<param defaultValue="" name="MODULO" sqlType="STRING"/>
		<param defaultValue="" name="MENU" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO_FECHA" sqlType="STRING"/>
		<param defaultValue="0" name="REQUIERE_FIRMA" sqlType="STRING"/>
		<param defaultValue="0" name="IND_ARCHIVO_CENTRAL" sqlType="STRING"/>
		<param defaultValue="0" name="PROCEDENCIA_AUT" sqlType="STRING"/>
		<param defaultValue="0" name="ENVIA_CORREO" sqlType="STRING"/>
		<param defaultValue="0" name="RECEPCION_CORRES" sqlType="STRING"/>
		<param defaultValue="0" name="ENVIO_CORRES" sqlType="STRING"/>
		<param defaultValue="0" name="PRORROGA" sqlType="STRING"/>
		<param defaultValue="0" name="VALIDA_AL_TRAMITAR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="nodos">
		<call-query href="insertNodos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROCESO" query-param="CODIGO_PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>
			<with-param name="RADICADO" query-param="RADICADO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
