			<with-param name="TIPO_RADICADO" query-param="TIPO_RADICADO"/>
			<with-param name="ARCHIVA_DOCUMENTO" query-param="ARCHIVA_DOCUMENTO"/>
			<with-param name="SERIE_DOCUMENTAL" query-param="SERIE_DOCUMENTAL"/>
			<with-param name="RUTA" query-param="RUTA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PREFIJO" query-param="PREFIJO"/>
