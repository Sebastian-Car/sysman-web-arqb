			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>

		</call-query>
	</resource>

	<query id="getNodosValiddependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE VALIDA_AL_TRAMITAR WHEN 0 THEN 'false' ELSE 'true' END) VALIDA_AL_TRAMITAR FROM NODOS WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :CODIGO_PROCESO AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALIDA_AL_TRAMITAR":"$VALIDA_AL_TRAMITAR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/validdependencia">
		<call-query href="getNodosValiddependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROCESO" query-param="CODIGO_PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
		<query id="getNodosValidacheckdependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(( SELECT 1 FROM NODOS N INNER JOIN PROCESOS P ON P.COMPANIA = N.COMPANIA AND P.CODIGO = N.CODIGO_PROCESO WHERE N.COMPANIA = :COMPANIA AND N.CODIGO = :NODO_ACTUAL AND P.CODIGO = :CODIGOPROCESO AND N.VALIDA_AL_TRAMITAR = -1 AND ROWNUM = 1 ), 0) AS RESULTADO FROM DUAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESULTADO":"$RESULTADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NODO_ACTUAL" sqlType="STRING"/>
		<param name="CODIGOPROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/validacheckdependencia">
		<call-query href="getNodosValidacheckdependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NODO_ACTUAL" query-param="NODO_ACTUAL"/>
			<with-param name="CODIGOPROCESO" query-param="CODIGOPROCESO"/>

		</call-query>
	</resource>

</data>
