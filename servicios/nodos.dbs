			<with-param name="PRORROGA" query-param="PRORROGA"/>
			<with-param name="VALIDA_AL_TRAMITAR" query-param="VALIDA_AL_TRAMITAR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNodos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NODOS WHERE NODOS.COMPANIA= :KEY_COMPANIA AND NODOS.CODIGO_PROCESO= :KEY_CODIGO_PROCESO AND NODOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="nodos">
		<call-query href="deleteNodos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_PROCESO" query-param="KEY_CODIGO_PROCESO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getNodosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  N.COMPANIA , N.CODIGO , N.NOMBRE , N.CODIGO_PROCESO , P.NOMBRE PROCESO_NOM  FROM NODOS N INNER JOIN PROCESOS P ON N.COMPANIA = P.COMPANIA AND N.CODIGO_PROCESO = P.CODIGO WHERE N.COMPANIA = :COMPANIA AND N.CODIGO_PROCESO = :PROCESO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END)  LIKE UPPER( '%' || :PROCESO_NOM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGO_PROCESO":"$CODIGO_PROCESO","PROCESO_NOM":"$PROCESO_NOM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nodos">
		<call-query href="getNodosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PROCESO_NOM" query-param="PROCESO_NOM"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNodosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  N.COMPANIA , N.CODIGO , N.NOMBRE , N.CODIGO_PROCESO , P.NOMBRE PROCESO_NOM  FROM NODOS N INNER JOIN PROCESOS P ON N.COMPANIA = P.COMPANIA AND N.CODIGO_PROCESO = P.CODIGO WHERE N.COMPANIA = :COMPANIA AND N.CODIGO_PROCESO = :PROCESO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END)  LIKE UPPER( '%' || :PROCESO_NOM || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/numero">
		<call-query href="getNodosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PROCESO_NOM" query-param="PROCESO_NOM"/>

		</call-query>
	</resource>
	<query id="getNodosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT NODOS.COMPANIA, NODOS.CODIGO_PROCESO, PROCESOS.NOMBRE PROCESO_NOM, NODOS.CODIGO, NODOS.ARCHIVO, NODOS.RADICADO, NODOS.NOMBRE, NODOS.DESCRIPCION,(CASE NODOS.NODO_FINAL WHEN 0 THEN 'false' ELSE 'true' END) NODO_FINAL, NODOS.TIEMPO_MINIMO, NODOS.TIEMPO_MAXIMO, NODOS.TIEMPO_ESTIMADO, NODOS.TIPO_CALIDAD, NODOS.TIPO_OPERACION, NODOS.TIPO_DIA,(CASE NODOS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, NODOS.DEPENDENCIA, DEPENDENCIA.NOMBRE DEPENDENCIA_NOM,(CASE NODOS.MANEJA_RADICADO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RADICADO, NODOS.TIPO_RADICADO,(CASE NODOS.ARCHIVA_DOCUMENTO WHEN 0 THEN 'false' ELSE 'true' END) ARCHIVA_DOCUMENTO, NODOS.SERIE_DOCUMENTAL, SERIEDOCUMENTAL.NOMBRE SERIE_DOC_NOM, NODOS.RUTA, NODOS.ESTADO, NODOS.PREFIJO,(TO_CHAR(NODOS.FECHA_CREACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_CREACION, NODOS.VERSION,(TO_CHAR(NODOS.ELABORO_FECHA,'DD/MM/YYYY HH24:MI:SS')) ELABORO_FECHA, NODOS.ELABORO_CARGO, NODOS.ELABORO_NOMBRE,(TO_CHAR(NODOS.REVISO_FECHA,'DD/MM/YYYY HH24:MI:SS')) REVISO_FECHA, NODOS.REVISO_CARGO, NODOS.REVISO_NOMBRE,(TO_CHAR(NODOS.MODIFICO_FECHA,'DD/MM/YYYY HH24:MI:SS')) MODIFICO_FECHA, NODOS.MODIFICO_CARGO, NODOS.MODIFICO_NOMBRE, NODOS.TITULO_CALIDAD, NODOS.FORMATO, NODOS.MODULO, NODOS.MENU, CONCAT(NODOS.FORMATO,TO_CHAR(NODOS.FORMATO_FECHA,'DD/MM/YYYY') ) ID_FORMATO,(TO_CHAR(NODOS.FORMATO_FECHA,'DD/MM/YYYY HH24:MI:SS')) FORMATO_FECHA,(CASE NODOS.REQUIERE_FIRMA WHEN 0 THEN 'false' ELSE 'true' END) REQUIERE_FIRMA,(TO_CHAR(NODOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NODOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, NODOS.CREATED_BY, NODOS.MODIFIED_BY,(CASE NODOS.IND_ARCHIVO_CENTRAL WHEN 0 THEN 'false' ELSE 'true' END) IND_ARCHIVO_CENTRAL,(CASE PROCEDENCIA_AUT WHEN 0 THEN 'false' ELSE 'true' END) PROCEDENCIA_AUT,(CASE ENVIA_CORREO WHEN 0 THEN 'false' ELSE 'true' END) ENVIA_CORREO,(CASE RECEPCION_CORRES WHEN 0 THEN 'false' ELSE 'true' END) RECEPCION_CORRES,(CASE ENVIO_CORRES WHEN 0 THEN 'false' ELSE 'true' END) ENVIO_CORRES,(CASE PRORROGA WHEN 0 THEN 'false' ELSE 'true' END) PRORROGA,(CASE NODOS.VALIDA_AL_TRAMITAR WHEN 0 THEN 'false' ELSE 'true' END) VALIDA_AL_TRAMITAR FROM NODOS INNER JOIN PROCESOS ON NODOS.COMPANIA = PROCESOS.COMPANIA AND NODOS.CODIGO_PROCESO = PROCESOS.CODIGO LEFT JOIN DEPENDENCIA ON NODOS.COMPANIA = DEPENDENCIA.COMPANIA AND NODOS.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN SERIEDOCUMENTAL ON NODOS.COMPANIA = SERIEDOCUMENTAL.COMPANIA AND NODOS.SERIE_DOCUMENTAL = SERIEDOCUMENTAL.CODIGO WHERE NODOS.COMPANIA= :KEY_COMPANIA AND NODOS.CODIGO_PROCESO= :KEY_CODIGO_PROCESO AND NODOS.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_PROCESO":"$CODIGO_PROCESO","PROCESO_NOM":"$PROCESO_NOM","CODIGO":"$CODIGO","ARCHIVO":"$ARCHIVO","RADICADO":"$RADICADO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","NODO_FINAL":"$NODO_FINAL(type:boolean)","TIEMPO_MINIMO":"$TIEMPO_MINIMO","TIEMPO_MAXIMO":"$TIEMPO_MAXIMO","TIEMPO_ESTIMADO":"$TIEMPO_ESTIMADO","TIPO_CALIDAD":"$TIPO_CALIDAD(type:integer)","TIPO_OPERACION":"$TIPO_OPERACION(type:integer)","TIPO_DIA":"$TIPO_DIA(type:integer)","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","DEPENDENCIA":"$DEPENDENCIA","DEPENDENCIA_NOM":"$DEPENDENCIA_NOM","MANEJA_RADICADO":"$MANEJA_RADICADO(type:boolean)","TIPO_RADICADO":"$TIPO_RADICADO(type:integer)","ARCHIVA_DOCUMENTO":"$ARCHIVA_DOCUMENTO(type:boolean)","SERIE_DOCUMENTAL":"$SERIE_DOCUMENTAL","SERIE_DOC_NOM":"$SERIE_DOC_NOM","RUTA":"$RUTA","ESTADO":"$ESTADO(type:integer)","PREFIJO":"$PREFIJO","FECHA_CREACION":"$FECHA_CREACION","VERSION":"$VERSION","ELABORO_FECHA":"$ELABORO_FECHA","ELABORO_CARGO":"$ELABORO_CARGO","ELABORO_NOMBRE":"$ELABORO_NOMBRE","REVISO_FECHA":"$REVISO_FECHA","REVISO_CARGO":"$REVISO_CARGO","REVISO_NOMBRE":"$REVISO_NOMBRE","MODIFICO_FECHA":"$MODIFICO_FECHA","MODIFICO_CARGO":"$MODIFICO_CARGO","MODIFICO_NOMBRE":"$MODIFICO_NOMBRE","TITULO_CALIDAD":"$TITULO_CALIDAD","FORMATO":"$FORMATO","MODULO":"$MODULO(type:integer)","MENU":"$MENU(type:long)","ID_FORMATO":"$ID_FORMATO","FORMATO_FECHA":"$FORMATO_FECHA","REQUIERE_FIRMA":"$REQUIERE_FIRMA(type:boolean)","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","IND_ARCHIVO_CENTRAL":"$IND_ARCHIVO_CENTRAL(type:boolean)","PROCEDENCIA_AUT":"$PROCEDENCIA_AUT(type:boolean)","ENVIA_CORREO":"$ENVIA_CORREO(type:boolean)","RECEPCION_CORRES":"$RECEPCION_CORRES(type:boolean)","ENVIO_CORRES":"$ENVIO_CORRES(type:boolean)","PRORROGA":"$PRORROGA(type:boolean)","VALIDA_AL_TRAMITAR":"$VALIDA_AL_TRAMITAR(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodos/data">
		<call-query href="getNodosRegistroQuery">
