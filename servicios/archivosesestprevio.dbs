<data name="archivosesestprevio" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertArchivosesestprevio" keyColumns="COMPANIA,COD_ESTUDIO,VIGENCIA,ARCHIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ARCHIVOS_ES_ESTPREVIO (ARCHIVO, COMPANIA, COD_ESTUDIO, VIGENCIA, DATE_CREATED, CREATED_BY) VALUES (:ARCHIVO, :COMPANIA, :COD_ESTUDIO, :VIGENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO(type:long)","KEY_VIGENCIA":"$VIGENCIA(type:integer)","KEY_ARCHIVO":"$ARCHIVO"}]}}		</result>
		<param name="ARCHIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="archivosesestprevio">
		<call-query href="insertArchivosesestprevio">
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteArchivosesestprevio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ARCHIVOS_ES_ESTPREVIO WHERE ARCHIVOS_ES_ESTPREVIO.COMPANIA= :KEY_COMPANIA AND ARCHIVOS_ES_ESTPREVIO.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ARCHIVOS_ES_ESTPREVIO.VIGENCIA= :KEY_VIGENCIA AND ARCHIVOS_ES_ESTPREVIO.ARCHIVO= :KEY_ARCHIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>
		<param name="KEY_ARCHIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="archivosesestprevio">
		<call-query href="deleteArchivosesestprevio">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_ARCHIVO" query-param="KEY_ARCHIVO"/>

		</call-query>
	</resource>
	<query id="getArchivosesestprevioPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ARCHIVO, COMPANIA, COD_ESTUDIO, VIGENCIA  FROM ARCHIVOS_ES_ESTPREVIO WHERE COMPANIA = :COMPANIA AND COD_ESTUDIO =:CODIGO AND VIGENCIA = :VIGENCIA) WHERE (CASE WHEN ARCHIVO IS NULL THEN ' ' ELSE UPPER(ARCHIVO) END)  LIKE UPPER( '%' || :ARCHIVO || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ARCHIVO":"$ARCHIVO","COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO(type:long)","VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ARCHIVO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="archivosesestprevio">
		<call-query href="getArchivosesestprevioPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getArchivosesestprevioNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ARCHIVO, COMPANIA, COD_ESTUDIO, VIGENCIA  FROM ARCHIVOS_ES_ESTPREVIO WHERE COMPANIA = :COMPANIA AND COD_ESTUDIO =:CODIGO AND VIGENCIA = :VIGENCIA) WHERE (CASE WHEN ARCHIVO IS NULL THEN ' ' ELSE UPPER(ARCHIVO) END)  LIKE UPPER( '%' || :ARCHIVO || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ARCHIVO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="archivosesestprevio/numero">
		<call-query href="getArchivosesestprevioNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="updateArchivosesestprevio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ARCHIVOS_ES_ESTPREVIO SET ARCHIVO=:ARCHIVO, COMPANIA=:COMPANIA, COD_ESTUDIO=:COD_ESTUDIO, VIGENCIA=:VIGENCIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ARCHIVOS_ES_ESTPREVIO.COMPANIA= :KEY_COMPANIA AND ARCHIVOS_ES_ESTPREVIO.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ARCHIVOS_ES_ESTPREVIO.VIGENCIA= :KEY_VIGENCIA AND ARCHIVOS_ES_ESTPREVIO.ARCHIVO= :KEY_ARCHIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ARCHIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_ARCHIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="archivosesestprevio">
		<call-query href="updateArchivosesestprevio">
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_ARCHIVO" query-param="KEY_ARCHIVO"/>

		</call-query>
	</resource>

</data>