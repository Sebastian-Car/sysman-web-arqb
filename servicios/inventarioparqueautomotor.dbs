		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/serienomautofin/pag">
		<call-query href="getInventarioparqueautomotorPagSerienomautofinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIEINICIAL" query-param="SERIEINICIAL"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorNumSerienomautofinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  INVENTARIO_PARQUE_AUTOMOTOR.SERIE_ELEMENTO SERIE, INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO ELEMENTO, INVENTARIO.NOMBRELARGO  FROM INVENTARIO_PARQUE_AUTOMOTOR INNER JOIN INVENTARIO ON INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA = INVENTARIO.COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA = :COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.ES_AUTOMOTOR = -1 AND INVENTARIO_PARQUE_AUTOMOTOR.SERIE_ELEMENTO &gt;= :SERIEINICIAL ORDER BY INVENTARIO_PARQUE_AUTOMOTOR.SERIE_ELEMENTO) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIEINICIAL" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/serienomautofin/num">
		<call-query href="getInventarioparqueautomotorNumSerienomautofinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIEINICIAL" query-param="SERIEINICIAL"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>

		</call-query>
	</resource>

</data>