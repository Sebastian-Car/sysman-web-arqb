	<query id="deleteInventarioparqueautomotor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM INVENTARIO_PARQUE_AUTOMOTOR WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA= :KEY_COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.PLACA= :KEY_PLACA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="inventarioparqueautomotor">
		<call-query href="deleteInventarioparqueautomotor">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>

		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ES_AUTOMOTOR, PLACA, COLOR, MODELO, CILINDRAJE, VALOR, CASE WHEN ESTADO = 'I' THEN 'Inactivo' WHEN ESTADO = 'A' THEN 'Activo' END AS ESTADO FROM INVENTARIO_PARQUE_AUTOMOTOR WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA =:COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.ESTADO IN ( CASE WHEN :PARESTADO = 2 THEN 'A' WHEN :PARESTADO = 3 THEN 'I' ELSE INVENTARIO_PARQUE_AUTOMOTOR.ESTADO END ) AND ES_AUTOMOTOR = :ESAUTOMOTOR ORDER BY INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.PLACA) INI WHERE (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END) LIKE UPPER(CONCAT(CONCAT('%',:PLACA), '%')) AND (CASE WHEN COLOR IS NULL THEN ' ' ELSE UPPER(COLOR) END) LIKE UPPER(CONCAT(CONCAT('%',:COLOR), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODELO), '%')) AND (CASE WHEN CILINDRAJE IS NULL THEN ' ' ELSE UPPER(CILINDRAJE) END) LIKE UPPER(CONCAT(:CILINDRAJE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ES_AUTOMOTOR":"$ES_AUTOMOTOR(type:integer)","PLACA":"$PLACA","COLOR":"$COLOR","MODELO":"$MODELO(type:integer)","CILINDRAJE":"$CILINDRAJE","VALOR":"$VALOR","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PARESTADO" sqlType="STRING"/>
		<param name="ESAUTOMOTOR" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="COLOR" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="CILINDRAJE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor">
		<call-query href="getInventarioparqueautomotorPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PARESTADO" query-param="PARESTADO"/>
			<with-param name="ESAUTOMOTOR" query-param="ESAUTOMOTOR"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="COLOR" query-param="COLOR"/>
			<with-param name="MODELO" query-param="MODELO"/>
			<with-param name="CILINDRAJE" query-param="CILINDRAJE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ES_AUTOMOTOR, PLACA, COLOR, MODELO, CILINDRAJE, VALOR, CASE WHEN ESTADO = 'I' THEN 'Inactivo' WHEN ESTADO = 'A' THEN 'Activo' END AS ESTADO FROM INVENTARIO_PARQUE_AUTOMOTOR WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA =:COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.ESTADO IN ( CASE WHEN :PARESTADO = 2 THEN 'A' WHEN :PARESTADO = 3 THEN 'I' ELSE INVENTARIO_PARQUE_AUTOMOTOR.ESTADO END ) AND ES_AUTOMOTOR = :ESAUTOMOTOR ORDER BY INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.PLACA) INI WHERE (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END) LIKE UPPER(CONCAT(CONCAT('%',:PLACA), '%')) AND (CASE WHEN COLOR IS NULL THEN ' ' ELSE UPPER(COLOR) END) LIKE UPPER(CONCAT(CONCAT('%',:COLOR), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODELO), '%')) AND (CASE WHEN CILINDRAJE IS NULL THEN ' ' ELSE UPPER(CILINDRAJE) END) LIKE UPPER(CONCAT(:CILINDRAJE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PARESTADO" sqlType="STRING"/>
		<param name="ESAUTOMOTOR" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="COLOR" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="CILINDRAJE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/numero">
		<call-query href="getInventarioparqueautomotorNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PARESTADO" query-param="PARESTADO"/>
			<with-param name="ESAUTOMOTOR" query-param="ESAUTOMOTOR"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="COLOR" query-param="COLOR"/>
