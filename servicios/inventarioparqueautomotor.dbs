<data name="inventarioparqueautomotor" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getInventarioparqueautomotorPlacasPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  INVENTARIO_PARQUE_AUTOMOTOR.PLACA  FROM INVENTARIO_PARQUE_AUTOMOTOR WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA = :COMPANIA ORDER BY INVENTARIO_PARQUE_AUTOMOTOR.PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PLACA":"$PLACA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/placasporcompania">
		<call-query href="getInventarioparqueautomotorPlacasPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateInventarioparqueautomotorCaptanquecombustible" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVENTARIO_PARQUE_AUTOMOTOR SET CAPTANQUECOMBUSTIBLE=:CAPTANQUECOMBUSTIBLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA= :KEY_COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.PLACA= :KEY_PLACA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CAPTANQUECOMBUSTIBLE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="inventarioparqueautomotor/captanquecombustible">
		<call-query href="updateInventarioparqueautomotorCaptanquecombustible">
			<with-param name="CAPTANQUECOMBUSTIBLE" query-param="CAPTANQUECOMBUSTIBLE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>

		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorPlacaSerieAsignadaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PLACA  FROM INVENTARIO_PARQUE_AUTOMOTOR WHERE SERIE_ELEMENTO = :SERIE_ELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PLACA":"$PLACA"}]}}		</result>
		<param name="SERIE_ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/placaserieasignada">
		<call-query href="getInventarioparqueautomotorPlacaSerieAsignadaQuery">
			<with-param name="SERIE_ELEMENTO" query-param="SERIE_ELEMENTO"/>

		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorPagInventarioactvgrillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPO_DE_AUTOMOTOR.NOMBRE CLASEVEHICULO, INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.ES_AUTOMOTOR, INVENTARIO_PARQUE_AUTOMOTOR.PLACA, INVENTARIO_PARQUE_AUTOMOTOR.SERIE_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.VALOR, CASE WHEN INVENTARIO_PARQUE_AUTOMOTOR.ESTADO = 'I' THEN 'Inactivo' WHEN INVENTARIO_PARQUE_AUTOMOTOR.ESTADO = 'A' THEN 'Activo' END AS ESTADO  FROM INVENTARIO_PARQUE_AUTOMOTOR LEFT JOIN TIPO_DE_AUTOMOTOR ON TIPO_DE_AUTOMOTOR.TIPO_DE_AUTOMOTOR = INVENTARIO_PARQUE_AUTOMOTOR.TIPO WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA =:COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.ESTADO IN ( CASE WHEN :PARESTADO = 2 THEN 'A' WHEN :PARESTADO = 3 THEN 'I' ELSE INVENTARIO_PARQUE_AUTOMOTOR.ESTADO END ) AND ES_AUTOMOTOR =:ESAUTOMOTOR ORDER BY INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.PLACA) WHERE (CASE WHEN CLASEVEHICULO IS NULL THEN ' ' ELSE UPPER(CLASEVEHICULO) END)  LIKE UPPER( '%' || :CLASEVEHICULO || '%')  AND (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END)  LIKE UPPER(:PLACA || '%')  AND (CASE WHEN SERIE_ELEMENTO IS NULL THEN ' ' ELSE UPPER(SERIE_ELEMENTO) END)  LIKE UPPER(:SERIE_ELEMENTO || '%')  AND (CASE WHEN CODIGO_ELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGO_ELEMENTO) END)  LIKE UPPER( '%' || :CODIGO_ELEMENTO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEVEHICULO":"$CLASEVEHICULO","COMPANIA":"$COMPANIA","ES_AUTOMOTOR":"$ES_AUTOMOTOR(type:integer)","PLACA":"$PLACA","SERIE_ELEMENTO":"$SERIE_ELEMENTO","CODIGO_ELEMENTO":"$CODIGO_ELEMENTO","VALOR":"$VALOR","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PARESTADO" sqlType="STRING"/>
		<param name="ESAUTOMOTOR" sqlType="STRING"/>
		<param name="CLASEVEHICULO" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="SERIE_ELEMENTO" sqlType="STRING"/>
		<param name="CODIGO_ELEMENTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/inventarioactvgrilla/pag">
		<call-query href="getInventarioparqueautomotorPagInventarioactvgrillaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PARESTADO" query-param="PARESTADO"/>
			<with-param name="ESAUTOMOTOR" query-param="ESAUTOMOTOR"/>
			<with-param name="CLASEVEHICULO" query-param="CLASEVEHICULO"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="SERIE_ELEMENTO" query-param="SERIE_ELEMENTO"/>
			<with-param name="CODIGO_ELEMENTO" query-param="CODIGO_ELEMENTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorNumInventarioactvgrillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPO_DE_AUTOMOTOR.NOMBRE CLASEVEHICULO, INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.ES_AUTOMOTOR, INVENTARIO_PARQUE_AUTOMOTOR.PLACA, INVENTARIO_PARQUE_AUTOMOTOR.SERIE_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.VALOR, CASE WHEN INVENTARIO_PARQUE_AUTOMOTOR.ESTADO = 'I' THEN 'Inactivo' WHEN INVENTARIO_PARQUE_AUTOMOTOR.ESTADO = 'A' THEN 'Activo' END AS ESTADO  FROM INVENTARIO_PARQUE_AUTOMOTOR LEFT JOIN TIPO_DE_AUTOMOTOR ON TIPO_DE_AUTOMOTOR.TIPO_DE_AUTOMOTOR = INVENTARIO_PARQUE_AUTOMOTOR.TIPO WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA =:COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.ESTADO IN ( CASE WHEN :PARESTADO = 2 THEN 'A' WHEN :PARESTADO = 3 THEN 'I' ELSE INVENTARIO_PARQUE_AUTOMOTOR.ESTADO END ) AND ES_AUTOMOTOR =:ESAUTOMOTOR ORDER BY INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.PLACA) WHERE (CASE WHEN CLASEVEHICULO IS NULL THEN ' ' ELSE UPPER(CLASEVEHICULO) END)  LIKE UPPER( '%' || :CLASEVEHICULO || '%')  AND (CASE WHEN PLACA IS NULL THEN ' ' ELSE UPPER(PLACA) END)  LIKE UPPER(:PLACA || '%')  AND (CASE WHEN SERIE_ELEMENTO IS NULL THEN ' ' ELSE UPPER(SERIE_ELEMENTO) END)  LIKE UPPER(:SERIE_ELEMENTO || '%')  AND (CASE WHEN CODIGO_ELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGO_ELEMENTO) END)  LIKE UPPER( '%' || :CODIGO_ELEMENTO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PARESTADO" sqlType="STRING"/>
		<param name="ESAUTOMOTOR" sqlType="STRING"/>
		<param name="CLASEVEHICULO" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="SERIE_ELEMENTO" sqlType="STRING"/>
		<param name="CODIGO_ELEMENTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/inventarioactvgrilla/num">
		<call-query href="getInventarioparqueautomotorNumInventarioactvgrillaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PARESTADO" query-param="PARESTADO"/>
			<with-param name="ESAUTOMOTOR" query-param="ESAUTOMOTOR"/>
			<with-param name="CLASEVEHICULO" query-param="CLASEVEHICULO"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="SERIE_ELEMENTO" query-param="SERIE_ELEMENTO"/>
			<with-param name="CODIGO_ELEMENTO" query-param="CODIGO_ELEMENTO"/>
			<with-param name="VALOR" query-param="VALOR"/>

		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorInvenactivosreadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  INVENTARIO_PARQUE_AUTOMOTOR.DESCRIPCION, INVENTARIO_PARQUE_AUTOMOTOR.COLOR, INVENTARIO_PARQUE_AUTOMOTOR.MODELO, INVENTARIO_PARQUE_AUTOMOTOR.VALOR,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHA_PUESTA_SERVICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_PUESTA_SERVICIO, INVENTARIO_PARQUE_AUTOMOTOR.PROCEDENCIA, INVENTARIO_PARQUE_AUTOMOTOR.CODPROCEDENCIA,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHA_INICIO_COMODATO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_COMODATO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHA_FINAL_COMODATO,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_COMODATO, INVENTARIO_PARQUE_AUTOMOTOR.ENTIDAD_COMODATARIA, INVENTARIO_PARQUE_AUTOMOTOR.SUCURSAL_COMODATARIA, INVENTARIO_PARQUE_AUTOMOTOR.OBSERVACIONCOMODATO, INVENTARIO_PARQUE_AUTOMOTOR.OBSERVACIONES, PAISES.PAIS, DEPARTAMENTO.CODIGO DEPARTAMENTO, CIUDAD.CODIGO MUNICIPIO_DE_PLACAS, INVENTARIO_PARQUE_AUTOMOTOR.NTARJETAPROPIEDAD, INVENTARIO_PARQUE_AUTOMOTOR.NROPOLIZASEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAINICIALSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIALSEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAFINALSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALSEGURO, INVENTARIO_PARQUE_AUTOMOTOR.NOPOLIZAOTROSEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAINICIALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIALOTROSEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAFINALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALOTROSEGURO,(CASE INVENTARIO_PARQUE_AUTOMOTOR.RECLAMACIONSEGURO WHEN 0 THEN 'false' ELSE 'true' END) RECLAMACIONSEGURO, INVENTARIO_PARQUE_AUTOMOTOR.DESCUENTORECLAMACION,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAVENCIMPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMPAGOIMPUESTO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOIMPUESTO, INVENTARIO_PARQUE_AUTOMOTOR.LUGAR_PARQUEO, INVENTARIO_PARQUE_AUTOMOTOR.ASIGNACION, INVENTARIO_PARQUE_AUTOMOTOR.SUCURSAL, INVENTARIO_PARQUE_AUTOMOTOR.DISPONIBILIDAD, INVENTARIO_PARQUE_AUTOMOTOR.FOTOGRAFIA, INVENTARIO_PARQUE_AUTOMOTOR.CLASEVEHICULO, INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.SERIE_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.PLACASANTERIORES, INVENTARIO_PARQUE_AUTOMOTOR.SERIE, INVENTARIO_PARQUE_AUTOMOTOR.ESTADO, INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.PLACA, INVENTARIO_PARQUE_AUTOMOTOR.TIPO, INVENTARIO_PARQUE_AUTOMOTOR.MARCA  FROM INVENTARIO_PARQUE_AUTOMOTOR LEFT JOIN CIUDAD ON INVENTARIO_PARQUE_AUTOMOTOR.PAIS = CIUDAD.PAIS AND INVENTARIO_PARQUE_AUTOMOTOR.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND INVENTARIO_PARQUE_AUTOMOTOR.MUNICIPIO_DE_PLACAS = CIUDAD.CODIGO LEFT JOIN DEPARTAMENTO ON CIUDAD.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND CIUDAD.PAIS = DEPARTAMENTO.PAIS LEFT JOIN PAISES ON DEPARTAMENTO.PAIS = PAISES.PAIS WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA =:KEY_COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.PLACA =:KEY_PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION":"$DESCRIPCION","COLOR":"$COLOR","MODELO":"$MODELO(type:integer)","VALOR":"$VALOR","FECHA_PUESTA_SERVICIO":"$FECHA_PUESTA_SERVICIO","PROCEDENCIA":"$PROCEDENCIA","CODPROCEDENCIA":"$CODPROCEDENCIA","FECHA_INICIO_COMODATO":"$FECHA_INICIO_COMODATO","FECHA_FINAL_COMODATO":"$FECHA_FINAL_COMODATO","ENTIDAD_COMODATARIA":"$ENTIDAD_COMODATARIA","SUCURSAL_COMODATARIA":"$SUCURSAL_COMODATARIA","OBSERVACIONCOMODATO":"$OBSERVACIONCOMODATO","OBSERVACIONES":"$OBSERVACIONES","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","MUNICIPIO_DE_PLACAS":"$MUNICIPIO_DE_PLACAS","NTARJETAPROPIEDAD":"$NTARJETAPROPIEDAD","NROPOLIZASEGURO":"$NROPOLIZASEGURO","FECHAINICIALSEGURO":"$FECHAINICIALSEGURO","FECHAFINALSEGURO":"$FECHAFINALSEGURO","NOPOLIZAOTROSEGURO":"$NOPOLIZAOTROSEGURO","FECHAINICIALOTROSEGURO":"$FECHAINICIALOTROSEGURO","FECHAFINALOTROSEGURO":"$FECHAFINALOTROSEGURO","RECLAMACIONSEGURO":"$RECLAMACIONSEGURO(type:boolean)","DESCUENTORECLAMACION":"$DESCUENTORECLAMACION","FECHAVENCIMPAGOIMPUESTO":"$FECHAVENCIMPAGOIMPUESTO","FECHAPAGOIMPUESTO":"$FECHAPAGOIMPUESTO","LUGAR_PARQUEO":"$LUGAR_PARQUEO","ASIGNACION":"$ASIGNACION","SUCURSAL":"$SUCURSAL","DISPONIBILIDAD":"$DISPONIBILIDAD","FOTOGRAFIA":"$FOTOGRAFIA","CLASEVEHICULO":"$CLASEVEHICULO","CODIGO_ELEMENTO":"$CODIGO_ELEMENTO","SERIE_ELEMENTO":"$SERIE_ELEMENTO","PLACASANTERIORES":"$PLACASANTERIORES","SERIE":"$SERIE","ESTADO":"$ESTADO","COMPANIA":"$COMPANIA","PLACA":"$PLACA","TIPO":"$TIPO","MARCA":"$MARCA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/invenactivosread">
		<call-query href="getInventarioparqueautomotorInvenactivosreadQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>

		</call-query>
	</resource>
	<query id="insertInventarioparqueautomotorInvactinsert" keyColumns="COMPANIA,PLACA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INVENTARIO_PARQUE_AUTOMOTOR (COMPANIA, PLACA, ESTADO, PAIS, DEPARTAMENTO, MUNICIPIO_DE_PLACAS, DESCRIPCION, MODELO, TIPO, MARCA, COLOR, VALOR, FECHA_PUESTA_SERVICIO, ASIGNACION, CODIGO_ELEMENTO, SERIE_ELEMENTO, ES_AUTOMOTOR, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :PLACA, :ESTADO, :PAIS, :DEPARTAMENTO, :MUNICIPIO_DE_PLACAS, :DESCRIPCION, :MODELO, :TIPO, :MARCA, :COLOR, :VALOR, TO_DATE(:FECHA_PUESTA_SERVICIO,'DD/MM/YYYY HH24:MI:SS'), :ASIGNACION, :CODIGO_ELEMENTO, :SERIE_ELEMENTO, :ES_AUTOMOTOR, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PLACA":"$PLACA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="PAIS" sqlType="STRING"/>
		<param defaultValue="" name="DEPARTAMENTO" sqlType="STRING"/>
		<param defaultValue="" name="MUNICIPIO_DE_PLACAS" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="MODELO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="MARCA" sqlType="STRING"/>
		<param defaultValue="" name="COLOR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_PUESTA_SERVICIO" sqlType="STRING"/>
		<param defaultValue="" name="ASIGNACION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_ELEMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="SERIE_ELEMENTO" sqlType="STRING"/>
		<param name="ES_AUTOMOTOR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="inventarioparqueautomotor/invactinsert">
		<call-query href="insertInventarioparqueautomotorInvactinsert">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="MUNICIPIO_DE_PLACAS" query-param="MUNICIPIO_DE_PLACAS"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MODELO" query-param="MODELO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="COLOR" query-param="COLOR"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA_PUESTA_SERVICIO" query-param="FECHA_PUESTA_SERVICIO"/>
			<with-param name="ASIGNACION" query-param="ASIGNACION"/>
			<with-param name="CODIGO_ELEMENTO" query-param="CODIGO_ELEMENTO"/>
			<with-param name="SERIE_ELEMENTO" query-param="SERIE_ELEMENTO"/>
			<with-param name="ES_AUTOMOTOR" query-param="ES_AUTOMOTOR"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

