	<query id="getInventarioparqueautomotorPagElenombautiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO CODIGOELEMENTO, INVENTARIO.NOMBRELARGO  FROM INVENTARIO_PARQUE_AUTOMOTOR INNER JOIN INVENTARIO ON INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA = INVENTARIO.COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA = :COMPANIA AND ES_AUTOMOTOR = -1 ORDER BY INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/elenombautini/pag">
