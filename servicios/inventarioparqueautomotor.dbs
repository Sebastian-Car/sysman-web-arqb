	<query id="insertInventarioparqueautomotor" keyColumns="COMPANIA,PLACA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INVENTARIO_PARQUE_AUTOMOTOR (COLOR, MODELO, NO_MOTOR, CILINDRAJE, SERIE_CHASIS, VALOR, FECHA_PUESTA_SERVICIO, PROCEDENCIA, CODPROCEDENCIA, FECHA_INICIO_COMODATO, FECHA_FINAL_COMODATO, ENTIDAD_COMODATARIA, SUCURSAL_COMODATARIA, OBSERVACIONCOMODATO, OBSERVACIONES, CAPACIDAD_PASAJEROS, CAPACIDAD_TONELADAS, PAIS, DEPARTAMENTO, MUNICIPIO_DE_PLACAS, NRO_DE_LLANTAS, REFERENCIA_LLANTAS, NRO_BATERIAS, CARACTERISTICASBATERIA, NTARJETAPROPIEDAD, NROPOLIZASEGURO, FECHAINICIALSEGURO, FECHAFINALSEGURO, NOPOLIZAOTROSEGURO, FECHAINICIALOTROSEGURO, FECHAFINALOTROSEGURO, RECLAMACIONSEGURO, DESCUENTORECLAMACION, FECHAVENCIMPAGOIMPUESTO, FECHAPAGOIMPUESTO, TIPO_DE_COMBUSTIBLE, CAPTANQUECOMBUSTIBLE, LUGAR_PARQUEO, SUCURSAL_PARQUEO, ACCESORIOS, ASIGNACION, CONDUCTOR, SUCURSAL, DISPONIBILIDAD, PICOYPLACA, FOTOGRAFIA, CLASEVEHICULO, CODIGO_ELEMENTO, SERIE_ELEMENTO, PLACASANTERIORES, ACEITE, SERIE, ESTADO, DIASPICOPLACA, CENTRO_COSTO, COMPANIA, PLACA, TIPO, MARCA, CREATED_BY, DATE_CREATED, ES_AUTOMOTOR) VALUES (:COLOR, :MODELO, :NO_MOTOR, :CILINDRAJE, :SERIE_CHASIS, :VALOR, TO_DATE(:FECHA_PUESTA_SERVICIO,'DD/MM/YYYY HH24:MI:SS'), :PROCEDENCIA, :CODPROCEDENCIA, TO_DATE(:FECHA_INICIO_COMODATO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL_COMODATO,'DD/MM/YYYY HH24:MI:SS'), :ENTIDAD_COMODATARIA, :SUCURSAL_COMODATARIA, :OBSERVACIONCOMODATO, :OBSERVACIONES, :CAPACIDAD_PASAJEROS, :CAPACIDAD_TONELADAS, :PAIS, :DEPARTAMENTO, :MUNICIPIO_DE_PLACAS, :NRO_DE_LLANTAS, :REFERENCIA_LLANTAS, :NRO_BATERIAS, :CARACTERISTICASBATERIA, :NTARJETAPROPIEDAD, :NROPOLIZASEGURO, TO_DATE(:FECHAINICIALSEGURO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINALSEGURO,'DD/MM/YYYY HH24:MI:SS'), :NOPOLIZAOTROSEGURO, TO_DATE(:FECHAINICIALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS'), :RECLAMACIONSEGURO, :DESCUENTORECLAMACION, TO_DATE(:FECHAVENCIMPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS'), :TIPO_DE_COMBUSTIBLE, :CAPTANQUECOMBUSTIBLE, :LUGAR_PARQUEO, :SUCURSAL_PARQUEO, :ACCESORIOS, :ASIGNACION, :CONDUCTOR, :SUCURSAL, :DISPONIBILIDAD, :PICOYPLACA, :FOTOGRAFIA, :CLASEVEHICULO, :CODIGO_ELEMENTO, :SERIE_ELEMENTO, :PLACASANTERIORES, :ACEITE, :SERIE, :ESTADO, :DIASPICOPLACA, :CENTRO_COSTO, :COMPANIA, :PLACA, :TIPO, :MARCA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :ES_AUTOMOTOR)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PLACA":"$PLACA"}]}}		</result>
