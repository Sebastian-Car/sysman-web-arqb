		</call-query>
	</resource>
	<query id="getInventarioparqueautomotorRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT INVENTARIO_PARQUE_AUTOMOTOR.COLOR, INVENTARIO_PARQUE_AUTOMOTOR.MODELO, INVENTARIO_PARQUE_AUTOMOTOR.NO_MOTOR, INVENTARIO_PARQUE_AUTOMOTOR.CILINDRAJE, INVENTARIO_PARQUE_AUTOMOTOR.SERIE_CHASIS, INVENTARIO_PARQUE_AUTOMOTOR.VALOR,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHA_PUESTA_SERVICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_PUESTA_SERVICIO, INVENTARIO_PARQUE_AUTOMOTOR.PROCEDENCIA, INVENTARIO_PARQUE_AUTOMOTOR.CODPROCEDENCIA,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHA_INICIO_COMODATO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_COMODATO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHA_FINAL_COMODATO,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_COMODATO, INVENTARIO_PARQUE_AUTOMOTOR.ENTIDAD_COMODATARIA, INVENTARIO_PARQUE_AUTOMOTOR.SUCURSAL_COMODATARIA, INVENTARIO_PARQUE_AUTOMOTOR.OBSERVACIONCOMODATO, INVENTARIO_PARQUE_AUTOMOTOR.OBSERVACIONES, INVENTARIO_PARQUE_AUTOMOTOR.CAPACIDAD_PASAJEROS, INVENTARIO_PARQUE_AUTOMOTOR.CAPACIDAD_TONELADAS, INVENTARIO_PARQUE_AUTOMOTOR.PAIS, INVENTARIO_PARQUE_AUTOMOTOR.DEPARTAMENTO, INVENTARIO_PARQUE_AUTOMOTOR.MUNICIPIO_DE_PLACAS, INVENTARIO_PARQUE_AUTOMOTOR.NRO_DE_LLANTAS, INVENTARIO_PARQUE_AUTOMOTOR.REFERENCIA_LLANTAS, INVENTARIO_PARQUE_AUTOMOTOR.NRO_BATERIAS, INVENTARIO_PARQUE_AUTOMOTOR.CARACTERISTICASBATERIA, INVENTARIO_PARQUE_AUTOMOTOR.NTARJETAPROPIEDAD, INVENTARIO_PARQUE_AUTOMOTOR.NROPOLIZASEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAINICIALSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIALSEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAFINALSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALSEGURO, INVENTARIO_PARQUE_AUTOMOTOR.NOPOLIZAOTROSEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAINICIALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIALOTROSEGURO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAFINALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALOTROSEGURO,(CASE INVENTARIO_PARQUE_AUTOMOTOR.RECLAMACIONSEGURO WHEN 0 THEN 'false' ELSE 'true' END) RECLAMACIONSEGURO, INVENTARIO_PARQUE_AUTOMOTOR.DESCUENTORECLAMACION,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAVENCIMPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMPAGOIMPUESTO,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.FECHAPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOIMPUESTO, INVENTARIO_PARQUE_AUTOMOTOR.TIPO_DE_COMBUSTIBLE, INVENTARIO_PARQUE_AUTOMOTOR.CAPTANQUECOMBUSTIBLE, INVENTARIO_PARQUE_AUTOMOTOR.LUGAR_PARQUEO, INVENTARIO_PARQUE_AUTOMOTOR.SUCURSAL_PARQUEO, INVENTARIO_PARQUE_AUTOMOTOR.ACCESORIOS, INVENTARIO_PARQUE_AUTOMOTOR.ASIGNACION, INVENTARIO_PARQUE_AUTOMOTOR.CONDUCTOR, INVENTARIO_PARQUE_AUTOMOTOR.SUCURSAL, INVENTARIO_PARQUE_AUTOMOTOR.DISPONIBILIDAD,(CASE INVENTARIO_PARQUE_AUTOMOTOR.PICOYPLACA WHEN 0 THEN 'false' ELSE 'true' END) PICOYPLACA, INVENTARIO_PARQUE_AUTOMOTOR.FOTOGRAFIA, INVENTARIO_PARQUE_AUTOMOTOR.CLASEVEHICULO, INVENTARIO_PARQUE_AUTOMOTOR.CODIGO_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.SERIE_ELEMENTO, INVENTARIO_PARQUE_AUTOMOTOR.PLACASANTERIORES, INVENTARIO_PARQUE_AUTOMOTOR.ACEITE, INVENTARIO_PARQUE_AUTOMOTOR.SERIE, INVENTARIO_PARQUE_AUTOMOTOR.ESTADO, INVENTARIO_PARQUE_AUTOMOTOR.DIASPICOPLACA, INVENTARIO_PARQUE_AUTOMOTOR.CENTRO_COSTO, INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA, INVENTARIO_PARQUE_AUTOMOTOR.PLACA, INVENTARIO_PARQUE_AUTOMOTOR.TIPO, INVENTARIO_PARQUE_AUTOMOTOR.MARCA, INVENTARIO_PARQUE_AUTOMOTOR.CREATED_BY,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, INVENTARIO_PARQUE_AUTOMOTOR.MODIFIED_BY,(TO_CHAR(INVENTARIO_PARQUE_AUTOMOTOR.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TERCERO.NOMBRE NOMBRECONDUCTOR, TERCERO1.NOMBRE NOMBRECOMODATARIA FROM INVENTARIO_PARQUE_AUTOMOTOR LEFT JOIN TERCERO ON INVENTARIO_PARQUE_AUTOMOTOR.CONDUCTOR=TERCERO.NIT LEFT JOIN TERCERO TERCERO1 ON INVENTARIO_PARQUE_AUTOMOTOR.ENTIDAD_COMODATARIA=TERCERO1.NIT WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA= :KEY_COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.PLACA= :KEY_PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COLOR":"$COLOR","MODELO":"$MODELO(type:integer)","NO_MOTOR":"$NO_MOTOR","CILINDRAJE":"$CILINDRAJE","SERIE_CHASIS":"$SERIE_CHASIS","VALOR":"$VALOR","FECHA_PUESTA_SERVICIO":"$FECHA_PUESTA_SERVICIO","PROCEDENCIA":"$PROCEDENCIA","CODPROCEDENCIA":"$CODPROCEDENCIA","FECHA_INICIO_COMODATO":"$FECHA_INICIO_COMODATO","FECHA_FINAL_COMODATO":"$FECHA_FINAL_COMODATO","ENTIDAD_COMODATARIA":"$ENTIDAD_COMODATARIA","SUCURSAL_COMODATARIA":"$SUCURSAL_COMODATARIA","OBSERVACIONCOMODATO":"$OBSERVACIONCOMODATO","OBSERVACIONES":"$OBSERVACIONES","CAPACIDAD_PASAJEROS":"$CAPACIDAD_PASAJEROS(type:integer)","CAPACIDAD_TONELADAS":"$CAPACIDAD_TONELADAS(type:integer)","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","MUNICIPIO_DE_PLACAS":"$MUNICIPIO_DE_PLACAS","NRO_DE_LLANTAS":"$NRO_DE_LLANTAS(type:integer)","REFERENCIA_LLANTAS":"$REFERENCIA_LLANTAS","NRO_BATERIAS":"$NRO_BATERIAS(type:integer)","CARACTERISTICASBATERIA":"$CARACTERISTICASBATERIA","NTARJETAPROPIEDAD":"$NTARJETAPROPIEDAD","NROPOLIZASEGURO":"$NROPOLIZASEGURO","FECHAINICIALSEGURO":"$FECHAINICIALSEGURO","FECHAFINALSEGURO":"$FECHAFINALSEGURO","NOPOLIZAOTROSEGURO":"$NOPOLIZAOTROSEGURO","FECHAINICIALOTROSEGURO":"$FECHAINICIALOTROSEGURO","FECHAFINALOTROSEGURO":"$FECHAFINALOTROSEGURO","RECLAMACIONSEGURO":"$RECLAMACIONSEGURO(type:boolean)","DESCUENTORECLAMACION":"$DESCUENTORECLAMACION","FECHAVENCIMPAGOIMPUESTO":"$FECHAVENCIMPAGOIMPUESTO","FECHAPAGOIMPUESTO":"$FECHAPAGOIMPUESTO","TIPO_DE_COMBUSTIBLE":"$TIPO_DE_COMBUSTIBLE","CAPTANQUECOMBUSTIBLE":"$CAPTANQUECOMBUSTIBLE","LUGAR_PARQUEO":"$LUGAR_PARQUEO","SUCURSAL_PARQUEO":"$SUCURSAL_PARQUEO","ACCESORIOS":"$ACCESORIOS","ASIGNACION":"$ASIGNACION","CONDUCTOR":"$CONDUCTOR","SUCURSAL":"$SUCURSAL","DISPONIBILIDAD":"$DISPONIBILIDAD","PICOYPLACA":"$PICOYPLACA(type:boolean)","FOTOGRAFIA":"$FOTOGRAFIA","CLASEVEHICULO":"$CLASEVEHICULO","CODIGO_ELEMENTO":"$CODIGO_ELEMENTO","SERIE_ELEMENTO":"$SERIE_ELEMENTO","PLACASANTERIORES":"$PLACASANTERIORES","ACEITE":"$ACEITE","SERIE":"$SERIE","ESTADO":"$ESTADO","DIASPICOPLACA":"$DIASPICOPLACA","CENTRO_COSTO":"$CENTRO_COSTO","COMPANIA":"$COMPANIA","PLACA":"$PLACA","TIPO":"$TIPO","MARCA":"$MARCA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRECONDUCTOR":"$NOMBRECONDUCTOR","NOMBRECOMODATARIA":"$NOMBRECOMODATARIA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioparqueautomotor/data">
		<call-query href="getInventarioparqueautomotorRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>

		</call-query>
	</resource>
	<query id="updateInventarioparqueautomotor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVENTARIO_PARQUE_AUTOMOTOR SET COLOR=:COLOR, MODELO=:MODELO, NO_MOTOR=:NO_MOTOR, CILINDRAJE=:CILINDRAJE, SERIE_CHASIS=:SERIE_CHASIS, VALOR=:VALOR, FECHA_PUESTA_SERVICIO=TO_DATE(:FECHA_PUESTA_SERVICIO,'DD/MM/YYYY HH24:MI:SS'), PROCEDENCIA=:PROCEDENCIA, CODPROCEDENCIA=:CODPROCEDENCIA, FECHA_INICIO_COMODATO=TO_DATE(:FECHA_INICIO_COMODATO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL_COMODATO=TO_DATE(:FECHA_FINAL_COMODATO,'DD/MM/YYYY HH24:MI:SS'), ENTIDAD_COMODATARIA=:ENTIDAD_COMODATARIA, SUCURSAL_COMODATARIA=:SUCURSAL_COMODATARIA, OBSERVACIONCOMODATO=:OBSERVACIONCOMODATO, OBSERVACIONES=:OBSERVACIONES, CAPACIDAD_PASAJEROS=:CAPACIDAD_PASAJEROS, CAPACIDAD_TONELADAS=:CAPACIDAD_TONELADAS, PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, MUNICIPIO_DE_PLACAS=:MUNICIPIO_DE_PLACAS, NRO_DE_LLANTAS=:NRO_DE_LLANTAS, REFERENCIA_LLANTAS=:REFERENCIA_LLANTAS, NRO_BATERIAS=:NRO_BATERIAS, CARACTERISTICASBATERIA=:CARACTERISTICASBATERIA, NTARJETAPROPIEDAD=:NTARJETAPROPIEDAD, NROPOLIZASEGURO=:NROPOLIZASEGURO, FECHAINICIALSEGURO=TO_DATE(:FECHAINICIALSEGURO,'DD/MM/YYYY HH24:MI:SS'), FECHAFINALSEGURO=TO_DATE(:FECHAFINALSEGURO,'DD/MM/YYYY HH24:MI:SS'), NOPOLIZAOTROSEGURO=:NOPOLIZAOTROSEGURO, FECHAINICIALOTROSEGURO=TO_DATE(:FECHAINICIALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS'), FECHAFINALOTROSEGURO=TO_DATE(:FECHAFINALOTROSEGURO,'DD/MM/YYYY HH24:MI:SS'), RECLAMACIONSEGURO=:RECLAMACIONSEGURO, DESCUENTORECLAMACION=:DESCUENTORECLAMACION, FECHAVENCIMPAGOIMPUESTO=TO_DATE(:FECHAVENCIMPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS'), FECHAPAGOIMPUESTO=TO_DATE(:FECHAPAGOIMPUESTO,'DD/MM/YYYY HH24:MI:SS'), TIPO_DE_COMBUSTIBLE=:TIPO_DE_COMBUSTIBLE, CAPTANQUECOMBUSTIBLE=:CAPTANQUECOMBUSTIBLE, LUGAR_PARQUEO=:LUGAR_PARQUEO, SUCURSAL_PARQUEO=:SUCURSAL_PARQUEO, ACCESORIOS=:ACCESORIOS, ASIGNACION=:ASIGNACION, CONDUCTOR=:CONDUCTOR, SUCURSAL=:SUCURSAL, DISPONIBILIDAD=:DISPONIBILIDAD, PICOYPLACA=:PICOYPLACA, FOTOGRAFIA=:FOTOGRAFIA, CLASEVEHICULO=:CLASEVEHICULO, CODIGO_ELEMENTO=:CODIGO_ELEMENTO, SERIE_ELEMENTO=:SERIE_ELEMENTO, PLACASANTERIORES=:PLACASANTERIORES, ACEITE=:ACEITE, SERIE=:SERIE, ESTADO=:ESTADO, DIASPICOPLACA=:DIASPICOPLACA, CENTRO_COSTO=:CENTRO_COSTO, TIPO=:TIPO, MARCA=:MARCA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE INVENTARIO_PARQUE_AUTOMOTOR.COMPANIA= :KEY_COMPANIA AND INVENTARIO_PARQUE_AUTOMOTOR.PLACA= :KEY_PLACA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

