	<query id="deleteProgramacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PROGRAMACION WHERE PROGRAMACION.COMPANIA= :KEY_COMPANIA AND PROGRAMACION.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND PROGRAMACION.CODIGOCOMPONENTE= :KEY_CODIGOCOMPONENTE AND PROGRAMACION.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE AND PROGRAMACION.CODIGOACTIVIDAD= :KEY_CODIGOACTIVIDAD AND PROGRAMACION.VIGENCIA= :KEY_VIGENCIA AND PROGRAMACION.TIPOESTADO= :KEY_TIPOESTADO AND PROGRAMACION.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPROYECTO" sqlType="STRING"/>
		<param name="KEY_CODIGOCOMPONENTE" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="KEY_CODIGOACTIVIDAD" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>
		<param name="KEY_TIPOESTADO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="programacion">
		<call-query href="deleteProgramacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPROYECTO" query-param="KEY_CODIGOPROYECTO"/>
			<with-param name="KEY_CODIGOCOMPONENTE" query-param="KEY_CODIGOCOMPONENTE"/>
			<with-param name="KEY_TIPOCOMPONENTE" query-param="KEY_TIPOCOMPONENTE"/>
			<with-param name="KEY_CODIGOACTIVIDAD" query-param="KEY_CODIGOACTIVIDAD"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_TIPOESTADO" query-param="KEY_TIPOESTADO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getProgramacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROGRAMACION.COMPANIA, PROGRAMACION.CODIGOPROYECTO, PROGRAMACION.CODIGOCOMPONENTE, PROGRAMACION.TIPOCOMPONENTE, PROGRAMACION.CODIGOACTIVIDAD, PROGRAMACION.VIGENCIA, PROGRAMACION.TIPOESTADO, PROGRAMACION.CODIGO, COMPONENTES_ACTIVIDADES.NOMBREACTIVIDAD, DECODE(PROGRAMACION.TIPOESTADO,'P','Programado','RP','Reprogramado','E','Ejecutado') NOMBRETIPOESTADO  FROM PROGRAMACION INNER JOIN COMPONENTES_ACTIVIDADES ON PROGRAMACION.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND PROGRAMACION.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND PROGRAMACION.CODIGOCOMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND PROGRAMACION.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE AND PROGRAMACION.CODIGOACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD WHERE PROGRAMACION.COMPANIA = :COMPANIA AND PROGRAMACION.CODIGOPROYECTO = :PROYECTO AND PROGRAMACION.CODIGOCOMPONENTE = :COMPONENTE AND PROGRAMACION.VIGENCIA = :MI_VIGENCIA AND PROGRAMACION.TIPOESTADO = :TIPOESTADO ORDER BY PROGRAMACION.CODIGOACTIVIDAD) WHERE (CASE WHEN CODIGOACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGOACTIVIDAD) END)  LIKE UPPER(:CODIGOACTIVIDAD || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%')  AND (CASE WHEN NOMBRETIPOESTADO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOESTADO) END)  LIKE UPPER( '%' || :NOMBRETIPOESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOPROYECTO":"$CODIGOPROYECTO","CODIGOCOMPONENTE":"$CODIGOCOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","CODIGOACTIVIDAD":"$CODIGOACTIVIDAD","VIGENCIA":"$VIGENCIA(type:integer)","TIPOESTADO":"$TIPOESTADO","CODIGO":"$CODIGO","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","NOMBRETIPOESTADO":"$NOMBRETIPOESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="MI_VIGENCIA" sqlType="STRING"/>
		<param name="TIPOESTADO" sqlType="STRING"/>
		<param name="CODIGOACTIVIDAD" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRETIPOESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="programacion">
		<call-query href="getProgramacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="MI_VIGENCIA" query-param="MI_VIGENCIA"/>
			<with-param name="TIPOESTADO" query-param="TIPOESTADO"/>
			<with-param name="CODIGOACTIVIDAD" query-param="CODIGOACTIVIDAD"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>
			<with-param name="NOMBRETIPOESTADO" query-param="NOMBRETIPOESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProgramacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROGRAMACION.COMPANIA, PROGRAMACION.CODIGOPROYECTO, PROGRAMACION.CODIGOCOMPONENTE, PROGRAMACION.TIPOCOMPONENTE, PROGRAMACION.CODIGOACTIVIDAD, PROGRAMACION.VIGENCIA, PROGRAMACION.TIPOESTADO, PROGRAMACION.CODIGO, COMPONENTES_ACTIVIDADES.NOMBREACTIVIDAD, DECODE(PROGRAMACION.TIPOESTADO,'P','Programado','RP','Reprogramado','E','Ejecutado') NOMBRETIPOESTADO  FROM PROGRAMACION INNER JOIN COMPONENTES_ACTIVIDADES ON PROGRAMACION.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND PROGRAMACION.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND PROGRAMACION.CODIGOCOMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND PROGRAMACION.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE AND PROGRAMACION.CODIGOACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD WHERE PROGRAMACION.COMPANIA = :COMPANIA AND PROGRAMACION.CODIGOPROYECTO = :PROYECTO AND PROGRAMACION.CODIGOCOMPONENTE = :COMPONENTE AND PROGRAMACION.VIGENCIA = :MI_VIGENCIA AND PROGRAMACION.TIPOESTADO = :TIPOESTADO ORDER BY PROGRAMACION.CODIGOACTIVIDAD) WHERE (CASE WHEN CODIGOACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGOACTIVIDAD) END)  LIKE UPPER(:CODIGOACTIVIDAD || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%')  AND (CASE WHEN NOMBRETIPOESTADO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOESTADO) END)  LIKE UPPER( '%' || :NOMBRETIPOESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="MI_VIGENCIA" sqlType="STRING"/>
		<param name="TIPOESTADO" sqlType="STRING"/>
		<param name="CODIGOACTIVIDAD" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRETIPOESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="programacion/numero">
		<call-query href="getProgramacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="MI_VIGENCIA" query-param="MI_VIGENCIA"/>
			<with-param name="TIPOESTADO" query-param="TIPOESTADO"/>
			<with-param name="CODIGOACTIVIDAD" query-param="CODIGOACTIVIDAD"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>
			<with-param name="NOMBRETIPOESTADO" query-param="NOMBRETIPOESTADO"/>

		</call-query>
	</resource>
	<query id="getProgramacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PROGRAMACION.COMPANIA, PROGRAMACION.CODIGOPROYECTO, PROGRAMACION.CODIGOCOMPONENTE, PROGRAMACION.TIPOCOMPONENTE, PROGRAMACION.CODIGOACTIVIDAD, PROGRAMACION.VIGENCIA, PROGRAMACION.TIPOESTADO, PROGRAMACION.CODIGO, PROGRAMACION.CODIGO_QUEAPRUEBA, PROGRAMACION.CANTIDAD, PROGRAMACION.TIPOT_QUEAPRUEBA, PROGRAMACION.VALORTOTAL, PROGRAMACION.PORCENTAJE1, PROGRAMACION.VALOR1, PROGRAMACION.PORCENTAJE2, PROGRAMACION.VALOR2, PROGRAMACION.PORCENTAJE3, PROGRAMACION.VALOR3, PROGRAMACION.PORCENTAJE4, PROGRAMACION.VALOR4, PROGRAMACION.PORCENTAJE5, PROGRAMACION.VALOR5, PROGRAMACION.PORCENTAJE6, PROGRAMACION.VALOR6, PROGRAMACION.PORCENTAJE7, PROGRAMACION.VALOR7, PROGRAMACION.PORCENTAJE8, PROGRAMACION.VALOR8, PROGRAMACION.PORCENTAJE9, PROGRAMACION.VALOR9, PROGRAMACION.PORCENTAJE10, PROGRAMACION.VALOR10, PROGRAMACION.PORCENTAJE11, PROGRAMACION.VALOR11, PROGRAMACION.PORCENTAJE12, PROGRAMACION.VALOR12, PROGRAMACION.CLASET_QUEAPRUEBA, PROGRAMACION.DEPENDENCIA_QUEAPRUEBA, PROGRAMACION.CODIGOITEM_QUEAPRUEBA, PROGRAMACION.CREATED_BY, PROGRAMACION.MODIFIED_BY,(TO_CHAR(PROGRAMACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(PROGRAMACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, DECODE(PROGRAMACION.TIPOESTADO,'P','Programado','R','Reprogramado','E','Ejecutado') NOMBRETIPOESTADO  FROM PROGRAMACION INNER JOIN COMPONENTES_ACTIVIDADES ON PROGRAMACION.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND PROGRAMACION.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND PROGRAMACION.CODIGOCOMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND PROGRAMACION.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE AND PROGRAMACION.CODIGOACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD WHERE PROGRAMACION.COMPANIA= :KEY_COMPANIA AND PROGRAMACION.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND PROGRAMACION.CODIGOCOMPONENTE= :KEY_CODIGOCOMPONENTE AND PROGRAMACION.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE AND PROGRAMACION.CODIGOACTIVIDAD= :KEY_CODIGOACTIVIDAD AND PROGRAMACION.VIGENCIA= :KEY_VIGENCIA AND PROGRAMACION.TIPOESTADO= :KEY_TIPOESTADO AND PROGRAMACION.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOPROYECTO":"$CODIGOPROYECTO","CODIGOCOMPONENTE":"$CODIGOCOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","CODIGOACTIVIDAD":"$CODIGOACTIVIDAD","VIGENCIA":"$VIGENCIA(type:integer)","TIPOESTADO":"$TIPOESTADO","CODIGO":"$CODIGO","CODIGO_QUEAPRUEBA":"$CODIGO_QUEAPRUEBA(type:long)","CANTIDAD":"$CANTIDAD","TIPOT_QUEAPRUEBA":"$TIPOT_QUEAPRUEBA","VALORTOTAL":"$VALORTOTAL","PORCENTAJE1":"$PORCENTAJE1","VALOR1":"$VALOR1","PORCENTAJE2":"$PORCENTAJE2","VALOR2":"$VALOR2","PORCENTAJE3":"$PORCENTAJE3","VALOR3":"$VALOR3","PORCENTAJE4":"$PORCENTAJE4","VALOR4":"$VALOR4","PORCENTAJE5":"$PORCENTAJE5","VALOR5":"$VALOR5","PORCENTAJE6":"$PORCENTAJE6","VALOR6":"$VALOR6","PORCENTAJE7":"$PORCENTAJE7","VALOR7":"$VALOR7","PORCENTAJE8":"$PORCENTAJE8","VALOR8":"$VALOR8","PORCENTAJE9":"$PORCENTAJE9","VALOR9":"$VALOR9","PORCENTAJE10":"$PORCENTAJE10","VALOR10":"$VALOR10","PORCENTAJE11":"$PORCENTAJE11","VALOR11":"$VALOR11","PORCENTAJE12":"$PORCENTAJE12","VALOR12":"$VALOR12","CLASET_QUEAPRUEBA":"$CLASET_QUEAPRUEBA","DEPENDENCIA_QUEAPRUEBA":"$DEPENDENCIA_QUEAPRUEBA","CODIGOITEM_QUEAPRUEBA":"$CODIGOITEM_QUEAPRUEBA(type:long)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRETIPOESTADO":"$NOMBRETIPOESTADO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPROYECTO" sqlType="STRING"/>
		<param name="KEY_CODIGOCOMPONENTE" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="KEY_CODIGOACTIVIDAD" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_TIPOESTADO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="programacion/data">
		<call-query href="getProgramacionRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPROYECTO" query-param="KEY_CODIGOPROYECTO"/>
			<with-param name="KEY_CODIGOCOMPONENTE" query-param="KEY_CODIGOCOMPONENTE"/>
			<with-param name="KEY_TIPOCOMPONENTE" query-param="KEY_TIPOCOMPONENTE"/>
			<with-param name="KEY_CODIGOACTIVIDAD" query-param="KEY_CODIGOACTIVIDAD"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_TIPOESTADO" query-param="KEY_TIPOESTADO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateProgramacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROGRAMACION SET TIPOCOMPONENTE=:TIPOCOMPONENTE, CODIGOACTIVIDAD=:CODIGOACTIVIDAD, CODIGO=:CODIGO, CODIGO_QUEAPRUEBA=:CODIGO_QUEAPRUEBA, CANTIDAD=:CANTIDAD, TIPOT_QUEAPRUEBA=:TIPOT_QUEAPRUEBA, VALORTOTAL=:VALORTOTAL, PORCENTAJE1=:PORCENTAJE1, VALOR1=:VALOR1, PORCENTAJE2=:PORCENTAJE2, VALOR2=:VALOR2, PORCENTAJE3=:PORCENTAJE3, VALOR3=:VALOR3, PORCENTAJE4=:PORCENTAJE4, VALOR4=:VALOR4, PORCENTAJE5=:PORCENTAJE5, VALOR5=:VALOR5, PORCENTAJE6=:PORCENTAJE6, VALOR6=:VALOR6, PORCENTAJE7=:PORCENTAJE7, VALOR7=:VALOR7, PORCENTAJE8=:PORCENTAJE8, VALOR8=:VALOR8, PORCENTAJE9=:PORCENTAJE9, VALOR9=:VALOR9, PORCENTAJE10=:PORCENTAJE10, VALOR10=:VALOR10, PORCENTAJE11=:PORCENTAJE11, VALOR11=:VALOR11, PORCENTAJE12=:PORCENTAJE12, VALOR12=:VALOR12, CLASET_QUEAPRUEBA=:CLASET_QUEAPRUEBA, DEPENDENCIA_QUEAPRUEBA=:DEPENDENCIA_QUEAPRUEBA, CODIGOITEM_QUEAPRUEBA=:CODIGOITEM_QUEAPRUEBA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE PROGRAMACION.COMPANIA= :KEY_COMPANIA AND PROGRAMACION.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND PROGRAMACION.CODIGOCOMPONENTE= :KEY_CODIGOCOMPONENTE AND PROGRAMACION.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE AND PROGRAMACION.CODIGOACTIVIDAD= :KEY_CODIGOACTIVIDAD AND PROGRAMACION.VIGENCIA= :KEY_VIGENCIA AND PROGRAMACION.TIPOESTADO= :KEY_TIPOESTADO AND PROGRAMACION.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="CODIGOACTIVIDAD" sqlType="STRING"/>
