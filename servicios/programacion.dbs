			<with-param name="VALOR6" query-param="VALOR6"/>
			<with-param name="PORCENTAJE6" query-param="PORCENTAJE6"/>
			<with-param name="VALOR7" query-param="VALOR7"/>
			<with-param name="PORCENTAJE7" query-param="PORCENTAJE7"/>
			<with-param name="VALOR8" query-param="VALOR8"/>
			<with-param name="PORCENTAJE8" query-param="PORCENTAJE8"/>
			<with-param name="VALOR9" query-param="VALOR9"/>
			<with-param name="PORCENTAJE9" query-param="PORCENTAJE9"/>
			<with-param name="VALOR10" query-param="VALOR10"/>
			<with-param name="PORCENTAJE10" query-param="PORCENTAJE10"/>
			<with-param name="VALOR11" query-param="VALOR11"/>
			<with-param name="PORCENTAJE11" query-param="PORCENTAJE11"/>
			<with-param name="VALOR12" query-param="VALOR12"/>
			<with-param name="PORCENTAJE12" query-param="PORCENTAJE12"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="TIPOT_QUEAPRUEBA" query-param="TIPOT_QUEAPRUEBA"/>
			<with-param name="CLASET_QUEAPRUEBA" query-param="CLASET_QUEAPRUEBA"/>
			<with-param name="CODIGO_QUEAPRUEBA" query-param="CODIGO_QUEAPRUEBA"/>
			<with-param name="DEPENDENCIA_QUEAPRUEBA" query-param="DEPENDENCIA_QUEAPRUEBA"/>
			<with-param name="CODIGOITEM_QUEAPRUEBA" query-param="CODIGOITEM_QUEAPRUEBA"/>
