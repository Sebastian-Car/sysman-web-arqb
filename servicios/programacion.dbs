<data name="programacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getProgramacionExisteEnCompActividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM PROGRAMACION WHERE COMPANIA = :COMPANIA AND CODIGOPROYECTO = :CODIGOPROYECTO AND CODIGOCOMPONENTE = :COMPONENTE AND TIPOCOMPONENTE = :TIPOCOMPONENTE AND CODIGOACTIVIDAD IN( SELECT ACTIVIDAD FROM COMPONENTES_ACTIVIDADES WHERE VIGENCIA = :VIGENCIACOMPONENTE )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="VIGENCIACOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="programacion/existeencompactividades">
		<call-query href="getProgramacionExisteEnCompActividadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>
			<with-param name="VIGENCIACOMPONENTE" query-param="VIGENCIACOMPONENTE"/>

		</call-query>
	</resource>
	<query id="getProgramacionValoresporprogramacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VALOR1, VALOR2, VALOR3, VALOR4, VALOR5, VALOR6, VALOR7, VALOR8, VALOR9, VALOR10, VALOR11, VALOR12  FROM PROGRAMACION WHERE COMPANIA = :KEY_COMPANIA AND CODIGOPROYECTO = :KEY_CODIGOPROYECTO AND CODIGOCOMPONENTE = :KEY_CODIGOCOMPONENTE AND TIPOCOMPONENTE = :KEY_TIPOCOMPONENTE AND CODIGOACTIVIDAD = :KEY_CODIGOACTIVIDAD AND VIGENCIA = :KEY_VIGENCIA AND TIPOESTADO = :KEY_TIPOESTADO AND CODIGO = :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR1":"$VALOR1","VALOR2":"$VALOR2","VALOR3":"$VALOR3","VALOR4":"$VALOR4","VALOR5":"$VALOR5","VALOR6":"$VALOR6","VALOR7":"$VALOR7","VALOR8":"$VALOR8","VALOR9":"$VALOR9","VALOR10":"$VALOR10","VALOR11":"$VALOR11","VALOR12":"$VALOR12"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPROYECTO" sqlType="STRING"/>
		<param name="KEY_CODIGOCOMPONENTE" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="KEY_CODIGOACTIVIDAD" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_TIPOESTADO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="programacion/valoresporprogramacion">
		<call-query href="getProgramacionValoresporprogramacionQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPROYECTO" query-param="KEY_CODIGOPROYECTO"/>
			<with-param name="KEY_CODIGOCOMPONENTE" query-param="KEY_CODIGOCOMPONENTE"/>
			<with-param name="KEY_TIPOCOMPONENTE" query-param="KEY_TIPOCOMPONENTE"/>
			<with-param name="KEY_CODIGOACTIVIDAD" query-param="KEY_CODIGOACTIVIDAD"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_TIPOESTADO" query-param="KEY_TIPOESTADO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="insertProgramacion" keyColumns="COMPANIA,CODIGOPROYECTO,CODIGOCOMPONENTE,TIPOCOMPONENTE,CODIGOACTIVIDAD,VIGENCIA,TIPOESTADO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PROGRAMACION (COMPANIA, CODIGOPROYECTO, CODIGOCOMPONENTE, TIPOCOMPONENTE, CODIGOACTIVIDAD, VIGENCIA, TIPOESTADO, CODIGO, CODIGO_REPROGRAMADO, REPROGRAMADO, PERIOCIDAD, VALOR1, PORCENTAJE1, VALOR2, PORCENTAJE2, VALOR3, PORCENTAJE3, VALOR4, PORCENTAJE4, VALOR5, PORCENTAJE5, VALOR6, PORCENTAJE6, VALOR7, PORCENTAJE7, VALOR8, PORCENTAJE8, VALOR9, PORCENTAJE9, VALOR10, PORCENTAJE10, VALOR11, PORCENTAJE11, VALOR12, PORCENTAJE12, VALORTOTAL, CANTIDAD, TIPOT_QUEAPRUEBA, CLASET_QUEAPRUEBA, CODIGO_QUEAPRUEBA, DEPENDENCIA_QUEAPRUEBA, CODIGOITEM_QUEAPRUEBA, PERIOCIDAD_ANTERIOR_P, CREATED_BY, FECHA, DATE_CREATED) VALUES (:COMPANIA, :CODIGOPROYECTO, :CODIGOCOMPONENTE, :TIPOCOMPONENTE, :CODIGOACTIVIDAD, :VIGENCIA, :TIPOESTADO, :CODIGO, :CODIGO_REPROGRAMADO, :REPROGRAMADO, :PERIOCIDAD, :VALOR1, :PORCENTAJE1, :VALOR2, :PORCENTAJE2, :VALOR3, :PORCENTAJE3, :VALOR4, :PORCENTAJE4, :VALOR5, :PORCENTAJE5, :VALOR6, :PORCENTAJE6, :VALOR7, :PORCENTAJE7, :VALOR8, :PORCENTAJE8, :VALOR9, :PORCENTAJE9, :VALOR10, :PORCENTAJE10, :VALOR11, :PORCENTAJE11, :VALOR12, :PORCENTAJE12, :VALORTOTAL, :CANTIDAD, :TIPOT_QUEAPRUEBA, :CLASET_QUEAPRUEBA, :CODIGO_QUEAPRUEBA, :DEPENDENCIA_QUEAPRUEBA, :CODIGOITEM_QUEAPRUEBA, :PERIOCIDAD_ANTERIOR_P, :CREATED_BY, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOPROYECTO":"$CODIGOPROYECTO","KEY_CODIGOCOMPONENTE":"$CODIGOCOMPONENTE","KEY_TIPOCOMPONENTE":"$TIPOCOMPONENTE","KEY_CODIGOACTIVIDAD":"$CODIGOACTIVIDAD","KEY_VIGENCIA":"$VIGENCIA(type:integer)","KEY_TIPOESTADO":"$TIPOESTADO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGOCOMPONENTE" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="CODIGOACTIVIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param name="TIPOESTADO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_REPROGRAMADO" sqlType="STRING"/>
		<param defaultValue="0" name="REPROGRAMADO" sqlType="STRING"/>
		<param defaultValue="" name="PERIOCIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR1" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE1" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR2" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE2" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR3" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE3" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR4" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE4" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR5" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE5" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR6" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE6" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR7" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE7" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR8" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE8" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR9" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE9" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR10" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE10" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR11" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE11" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR12" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE12" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="TIPOT_QUEAPRUEBA" sqlType="STRING"/>
		<param defaultValue="" name="CLASET_QUEAPRUEBA" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO_QUEAPRUEBA" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA_QUEAPRUEBA" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGOITEM_QUEAPRUEBA" sqlType="STRING"/>
		<param defaultValue="" name="PERIOCIDAD_ANTERIOR_P" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="programacion">
		<call-query href="insertProgramacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="CODIGOCOMPONENTE" query-param="CODIGOCOMPONENTE"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>
