<data name="natcursoscarreras" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatcursoscarreras" keyColumns="COMPANIA,NITENTIDAD,SUCURSAL,NOMBRECARRERA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_CURSOS_CARRERAS (COMPANIA, NITENTIDAD, SUCURSAL, NOMBRECARRERA, MODALIDAD, TITULOOTORGADO, DIRIGIDOA, OBJETO, CONTENIDOTEMAS, DURACION, OBSERVACIONES, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NITENTIDAD, :SUCURSAL, :NOMBRECARRERA, :MODALIDAD, :TITULOOTORGADO, :DIRIGIDOA, :OBJETO, :CONTENIDOTEMAS, :DURACION, :OBSERVACIONES, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NITENTIDAD":"$NITENTIDAD","KEY_SUCURSAL":"$SUCURSAL","KEY_NOMBRECARRERA":"$NOMBRECARRERA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITENTIDAD" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRECARRERA" sqlType="STRING"/>
		<param defaultValue="" name="MODALIDAD" sqlType="STRING"/>
		<param defaultValue="" name="TITULOOTORGADO" sqlType="STRING"/>
		<param defaultValue="" name="DIRIGIDOA" sqlType="STRING"/>
		<param defaultValue="" name="OBJETO" sqlType="STRING"/>
		<param defaultValue="" name="CONTENIDOTEMAS" sqlType="STRING"/>
		<param defaultValue="" name="DURACION" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natcursoscarreras">
		<call-query href="insertNatcursoscarreras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITENTIDAD" query-param="NITENTIDAD"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRECARRERA" query-param="NOMBRECARRERA"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="TITULOOTORGADO" query-param="TITULOOTORGADO"/>
			<with-param name="DIRIGIDOA" query-param="DIRIGIDOA"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="CONTENIDOTEMAS" query-param="CONTENIDOTEMAS"/>
			<with-param name="DURACION" query-param="DURACION"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteNatcursoscarreras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_CURSOS_CARRERAS WHERE NAT_CURSOS_CARRERAS.COMPANIA= :KEY_COMPANIA AND NAT_CURSOS_CARRERAS.NITENTIDAD= :KEY_NITENTIDAD AND NAT_CURSOS_CARRERAS.SUCURSAL= :KEY_SUCURSAL AND NAT_CURSOS_CARRERAS.NOMBRECARRERA= :KEY_NOMBRECARRERA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NITENTIDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NOMBRECARRERA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natcursoscarreras">
		<call-query href="deleteNatcursoscarreras">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NITENTIDAD" query-param="KEY_NITENTIDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NOMBRECARRERA" query-param="KEY_NOMBRECARRERA"/>

		</call-query>
	</resource>
	<query id="getNatcursoscarrerasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA ,NITENTIDAD ,SUCURSAL ,NOMBRECARRERA ,MODALIDAD  FROM NAT_CURSOS_CARRERAS WHERE COMPANIA = :COMPANIA AND NITENTIDAD = :NITENTIDAD AND SUCURSAL = :SUCURSAL) WHERE (CASE WHEN NOMBRECARRERA IS NULL THEN ' ' ELSE UPPER(NOMBRECARRERA) END)  LIKE UPPER( '%' || :NOMBRECARRERA || '%')  AND (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END)  LIKE UPPER( '%' || :MODALIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NITENTIDAD":"$NITENTIDAD","SUCURSAL":"$SUCURSAL","NOMBRECARRERA":"$NOMBRECARRERA","MODALIDAD":"$MODALIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITENTIDAD" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRECARRERA" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natcursoscarreras">
		<call-query href="getNatcursoscarrerasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITENTIDAD" query-param="NITENTIDAD"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRECARRERA" query-param="NOMBRECARRERA"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatcursoscarrerasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA ,NITENTIDAD ,SUCURSAL ,NOMBRECARRERA ,MODALIDAD  FROM NAT_CURSOS_CARRERAS WHERE COMPANIA = :COMPANIA AND NITENTIDAD = :NITENTIDAD AND SUCURSAL = :SUCURSAL) WHERE (CASE WHEN NOMBRECARRERA IS NULL THEN ' ' ELSE UPPER(NOMBRECARRERA) END)  LIKE UPPER( '%' || :NOMBRECARRERA || '%')  AND (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END)  LIKE UPPER( '%' || :MODALIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITENTIDAD" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRECARRERA" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcursoscarreras/numero">
		<call-query href="getNatcursoscarrerasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITENTIDAD" query-param="NITENTIDAD"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRECARRERA" query-param="NOMBRECARRERA"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>

		</call-query>
	</resource>
	<query id="getNatcursoscarrerasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA , NITENTIDAD , SUCURSAL , NOMBRECARRERA , MODALIDAD , TITULOOTORGADO , DIRIGIDOA , OBJETO , CONTENIDOTEMAS , DURACION , OBSERVACIONES , CREATED_BY ,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY ,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM NAT_CURSOS_CARRERAS WHERE NAT_CURSOS_CARRERAS.COMPANIA= :KEY_COMPANIA AND NAT_CURSOS_CARRERAS.NITENTIDAD= :KEY_NITENTIDAD AND NAT_CURSOS_CARRERAS.SUCURSAL= :KEY_SUCURSAL AND NAT_CURSOS_CARRERAS.NOMBRECARRERA= :KEY_NOMBRECARRERA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NITENTIDAD":"$NITENTIDAD","SUCURSAL":"$SUCURSAL","NOMBRECARRERA":"$NOMBRECARRERA","MODALIDAD":"$MODALIDAD","TITULOOTORGADO":"$TITULOOTORGADO","DIRIGIDOA":"$DIRIGIDOA","OBJETO":"$OBJETO","CONTENIDOTEMAS":"$CONTENIDOTEMAS","DURACION":"$DURACION","OBSERVACIONES":"$OBSERVACIONES","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NITENTIDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NOMBRECARRERA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcursoscarreras/data">
		<call-query href="getNatcursoscarrerasRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NITENTIDAD" query-param="KEY_NITENTIDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NOMBRECARRERA" query-param="KEY_NOMBRECARRERA"/>

		</call-query>
	</resource>
	<query id="updateNatcursoscarreras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_CURSOS_CARRERAS SET NOMBRECARRERA=:NOMBRECARRERA, MODALIDAD=:MODALIDAD, TITULOOTORGADO=:TITULOOTORGADO, DIRIGIDOA=:DIRIGIDOA, OBJETO=:OBJETO, CONTENIDOTEMAS=:CONTENIDOTEMAS, DURACION=:DURACION, OBSERVACIONES=:OBSERVACIONES, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_CURSOS_CARRERAS.COMPANIA= :KEY_COMPANIA AND NAT_CURSOS_CARRERAS.NITENTIDAD= :KEY_NITENTIDAD AND NAT_CURSOS_CARRERAS.SUCURSAL= :KEY_SUCURSAL AND NAT_CURSOS_CARRERAS.NOMBRECARRERA= :KEY_NOMBRECARRERA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRECARRERA" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="TITULOOTORGADO" sqlType="STRING"/>
		<param name="DIRIGIDOA" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="CONTENIDOTEMAS" sqlType="STRING"/>
		<param name="DURACION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NITENTIDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NOMBRECARRERA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natcursoscarreras">
		<call-query href="updateNatcursoscarreras">
			<with-param name="NOMBRECARRERA" query-param="NOMBRECARRERA"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="TITULOOTORGADO" query-param="TITULOOTORGADO"/>
			<with-param name="DIRIGIDOA" query-param="DIRIGIDOA"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="CONTENIDOTEMAS" query-param="CONTENIDOTEMAS"/>
			<with-param name="DURACION" query-param="DURACION"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NITENTIDAD" query-param="KEY_NITENTIDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NOMBRECARRERA" query-param="KEY_NOMBRECARRERA"/>

		</call-query>
	</resource>

</data>