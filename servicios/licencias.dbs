	<query id="updateLicencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE LICENCIAS SET COMPANIA=:COMPANIA, LICENCIA=:LICENCIA, ANO=:ANO, DIAS=:DIAS, FECHA_ACTO=TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHANOVEDAD=TO_DATE(:FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS'), MES=:MES, NUMERO_ACTO=:NUMERO_ACTO, PERIODO=:PERIODO, TIPOACTO=:TIPOACTO, VALOR=:VALOR, OBSERVACION_L=:OBSERVACION_L, DIAS_INICIALES=:DIAS_INICIALES, LICENCIA_REMUNERADA=:LICENCIA_REMUNERADA, FECHA_INICIO_REAL=TO_DATE(:FECHA_INICIO_REAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL_REAL=TO_DATE(:FECHA_FINAL_REAL,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE LICENCIAS.COMPANIA= :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO= :KEY_NUMERO_ACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="FECHA_ACTO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHANOVEDAD" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NUMERO_ACTO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="OBSERVACION_L" sqlType="STRING"/>
		<param name="DIAS_INICIALES" sqlType="STRING"/>
		<param name="LICENCIA_REMUNERADA" sqlType="STRING"/>
		<param name="FECHA_INICIO_REAL" sqlType="STRING"/>
		<param name="FECHA_FINAL_REAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="licencias">
		<call-query href="updateLicencias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="FECHA_ACTO" query-param="FECHA_ACTO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHANOVEDAD" query-param="FECHANOVEDAD"/>
			<with-param name="MES" query-param="MES"/>
