	<query id="updateLicenciasLicencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE LICENCIAS SET TIPOACTO=:TIPOACTO, FECHA_ACTO=TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), LICENCIA=:LICENCIA, FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), ANO=:ANO, MES=:MES, PERIODO=:PERIODO, OBSERVACION_L=:OBSERVACION_L, NUMERO_ACTO=:NUMERO_ACTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE LICENCIAS.COMPANIA= :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO= :KEY_NUMERO_ACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="FECHA_ACTO" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="OBSERVACION_L" sqlType="STRING"/>
		<param name="NUMERO_ACTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="licencias/licencia">
		<call-query href="updateLicenciasLicencia">
			<with-param name="TIPOACTO" query-param="TIPOACTO"/>
			<with-param name="FECHA_ACTO" query-param="FECHA_ACTO"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="OBSERVACION_L" query-param="OBSERVACION_L"/>
			<with-param name="NUMERO_ACTO" query-param="NUMERO_ACTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_NUMERO_ACTO" query-param="KEY_NUMERO_ACTO"/>

		</call-query>
	</resource>
	<query id="getLicenciasLicenciaporempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO, LICENCIAS.LICENCIA, LICENCIAS.ANO, LICENCIAS.MES, LICENCIAS.PERIODO, LICENCIAS.OBSERVACION_L, LICENCIAS.TIPOACTO CODIGO,(TO_CHAR(LICENCIAS.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO, LICENCIAS.NUMERO_DCTO, LICENCIAS.SUCURSAL, LICENCIAS.TIPOACTO, LICENCIAS.CREATED_BY,(TO_CHAR(LICENCIAS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, LICENCIAS.MODIFIED_BY,(TO_CHAR(LICENCIAS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM LICENCIAS WHERE LICENCIAS.COMPANIA= :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO= :KEY_NUMERO_ACTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO","LICENCIA":"$LICENCIA","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","OBSERVACION_L":"$OBSERVACION_L","CODIGO":"$CODIGO(type:integer)","FECHA_ACTO":"$FECHA_ACTO","FECHA_FINAL":"$FECHA_FINAL","FECHA_INICIO":"$FECHA_INICIO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","TIPOACTO":"$TIPOACTO(type:integer)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="licencias/licenciaporempleado">
		<call-query href="getLicenciasLicenciaporempleadoQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_NUMERO_ACTO" query-param="KEY_NUMERO_ACTO"/>

		</call-query>
	</resource>
	<query id="updateLicenciasActLicenciasSinRemun" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE LICENCIAS SET ID_DE_EMPLEADO=:ID_DE_EMPLEADO, PERIODO=:PERIODO, LICENCIA=:LICENCIA, FECHANOVEDAD=TO_DATE(:FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS'), FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), ANO=:ANO, MES=:MES, DIAS=:DIAS, VALOR=:VALOR, TIPOACTO=:TIPOACTO, NUMERO_ACTO=:NUMERO_ACTO, FECHA_ACTO=TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), OBSERVACION_L=:OBSERVACION_L, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE LICENCIAS.COMPANIA= :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO= :KEY_NUMERO_ACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="FECHANOVEDAD" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="NUMERO_ACTO" sqlType="STRING"/>
		<param name="FECHA_ACTO" sqlType="STRING"/>
		<param name="OBSERVACION_L" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="licencias/actlicenciassinremun">
		<call-query href="updateLicenciasActLicenciasSinRemun">
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="FECHANOVEDAD" query-param="FECHANOVEDAD"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TIPOACTO" query-param="TIPOACTO"/>
			<with-param name="NUMERO_ACTO" query-param="NUMERO_ACTO"/>
			<with-param name="FECHA_ACTO" query-param="FECHA_ACTO"/>
			<with-param name="OBSERVACION_L" query-param="OBSERVACION_L"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_NUMERO_ACTO" query-param="KEY_NUMERO_ACTO"/>

		</call-query>
	</resource>
	<query id="getLicenciasSelLicenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_TIPOACTO_SANCIONES.CODIGO, NAT_TIPOACTO_SANCIONES.NOMBRE, LICENCIAS.LICENCIA,(TO_CHAR(LICENCIAS.FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS')) FECHANOVEDAD,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, LICENCIAS.ANO, LICENCIAS.MES, LICENCIAS.DIAS, LICENCIAS.VALOR, LICENCIAS.TIPOACTO, LICENCIAS.NUMERO_ACTO,(TO_CHAR(LICENCIAS.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, LICENCIAS.OBSERVACION_L, LICENCIAS.PERIODO, LICENCIAS.CREATED_BY,(TO_CHAR(LICENCIAS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, LICENCIAS.MODIFIED_BY,(TO_CHAR(LICENCIAS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM LICENCIAS INNER JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA LEFT JOIN NAT_TIPOACTO_SANCIONES ON LICENCIAS.TIPOACTO = NAT_TIPOACTO_SANCIONES.CODIGO WHERE LICENCIAS.COMPANIA = :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO = :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO = :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO = :KEY_NUMERO_ACTO ORDER BY LICENCIAS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","LICENCIA":"$LICENCIA","FECHANOVEDAD":"$FECHANOVEDAD","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","DIAS":"$DIAS","VALOR":"$VALOR","TIPOACTO":"$TIPOACTO(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO","FECHA_ACTO":"$FECHA_ACTO","OBSERVACION_L":"$OBSERVACION_L","PERIODO":"$PERIODO(type:integer)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="licencias/sellicencia">
		<call-query href="getLicenciasSelLicenciaQuery">
