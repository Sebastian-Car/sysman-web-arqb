	<query id="getLicenciasHojasDeVidaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LICENCIAS.COMPANIA, LICENCIAS.LICENCIA, LICENCIAS.ANO, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.DIAS,(TO_CHAR(LICENCIAS.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS')) FECHANOVEDAD, LICENCIAS.MES, LICENCIAS.NUMERO_ACTO, LICENCIAS.PERIODO, LICENCIAS.TIPOACTO, LICENCIAS.VALOR, LICENCIAS.OBSERVACION_L, TIPOS_LICENCIA.DESCRIPCION NOM_LICENCIA, PERIODOS.NOM_PERIODO, NAT_TIPOACTO_SANCIONES.NOMBRE NOM_TIPOACTO,(TO_CHAR(LICENCIAS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(LICENCIAS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, LICENCIAS.CREATED_BY, LICENCIAS.MODIFIED_BY  FROM LICENCIAS LEFT JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA LEFT JOIN PERIODOS ON LICENCIAS.COMPANIA = PERIODOS.COMPANIA AND LICENCIAS.ID_DE_PROCESO = PERIODOS.ID_DE_PROCESO AND LICENCIAS.ANO = PERIODOS.ANO AND LICENCIAS.MES = PERIODOS.MES AND LICENCIAS.PERIODO = PERIODOS.PERIODO LEFT JOIN NAT_TIPOACTO_SANCIONES ON LICENCIAS.TIPOACTO = NAT_TIPOACTO_SANCIONES.CODIGO WHERE LICENCIAS.COMPANIA = :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO = :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO = :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO = :KEY_NUMERO_ACTO ORDER BY LICENCIAS.FECHA_ACTO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","LICENCIA":"$LICENCIA","ANO":"$ANO(type:integer)","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","DIAS":"$DIAS","FECHA_ACTO":"$FECHA_ACTO","FECHA_FINAL":"$FECHA_FINAL","FECHA_INICIO":"$FECHA_INICIO","FECHANOVEDAD":"$FECHANOVEDAD","MES":"$MES(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO","PERIODO":"$PERIODO(type:integer)","TIPOACTO":"$TIPOACTO(type:integer)","VALOR":"$VALOR","OBSERVACION_L":"$OBSERVACION_L","NOM_LICENCIA":"$NOM_LICENCIA","NOM_PERIODO":"$NOM_PERIODO","NOM_TIPOACTO":"$NOM_TIPOACTO","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="licencias/hojasdevida">
		<call-query href="getLicenciasHojasDeVidaQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_NUMERO_ACTO" query-param="KEY_NUMERO_ACTO"/>

		</call-query>
	</resource>
	<query id="deleteLicenciasHojasDeVida" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM LICENCIAS WHERE COMPANIA = :KEY_COMPANIA AND ID_DE_EMPLEADO = :KEY_ID_DE_EMPLEADO AND ID_DE_PROCESO  = :KEY_ID_DE_PROCESO AND NUMERO_ACTO     = :KEY_NUMERO_ACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="licencias/hojasdevida">
		<call-query href="deleteLicenciasHojasDeVida">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_NUMERO_ACTO" query-param="KEY_NUMERO_ACTO"/>

		</call-query>
	</resource>
	<query id="getLicenciasPagLicenciasnoremuneradasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE COMPANIA = :COMPANIA AND TIPOS_LICENCIA.REMUNERACION IN (0)) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="licencias/licenciasnoremuneradas/pag">
		<call-query href="getLicenciasPagLicenciasnoremuneradasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getLicenciasNumLicenciasnoremuneradasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE COMPANIA = :COMPANIA AND TIPOS_LICENCIA.REMUNERACION IN (0)) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="licencias/licenciasnoremuneradas/num">
		<call-query href="getLicenciasNumLicenciasnoremuneradasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getLicenciasPagSancionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOS_LICENCIA.DESCRIPCION, LICENCIAS.ANO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(LICENCIAS.MES) MES,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO  FROM LICENCIAS INNER JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA LEFT JOIN NAT_TIPOACTO_SANCIONES ON LICENCIAS.TIPOACTO = NAT_TIPOACTO_SANCIONES.CODIGO WHERE LICENCIAS.COMPANIA = :COMPANIA AND LICENCIAS.TIPOACTO IN (1) AND LICENCIAS.ID_DE_EMPLEADO = :ID_DE_EMPLEADO ORDER BY LICENCIAS.ANO DESC) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION":"$DESCRIPCION","ANO":"$ANO(type:integer)","MES":"$MES","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

