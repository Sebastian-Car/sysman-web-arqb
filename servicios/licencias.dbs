	<query id="insertLicenciasHojasDeVida" keyColumns="COMPANIA,ID_DE_PROCESO,ID_DE_EMPLEADO,NUMERO_ACTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO LICENCIAS (COMPANIA, LICENCIA, ID_DE_PROCESO, ID_DE_EMPLEADO, ANO, DIAS, FECHA_ACTO, FECHA_FINAL, FECHA_INICIO, FECHANOVEDAD, MES, NUMERO_ACTO, PERIODO, TIPOACTO, VALOR, OBSERVACION_L, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :LICENCIA, :ID_DE_PROCESO, :ID_DE_EMPLEADO, :ANO, :DIAS, TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS'), :MES, :NUMERO_ACTO, :PERIODO, :TIPOACTO, :VALOR, :OBSERVACION_L, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_NUMERO_ACTO":"$NUMERO_ACTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param defaultValue="1" name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ACTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHANOVEDAD" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NUMERO_ACTO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param defaultValue="99" name="TIPOACTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION_L" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
