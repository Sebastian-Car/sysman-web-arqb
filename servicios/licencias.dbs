			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_NUMERO_ACTO" query-param="KEY_NUMERO_ACTO"/>

		</call-query>
	</resource>
	<query id="getLicenciasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO, TIPOS_LICENCIA.DESCRIPCION, LICENCIAS.ANO, TRIM(PCK_SYSMAN_UTL.FC_NOMBRE_MES(LICENCIAS.MES)) MES, PERIODOS.NOM_PERIODO PERIODO, TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY') FECHA_INICIO, TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY') FECHA_FINAL, LICENCIAS.DIAS FROM LICENCIAS LEFT JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA=TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA=TIPOS_LICENCIA.LICENCIA INNER JOIN PERIODOS ON LICENCIAS.COMPANIA =PERIODOS.COMPANIA AND LICENCIAS.ID_DE_PROCESO =PERIODOS.ID_DE_PROCESO AND LICENCIAS.ANO =PERIODOS.ANO AND LICENCIAS.MES =PERIODOS.MES AND LICENCIAS.PERIODO =PERIODOS.PERIODO WHERE LICENCIAS.COMPANIA = :COMPANIA AND LICENCIAS.ID_DE_EMPLEADO= :ID_DE_EMPLEADO ORDER BY LICENCIAS.ANO DESC, LICENCIAS.MES DESC, LICENCIAS.PERIODO DESC) INI WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(:FECHA_INICIO, '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(:FECHA_FINAL, '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(:DIAS, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO","DESCRIPCION":"$DESCRIPCION","ANO":"$ANO(type:integer)","MES":"$MES","PERIODO":"$PERIODO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","DIAS":"$DIAS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="licencias">
		<call-query href="getLicenciasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getLicenciasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO, TIPOS_LICENCIA.DESCRIPCION, LICENCIAS.ANO, TRIM(PCK_SYSMAN_UTL.FC_NOMBRE_MES(LICENCIAS.MES)) MES, PERIODOS.NOM_PERIODO PERIODO, TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY') FECHA_INICIO, TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY') FECHA_FINAL, LICENCIAS.DIAS FROM LICENCIAS LEFT JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA=TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA=TIPOS_LICENCIA.LICENCIA INNER JOIN PERIODOS ON LICENCIAS.COMPANIA =PERIODOS.COMPANIA AND LICENCIAS.ID_DE_PROCESO =PERIODOS.ID_DE_PROCESO AND LICENCIAS.ANO =PERIODOS.ANO AND LICENCIAS.MES =PERIODOS.MES AND LICENCIAS.PERIODO =PERIODOS.PERIODO WHERE LICENCIAS.COMPANIA = :COMPANIA AND LICENCIAS.ID_DE_EMPLEADO= :ID_DE_EMPLEADO ORDER BY LICENCIAS.ANO DESC, LICENCIAS.MES DESC, LICENCIAS.PERIODO DESC) INI WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(:FECHA_INICIO, '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(:FECHA_FINAL, '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(:DIAS, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>

	</query>
