	</resource>
	<query id="insertLicencias" keyColumns="COMPANIA,ID_DE_PROCESO,ID_DE_EMPLEADO,NUMERO_ACTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO LICENCIAS (COMPANIA, ID_DE_PROCESO, ID_DE_EMPLEADO, NUMERO_ACTO, LICENCIA, FECHA_INICIO, FECHA_FINAL, FECHA_ACTO, ANO, MES, PERIODO, DIAS, OBSERVACION_L, TIPOACTO, VALOR, FECHANOVEDAD, NUMEROPERIODO, DIAS_INICIALES, LICENCIA_REMUNERADA, FECHA_INICIO_REAL, FECHA_FINAL_REAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_PROCESO, :ID_DE_EMPLEADO, :NUMERO_ACTO, :LICENCIA, TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), :ANO, :MES, :PERIODO, :DIAS, :OBSERVACION_L, :TIPOACTO, :VALOR, TO_DATE(:FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS'), :NUMEROPERIODO, :DIAS_INICIALES, :LICENCIA_REMUNERADA, TO_DATE(:FECHA_INICIO_REAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL_REAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_NUMERO_ACTO":"$NUMERO_ACTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="1" name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_ACTO" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ACTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION_L" sqlType="STRING"/>
		<param defaultValue="99" name="TIPOACTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="FECHANOVEDAD" sqlType="STRING"/>
		<param defaultValue="" name="NUMEROPERIODO" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS_INICIALES" sqlType="STRING"/>
		<param defaultValue="" name="LICENCIA_REMUNERADA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO_REAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL_REAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
