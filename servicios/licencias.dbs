	<query id="deleteLicencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM LICENCIAS WHERE LICENCIAS.COMPANIA= :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO= :KEY_NUMERO_ACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

