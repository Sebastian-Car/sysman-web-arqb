	<query id="getLicenciasPagNoremuneradasporempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, TO_CHAR(LICENCIAS.FECHA_INICIO, 'DD/MM/YYYY') FECHA_INICIO, TO_CHAR(LICENCIAS.FECHA_FINAL, 'DD/MM/YYYY') FECHA_FINAL, LICENCIAS.ANO, NAT_TIPOACTO_SANCIONES.NOMBRE, LICENCIAS.NUMERO_ACTO, TIPOS_LICENCIA.DESCRIPCION  FROM LICENCIAS LEFT JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA INNER JOIN NAT_TIPOACTO_SANCIONES ON LICENCIAS.TIPOACTO = NAT_TIPOACTO_SANCIONES.CODIGO WHERE LICENCIAS.COMPANIA = :COMPANIA AND LICENCIAS.ID_DE_EMPLEADO = :EMPLEADO AND TIPOS_LICENCIA.REMUNERACION NOT IN (0)) WHERE (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NUMERO_ACTO IS NULL THEN ' ' ELSE UPPER(NUMERO_ACTO) END)  LIKE UPPER( '%' || :NUMERO_ACTO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","ANO":"$ANO(type:integer)","NOMBRE":"$NOMBRE","NUMERO_ACTO":"$NUMERO_ACTO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
