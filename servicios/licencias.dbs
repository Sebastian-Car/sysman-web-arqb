	<query id="getLicenciasNumHojasDeVidaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO, LICENCIAS.LICENCIA,(TO_CHAR(LICENCIAS.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, LICENCIAS.MES, LICENCIAS.VALOR, TIPOS_LICENCIA.DESCRIPCION  FROM LICENCIAS LEFT JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA WHERE LICENCIAS.COMPANIA = :KEY_COMPANIA AND ID_DE_EMPLEADO = :KEY_ID_DE_EMPLEADO AND TIPOS_LICENCIA.REMUNERACION IN (0) ORDER BY LICENCIAS.FECHA_ACTO DESC) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN FECHA_ACTO IS NULL THEN ' ' ELSE UPPER(FECHA_ACTO) END)  LIKE UPPER( '%' || :FECHA_ACTO || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="FECHA_ACTO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="licencias/hojasdevida/num">
		<call-query href="getLicenciasNumHojasDeVidaQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
