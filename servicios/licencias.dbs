<data name="licencias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getLicenciasPagPorCompaniaYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOS_LICENCIA.DESCRIPCION, LICENCIAS.ANO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(LICENCIAS.MES) MES,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO  FROM LICENCIAS INNER JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA WHERE LICENCIAS.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.REMUNERACION IN (:REMUNERACION) AND LICENCIAS.ID_DE_EMPLEADO = :ID_DE_EMPLEADO AND LICENCIAS.TIPOACTO NOT IN (1) ORDER BY LICENCIAS.ANO DESC) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION":"$DESCRIPCION","ANO":"$ANO(type:integer)","MES":"$MES","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="REMUNERACION" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="licencias/porcompaniaytipo/pag">
		<call-query href="getLicenciasPagPorCompaniaYTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getLicenciasNumPorCompaniaYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOS_LICENCIA.DESCRIPCION, LICENCIAS.ANO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(LICENCIAS.MES) MES,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO  FROM LICENCIAS INNER JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA WHERE LICENCIAS.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.REMUNERACION IN (:REMUNERACION) AND LICENCIAS.ID_DE_EMPLEADO = :ID_DE_EMPLEADO AND LICENCIAS.TIPOACTO NOT IN (1) ORDER BY LICENCIAS.ANO DESC) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="REMUNERACION" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="licencias/porcompaniaytipo/num">
		<call-query href="getLicenciasNumPorCompaniaYTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>

		</call-query>
	</resource>
	<query id="getLicenciasPorCompaniaYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOS_LICENCIA.DESCRIPCION NOM_LICENCIA, NAT_TIPOACTO_SANCIONES.CODIGO, NAT_TIPOACTO_SANCIONES.NOMBRE, LICENCIAS.LICENCIA,(TO_CHAR(LICENCIAS.FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS')) FECHANOVEDAD,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, LICENCIAS.ANO, LICENCIAS.MES, LICENCIAS.DIAS, LICENCIAS.VALOR, LICENCIAS.TIPOACTO, LICENCIAS.NUMERO_ACTO,(TO_CHAR(LICENCIAS.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, LICENCIAS.OBSERVACION_L, LICENCIAS.PERIODO, LICENCIAS.CREATED_BY,(TO_CHAR(LICENCIAS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, LICENCIAS.MODIFIED_BY,(TO_CHAR(LICENCIAS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM LICENCIAS INNER JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA LEFT JOIN NAT_TIPOACTO_SANCIONES ON LICENCIAS.TIPOACTO = NAT_TIPOACTO_SANCIONES.CODIGO WHERE LICENCIAS.COMPANIA = :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO = :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO = :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO = :KEY_NUMERO_ACTO ORDER BY LICENCIAS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOM_LICENCIA":"$NOM_LICENCIA","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","LICENCIA":"$LICENCIA","FECHANOVEDAD":"$FECHANOVEDAD","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","DIAS":"$DIAS","VALOR":"$VALOR","TIPOACTO":"$TIPOACTO(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO","FECHA_ACTO":"$FECHA_ACTO","OBSERVACION_L":"$OBSERVACION_L","PERIODO":"$PERIODO(type:integer)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="licencias/porcompaniaytipo">
		<call-query href="getLicenciasPorCompaniaYTipoQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_NUMERO_ACTO" query-param="KEY_NUMERO_ACTO"/>

		</call-query>
	</resource>
	<query id="insertLicenciasPorCompaniaYTipo" keyColumns="COMPANIA,ID_DE_PROCESO,ID_DE_EMPLEADO,NUMERO_ACTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO LICENCIAS (PERIODO, ID_DE_EMPLEADO, COMPANIA, LICENCIA, FECHANOVEDAD, FECHA_INICIO, FECHA_FINAL, ANO, MES, DIAS, VALOR, TIPOACTO, NUMERO_ACTO, FECHA_ACTO, OBSERVACION_L, ID_DE_PROCESO, DATE_CREATED, CREATED_BY) VALUES (:PERIODO, :ID_DE_EMPLEADO, :COMPANIA, :LICENCIA, TO_DATE(:FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), :ANO, :MES, :DIAS, :VALOR, :TIPOACTO, :NUMERO_ACTO, TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACION_L, :ID_DE_PROCESO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_NUMERO_ACTO":"$NUMERO_ACTO"}]}}		</result>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param defaultValue="" name="FECHANOVEDAD" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="99" name="TIPOACTO" sqlType="STRING"/>
		<param name="NUMERO_ACTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ACTO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION_L" sqlType="STRING"/>
		<param defaultValue="1" name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="licencias/porcompaniaytipo">
		<call-query href="insertLicenciasPorCompaniaYTipo">
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
