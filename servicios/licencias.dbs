	<query id="getLicenciasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT LICENCIAS.COMPANIA, LICENCIAS.ID_DE_PROCESO, LICENCIAS.ID_DE_EMPLEADO, LICENCIAS.NUMERO_ACTO, LICENCIAS.LICENCIA,(TO_CHAR(LICENCIAS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(LICENCIAS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(LICENCIAS.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, LICENCIAS.ANO, LICENCIAS.MES, LICENCIAS.PERIODO, LICENCIAS.DIAS, LICENCIAS.OBSERVACION_L, LICENCIAS.TIPOACTO, LICENCIAS.VALOR,(TO_CHAR(LICENCIAS.FECHANOVEDAD,'DD/MM/YYYY HH24:MI:SS')) FECHANOVEDAD, LICENCIAS.NUMEROPERIODO, LICENCIAS.CREATED_BY,(TO_CHAR(LICENCIAS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, LICENCIAS.MODIFIED_BY,(TO_CHAR(LICENCIAS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, LICENCIAS.DIAS_INICIALES, TIPOS_LICENCIA.DESCRIPCION, LICENCIAS.LICENCIA_REMUNERADA,(TO_CHAR(FECHA_INICIO_REAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_REAL,(TO_CHAR(FECHA_FINAL_REAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_REAL FROM LICENCIAS INNER JOIN TIPOS_LICENCIA ON LICENCIAS.COMPANIA = TIPOS_LICENCIA.COMPANIA AND LICENCIAS.LICENCIA = TIPOS_LICENCIA.LICENCIA WHERE LICENCIAS.COMPANIA= :KEY_COMPANIA AND LICENCIAS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND LICENCIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND LICENCIAS.NUMERO_ACTO= :KEY_NUMERO_ACTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_ACTO":"$NUMERO_ACTO","LICENCIA":"$LICENCIA","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","FECHA_ACTO":"$FECHA_ACTO","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","DIAS":"$DIAS","OBSERVACION_L":"$OBSERVACION_L","TIPOACTO":"$TIPOACTO(type:integer)","VALOR":"$VALOR","FECHANOVEDAD":"$FECHANOVEDAD","NUMEROPERIODO":"$NUMEROPERIODO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DIAS_INICIALES":"$DIAS_INICIALES","DESCRIPCION":"$DESCRIPCION","LICENCIA_REMUNERADA":"$LICENCIA_REMUNERADA","FECHA_INICIO_REAL":"$FECHA_INICIO_REAL","FECHA_FINAL_REAL":"$FECHA_FINAL_REAL"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ACTO" sqlType="STRING"/>

	</query>
