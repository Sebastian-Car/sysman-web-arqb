<data name="desicionrecurso" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDesicionrecursoExistedesicionrecursoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) EXISTE  FROM DESICIONRECURSO WHERE DESICIONRECURSO.COMPANIA= :KEY_COMPANIA AND DESICIONRECURSO.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND DESICIONRECURSO.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND DESICIONRECURSO.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND DESICIONRECURSO.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND DESICIONRECURSO.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND DESICIONRECURSO.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND DESICIONRECURSO.SUCURSAL_EVALUADOR= :KEY_SUCURSAL_EVALUADOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="desicionrecurso/existedesicionrecurso">
		<call-query href="getDesicionrecursoExistedesicionrecursoQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_CEDULA_EVALUADOR" query-param="KEY_CEDULA_EVALUADOR"/>
			<with-param name="KEY_SUCURSAL_EVALUADOR" query-param="KEY_SUCURSAL_EVALUADOR"/>

		</call-query>
	</resource>
	<query id="insertDesicionrecurso" keyColumns="COMPANIA,NUMERO_EVALUACION,CLASE_EVALUACION,TIPO_EVALUACION,CEDULA_EVALUADO,SUCURSAL_EVALUADO,CEDULA_EVALUADOR,SUCURSAL_EVALUADOR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DESICIONRECURSO (COMPANIA, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, REPOSICION, DESICIONREPOSICION, FECHAREPOSICION, MOTIVACIONREPOSIC, APELACION, DESICIONREAPELACI, FECHAAPELACION, MOTIVACIONAPELAC, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NUMERO_EVALUACION, :CLASE_EVALUACION, :TIPO_EVALUACION, :CEDULA_EVALUADO, :SUCURSAL_EVALUADO, :CEDULA_EVALUADOR, :SUCURSAL_EVALUADOR, :REPOSICION, :DESICIONREPOSICION, TO_DATE(:FECHAREPOSICION,'DD/MM/YYYY HH24:MI:SS'), :MOTIVACIONREPOSIC, :APELACION, :DESICIONREAPELACI, TO_DATE(:FECHAAPELACION,'DD/MM/YYYY HH24:MI:SS'), :MOTIVACIONAPELAC, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","KEY_TIPO_EVALUACION":"$TIPO_EVALUACION","KEY_CEDULA_EVALUADO":"$CEDULA_EVALUADO","KEY_SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","KEY_CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","KEY_SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="0" name="REPOSICION" sqlType="STRING"/>
		<param defaultValue="" name="DESICIONREPOSICION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAREPOSICION" sqlType="STRING"/>
		<param defaultValue="" name="MOTIVACIONREPOSIC" sqlType="STRING"/>
		<param defaultValue="0" name="APELACION" sqlType="STRING"/>
		<param defaultValue="" name="DESICIONREAPELACI" sqlType="STRING"/>
		<param defaultValue="" name="FECHAAPELACION" sqlType="STRING"/>
		<param defaultValue="" name="MOTIVACIONAPELAC" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="desicionrecurso">
		<call-query href="insertDesicionrecurso">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_EVALUACION" query-param="NUMERO_EVALUACION"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="SUCURSAL_EVALUADOR" query-param="SUCURSAL_EVALUADOR"/>
			<with-param name="REPOSICION" query-param="REPOSICION"/>
			<with-param name="DESICIONREPOSICION" query-param="DESICIONREPOSICION"/>
			<with-param name="FECHAREPOSICION" query-param="FECHAREPOSICION"/>
			<with-param name="MOTIVACIONREPOSIC" query-param="MOTIVACIONREPOSIC"/>
			<with-param name="APELACION" query-param="APELACION"/>
			<with-param name="DESICIONREAPELACI" query-param="DESICIONREAPELACI"/>
			<with-param name="FECHAAPELACION" query-param="FECHAAPELACION"/>
			<with-param name="MOTIVACIONAPELAC" query-param="MOTIVACIONAPELAC"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteDesicionrecurso" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DESICIONRECURSO WHERE DESICIONRECURSO.COMPANIA= :KEY_COMPANIA AND DESICIONRECURSO.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND DESICIONRECURSO.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND DESICIONRECURSO.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND DESICIONRECURSO.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND DESICIONRECURSO.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND DESICIONRECURSO.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND DESICIONRECURSO.SUCURSAL_EVALUADOR= :KEY_SUCURSAL_EVALUADOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="INTEGER"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADOR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="desicionrecurso">
		<call-query href="deleteDesicionrecurso">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_CEDULA_EVALUADOR" query-param="KEY_CEDULA_EVALUADOR"/>
			<with-param name="KEY_SUCURSAL_EVALUADOR" query-param="KEY_SUCURSAL_EVALUADOR"/>

		</call-query>
	</resource>
	<query id="getDesicionrecursoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA ,NUMERO_EVALUACION ,CLASE_EVALUACION ,TIPO_EVALUACION ,CEDULA_EVALUADO ,SUCURSAL_EVALUADO ,CEDULA_EVALUADOR ,SUCURSAL_EVALUADOR ,(CASE REPOSICION WHEN 0 THEN 'false' ELSE 'true' END) REPOSICION,DESICIONREPOSICION ,(TO_CHAR(FECHAREPOSICION,'DD/MM/YYYY HH24:MI:SS')) FECHAREPOSICION,MOTIVACIONREPOSIC ,(CASE APELACION WHEN 0 THEN 'false' ELSE 'true' END) APELACION, DESICIONREAPELACI ,(TO_CHAR(FECHAAPELACION,'DD/MM/YYYY HH24:MI:SS')) FECHAAPELACION, MOTIVACIONAPELAC ,CREATED_BY ,MODIFIED_BY ,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM DESICIONRECURSO WHERE DESICIONRECURSO.COMPANIA= :KEY_COMPANIA AND DESICIONRECURSO.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND DESICIONRECURSO.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND DESICIONRECURSO.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND DESICIONRECURSO.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND DESICIONRECURSO.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND DESICIONRECURSO.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND DESICIONRECURSO.SUCURSAL_EVALUADOR= :KEY_SUCURSAL_EVALUADOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR","REPOSICION":"$REPOSICION(type:boolean)","DESICIONREPOSICION":"$DESICIONREPOSICION","FECHAREPOSICION":"$FECHAREPOSICION","MOTIVACIONREPOSIC":"$MOTIVACIONREPOSIC","APELACION":"$APELACION(type:boolean)","DESICIONREAPELACI":"$DESICIONREAPELACI","FECHAAPELACION":"$FECHAAPELACION","MOTIVACIONAPELAC":"$MOTIVACIONAPELAC","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="desicionrecurso/data">
		<call-query href="getDesicionrecursoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_CEDULA_EVALUADOR" query-param="KEY_CEDULA_EVALUADOR"/>
			<with-param name="KEY_SUCURSAL_EVALUADOR" query-param="KEY_SUCURSAL_EVALUADOR"/>

		</call-query>
	</resource>
	<query id="updateDesicionrecurso" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DESICIONRECURSO SET COMPANIA=:COMPANIA, NUMERO_EVALUACION=:NUMERO_EVALUACION, CLASE_EVALUACION=:CLASE_EVALUACION, TIPO_EVALUACION=:TIPO_EVALUACION, CEDULA_EVALUADO=:CEDULA_EVALUADO, SUCURSAL_EVALUADO=:SUCURSAL_EVALUADO, CEDULA_EVALUADOR=:CEDULA_EVALUADOR, SUCURSAL_EVALUADOR=:SUCURSAL_EVALUADOR, REPOSICION=:REPOSICION, DESICIONREPOSICION=:DESICIONREPOSICION, FECHAREPOSICION=TO_DATE(:FECHAREPOSICION,'DD/MM/YYYY HH24:MI:SS'), MOTIVACIONREPOSIC=:MOTIVACIONREPOSIC, APELACION=:APELACION, DESICIONREAPELACI=:DESICIONREAPELACI, FECHAAPELACION=TO_DATE(:FECHAAPELACION,'DD/MM/YYYY HH24:MI:SS'), MOTIVACIONAPELAC=:MOTIVACIONAPELAC, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE DESICIONRECURSO.COMPANIA= :KEY_COMPANIA AND DESICIONRECURSO.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND DESICIONRECURSO.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND DESICIONRECURSO.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND DESICIONRECURSO.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND DESICIONRECURSO.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND DESICIONRECURSO.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND DESICIONRECURSO.SUCURSAL_EVALUADOR= :KEY_SUCURSAL_EVALUADOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="REPOSICION" sqlType="STRING"/>
		<param name="DESICIONREPOSICION" sqlType="STRING"/>
		<param name="FECHAREPOSICION" sqlType="STRING"/>
		<param name="MOTIVACIONREPOSIC" sqlType="STRING"/>
		<param name="APELACION" sqlType="STRING"/>
		<param name="DESICIONREAPELACI" sqlType="STRING"/>
		<param name="FECHAAPELACION" sqlType="STRING"/>
		<param name="MOTIVACIONAPELAC" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADOR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="desicionrecurso">
		<call-query href="updateDesicionrecurso">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_EVALUACION" query-param="NUMERO_EVALUACION"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="SUCURSAL_EVALUADOR" query-param="SUCURSAL_EVALUADOR"/>
			<with-param name="REPOSICION" query-param="REPOSICION"/>
			<with-param name="DESICIONREPOSICION" query-param="DESICIONREPOSICION"/>
			<with-param name="FECHAREPOSICION" query-param="FECHAREPOSICION"/>
			<with-param name="MOTIVACIONREPOSIC" query-param="MOTIVACIONREPOSIC"/>
			<with-param name="APELACION" query-param="APELACION"/>
			<with-param name="DESICIONREAPELACI" query-param="DESICIONREAPELACI"/>
			<with-param name="FECHAAPELACION" query-param="FECHAAPELACION"/>
			<with-param name="MOTIVACIONAPELAC" query-param="MOTIVACIONAPELAC"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_CEDULA_EVALUADOR" query-param="KEY_CEDULA_EVALUADOR"/>
			<with-param name="KEY_SUCURSAL_EVALUADOR" query-param="KEY_SUCURSAL_EVALUADOR"/>

		</call-query>
	</resource>

</data>