<data name="sprespuestamodeloplantilla" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSprespuestamodeloplantilla" keyColumns="COMPANIA,CLASE,SUBCLASE,CODIGO,CONSECUTIVOCLASE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_RESPUESTA_MODELO_PLANTILLA (COMPANIA, CLASE, SUBCLASE, CODIGO, CONSECUTIVOCLASE, RESPUESTA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASE, :SUBCLASE, :CODIGO, :CONSECUTIVOCLASE, :RESPUESTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASE":"$CLASE","KEY_SUBCLASE":"$SUBCLASE(type:integer)","KEY_CODIGO":"$CODIGO(type:integer)","KEY_CONSECUTIVOCLASE":"$CONSECUTIVOCLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="SUBCLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVOCLASE" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sprespuestamodeloplantilla">
		<call-query href="insertSprespuestamodeloplantilla">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="SUBCLASE" query-param="SUBCLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONSECUTIVOCLASE" query-param="CONSECUTIVOCLASE"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSprespuestamodeloplantilla" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_RESPUESTA_MODELO_PLANTILLA WHERE SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA= :KEY_COMPANIA AND SP_RESPUESTA_MODELO_PLANTILLA.CLASE= :KEY_CLASE AND SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE= :KEY_SUBCLASE AND SP_RESPUESTA_MODELO_PLANTILLA.CODIGO= :KEY_CODIGO AND SP_RESPUESTA_MODELO_PLANTILLA.CONSECUTIVOCLASE= :KEY_CONSECUTIVOCLASE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>
		<param name="KEY_SUBCLASE" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVOCLASE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sprespuestamodeloplantilla">
		<call-query href="deleteSprespuestamodeloplantilla">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASE" query-param="KEY_CLASE"/>
			<with-param name="KEY_SUBCLASE" query-param="KEY_SUBCLASE"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CONSECUTIVOCLASE" query-param="KEY_CONSECUTIVOCLASE"/>

		</call-query>
	</resource>
	<query id="getSprespuestamodeloplantillaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA, SP_RESPUESTA_MODELO_PLANTILLA.CLASE, SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE, SP_RESPUESTA_MODELO_PLANTILLA.CODIGO, SP_RESPUESTA_MODELO_PLANTILLA.CONSECUTIVOCLASE, SP_CARTA_VAR.PREGUNTA , SP_RESPUESTA_MODELO_PLANTILLA.RESPUESTA  FROM SP_RESPUESTA_MODELO_PLANTILLA INNER JOIN SP_CARTA_VAR ON SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA = SP_CARTA_VAR.COMPANIA AND SP_RESPUESTA_MODELO_PLANTILLA.CLASE = SP_CARTA_VAR.CLASE AND SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE = SP_CARTA_VAR.SUBCLASE AND SP_RESPUESTA_MODELO_PLANTILLA.CODIGO = SP_CARTA_VAR.CODIGO WHERE SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA = :COMPANIA AND SP_RESPUESTA_MODELO_PLANTILLA.CLASE = :CLASE AND SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE = :SUBCLASE AND SP_RESPUESTA_MODELO_PLANTILLA.CONSECUTIVOCLASE = :CONSECUTIVO) WHERE (CASE WHEN PREGUNTA IS NULL THEN ' ' ELSE UPPER(PREGUNTA) END)  LIKE UPPER( '%' || :PREGUNTA || '%')  AND (CASE WHEN RESPUESTA IS NULL THEN ' ' ELSE UPPER(RESPUESTA) END)  LIKE UPPER( '%' || :RESPUESTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASE":"$CLASE","SUBCLASE":"$SUBCLASE(type:integer)","CODIGO":"$CODIGO(type:integer)","CONSECUTIVOCLASE":"$CONSECUTIVOCLASE","PREGUNTA":"$PREGUNTA","RESPUESTA":"$RESPUESTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="SUBCLASE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PREGUNTA" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sprespuestamodeloplantilla">
		<call-query href="getSprespuestamodeloplantillaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="SUBCLASE" query-param="SUBCLASE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PREGUNTA" query-param="PREGUNTA"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSprespuestamodeloplantillaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA, SP_RESPUESTA_MODELO_PLANTILLA.CLASE, SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE, SP_RESPUESTA_MODELO_PLANTILLA.CODIGO, SP_RESPUESTA_MODELO_PLANTILLA.CONSECUTIVOCLASE, SP_CARTA_VAR.PREGUNTA , SP_RESPUESTA_MODELO_PLANTILLA.RESPUESTA  FROM SP_RESPUESTA_MODELO_PLANTILLA INNER JOIN SP_CARTA_VAR ON SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA = SP_CARTA_VAR.COMPANIA AND SP_RESPUESTA_MODELO_PLANTILLA.CLASE = SP_CARTA_VAR.CLASE AND SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE = SP_CARTA_VAR.SUBCLASE AND SP_RESPUESTA_MODELO_PLANTILLA.CODIGO = SP_CARTA_VAR.CODIGO WHERE SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA = :COMPANIA AND SP_RESPUESTA_MODELO_PLANTILLA.CLASE = :CLASE AND SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE = :SUBCLASE AND SP_RESPUESTA_MODELO_PLANTILLA.CONSECUTIVOCLASE = :CONSECUTIVO) WHERE (CASE WHEN PREGUNTA IS NULL THEN ' ' ELSE UPPER(PREGUNTA) END)  LIKE UPPER( '%' || :PREGUNTA || '%')  AND (CASE WHEN RESPUESTA IS NULL THEN ' ' ELSE UPPER(RESPUESTA) END)  LIKE UPPER( '%' || :RESPUESTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="SUBCLASE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PREGUNTA" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sprespuestamodeloplantilla/numero">
		<call-query href="getSprespuestamodeloplantillaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="SUBCLASE" query-param="SUBCLASE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PREGUNTA" query-param="PREGUNTA"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>

		</call-query>
	</resource>
	<query id="updateSprespuestamodeloplantilla" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_RESPUESTA_MODELO_PLANTILLA SET CODIGO=:CODIGO, RESPUESTA=:RESPUESTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_RESPUESTA_MODELO_PLANTILLA.COMPANIA= :KEY_COMPANIA AND SP_RESPUESTA_MODELO_PLANTILLA.CLASE= :KEY_CLASE AND SP_RESPUESTA_MODELO_PLANTILLA.SUBCLASE= :KEY_SUBCLASE AND SP_RESPUESTA_MODELO_PLANTILLA.CODIGO= :KEY_CODIGO AND SP_RESPUESTA_MODELO_PLANTILLA.CONSECUTIVOCLASE= :KEY_CONSECUTIVOCLASE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>
		<param name="KEY_SUBCLASE" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVOCLASE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sprespuestamodeloplantilla">
		<call-query href="updateSprespuestamodeloplantilla">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASE" query-param="KEY_CLASE"/>
			<with-param name="KEY_SUBCLASE" query-param="KEY_SUBCLASE"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CONSECUTIVOCLASE" query-param="KEY_CONSECUTIVOCLASE"/>

		</call-query>
	</resource>

</data>