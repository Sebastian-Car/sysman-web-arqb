<data name="tipoclasificadoreshijo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoclasificadoreshijoPagHijosporpadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT TCH.IDHIJO, CC.CODIGO CLASFIFICADORHIJO, CC.NOMBRE NOMBREPADRE, TC.CODIGO CODCLASIFICADOR, TC.NOMBRE NOMBREHIJO FROM TIPOCLASIFICADORESHIJO TCH INNER JOIN TIPOCLASIFICADOR TC ON (TCH.IDPADRE = TC.ID) INNER JOIN CLASECLASIFICADOR CC ON (TC.CLASECLASIFICADOR = CC.CODIGO) WHERE TCH.IDPADRE = :IDPADRE AND CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO) INI WHERE (CASE WHEN IDHIJO IS NULL THEN ' ' ELSE UPPER(IDHIJO) END) LIKE UPPER(CONCAT(:IDHIJO, '%')) AND (CASE WHEN CLASFIFICADORHIJO IS NULL THEN ' ' ELSE UPPER(CLASFIFICADORHIJO) END) LIKE UPPER(CONCAT(:CLASFIFICADORHIJO, '%')) AND (CASE WHEN NOMBREPADRE IS NULL THEN ' ' ELSE UPPER(NOMBREPADRE) END) LIKE UPPER(CONCAT(:NOMBREPADRE, '%')) AND (CASE WHEN CODCLASIFICADOR IS NULL THEN ' ' ELSE UPPER(CODCLASIFICADOR) END) LIKE UPPER(CONCAT(:CODCLASIFICADOR, '%')) AND (CASE WHEN NOMBREHIJO IS NULL THEN ' ' ELSE UPPER(NOMBREHIJO) END) LIKE UPPER(CONCAT(:NOMBREHIJO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDHIJO":"$IDHIJO","CLASFIFICADORHIJO":"$CLASFIFICADORHIJO","NOMBREPADRE":"$NOMBREPADRE","CODCLASIFICADOR":"$CODCLASIFICADOR","NOMBREHIJO":"$NOMBREHIJO"}]}}		</result>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="IDHIJO" sqlType="STRING"/>
		<param name="CLASFIFICADORHIJO" sqlType="STRING"/>
		<param name="NOMBREPADRE" sqlType="STRING"/>
		<param name="CODCLASIFICADOR" sqlType="STRING"/>
		<param name="NOMBREHIJO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoclasificadoreshijo/hijosporpadre/pag">
		<call-query href="getTipoclasificadoreshijoPagHijosporpadreQuery">
			<with-param name="IDPADRE" query-param="IDPADRE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="IDHIJO" query-param="IDHIJO"/>
			<with-param name="CLASFIFICADORHIJO" query-param="CLASFIFICADORHIJO"/>
			<with-param name="NOMBREPADRE" query-param="NOMBREPADRE"/>
			<with-param name="CODCLASIFICADOR" query-param="CODCLASIFICADOR"/>
			<with-param name="NOMBREHIJO" query-param="NOMBREHIJO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoNumHijosporpadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT TCH.IDHIJO, CC.CODIGO CLASFIFICADORHIJO, CC.NOMBRE NOMBREPADRE, TC.CODIGO CODCLASIFICADOR, TC.NOMBRE NOMBREHIJO FROM TIPOCLASIFICADORESHIJO TCH INNER JOIN TIPOCLASIFICADOR TC ON (TCH.IDPADRE = TC.ID) INNER JOIN CLASECLASIFICADOR CC ON (TC.CLASECLASIFICADOR = CC.CODIGO) WHERE TCH.IDPADRE = :IDPADRE AND CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO) INI WHERE (CASE WHEN IDHIJO IS NULL THEN ' ' ELSE UPPER(IDHIJO) END) LIKE UPPER(CONCAT(:IDHIJO, '%')) AND (CASE WHEN CLASFIFICADORHIJO IS NULL THEN ' ' ELSE UPPER(CLASFIFICADORHIJO) END) LIKE UPPER(CONCAT(:CLASFIFICADORHIJO, '%')) AND (CASE WHEN NOMBREPADRE IS NULL THEN ' ' ELSE UPPER(NOMBREPADRE) END) LIKE UPPER(CONCAT(:NOMBREPADRE, '%')) AND (CASE WHEN CODCLASIFICADOR IS NULL THEN ' ' ELSE UPPER(CODCLASIFICADOR) END) LIKE UPPER(CONCAT(:CODCLASIFICADOR, '%')) AND (CASE WHEN NOMBREHIJO IS NULL THEN ' ' ELSE UPPER(NOMBREHIJO) END) LIKE UPPER(CONCAT(:NOMBREHIJO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="IDHIJO" sqlType="STRING"/>
		<param name="CLASFIFICADORHIJO" sqlType="STRING"/>
		<param name="NOMBREPADRE" sqlType="STRING"/>
		<param name="CODCLASIFICADOR" sqlType="STRING"/>
		<param name="NOMBREHIJO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificadoreshijo/hijosporpadre/num">
		<call-query href="getTipoclasificadoreshijoNumHijosporpadreQuery">
			<with-param name="IDPADRE" query-param="IDPADRE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="IDHIJO" query-param="IDHIJO"/>
			<with-param name="CLASFIFICADORHIJO" query-param="CLASFIFICADORHIJO"/>
			<with-param name="NOMBREPADRE" query-param="NOMBREPADRE"/>
			<with-param name="CODCLASIFICADOR" query-param="CODCLASIFICADOR"/>
			<with-param name="NOMBREHIJO" query-param="NOMBREHIJO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoHijosdelpadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT TCH.IDHIJO, CC.CODIGO CLASFIFICADORHIJO, CC.NOMBRE NOMBREPADRE, TC.CODIGO CODCLASIFICADOR, TC.NOMBRE NOMBREHIJO FROM TIPOCLASIFICADORESHIJO TCH INNER JOIN TIPOCLASIFICADOR TC ON TCH.COMPANIA = TC.COMPANIA AND TCH.ANO = TC.ANO AND TCH.IDHIJO = TC.ID INNER JOIN CLASECLASIFICADOR CC ON TC.COMPANIA = CC.COMPANIA AND TC.ANO = CC.ANO AND TC.CLASECLASIFICADOR = CC.CODIGO WHERE TCH.IDPADRE = :IDPADRE AND CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDHIJO":"$IDHIJO","CLASFIFICADORHIJO":"$CLASFIFICADORHIJO","NOMBREPADRE":"$NOMBREPADRE","CODCLASIFICADOR":"$CODCLASIFICADOR","NOMBREHIJO":"$NOMBREHIJO"}]}}		</result>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificadoreshijo/hijosdelpadre">
		<call-query href="getTipoclasificadoreshijoHijosdelpadreQuery">
			<with-param name="IDPADRE" query-param="IDPADRE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoTipoclasificadoreshijo/hijosdelpadreporanotodosreporteQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT CC.CODIGO CLASFIFICADORPADRE, CC.NOMBRE NOMBREPADRE, TCH.IDHIJO, TC.CODIGO CODCLASIFICADORHIJO, TC.NOMBRE NOMBREHIJO, TO_CHAR(TCH.DATE_CREATED,'DD/MM/YYYY') FECHA FROM TIPOCLASIFICADORESHIJO TCH INNER JOIN TIPOCLASIFICADOR TC ON (TCH.IDHIJO = TC.ID) INNER JOIN CLASECLASIFICADOR CC ON (TC.CLASECLASIFICADOR = CC.CODIGO) WHERE CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO AND TCH.DATE_CREATED BETWEEN TO_DATE(:FECHA_INICIAL) AND TO_DATE(:FECHA_FINAL) ORDER BY 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASFIFICADORPADRE":"$CLASFIFICADORPADRE","NOMBREPADRE":"$NOMBREPADRE","IDHIJO":"$IDHIJO","CODCLASIFICADORHIJO":"$CODCLASIFICADORHIJO","NOMBREHIJO":"$NOMBREHIJO","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificadoreshijo/tipoclasificadoreshijo/hijosdelpadreporanotodosreporte">
		<call-query href="getTipoclasificadoreshijoTipoclasificadoreshijo/hijosdelpadreporanotodosreporteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoGetreporteconfigclasificadosplanQuery"  useConfig="sysmandsunist">
		<sql>SELECT ini.ano, ini.codigo rubro, ini.naturaleza, CASE WHEN ini.regalias = 0 THEN 'No' ELSE 'Sí' END esregalias, ini.tipovigencia, ini.vigencia, ini.vigencia_gasto, nvl(nvl(sector_man, sector_pad),0) sector, nvl(sector.nombre,'N/A') sector_nombre, nvl(nvl(programa_man, programa_pad),0) programa, nvl(programa.nombre,'N/A') programa_nombre, nvl(nvl(subprograma_man, subprograma_pad),0) subprograma, nvl(subprograma.nombre,'N/A') subprograma_nombre, nvl(nvl(codigoproducto_man, codigoproducto_pad),0) codigoproducto, nvl(codigoproducto.nombre,'N/A') codigoproducto_nombre, nvl(nvl(codigobpin_man, codigobpin_pad),0) codigobpin, nvl(codigobpin.nombre,'N/A') codigobpin_nombre, nvl(nvl(codigoccpet_man, codigoccpet_pad),0) codigoccpet, nvl(codigoccpet.nombre,'N/A') codigoccpet_nombre, nvl(nvl(codigocpcdane_man, codigocpcdane_pad),0) codigocpcdane, nvl(codigocpcdane.nombre,'N/A') codigocpcdane_nombre, nvl(nvl(codigounidadeje_man, codigounidadeje_pad),0) codigounidadeje, nvl(codigounidadeje.nombre,'N/A') codigounidadeje_nombre, nvl(nvl(codigofuente_man, codigofuente_pad),0) codigofuente, nvl(codigofuente.nombre,'N/A') codigofuente_nombre, nvl(nvl(codigoccpetrega_man, codigoccpetrega_pad),0) codigoccpetrega, nvl(codigoccpetrega.nombre,'N/A') codigoccpetrega_nombre, nvl(nvl(codigopolitica_man, codigopolitica_pad),0) codigopolitica, nvl(codigopolitica.nombre,'N/A') codigopolitica_nombre, nvl(nvl(codigodetalles_man, codigodetalles_pad),0) codigodetalles, nvl(codigodetalles.nombre, 'N/A') codigodetalles_nombre, nvl(sector_sum,0) sector_can, nvl(programa_sum,0) programa_can, nvl(subprograma_sum,0) subprograma_can, nvl(codigoproducto_sum,0) codigoproducto_can, nvl(codigobpin_sum,0) codigobpin_can, nvl(codigoccpet_sum,0) codigoccpet_can, nvl(codigocpcdane_sum,0) codigocpcdane_can, nvl(codigounidadeje_sum,0) codigounidadeje_can, nvl(codigofuente_sum,0) codigofuente_can, nvl(codigoccpetrega_sum,0) codigoccpetrega_can, nvl(codigopolitica_sum,0) codigopolitica_can, nvl(codigodetalles_sum,0) codigodetalles_can FROM ( SELECT MOV.COMPANIA, MOV.ANO, MOV.CODIGO, MOV.REGALIAS, MOV.NATURALEZA, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='001' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) SECTOR_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='001' THEN 1 ELSE 0 END) SECTOR_SUM, DCPPTALMOV.SECTOR SECTOR_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='002' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) PROGRAMA_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='002' THEN 1 ELSE 0 END) PROGRAMA_SUM, DCPPTALMOV.PROGRAMA PROGRAMA_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='003' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) SUBPROGRAMA_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='003' THEN 1 ELSE 0 END) SUBPROGRAMA_SUM, DCPPTALMOV.SUBPROGRAMA SUBPROGRAMA_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='004' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOPRODUCTO_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='004' THEN 1 ELSE 0 END) CODIGOPRODUCTO_SUM, DCPPTALMOV.COD_PROD_CUIPO CODIGOPRODUCTO_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='005' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOBPIN_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='005' THEN 1 ELSE 0 END) CODIGOBPIN_SUM, DCPPTALMOV.CODIGO_BPIN CODIGOBPIN_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='006' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOCCPET_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='006' THEN 1 ELSE 0 END) CODIGOCCPET_SUM, DCPPTALMOV.CODIGO_CCPET CODIGOCCPET_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='007' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOCPCDANE_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='007' THEN 1 ELSE 0 END) CODIGOCPCDANE_SUM, DCPPTALMOV.CODIGO_CPC CODIGOCPCDANE_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='008' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOUNIDADEJE_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='008' THEN 1 ELSE 0 END) CODIGOUNIDADEJE_SUM, DCPPTALMOV.CODIGOUNIDADEJE CODIGOUNIDADEJE_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='009' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOFUENTE_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='009' THEN 1 ELSE 0 END) CODIGOFUENTE_SUM, DCPPTALMOV.FUENTE_CUIPO CODIGOFUENTE_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='010' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOCCPETREGA_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='010' THEN 1 ELSE 0 END) CODIGOCCPETREGA_SUM, DCPPTALMOV.CODIGOCCPETREGA CODIGOCCPETREGA_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='011' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGOPOLITICA_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='011' THEN 1 ELSE 0 END) CODIGOPOLITICA_SUM, DCPPTALMOV.POLITICA_PUBLICA CODIGOPOLITICA_MAN, MAX(CASE WHEN PADRE.CLASECLASIFICADOR ='012' THEN PADRE.TIPOCLASIFICADOR ELSE NULL END) CODIGODETALLES_PAD, SUM(CASE WHEN PADRE.CLASECLASIFICADOR ='012' THEN 1 ELSE 0 END) CODIGODETALLES_SUM, DCPPTALMOV.DETALLE_SECTORIAL CODIGODETALLES_MAN, MOV.TIPOVIGENCIA, TV.NOMBRE VIGENCIA, TV.EQUIVALENTE_CUIPO VIGENCIA_GASTO FROM PLAN_PRESUPUESTAL MOV LEFT JOIN PLAN_PRESUPUESTAL PADRE ON PADRE.COMPANIA = MOV.COMPANIA AND PADRE.ANO = MOV.ANO AND PADRE.CODIGO = SUBSTR(MOV.CODIGO,1,LENGTH(PADRE.CODIGO)) INNER JOIN DETALLE_COMPROBANTE_PPTAL DCPPTALP ON ( DCPPTALP.CUENTA = PADRE.CODIGO) INNER JOIN DETALLE_COMPROBANTE_PPTAL DCPPTALMOV ON (DCPPTALMOV.CUENTA = MOV.CODIGO) LEFT JOIN TIPOVIGENCIA TV ON TV.CODIGO = MOV.TIPOVIGENCIA WHERE MOV.COMPANIA = :COMPANIA AND MOV.DATE_CREATED BETWEEN TO_DATE(:FECHA_INICIAL) AND TO_DATE(:FECHA_FINAL) AND MOV.ANO=:ANO AND (MOV.MOVIMIENTO&lt;&gt;0 OR MOV.MAN_AUX_FUE&lt;&gt;0 OR MOV.MAN_AUX_GEN&lt;&gt;0 OR MOV.MAN_AUX_REF&lt;&gt;0 OR MOV.MAN_AUX_TER&lt;&gt;0 OR MOV.MAN_CEN_CTO&lt;&gt;0 ) GROUP BY MOV.COMPANIA, MOV.ANO, MOV.CODIGO, MOV.REGALIAS, MOV.TIPOVIGENCIA, MOV.NATURALEZA, TV.EQUIVALENTE_CUIPO, TV.NOMBRE, DCPPTALMOV.SECTOR, DCPPTALMOV.PROGRAMA, DCPPTALMOV.SUBPROGRAMA, DCPPTALMOV.COD_PROD_CUIPO, DCPPTALMOV.CODIGO_BPIN, DCPPTALMOV.CODIGO_CCPET, DCPPTALMOV.CODIGO_CPC, DCPPTALMOV.CODIGOUNIDADEJE, DCPPTALMOV.FUENTE_CUIPO, DCPPTALMOV.CODIGOCCPETREGA, DCPPTALMOV.POLITICA_PUBLICA, DCPPTALMOV.DETALLE_SECTORIAL ) INI LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='001') SECTOR ON INI.COMPANIA = SECTOR.COMPANIA AND INI.ANO = SECTOR.ANO AND NVL(SECTOR_MAN, SECTOR_PAD) = SECTOR.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='002') PROGRAMA ON INI.COMPANIA = PROGRAMA.COMPANIA AND INI.ANO = PROGRAMA.ANO AND NVL(PROGRAMA_MAN, PROGRAMA_PAD) = PROGRAMA.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='003') SUBPROGRAMA ON INI.COMPANIA = SUBPROGRAMA.COMPANIA AND INI.ANO = SUBPROGRAMA.ANO AND NVL(SUBPROGRAMA_MAN, SUBPROGRAMA_PAD) = SUBPROGRAMA.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='004') CODIGOPRODUCTO ON INI.COMPANIA = CODIGOPRODUCTO.COMPANIA AND INI.ANO = CODIGOPRODUCTO.ANO AND NVL(CODIGOPRODUCTO_MAN, CODIGOPRODUCTO_PAD) = CODIGOPRODUCTO.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='005') CODIGOBPIN ON INI.COMPANIA = CODIGOBPIN.COMPANIA AND INI.ANO = CODIGOBPIN.ANO AND NVL(CODIGOBPIN_MAN, CODIGOBPIN_PAD) = CODIGOBPIN.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='006') CODIGOCCPET ON INI.COMPANIA = CODIGOCCPET.COMPANIA AND INI.ANO = CODIGOCCPET.ANO AND NVL(CODIGOCCPET_MAN, CODIGOCCPET_PAD) = CODIGOCCPET.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='007') CODIGOCPCDANE ON INI.COMPANIA = CODIGOCPCDANE.COMPANIA AND INI.ANO = CODIGOCPCDANE.ANO AND NVL(CODIGOCPCDANE_MAN, CODIGOCPCDANE_PAD) = CODIGOCPCDANE.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='008') CODIGOUNIDADEJE ON INI.COMPANIA = CODIGOUNIDADEJE.COMPANIA AND INI.ANO = CODIGOUNIDADEJE.ANO AND NVL(CODIGOUNIDADEJE_MAN, CODIGOUNIDADEJE_PAD) = CODIGOUNIDADEJE.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='009') CODIGOFUENTE ON INI.COMPANIA = CODIGOFUENTE.COMPANIA AND INI.ANO = CODIGOFUENTE.ANO AND NVL(CODIGOFUENTE_MAN, CODIGOFUENTE_PAD) = CODIGOFUENTE.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='010') CODIGOCCPETREGA ON INI.COMPANIA = CODIGOCCPETREGA.COMPANIA AND INI.ANO = CODIGOCCPETREGA.ANO AND NVL(CODIGOCCPETREGA_MAN, CODIGOCCPETREGA_PAD) = CODIGOCCPETREGA.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='011') CODIGOPOLITICA ON INI.COMPANIA = CODIGOPOLITICA.COMPANIA AND INI.ANO = CODIGOPOLITICA.ANO AND NVL(CODIGOPOLITICA_MAN, CODIGOPOLITICA_PAD) = CODIGOPOLITICA.CODIGO LEFT JOIN (SELECT * FROM TIPOCLASIFICADOR WHERE CLASECLASIFICADOR='012') CODIGODETALLES ON INI.COMPANIA = CODIGODETALLES.COMPANIA AND INI.ANO = CODIGODETALLES.ANO AND NVL(CODIGODETALLES_MAN, CODIGODETALLES_PAD) = CODIGODETALLES.CODIGO ORDER BY INI.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","RUBRO":"$RUBRO","NATURALEZA":"$NATURALEZA","ESREGALIAS":"$ESREGALIAS","TIPOVIGENCIA":"$TIPOVIGENCIA","VIGENCIA":"$VIGENCIA","VIGENCIA_GASTO":"$VIGENCIA_GASTO","SECTOR":"$SECTOR","SECTOR_NOMBRE":"$SECTOR_NOMBRE","PROGRAMA":"$PROGRAMA","PROGRAMA_NOMBRE":"$PROGRAMA_NOMBRE","SUBPROGRAMA":"$SUBPROGRAMA","SUBPROGRAMA_NOMBRE":"$SUBPROGRAMA_NOMBRE","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOPRODUCTO_NOMBRE":"$CODIGOPRODUCTO_NOMBRE","CODIGOBPIN":"$CODIGOBPIN","CODIGOBPIN_NOMBRE":"$CODIGOBPIN_NOMBRE","CODIGOCCPET":"$CODIGOCCPET","CODIGOCCPET_NOMBRE":"$CODIGOCCPET_NOMBRE","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOCPCDANE_NOMBRE":"$CODIGOCPCDANE_NOMBRE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOUNIDADEJE_NOMBRE":"$CODIGOUNIDADEJE_NOMBRE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOFUENTE_NOMBRE":"$CODIGOFUENTE_NOMBRE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","CODIGOCCPETREGA_NOMBRE":"$CODIGOCCPETREGA_NOMBRE","CODIGOPOLITICA":"$CODIGOPOLITICA","CODIGOPOLITICA_NOMBRE":"$CODIGOPOLITICA_NOMBRE","CODIGODETALLES":"$CODIGODETALLES","CODIGODETALLES_NOMBRE":"$CODIGODETALLES_NOMBRE","SECTOR_CAN":"$SECTOR_CAN(type:integer)","PROGRAMA_CAN":"$PROGRAMA_CAN(type:integer)","SUBPROGRAMA_CAN":"$SUBPROGRAMA_CAN(type:integer)","CODIGOPRODUCTO_CAN":"$CODIGOPRODUCTO_CAN(type:integer)","CODIGOBPIN_CAN":"$CODIGOBPIN_CAN(type:integer)","CODIGOCCPET_CAN":"$CODIGOCCPET_CAN(type:integer)","CODIGOCPCDANE_CAN":"$CODIGOCPCDANE_CAN(type:integer)","CODIGOUNIDADEJE_CAN":"$CODIGOUNIDADEJE_CAN(type:integer)","CODIGOFUENTE_CAN":"$CODIGOFUENTE_CAN(type:integer)","CODIGOCCPETREGA_CAN":"$CODIGOCCPETREGA_CAN(type:integer)","CODIGOPOLITICA_CAN":"$CODIGOPOLITICA_CAN(type:integer)","CODIGODETALLES_CAN":"$CODIGODETALLES_CAN(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificadoreshijo/getreporteconfigclasificadosplan">
		<call-query href="getTipoclasificadoreshijoGetreporteconfigclasificadosplanQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoGetreporteplanpresupuestalcaslificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT MOV.COMPANIA, MOV.ANO, MOV.CODIGO, (CASE MOV.REGALIAS WHEN 0 THEN 'No' ELSE 'Si' END) REGALIAS, MOV.NATURALEZA, NVL(MOV.CLASECLASIFICADOR,0) COD_CLASECLASIFICADOR, NVL(CLA.NOMBRE,'N/A') CLASECLASIFICADOR, NVL(MOV.TIPOCLASIFICADOR,0) COD_TIPOCLASIFICADOR, NVL(TIP.NOMBRE,'N/A') CLASIFICADOR, MOV.TIPOVIGENCIA, TV.NOMBRE VIGENCIA, NVL(TV.EQUIVALENTE_CUIPO,0) VIGENCIA_GASTO FROM PLAN_PRESUPUESTAL MOV LEFT JOIN TIPOCLASIFICADOR TIP ON TIP.COMPANIA = MOV.COMPANIA AND TIP.ANO = MOV.ANO AND TIP.CLASECLASIFICADOR = MOV.CLASECLASIFICADOR AND TIP.CODIGO = MOV.TIPOCLASIFICADOR LEFT JOIN CLASECLASIFICADOR CLA ON CLA.COMPANIA = TIP.COMPANIA AND CLA.ANO = TIP.ANO AND CLA.CODIGO = TIP.CLASECLASIFICADOR LEFT JOIN TIPOVIGENCIA TV ON TV.CODIGO = MOV.TIPOVIGENCIA WHERE MOV.COMPANIA = :COMPANIA AND MOV.ANO = :ANO AND TO_CHAR(MOV.DATE_CREATED, 'DD/MM/YYYY') BETWEEN :FECHA_INICIAL AND :FECHA_FINAL ORDER BY ANO, CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","REGALIAS":"$REGALIAS","NATURALEZA":"$NATURALEZA","COD_CLASECLASIFICADOR":"$COD_CLASECLASIFICADOR","CLASECLASIFICADOR":"$CLASECLASIFICADOR","COD_TIPOCLASIFICADOR":"$COD_TIPOCLASIFICADOR","CLASIFICADOR":"$CLASIFICADOR","TIPOVIGENCIA":"$TIPOVIGENCIA","VIGENCIA":"$VIGENCIA","VIGENCIA_GASTO":"$VIGENCIA_GASTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>

	</query>
