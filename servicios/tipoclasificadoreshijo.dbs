	<query id="updateTipoclasificadoreshijo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPOCLASIFICADORESHIJO SET COMPANIA=:COMPANIA, ANO=:ANO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), IDPADRE=:IDPADRE, IDHIJO=:IDHIJO WHERE TIPOCLASIFICADORESHIJO.COMPANIA= :KEY_COMPANIA AND TIPOCLASIFICADORESHIJO.ANO= :KEY_ANO AND TIPOCLASIFICADORESHIJO.IDPADRE= :KEY_IDPADRE AND TIPOCLASIFICADORESHIJO.IDHIJO= :KEY_IDHIJO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="IDHIJO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_IDPADRE" sqlType="STRING"/>
		<param name="KEY_IDHIJO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipoclasificadoreshijo">
