	<query id="getTipoclasificadoreshijoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, IDPADRE, IDHIJO FROM TIPOCLASIFICADORESHIJO WHERE TIPOCLASIFICADORESHIJO.COMPANIA= :KEY_COMPANIA AND TIPOCLASIFICADORESHIJO.ANO= :KEY_ANO AND TIPOCLASIFICADORESHIJO.IDPADRE= :KEY_IDPADRE AND TIPOCLASIFICADORESHIJO.IDHIJO= :KEY_IDHIJO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","IDPADRE":"$IDPADRE","IDHIJO":"$IDHIJO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_IDPADRE" sqlType="STRING"/>
		<param name="KEY_IDHIJO" sqlType="STRING"/>

	</query>
