	<query id="getTipoclasificadoreshijoGetreporteclasificadoresmvtogastosQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT ANO, CUENTA RUBRO, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA, VALOR_DEBITO, NVL(SECTOR, '0') SECTOR, NVL(PROGRAMA, '0') PROGRAMA, NVL(SUBPROGRAMA, '0') SUBPROGRAMA, NVL(COD_PROD_CUIPO, '0') CODIGOPRODUCTO, NVL(CODIGO_BPIN, '0') CODIGOBPIN, NVL(CODIGO_CCPET, '0') CODIGOCCPET, NVL(CODIGO_CPC, '0') CODIGOCPCDANE, NVL(CODIGOUNIDADEJE, '0') CODIGOUNIDADEJE, NVL(FUENTE_CUIPO, '0') CODIGOFUENTE, NVL(CODIGOCCPETREGA, '0') CODIGOCCPETREGA, NVL(POLITICA_PUBLICA, '0') POLITICAPUBLICA, NVL(DETALLE_SECTORIAL, '0') DETALLESECTORIAL FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND TO_CHAR(FECHA, 'DD/MM/YYYY') BETWEEN :FECHA_INICIAL AND :FECHA_FINAL AND ANO = :ANO AND ( ( SECTOR IS NULL OR SECTOR IN ( '' ) ) OR ( PROGRAMA IS NULL OR PROGRAMA IN ( '' ) ) OR ( SUBPROGRAMA IS NULL OR SUBPROGRAMA IN ( '' ) ) OR ( COD_PROD_CUIPO IS NULL OR COD_PROD_CUIPO IN ( '' ) ) OR ( CODIGO_BPIN IS NULL OR CODIGO_BPIN IN ( '' ) ) OR ( CODIGO_CCPET IS NULL OR CODIGO_CCPET IN ( '' ) ) OR ( CODIGO_CPC IS NULL OR CODIGO_CPC IN ( '' ) ) OR ( CODIGOUNIDADEJE IS NULL OR CODIGOUNIDADEJE IN ( '' ) ) OR ( FUENTE_CUIPO IS NULL OR FUENTE_CUIPO IN ( '' ) ) OR ( CODIGOCCPETREGA IS NULL OR CODIGOCCPETREGA IN ( '' ) ) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","RUBRO":"$RUBRO","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","VALOR_DEBITO":"$VALOR_DEBITO","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITICAPUBLICA":"$POLITICAPUBLICA","DETALLESECTORIAL":"$DETALLESECTORIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
