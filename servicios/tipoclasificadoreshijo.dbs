	</resource>
	<query id="insertTipoclasificadoreshijo" keyColumns="COMPANIA,ANO,IDPADRE,IDHIJO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOCLASIFICADORESHIJO (COMPANIA, ANO, IDPADRE, IDHIJO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :IDPADRE, :IDHIJO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_IDPADRE":"$IDPADRE","KEY_IDHIJO":"$IDHIJO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="IDHIJO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tipoclasificadoreshijo">
		<call-query href="insertTipoclasificadoreshijo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="IDPADRE" query-param="IDPADRE"/>
			<with-param name="IDHIJO" query-param="IDHIJO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTipoclasificadoreshijo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPOCLASIFICADORESHIJO WHERE TIPOCLASIFICADORESHIJO.COMPANIA= :KEY_COMPANIA AND TIPOCLASIFICADORESHIJO.ANO= :KEY_ANO AND TIPOCLASIFICADORESHIJO.IDPADRE= :KEY_IDPADRE AND TIPOCLASIFICADORESHIJO.IDHIJO= :KEY_IDHIJO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_IDPADRE" sqlType="STRING"/>
		<param name="KEY_IDHIJO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tipoclasificadoreshijo">
		<call-query href="deleteTipoclasificadoreshijo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_IDPADRE" query-param="KEY_IDPADRE"/>
			<with-param name="KEY_IDHIJO" query-param="KEY_IDHIJO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, IDPADRE, IDHIJO FROM TIPOCLASIFICADORESHIJO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN IDPADRE IS NULL THEN ' ' ELSE UPPER(IDPADRE) END) LIKE UPPER(CONCAT(CONCAT('%',:IDPADRE), '%')) AND (CASE WHEN IDHIJO IS NULL THEN ' ' ELSE UPPER(IDHIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:IDHIJO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","IDPADRE":"$IDPADRE","IDHIJO":"$IDHIJO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="IDHIJO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoclasificadoreshijo">
		<call-query href="getTipoclasificadoreshijoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="IDPADRE" query-param="IDPADRE"/>
			<with-param name="IDHIJO" query-param="IDHIJO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, IDPADRE, IDHIJO FROM TIPOCLASIFICADORESHIJO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN IDPADRE IS NULL THEN ' ' ELSE UPPER(IDPADRE) END) LIKE UPPER(CONCAT(CONCAT('%',:IDPADRE), '%')) AND (CASE WHEN IDHIJO IS NULL THEN ' ' ELSE UPPER(IDHIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:IDHIJO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
