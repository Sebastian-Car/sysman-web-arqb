	<query id="getTipoclasificadoreshijoPagListahijosdelpadreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TCH.IDHIJO, CC.CODIGO CLASFIFICADORHIJO, CC.NOMBRE NOMBREPADRE, TC.CODIGO CODCLASIFICADOR, TC.NOMBRE NOMBREHIJO FROM TIPOCLASIFICADORESHIJO TCH INNER JOIN TIPOCLASIFICADOR TC ON TCH.COMPANIA = TC.COMPANIA AND TCH.ANO = TC.ANO AND TCH.IDHIJO = TC.ID INNER JOIN CLASECLASIFICADOR CC ON TC.COMPANIA = CC.COMPANIA AND TC.ANO = CC.ANO AND TC.CLASECLASIFICADOR = CC.CODIGO WHERE TCH.IDPADRE = :IDPADRE AND CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO) INI WHERE (CASE WHEN IDHIJO IS NULL THEN ' ' ELSE UPPER(IDHIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:IDHIJO), '%')) AND (CASE WHEN CLASFIFICADORHIJO IS NULL THEN ' ' ELSE UPPER(CLASFIFICADORHIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASFIFICADORHIJO), '%')) AND (CASE WHEN NOMBREPADRE IS NULL THEN ' ' ELSE UPPER(NOMBREPADRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPADRE), '%')) AND (CASE WHEN CODCLASIFICADOR IS NULL THEN ' ' ELSE UPPER(CODCLASIFICADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:CODCLASIFICADOR), '%')) AND (CASE WHEN NOMBREHIJO IS NULL THEN ' ' ELSE UPPER(NOMBREHIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREHIJO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDHIJO":"$IDHIJO","CLASFIFICADORHIJO":"$CLASFIFICADORHIJO","NOMBREPADRE":"$NOMBREPADRE","CODCLASIFICADOR":"$CODCLASIFICADOR","NOMBREHIJO":"$NOMBREHIJO"}]}}		</result>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="IDHIJO" sqlType="STRING"/>
		<param name="CLASFIFICADORHIJO" sqlType="STRING"/>
		<param name="NOMBREPADRE" sqlType="STRING"/>
		<param name="CODCLASIFICADOR" sqlType="STRING"/>
		<param name="NOMBREHIJO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
