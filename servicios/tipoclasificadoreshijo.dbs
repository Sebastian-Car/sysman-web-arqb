		<call-query href="getTipoclasificadoreshijoGetreporteplanpresupuestalcaslificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadoreshijoGetreporteclasificadorescadenapresupuestalQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(DIS.COMPANIA) COMPANIA, TO_CHAR(DIS.ANO) AÑO_DIS, PLPPTAL.CODIGO RUBRO, DIS.TIPO_CPTE TIPO_DIS, TO_CHAR(DIS.COMPROBANTE) DIS, TO_CHAR(DIS.FECHA, 'DD/MM/YYYY') FECHA_DIS, TO_CHAR(DIS.CONSECUTIVO) CONSECUTIVO_PPTO, TO_CHAR(ABS(DIS.DISPONIBILIDADNETA)) VALOR_DIS, NVL(DIS.SECTOR,0) SECTOR_DIS, NVL(DIS.PROGRAMA,0) PROGRAMA_DIS, NVL(DIS.SUBPROGRAMA,0) SUBPROGRAMA_DIS, NVL(DIS.COD_PROD_CUIPO,0) PRODUCTO_DIS, NVL(DIS.CODIGO_BPIN,0) CODIGO_BPIN_DIS, NVL(DIS.CODIGO_CCPET,0) CODIGO_CCPET_DIS, NVL(DIS.CODIGO_CPC,0) CODIGO_CPC_DIS, NVL(DIS.CODIGOUNIDADEJE,0) CODIGO_UNIDAD_EJECUTA_DIS, NVL(DIS.FUENTE_CUIPO,0) FUENTE_DIS, NVL(DIS.CODIGOCCPETREGA,0) CODIGO_CCPET_REGALIAS_DIS, NVL(DIS.POLITICA_PUBLICA,0) CCODIGO_POLITICA_DIS, NVL(DIS.DETALLE_SECTORIAL,0) DETALLE_SECTORIAL_DIS, RES.TIPO_CPTE TIPO_RES, TO_CHAR(RES.COMPROBANTE) RES, TO_CHAR(RES.FECHA, 'DD/MM/YYYY') FECHA_RES, RES.CONSECUTIVO CONSECUTIVO_RES, TO_CHAR(ABS(DIS.DISPONIBILIDADNETA)) VALOR_RES, NVL(RES.SECTOR,0) SECTOR_RES, NVL(RES.PROGRAMA,0) PROGRAMA_RES, NVL(RES.SUBPROGRAMA,0) SUBPROGRAMA_RES, NVL(RES.COD_PROD_CUIPO,0) PRODUCTO_RES, NVL(RES.CODIGO_BPIN,0) CODIGO_BPIN_RES, NVL(RES.CODIGO_CCPET,0) CODIGO_CCPET_RES, NVL(RES.CODIGO_CPC,0) CODIGO_CPC_RES, NVL(RES.CODIGOUNIDADEJE,0) CODIGO_UNIDAD_EJECUTA_RES, NVL(RES.FUENTE_CUIPO,0) FUENTE_RES, NVL(RES.CODIGOCCPETREGA,0) CODIGO_CCPET_REGALIAS_RES, NVL(RES.POLITICA_PUBLICA,0) CODIGO_POLITICA_RES, NVL(RES.DETALLE_SECTORIAL,0) DETALLE_SECTORIAL_RES, REO.TIPO_CPTE TIPO_REO, TO_CHAR(REO.COMPROBANTE) REO, TO_CHAR(REO.FECHA, 'DD/MM/YYYY') FECHA_REO, REO.CONSECUTIVO CONSECUTIVO, TO_CHAR(ABS(REO.DISPONIBILIDADNETA - REO.DEBITO_AFECTADO)) VALOR_REO, NVL(REO.SECTOR,0) SECTOR_REO, NVL(REO.PROGRAMA,0) PROGRAMA_REO, NVL(REO.SUBPROGRAMA,0) SUBPROGRAMA_REO, NVL(REO.COD_PROD_CUIPO,0) PRODUCTO_REO, NVL(REO.CODIGO_BPIN,0) CODIGO_BPIN_REO, NVL(REO.CODIGO_CCPET,0) CODIGO_CCPET_REO, NVL(REO.CODIGO_CPC,0) CODIGO_CPC_REO, NVL(REO.CODIGOUNIDADEJE,0) CODIGO_UNIDAD_EJECUTA_REO, NVL(REO.FUENTE_CUIPO,0) FUENTE_REO, NVL(REO.CODIGOCCPETREGA,0) CODIGO_CCPET_REGALIAS_REO, NVL(REO.POLITICA_PUBLICA,0) CCODIGO_POLITICA_REO, NVL(REO.DETALLE_SECTORIAL,0) DETALLE_SECTORIAL_REO, EGR.TIPO_CPTE TIPO_EGR, TO_CHAR(EGR.COMPROBANTE) EGR, TO_CHAR(EGR.FECHA, 'DD/MM/YYYY') FECHA_EGR, EGR.CONSECUTIVO CONSECUTIVO_EGR, TO_CHAR(ABS(EGR.VALOR_DEBITO)) VALOR_EGR, NVL(EGR.SECTOR,0) SECTOR_EGR, NVL(EGR.PROGRAMA,0) PROGRAMA_EGR, NVL(EGR.SUBPROGRAMA,0) SUBPROGRAMA_EGR, NVL(EGR.COD_PROD_CUIPO,0) PRODUCTO_EGR, NVL(EGR.CODIGO_BPIN,0) CODIGO_BPIN_EGR, NVL(EGR.CODIGO_CCPET,0) CODIGO_CCPET_EGR, NVL(EGR.CODIGO_CPC,0) CODIGO_CPC_EGR, NVL(EGR.CODIGOUNIDADEJE,0) CODIGO_UNIDAD_EJECUTA_EGR, NVL(EGR.FUENTE_CUIPO,0) FUENTE_EGR, NVL(EGR.CODIGOCCPETREGA,0) CODIGO_CCPET_REGALIAS_EGR, NVL(EGR.POLITICA_PUBLICA,0) CODIGO_POLITICA_EGR, NVL(EGR.DETALLE_SECTORIAL,0) DETALLE_SECTORIAL_EGR FROM DETALLE_COMPROBANTE_PPTAL DIS LEFT JOIN COMPROBANTE_PPTAL CPTEPPTAL ON DIS.COMPANIA = CPTEPPTAL.COMPANIA AND DIS.ANO = CPTEPPTAL.ANO AND DIS.COMPROBANTE = CPTEPPTAL.NUMERO AND DIS.TIPO_CPTE = CPTEPPTAL.TIPO INNER JOIN DETALLE_COMPROBANTE_PPTAL RES ON RES.COMPANIA = DIS.COMPANIA AND RES.ANO = DIS.ANO AND RES.TIPO_CPTE_AFECT = DIS.TIPO_CPTE AND RES.CMPTE_AFECTADO = DIS.COMPROBANTE AND RES.CONSECUTIVOPPTO = DIS.CONSECUTIVO INNER JOIN DETALLE_COMPROBANTE_PPTAL REO ON RES.COMPANIA = RES.COMPANIA AND REO.ANO = RES.ANO AND REO.TIPO_CPTE_AFECT = RES.TIPO_CPTE AND REO.CMPTE_AFECTADO = RES.COMPROBANTE AND REO.CONSECUTIVOPPTO = RES.CONSECUTIVO INNER JOIN DETALLE_COMPROBANTE_PPTAL EGR ON EGR.COMPANIA = REO.COMPANIA AND EGR.ANO = REO.ANO AND EGR.TIPO_CPTE_AFECT = REO.TIPO_CPTE AND EGR.CMPTE_AFECTADO = REO.COMPROBANTE AND EGR.CONSECUTIVOPPTO = REO.CONSECUTIVO LEFT JOIN PLAN_PRESUPUESTAL PLPPTAL ON DIS.COMPANIA = PLPPTAL.COMPANIA AND DIS.ANO = PLPPTAL.ANO AND DIS.CUENTA = PLPPTAL.CODIGO LEFT JOIN TIPO_COMPROBPP ON DIS.COMPANIA = TIPO_COMPROBPP.COMPANIA AND DIS.TIPO_CPTE = TIPO_COMPROBPP.CODIGO WHERE DIS.COMPANIA = :COMPANIA AND TIPO_COMPROBPP.CLASE = 'DIS' AND DIS.ANO = :ANO AND PLPPTAL.VIGENCIA = :ANO AND DIS.FECHA BETWEEN :FECHA_INICIAL AND :FECHA_FINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","AÑO_DIS":"$AÑO_DIS","RUBRO":"$RUBRO","TIPO_DIS":"$TIPO_DIS","DIS":"$DIS","FECHA_DIS":"$FECHA_DIS","CONSECUTIVO_PPTO":"$CONSECUTIVO_PPTO","VALOR_DIS":"$VALOR_DIS","SECTOR_DIS":"$SECTOR_DIS","PROGRAMA_DIS":"$PROGRAMA_DIS","SUBPROGRAMA_DIS":"$SUBPROGRAMA_DIS","PRODUCTO_DIS":"$PRODUCTO_DIS","CODIGO_BPIN_DIS":"$CODIGO_BPIN_DIS","CODIGO_CCPET_DIS":"$CODIGO_CCPET_DIS","CODIGO_CPC_DIS":"$CODIGO_CPC_DIS","CODIGO_UNIDAD_EJECUTA_DIS":"$CODIGO_UNIDAD_EJECUTA_DIS","FUENTE_DIS":"$FUENTE_DIS","CODIGO_CCPET_REGALIAS_DIS":"$CODIGO_CCPET_REGALIAS_DIS","CCODIGO_POLITICA_DIS":"$CCODIGO_POLITICA_DIS","DETALLE_SECTORIAL_DIS":"$DETALLE_SECTORIAL_DIS","TIPO_RES":"$TIPO_RES","RES":"$RES","FECHA_RES":"$FECHA_RES","CONSECUTIVO_RES":"$CONSECUTIVO_RES(type:integer)","VALOR_RES":"$VALOR_RES","SECTOR_RES":"$SECTOR_RES","PROGRAMA_RES":"$PROGRAMA_RES","SUBPROGRAMA_RES":"$SUBPROGRAMA_RES","PRODUCTO_RES":"$PRODUCTO_RES","CODIGO_BPIN_RES":"$CODIGO_BPIN_RES","CODIGO_CCPET_RES":"$CODIGO_CCPET_RES","CODIGO_CPC_RES":"$CODIGO_CPC_RES","CODIGO_UNIDAD_EJECUTA_RES":"$CODIGO_UNIDAD_EJECUTA_RES","FUENTE_RES":"$FUENTE_RES","CODIGO_CCPET_REGALIAS_RES":"$CODIGO_CCPET_REGALIAS_RES","CODIGO_POLITICA_RES":"$CODIGO_POLITICA_RES","DETALLE_SECTORIAL_RES":"$DETALLE_SECTORIAL_RES","TIPO_REO":"$TIPO_REO","REO":"$REO","FECHA_REO":"$FECHA_REO","CONSECUTIVO":"$CONSECUTIVO(type:integer)","VALOR_REO":"$VALOR_REO","SECTOR_REO":"$SECTOR_REO","PROGRAMA_REO":"$PROGRAMA_REO","SUBPROGRAMA_REO":"$SUBPROGRAMA_REO","PRODUCTO_REO":"$PRODUCTO_REO","CODIGO_BPIN_REO":"$CODIGO_BPIN_REO","CODIGO_CCPET_REO":"$CODIGO_CCPET_REO","CODIGO_CPC_REO":"$CODIGO_CPC_REO","CODIGO_UNIDAD_EJECUTA_REO":"$CODIGO_UNIDAD_EJECUTA_REO","FUENTE_REO":"$FUENTE_REO","CODIGO_CCPET_REGALIAS_REO":"$CODIGO_CCPET_REGALIAS_REO","CCODIGO_POLITICA_REO":"$CCODIGO_POLITICA_REO","DETALLE_SECTORIAL_REO":"$DETALLE_SECTORIAL_REO","TIPO_EGR":"$TIPO_EGR","EGR":"$EGR","FECHA_EGR":"$FECHA_EGR","CONSECUTIVO_EGR":"$CONSECUTIVO_EGR(type:integer)","VALOR_EGR":"$VALOR_EGR","SECTOR_EGR":"$SECTOR_EGR","PROGRAMA_EGR":"$PROGRAMA_EGR","SUBPROGRAMA_EGR":"$SUBPROGRAMA_EGR","PRODUCTO_EGR":"$PRODUCTO_EGR","CODIGO_BPIN_EGR":"$CODIGO_BPIN_EGR","CODIGO_CCPET_EGR":"$CODIGO_CCPET_EGR","CODIGO_CPC_EGR":"$CODIGO_CPC_EGR","CODIGO_UNIDAD_EJECUTA_EGR":"$CODIGO_UNIDAD_EJECUTA_EGR","FUENTE_EGR":"$FUENTE_EGR","CODIGO_CCPET_REGALIAS_EGR":"$CODIGO_CCPET_REGALIAS_EGR","CODIGO_POLITICA_EGR":"$CODIGO_POLITICA_EGR","DETALLE_SECTORIAL_EGR":"$DETALLE_SECTORIAL_EGR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>

	</query>
