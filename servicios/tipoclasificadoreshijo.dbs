	<query id="insertTipoclasificadoreshijoInserttipoclasificadoreshijoanonue" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOCLASIFICADORESHIJO (COMPANIA, ANO, IDPADRE, IDHIJO, CREATED_BY, DATE_CREATED) SELECT COMPANIA, :ANOPREPARAR, IDPADRE, IDHIJO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS') FROM TIPOCLASIFICADORESHIJO WHERE COMPANIA = :COMPANIA AND ANO = :ANO</sql>
