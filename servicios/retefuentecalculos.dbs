<data name="retefuentecalculos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getRetefuentecalculosPagNombrePersonalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT RTE_FTE_CALCULOS_CONSULTA1.NOMBRECOMPLETO, RTE_FTE_CALCULOS_CONSULTA1.NUMERO_DCTO NUMERO_DCTO,RTE_FTE_CALCULOS_CONSULTA1.ID_DE_EMPLEADO FROM (SELECT DISTINCT PERSONAL.NOMBRECOMPLETO, PERSONAL.NUMERO_DCTO, HISTORICOS.COMPANIA, HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO FROM (HISTORICOS INNER JOIN CONCEPTOS ON HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO AND HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA) LEFT JOIN PERSONAL ON HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO AND HISTORICOS.COMPANIA = PERSONAL.COMPANIA WHERE HISTORICOS.COMPANIA = :COMPANIA AND CONCEPTOS.CLASE = 3 AND CONCEPTOS.FACTOR_RETEFUENTE NOT IN(0) AND HISTORICOS.ID_DE_PROCESO = :PROCESO AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND HISTORICOS.PERIODO = :PERIODO ) RTE_FTE_CALCULOS_CONSULTA1 LEFT JOIN RETEFUENTE_CALCULOS ON RTE_FTE_CALCULOS_CONSULTA1.COMPANIA = RETEFUENTE_CALCULOS.COMPANIA AND RTE_FTE_CALCULOS_CONSULTA1.ID_DE_PROCESO = RETEFUENTE_CALCULOS.ID_DE_PROCESO AND RTE_FTE_CALCULOS_CONSULTA1.ANO = RETEFUENTE_CALCULOS.ANO AND RTE_FTE_CALCULOS_CONSULTA1.MES = RETEFUENTE_CALCULOS.MES AND RTE_FTE_CALCULOS_CONSULTA1.PERIODO = RETEFUENTE_CALCULOS.PERIODO AND RTE_FTE_CALCULOS_CONSULTA1.ID_DE_EMPLEADO = RETEFUENTE_CALCULOS.ID_DE_EMPLEADO WHERE RETEFUENTE_CALCULOS.ANO IS NOT NULL ORDER BY RTE_FTE_CALCULOS_CONSULTA1.NOMBRECOMPLETO) INI WHERE (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRECOMPLETO":"$NOMBRECOMPLETO","NUMERO_DCTO":"$NUMERO_DCTO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="retefuentecalculos/nombrepersonal/pag">
		<call-query href="getRetefuentecalculosPagNombrePersonalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRetefuentecalculosNumNombrePersonalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT RTE_FTE_CALCULOS_CONSULTA1.NOMBRECOMPLETO, RTE_FTE_CALCULOS_CONSULTA1.NUMERO_DCTO NUMERO_DCTO,RTE_FTE_CALCULOS_CONSULTA1.ID_DE_EMPLEADO FROM (SELECT DISTINCT PERSONAL.NOMBRECOMPLETO, PERSONAL.NUMERO_DCTO, HISTORICOS.COMPANIA, HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO FROM (HISTORICOS INNER JOIN CONCEPTOS ON HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO AND HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA) LEFT JOIN PERSONAL ON HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO AND HISTORICOS.COMPANIA = PERSONAL.COMPANIA WHERE HISTORICOS.COMPANIA = :COMPANIA AND CONCEPTOS.CLASE = 3 AND CONCEPTOS.FACTOR_RETEFUENTE NOT IN(0) AND HISTORICOS.ID_DE_PROCESO = :PROCESO AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND HISTORICOS.PERIODO = :PERIODO ) RTE_FTE_CALCULOS_CONSULTA1 LEFT JOIN RETEFUENTE_CALCULOS ON RTE_FTE_CALCULOS_CONSULTA1.COMPANIA = RETEFUENTE_CALCULOS.COMPANIA AND RTE_FTE_CALCULOS_CONSULTA1.ID_DE_PROCESO = RETEFUENTE_CALCULOS.ID_DE_PROCESO AND RTE_FTE_CALCULOS_CONSULTA1.ANO = RETEFUENTE_CALCULOS.ANO AND RTE_FTE_CALCULOS_CONSULTA1.MES = RETEFUENTE_CALCULOS.MES AND RTE_FTE_CALCULOS_CONSULTA1.PERIODO = RETEFUENTE_CALCULOS.PERIODO AND RTE_FTE_CALCULOS_CONSULTA1.ID_DE_EMPLEADO = RETEFUENTE_CALCULOS.ID_DE_EMPLEADO WHERE RETEFUENTE_CALCULOS.ANO IS NOT NULL ORDER BY RTE_FTE_CALCULOS_CONSULTA1.NOMBRECOMPLETO) INI WHERE (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="retefuentecalculos/nombrepersonal/num">
		<call-query href="getRetefuentecalculosNumNombrePersonalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>

		</call-query>
	</resource>

</data>