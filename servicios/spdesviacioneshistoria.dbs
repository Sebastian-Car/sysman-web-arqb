<data name="spdesviacioneshistoria" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpdesviacioneshistoriaGeneralQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_DESVIACIONES_HISTORIA.COMPANIA, SP_DESVIACIONES_HISTORIA.DESVIACION, SP_DESVIACIONES_HISTORIA.CICLO, SP_DESVIACIONES_HISTORIA.CODIGORUTA, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_DESVIACIONES_HISTORIA.COMPANIA,SP_DESVIACIONES_HISTORIA.ANO,SP_DESVIACIONES_HISTORIA.PERIODO,NULL)PER, SP_DESVIACIONES_HISTORIA.ANO, SP_DESVIACIONES_HISTORIA.PERIODO, SP_DESVIACIONES_HISTORIA.LECTURAINICIAL, SP_DESVIACIONES_HISTORIA.LECTURAFINAL, SP_DESVIACIONES_HISTORIA.CONSUMOACUFACTURADO, SP_DESVIACIONES_HISTORIA.CONSUMOACUREAL, SP_DESVIACIONES_HISTORIA.CONSUMOALCREAL, SP_DESVIACIONES_HISTORIA.CONSUMOALCFACTURADO, SP_DESVIACIONES_HISTORIA.CONSUMOACUREAL - SP_DESVIACIONES_HISTORIA.CONSUMOACUFACTURADO PENDIENTE, SP_DESVIACIONES_HISTORIA.VALORACUREAL - SP_DESVIACIONES_HISTORIA.VALORACUFACTURADO PENDIENTEACU, SP_DESVIACIONES_HISTORIA.VALORACUREAL, SP_DESVIACIONES_HISTORIA.VALORACUFACTURADO, SP_DESVIACIONES_HISTORIA.VALORALCREAL - SP_DESVIACIONES_HISTORIA.VALORALCFACTURADO PENDIENTEALC, SP_DESVIACIONES_HISTORIA.VALORALCREAL, SP_DESVIACIONES_HISTORIA.VALORALCFACTURADO,(CASE SP_DESVIACIONES_HISTORIA.CONSUMOMANUAL WHEN 0 THEN 'false' ELSE 'true' END) CONSUMOMANUAL,(CASE SP_DESVIACIONES_HISTORIA.PORMICRO WHEN 0 THEN 'false' ELSE 'true' END) PORMICRO, SP_DESVIACIONES_HISTORIA.METROSMICRO  FROM SP_DESVIACIONES_HISTORIA WHERE COMPANIA= :COMPANIA AND DESVIACION=:DESVIACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DESVIACION":"$DESVIACION(type:long)","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","PER":"$PER","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","LECTURAINICIAL":"$LECTURAINICIAL","LECTURAFINAL":"$LECTURAFINAL","CONSUMOACUFACTURADO":"$CONSUMOACUFACTURADO","CONSUMOACUREAL":"$CONSUMOACUREAL","CONSUMOALCREAL":"$CONSUMOALCREAL","CONSUMOALCFACTURADO":"$CONSUMOALCFACTURADO","PENDIENTE":"$PENDIENTE(type:integer)","PENDIENTEACU":"$PENDIENTEACU(type:integer)","VALORACUREAL":"$VALORACUREAL","VALORACUFACTURADO":"$VALORACUFACTURADO","PENDIENTEALC":"$PENDIENTEALC(type:integer)","VALORALCREAL":"$VALORALCREAL","VALORALCFACTURADO":"$VALORALCFACTURADO","CONSUMOMANUAL":"$CONSUMOMANUAL(type:boolean)","PORMICRO":"$PORMICRO(type:boolean)","METROSMICRO":"$METROSMICRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DESVIACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdesviacioneshistoria/general">
		<call-query href="getSpdesviacioneshistoriaGeneralQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DESVIACION" query-param="DESVIACION"/>

		</call-query>
	</resource>
	<query id="getSpdesviacioneshistoriaTotalesHistoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(SP_DESVIACIONES_HISTORIA.CONSUMOACUREAL - SP_DESVIACIONES_HISTORIA.CONSUMOACUFACTURADO),0) PENDIENTE, NVL(SUM(SP_DESVIACIONES_HISTORIA.VALORACUREAL - SP_DESVIACIONES_HISTORIA.VALORACUFACTURADO),0) PENDIENTEACU, NVL(SUM(SP_DESVIACIONES_HISTORIA.VALORALCREAL - SP_DESVIACIONES_HISTORIA.VALORALCFACTURADO),0) PENDIENTEALC, NVL(SUM(SP_DESVIACIONES_HISTORIA.METROSMICRO),0) METROSMICRO  FROM SP_DESVIACIONES_HISTORIA WHERE SP_DESVIACIONES_HISTORIA.COMPANIA = :COMPANIA AND SP_DESVIACIONES_HISTORIA.DESVIACION = :DESVIACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PENDIENTE":"$PENDIENTE(type:integer)","PENDIENTEACU":"$PENDIENTEACU(type:integer)","PENDIENTEALC":"$PENDIENTEALC(type:integer)","METROSMICRO":"$METROSMICRO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DESVIACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdesviacioneshistoria/totaleshistoria">
		<call-query href="getSpdesviacioneshistoriaTotalesHistoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DESVIACION" query-param="DESVIACION"/>

		</call-query>
	</resource>
	<query id="getSpdesviacioneshistoriaListarDesviacionesPorItemQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_DESVIACIONES_HISTORIA.COMPANIA, SP_DESVIACIONES_HISTORIA.ANO, SP_DESVIACIONES_HISTORIA.PERIODO,NULL) NOMBREPERIODO, SP_DESVIACIONES_HISTORIA.LECTURAINICIAL ANTERIOR, SP_DESVIACIONES_HISTORIA.LECTURAFINAL ACTUAL, SP_DESVIACIONES_HISTORIA.CONSUMOACUFACTURADO FACTURADO, SP_DESVIACIONES_HISTORIA.CONSUMOACUREAL CONREAL, SP_DESVIACIONES_HISTORIA.CONSUMOACUREAL - SP_DESVIACIONES_HISTORIA.CONSUMOACUFACTURADO PENDIENTE, SP_DESVIACIONES_HISTORIA.VALORACUREAL - SP_DESVIACIONES_HISTORIA.VALORACUFACTURADO ACUEDUCTO, SP_DESVIACIONES_HISTORIA.VALORALCREAL - SP_DESVIACIONES_HISTORIA.VALORALCFACTURADO ALCANTARILLADO  FROM SP_DESVIACIONES_HISTORIA WHERE SP_DESVIACIONES_HISTORIA.COMPANIA = :COMPANIA AND SP_DESVIACIONES_HISTORIA.DESVIACION = :ITEM</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBREPERIODO":"$NOMBREPERIODO","ANTERIOR":"$ANTERIOR","ACTUAL":"$ACTUAL","FACTURADO":"$FACTURADO","CONREAL":"$CONREAL","PENDIENTE":"$PENDIENTE(type:integer)","ACUEDUCTO":"$ACUEDUCTO(type:integer)","ALCANTARILLADO":"$ALCANTARILLADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ITEM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdesviacioneshistoria/listardesviacionesporitem">
		<call-query href="getSpdesviacioneshistoriaListarDesviacionesPorItemQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ITEM" query-param="ITEM"/>

		</call-query>
	</resource>

</data>