<data name="vehiculoseguro" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVehiculoseguroVehiculosSegurosPorPlacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, PLACA, CODIGO, NUMEROPOLIZA, NIT, SUCURSAL, NOMBRE,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, TO_CHAR(FECHAINICIAL,'dd/MM/YYYY') FECHAINICIALM, TO_CHAR(FECHAFINAL,'dd/MM/YYYY') FECHAFINALM, OBSERVACIONES  FROM VEHICULOSEGURO WHERE COMPANIA=:COMPANIA AND PLACA = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PLACA":"$PLACA","CODIGO":"$CODIGO","NUMEROPOLIZA":"$NUMEROPOLIZA","NIT":"$NIT","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","FECHAINICIALM":"$FECHAINICIALM","FECHAFINALM":"$FECHAFINALM","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vehiculoseguro/vehiculossegurosporplaca">
		<call-query href="getVehiculoseguroVehiculosSegurosPorPlacaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="insertVehiculoseguro" keyColumns="COMPANIA,PLACA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VEHICULOSEGURO (COMPANIA, PLACA, CODIGO, FECHAFINAL, NOMBRE, SUCURSAL, FECHAINICIAL, OBSERVACIONES, NUMEROPOLIZA, NIT, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :PLACA, :CODIGO, TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), :NOMBRE, :SUCURSAL, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACIONES, :NUMEROPOLIZA, :NIT, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PLACA":"$PLACA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAFINAL" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINICIAL" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="" name="NUMEROPOLIZA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vehiculoseguro">
		<call-query href="insertVehiculoseguro">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NUMEROPOLIZA" query-param="NUMEROPOLIZA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteVehiculoseguro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VEHICULOSEGURO WHERE VEHICULOSEGURO.COMPANIA= :KEY_COMPANIA AND VEHICULOSEGURO.PLACA= :KEY_PLACA AND VEHICULOSEGURO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vehiculoseguro">
		<call-query href="deleteVehiculoseguro">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateVehiculoseguro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VEHICULOSEGURO SET CODIGO=:CODIGO, NIT=:NIT, NOMBRE=:NOMBRE, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), OBSERVACIONES=:OBSERVACIONES, NUMEROPOLIZA=:NUMEROPOLIZA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE VEHICULOSEGURO.COMPANIA= :KEY_COMPANIA AND VEHICULOSEGURO.PLACA= :KEY_PLACA AND VEHICULOSEGURO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NUMEROPOLIZA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vehiculoseguro">
		<call-query href="updateVehiculoseguro">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NUMEROPOLIZA" query-param="NUMEROPOLIZA"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>