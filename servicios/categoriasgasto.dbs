<data name="categoriasgasto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCategoriasgastoTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CATEGORIAGASTO.CODIGO, CATEGORIAGASTO.NOMBRE  FROM CATEGORIAGASTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="categoriasgasto/todos">
		<call-query href="getCategoriasgastoTodosQuery">
 
		</call-query>
	</resource>
	<query id="getCategoriasgastoPagTodosPorCompaniaAnoEscalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE  FROM CATEGORIA WHERE CATEGORIA.COMPANIA = :COMPANIA AND CATEGORIA.ANO = :ANO AND CATEGORIA.ESCALAFON = :ESCALAFON) WHERE (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER( '%' || :ID_DE_CATEGORIA || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER(:SALARIO_BASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="categoriasgasto/todosporcompaniaanoescalafon/pag">
		<call-query href="getCategoriasgastoPagTodosPorCompaniaAnoEscalafonQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCategoriasgastoNumTodosPorCompaniaAnoEscalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE  FROM CATEGORIA WHERE CATEGORIA.COMPANIA = :COMPANIA AND CATEGORIA.ANO = :ANO AND CATEGORIA.ESCALAFON = :ESCALAFON) WHERE (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER( '%' || :ID_DE_CATEGORIA || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER(:SALARIO_BASE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="categoriasgasto/todosporcompaniaanoescalafon/num">
		<call-query href="getCategoriasgastoNumTodosPorCompaniaAnoEscalafonQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>

		</call-query>
	</resource>

</data>