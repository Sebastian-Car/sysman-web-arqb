<data name="piplanindicativoobs" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPiplanindicativoobsListaPlanDeAccionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA , VIGENCIA_INICIAL , ID_PLAN , CONSECUTIVO ,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, OBSERVACION  FROM PI_PLAN_INDICATIVO_OBS WHERE PI_PLAN_INDICATIVO_OBS.COMPANIA = :COMPANIA AND PI_PLAN_INDICATIVO_OBS.VIGENCIA_INICIAL = :VIGENCIA AND PI_PLAN_INDICATIVO_OBS.ID_PLAN = :ID_PLAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","ID_PLAN":"$ID_PLAN","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanindicativoobs/listaplandeaccion">
		<call-query href="getPiplanindicativoobsListaPlanDeAccionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>

		</call-query>
	</resource>
	<query id="insertPiplanindicativoobs" keyColumns="COMPANIA,VIGENCIA_INICIAL,ID_PLAN,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PI_PLAN_INDICATIVO_OBS (COMPANIA, VIGENCIA_INICIAL, ID_PLAN, CONSECUTIVO, OBSERVACION, FECHA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :VIGENCIA_INICIAL, :ID_PLAN, :CONSECUTIVO, :OBSERVACION, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="piplanindicativoobs">
		<call-query href="insertPiplanindicativoobs">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePiplanindicativoobs" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PI_PLAN_INDICATIVO_OBS WHERE PI_PLAN_INDICATIVO_OBS.COMPANIA= :KEY_COMPANIA AND PI_PLAN_INDICATIVO_OBS.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PLAN_INDICATIVO_OBS.ID_PLAN= :KEY_ID_PLAN AND PI_PLAN_INDICATIVO_OBS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="INTEGER"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="piplanindicativoobs">
		<call-query href="deletePiplanindicativoobs">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updatePiplanindicativoobs" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_PLAN_INDICATIVO_OBS SET COMPANIA=:COMPANIA, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, ID_PLAN=:ID_PLAN, CONSECUTIVO=:CONSECUTIVO, OBSERVACION=:OBSERVACION, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_PLAN_INDICATIVO_OBS.COMPANIA= :KEY_COMPANIA AND PI_PLAN_INDICATIVO_OBS.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PLAN_INDICATIVO_OBS.ID_PLAN= :KEY_ID_PLAN AND PI_PLAN_INDICATIVO_OBS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="piplanindicativoobs">
		<call-query href="updatePiplanindicativoobs">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>