<data name="vpfactores" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVpfactoresPagPorproyectoyclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID,CODIGO, NOMBRE,FACTOR  FROM VP_FACTORES WHERE COMPANIA = :COMPANIA AND ID_PROYECTO = :PROYECTO AND CLASE_FACTOR = :CLASE_FACTOR) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER( '%' || :ID || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FACTOR":"$FACTOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CLASE_FACTOR" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpfactores/porproyectoyclase/pag">
		<call-query href="getVpfactoresPagPorproyectoyclaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CLASE_FACTOR" query-param="CLASE_FACTOR"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpfactoresNumPorproyectoyclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID,CODIGO, NOMBRE,FACTOR  FROM VP_FACTORES WHERE COMPANIA = :COMPANIA AND ID_PROYECTO = :PROYECTO AND CLASE_FACTOR = :CLASE_FACTOR) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER( '%' || :ID || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CLASE_FACTOR" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpfactores/porproyectoyclase/num">
		<call-query href="getVpfactoresNumPorproyectoyclaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CLASE_FACTOR" query-param="CLASE_FACTOR"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertVpfactores" keyColumns="ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VP_FACTORES (ID, COMPANIA, CODIGO_PROYECTO, CLASE, ID_PROYECTO, NOMBRE, DESCRIPCION, CODIGO, FACTOR, CLASE_FACTOR, DATE_CREATED, CREATED_BY) VALUES (:ID, :COMPANIA, :CODIGO_PROYECTO, :CLASE, :ID_PROYECTO, :NOMBRE, :DESCRIPCION, :CODIGO, :FACTOR, :CLASE_FACTOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ID":"$ID"}]}}		</result>
		<param name="ID" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID_PROYECTO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="0" name="FACTOR" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_FACTOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vpfactores">
		<call-query href="insertVpfactores">
			<with-param name="ID" query-param="ID"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID_PROYECTO" query-param="ID_PROYECTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FACTOR" query-param="FACTOR"/>
			<with-param name="CLASE_FACTOR" query-param="CLASE_FACTOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVpfactores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VP_FACTORES WHERE VP_FACTORES.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vpfactores">
		<call-query href="deleteVpfactores">
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getVpfactoresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID, COMPANIA, CODIGO, NOMBRE, DESCRIPCION, FACTOR  FROM VP_FACTORES WHERE COMPANIA = :COMPANIA AND ID_PROYECTO = :PROYECTO AND CLASE_FACTOR = :CLASE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN FACTOR IS NULL THEN ' ' ELSE UPPER(FACTOR) END)  LIKE UPPER(:FACTOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","FACTOR":"$FACTOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FACTOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpfactores">
		<call-query href="getVpfactoresPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FACTOR" query-param="FACTOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpfactoresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID, COMPANIA, CODIGO, NOMBRE, DESCRIPCION, FACTOR  FROM VP_FACTORES WHERE COMPANIA = :COMPANIA AND ID_PROYECTO = :PROYECTO AND CLASE_FACTOR = :CLASE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN FACTOR IS NULL THEN ' ' ELSE UPPER(FACTOR) END)  LIKE UPPER(:FACTOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FACTOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpfactores/numero">
		<call-query href="getVpfactoresNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FACTOR" query-param="FACTOR"/>

		</call-query>
	</resource>
	<query id="getVpfactoresRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID, COMPANIA, CODIGO_PROYECTO, CLASE, ID_PROYECTO, NOMBRE, DESCRIPCION, CODIGO, FACTOR, CLASE_FACTOR, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM VP_FACTORES WHERE VP_FACTORES.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CODIGO_PROYECTO":"$CODIGO_PROYECTO","CLASE":"$CLASE","ID_PROYECTO":"$ID_PROYECTO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","CODIGO":"$CODIGO","FACTOR":"$FACTOR","CLASE_FACTOR":"$CLASE_FACTOR","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpfactores/data">
		<call-query href="getVpfactoresRegistroQuery">
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateVpfactores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VP_FACTORES SET ID=:ID, COMPANIA=:COMPANIA, CODIGO_PROYECTO=:CODIGO_PROYECTO, CLASE=:CLASE, ID_PROYECTO=:ID_PROYECTO, NOMBRE=:NOMBRE, DESCRIPCION=:DESCRIPCION, CODIGO=:CODIGO, FACTOR=:FACTOR, CLASE_FACTOR=:CLASE_FACTOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VP_FACTORES.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID_PROYECTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FACTOR" sqlType="STRING"/>
		<param name="CLASE_FACTOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vpfactores">
		<call-query href="updateVpfactores">
			<with-param name="ID" query-param="ID"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID_PROYECTO" query-param="ID_PROYECTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FACTOR" query-param="FACTOR"/>
			<with-param name="CLASE_FACTOR" query-param="CLASE_FACTOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>

</data>