		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="CLASEPROBLEMA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spordentrabajo/grillaregistrodelecturas/num">
		<call-query href="getSpordentrabajoNumGrillaRegistroDeLecturasQuery">
