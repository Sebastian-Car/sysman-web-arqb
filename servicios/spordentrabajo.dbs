<data name="spordentrabajo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateSpordentrabajoActualizarRefactorizacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_ORDENTRABAJO SET CAUSALREFAC = '0', DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') ,MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CLASEDOC='PQR' AND CAUSALREFAC IS NULL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spordentrabajo/actualizarrefactorizacion">
		<call-query href="updateSpordentrabajoActualizarRefactorizacion">
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>

		</call-query>
	</resource>
	<query id="getSpordentrabajoPagGrillaRegistroDeLecturasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_ORDENTRABAJO.NUMORDEN, DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'C','Consulta',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'Q','Queja',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'RE','Reclamo',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'R','Recurso de Reposición',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'P','Petición',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'RA','Recurso de Reposición y Subsidiario de Apelación',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'D','Denuncia',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'SD','Solicitud de información de copias de documentos')))))))) TIPOREQUERIMIENTO, SP_ORDENTRABAJO.CODIGORUTA, DECODE(SP_ORDENTRABAJO.PRESENTACION,'V','Verbal',DECODE(SP_ORDENTRABAJO.PRESENTACION,'E','Escrita',DECODE(SP_ORDENTRABAJO.PRESENTACION,'T','Teléfono',''))) PRESENTACION,(CASE SP_ORDENTRABAJO.ENVIOOFICINA WHEN 0 THEN 'false' ELSE 'true' END) ENVIOOFICINA,(CASE SP_ORDENTRABAJO.NECESITAVISITA WHEN 0 THEN 'false' ELSE 'true' END) NECESITAVISITA,(TO_CHAR(SP_ORDENTRABAJO.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD, SP_D_ORDENTRABAJO.PROBLEMA, SP_D_ORDENTRABAJO.SOLUCION, SP_D_ORDENTRABAJO.OBSERVACIONES,(TO_CHAR(SP_D_ORDENTRABAJO.FECHASOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHASOLUCION,(CASE SP_D_ORDENTRABAJO.INDFAVOREMPRESA WHEN 0 THEN 'false' ELSE 'true' END) INDFAVOREMPRESA, SP_ORDENTRABAJO.CLASEDOC, SP_D_ORDENTRABAJO.CLASEPROBLEMA, SP_PROBLEMA.NOMBRE  FROM SP_D_ORDENTRABAJO LEFT JOIN SP_ORDENTRABAJO ON SP_D_ORDENTRABAJO.ORDENTRABAJO = SP_ORDENTRABAJO.NUMORDEN AND SP_D_ORDENTRABAJO.CLASEDOC = SP_ORDENTRABAJO.CLASEDOC AND SP_D_ORDENTRABAJO.COMPANIA = SP_ORDENTRABAJO.COMPANIA INNER JOIN SP_PROBLEMA ON SP_D_ORDENTRABAJO.PROBLEMA = SP_PROBLEMA.CODIGO AND SP_D_ORDENTRABAJO.CLASEPROBLEMA = SP_PROBLEMA.CLASEPROBLEMA AND SP_D_ORDENTRABAJO.COMPANIA = SP_PROBLEMA.COMPANIA WHERE SP_ORDENTRABAJO.CODIGORUTA = :CODIGORUTA AND SP_ORDENTRABAJO.COMPANIA = :COMPANIA AND SP_ORDENTRABAJO.CICLO = :CICLO) WHERE (CASE WHEN NUMORDEN IS NULL THEN ' ' ELSE UPPER(NUMORDEN) END)  LIKE UPPER(:NUMORDEN || '%')  AND (CASE WHEN TIPOREQUERIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOREQUERIMIENTO) END)  LIKE UPPER(:TIPOREQUERIMIENTO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN PRESENTACION IS NULL THEN ' ' ELSE UPPER(PRESENTACION) END)  LIKE UPPER(:PRESENTACION || '%')  AND (CASE WHEN ENVIOOFICINA IS NULL THEN ' ' ELSE UPPER(ENVIOOFICINA) END)  LIKE UPPER(:ENVIOOFICINA || '%')  AND (CASE WHEN NECESITAVISITA IS NULL THEN ' ' ELSE UPPER(NECESITAVISITA) END)  LIKE UPPER(:NECESITAVISITA || '%')  AND (CASE WHEN FECHASOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHASOLICITUD) END)  LIKE UPPER(:FECHASOLICITUD || '%')  AND (CASE WHEN PROBLEMA IS NULL THEN ' ' ELSE UPPER(PROBLEMA) END)  LIKE UPPER(:PROBLEMA || '%')  AND (CASE WHEN SOLUCION IS NULL THEN ' ' ELSE UPPER(SOLUCION) END)  LIKE UPPER( '%' || :SOLUCION || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN FECHASOLUCION IS NULL THEN ' ' ELSE UPPER(FECHASOLUCION) END)  LIKE UPPER( '%' || :FECHASOLUCION || '%')  AND (CASE WHEN INDFAVOREMPRESA IS NULL THEN ' ' ELSE UPPER(INDFAVOREMPRESA) END)  LIKE UPPER(:INDFAVOREMPRESA || '%')  AND (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END)  LIKE UPPER( '%' || :CLASEDOC || '%')  AND (CASE WHEN CLASEPROBLEMA IS NULL THEN ' ' ELSE UPPER(CLASEPROBLEMA) END)  LIKE UPPER(:CLASEPROBLEMA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMORDEN":"$NUMORDEN(type:long)","TIPOREQUERIMIENTO":"$TIPOREQUERIMIENTO","CODIGORUTA":"$CODIGORUTA","PRESENTACION":"$PRESENTACION","ENVIOOFICINA":"$ENVIOOFICINA(type:boolean)","NECESITAVISITA":"$NECESITAVISITA(type:boolean)","FECHASOLICITUD":"$FECHASOLICITUD","PROBLEMA":"$PROBLEMA","SOLUCION":"$SOLUCION","OBSERVACIONES":"$OBSERVACIONES","FECHASOLUCION":"$FECHASOLUCION","INDFAVOREMPRESA":"$INDFAVOREMPRESA(type:boolean)","CLASEDOC":"$CLASEDOC","CLASEPROBLEMA":"$CLASEPROBLEMA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="TIPOREQUERIMIENTO" sqlType="STRING"/>
		<param name="PRESENTACION" sqlType="STRING"/>
		<param name="ENVIOOFICINA" sqlType="STRING"/>
		<param name="NECESITAVISITA" sqlType="STRING"/>
		<param name="FECHASOLICITUD" sqlType="STRING"/>
		<param name="PROBLEMA" sqlType="STRING"/>
		<param name="SOLUCION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="FECHASOLUCION" sqlType="STRING"/>
		<param name="INDFAVOREMPRESA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="CLASEPROBLEMA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spordentrabajo/grillaregistrodelecturas/pag">
		<call-query href="getSpordentrabajoPagGrillaRegistroDeLecturasQuery">
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>
