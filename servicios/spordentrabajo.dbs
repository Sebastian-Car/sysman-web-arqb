	</query>
	<resource method="POST" path="spordentrabajo">
		<call-query href="insertSpordentrabajo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="PRESENTACION" query-param="PRESENTACION"/>
			<with-param name="ENVIOOFICINA" query-param="ENVIOOFICINA"/>
			<with-param name="NECESITAVISITA" query-param="NECESITAVISITA"/>
			<with-param name="DEPENDENCIAENV" query-param="DEPENDENCIAENV"/>
			<with-param name="RECIBIDOPOR" query-param="RECIBIDOPOR"/>
			<with-param name="OPERADOR" query-param="OPERADOR"/>
			<with-param name="AFORADOR" query-param="AFORADOR"/>
			<with-param name="PRIMERAPELLIDO" query-param="PRIMERAPELLIDO"/>
			<with-param name="SEGUNDOAPELLIDO" query-param="SEGUNDOAPELLIDO"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="DIRTECNICA" query-param="DIRTECNICA"/>
			<with-param name="DIRGUIA" query-param="DIRGUIA"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="ORDENGENERADA" query-param="ORDENGENERADA"/>
			<with-param name="REMISION" query-param="REMISION"/>
			<with-param name="RADICADO" query-param="RADICADO"/>
			<with-param name="SOLICITANTE" query-param="SOLICITANTE"/>
			<with-param name="NUMORDENEXT" query-param="NUMORDENEXT"/>
			<with-param name="OFPRESENTACION" query-param="OFPRESENTACION"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="NOREPORTARSUI" query-param="NOREPORTARSUI"/>
			<with-param name="TIPOREQUERIMIENTO" query-param="TIPOREQUERIMIENTO"/>
			<with-param name="NUMORDENT" query-param="NUMORDENT"/>
			<with-param name="CAUSALREFAC" query-param="CAUSALREFAC"/>
			<with-param name="NUM_REFAC" query-param="NUM_REFAC"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="SOLICITANTE_NIT" query-param="SOLICITANTE_NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="SOLICITANTE_TEL" query-param="SOLICITANTE_TEL"/>
			<with-param name="SOLICITANTE_DIR" query-param="SOLICITANTE_DIR"/>
