	<query id="updateSpordentrabajo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_ORDENTRABAJO SET CICLO=:CICLO, CODIGORUTA=:CODIGORUTA, PRESENTACION=:PRESENTACION, ENVIOOFICINA=:ENVIOOFICINA, NECESITAVISITA=:NECESITAVISITA, DEPENDENCIAENV=:DEPENDENCIAENV, RECIBIDOPOR=:RECIBIDOPOR, OPERADOR=:OPERADOR, AFORADOR=:AFORADOR, PRIMERAPELLIDO=:PRIMERAPELLIDO, SEGUNDOAPELLIDO=:SEGUNDOAPELLIDO, NOMBRES=:NOMBRES, DIRTECNICA=:DIRTECNICA, DIRGUIA=:DIRGUIA, TELEFONO=:TELEFONO, ORDENGENERADA=:ORDENGENERADA, REMISION=:REMISION, RADICADO=:RADICADO, SOLICITANTE=:SOLICITANTE, NUMORDENEXT=:NUMORDENEXT, OFPRESENTACION=:OFPRESENTACION, ACTIVO=:ACTIVO, NOREPORTARSUI=:NOREPORTARSUI, TIPOREQUERIMIENTO=:TIPOREQUERIMIENTO, NUMORDENT=:NUMORDENT, CAUSALREFAC=:CAUSALREFAC, NUM_REFAC=:NUM_REFAC, FACTURA=:FACTURA, SOLICITANTE_NIT=:SOLICITANTE_NIT, SUCURSAL=:SUCURSAL, SOLICITANTE_TEL=:SOLICITANTE_TEL, SOLICITANTE_DIR=:SOLICITANTE_DIR, INDENVIARSOLCITUD=:INDENVIARSOLCITUD, INDASIGNADO=:INDASIGNADO, AFORADORSITIO=:AFORADORSITIO, EMAIL=:EMAIL, HORASOLICITUD=TO_DATE(:HORASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), FECHAENVIO=TO_DATE(:FECHAENVIO,'DD/MM/YYYY HH24:MI:SS'), FECHASOLICITUD=TO_DATE(:FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_ORDENTRABAJO.COMPANIA= :KEY_COMPANIA AND SP_ORDENTRABAJO.CLASEDOC= :KEY_CLASEDOC AND SP_ORDENTRABAJO.NUMORDEN= :KEY_NUMORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
