			<with-param name="INDFAVOREMPRESA" query-param="INDFAVOREMPRESA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="CLASEPROBLEMA" query-param="CLASEPROBLEMA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpordentrabajoNumGrillaRegistroDeLecturasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_ORDENTRABAJO.NUMORDEN, DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'C','Consulta',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'Q','Queja',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'RE','Reclamo',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'R','Recurso de Reposición',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'P','Petición',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'RA','Recurso de Reposición y Subsidiario de Apelación',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'D','Denuncia',DECODE(SP_ORDENTRABAJO.TIPOREQUERIMIENTO,'SD','Solicitud de información de copias de documentos')))))))) TIPOREQUERIMIENTO, SP_ORDENTRABAJO.CODIGORUTA, DECODE(SP_ORDENTRABAJO.PRESENTACION,'V','Verbal',DECODE(SP_ORDENTRABAJO.PRESENTACION,'E','Escrita',DECODE(SP_ORDENTRABAJO.PRESENTACION,'T','Teléfono',''))) PRESENTACION,(CASE SP_ORDENTRABAJO.ENVIOOFICINA WHEN 0 THEN 'false' ELSE 'true' END) ENVIOOFICINA,(CASE SP_ORDENTRABAJO.NECESITAVISITA WHEN 0 THEN 'false' ELSE 'true' END) NECESITAVISITA,(TO_CHAR(SP_ORDENTRABAJO.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD, SP_D_ORDENTRABAJO.PROBLEMA, SP_D_ORDENTRABAJO.SOLUCION, SP_D_ORDENTRABAJO.OBSERVACIONES,(TO_CHAR(SP_D_ORDENTRABAJO.FECHASOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHASOLUCION,(CASE SP_D_ORDENTRABAJO.INDFAVOREMPRESA WHEN 0 THEN 'false' ELSE 'true' END) INDFAVOREMPRESA, SP_ORDENTRABAJO.CLASEDOC, SP_D_ORDENTRABAJO.CLASEPROBLEMA, SP_PROBLEMA.NOMBRE  FROM SP_D_ORDENTRABAJO LEFT JOIN SP_ORDENTRABAJO ON SP_D_ORDENTRABAJO.ORDENTRABAJO = SP_ORDENTRABAJO.NUMORDEN AND SP_D_ORDENTRABAJO.CLASEDOC = SP_ORDENTRABAJO.CLASEDOC AND SP_D_ORDENTRABAJO.COMPANIA = SP_ORDENTRABAJO.COMPANIA INNER JOIN SP_PROBLEMA ON SP_D_ORDENTRABAJO.PROBLEMA = SP_PROBLEMA.CODIGO AND SP_D_ORDENTRABAJO.CLASEPROBLEMA = SP_PROBLEMA.CLASEPROBLEMA AND SP_D_ORDENTRABAJO.COMPANIA = SP_PROBLEMA.COMPANIA WHERE SP_ORDENTRABAJO.CODIGORUTA = :CODIGORUTA AND SP_ORDENTRABAJO.COMPANIA = :COMPANIA AND SP_ORDENTRABAJO.CICLO = :CICLO) WHERE (CASE WHEN NUMORDEN IS NULL THEN ' ' ELSE UPPER(NUMORDEN) END)  LIKE UPPER(:NUMORDEN || '%')  AND (CASE WHEN TIPOREQUERIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOREQUERIMIENTO) END)  LIKE UPPER(:TIPOREQUERIMIENTO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN PRESENTACION IS NULL THEN ' ' ELSE UPPER(PRESENTACION) END)  LIKE UPPER(:PRESENTACION || '%')  AND (CASE WHEN ENVIOOFICINA IS NULL THEN ' ' ELSE UPPER(ENVIOOFICINA) END)  LIKE UPPER(:ENVIOOFICINA || '%')  AND (CASE WHEN NECESITAVISITA IS NULL THEN ' ' ELSE UPPER(NECESITAVISITA) END)  LIKE UPPER(:NECESITAVISITA || '%')  AND (CASE WHEN FECHASOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHASOLICITUD) END)  LIKE UPPER(:FECHASOLICITUD || '%')  AND (CASE WHEN PROBLEMA IS NULL THEN ' ' ELSE UPPER(PROBLEMA) END)  LIKE UPPER(:PROBLEMA || '%')  AND (CASE WHEN SOLUCION IS NULL THEN ' ' ELSE UPPER(SOLUCION) END)  LIKE UPPER( '%' || :SOLUCION || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN FECHASOLUCION IS NULL THEN ' ' ELSE UPPER(FECHASOLUCION) END)  LIKE UPPER( '%' || :FECHASOLUCION || '%')  AND (CASE WHEN INDFAVOREMPRESA IS NULL THEN ' ' ELSE UPPER(INDFAVOREMPRESA) END)  LIKE UPPER(:INDFAVOREMPRESA || '%')  AND (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END)  LIKE UPPER( '%' || :CLASEDOC || '%')  AND (CASE WHEN CLASEPROBLEMA IS NULL THEN ' ' ELSE UPPER(CLASEPROBLEMA) END)  LIKE UPPER(:CLASEPROBLEMA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="TIPOREQUERIMIENTO" sqlType="STRING"/>
		<param name="PRESENTACION" sqlType="STRING"/>
