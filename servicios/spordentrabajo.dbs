	<query id="insertSpordentrabajo" keyColumns="COMPANIA,CLASEDOC,NUMORDEN" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_ORDENTRABAJO (COMPANIA, CLASEDOC, NUMORDEN, CICLO, CODIGORUTA, PRESENTACION, ENVIOOFICINA, NECESITAVISITA, DEPENDENCIAENV, RECIBIDOPOR, OPERADOR, AFORADOR, PRIMERAPELLIDO, SEGUNDOAPELLIDO, NOMBRES, DIRTECNICA, DIRGUIA, TELEFONO, ORDENGENERADA, REMISION, RADICADO, SOLICITANTE, NUMORDENEXT, OFPRESENTACION, ACTIVO, NOREPORTARSUI, TIPOREQUERIMIENTO, NUMORDENT, CAUSALREFAC, NUM_REFAC, FACTURA, SOLICITANTE_NIT, SUCURSAL, SOLICITANTE_TEL, SOLICITANTE_DIR, INDENVIARSOLCITUD, INDASIGNADO, AFORADORSITIO, EMAIL, HORASOLICITUD, FECHAENVIO, FECHASOLICITUD, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CLASEDOC, :NUMORDEN, :CICLO, :CODIGORUTA, :PRESENTACION, :ENVIOOFICINA, :NECESITAVISITA, :DEPENDENCIAENV, :RECIBIDOPOR, :OPERADOR, :AFORADOR, :PRIMERAPELLIDO, :SEGUNDOAPELLIDO, :NOMBRES, :DIRTECNICA, :DIRGUIA, :TELEFONO, :ORDENGENERADA, :REMISION, :RADICADO, :SOLICITANTE, :NUMORDENEXT, :OFPRESENTACION, :ACTIVO, :NOREPORTARSUI, :TIPOREQUERIMIENTO, :NUMORDENT, :CAUSALREFAC, :NUM_REFAC, :FACTURA, :SOLICITANTE_NIT, :SUCURSAL, :SOLICITANTE_TEL, :SOLICITANTE_DIR, :INDENVIARSOLCITUD, :INDASIGNADO, :AFORADORSITIO, :EMAIL, TO_DATE(:HORASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAENVIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEDOC":"$CLASEDOC","KEY_NUMORDEN":"$NUMORDEN(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param defaultValue="" name="PRESENTACION" sqlType="STRING"/>
		<param defaultValue="0" name="ENVIOOFICINA" sqlType="STRING"/>
		<param defaultValue="0" name="NECESITAVISITA" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIAENV" sqlType="STRING"/>
		<param defaultValue="" name="RECIBIDOPOR" sqlType="STRING"/>
		<param defaultValue="" name="OPERADOR" sqlType="STRING"/>
		<param defaultValue="" name="AFORADOR" sqlType="STRING"/>
		<param defaultValue="" name="PRIMERAPELLIDO" sqlType="STRING"/>
		<param defaultValue="" name="SEGUNDOAPELLIDO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRES" sqlType="STRING"/>
		<param defaultValue="" name="DIRTECNICA" sqlType="STRING"/>
		<param defaultValue="" name="DIRGUIA" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO" sqlType="STRING"/>
		<param defaultValue="0" name="ORDENGENERADA" sqlType="STRING"/>
		<param defaultValue="" name="REMISION" sqlType="STRING"/>
		<param defaultValue="" name="RADICADO" sqlType="STRING"/>
		<param defaultValue="" name="SOLICITANTE" sqlType="STRING"/>
		<param defaultValue="0" name="NUMORDENEXT" sqlType="STRING"/>
		<param defaultValue="" name="OFPRESENTACION" sqlType="STRING"/>
		<param defaultValue="0" name="ACTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="NOREPORTARSUI" sqlType="STRING"/>
		<param defaultValue="" name="TIPOREQUERIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="NUMORDENT" sqlType="STRING"/>
		<param defaultValue="" name="CAUSALREFAC" sqlType="STRING"/>
		<param defaultValue="0" name="NUM_REFAC" sqlType="STRING"/>
		<param defaultValue="0" name="FACTURA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="SOLICITANTE_NIT" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="SOLICITANTE_TEL" sqlType="STRING"/>
		<param defaultValue="" name="SOLICITANTE_DIR" sqlType="STRING"/>
		<param defaultValue="0" name="INDENVIARSOLCITUD" sqlType="STRING"/>
		<param defaultValue="0" name="INDASIGNADO" sqlType="STRING"/>
		<param defaultValue="" name="AFORADORSITIO" sqlType="STRING"/>
		<param defaultValue="" name="EMAIL" sqlType="STRING"/>
		<param defaultValue="" name="HORASOLICITUD" sqlType="STRING"/>
