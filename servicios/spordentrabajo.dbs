			<with-param name="EMAIL" query-param="EMAIL"/>
			<with-param name="HORASOLICITUD" query-param="HORASOLICITUD"/>
			<with-param name="FECHAENVIO" query-param="FECHAENVIO"/>
			<with-param name="FECHASOLICITUD" query-param="FECHASOLICITUD"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="getSpordentrabajoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_ORDENTRABAJO.COMPANIA, SP_ORDENTRABAJO.CLASEDOC, SP_ORDENTRABAJO.NUMORDEN, SP_ORDENTRABAJO.CICLO, SP_ORDENTRABAJO.CODIGORUTA, SP_ORDENTRABAJO.AFORADOR, SP_USUARIO.CODIGOINTERNO,(CASE SP_ORDENTRABAJO.INDASIGNADO WHEN 0 THEN 'false' ELSE 'true' END) INDASIGNADO FROM SP_ORDENTRABAJO INNER JOIN SP_USUARIO ON SP_ORDENTRABAJO.COMPANIA = SP_USUARIO.COMPANIA AND SP_ORDENTRABAJO.CICLO = SP_USUARIO.CICLO AND SP_ORDENTRABAJO.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_ORDENTRABAJO.COMPANIA = :COMPANIA AND SP_ORDENTRABAJO.CLASEDOC = :CLASEDOC ORDER BY SP_ORDENTRABAJO.NUMORDEN DESC) WHERE (CASE WHEN NUMORDEN IS NULL THEN ' ' ELSE UPPER(NUMORDEN) END)  LIKE UPPER(:NUMORDEN || '%')  AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER(:CICLO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN AFORADOR IS NULL THEN ' ' ELSE UPPER(AFORADOR) END)  LIKE UPPER(:AFORADOR || '%')  AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END)  LIKE UPPER(:CODIGOINTERNO || '%')  AND (CASE WHEN INDASIGNADO IS NULL THEN ' ' ELSE UPPER(INDASIGNADO) END)  LIKE UPPER( '%' || :INDASIGNADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEDOC":"$CLASEDOC","NUMORDEN":"$NUMORDEN(type:long)","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","AFORADOR":"$AFORADOR","CODIGOINTERNO":"$CODIGOINTERNO","INDASIGNADO":"$INDASIGNADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="AFORADOR" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="INDASIGNADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spordentrabajo">
		<call-query href="getSpordentrabajoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="AFORADOR" query-param="AFORADOR"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="INDASIGNADO" query-param="INDASIGNADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpordentrabajoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_ORDENTRABAJO.COMPANIA, SP_ORDENTRABAJO.CLASEDOC, SP_ORDENTRABAJO.NUMORDEN, SP_ORDENTRABAJO.CICLO, SP_ORDENTRABAJO.CODIGORUTA, SP_ORDENTRABAJO.AFORADOR, SP_USUARIO.CODIGOINTERNO,(CASE SP_ORDENTRABAJO.INDASIGNADO WHEN 0 THEN 'false' ELSE 'true' END) INDASIGNADO FROM SP_ORDENTRABAJO INNER JOIN SP_USUARIO ON SP_ORDENTRABAJO.COMPANIA = SP_USUARIO.COMPANIA AND SP_ORDENTRABAJO.CICLO = SP_USUARIO.CICLO AND SP_ORDENTRABAJO.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_ORDENTRABAJO.COMPANIA = :COMPANIA AND SP_ORDENTRABAJO.CLASEDOC = :CLASEDOC ORDER BY SP_ORDENTRABAJO.NUMORDEN DESC) WHERE (CASE WHEN NUMORDEN IS NULL THEN ' ' ELSE UPPER(NUMORDEN) END)  LIKE UPPER(:NUMORDEN || '%')  AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER( '%' || :CICLO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN AFORADOR IS NULL THEN ' ' ELSE UPPER(AFORADOR) END)  LIKE UPPER( '%' || :AFORADOR || '%')  AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END)  LIKE UPPER( '%' || :CODIGOINTERNO || '%')  AND (CASE WHEN INDASIGNADO IS NULL THEN ' ' ELSE UPPER(INDASIGNADO) END)  LIKE UPPER( '%' || :INDASIGNADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="AFORADOR" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="INDASIGNADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spordentrabajo/numero">
		<call-query href="getSpordentrabajoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="AFORADOR" query-param="AFORADOR"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="INDASIGNADO" query-param="INDASIGNADO"/>

		</call-query>
	</resource>
	<query id="getSpordentrabajoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_ORDENTRABAJO.COMPANIA, SP_ORDENTRABAJO.CLASEDOC, SP_ORDENTRABAJO.NUMORDEN, SP_ORDENTRABAJO.CICLO, SP_ORDENTRABAJO.CODIGORUTA, SP_ORDENTRABAJO.PRESENTACION,(CASE SP_ORDENTRABAJO.ENVIOOFICINA WHEN 0 THEN 'false' ELSE 'true' END) ENVIOOFICINA,(CASE SP_ORDENTRABAJO.NECESITAVISITA WHEN 0 THEN 'false' ELSE 'true' END) NECESITAVISITA, SP_ORDENTRABAJO.DEPENDENCIAENV, SP_ORDENTRABAJO.RECIBIDOPOR, SP_ORDENTRABAJO.OPERADOR, SP_ORDENTRABAJO.AFORADOR, SP_ORDENTRABAJO.PRIMERAPELLIDO, SP_ORDENTRABAJO.SEGUNDOAPELLIDO, SP_ORDENTRABAJO.NOMBRES, SP_ORDENTRABAJO.DIRTECNICA, SP_ORDENTRABAJO.DIRGUIA, SP_ORDENTRABAJO.TELEFONO,(CASE SP_ORDENTRABAJO.ORDENGENERADA WHEN 0 THEN 'false' ELSE 'true' END) ORDENGENERADA, SP_ORDENTRABAJO.REMISION, SP_ORDENTRABAJO.RADICADO, SP_ORDENTRABAJO.SOLICITANTE, SP_ORDENTRABAJO.NUMORDENEXT, SP_ORDENTRABAJO.OFPRESENTACION,(CASE SP_ORDENTRABAJO.ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,(CASE SP_ORDENTRABAJO.NOREPORTARSUI WHEN 0 THEN 'false' ELSE 'true' END) NOREPORTARSUI, SP_ORDENTRABAJO.TIPOREQUERIMIENTO, SP_ORDENTRABAJO.NUMORDENT, SP_ORDENTRABAJO.CAUSALREFAC, SP_ORDENTRABAJO.NUM_REFAC, SP_ORDENTRABAJO.FACTURA, SP_ORDENTRABAJO.SOLICITANTE_NIT, SP_ORDENTRABAJO.SUCURSAL, SP_ORDENTRABAJO.SOLICITANTE_TEL, SP_ORDENTRABAJO.SOLICITANTE_DIR,(CASE SP_ORDENTRABAJO.INDENVIARSOLCITUD WHEN 0 THEN 'false' ELSE 'true' END) INDENVIARSOLCITUD,(CASE SP_ORDENTRABAJO.INDASIGNADO WHEN 0 THEN 'false' ELSE 'true' END) INDASIGNADO, SP_ORDENTRABAJO.AFORADORSITIO, SP_ORDENTRABAJO.EMAIL, SP_ORDENTRABAJO.CREATED_BY, SP_ORDENTRABAJO.MODIFIED_BY,(TO_CHAR(SP_ORDENTRABAJO.HORASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) HORASOLICITUD,(TO_CHAR(SP_ORDENTRABAJO.FECHAENVIO,'DD/MM/YYYY HH24:MI:SS')) FECHAENVIO,(TO_CHAR(SP_ORDENTRABAJO.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD,(TO_CHAR(SP_ORDENTRABAJO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(SP_ORDENTRABAJO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, TERCERO.NOMBRE NOMBREAFORADOR, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.PERIODO PERIODOUSUARIO, SP_USUARIO.ANO ANOUSUARIO, SP_USUARIO.AFORADOR ULTIMOAFORADOR  FROM SP_ORDENTRABAJO INNER JOIN SP_USUARIO ON SP_ORDENTRABAJO.COMPANIA = SP_USUARIO.COMPANIA AND SP_ORDENTRABAJO.CICLO = SP_USUARIO.CICLO AND SP_ORDENTRABAJO.CODIGORUTA = SP_USUARIO.CODIGORUTA LEFT JOIN SP_AFORADORES ON SP_ORDENTRABAJO.COMPANIA = SP_AFORADORES.COMPANIA AND SP_ORDENTRABAJO.AFORADOR = SP_AFORADORES.CODIGO LEFT JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = SP_AFORADORES.SUCURSAL WHERE SP_ORDENTRABAJO.COMPANIA= :KEY_COMPANIA AND SP_ORDENTRABAJO.CLASEDOC= :KEY_CLASEDOC AND SP_ORDENTRABAJO.NUMORDEN= :KEY_NUMORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEDOC":"$CLASEDOC","NUMORDEN":"$NUMORDEN(type:long)","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","PRESENTACION":"$PRESENTACION","ENVIOOFICINA":"$ENVIOOFICINA(type:boolean)","NECESITAVISITA":"$NECESITAVISITA(type:boolean)","DEPENDENCIAENV":"$DEPENDENCIAENV","RECIBIDOPOR":"$RECIBIDOPOR","OPERADOR":"$OPERADOR","AFORADOR":"$AFORADOR","PRIMERAPELLIDO":"$PRIMERAPELLIDO","SEGUNDOAPELLIDO":"$SEGUNDOAPELLIDO","NOMBRES":"$NOMBRES","DIRTECNICA":"$DIRTECNICA","DIRGUIA":"$DIRGUIA","TELEFONO":"$TELEFONO","ORDENGENERADA":"$ORDENGENERADA(type:boolean)","REMISION":"$REMISION","RADICADO":"$RADICADO","SOLICITANTE":"$SOLICITANTE","NUMORDENEXT":"$NUMORDENEXT","OFPRESENTACION":"$OFPRESENTACION","ACTIVO":"$ACTIVO(type:boolean)","NOREPORTARSUI":"$NOREPORTARSUI(type:boolean)","TIPOREQUERIMIENTO":"$TIPOREQUERIMIENTO","NUMORDENT":"$NUMORDENT","CAUSALREFAC":"$CAUSALREFAC","NUM_REFAC":"$NUM_REFAC","FACTURA":"$FACTURA","SOLICITANTE_NIT":"$SOLICITANTE_NIT","SUCURSAL":"$SUCURSAL","SOLICITANTE_TEL":"$SOLICITANTE_TEL","SOLICITANTE_DIR":"$SOLICITANTE_DIR","INDENVIARSOLCITUD":"$INDENVIARSOLCITUD(type:boolean)","INDASIGNADO":"$INDASIGNADO(type:boolean)","AFORADORSITIO":"$AFORADORSITIO","EMAIL":"$EMAIL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","HORASOLICITUD":"$HORASOLICITUD","FECHAENVIO":"$FECHAENVIO","FECHASOLICITUD":"$FECHASOLICITUD","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","NOMBREAFORADOR":"$NOMBREAFORADOR","CODIGOINTERNO":"$CODIGOINTERNO","PERIODOUSUARIO":"$PERIODOUSUARIO","ANOUSUARIO":"$ANOUSUARIO(type:integer)","ULTIMOAFORADOR":"$ULTIMOAFORADOR"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEDOC" sqlType="STRING"/>
		<param name="KEY_NUMORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spordentrabajo/data">
