<data name="inversionesrf" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertInversionesrf" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INVERSIONRF (COMPANIA, CODIGO, FONDO, ANO, ORIGENRECURSOS, ENTIDADEMISORA, VALORNOMINAL, TASA, VENCIDO, ANTICIPADO, RENDIMIENTOSFINANCIEROS, FECHACOLOCACION, FECHAVENCIMIENTO, SALDOFINAL, REINVERSION, TIPOINVERSION, MONEDA, FECHA_COMPRA, TIPO_INV_FUT, PLAZO, INVERSION_VENDIDA, VALOR_VENTA, FECHA_VENTA, TASA_VENTA, TASA_COMPRA, INTERMEDIARIA, BANCO, DESCRIPCION, PERIODICIDAD, TIPO_MEN, NUMERO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :FONDO, :ANO, :ORIGENRECURSOS, :ENTIDADEMISORA, :VALORNOMINAL, :TASA, :VENCIDO, :ANTICIPADO, :RENDIMIENTOSFINANCIEROS, TO_DATE(:FECHACOLOCACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :SALDOFINAL, :REINVERSION, :TIPOINVERSION, :MONEDA, TO_DATE(:FECHA_COMPRA,'DD/MM/YYYY HH24:MI:SS'), :TIPO_INV_FUT, :PLAZO, :INVERSION_VENDIDA, :VALOR_VENTA, TO_DATE(:FECHA_VENTA,'DD/MM/YYYY HH24:MI:SS'), :TASA_VENTA, :TASA_COMPRA, :INTERMEDIARIA, :BANCO, :DESCRIPCION, :PERIODICIDAD, :TIPO_MEN, :NUMERO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param defaultValue="" name="ANO" sqlType="STRING"/>
		<param name="ORIGENRECURSOS" sqlType="STRING"/>
		<param defaultValue="" name="ENTIDADEMISORA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORNOMINAL" sqlType="STRING"/>
		<param defaultValue="0" name="TASA" sqlType="STRING"/>
		<param defaultValue="0" name="VENCIDO" sqlType="STRING"/>
		<param defaultValue="0" name="ANTICIPADO" sqlType="STRING"/>
		<param defaultValue="0" name="RENDIMIENTOSFINANCIEROS" sqlType="STRING"/>
		<param defaultValue="" name="FECHACOLOCACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="SALDOFINAL" sqlType="STRING"/>
		<param defaultValue="0" name="REINVERSION" sqlType="STRING"/>
		<param defaultValue="" name="TIPOINVERSION" sqlType="STRING"/>
		<param defaultValue="COP" name="MONEDA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_COMPRA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_INV_FUT" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZO" sqlType="STRING"/>
		<param defaultValue="0" name="INVERSION_VENDIDA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_VENTA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_VENTA" sqlType="STRING"/>
		<param defaultValue="0" name="TASA_VENTA" sqlType="STRING"/>
		<param defaultValue="0" name="TASA_COMPRA" sqlType="STRING"/>
		<param defaultValue="" name="INTERMEDIARIA" sqlType="STRING"/>
		<param defaultValue="" name="BANCO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="PERIODICIDAD" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_MEN" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="inversionesrf">
		<call-query href="insertInversionesrf">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ORIGENRECURSOS" query-param="ORIGENRECURSOS"/>
			<with-param name="ENTIDADEMISORA" query-param="ENTIDADEMISORA"/>
			<with-param name="VALORNOMINAL" query-param="VALORNOMINAL"/>
			<with-param name="TASA" query-param="TASA"/>
			<with-param name="VENCIDO" query-param="VENCIDO"/>
			<with-param name="ANTICIPADO" query-param="ANTICIPADO"/>
			<with-param name="RENDIMIENTOSFINANCIEROS" query-param="RENDIMIENTOSFINANCIEROS"/>
			<with-param name="FECHACOLOCACION" query-param="FECHACOLOCACION"/>
			<with-param name="FECHAVENCIMIENTO" query-param="FECHAVENCIMIENTO"/>
			<with-param name="SALDOFINAL" query-param="SALDOFINAL"/>
			<with-param name="REINVERSION" query-param="REINVERSION"/>
			<with-param name="TIPOINVERSION" query-param="TIPOINVERSION"/>
			<with-param name="MONEDA" query-param="MONEDA"/>
			<with-param name="FECHA_COMPRA" query-param="FECHA_COMPRA"/>
			<with-param name="TIPO_INV_FUT" query-param="TIPO_INV_FUT"/>
			<with-param name="PLAZO" query-param="PLAZO"/>
			<with-param name="INVERSION_VENDIDA" query-param="INVERSION_VENDIDA"/>
			<with-param name="VALOR_VENTA" query-param="VALOR_VENTA"/>
			<with-param name="FECHA_VENTA" query-param="FECHA_VENTA"/>
			<with-param name="TASA_VENTA" query-param="TASA_VENTA"/>
			<with-param name="TASA_COMPRA" query-param="TASA_COMPRA"/>
			<with-param name="INTERMEDIARIA" query-param="INTERMEDIARIA"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="TIPO_MEN" query-param="TIPO_MEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteInversionesrf" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM INVERSIONRF WHERE INVERSIONRF.COMPANIA= :KEY_COMPANIA AND INVERSIONRF.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="inversionesrf">
		<call-query href="deleteInversionesrf">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getInversionesrfPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  INVERSIONRF.COMPANIA,INVERSIONRF.CODIGO,INVERSIONRF.FONDO,INVERSIONRF.ORIGENRECURSOS,FUENTE_RECURSOS.NOMBRE NOMBRERECURSO,TO_CHAR(INVERSIONRF.FECHACOLOCACION, 'DD/MM/YYYY')FECHACOLOCACION,TO_CHAR(INVERSIONRF.FECHAVENCIMIENTO , 'DD/MM/YYYY')FECHAVENCIMIENTO,TO_CHAR(INVERSIONRF.FECHA_COMPRA, 'DD/MM/YYYY')FECHA_COMPRA  FROM INVERSIONRF INNER JOIN FUENTE_RECURSOS ON INVERSIONRF.COMPANIA = FUENTE_RECURSOS.COMPANIA AND INVERSIONRF.ANO = FUENTE_RECURSOS.ANO AND INVERSIONRF.ORIGENRECURSOS = FUENTE_RECURSOS.CODIGO WHERE INVERSIONRF.COMPANIA = :COMPANIA ORDER BY INVERSIONRF.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FONDO IS NULL THEN ' ' ELSE UPPER(FONDO) END)  LIKE UPPER( '%' || :FONDO || '%')  AND (CASE WHEN NOMBRERECURSO IS NULL THEN ' ' ELSE UPPER(NOMBRERECURSO) END)  LIKE UPPER( '%' || :NOMBRERECURSO || '%')  AND (CASE WHEN FECHACOLOCACION IS NULL THEN ' ' ELSE UPPER(FECHACOLOCACION) END)  LIKE UPPER( '%' || :FECHACOLOCACION || '%')  AND (CASE WHEN FECHAVENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAVENCIMIENTO) END)  LIKE UPPER( '%' || :FECHAVENCIMIENTO || '%')  AND (CASE WHEN FECHA_COMPRA IS NULL THEN ' ' ELSE UPPER(FECHA_COMPRA) END)  LIKE UPPER( '%' || :FECHA_COMPRA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","FONDO":"$FONDO","ORIGENRECURSOS":"$ORIGENRECURSOS","NOMBRERECURSO":"$NOMBRERECURSO","FECHACOLOCACION":"$FECHACOLOCACION","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","FECHA_COMPRA":"$FECHA_COMPRA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="NOMBRERECURSO" sqlType="STRING"/>
		<param name="FECHACOLOCACION" sqlType="STRING"/>
		<param name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param name="FECHA_COMPRA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inversionesrf">
		<call-query href="getInversionesrfPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="NOMBRERECURSO" query-param="NOMBRERECURSO"/>
			<with-param name="FECHACOLOCACION" query-param="FECHACOLOCACION"/>
			<with-param name="FECHAVENCIMIENTO" query-param="FECHAVENCIMIENTO"/>
			<with-param name="FECHA_COMPRA" query-param="FECHA_COMPRA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInversionesrfNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  INVERSIONRF.COMPANIA,INVERSIONRF.CODIGO,INVERSIONRF.FONDO,INVERSIONRF.ORIGENRECURSOS,FUENTE_RECURSOS.NOMBRE NOMBRERECURSO,TO_CHAR(INVERSIONRF.FECHACOLOCACION, 'DD/MM/YYYY')FECHACOLOCACION,TO_CHAR(INVERSIONRF.FECHAVENCIMIENTO , 'DD/MM/YYYY')FECHAVENCIMIENTO,TO_CHAR(INVERSIONRF.FECHA_COMPRA, 'DD/MM/YYYY')FECHA_COMPRA  FROM INVERSIONRF INNER JOIN FUENTE_RECURSOS ON INVERSIONRF.COMPANIA = FUENTE_RECURSOS.COMPANIA AND INVERSIONRF.ANO = FUENTE_RECURSOS.ANO AND INVERSIONRF.ORIGENRECURSOS = FUENTE_RECURSOS.CODIGO WHERE INVERSIONRF.COMPANIA = :COMPANIA ORDER BY INVERSIONRF.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN FONDO IS NULL THEN ' ' ELSE UPPER(FONDO) END)  LIKE UPPER( '%' || :FONDO || '%')  AND (CASE WHEN NOMBRERECURSO IS NULL THEN ' ' ELSE UPPER(NOMBRERECURSO) END)  LIKE UPPER( '%' || :NOMBRERECURSO || '%')  AND (CASE WHEN FECHACOLOCACION IS NULL THEN ' ' ELSE UPPER(FECHACOLOCACION) END)  LIKE UPPER( '%' || :FECHACOLOCACION || '%')  AND (CASE WHEN FECHAVENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAVENCIMIENTO) END)  LIKE UPPER( '%' || :FECHAVENCIMIENTO || '%')  AND (CASE WHEN FECHA_COMPRA IS NULL THEN ' ' ELSE UPPER(FECHA_COMPRA) END)  LIKE UPPER( '%' || :FECHA_COMPRA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="NOMBRERECURSO" sqlType="STRING"/>
		<param name="FECHACOLOCACION" sqlType="STRING"/>
		<param name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param name="FECHA_COMPRA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inversionesrf/numero">
		<call-query href="getInversionesrfNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="NOMBRERECURSO" query-param="NOMBRERECURSO"/>
			<with-param name="FECHACOLOCACION" query-param="FECHACOLOCACION"/>
			<with-param name="FECHAVENCIMIENTO" query-param="FECHAVENCIMIENTO"/>
			<with-param name="FECHA_COMPRA" query-param="FECHA_COMPRA"/>

		</call-query>
	</resource>
	<query id="getInversionesrfRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  INVERSIONRF.COMPANIA,INVERSIONRF.CODIGO,INVERSIONRF.FONDO,INVERSIONRF.ANO,INVERSIONRF.ORIGENRECURSOS,INVERSIONRF.ENTIDADEMISORA, INVERSIONRF.VALORNOMINAL,INVERSIONRF.TASA,INVERSIONRF.VENCIDO,INVERSIONRF.ANTICIPADO,INVERSIONRF.RENDIMIENTOSFINANCIEROS,(TO_CHAR(INVERSIONRF.FECHACOLOCACION,'DD/MM/YYYY HH24:MI:SS')) FECHACOLOCACION,(TO_CHAR(INVERSIONRF.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO,INVERSIONRF.SALDOFINAL,(CASE INVERSIONRF.REINVERSION WHEN 0 THEN 'false' ELSE 'true' END) REINVERSION,INVERSIONRF.TIPOINVERSION, INVERSIONRF.MONEDA,(TO_CHAR(INVERSIONRF.FECHA_COMPRA,'DD/MM/YYYY HH24:MI:SS')) FECHA_COMPRA,INVERSIONRF.TIPO_INV_FUT,INVERSIONRF.ENCARGO_FIDUCIARIO,INVERSIONRF.PLAZO,(CASE INVERSIONRF.INVERSION_VENDIDA WHEN 0 THEN 'false' ELSE 'true' END) INVERSION_VENDIDA,INVERSIONRF.VALOR_VENTA,(TO_CHAR(INVERSIONRF.FECHA_VENTA,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENTA,INVERSIONRF.TASA_VENTA,INVERSIONRF.TASA_COMPRA, INVERSIONRF.VALOR_PAGADO,INVERSIONRF.INTERMEDIARIA,INVERSIONRF.BANCO,INVERSIONRF.DESCRIPCION,INVERSIONRF.PERIODICIDAD, INVERSIONRF.TIPO_MEN,INVERSIONRF.NUMERO,(TO_CHAR(INVERSIONRF.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,INVERSIONRF.CREATED_BY,(TO_CHAR(INVERSIONRF.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, INVERSIONRF.MODIFIED_BY  FROM INVERSIONRF WHERE INVERSIONRF.COMPANIA= :KEY_COMPANIA AND INVERSIONRF.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","FONDO":"$FONDO","ANO":"$ANO(type:integer)","ORIGENRECURSOS":"$ORIGENRECURSOS","ENTIDADEMISORA":"$ENTIDADEMISORA","VALORNOMINAL":"$VALORNOMINAL","TASA":"$TASA","VENCIDO":"$VENCIDO","ANTICIPADO":"$ANTICIPADO","RENDIMIENTOSFINANCIEROS":"$RENDIMIENTOSFINANCIEROS","FECHACOLOCACION":"$FECHACOLOCACION","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","SALDOFINAL":"$SALDOFINAL","REINVERSION":"$REINVERSION(type:boolean)","TIPOINVERSION":"$TIPOINVERSION(type:integer)","MONEDA":"$MONEDA","FECHA_COMPRA":"$FECHA_COMPRA","TIPO_INV_FUT":"$TIPO_INV_FUT","ENCARGO_FIDUCIARIO":"$ENCARGO_FIDUCIARIO","PLAZO":"$PLAZO(type:integer)","INVERSION_VENDIDA":"$INVERSION_VENDIDA(type:boolean)","VALOR_VENTA":"$VALOR_VENTA","FECHA_VENTA":"$FECHA_VENTA","TASA_VENTA":"$TASA_VENTA","TASA_COMPRA":"$TASA_COMPRA","VALOR_PAGADO":"$VALOR_PAGADO","INTERMEDIARIA":"$INTERMEDIARIA","BANCO":"$BANCO","DESCRIPCION":"$DESCRIPCION","PERIODICIDAD":"$PERIODICIDAD(type:integer)","TIPO_MEN":"$TIPO_MEN","NUMERO":"$NUMERO(type:long)","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inversionesrf/data">
		<call-query href="getInversionesrfRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateInversionesrf" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVERSIONRF SET FONDO=:FONDO, ANO=:ANO, ORIGENRECURSOS=:ORIGENRECURSOS, ENTIDADEMISORA=:ENTIDADEMISORA, VALORNOMINAL=:VALORNOMINAL, TASA=:TASA, VENCIDO=:VENCIDO, ANTICIPADO=:ANTICIPADO, RENDIMIENTOSFINANCIEROS=:RENDIMIENTOSFINANCIEROS, FECHACOLOCACION=TO_DATE(:FECHACOLOCACION,'DD/MM/YYYY HH24:MI:SS'), FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), SALDOFINAL=:SALDOFINAL, REINVERSION=:REINVERSION, TIPOINVERSION=:TIPOINVERSION, MONEDA=:MONEDA, FECHA_COMPRA=TO_DATE(:FECHA_COMPRA,'DD/MM/YYYY HH24:MI:SS'), TIPO_INV_FUT=:TIPO_INV_FUT, PLAZO=:PLAZO, INVERSION_VENDIDA=:INVERSION_VENDIDA, VALOR_VENTA=:VALOR_VENTA, FECHA_VENTA=TO_DATE(:FECHA_VENTA,'DD/MM/YYYY HH24:MI:SS'), TASA_VENTA=:TASA_VENTA, TASA_COMPRA=:TASA_COMPRA, INTERMEDIARIA=:INTERMEDIARIA, BANCO=:BANCO, DESCRIPCION=:DESCRIPCION, PERIODICIDAD=:PERIODICIDAD, TIPO_MEN=:TIPO_MEN, NUMERO=:NUMERO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE INVERSIONRF.COMPANIA= :KEY_COMPANIA AND INVERSIONRF.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FONDO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ORIGENRECURSOS" sqlType="STRING"/>
		<param name="ENTIDADEMISORA" sqlType="STRING"/>
		<param name="VALORNOMINAL" sqlType="STRING"/>
		<param name="TASA" sqlType="STRING"/>
		<param name="VENCIDO" sqlType="STRING"/>
		<param name="ANTICIPADO" sqlType="STRING"/>
		<param name="RENDIMIENTOSFINANCIEROS" sqlType="STRING"/>
		<param name="FECHACOLOCACION" sqlType="STRING"/>
		<param name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param name="SALDOFINAL" sqlType="STRING"/>
		<param name="REINVERSION" sqlType="STRING"/>
		<param name="TIPOINVERSION" sqlType="STRING"/>
		<param name="MONEDA" sqlType="STRING"/>
		<param name="FECHA_COMPRA" sqlType="STRING"/>
		<param name="TIPO_INV_FUT" sqlType="STRING"/>
		<param name="PLAZO" sqlType="STRING"/>
		<param name="INVERSION_VENDIDA" sqlType="STRING"/>
		<param name="VALOR_VENTA" sqlType="STRING"/>
		<param name="FECHA_VENTA" sqlType="STRING"/>
		<param name="TASA_VENTA" sqlType="STRING"/>
		<param name="TASA_COMPRA" sqlType="STRING"/>
		<param name="INTERMEDIARIA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PERIODICIDAD" sqlType="STRING"/>
		<param name="TIPO_MEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="inversionesrf">
		<call-query href="updateInversionesrf">
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ORIGENRECURSOS" query-param="ORIGENRECURSOS"/>
			<with-param name="ENTIDADEMISORA" query-param="ENTIDADEMISORA"/>
			<with-param name="VALORNOMINAL" query-param="VALORNOMINAL"/>
			<with-param name="TASA" query-param="TASA"/>
			<with-param name="VENCIDO" query-param="VENCIDO"/>
			<with-param name="ANTICIPADO" query-param="ANTICIPADO"/>
			<with-param name="RENDIMIENTOSFINANCIEROS" query-param="RENDIMIENTOSFINANCIEROS"/>
			<with-param name="FECHACOLOCACION" query-param="FECHACOLOCACION"/>
			<with-param name="FECHAVENCIMIENTO" query-param="FECHAVENCIMIENTO"/>
			<with-param name="SALDOFINAL" query-param="SALDOFINAL"/>
			<with-param name="REINVERSION" query-param="REINVERSION"/>
			<with-param name="TIPOINVERSION" query-param="TIPOINVERSION"/>
			<with-param name="MONEDA" query-param="MONEDA"/>
			<with-param name="FECHA_COMPRA" query-param="FECHA_COMPRA"/>
			<with-param name="TIPO_INV_FUT" query-param="TIPO_INV_FUT"/>
			<with-param name="PLAZO" query-param="PLAZO"/>
			<with-param name="INVERSION_VENDIDA" query-param="INVERSION_VENDIDA"/>
			<with-param name="VALOR_VENTA" query-param="VALOR_VENTA"/>
			<with-param name="FECHA_VENTA" query-param="FECHA_VENTA"/>
			<with-param name="TASA_VENTA" query-param="TASA_VENTA"/>
			<with-param name="TASA_COMPRA" query-param="TASA_COMPRA"/>
			<with-param name="INTERMEDIARIA" query-param="INTERMEDIARIA"/>
