<data name="eslocaliza" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEslocalizaPagGrillasinbarrioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_LOCALIZA.COMPANIA, ES_LOCALIZA.COD_ESTUDIO, ES_LOCALIZA.PAIS, ES_LOCALIZA.DEPARTAMENTO, ES_LOCALIZA.CIUDAD, ES_LOCALIZA.CODIGO, ES_LOCALIZA.UBICACION, PAISES.NOMBRE NOMBREPAIS, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, CIUDAD.NOMBRE NOMBRECIUDAD  FROM ES_LOCALIZA INNER JOIN PAISES ON ES_LOCALIZA.PAIS = PAISES.PAIS INNER JOIN DEPARTAMENTO ON ES_LOCALIZA.PAIS = DEPARTAMENTO.PAIS AND ES_LOCALIZA.DEPARTAMENTO = DEPARTAMENTO.CODIGO INNER JOIN CIUDAD ON ES_LOCALIZA.PAIS = CIUDAD.PAIS AND ES_LOCALIZA.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND ES_LOCALIZA.CIUDAD = CIUDAD.CODIGO WHERE COMPANIA = :COMPANIA AND ES_LOCALIZA.COD_ESTUDIO = :CODESTUDIO) WHERE (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END)  LIKE UPPER( '%' || :UBICACION || '%')  AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END)  LIKE UPPER( '%' || :NOMBREPAIS || '%')  AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END)  LIKE UPPER( '%' || :NOMBREDEPARTAMENTO || '%')  AND (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END)  LIKE UPPER( '%' || :NOMBRECIUDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","CODIGO":"$CODIGO","UBICACION":"$UBICACION","NOMBREPAIS":"$NOMBREPAIS","NOMBREDEPARTAMENTO":"$NOMBREDEPARTAMENTO","NOMBRECIUDAD":"$NOMBRECIUDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="eslocaliza/grillasinbarrio/pag">
		<call-query href="getEslocalizaPagGrillasinbarrioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="NOMBREPAIS" query-param="NOMBREPAIS"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEslocalizaNumGrillasinbarrioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_LOCALIZA.COMPANIA, ES_LOCALIZA.COD_ESTUDIO, ES_LOCALIZA.PAIS, ES_LOCALIZA.DEPARTAMENTO, ES_LOCALIZA.CIUDAD, ES_LOCALIZA.CODIGO, ES_LOCALIZA.UBICACION, PAISES.NOMBRE NOMBREPAIS, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, CIUDAD.NOMBRE NOMBRECIUDAD  FROM ES_LOCALIZA INNER JOIN PAISES ON ES_LOCALIZA.PAIS = PAISES.PAIS INNER JOIN DEPARTAMENTO ON ES_LOCALIZA.PAIS = DEPARTAMENTO.PAIS AND ES_LOCALIZA.DEPARTAMENTO = DEPARTAMENTO.CODIGO INNER JOIN CIUDAD ON ES_LOCALIZA.PAIS = CIUDAD.PAIS AND ES_LOCALIZA.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND ES_LOCALIZA.CIUDAD = CIUDAD.CODIGO WHERE COMPANIA = :COMPANIA AND ES_LOCALIZA.COD_ESTUDIO = :CODESTUDIO) WHERE (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END)  LIKE UPPER( '%' || :UBICACION || '%')  AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END)  LIKE UPPER( '%' || :NOMBREPAIS || '%')  AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END)  LIKE UPPER( '%' || :NOMBREDEPARTAMENTO || '%')  AND (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END)  LIKE UPPER( '%' || :NOMBRECIUDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="eslocaliza/grillasinbarrio/num">
		<call-query href="getEslocalizaNumGrillasinbarrioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="NOMBREPAIS" query-param="NOMBREPAIS"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>

		</call-query>
	</resource>
	<query id="updateEslocalizaUpdsinbarrio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_LOCALIZA SET PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, CIUDAD=:CIUDAD, UBICACION=:UBICACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_LOCALIZA.COMPANIA= :KEY_COMPANIA AND ES_LOCALIZA.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_LOCALIZA.PAIS= :KEY_PAIS AND ES_LOCALIZA.DEPARTAMENTO= :KEY_DEPARTAMENTO AND ES_LOCALIZA.CIUDAD= :KEY_CIUDAD AND ES_LOCALIZA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_DEPARTAMENTO" sqlType="STRING"/>
		<param name="KEY_CIUDAD" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="eslocaliza/updsinbarrio">
		<call-query href="updateEslocalizaUpdsinbarrio">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CIUDAD" query-param="CIUDAD"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_DEPARTAMENTO" query-param="KEY_DEPARTAMENTO"/>
			<with-param name="KEY_CIUDAD" query-param="KEY_CIUDAD"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="insertEslocaliza" keyColumns="COMPANIA,COD_ESTUDIO,PAIS,DEPARTAMENTO,CIUDAD,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_LOCALIZA (COMPANIA, COD_ESTUDIO, PAIS, DEPARTAMENTO, CIUDAD, BARRIO, CODIGO, UBICACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_ESTUDIO, :PAIS, :DEPARTAMENTO, :CIUDAD, :BARRIO, :CODIGO, :UBICACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO","KEY_PAIS":"$PAIS","KEY_DEPARTAMENTO":"$DEPARTAMENTO","KEY_CIUDAD":"$CIUDAD","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param defaultValue="" name="BARRIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="eslocaliza">
		<call-query href="insertEslocaliza">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CIUDAD" query-param="CIUDAD"/>
			<with-param name="BARRIO" query-param="BARRIO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEslocaliza" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_LOCALIZA WHERE ES_LOCALIZA.COMPANIA= :KEY_COMPANIA AND ES_LOCALIZA.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_LOCALIZA.PAIS= :KEY_PAIS AND ES_LOCALIZA.DEPARTAMENTO= :KEY_DEPARTAMENTO AND ES_LOCALIZA.CIUDAD= :KEY_CIUDAD AND ES_LOCALIZA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_DEPARTAMENTO" sqlType="STRING"/>
		<param name="KEY_CIUDAD" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="eslocaliza">
		<call-query href="deleteEslocaliza">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_DEPARTAMENTO" query-param="KEY_DEPARTAMENTO"/>
			<with-param name="KEY_CIUDAD" query-param="KEY_CIUDAD"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getEslocalizaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ES_LOCALIZA.COMPANIA, ES_LOCALIZA.COD_ESTUDIO, ES_LOCALIZA.PAIS, ES_LOCALIZA.DEPARTAMENTO, ES_LOCALIZA.CIUDAD, ES_LOCALIZA.BARRIO, ES_LOCALIZA.CODIGO, ES_LOCALIZA.UBICACION, PAISES.NOMBRE NOMBREPAIS, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, CIUDAD.NOMBRE NOMBRECIUDAD, BARRIOS.NOMBRE NOMBREBARRIO FROM ES_LOCALIZA INNER JOIN PAISES ON ES_LOCALIZA.PAIS = PAISES.PAIS INNER JOIN DEPARTAMENTO ON ES_LOCALIZA.PAIS = DEPARTAMENTO.PAIS AND ES_LOCALIZA.DEPARTAMENTO = DEPARTAMENTO.CODIGO INNER JOIN CIUDAD ON ES_LOCALIZA.PAIS = CIUDAD.PAIS AND ES_LOCALIZA.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND ES_LOCALIZA.CIUDAD = CIUDAD.CODIGO LEFT JOIN BARRIOS ON ES_LOCALIZA.PAIS = BARRIOS.PAIS AND ES_LOCALIZA.DEPARTAMENTO = BARRIOS.DEPARTAMENTO AND ES_LOCALIZA.CIUDAD = BARRIOS.CIUDAD AND ES_LOCALIZA.BARRIO = BARRIOS.CODIGO WHERE COMPANIA = :COMPANIA AND ES_LOCALIZA.COD_ESTUDIO = :CODESTUDIO) INI WHERE (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:UBICACION), '%')) AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPAIS), '%')) AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREDEPARTAMENTO), '%')) AND (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECIUDAD), '%')) AND (CASE WHEN NOMBREBARRIO IS NULL THEN ' ' ELSE UPPER(NOMBREBARRIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREBARRIO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","BARRIO":"$BARRIO","CODIGO":"$CODIGO","UBICACION":"$UBICACION","NOMBREPAIS":"$NOMBREPAIS","NOMBREDEPARTAMENTO":"$NOMBREDEPARTAMENTO","NOMBRECIUDAD":"$NOMBRECIUDAD","NOMBREBARRIO":"$NOMBREBARRIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>
		<param name="NOMBREBARRIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="eslocaliza">
		<call-query href="getEslocalizaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="NOMBREPAIS" query-param="NOMBREPAIS"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>
			<with-param name="NOMBREBARRIO" query-param="NOMBREBARRIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEslocalizaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ES_LOCALIZA.COMPANIA, ES_LOCALIZA.COD_ESTUDIO, ES_LOCALIZA.PAIS, ES_LOCALIZA.DEPARTAMENTO, ES_LOCALIZA.CIUDAD, ES_LOCALIZA.BARRIO, ES_LOCALIZA.CODIGO, ES_LOCALIZA.UBICACION, PAISES.NOMBRE NOMBREPAIS, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, CIUDAD.NOMBRE NOMBRECIUDAD, BARRIOS.NOMBRE NOMBREBARRIO FROM ES_LOCALIZA INNER JOIN PAISES ON ES_LOCALIZA.PAIS = PAISES.PAIS INNER JOIN DEPARTAMENTO ON ES_LOCALIZA.PAIS = DEPARTAMENTO.PAIS AND ES_LOCALIZA.DEPARTAMENTO = DEPARTAMENTO.CODIGO INNER JOIN CIUDAD ON ES_LOCALIZA.PAIS = CIUDAD.PAIS AND ES_LOCALIZA.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND ES_LOCALIZA.CIUDAD = CIUDAD.CODIGO LEFT JOIN BARRIOS ON ES_LOCALIZA.PAIS = BARRIOS.PAIS AND ES_LOCALIZA.DEPARTAMENTO = BARRIOS.DEPARTAMENTO AND ES_LOCALIZA.CIUDAD = BARRIOS.CIUDAD AND ES_LOCALIZA.BARRIO = BARRIOS.CODIGO WHERE COMPANIA = :COMPANIA AND ES_LOCALIZA.COD_ESTUDIO = :CODESTUDIO) INI WHERE (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:UBICACION), '%')) AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPAIS), '%')) AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREDEPARTAMENTO), '%')) AND (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECIUDAD), '%')) AND (CASE WHEN NOMBREBARRIO IS NULL THEN ' ' ELSE UPPER(NOMBREBARRIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREBARRIO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>
		<param name="NOMBREBARRIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="eslocaliza/numero">
		<call-query href="getEslocalizaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="NOMBREPAIS" query-param="NOMBREPAIS"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>
			<with-param name="NOMBREBARRIO" query-param="NOMBREBARRIO"/>

		</call-query>
	</resource>
	<query id="updateEslocaliza" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_LOCALIZA SET PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, CIUDAD=:CIUDAD, BARRIO=:BARRIO, UBICACION=:UBICACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_LOCALIZA.COMPANIA= :KEY_COMPANIA AND ES_LOCALIZA.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_LOCALIZA.PAIS= :KEY_PAIS AND ES_LOCALIZA.DEPARTAMENTO= :KEY_DEPARTAMENTO AND ES_LOCALIZA.CIUDAD= :KEY_CIUDAD AND ES_LOCALIZA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="BARRIO" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_DEPARTAMENTO" sqlType="STRING"/>
		<param name="KEY_CIUDAD" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="eslocaliza">
		<call-query href="updateEslocaliza">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="DEPARTAMENTO" query-param="DEPARTAMENTO"/>
			<with-param name="CIUDAD" query-param="CIUDAD"/>
			<with-param name="BARRIO" query-param="BARRIO"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_DEPARTAMENTO" query-param="KEY_DEPARTAMENTO"/>
			<with-param name="KEY_CIUDAD" query-param="KEY_CIUDAD"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>