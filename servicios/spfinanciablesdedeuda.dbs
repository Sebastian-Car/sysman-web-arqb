	<query id="updateSpfinanciablesdedeuda" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_FINANCIABLESDEDEUDA SET USUARIO=:USUARIO, ANO=:ANO, PERIODO=:PERIODO, VRAFINANCIAR=:VRAFINANCIAR, NOCUOTAS=:NOCUOTAS, ABONOINICIAL=:ABONOINICIAL, USUARIOSISTEMA=:USUARIOSISTEMA, FINANCIADO=:FINANCIADO, CICLO=:CICLO, VALORCUOTA=:VALORCUOTA, PERIODOSNOCOBRO=:PERIODOSNOCOBRO, INDANULADO=:INDANULADO, USUARIOANULO=:USUARIOANULO, CONSECUTIVOMANUAL=:CONSECUTIVOMANUAL, NOMBRES=:NOMBRES, IDENTIFICACION=:IDENTIFICACION, LUGAREXPEDICION=:LUGAREXPEDICION, CELULAR=:CELULAR, ROL=:ROL, PERIODOSATRASOINI=:PERIODOSATRASOINI, ESTRATO=:ESTRATO, USO=:USO, FACTURA=:FACTURA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHAFACTURA=TO_DATE(:FECHAFACTURA,'DD/MM/YYYY HH24:MI:SS'), FECHAANULACION=TO_DATE(:FECHAANULACION,'DD/MM/YYYY HH24:MI:SS'), FECHAACTUAL=TO_DATE(:FECHAACTUAL,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS') WHERE SP_FINANCIABLESDEDEUDA.COMPANIA= :KEY_COMPANIA AND SP_FINANCIABLESDEDEUDA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
