	<query id="deleteSpfinanciablesdedeuda" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_FINANCIABLESDEDEUDA WHERE SP_FINANCIABLESDEDEUDA.COMPANIA= :KEY_COMPANIA AND SP_FINANCIABLESDEDEUDA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spfinanciablesdedeuda">
		<call-query href="deleteSpfinanciablesdedeuda">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSpfinanciablesdedeudaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_FINANCIABLESDEDEUDA.COMPANIA, SP_FINANCIABLESDEDEUDA.CONSECUTIVO, SP_FINANCIABLESDEDEUDA.USUARIO, TRIM(CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) ) NOMBREUSUARIO , SP_FINANCIABLESDEDEUDA.ANO, SP_FINANCIABLESDEDEUDA.PERIODO,(CASE SP_FINANCIABLESDEDEUDA.FINANCIADO WHEN 0 THEN 'false' ELSE 'true' END) FINANCIADO FROM SP_FINANCIABLESDEDEUDA INNER JOIN SP_USUARIO ON SP_FINANCIABLESDEDEUDA.COMPANIA = SP_USUARIO.COMPANIA AND SP_FINANCIABLESDEDEUDA.CICLO = SP_USUARIO.CICLO AND SP_FINANCIABLESDEDEUDA.USUARIO = SP_USUARIO.CODIGORUTA WHERE SP_FINANCIABLESDEDEUDA.COMPANIA =:COMPANIA ORDER BY SP_FINANCIABLESDEDEUDA.CONSECUTIVO DESC) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END) LIKE UPPER(CONCAT(:USUARIO, '%')) AND (CASE WHEN NOMBREUSUARIO IS NULL THEN ' ' ELSE UPPER(NOMBREUSUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREUSUARIO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","USUARIO":"$USUARIO","NOMBREUSUARIO":"$NOMBREUSUARIO","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","FINANCIADO":"$FINANCIADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NOMBREUSUARIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spfinanciablesdedeuda">
		<call-query href="getSpfinanciablesdedeudaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NOMBREUSUARIO" query-param="NOMBREUSUARIO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpfinanciablesdedeudaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_FINANCIABLESDEDEUDA.COMPANIA, SP_FINANCIABLESDEDEUDA.CONSECUTIVO, SP_FINANCIABLESDEDEUDA.USUARIO, TRIM(CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) ) NOMBREUSUARIO , SP_FINANCIABLESDEDEUDA.ANO, SP_FINANCIABLESDEDEUDA.PERIODO,(CASE SP_FINANCIABLESDEDEUDA.FINANCIADO WHEN 0 THEN 'false' ELSE 'true' END) FINANCIADO FROM SP_FINANCIABLESDEDEUDA INNER JOIN SP_USUARIO ON SP_FINANCIABLESDEDEUDA.COMPANIA = SP_USUARIO.COMPANIA AND SP_FINANCIABLESDEDEUDA.CICLO = SP_USUARIO.CICLO AND SP_FINANCIABLESDEDEUDA.USUARIO = SP_USUARIO.CODIGORUTA WHERE SP_FINANCIABLESDEDEUDA.COMPANIA =:COMPANIA ORDER BY SP_FINANCIABLESDEDEUDA.CONSECUTIVO DESC) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END) LIKE UPPER(CONCAT(:USUARIO, '%')) AND (CASE WHEN NOMBREUSUARIO IS NULL THEN ' ' ELSE UPPER(NOMBREUSUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREUSUARIO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NOMBREUSUARIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfinanciablesdedeuda/numero">
		<call-query href="getSpfinanciablesdedeudaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NOMBREUSUARIO" query-param="NOMBREUSUARIO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpfinanciablesdedeudaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_FINANCIABLESDEDEUDA.COMPANIA, SP_FINANCIABLESDEDEUDA.CONSECUTIVO, SP_FINANCIABLESDEDEUDA.USUARIO, TRIM(CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) ) NOMBREUSUARIO , SP_FINANCIABLESDEDEUDA.ANO, SP_FINANCIABLESDEDEUDA.PERIODO, SP_FINANCIABLESDEDEUDA.VRAFINANCIAR, SP_FINANCIABLESDEDEUDA.NOCUOTAS, SP_FINANCIABLESDEDEUDA.ABONOINICIAL, SP_FINANCIABLESDEDEUDA.USUARIOSISTEMA,(CASE SP_FINANCIABLESDEDEUDA.FINANCIADO WHEN 0 THEN 'false' ELSE 'true' END) FINANCIADO, SP_FINANCIABLESDEDEUDA.CICLO, SP_FINANCIABLESDEDEUDA.VALORCUOTA, SP_FINANCIABLESDEDEUDA.PERIODOSNOCOBRO,(CASE SP_FINANCIABLESDEDEUDA.INDANULADO WHEN 0 THEN 'false' ELSE 'true' END) INDANULADO, SP_FINANCIABLESDEDEUDA.USUARIOANULO, SP_FINANCIABLESDEDEUDA.CONSECUTIVOMANUAL, SP_FINANCIABLESDEDEUDA.NOMBRES, SP_FINANCIABLESDEDEUDA.IDENTIFICACION, SP_FINANCIABLESDEDEUDA.LUGAREXPEDICION, SP_FINANCIABLESDEDEUDA.CELULAR, SP_FINANCIABLESDEDEUDA.ROL, SP_FINANCIABLESDEDEUDA.PERIODOSATRASOINI, SP_FINANCIABLESDEDEUDA.ESTRATO, SP_FINANCIABLESDEDEUDA.USO, SP_FINANCIABLESDEDEUDA.FACTURA, SP_FINANCIABLESDEDEUDA.CREATED_BY, SP_FINANCIABLESDEDEUDA.MODIFIED_BY,(TO_CHAR(SP_FINANCIABLESDEDEUDA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(SP_FINANCIABLESDEDEUDA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(SP_FINANCIABLESDEDEUDA.FECHAFACTURA,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURA,(TO_CHAR(SP_FINANCIABLESDEDEUDA.FECHAANULACION,'DD/MM/YYYY HH24:MI:SS')) FECHAANULACION,(TO_CHAR(SP_FINANCIABLESDEDEUDA.FECHAACTUAL,'DD/MM/YYYY HH24:MI:SS')) FECHAACTUAL,(TO_CHAR(SP_FINANCIABLESDEDEUDA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM SP_FINANCIABLESDEDEUDA INNER JOIN SP_USUARIO ON SP_FINANCIABLESDEDEUDA.COMPANIA = SP_USUARIO.COMPANIA AND SP_FINANCIABLESDEDEUDA.CICLO = SP_USUARIO.CICLO AND SP_FINANCIABLESDEDEUDA.USUARIO = SP_USUARIO.CODIGORUTA WHERE SP_FINANCIABLESDEDEUDA.COMPANIA= :KEY_COMPANIA AND SP_FINANCIABLESDEDEUDA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","USUARIO":"$USUARIO","NOMBREUSUARIO":"$NOMBREUSUARIO","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","VRAFINANCIAR":"$VRAFINANCIAR","NOCUOTAS":"$NOCUOTAS","ABONOINICIAL":"$ABONOINICIAL","USUARIOSISTEMA":"$USUARIOSISTEMA","FINANCIADO":"$FINANCIADO(type:boolean)","CICLO":"$CICLO(type:integer)","VALORCUOTA":"$VALORCUOTA","PERIODOSNOCOBRO":"$PERIODOSNOCOBRO","INDANULADO":"$INDANULADO(type:boolean)","USUARIOANULO":"$USUARIOANULO","CONSECUTIVOMANUAL":"$CONSECUTIVOMANUAL","NOMBRES":"$NOMBRES","IDENTIFICACION":"$IDENTIFICACION","LUGAREXPEDICION":"$LUGAREXPEDICION","CELULAR":"$CELULAR","ROL":"$ROL","PERIODOSATRASOINI":"$PERIODOSATRASOINI(type:integer)","ESTRATO":"$ESTRATO","USO":"$USO","FACTURA":"$FACTURA(type:long)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","FECHAFACTURA":"$FECHAFACTURA","FECHAANULACION":"$FECHAANULACION","FECHAACTUAL":"$FECHAACTUAL","FECHA":"$FECHA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfinanciablesdedeuda/data">
		<call-query href="getSpfinanciablesdedeudaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
