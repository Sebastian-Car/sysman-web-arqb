			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="insertSpfinanciablesdedeuda" keyColumns="COMPANIA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_FINANCIABLESDEDEUDA (COMPANIA, CONSECUTIVO, USUARIO, ANO, PERIODO, VRAFINANCIAR, NOCUOTAS, ABONOINICIAL, USUARIOSISTEMA, FINANCIADO, CICLO, VALORCUOTA, PERIODOSNOCOBRO, INDANULADO, USUARIOANULO, CONSECUTIVOMANUAL, NOMBRES, IDENTIFICACION, LUGAREXPEDICION, CELULAR, ROL, PERIODOSATRASOINI, ESTRATO, USO, FACTURA, CREATED_BY, DATE_CREATED, FECHAFACTURA, FECHAANULACION, FECHAACTUAL, FECHA) VALUES (:COMPANIA, :CONSECUTIVO, :USUARIO, :ANO, :PERIODO, :VRAFINANCIAR, :NOCUOTAS, :ABONOINICIAL, :USUARIOSISTEMA, :FINANCIADO, :CICLO, :VALORCUOTA, :PERIODOSNOCOBRO, :INDANULADO, :USUARIOANULO, :CONSECUTIVOMANUAL, :NOMBRES, :IDENTIFICACION, :LUGAREXPEDICION, :CELULAR, :ROL, :PERIODOSATRASOINI, :ESTRATO, :USO, :FACTURA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFACTURA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAANULACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAACTUAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param defaultValue="0" name="VRAFINANCIAR" sqlType="STRING"/>
		<param defaultValue="0" name="NOCUOTAS" sqlType="STRING"/>
		<param defaultValue="0" name="ABONOINICIAL" sqlType="STRING"/>
		<param defaultValue="" name="USUARIOSISTEMA" sqlType="STRING"/>
		<param defaultValue="0" name="FINANCIADO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORCUOTA" sqlType="STRING"/>
		<param defaultValue="0" name="PERIODOSNOCOBRO" sqlType="STRING"/>
		<param defaultValue="0" name="INDANULADO" sqlType="STRING"/>
		<param defaultValue="" name="USUARIOANULO" sqlType="STRING"/>
		<param defaultValue="" name="CONSECUTIVOMANUAL" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRES" sqlType="STRING"/>
		<param defaultValue="" name="IDENTIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="LUGAREXPEDICION" sqlType="STRING"/>
		<param defaultValue="" name="CELULAR" sqlType="STRING"/>
		<param defaultValue="" name="ROL" sqlType="STRING"/>
		<param defaultValue="0" name="PERIODOSATRASOINI" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param defaultValue="0" name="FACTURA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="FECHAFACTURA" sqlType="STRING"/>
		<param defaultValue="" name="FECHAANULACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAACTUAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spfinanciablesdedeuda">
