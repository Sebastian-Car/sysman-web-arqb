<data name="spfinanciablesdedeuda" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpfinanciablesdedeudaTerceroPorConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_FINANCIABLESDEDEUDA.COMPANIA, SP_FINANCIABLESDEDEUDA.CONSECUTIVO, SP_FINANCIABLESDEDEUDA.NOMBRES, SP_FINANCIABLESDEDEUDA.IDENTIFICACION, SP_FINANCIABLESDEDEUDA.LUGAREXPEDICION, SP_FINANCIABLESDEDEUDA.CELULAR, SP_FINANCIABLESDEDEUDA.ROL  FROM SP_FINANCIABLESDEDEUDA WHERE COMPANIA = :KEY_COMPANIA AND CONSECUTIVO = :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","NOMBRES":"$NOMBRES","IDENTIFICACION":"$IDENTIFICACION","LUGAREXPEDICION":"$LUGAREXPEDICION","CELULAR":"$CELULAR","ROL":"$ROL"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfinanciablesdedeuda/terceroporconsecutivo">
		<call-query href="getSpfinanciablesdedeudaTerceroPorConsecutivoQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateSpfinanciablesdedeudaTerceroFinanciable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_FINANCIABLESDEDEUDA SET NOMBRES=:NOMBRES, IDENTIFICACION=:IDENTIFICACION, LUGAREXPEDICION=:LUGAREXPEDICION, CELULAR=:CELULAR, ROL=:ROL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_FINANCIABLESDEDEUDA.COMPANIA= :KEY_COMPANIA AND SP_FINANCIABLESDEDEUDA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRES" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="LUGAREXPEDICION" sqlType="STRING"/>
		<param name="CELULAR" sqlType="STRING"/>
		<param name="ROL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spfinanciablesdedeuda/tercerofinanciable">
		<call-query href="updateSpfinanciablesdedeudaTerceroFinanciable">
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="LUGAREXPEDICION" query-param="LUGAREXPEDICION"/>
			<with-param name="CELULAR" query-param="CELULAR"/>
			<with-param name="ROL" query-param="ROL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSpfinanciablesdedeudaValidaConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM SP_FINANCIABLESDEDEUDA WHERE SP_FINANCIABLESDEDEUDA.COMPANIA = :COMPANIA AND SP_FINANCIABLESDEDEUDA.CONSECUTIVO = :CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
