<data name="piplanindicativo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPiplanindicativoViginicialporcompQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PI_PLAN_INDICATIVO.VIGENCIA_INICIAL  FROM PI_PLAN_INDICATIVO WHERE PI_PLAN_INDICATIVO.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanindicativo/viginicialporcomp">
		<call-query href="getPiplanindicativoViginicialporcompQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPiplanindicativoPagPaaynopaaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PI_PLAN_INDICATIVO.NUMERO, PI_PLAN_INDICATIVO.DESCRIPCION, PI_PLAN_INDICATIVO.VALOR_PRESUPUESTO_INI, TIPODESTINO.NOMBRE  FROM PI_PLAN_INDICATIVO LEFT JOIN TIPODESTINO ON PI_PLAN_INDICATIVO.TIPO_GASTO = TIPODESTINO.CODIGO WHERE PI_PLAN_INDICATIVO.COMPANIA = :COMPANIA) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALOR_PRESUPUESTO_INI IS NULL THEN ' ' ELSE UPPER(VALOR_PRESUPUESTO_INI) END)  LIKE UPPER(:VALOR_PRESUPUESTO_INI || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DESCRIPCION":"$DESCRIPCION","VALOR_PRESUPUESTO_INI":"$VALOR_PRESUPUESTO_INI","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_PRESUPUESTO_INI" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piplanindicativo/paaynopaa/pag">
		<call-query href="getPiplanindicativoPagPaaynopaaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR_PRESUPUESTO_INI" query-param="VALOR_PRESUPUESTO_INI"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPiplanindicativoNumPaaynopaaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PI_PLAN_INDICATIVO.NUMERO, PI_PLAN_INDICATIVO.DESCRIPCION, PI_PLAN_INDICATIVO.VALOR_PRESUPUESTO_INI, TIPODESTINO.NOMBRE  FROM PI_PLAN_INDICATIVO LEFT JOIN TIPODESTINO ON PI_PLAN_INDICATIVO.TIPO_GASTO = TIPODESTINO.CODIGO WHERE PI_PLAN_INDICATIVO.COMPANIA = :COMPANIA) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALOR_PRESUPUESTO_INI IS NULL THEN ' ' ELSE UPPER(VALOR_PRESUPUESTO_INI) END)  LIKE UPPER(:VALOR_PRESUPUESTO_INI || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_PRESUPUESTO_INI" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanindicativo/paaynopaa/num">
		<call-query href="getPiplanindicativoNumPaaynopaaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR_PRESUPUESTO_INI" query-param="VALOR_PRESUPUESTO_INI"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPiplanindicativoPagTodoslosdatosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT TIPO, ID_PLAN, VIGENCIA_INICIAL,NUMERO  FROM PI_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA ORDER BY ID_PLAN) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END)  LIKE UPPER(:VIGENCIA_INICIAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","ID_PLAN":"$ID_PLAN","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piplanindicativo/todoslosdatos/pag">
		<call-query href="getPiplanindicativoPagTodoslosdatosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPiplanindicativoNumTodoslosdatosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT TIPO, ID_PLAN, VIGENCIA_INICIAL,NUMERO  FROM PI_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA ORDER BY ID_PLAN) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END)  LIKE UPPER(:VIGENCIA_INICIAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanindicativo/todoslosdatos/num">
		<call-query href="getPiplanindicativoNumTodoslosdatosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="getPiplanindicativoSaldopresupuestofuenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN - ( SELECT NVL( SUM (PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN),0) PRESUPUESTO_ASIGNADO FROM PI_PLAN_INDICATIVO_FUENTES INNER JOIN PI_PLAN_INDICATIVO ON PI_PLAN_INDICATIVO_FUENTES.COMPANIA =PI_PLAN_INDICATIVO.COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.TIPO =PI_PLAN_INDICATIVO.TIPO AND PI_PLAN_INDICATIVO_FUENTES.ID_PLAN =PI_PLAN_INDICATIVO.ID_PLAN AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN =PI_PLAN_INDICATIVO.VIGENCIA_INICIAL AND PI_PLAN_INDICATIVO_FUENTES.NUMERO =PI_PLAN_INDICATIVO.NUMERO INNER JOIN FUENTE_RECURSOS ON PI_PLAN_INDICATIVO_FUENTES.COMPANIA =FUENTE_RECURSOS.COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_META =FUENTE_RECURSOS.ANO AND PI_PLAN_INDICATIVO_FUENTES.FUENTE =FUENTE_RECURSOS.CODIGO WHERE PI_PLAN_INDICATIVO_FUENTES.COMPANIA =:COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.TIPO =:TIPO AND PI_PLAN_INDICATIVO_FUENTES.NUMERO =:NUMERO AND PI_PLAN_INDICATIVO_FUENTES.ID_PLAN LIKE CONCAT(:PLAN,'%') AND PI_PLAN_INDICATIVO_FUENTES.ID_PLAN &lt;&gt; :PLAN AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN =:VIGENCIA AND PI_PLAN_INDICATIVO_FUENTES.FUENTE = :FUENTE) SALDO FROM PI_PLAN_INDICATIVO_FUENTES INNER JOIN PI_PLAN_INDICATIVO ON PI_PLAN_INDICATIVO_FUENTES.COMPANIA =PI_PLAN_INDICATIVO.COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.TIPO =PI_PLAN_INDICATIVO.TIPO AND PI_PLAN_INDICATIVO_FUENTES.ID_PLAN =PI_PLAN_INDICATIVO.ID_PLAN AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN =PI_PLAN_INDICATIVO.VIGENCIA_INICIAL AND PI_PLAN_INDICATIVO_FUENTES.NUMERO =PI_PLAN_INDICATIVO.NUMERO INNER JOIN FUENTE_RECURSOS ON PI_PLAN_INDICATIVO_FUENTES.COMPANIA =FUENTE_RECURSOS.COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_META =FUENTE_RECURSOS.ANO AND PI_PLAN_INDICATIVO_FUENTES.FUENTE =FUENTE_RECURSOS.CODIGO WHERE PI_PLAN_INDICATIVO_FUENTES.COMPANIA =:COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.TIPO =:TIPO AND PI_PLAN_INDICATIVO_FUENTES.NUMERO =:NUMERO AND PI_PLAN_INDICATIVO_FUENTES.ID_PLAN = :PLAN AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN =:VIG</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALDO":"$SALDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PLAN" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="VIG" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanindicativo/saldopresupuestofuente">
		<call-query href="getPiplanindicativoSaldopresupuestofuenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PLAN" query-param="PLAN"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="VIG" query-param="VIG"/>

		</call-query>
	</resource>
	<query id="insertPiplanindicativo" keyColumns="COMPANIA,TIPO,ID_PLAN,VIGENCIA_INICIAL,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PI_PLAN_INDICATIVO (COMPANIA, TIPO, ID_PLAN, VIGENCIA_INICIAL, VIGENCIA_FINAL, RESPONSABLE, SUCURSAL, DEPENDENCIA_INI, DEPENDENCIA_FIN, VALOR_PRESUPUESTO_INI, VALOR_PRESUPUESTO_FIN, VALOR_COMPROMETIDO_INI, VALOR_COMPROMETIDO_FIN, VALOR_PAGADO_INI, VALOR_PAGADO_FIN, DESCRIPCION, ESNUEVO, CODIGOBPIM, VALOR_OBLIGACIONES_INI, VALOR_OBLIGACIONES_FIN, DESCRIPCION_INI, RESPONSABLE_INI, DEBE_ELIMINAR, NUMERO, PREDECESOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :ID_PLAN, :VIGENCIA_INICIAL, :VIGENCIA_FINAL, :RESPONSABLE, :SUCURSAL, :DEPENDENCIA_INI, :DEPENDENCIA_FIN, :VALOR_PRESUPUESTO_INI, :VALOR_PRESUPUESTO_FIN, :VALOR_COMPROMETIDO_INI, :VALOR_COMPROMETIDO_FIN, :VALOR_PAGADO_INI, :VALOR_PAGADO_FIN, :DESCRIPCION, :ESNUEVO, :CODIGOBPIM, :VALOR_OBLIGACIONES_INI, :VALOR_OBLIGACIONES_FIN, :DESCRIPCION_INI, :RESPONSABLE_INI, :DEBE_ELIMINAR, :NUMERO, :PREDECESOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_ID_PLAN":"$ID_PLAN","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA_INI" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PRESUPUESTO_INI" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PRESUPUESTO_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_COMPROMETIDO_INI" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_COMPROMETIDO_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PAGADO_INI" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PAGADO_FIN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="ESNUEVO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOBPIM" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_OBLIGACIONES_INI" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_OBLIGACIONES_FIN" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_INI" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE_INI" sqlType="STRING"/>
		<param defaultValue="0" name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="PREDECESOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="piplanindicativo">
		<call-query href="insertPiplanindicativo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA_FINAL" query-param="VIGENCIA_FINAL"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DEPENDENCIA_INI" query-param="DEPENDENCIA_INI"/>
			<with-param name="DEPENDENCIA_FIN" query-param="DEPENDENCIA_FIN"/>
			<with-param name="VALOR_PRESUPUESTO_INI" query-param="VALOR_PRESUPUESTO_INI"/>
			<with-param name="VALOR_PRESUPUESTO_FIN" query-param="VALOR_PRESUPUESTO_FIN"/>
			<with-param name="VALOR_COMPROMETIDO_INI" query-param="VALOR_COMPROMETIDO_INI"/>
			<with-param name="VALOR_COMPROMETIDO_FIN" query-param="VALOR_COMPROMETIDO_FIN"/>
			<with-param name="VALOR_PAGADO_INI" query-param="VALOR_PAGADO_INI"/>
			<with-param name="VALOR_PAGADO_FIN" query-param="VALOR_PAGADO_FIN"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ESNUEVO" query-param="ESNUEVO"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="VALOR_OBLIGACIONES_INI" query-param="VALOR_OBLIGACIONES_INI"/>
			<with-param name="VALOR_OBLIGACIONES_FIN" query-param="VALOR_OBLIGACIONES_FIN"/>
			<with-param name="DESCRIPCION_INI" query-param="DESCRIPCION_INI"/>
			<with-param name="RESPONSABLE_INI" query-param="RESPONSABLE_INI"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getPiplanindicativoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PI_PLAN_INDICATIVO.COMPANIA, PI_PLAN_INDICATIVO.TIPO, PI_PLAN_INDICATIVO.ID_PLAN, PI_PLAN_INDICATIVO.VIGENCIA_INICIAL, PI_PLAN_INDICATIVO.NUMERO, PI_PLAN_INDICATIVO.DESCRIPCION, PI_PLAN_INDICATIVO.RESPONSABLE, PI_PLAN_INDICATIVO.CODIGOBPIM,(CASE PI_PLAN_INDICATIVO.DEBE_ELIMINAR WHEN 0 THEN 'false' ELSE 'true' END) DEBE_ELIMINAR, PI_PLAN_INDICATIVO.SUCURSAL, TERCERO.NOMBRE NOMBRERESPONSABLE  FROM PI_PLAN_INDICATIVO INNER JOIN TERCERO ON PI_PLAN_INDICATIVO.COMPANIA = TERCERO.COMPANIA AND PI_PLAN_INDICATIVO.RESPONSABLE = TERCERO.NIT AND PI_PLAN_INDICATIVO.SUCURSAL = TERCERO.SUCURSAL WHERE PI_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND PI_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND PI_PLAN_INDICATIVO.TIPO = :TIPO AND PI_PLAN_INDICATIVO.NUMERO = :NUMERO AND PI_PLAN_INDICATIVO.PREDECESOR = :PREDECESOR AND (LENGTH(PI_PLAN_INDICATIVO.ID_PLAN) = :ACCION OR PI_PLAN_INDICATIVO.ESNUEVO NOT IN(0))) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER( '%' || :CODIGOBPIM || '%')  AND (CASE WHEN DEBE_ELIMINAR IS NULL THEN ' ' ELSE UPPER(DEBE_ELIMINAR) END)  LIKE UPPER(:DEBE_ELIMINAR || '%')  AND (CASE WHEN NOMBRERESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRERESPONSABLE) END)  LIKE UPPER( '%' || :NOMBRERESPONSABLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","ID_PLAN":"$ID_PLAN","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION","RESPONSABLE":"$RESPONSABLE","CODIGOBPIM":"$CODIGOBPIM","DEBE_ELIMINAR":"$DEBE_ELIMINAR(type:boolean)","SUCURSAL":"$SUCURSAL","NOMBRERESPONSABLE":"$NOMBRERESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="NOMBRERESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piplanindicativo">
		<call-query href="getPiplanindicativoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="NOMBRERESPONSABLE" query-param="NOMBRERESPONSABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPiplanindicativoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PI_PLAN_INDICATIVO.COMPANIA, PI_PLAN_INDICATIVO.TIPO, PI_PLAN_INDICATIVO.ID_PLAN, PI_PLAN_INDICATIVO.VIGENCIA_INICIAL, PI_PLAN_INDICATIVO.NUMERO, PI_PLAN_INDICATIVO.DESCRIPCION, PI_PLAN_INDICATIVO.RESPONSABLE, PI_PLAN_INDICATIVO.CODIGOBPIM,(CASE PI_PLAN_INDICATIVO.DEBE_ELIMINAR WHEN 0 THEN 'false' ELSE 'true' END) DEBE_ELIMINAR, PI_PLAN_INDICATIVO.SUCURSAL, TERCERO.NOMBRE NOMBRERESPONSABLE  FROM PI_PLAN_INDICATIVO INNER JOIN TERCERO ON PI_PLAN_INDICATIVO.COMPANIA = TERCERO.COMPANIA AND PI_PLAN_INDICATIVO.RESPONSABLE = TERCERO.NIT AND PI_PLAN_INDICATIVO.SUCURSAL = TERCERO.SUCURSAL WHERE PI_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND PI_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND PI_PLAN_INDICATIVO.TIPO = :TIPO AND PI_PLAN_INDICATIVO.NUMERO = :NUMERO AND PI_PLAN_INDICATIVO.PREDECESOR = :PREDECESOR AND (LENGTH(PI_PLAN_INDICATIVO.ID_PLAN) = :ACCION OR PI_PLAN_INDICATIVO.ESNUEVO NOT IN(0))) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER( '%' || :CODIGOBPIM || '%')  AND (CASE WHEN DEBE_ELIMINAR IS NULL THEN ' ' ELSE UPPER(DEBE_ELIMINAR) END)  LIKE UPPER(:DEBE_ELIMINAR || '%')  AND (CASE WHEN NOMBRERESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRERESPONSABLE) END)  LIKE UPPER( '%' || :NOMBRERESPONSABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="NOMBRERESPONSABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanindicativo/numero">
		<call-query href="getPiplanindicativoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="NOMBRERESPONSABLE" query-param="NOMBRERESPONSABLE"/>

		</call-query>
	</resource>
	<query id="updatePiplanindicativo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_PLAN_INDICATIVO SET RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, DESCRIPCION=:DESCRIPCION, CODIGOBPIM=:CODIGOBPIM, RESPONSABLE_INI=:RESPONSABLE_INI, DEBE_ELIMINAR=:DEBE_ELIMINAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND PI_PLAN_INDICATIVO.TIPO= :KEY_TIPO AND PI_PLAN_INDICATIVO.ID_PLAN= :KEY_ID_PLAN AND PI_PLAN_INDICATIVO.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PLAN_INDICATIVO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="RESPONSABLE_INI" sqlType="STRING"/>
		<param name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="piplanindicativo">
		<call-query href="updatePiplanindicativo">
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="RESPONSABLE_INI" query-param="RESPONSABLE_INI"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>

</data>