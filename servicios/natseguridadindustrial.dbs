			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_FACTOR_RIESGO" query-param="KEY_FACTOR_RIESGO"/>

		</call-query>
	</resource>
	<query id="getNatseguridadindustrialPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_SEGURIDAD_INDUSTRIAL.COMPANIA , NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO , NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO, NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL, NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.TIPO_TRANSACCION, NAT_SEGURIDAD_INDUSTRIAL.CLASE_TRANSACCION, PERSONAL.NOMBRECOMPLETO, NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO, NAT_RIESGO_LABORAL.NOMBRE AS NOMBRE_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.TIPO_ACCIDENTE  FROM NAT_SEGURIDAD_INDUSTRIAL INNER JOIN PERSONAL ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = PERSONAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN NAT_RIESGO_LABORAL ON NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO = NAT_RIESGO_LABORAL.ID_RIESGO WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = :COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO = :NUMERO_DCTO AND NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL = :SUCURSAL AND NAT_SEGURIDAD_INDUSTRIAL.TIPO_TRANSACCION = :TIPO_TRANSACCION ORDER BY CONSECUTIVO) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRE_RIESGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RIESGO) END)  LIKE UPPER( '%' || :NOMBRE_RIESGO || '%')  AND (CASE WHEN TIPO_ACCIDENTE IS NULL THEN ' ' ELSE UPPER(TIPO_ACCIDENTE) END)  LIKE UPPER( '%' || :TIPO_ACCIDENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","FACTOR_RIESGO":"$FACTOR_RIESGO","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CLASE_TRANSACCION":"$CLASE_TRANSACCION","NOMBRECOMPLETO":"$NOMBRECOMPLETO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRE_RIESGO":"$NOMBRE_RIESGO","TIPO_ACCIDENTE":"$TIPO_ACCIDENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE_RIESGO" sqlType="STRING"/>
		<param name="TIPO_ACCIDENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natseguridadindustrial">
		<call-query href="getNatseguridadindustrialPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRE_RIESGO" query-param="NOMBRE_RIESGO"/>
			<with-param name="TIPO_ACCIDENTE" query-param="TIPO_ACCIDENTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatseguridadindustrialNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_SEGURIDAD_INDUSTRIAL.COMPANIA , NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO , NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO, NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL, NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.TIPO_TRANSACCION, NAT_SEGURIDAD_INDUSTRIAL.CLASE_TRANSACCION, PERSONAL.NOMBRECOMPLETO, NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO, NAT_RIESGO_LABORAL.NOMBRE AS NOMBRE_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.TIPO_ACCIDENTE  FROM NAT_SEGURIDAD_INDUSTRIAL INNER JOIN PERSONAL ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = PERSONAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN NAT_RIESGO_LABORAL ON NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO = NAT_RIESGO_LABORAL.ID_RIESGO WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = :COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO = :NUMERO_DCTO AND NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL = :SUCURSAL AND NAT_SEGURIDAD_INDUSTRIAL.TIPO_TRANSACCION = :TIPO_TRANSACCION ORDER BY CONSECUTIVO) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRE_RIESGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RIESGO) END)  LIKE UPPER( '%' || :NOMBRE_RIESGO || '%')  AND (CASE WHEN TIPO_ACCIDENTE IS NULL THEN ' ' ELSE UPPER(TIPO_ACCIDENTE) END)  LIKE UPPER( '%' || :TIPO_ACCIDENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE_RIESGO" sqlType="STRING"/>
		<param name="TIPO_ACCIDENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natseguridadindustrial/numero">
		<call-query href="getNatseguridadindustrialNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRE_RIESGO" query-param="NOMBRE_RIESGO"/>
			<with-param name="TIPO_ACCIDENTE" query-param="TIPO_ACCIDENTE"/>

		</call-query>
	</resource>
	<query id="getNatseguridadindustrialRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_SEGURIDAD_INDUSTRIAL.COMPANIA, NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO, NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO, NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL, NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.TIPO_TRANSACCION, NAT_SEGURIDAD_INDUSTRIAL.CLASE_TRANSACCION, PERSONAL.NOMBRECOMPLETO NOMBRE, NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO, NAT_SEGURIDAD_INDUSTRIAL.CONCEPTO_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.CRITERIO_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.NATURALEZA_LESION, NAT_SEGURIDAD_INDUSTRIAL.PARTE_CUERPO_AFEC, NAT_SEGURIDAD_INDUSTRIAL.AGENTE_LESION, NAT_SEGURIDAD_INDUSTRIAL.TIPO_ACCIDENTE, NAT_SEGURIDAD_INDUSTRIAL.CAUSA_ACCIDENTE, NAT_SEGURIDAD_INDUSTRIAL.ACCIONES_CORRECT, NAT_RIESGO_LABORAL.NOMBRE NOMBRE_RIESGO, NAT_CONCEPTO_RIESGO.NOMBRE NOMBRE_CONCEPTO, NAT_SEGURIDAD_INDUSTRIAL.CREATED_BY,(TO_CHAR(NAT_SEGURIDAD_INDUSTRIAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NAT_SEGURIDAD_INDUSTRIAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, NAT_SEGURIDAD_INDUSTRIAL.MODIFIED_BY,(CASE NAT_SEGURIDAD_INDUSTRIAL.IND_INCAPACIDAD WHEN 0 THEN 'false' ELSE 'true' END) IND_INCAPACIDAD, NAT_SEGURIDAD_INDUSTRIAL.DIAS_INCAPACIDAD,(CASE NAT_SEGURIDAD_INDUSTRIAL.IND_TESTIGOS WHEN 0 THEN 'false' ELSE 'true' END) IND_TESTIGOS, NAT_SEGURIDAD_INDUSTRIAL.DIAGNOSTICO,(CASE NAT_SEGURIDAD_INDUSTRIAL.IND_REMISION WHEN 0 THEN 'false' ELSE 'true' END) IND_REMISION,(TO_CHAR(NAT_SEGURIDAD_INDUSTRIAL.FECHA_REMISION,'DD/MM/YYYY HH24:MI:SS')) FECHA_REMISION, NAT_SEGURIDAD_INDUSTRIAL.OBSERVACION_REMISION  FROM NAT_SEGURIDAD_INDUSTRIAL INNER JOIN PERSONAL ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = PERSONAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN NAT_RIESGO_LABORAL ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = NAT_RIESGO_LABORAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO = NAT_RIESGO_LABORAL.ID_RIESGO INNER JOIN NAT_CONCEPTO_RIESGO ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = NAT_RIESGO_LABORAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.CONCEPTO_RIESGO = NAT_CONCEPTO_RIESGO.ID_CONCEPTO AND NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO = NAT_CONCEPTO_RIESGO.ID_RIESGO AND NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA= :KEY_COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO= :KEY_CONSECUTIVO AND NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL= :KEY_SUCURSAL AND NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO= :KEY_FACTOR_RIESGO AND NAT_SEGURIDAD_INDUSTRIAL.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND NAT_SEGURIDAD_INDUSTRIAL.CLASE_TRANSACCION= :KEY_CLASE_TRANSACCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","FACTOR_RIESGO":"$FACTOR_RIESGO","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CLASE_TRANSACCION":"$CLASE_TRANSACCION","NOMBRE":"$NOMBRE","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","CONCEPTO_RIESGO":"$CONCEPTO_RIESGO","CRITERIO_RIESGO":"$CRITERIO_RIESGO","NATURALEZA_LESION":"$NATURALEZA_LESION","PARTE_CUERPO_AFEC":"$PARTE_CUERPO_AFEC","AGENTE_LESION":"$AGENTE_LESION","TIPO_ACCIDENTE":"$TIPO_ACCIDENTE","CAUSA_ACCIDENTE":"$CAUSA_ACCIDENTE","ACCIONES_CORRECT":"$ACCIONES_CORRECT","NOMBRE_RIESGO":"$NOMBRE_RIESGO","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","IND_INCAPACIDAD":"$IND_INCAPACIDAD(type:boolean)","DIAS_INCAPACIDAD":"$DIAS_INCAPACIDAD(type:integer)","IND_TESTIGOS":"$IND_TESTIGOS(type:boolean)","DIAGNOSTICO":"$DIAGNOSTICO","IND_REMISION":"$IND_REMISION(type:boolean)","FECHA_REMISION":"$FECHA_REMISION","OBSERVACION_REMISION":"$OBSERVACION_REMISION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FACTOR_RIESGO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CLASE_TRANSACCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natseguridadindustrial/data">
