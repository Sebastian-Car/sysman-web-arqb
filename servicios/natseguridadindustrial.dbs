	<query id="deleteNatseguridadindustrial" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_SEGURIDAD_INDUSTRIAL WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA= :KEY_COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO= :KEY_CONSECUTIVO AND NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL= :KEY_SUCURSAL AND NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO= :KEY_FACTOR_RIESGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FACTOR_RIESGO" sqlType="STRING"/>

	</query>
