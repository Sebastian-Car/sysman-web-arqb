	<query id="getNatseguridadindustrialRegistroAccidentesTrabajoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_SEGURIDAD_INDUSTRIAL.COMPANIA, NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO, NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO, NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.CONCEPTO_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.CRITERIO_RIESGO, NAT_SEGURIDAD_INDUSTRIAL.NATURALEZA_LESION, NAT_SEGURIDAD_INDUSTRIAL.PARTE_CUERPO_AFEC, NAT_SEGURIDAD_INDUSTRIAL.AGENTE_LESION, NAT_SEGURIDAD_INDUSTRIAL.TIPO_ACCIDENTE, NAT_SEGURIDAD_INDUSTRIAL.CAUSA_ACCIDENTE, NAT_SEGURIDAD_INDUSTRIAL.ACCIONES_CORRECT, NAT_SEGURIDAD_INDUSTRIAL.CREATED_BY, NAT_SEGURIDAD_INDUSTRIAL.MODIFIED_BY,(TO_CHAR(NAT_SEGURIDAD_INDUSTRIAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NAT_SEGURIDAD_INDUSTRIAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO, NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL, PERSONAL.NOMBRECOMPLETO  FROM NAT_SEGURIDAD_INDUSTRIAL INNER JOIN PERSONAL ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = PERSONAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = :KEY_COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO = :KEY_CONSECUTIVO AND NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO = :KEY_NUMERO_DCTO AND NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL = :KEY_SUCURSAL AND NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO = :KEY_FACTOR_RIESGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","FACTOR_RIESGO":"$FACTOR_RIESGO","CONCEPTO_RIESGO":"$CONCEPTO_RIESGO","CRITERIO_RIESGO":"$CRITERIO_RIESGO","NATURALEZA_LESION":"$NATURALEZA_LESION","PARTE_CUERPO_AFEC":"$PARTE_CUERPO_AFEC","AGENTE_LESION":"$AGENTE_LESION","TIPO_ACCIDENTE":"$TIPO_ACCIDENTE","CAUSA_ACCIDENTE":"$CAUSA_ACCIDENTE","ACCIONES_CORRECT":"$ACCIONES_CORRECT","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FACTOR_RIESGO" sqlType="STRING"/>

	</query>
