<data name="natseguridadindustrial" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatseguridadindustrialPagListaAccidentesLaboralesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_SEGURIDAD_INDUSTRIAL.COMPANIA , NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO , NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO , NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO, NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL, PERSONAL.NOMBRECOMPLETO, NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO , NAT_SEGURIDAD_INDUSTRIAL.CONCEPTO_RIESGO  FROM NAT_SEGURIDAD_INDUSTRIAL INNER JOIN PERSONAL ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = PERSONAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = :COMPANIA) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN FACTOR_RIESGO IS NULL THEN ' ' ELSE UPPER(FACTOR_RIESGO) END)  LIKE UPPER(:FACTOR_RIESGO || '%')  AND (CASE WHEN CONCEPTO_RIESGO IS NULL THEN ' ' ELSE UPPER(CONCEPTO_RIESGO) END)  LIKE UPPER(:CONCEPTO_RIESGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NOMBRECOMPLETO":"$NOMBRECOMPLETO","FACTOR_RIESGO":"$FACTOR_RIESGO","CONCEPTO_RIESGO":"$CONCEPTO_RIESGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="CONCEPTO_RIESGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natseguridadindustrial/listaaccidenteslaborales/pag">
		<call-query href="getNatseguridadindustrialPagListaAccidentesLaboralesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
