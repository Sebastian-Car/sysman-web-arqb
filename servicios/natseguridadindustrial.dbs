	<query id="updateNatseguridadindustrial" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_SEGURIDAD_INDUSTRIAL SET FACTOR_RIESGO=:FACTOR_RIESGO, CONCEPTO_RIESGO=:CONCEPTO_RIESGO, CRITERIO_RIESGO=:CRITERIO_RIESGO, NATURALEZA_LESION=:NATURALEZA_LESION, PARTE_CUERPO_AFEC=:PARTE_CUERPO_AFEC, AGENTE_LESION=:AGENTE_LESION, TIPO_ACCIDENTE=:TIPO_ACCIDENTE, CAUSA_ACCIDENTE=:CAUSA_ACCIDENTE, ACCIONES_CORRECT=:ACCIONES_CORRECT, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), IND_INCAPACIDAD=:IND_INCAPACIDAD, DIAS_INCAPACIDAD=:DIAS_INCAPACIDAD, IND_TESTIGOS=:IND_TESTIGOS, DIAGNOSTICO=:DIAGNOSTICO, IND_REMISION=:IND_REMISION, FECHA_REMISION=TO_DATE(:FECHA_REMISION,'DD/MM/YYYY HH24:MI:SS'), OBSERVACION_REMISION=:OBSERVACION_REMISION WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA= :KEY_COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO= :KEY_CONSECUTIVO AND NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL= :KEY_SUCURSAL AND NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO= :KEY_FACTOR_RIESGO AND NAT_SEGURIDAD_INDUSTRIAL.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND NAT_SEGURIDAD_INDUSTRIAL.CLASE_TRANSACCION= :KEY_CLASE_TRANSACCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="CONCEPTO_RIESGO" sqlType="STRING"/>
		<param name="CRITERIO_RIESGO" sqlType="STRING"/>
		<param name="NATURALEZA_LESION" sqlType="STRING"/>
