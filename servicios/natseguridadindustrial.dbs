	<query id="insertNatseguridadindustrial" keyColumns="COMPANIA,CONSECUTIVO,NUMERO_DCTO,SUCURSAL,FACTOR_RIESGO,TIPO_TRANSACCION,CLASE_TRANSACCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_SEGURIDAD_INDUSTRIAL (COMPANIA, CONSECUTIVO, NUMERO_DCTO, SUCURSAL, FACTOR_RIESGO, TIPO_TRANSACCION, CLASE_TRANSACCION, ID_DE_EMPLEADO, CONCEPTO_RIESGO, CRITERIO_RIESGO, NATURALEZA_LESION, PARTE_CUERPO_AFEC, AGENTE_LESION, TIPO_ACCIDENTE, CAUSA_ACCIDENTE, ACCIONES_CORRECT, IND_INCAPACIDAD, DIAS_INCAPACIDAD, IND_TESTIGOS, DIAGNOSTICO, IND_REMISION, FECHA_REMISION, OBSERVACION_REMISION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONSECUTIVO, :NUMERO_DCTO, :SUCURSAL, :FACTOR_RIESGO, :TIPO_TRANSACCION, :CLASE_TRANSACCION, :ID_DE_EMPLEADO, :CONCEPTO_RIESGO, :CRITERIO_RIESGO, :NATURALEZA_LESION, :PARTE_CUERPO_AFEC, :AGENTE_LESION, :TIPO_ACCIDENTE, :CAUSA_ACCIDENTE, :ACCIONES_CORRECT, :IND_INCAPACIDAD, :DIAS_INCAPACIDAD, :IND_TESTIGOS, :DIAGNOSTICO, :IND_REMISION, TO_DATE(:FECHA_REMISION,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACION_REMISION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_FACTOR_RIESGO":"$FACTOR_RIESGO","KEY_TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","KEY_CLASE_TRANSACCION":"$CLASE_TRANSACCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
