			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatseguridadindustrialNumListaAccidentesLaboralesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_SEGURIDAD_INDUSTRIAL.COMPANIA , NAT_SEGURIDAD_INDUSTRIAL.CONSECUTIVO , NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO , NAT_SEGURIDAD_INDUSTRIAL.NUMERO_DCTO, NAT_SEGURIDAD_INDUSTRIAL.SUCURSAL, PERSONAL.NOMBRECOMPLETO, NAT_SEGURIDAD_INDUSTRIAL.FACTOR_RIESGO , NAT_SEGURIDAD_INDUSTRIAL.CONCEPTO_RIESGO  FROM NAT_SEGURIDAD_INDUSTRIAL INNER JOIN PERSONAL ON NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = PERSONAL.COMPANIA AND NAT_SEGURIDAD_INDUSTRIAL.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO WHERE NAT_SEGURIDAD_INDUSTRIAL.COMPANIA = :COMPANIA) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN FACTOR_RIESGO IS NULL THEN ' ' ELSE UPPER(FACTOR_RIESGO) END)  LIKE UPPER(:FACTOR_RIESGO || '%')  AND (CASE WHEN CONCEPTO_RIESGO IS NULL THEN ' ' ELSE UPPER(CONCEPTO_RIESGO) END)  LIKE UPPER(:CONCEPTO_RIESGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="CONCEPTO_RIESGO" sqlType="STRING"/>

	</query>
