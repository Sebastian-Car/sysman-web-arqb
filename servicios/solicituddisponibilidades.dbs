	<query id="deleteSolicituddisponibilidades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SOLICITUDDISPONIBILIDAD WHERE SOLICITUDDISPONIBILIDAD.COMPANIA= :KEY_COMPANIA AND SOLICITUDDISPONIBILIDAD.NUMERO= :KEY_NUMERO AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD= :KEY_TIPO_SOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPO_SOLICITUD" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="solicituddisponibilidades">
		<call-query href="deleteSolicituddisponibilidades">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPO_SOLICITUD" query-param="KEY_TIPO_SOLICITUD"/>

		</call-query>
	</resource>
		<query id="getSolicituddisponibilidadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CASE SOLICITUDDISPONIBILIDAD.APROBACION WHEN - 1 THEN 'Aprobado' WHEN 0 THEN 'No aprobado' WHEN 2 THEN 'En revisión' WHEN 3 THEN 'Anulado' ELSE '' END APROBACION, CASE SOLICITUDDISPONIBILIDAD.APROBACION WHEN - 1 THEN '#22b14c' WHEN 0 THEN '#ff7f27' WHEN 2 THEN '#ffd700' WHEN 3 THEN '#ed1c24' ELSE '' END COLOR_APROBACION, SOLICITUDDISPONIBILIDAD.NUMERO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.OBJETO, SOLICITUDDISPONIBILIDAD.VALOR, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TIPOS.NOMBRE NOMBRE_TIPO, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD, SOLICITUDDISPONIBILIDAD.COMPANIA, SOLICITUDDISPONIBILIDAD.RESPONSABLE_APROBAR, CASE WHEN SOLICITUDDISPONIBILIDAD.AFECTADO NOT IN (0) AND EXISTS ( SELECT 1 FROM DETALLE_COMPROBANTE_PPTAL D WHERE D.COMPANIA = SOLICITUDDISPONIBILIDAD.COMPANIA AND D.ANO = SOLICITUDDISPONIBILIDAD.ANO AND D.NUMERO_SOLICITUD = SOLICITUDDISPONIBILIDAD.NUMERO AND D.TIPO_SOLICITUD = SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD AND D.TIPO_CPTE = 'CDP' ) THEN 'Si' ELSE 'No' END AS AFECTADO FROM SOLICITUDDISPONIBILIDAD INNER JOIN DEPENDENCIA ON SOLICITUDDISPONIBILIDAD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUDDISPONIBILIDAD.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TIPOS ON SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = TIPOS.ID WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND SOLICITUDDISPONIBILIDAD.ANO = :ANO ORDER BY CASE WHEN :ORDEN = 'N' THEN TO_NUMBER(SOLICITUDDISPONIBILIDAD.NUMERO) END DESC, CASE WHEN :ORDEN = 'F' THEN SOLICITUDDISPONIBILIDAD.FECHA END DESC, CASE WHEN :ORDEN = 'D' THEN SOLICITUDDISPONIBILIDAD.DEPENDENCIA END DESC, CASE WHEN :ORDEN = 'E' THEN APROBACION END ASC) INI WHERE (CASE WHEN APROBACION IS NULL THEN ' ' ELSE UPPER(APROBACION) END) LIKE UPPER(CONCAT(:APROBACION, '%')) AND (CASE WHEN COLOR_APROBACION IS NULL THEN ' ' ELSE UPPER(COLOR_APROBACION) END) LIKE UPPER(CONCAT(CONCAT('%',:COLOR_APROBACION), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(:OBJETO, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEPENDENCIA), '%')) AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPO), '%')) AND (CASE WHEN RESPONSABLE_APROBAR IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_APROBAR) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE_APROBAR), '%')) AND (CASE WHEN AFECTADO IS NULL THEN ' ' ELSE UPPER(AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:AFECTADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APROBACION":"$APROBACION","COLOR_APROBACION":"$COLOR_APROBACION","NUMERO":"$NUMERO","FECHA":"$FECHA","OBJETO":"$OBJETO","VALOR":"$VALOR","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_TIPO":"$NOMBRE_TIPO","TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)","COMPANIA":"$COMPANIA","RESPONSABLE_APROBAR":"$RESPONSABLE_APROBAR","AFECTADO":"$AFECTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="APROBACION" sqlType="STRING"/>
		<param name="COLOR_APROBACION" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="RESPONSABLE_APROBAR" sqlType="STRING"/>
		<param name="AFECTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
