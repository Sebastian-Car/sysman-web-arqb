	<query id="getSolicituddisponibilidadesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SOLICITUDDISPONIBILIDAD.COMPANIA, SOLICITUDDISPONIBILIDAD.NUMERO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.OBJETO, SOLICITUDDISPONIBILIDAD.VALOR, SOLICITUDDISPONIBILIDAD.IMPUESTO, SOLICITUDDISPONIBILIDAD.VALOR_BASE, SOLICITUDDISPONIBILIDAD.ANO, SOLICITUDDISPONIBILIDAD.DEPENDENCIA, SOLICITUDDISPONIBILIDAD.TERCERO, SOLICITUDDISPONIBILIDAD.CREATED_BY,(TO_CHAR(SOLICITUDDISPONIBILIDAD.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SOLICITUDDISPONIBILIDAD.MODIFIED_BY,(TO_CHAR(SOLICITUDDISPONIBILIDAD.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SOLICITUDDISPONIBILIDAD.MODALIDAD_SELECCION,(CASE SOLICITUDDISPONIBILIDAD.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, TERCERO.SUCURSAL,(CASE SOLICITUDDISPONIBILIDAD.AFECTADO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADO, DEPENDENCIA.NOMBRE AS NOMBRE_DEPENDENCIA, TERCERO.NOMBRE AS NOMBRE_TERCERO, TIPOADJUDICACION.DESCRIPCION AS DESCRIPCION_MODALIDAD, SOLICITUDDISPONIBILIDAD.NRO_SOLICITUD_AFECT, SOLICITUDDISPONIBILIDAD.TIPO_CPTE_AFECT, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD, SOLICITUDDISPONIBILIDAD.BENEFICIARIO, TERCERO2.NOMBRE AS NOMBRE_BENEFICIARIO, SOLICITUDDISPONIBILIDAD.REFERENCIA, REFERENCIA.NOMBRE AS NOMBRE_REFERENCIA, SOLICITUDDISPONIBILIDAD.RECURSO, TIPOS.NOMBRE NOMBRE_TIPO_SOL, CASE SOLICITUDDISPONIBILIDAD.APROBACION WHEN - 1 THEN 'A' WHEN 0 THEN 'N' WHEN 2 THEN 'E' WHEN 3 THEN 'AN' ELSE '' END APROBACION,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_APROBACION, SOLICITUDDISPONIBILIDAD.DISPONIBILIDAD_RELACIONADA, SOLICITUDDISPONIBILIDAD.MOTIVO_RECHAZO, SOLICITUDDISPONIBILIDAD.DISPONIBILIDADNUMERO, SOLICITUDDISPONIBILIDAD.RESPONSABLE_APROBAR, SOLICITUDDISPONIBILIDAD.SUCURSAL_APROBAR, TER_APRO.NOMBRE AS NOMBRE_APROBAR, SOLICITUDDISPONIBILIDAD.CIUDAD, SOLICITUDDISPONIBILIDAD.TIPO_COMPROMISO, TIPO_COMPROMISOPPTAL.NOMBRE AS NOMBRE_COMPROMISO FROM SOLICITUDDISPONIBILIDAD LEFT JOIN DEPENDENCIA ON SOLICITUDDISPONIBILIDAD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUDDISPONIBILIDAD.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON SOLICITUDDISPONIBILIDAD.COMPANIA = TERCERO.COMPANIA AND SOLICITUDDISPONIBILIDAD.TERCERO = TERCERO.NIT AND SOLICITUDDISPONIBILIDAD.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN TERCERO TERCERO2 ON SOLICITUDDISPONIBILIDAD.COMPANIA = TERCERO2.COMPANIA AND SOLICITUDDISPONIBILIDAD.BENEFICIARIO = TERCERO2.NIT AND SOLICITUDDISPONIBILIDAD.SUCURSAL = TERCERO2.SUCURSAL LEFT JOIN TIPOADJUDICACION ON SOLICITUDDISPONIBILIDAD.COMPANIA = TIPOADJUDICACION.COMPANIA AND SOLICITUDDISPONIBILIDAD.MODALIDAD_SELECCION = TIPOADJUDICACION.CODIGO INNER JOIN TIPOS ON TIPOS.ID = SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD LEFT JOIN TERCERO TER_APRO ON SOLICITUDDISPONIBILIDAD.COMPANIA = TER_APRO.COMPANIA AND SOLICITUDDISPONIBILIDAD.RESPONSABLE_APROBAR = TER_APRO.NIT AND SOLICITUDDISPONIBILIDAD.SUCURSAL_APROBAR = TER_APRO.SUCURSAL LEFT JOIN REFERENCIA ON SOLICITUDDISPONIBILIDAD.COMPANIA = REFERENCIA.COMPANIA AND SOLICITUDDISPONIBILIDAD.ANO = REFERENCIA.ANO AND SOLICITUDDISPONIBILIDAD.REFERENCIA = REFERENCIA.CODIGO LEFT JOIN TIPO_COMPROMISOPPTAL ON SOLICITUDDISPONIBILIDAD.COMPANIA = TIPO_COMPROMISOPPTAL.COMPANIA AND SOLICITUDDISPONIBILIDAD.TIPO_COMPROMISO = TIPO_COMPROMISOPPTAL.CODIGO WHERE SOLICITUDDISPONIBILIDAD.COMPANIA= :KEY_COMPANIA AND SOLICITUDDISPONIBILIDAD.NUMERO= :KEY_NUMERO AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD= :KEY_TIPO_SOLICITUD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO","FECHA":"$FECHA","OBJETO":"$OBJETO","VALOR":"$VALOR(type:double)","IMPUESTO":"$IMPUESTO","VALOR_BASE":"$VALOR_BASE","ANO":"$ANO(type:integer)","DEPENDENCIA":"$DEPENDENCIA","TERCERO":"$TERCERO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODALIDAD_SELECCION":"$MODALIDAD_SELECCION","IMPRESO":"$IMPRESO(type:boolean)","SUCURSAL":"$SUCURSAL","AFECTADO":"$AFECTADO(type:boolean)","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_TERCERO":"$NOMBRE_TERCERO","DESCRIPCION_MODALIDAD":"$DESCRIPCION_MODALIDAD","NRO_SOLICITUD_AFECT":"$NRO_SOLICITUD_AFECT","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)","BENEFICIARIO":"$BENEFICIARIO","NOMBRE_BENEFICIARIO":"$NOMBRE_BENEFICIARIO","REFERENCIA":"$REFERENCIA","NOMBRE_REFERENCIA":"$NOMBRE_REFERENCIA","RECURSO":"$RECURSO","NOMBRE_TIPO_SOL":"$NOMBRE_TIPO_SOL","APROBACION":"$APROBACION","FECHA_APROBACION":"$FECHA_APROBACION","DISPONIBILIDAD_RELACIONADA":"$DISPONIBILIDAD_RELACIONADA","MOTIVO_RECHAZO":"$MOTIVO_RECHAZO","DISPONIBILIDADNUMERO":"$DISPONIBILIDADNUMERO","RESPONSABLE_APROBAR":"$RESPONSABLE_APROBAR","SUCURSAL_APROBAR":"$SUCURSAL_APROBAR","NOMBRE_APROBAR":"$NOMBRE_APROBAR","CIUDAD":"$CIUDAD","TIPO_COMPROMISO":"$TIPO_COMPROMISO","NOMBRE_COMPROMISO":"$NOMBRE_COMPROMISO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPO_SOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/data">
		<call-query href="getSolicituddisponibilidadesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPO_SOLICITUD" query-param="KEY_TIPO_SOLICITUD"/>

		</call-query>
	</resource>
	<query id="updateSolicituddisponibilidades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SOLICITUDDISPONIBILIDAD SET FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), OBJETO=:OBJETO, VALOR=:VALOR, IMPUESTO=:IMPUESTO, VALOR_BASE=:VALOR_BASE, ANO=:ANO, DEPENDENCIA=:DEPENDENCIA, TERCERO=:TERCERO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODALIDAD_SELECCION=:MODALIDAD_SELECCION, IMPRESO=:IMPRESO, SUCURSAL=:SUCURSAL, AFECTADO=:AFECTADO, APROBACION=:APROBACION, FECHA_APROBACION=TO_DATE(:FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS'), NRO_SOLICITUD_AFECT=:NRO_SOLICITUD_AFECT, TIPO_CPTE_AFECT=:TIPO_CPTE_AFECT, TIPO_SOLICITUD=:TIPO_SOLICITUD, DISPONIBILIDAD_RELACIONADA=:DISPONIBILIDAD_RELACIONADA, MOTIVO_RECHAZO=:MOTIVO_RECHAZO, DISPONIBILIDADNUMERO=:DISPONIBILIDADNUMERO, RESPONSABLE_APROBAR=:RESPONSABLE_APROBAR, SUCURSAL_APROBAR=:SUCURSAL_APROBAR, REFERENCIA=:REFERENCIA, BENEFICIARIO=:BENEFICIARIO, RECURSO=:RECURSO, CIUDAD=:CIUDAD, TIPO_COMPROMISO=:TIPO_COMPROMISO WHERE SOLICITUDDISPONIBILIDAD.COMPANIA= :KEY_COMPANIA AND SOLICITUDDISPONIBILIDAD.NUMERO= :KEY_NUMERO AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD= :KEY_TIPO_SOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="IMPUESTO" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODALIDAD_SELECCION" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="AFECTADO" sqlType="STRING"/>
		<param name="APROBACION" sqlType="STRING"/>
		<param name="FECHA_APROBACION" sqlType="STRING"/>
		<param name="NRO_SOLICITUD_AFECT" sqlType="STRING"/>
		<param name="TIPO_CPTE_AFECT" sqlType="STRING"/>
		<param name="TIPO_SOLICITUD" sqlType="STRING"/>
		<param name="DISPONIBILIDAD_RELACIONADA" sqlType="STRING"/>
		<param name="MOTIVO_RECHAZO" sqlType="STRING"/>
		<param name="DISPONIBILIDADNUMERO" sqlType="STRING"/>
		<param name="RESPONSABLE_APROBAR" sqlType="STRING"/>
		<param name="SUCURSAL_APROBAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="RECURSO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="TIPO_COMPROMISO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPO_SOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="solicituddisponibilidades">
		<call-query href="updateSolicituddisponibilidades">
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="IMPUESTO" query-param="IMPUESTO"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODALIDAD_SELECCION" query-param="MODALIDAD_SELECCION"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="AFECTADO" query-param="AFECTADO"/>
			<with-param name="APROBACION" query-param="APROBACION"/>
			<with-param name="FECHA_APROBACION" query-param="FECHA_APROBACION"/>
			<with-param name="NRO_SOLICITUD_AFECT" query-param="NRO_SOLICITUD_AFECT"/>
			<with-param name="TIPO_CPTE_AFECT" query-param="TIPO_CPTE_AFECT"/>
			<with-param name="TIPO_SOLICITUD" query-param="TIPO_SOLICITUD"/>
			<with-param name="DISPONIBILIDAD_RELACIONADA" query-param="DISPONIBILIDAD_RELACIONADA"/>
			<with-param name="MOTIVO_RECHAZO" query-param="MOTIVO_RECHAZO"/>
			<with-param name="DISPONIBILIDADNUMERO" query-param="DISPONIBILIDADNUMERO"/>
			<with-param name="RESPONSABLE_APROBAR" query-param="RESPONSABLE_APROBAR"/>
			<with-param name="SUCURSAL_APROBAR" query-param="SUCURSAL_APROBAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="RECURSO" query-param="RECURSO"/>
			<with-param name="CIUDAD" query-param="CIUDAD"/>
			<with-param name="TIPO_COMPROMISO" query-param="TIPO_COMPROMISO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPO_SOLICITUD" query-param="KEY_TIPO_SOLICITUD"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesPagNumeroyobjetoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO, SOLICITUDDISPONIBILIDAD.OBJETO FROM SOLICITUDDISPONIBILIDAD WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = :TIPOSOLICITUD ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","OBJETO":"$OBJETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOSOLICITUD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/numeroyobjeto/pag">
		<call-query href="getSolicituddisponibilidadesPagNumeroyobjetoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOSOLICITUD" query-param="TIPOSOLICITUD"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesNumNumeroyobjetoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO, SOLICITUDDISPONIBILIDAD.OBJETO FROM SOLICITUDDISPONIBILIDAD WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = :TIPOSOLICITUD ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOSOLICITUD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/numeroyobjeto/num">
		<call-query href="getSolicituddisponibilidadesNumNumeroyobjetoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOSOLICITUD" query-param="TIPOSOLICITUD"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
		
		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesPagTodosporterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO NUMERO_SOLICITUD, SOLICITUDDISPONIBILIDAD.OBJETO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.VALOR VALORSOLICITADO, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD FROM SOLICITUDDISPONIBILIDAD WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND TIPO_SOLICITUD = CASE (:TIPO) WHEN 'SCD' THEN 1 WHEN 'SAD' THEN 2 WHEN 'SRE' THEN 3 END AND SOLICITUDDISPONIBILIDAD.AFECTADO IN (0) AND SOLICITUDDISPONIBILIDAD.APROBACION IN ('-1','2') AND BENEFICIARIO = :TERCERO AND TRUNC(TO_DATE(TO_CHAR(FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')) &lt;= TO_DATE(:FECHAACTUAL, 'DD/MM/YYYY') ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO_SOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMERO_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_SOLICITUD), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END) LIKE UPPER(CONCAT(:VALORSOLICITADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_SOLICITUD":"$NUMERO_SOLICITUD","OBJETO":"$OBJETO","FECHA":"$FECHA","VALORSOLICITADO":"$VALORSOLICITADO","TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHAACTUAL" sqlType="STRING"/>
		<param name="NUMERO_SOLICITUD" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALORSOLICITADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/todosportercero/pag">
		<call-query href="getSolicituddisponibilidadesPagTodosporterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
