<data name="solicituddisponibilidades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSolicituddisponibilidadesPagListasolicitudesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO, SOLICITUDDISPONIBILIDAD.DEPENDENCIA, SOLICITUDDISPONIBILIDAD.TERCERO, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_TERCERO, TERCERO.SUCURSAL,SOLICITUDDISPONIBILIDAD.OBJETO FROM SOLICITUDDISPONIBILIDAD LEFT JOIN DEPENDENCIA ON SOLICITUDDISPONIBILIDAD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUDDISPONIBILIDAD.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON SOLICITUDDISPONIBILIDAD.COMPANIA = TERCERO.COMPANIA AND SOLICITUDDISPONIBILIDAD.TERCERO = TERCERO.NIT AND SOLICITUDDISPONIBILIDAD.SUCURSAL = TERCERO.SUCURSAL WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = :TIPOSOLICITUD ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DEPENDENCIA":"$DEPENDENCIA","TERCERO":"$TERCERO","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_TERCERO":"$NOMBRE_TERCERO","SUCURSAL":"$SUCURSAL","OBJETO":"$OBJETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOSOLICITUD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/listasolicitudes/pag">
		<call-query href="getSolicituddisponibilidadesPagListasolicitudesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOSOLICITUD" query-param="TIPOSOLICITUD"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesNumListasolicitudesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO, SOLICITUDDISPONIBILIDAD.DEPENDENCIA, SOLICITUDDISPONIBILIDAD.TERCERO, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TERCERO.NOMBRE NOMBRE_TERCERO, TERCERO.SUCURSAL,SOLICITUDDISPONIBILIDAD.OBJETO FROM SOLICITUDDISPONIBILIDAD LEFT JOIN DEPENDENCIA ON SOLICITUDDISPONIBILIDAD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUDDISPONIBILIDAD.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON SOLICITUDDISPONIBILIDAD.COMPANIA = TERCERO.COMPANIA AND SOLICITUDDISPONIBILIDAD.TERCERO = TERCERO.NIT AND SOLICITUDDISPONIBILIDAD.SUCURSAL = TERCERO.SUCURSAL WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = :TIPOSOLICITUD ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOSOLICITUD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/listasolicitudes/num">
		<call-query href="getSolicituddisponibilidadesNumListasolicitudesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOSOLICITUD" query-param="TIPOSOLICITUD"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO NUMERO_SOLICITUD, SOLICITUDDISPONIBILIDAD.OBJETO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.VALOR VALORSOLICITADO, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD FROM SOLICITUDDISPONIBILIDAD WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND TIPO_SOLICITUD = CASE (:TIPO) WHEN 'SCD' THEN 1 WHEN 'SAD' THEN 2 WHEN 'SRE' THEN 3 END AND SOLICITUDDISPONIBILIDAD.AFECTADO IN (0) AND SOLICITUDDISPONIBILIDAD.APROBACION IN ('-1','2') AND TRUNC(TO_DATE(TO_CHAR(FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')) &lt;= TO_DATE(:FECHAACTUAL, 'DD/MM/YYYY') ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO_SOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMERO_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_SOLICITUD), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END) LIKE UPPER(CONCAT(:VALORSOLICITADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_SOLICITUD":"$NUMERO_SOLICITUD","OBJETO":"$OBJETO","FECHA":"$FECHA","VALORSOLICITADO":"$VALORSOLICITADO","TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FECHAACTUAL" sqlType="STRING"/>
		<param name="NUMERO_SOLICITUD" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALORSOLICITADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/todosporcompania/pag">
		<call-query href="getSolicituddisponibilidadesPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="FECHAACTUAL" query-param="FECHAACTUAL"/>
			<with-param name="NUMERO_SOLICITUD" query-param="NUMERO_SOLICITUD"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALORSOLICITADO" query-param="VALORSOLICITADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO NUMERO_SOLICITUD, SOLICITUDDISPONIBILIDAD.OBJETO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.VALOR VALORSOLICITADO, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD FROM SOLICITUDDISPONIBILIDAD WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND TIPO_SOLICITUD = CASE (:TIPO) WHEN 'SCD' THEN 1 WHEN 'SAD' THEN 2 WHEN 'SRE' THEN 3 END AND SOLICITUDDISPONIBILIDAD.AFECTADO IN (0) AND SOLICITUDDISPONIBILIDAD.APROBACION IN ('-1','2') AND TRUNC(TO_DATE(TO_CHAR(FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')) &lt;= TO_DATE(:FECHAACTUAL, 'DD/MM/YYYY') ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO_SOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMERO_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_SOLICITUD), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END) LIKE UPPER(CONCAT(:VALORSOLICITADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FECHAACTUAL" sqlType="STRING"/>
		<param name="NUMERO_SOLICITUD" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALORSOLICITADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/todosporcompania/num">
		<call-query href="getSolicituddisponibilidadesNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="FECHAACTUAL" query-param="FECHAACTUAL"/>
			<with-param name="NUMERO_SOLICITUD" query-param="NUMERO_SOLICITUD"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALORSOLICITADO" query-param="VALORSOLICITADO"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesSolictudesvaciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL( LISTAGG( (CONCAT( '(', CONCAT( NUMERO ,CONCAT( ' -- ', CONCAT( FECHA, ')'))))),', ') WITHIN GROUP( ORDER BY NUMERO ),NULL) LISTADO FROM SOLICITUDDISPONIBILIDAD WHERE TIPO_SOLICITUD IN ( '1' ) AND DISPONIBILIDADNUMERO IS NULL AND COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LISTADO":"$LISTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/solictudesvacias">
		<call-query href="getSolicituddisponibilidadesSolictudesvaciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesPagGrillaporususarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CASE SOLICITUDDISPONIBILIDAD.APROBACION WHEN - 1 THEN 'Aprobado' WHEN 0 THEN 'No aprobado' WHEN 2 THEN 'En revisión' WHEN 3 THEN 'Anulado' ELSE '' END APROBACION, CASE SOLICITUDDISPONIBILIDAD.APROBACION WHEN - 1 THEN '#22b14c' WHEN 0 THEN '#ff7f27' WHEN 2 THEN '#ffd700' WHEN 3 THEN '#ed1c24' ELSE '' END COLOR_APROBACION, SOLICITUDDISPONIBILIDAD.NUMERO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.OBJETO, SOLICITUDDISPONIBILIDAD.VALOR, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TIPOS.NOMBRE NOMBRE_TIPO, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD, SOLICITUDDISPONIBILIDAD.COMPANIA, SOLICITUDDISPONIBILIDAD.RESPONSABLE_APROBAR, CASE WHEN SOLICITUDDISPONIBILIDAD.AFECTADO NOT IN (0) AND EXISTS ( SELECT 1 FROM DETALLE_COMPROBANTE_PPTAL D WHERE D.COMPANIA = SOLICITUDDISPONIBILIDAD.COMPANIA AND D.ANO = SOLICITUDDISPONIBILIDAD.ANO AND D.NUMERO_SOLICITUD = SOLICITUDDISPONIBILIDAD.NUMERO AND D.TIPO_SOLICITUD = SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD AND D.TIPO_CPTE = 'CDP' ) THEN 'Si' ELSE 'No' END AS AFECTADO FROM SOLICITUDDISPONIBILIDAD INNER JOIN DEPENDENCIA ON SOLICITUDDISPONIBILIDAD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUDDISPONIBILIDAD.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TIPOS ON SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = TIPOS.ID WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND SOLICITUDDISPONIBILIDAD.ANO = :ANO ORDER BY CASE WHEN :ORDEN = 'N' THEN TO_NUMBER(SOLICITUDDISPONIBILIDAD.NUMERO) END DESC, CASE WHEN :ORDEN = 'F' THEN SOLICITUDDISPONIBILIDAD.FECHA END DESC, CASE WHEN :ORDEN = 'D' THEN SOLICITUDDISPONIBILIDAD.DEPENDENCIA END DESC, CASE WHEN :ORDEN = 'E' THEN APROBACION END ASC) INI WHERE (CASE WHEN APROBACION IS NULL THEN ' ' ELSE UPPER(APROBACION) END) LIKE UPPER(CONCAT(:APROBACION, '%')) AND (CASE WHEN COLOR_APROBACION IS NULL THEN ' ' ELSE UPPER(COLOR_APROBACION) END) LIKE UPPER(CONCAT(CONCAT('%',:COLOR_APROBACION), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(:OBJETO, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEPENDENCIA), '%')) AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPO), '%')) AND (CASE WHEN RESPONSABLE_APROBAR IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_APROBAR) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE_APROBAR), '%')) AND (CASE WHEN AFECTADO IS NULL THEN ' ' ELSE UPPER(AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:AFECTADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APROBACION":"$APROBACION","COLOR_APROBACION":"$COLOR_APROBACION","NUMERO":"$NUMERO","FECHA":"$FECHA","OBJETO":"$OBJETO","VALOR":"$VALOR","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","NOMBRE_TIPO":"$NOMBRE_TIPO","TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)","COMPANIA":"$COMPANIA","RESPONSABLE_APROBAR":"$RESPONSABLE_APROBAR","AFECTADO":"$AFECTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="APROBACION" sqlType="STRING"/>
		<param name="COLOR_APROBACION" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="RESPONSABLE_APROBAR" sqlType="STRING"/>
		<param name="AFECTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="solicituddisponibilidades/grillaporususario/pag">
		<call-query href="getSolicituddisponibilidadesPagGrillaporususarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="APROBACION" query-param="APROBACION"/>
			<with-param name="COLOR_APROBACION" query-param="COLOR_APROBACION"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="RESPONSABLE_APROBAR" query-param="RESPONSABLE_APROBAR"/>
			<with-param name="AFECTADO" query-param="AFECTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesNumGrillaporususarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CASE SOLICITUDDISPONIBILIDAD.APROBACION WHEN - 1 THEN 'Aprobado' WHEN 0 THEN 'No aprobado' WHEN 2 THEN 'En revisión' WHEN 3 THEN 'Anulado' ELSE '' END APROBACION, CASE SOLICITUDDISPONIBILIDAD.APROBACION WHEN - 1 THEN '#22b14c' WHEN 0 THEN '#ff7f27' WHEN 2 THEN '#ffd700' WHEN 3 THEN '#ed1c24' ELSE '' END COLOR_APROBACION, SOLICITUDDISPONIBILIDAD.NUMERO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.OBJETO, SOLICITUDDISPONIBILIDAD.VALOR, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, TIPOS.NOMBRE NOMBRE_TIPO, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD, SOLICITUDDISPONIBILIDAD.COMPANIA, SOLICITUDDISPONIBILIDAD.RESPONSABLE_APROBAR, CASE WHEN SOLICITUDDISPONIBILIDAD.AFECTADO NOT IN (0) AND EXISTS ( SELECT 1 FROM DETALLE_COMPROBANTE_PPTAL D WHERE D.COMPANIA = SOLICITUDDISPONIBILIDAD.COMPANIA AND D.ANO = SOLICITUDDISPONIBILIDAD.ANO AND D.NUMERO_SOLICITUD = SOLICITUDDISPONIBILIDAD.NUMERO AND D.TIPO_SOLICITUD = SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD AND D.TIPO_CPTE = 'CDP' ) THEN 'Si' ELSE 'No' END AS AFECTADO FROM SOLICITUDDISPONIBILIDAD INNER JOIN DEPENDENCIA ON SOLICITUDDISPONIBILIDAD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUDDISPONIBILIDAD.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TIPOS ON SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD = TIPOS.ID WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND SOLICITUDDISPONIBILIDAD.ANO = :ANO ORDER BY CASE WHEN :ORDEN = 'N' THEN TO_NUMBER(SOLICITUDDISPONIBILIDAD.NUMERO) END DESC, CASE WHEN :ORDEN = 'F' THEN SOLICITUDDISPONIBILIDAD.FECHA END DESC, CASE WHEN :ORDEN = 'D' THEN SOLICITUDDISPONIBILIDAD.DEPENDENCIA END DESC, CASE WHEN :ORDEN = 'E' THEN APROBACION END ASC) INI WHERE (CASE WHEN APROBACION IS NULL THEN ' ' ELSE UPPER(APROBACION) END) LIKE UPPER(CONCAT(:APROBACION, '%')) AND (CASE WHEN COLOR_APROBACION IS NULL THEN ' ' ELSE UPPER(COLOR_APROBACION) END) LIKE UPPER(CONCAT(CONCAT('%',:COLOR_APROBACION), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(:OBJETO, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEPENDENCIA), '%')) AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPO), '%')) AND (CASE WHEN RESPONSABLE_APROBAR IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_APROBAR) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE_APROBAR), '%')) AND (CASE WHEN AFECTADO IS NULL THEN ' ' ELSE UPPER(AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:AFECTADO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="APROBACION" sqlType="STRING"/>
		<param name="COLOR_APROBACION" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="RESPONSABLE_APROBAR" sqlType="STRING"/>
		<param name="AFECTADO" sqlType="STRING"/>

	</query>
