	<query id="insertSolicituddisponibilidades" keyColumns="COMPANIA,NUMERO,TIPO_SOLICITUD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SOLICITUDDISPONIBILIDAD (COMPANIA, NUMERO, FECHA, OBJETO, VALOR, IMPUESTO, VALOR_BASE, ANO, DEPENDENCIA, TERCERO, CREATED_BY, DATE_CREATED, MODALIDAD_SELECCION, IMPRESO, SUCURSAL, AFECTADO, NRO_SOLICITUD_AFECT, TIPO_CPTE_AFECT, TIPO_SOLICITUD, APROBACION, FECHA_APROBACION, TIPO_AFECTACION, DISPONIBILIDAD_RELACIONADA, MOTIVO_RECHAZO, DISPONIBILIDADNUMERO, RESPONSABLE_APROBAR, SUCURSAL_APROBAR, REFERENCIA, BENEFICIARIO, RECURSO, CIUDAD, TIPO_COMPROMISO) VALUES (:COMPANIA, :NUMERO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :OBJETO, :VALOR, :IMPUESTO, :VALOR_BASE, :ANO, :DEPENDENCIA, :TERCERO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :MODALIDAD_SELECCION, :IMPRESO, :SUCURSAL, :AFECTADO, :NRO_SOLICITUD_AFECT, :TIPO_CPTE_AFECT, :TIPO_SOLICITUD, :APROBACION, TO_DATE(:FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS'), :TIPO_AFECTACION, :DISPONIBILIDAD_RELACIONADA, :MOTIVO_RECHAZO, :DISPONIBILIDADNUMERO, :RESPONSABLE_APROBAR, :SUCURSAL_APROBAR, :REFERENCIA, :BENEFICIARIO, :RECURSO, :CIUDAD, :TIPO_COMPROMISO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO","KEY_TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="OBJETO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="IMPUESTO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_BASE" sqlType="STRING"/>
		<param defaultValue="0" name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="MODALIDAD_SELECCION" sqlType="STRING"/>
		<param defaultValue="0" name="IMPRESO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="AFECTADO" sqlType="STRING"/>
		<param defaultValue="" name="NRO_SOLICITUD_AFECT" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CPTE_AFECT" sqlType="STRING"/>
		<param defaultValue="1" name="TIPO_SOLICITUD" sqlType="STRING"/>
		<param defaultValue="2" name="APROBACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_APROBACION" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_AFECTACION" sqlType="STRING"/>
		<param defaultValue=" " name="DISPONIBILIDAD_RELACIONADA" sqlType="STRING"/>
		<param defaultValue="" name="MOTIVO_RECHAZO" sqlType="STRING"/>
		<param defaultValue="" name="DISPONIBILIDADNUMERO" sqlType="STRING"/>
		<param defaultValue="" name="RESPONSABLE_APROBAR" sqlType="STRING"/>
		<param defaultValue="" name="SUCURSAL_APROBAR" sqlType="STRING"/>
		<param defaultValue="" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="BENEFICIARIO" sqlType="STRING"/>
		<param defaultValue="" name="RECURSO" sqlType="STRING"/>
		<param defaultValue="" name="CIUDAD" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_COMPROMISO" sqlType="STRING"/>

	</query>
