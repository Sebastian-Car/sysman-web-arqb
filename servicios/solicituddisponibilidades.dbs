			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSolicituddisponibilidadesNumTodosporterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SOLICITUDDISPONIBILIDAD.NUMERO NUMERO_SOLICITUD, SOLICITUDDISPONIBILIDAD.OBJETO,(TO_CHAR(SOLICITUDDISPONIBILIDAD.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SOLICITUDDISPONIBILIDAD.VALOR VALORSOLICITADO, SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD FROM SOLICITUDDISPONIBILIDAD WHERE SOLICITUDDISPONIBILIDAD.COMPANIA = :COMPANIA AND TIPO_SOLICITUD = CASE (:TIPO) WHEN 'SCD' THEN 1 WHEN 'SAD' THEN 2 WHEN 'SRE' THEN 3 END AND SOLICITUDDISPONIBILIDAD.AFECTADO IN (0) AND SOLICITUDDISPONIBILIDAD.APROBACION IN ('-1','2') AND BENEFICIARIO = :TERCERO AND TRUNC(TO_DATE(TO_CHAR(FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')) &lt;= TO_DATE(:FECHAACTUAL, 'DD/MM/YYYY') ORDER BY SOLICITUDDISPONIBILIDAD.NUMERO) INI WHERE (CASE WHEN NUMERO_SOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMERO_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_SOLICITUD), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END) LIKE UPPER(CONCAT(:VALORSOLICITADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHAACTUAL" sqlType="STRING"/>
