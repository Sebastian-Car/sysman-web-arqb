<data name="natcomision" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatcomision" keyColumns="COMPANIA,CO_NUMEDOCU,SUCURSAL,CO_TIPODOCUACTO,CO_NUME" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_COMISION (COMPANIA, CO_NUMEDOCU, SUCURSAL, CO_TIPODOCUACTO, CO_NUME, CO_CARGO, COPAIS, CODPTO, COMUNI, CO_ENTI, CO_DESC, CREATED_BY, CO_FECHRESODECR, DATE_CREATED, CO_FECHDESDE, CO_FECHHASTA) VALUES (:COMPANIA, :CO_NUMEDOCU, :SUCURSAL, :CO_TIPODOCUACTO, :CO_NUME, :CO_CARGO, :COPAIS, :CODPTO, :COMUNI, :CO_ENTI, :CO_DESC, :CREATED_BY, TO_DATE(:CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:CO_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:CO_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CO_NUMEDOCU":"$CO_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_CO_TIPODOCUACTO":"$CO_TIPODOCUACTO","KEY_CO_NUME":"$CO_NUME","KEY_CO_FECHRESODECR":"$CO_FECHRESODECR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CO_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param defaultValue="" name="CO_CARGO" sqlType="STRING"/>
		<param defaultValue="" name="COPAIS" sqlType="STRING"/>
		<param defaultValue="" name="CODPTO" sqlType="STRING"/>
		<param defaultValue="" name="COMUNI" sqlType="STRING"/>
		<param defaultValue="" name="CO_ENTI" sqlType="STRING"/>
		<param defaultValue="" name="CO_DESC" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="CO_FECHRESODECR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="CO_FECHDESDE" sqlType="STRING"/>
		<param defaultValue="" name="CO_FECHHASTA" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natcomision">
		<call-query href="insertNatcomision">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CO_NUMEDOCU" query-param="CO_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CO_TIPODOCUACTO" query-param="CO_TIPODOCUACTO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="CO_CARGO" query-param="CO_CARGO"/>
			<with-param name="COPAIS" query-param="COPAIS"/>
			<with-param name="CODPTO" query-param="CODPTO"/>
			<with-param name="COMUNI" query-param="COMUNI"/>
			<with-param name="CO_ENTI" query-param="CO_ENTI"/>
			<with-param name="CO_DESC" query-param="CO_DESC"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="CO_FECHRESODECR" query-param="CO_FECHRESODECR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CO_FECHDESDE" query-param="CO_FECHDESDE"/>
			<with-param name="CO_FECHHASTA" query-param="CO_FECHHASTA"/>

		</call-query>
	</resource>
	<query id="deleteNatcomision" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_COMISION WHERE NAT_COMISION.COMPANIA= :KEY_COMPANIA AND NAT_COMISION.CO_NUMEDOCU= :KEY_CO_NUMEDOCU AND NAT_COMISION.SUCURSAL= :KEY_SUCURSAL AND NAT_COMISION.CO_TIPODOCUACTO= :KEY_CO_TIPODOCUACTO AND NAT_COMISION.CO_NUME= :KEY_CO_NUME AND NAT_COMISION.CO_FECHRESODECR= TO_DATE(:KEY_CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CO_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_CO_NUME" sqlType="STRING"/>
		<param name="KEY_CO_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natcomision">
		<call-query href="deleteNatcomision">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CO_NUMEDOCU" query-param="KEY_CO_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CO_TIPODOCUACTO" query-param="KEY_CO_TIPODOCUACTO"/>
			<with-param name="KEY_CO_NUME" query-param="KEY_CO_NUME"/>
			<with-param name="KEY_CO_FECHRESODECR" query-param="KEY_CO_FECHRESODECR"/>

		</call-query>
	</resource>
	<query id="getNatcomisionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_COMISION.COMPANIA, NAT_COMISION.CO_NUMEDOCU, NAT_COMISION.SUCURSAL, NAT_COMISION.CO_TIPODOCUACTO, NAT_COMISION.CO_NUME,(TO_CHAR(NAT_COMISION.CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) CO_FECHRESODECR, CARGOS.NOMBRE_DEL_CARGO NOMBRECARGO, NAT_COMISION.CO_ENTI  FROM NAT_COMISION LEFT JOIN CARGOS ON NAT_COMISION.COMPANIA = CARGOS.COMPANIA AND NAT_COMISION.CO_CARGO = CARGOS.ID_DE_CARGO WHERE NAT_COMISION.COMPANIA = :COMPANIA AND NAT_COMISION.CO_NUMEDOCU = :NUMERO_DCTO AND NAT_COMISION.SUCURSAL = :SUCURSAL ORDER BY NAT_COMISION.CO_FECHRESODECR DESC) WHERE (CASE WHEN CO_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(CO_TIPODOCUACTO) END)  LIKE UPPER(:CO_TIPODOCUACTO || '%')  AND (CASE WHEN CO_NUME IS NULL THEN ' ' ELSE UPPER(CO_NUME) END)  LIKE UPPER(:CO_NUME || '%')  AND (CASE WHEN NOMBRECARGO IS NULL THEN ' ' ELSE UPPER(NOMBRECARGO) END)  LIKE UPPER( '%' || :NOMBRECARGO || '%')  AND (CASE WHEN CO_ENTI IS NULL THEN ' ' ELSE UPPER(CO_ENTI) END)  LIKE UPPER( '%' || :CO_ENTI || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CO_NUMEDOCU":"$CO_NUMEDOCU","SUCURSAL":"$SUCURSAL","CO_TIPODOCUACTO":"$CO_TIPODOCUACTO","CO_NUME":"$CO_NUME","CO_FECHRESODECR":"$CO_FECHRESODECR","NOMBRECARGO":"$NOMBRECARGO","CO_ENTI":"$CO_ENTI"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param name="NOMBRECARGO" sqlType="STRING"/>
		<param name="CO_ENTI" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natcomision">
		<call-query href="getNatcomisionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CO_TIPODOCUACTO" query-param="CO_TIPODOCUACTO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="NOMBRECARGO" query-param="NOMBRECARGO"/>
			<with-param name="CO_ENTI" query-param="CO_ENTI"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatcomisionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_COMISION.COMPANIA, NAT_COMISION.CO_NUMEDOCU, NAT_COMISION.SUCURSAL, NAT_COMISION.CO_TIPODOCUACTO, NAT_COMISION.CO_NUME,(TO_CHAR(NAT_COMISION.CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) CO_FECHRESODECR, CARGOS.NOMBRE_DEL_CARGO NOMBRECARGO, NAT_COMISION.CO_ENTI  FROM NAT_COMISION LEFT JOIN CARGOS ON NAT_COMISION.COMPANIA = CARGOS.COMPANIA AND NAT_COMISION.CO_CARGO = CARGOS.ID_DE_CARGO WHERE NAT_COMISION.COMPANIA = :COMPANIA AND NAT_COMISION.CO_NUMEDOCU = :NUMERO_DCTO AND NAT_COMISION.SUCURSAL = :SUCURSAL ORDER BY NAT_COMISION.CO_FECHRESODECR DESC) WHERE (CASE WHEN CO_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(CO_TIPODOCUACTO) END)  LIKE UPPER(:CO_TIPODOCUACTO || '%')  AND (CASE WHEN CO_NUME IS NULL THEN ' ' ELSE UPPER(CO_NUME) END)  LIKE UPPER(:CO_NUME || '%')  AND (CASE WHEN NOMBRECARGO IS NULL THEN ' ' ELSE UPPER(NOMBRECARGO) END)  LIKE UPPER( '%' || :NOMBRECARGO || '%')  AND (CASE WHEN CO_ENTI IS NULL THEN ' ' ELSE UPPER(CO_ENTI) END)  LIKE UPPER( '%' || :CO_ENTI || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param name="NOMBRECARGO" sqlType="STRING"/>
		<param name="CO_ENTI" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcomision/numero">
		<call-query href="getNatcomisionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CO_TIPODOCUACTO" query-param="CO_TIPODOCUACTO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="NOMBRECARGO" query-param="NOMBRECARGO"/>
			<with-param name="CO_ENTI" query-param="CO_ENTI"/>

		</call-query>
	</resource>
	<query id="getNatcomisionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_COMISION.COMPANIA, NAT_COMISION.CO_NUMEDOCU, NAT_COMISION.SUCURSAL, NAT_COMISION.CO_TIPODOCUACTO, NAT_COMISION.CO_NUME, NAT_COMISION.CO_CARGO, CARGOS.NOMBRE_DEL_CARGO NOMBRECARGO, NAT_COMISION.COPAIS, NAT_COMISION.CODPTO, NAT_COMISION.COMUNI, NAT_COMISION.CO_ENTI, NAT_COMISION.CO_DESC, NAT_COMISION.CREATED_BY, NAT_COMISION.MODIFIED_BY,(TO_CHAR(NAT_COMISION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(NAT_COMISION.CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) CO_FECHRESODECR,(TO_CHAR(NAT_COMISION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NAT_COMISION.CO_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) CO_FECHDESDE,(TO_CHAR(NAT_COMISION.CO_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) CO_FECHHASTA FROM NAT_COMISION LEFT JOIN CARGOS ON NAT_COMISION.CO_CARGO = CARGOS.ID_DE_CARGO WHERE NAT_COMISION.COMPANIA= :KEY_COMPANIA AND NAT_COMISION.CO_NUMEDOCU= :KEY_CO_NUMEDOCU AND NAT_COMISION.SUCURSAL= :KEY_SUCURSAL AND NAT_COMISION.CO_TIPODOCUACTO= :KEY_CO_TIPODOCUACTO AND NAT_COMISION.CO_NUME= :KEY_CO_NUME AND NAT_COMISION.CO_FECHRESODECR= TO_DATE(:KEY_CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CO_NUMEDOCU":"$CO_NUMEDOCU","SUCURSAL":"$SUCURSAL","CO_TIPODOCUACTO":"$CO_TIPODOCUACTO","CO_NUME":"$CO_NUME","CO_CARGO":"$CO_CARGO","NOMBRECARGO":"$NOMBRECARGO","COPAIS":"$COPAIS","CODPTO":"$CODPTO","COMUNI":"$COMUNI","CO_ENTI":"$CO_ENTI","CO_DESC":"$CO_DESC","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CO_FECHRESODECR":"$CO_FECHRESODECR","DATE_CREATED":"$DATE_CREATED","CO_FECHDESDE":"$CO_FECHDESDE","CO_FECHHASTA":"$CO_FECHHASTA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CO_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_CO_NUME" sqlType="STRING"/>
		<param name="KEY_CO_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcomision/data">
		<call-query href="getNatcomisionRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CO_NUMEDOCU" query-param="KEY_CO_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CO_TIPODOCUACTO" query-param="KEY_CO_TIPODOCUACTO"/>
			<with-param name="KEY_CO_NUME" query-param="KEY_CO_NUME"/>
			<with-param name="KEY_CO_FECHRESODECR" query-param="KEY_CO_FECHRESODECR"/>

		</call-query>
	</resource>
	<query id="updateNatcomision" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_COMISION SET CO_TIPODOCUACTO=:CO_TIPODOCUACTO, CO_NUME=:CO_NUME, CO_CARGO=:CO_CARGO, COPAIS=:COPAIS, CODPTO=:CODPTO, COMUNI=:COMUNI, CO_ENTI=:CO_ENTI, CO_DESC=:CO_DESC, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CO_FECHRESODECR=TO_DATE(:CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), CO_FECHDESDE=TO_DATE(:CO_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), CO_FECHHASTA=TO_DATE(:CO_FECHHASTA,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_COMISION.COMPANIA= :KEY_COMPANIA AND NAT_COMISION.CO_NUMEDOCU= :KEY_CO_NUMEDOCU AND NAT_COMISION.SUCURSAL= :KEY_SUCURSAL AND NAT_COMISION.CO_TIPODOCUACTO= :KEY_CO_TIPODOCUACTO AND NAT_COMISION.CO_NUME= :KEY_CO_NUME AND NAT_COMISION.CO_FECHRESODECR= TO_DATE(:KEY_CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param name="CO_CARGO" sqlType="STRING"/>
		<param name="COPAIS" sqlType="STRING"/>
		<param name="CODPTO" sqlType="STRING"/>
		<param name="COMUNI" sqlType="STRING"/>
		<param name="CO_ENTI" sqlType="STRING"/>
		<param name="CO_DESC" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="CO_FECHRESODECR" sqlType="STRING"/>
		<param name="CO_FECHDESDE" sqlType="STRING"/>
		<param name="CO_FECHHASTA" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CO_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CO_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_CO_NUME" sqlType="STRING"/>
		<param name="KEY_CO_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natcomision">
		<call-query href="updateNatcomision">
			<with-param name="CO_TIPODOCUACTO" query-param="CO_TIPODOCUACTO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="CO_CARGO" query-param="CO_CARGO"/>
			<with-param name="COPAIS" query-param="COPAIS"/>
			<with-param name="CODPTO" query-param="CODPTO"/>
			<with-param name="COMUNI" query-param="COMUNI"/>
			<with-param name="CO_ENTI" query-param="CO_ENTI"/>
			<with-param name="CO_DESC" query-param="CO_DESC"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="CO_FECHRESODECR" query-param="CO_FECHRESODECR"/>
			<with-param name="CO_FECHDESDE" query-param="CO_FECHDESDE"/>
			<with-param name="CO_FECHHASTA" query-param="CO_FECHHASTA"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CO_NUMEDOCU" query-param="KEY_CO_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CO_TIPODOCUACTO" query-param="KEY_CO_TIPODOCUACTO"/>
			<with-param name="KEY_CO_NUME" query-param="KEY_CO_NUME"/>
			<with-param name="KEY_CO_FECHRESODECR" query-param="KEY_CO_FECHRESODECR"/>

		</call-query>
	</resource>

</data>