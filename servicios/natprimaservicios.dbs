	<query id="insertNatprimaserviciosInsertprimasecretarial" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,ID_DE_EMPLEADO,PS_TIPODOCUACTO,PS_NUME,PS_TIPO,PS_CODIGOPERSONA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_PRIMA_SERVICIOS (COMPANIA, DP_NUMEDOCU, SUCURSAL, ID_DE_EMPLEADO, PS_TIPODOCUACTO, PS_NUME, PS_FECHRESODECR, PS_TIPO, PS_CODIGOPERSONA, PS_VALOR, PS_PORCENTAJE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :ID_DE_EMPLEADO, :PS_TIPODOCUACTO, :PS_NUME, TO_DATE(:PS_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), :PS_TIPO, :PS_CODIGOPERSONA, :PS_VALOR, :PS_PORCENTAJE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_PS_TIPODOCUACTO":"$PS_TIPODOCUACTO","KEY_PS_NUME":"$PS_NUME","KEY_PS_FECHRESODECR":"$PS_FECHRESODECR","KEY_PS_TIPO":"$PS_TIPO","KEY_PS_CODIGOPERSONA":"$PS_CODIGOPERSONA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="PS_TIPODOCUACTO" sqlType="STRING"/>
		<param name="PS_NUME" sqlType="STRING"/>
		<param name="PS_FECHRESODECR" sqlType="STRING"/>
		<param name="PS_TIPO" sqlType="STRING"/>
		<param name="PS_CODIGOPERSONA" sqlType="STRING"/>
		<param defaultValue="0" name="PS_VALOR" sqlType="STRING"/>
		<param defaultValue="0" name="PS_PORCENTAJE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
