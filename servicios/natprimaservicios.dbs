	<query id="updateNatprimaserviciosUpdateprimasecretarial" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_PRIMA_SERVICIOS SET PS_TIPODOCUACTO=:PS_TIPODOCUACTO, PS_NUME=:PS_NUME, PS_FECHRESODECR=TO_DATE(:PS_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), PS_TIPO=:PS_TIPO, PS_VALOR=:PS_VALOR, PS_PORCENTAJE=:PS_PORCENTAJE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_PRIMA_SERVICIOS.COMPANIA= :KEY_COMPANIA AND NAT_PRIMA_SERVICIOS.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_PRIMA_SERVICIOS.SUCURSAL= :KEY_SUCURSAL AND NAT_PRIMA_SERVICIOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND NAT_PRIMA_SERVICIOS.PS_TIPODOCUACTO= :KEY_PS_TIPODOCUACTO AND NAT_PRIMA_SERVICIOS.PS_NUME= :KEY_PS_NUME AND NAT_PRIMA_SERVICIOS.PS_FECHRESODECR= TO_DATE(:KEY_PS_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')  AND NAT_PRIMA_SERVICIOS.PS_TIPO= :KEY_PS_TIPO AND NAT_PRIMA_SERVICIOS.PS_CODIGOPERSONA= :KEY_PS_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PS_TIPODOCUACTO" sqlType="STRING"/>
		<param name="PS_NUME" sqlType="STRING"/>
		<param name="PS_FECHRESODECR" sqlType="STRING"/>
		<param name="PS_TIPO" sqlType="STRING"/>
		<param name="PS_VALOR" sqlType="STRING"/>
		<param name="PS_PORCENTAJE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_PS_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_PS_NUME" sqlType="STRING"/>
		<param name="KEY_PS_FECHRESODECR" sqlType="STRING"/>
		<param name="KEY_PS_TIPO" sqlType="STRING"/>
		<param name="KEY_PS_CODIGOPERSONA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natprimaservicios/updateprimasecretarial">
		<call-query href="updateNatprimaserviciosUpdateprimasecretarial">
			<with-param name="PS_TIPODOCUACTO" query-param="PS_TIPODOCUACTO"/>
			<with-param name="PS_NUME" query-param="PS_NUME"/>
			<with-param name="PS_FECHRESODECR" query-param="PS_FECHRESODECR"/>
			<with-param name="PS_TIPO" query-param="PS_TIPO"/>
			<with-param name="PS_VALOR" query-param="PS_VALOR"/>
			<with-param name="PS_PORCENTAJE" query-param="PS_PORCENTAJE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
