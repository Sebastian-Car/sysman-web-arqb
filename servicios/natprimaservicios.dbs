	</resource>
	<query id="updateNatprimaservicios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_PRIMA_SERVICIOS SET PS_TIPODOCUACTO=:PS_TIPODOCUACTO, PS_TIPO=:PS_TIPO, PS_NUME=:PS_NUME, PS_FECHRESODECR=TO_DATE(:PS_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), OBSERVACIONES=:OBSERVACIONES, PS_VALOR=:PS_VALOR, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, DP_NUMEDOCU=:DP_NUMEDOCU, DP_TIPODOCU=:DP_TIPODOCU, SUCURSAL=:SUCURSAL, PS_CODIGOPERSONA=:PS_CODIGOPERSONA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_PRIMA_SERVICIOS.COMPANIA= :KEY_COMPANIA AND NAT_PRIMA_SERVICIOS.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_PRIMA_SERVICIOS.SUCURSAL= :KEY_SUCURSAL AND NAT_PRIMA_SERVICIOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND NAT_PRIMA_SERVICIOS.PS_TIPODOCUACTO= :KEY_PS_TIPODOCUACTO AND NAT_PRIMA_SERVICIOS.PS_NUME= :KEY_PS_NUME AND NAT_PRIMA_SERVICIOS.PS_FECHRESODECR= TO_DATE(:KEY_PS_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')  AND NAT_PRIMA_SERVICIOS.PS_TIPO= :KEY_PS_TIPO AND NAT_PRIMA_SERVICIOS.PS_CODIGOPERSONA= :KEY_PS_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PS_TIPODOCUACTO" sqlType="STRING"/>
		<param name="PS_TIPO" sqlType="STRING"/>
		<param name="PS_NUME" sqlType="STRING"/>
		<param name="PS_FECHRESODECR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PS_VALOR" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="DP_TIPODOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PS_CODIGOPERSONA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_PS_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_PS_NUME" sqlType="STRING"/>
		<param name="KEY_PS_FECHRESODECR" sqlType="STRING"/>
		<param name="KEY_PS_TIPO" sqlType="STRING"/>
		<param name="KEY_PS_CODIGOPERSONA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natprimaservicios">
