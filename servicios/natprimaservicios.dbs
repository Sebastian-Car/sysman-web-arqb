		</call-query>
	</resource>
	<query id="getNatprimaserviciosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PSERVICIOS.COMPANIA, PSERVICIOS.DP_NUMEDOCU, PSERVICIOS.SUCURSAL, PSERVICIOS.ID_DE_EMPLEADO, NAT_TIPO_ACTO_ADTIVO.CODIGO, NAT_TIPO_ACTO_ADTIVO.TIPOACTOADTIVO, PSERVICIOS.PS_NUME,(TO_CHAR(PSERVICIOS.PS_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) PS_FECHRESODECR, PSERVICIOS.PS_TIPO, PSERVICIOS.DP_TIPODOCU, PSERVICIOS.PS_VALOR, PSERVICIOS.PS_CODIGOPERSONA, PSERVICIOS.OBSERVACIONES, CONCAT(DPERSONALES.APELLIDO1,CONCAT(' ',CONCAT(DPERSONALES.APELLIDO2,CONCAT(' ',DPERSONALES.NOMBRES) ) ) ) NOMBRES, PS_TIPODOCUACTO FROM NAT_PRIMA_SERVICIOS PSERVICIOS INNER JOIN NAT_DATOS_PERSONALES DPERSONALES ON PSERVICIOS.COMPANIA = DPERSONALES.COMPANIA AND PSERVICIOS.DP_NUMEDOCU = DPERSONALES.NUMERO_DCTO AND PSERVICIOS.SUCURSAL = DPERSONALES.SUCURSAL INNER JOIN NAT_TIPO_ACTO_ADTIVO ON NAT_TIPO_ACTO_ADTIVO.CODIGO = PSERVICIOS.PS_TIPODOCUACTO WHERE PSERVICIOS.COMPANIA =:COMPANIA AND PSERVICIOS.DP_NUMEDOCU =:DOCUMENTO AND PSERVICIOS.PS_TIPO IN ( CASE WHEN :MENU IN ( '1' ) THEN 'AUXILIO DE MATERNIDAD' ELSE 'AUXILIO MORTUOSO' END ) AND DPERSONALES.CODIGO =:CODIGO ORDER BY PS_TIPODOCUACTO, PS_NUME) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN TIPOACTOADTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTOADTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOACTOADTIVO), '%')) AND (CASE WHEN PS_NUME IS NULL THEN ' ' ELSE UPPER(PS_NUME) END) LIKE UPPER(CONCAT(CONCAT('%',:PS_NUME), '%')) AND (CASE WHEN PS_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(PS_FECHRESODECR) END) LIKE UPPER(CONCAT(CONCAT('%',:PS_FECHRESODECR), '%')) AND (CASE WHEN PS_VALOR IS NULL THEN ' ' ELSE UPPER(PS_VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:PS_VALOR), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="MENU" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOACTOADTIVO" sqlType="STRING"/>
		<param name="PS_NUME" sqlType="STRING"/>
		<param name="PS_FECHRESODECR" sqlType="STRING"/>
		<param name="PS_VALOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natprimaservicios/numero">
		<call-query href="getNatprimaserviciosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="MENU" query-param="MENU"/>
