			<with-param name="KEY_PS_NUME" query-param="KEY_PS_NUME"/>
			<with-param name="KEY_PS_FECHRESODECR" query-param="KEY_PS_FECHRESODECR"/>
			<with-param name="KEY_PS_TIPO" query-param="KEY_PS_TIPO"/>
			<with-param name="KEY_PS_CODIGOPERSONA" query-param="KEY_PS_CODIGOPERSONA"/>

		</call-query>
	</resource>
	<query id="getNatprimaserviciosPagGrillaprimasecretarialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_PRIMA_SERVICIOS.COMPANIA, NAT_PRIMA_SERVICIOS.DP_NUMEDOCU, NAT_PRIMA_SERVICIOS.SUCURSAL, NAT_PRIMA_SERVICIOS.ID_DE_EMPLEADO, NAT_PRIMA_SERVICIOS.PS_TIPODOCUACTO, NAT_TIPO_ACTO_ADTIVO.TIPOACTOADTIVO, NAT_PRIMA_SERVICIOS.PS_NUME,(TO_CHAR(NAT_PRIMA_SERVICIOS.PS_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) PS_FECHRESODECR, NAT_PRIMA_SERVICIOS.PS_TIPO, NAT_PRIMA_SERVICIOS.PS_CODIGOPERSONA, NAT_PRIMA_SERVICIOS.PS_VALOR, NAT_PRIMA_SERVICIOS.PS_PORCENTAJE  FROM NAT_PRIMA_SERVICIOS INNER JOIN NAT_DATOS_PERSONALES ON NAT_PRIMA_SERVICIOS.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_PRIMA_SERVICIOS.DP_NUMEDOCU = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_PRIMA_SERVICIOS.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL LEFT JOIN NAT_TIPO_ACTO_ADTIVO ON NAT_PRIMA_SERVICIOS.PS_TIPODOCUACTO = NAT_TIPO_ACTO_ADTIVO.CODIGO WHERE NAT_PRIMA_SERVICIOS.COMPANIA = :COMPANIA AND NAT_PRIMA_SERVICIOS.DP_NUMEDOCU = :NUMERO_DCTO AND NAT_PRIMA_SERVICIOS.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN TIPOACTOADTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTOADTIVO) END)  LIKE UPPER( '%' || :TIPOACTOADTIVO || '%')  AND (CASE WHEN PS_NUME IS NULL THEN ' ' ELSE UPPER(PS_NUME) END)  LIKE UPPER( '%' || :PS_NUME || '%')  AND (CASE WHEN PS_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(PS_FECHRESODECR) END)  LIKE UPPER( '%' || :PS_FECHRESODECR || '%')  AND (CASE WHEN PS_TIPO IS NULL THEN ' ' ELSE UPPER(PS_TIPO) END)  LIKE UPPER( '%' || :PS_TIPO || '%')  AND (CASE WHEN PS_VALOR IS NULL THEN ' ' ELSE UPPER(PS_VALOR) END)  LIKE UPPER(:PS_VALOR || '%')  AND (CASE WHEN PS_PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PS_PORCENTAJE) END)  LIKE UPPER(:PS_PORCENTAJE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","PS_TIPODOCUACTO":"$PS_TIPODOCUACTO","TIPOACTOADTIVO":"$TIPOACTOADTIVO","PS_NUME":"$PS_NUME","PS_FECHRESODECR":"$PS_FECHRESODECR","PS_TIPO":"$PS_TIPO","PS_CODIGOPERSONA":"$PS_CODIGOPERSONA","PS_VALOR":"$PS_VALOR","PS_PORCENTAJE":"$PS_PORCENTAJE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPOACTOADTIVO" sqlType="STRING"/>
		<param name="PS_NUME" sqlType="STRING"/>
		<param name="PS_FECHRESODECR" sqlType="STRING"/>
		<param name="PS_TIPO" sqlType="STRING"/>
		<param name="PS_VALOR" sqlType="STRING"/>
		<param name="PS_PORCENTAJE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natprimaservicios/grillaprimasecretarial/pag">
