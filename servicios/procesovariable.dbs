<data name="procesovariable" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertProcesovariable" keyColumns="COMPANIA,CODIGO_PROCESO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PROCESO_VARIABLE (COMPANIA, CODIGO_PROCESO, CODIGO, TIPO_DATO, ETIQUETA, OBLIGATORIO, MANEJA_ADJUNTO, ESTADO, MANEJA_RADICADO, ADJUNTO, ADJUNTO_OBLIGATORIO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_PROCESO, :CODIGO, :TIPO_DATO, :ETIQUETA, :OBLIGATORIO, :MANEJA_ADJUNTO, :ESTADO, :MANEJA_RADICADO, :ADJUNTO, :ADJUNTO_OBLIGATORIO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_PROCESO":"$CODIGO_PROCESO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO_DATO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGATORIO" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_ADJUNTO" sqlType="STRING"/>
		<param defaultValue="4" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_RADICADO" sqlType="STRING"/>
		<param defaultValue="" name="ADJUNTO" sqlType="STRING"/>
		<param defaultValue="0" name="ADJUNTO_OBLIGATORIO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="procesovariable">
		<call-query href="insertProcesovariable">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROCESO" query-param="CODIGO_PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPO_DATO" query-param="TIPO_DATO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="MANEJA_ADJUNTO" query-param="MANEJA_ADJUNTO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MANEJA_RADICADO" query-param="MANEJA_RADICADO"/>
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>
			<with-param name="ADJUNTO_OBLIGATORIO" query-param="ADJUNTO_OBLIGATORIO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteProcesovariable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PROCESO_VARIABLE WHERE PROCESO_VARIABLE.COMPANIA= :KEY_COMPANIA AND PROCESO_VARIABLE.CODIGO_PROCESO= :KEY_CODIGO_PROCESO AND PROCESO_VARIABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="procesovariable">
		<call-query href="deleteProcesovariable">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_PROCESO" query-param="KEY_CODIGO_PROCESO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getProcesovariablePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NV.COMPANIA, NV.CODIGO, NV.CODIGO_PROCESO, NV.ETIQUETA, T2.NOMBRE TIPO_DATO_NOM, T.NOMBRE ESTADO_NOM  FROM PROCESO_VARIABLE NV INNER JOIN TIPOS T ON NV.ESTADO = T.ID INNER JOIN TIPOS T2 ON NV.TIPO_DATO = T2.ID WHERE NV.COMPANIA = :COMPANIA AND NV.CODIGO_PROCESO = :PROCESO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN TIPO_DATO_NOM IS NULL THEN ' ' ELSE UPPER(TIPO_DATO_NOM) END)  LIKE UPPER( '%' || :TIPO_DATO_NOM || '%')  AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END)  LIKE UPPER( '%' || :ESTADO_NOM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CODIGO_PROCESO":"$CODIGO_PROCESO","ETIQUETA":"$ETIQUETA","TIPO_DATO_NOM":"$TIPO_DATO_NOM","ESTADO_NOM":"$ESTADO_NOM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="TIPO_DATO_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procesovariable">
		<call-query href="getProcesovariablePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="TIPO_DATO_NOM" query-param="TIPO_DATO_NOM"/>
			<with-param name="ESTADO_NOM" query-param="ESTADO_NOM"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcesovariableNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NV.COMPANIA, NV.CODIGO, NV.CODIGO_PROCESO, NV.ETIQUETA, T2.NOMBRE TIPO_DATO_NOM, T.NOMBRE ESTADO_NOM  FROM PROCESO_VARIABLE NV INNER JOIN TIPOS T ON NV.ESTADO = T.ID INNER JOIN TIPOS T2 ON NV.TIPO_DATO = T2.ID WHERE NV.COMPANIA = :COMPANIA AND NV.CODIGO_PROCESO = :PROCESO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN TIPO_DATO_NOM IS NULL THEN ' ' ELSE UPPER(TIPO_DATO_NOM) END)  LIKE UPPER( '%' || :TIPO_DATO_NOM || '%')  AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END)  LIKE UPPER( '%' || :ESTADO_NOM || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="TIPO_DATO_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procesovariable/numero">
		<call-query href="getProcesovariableNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="TIPO_DATO_NOM" query-param="TIPO_DATO_NOM"/>
			<with-param name="ESTADO_NOM" query-param="ESTADO_NOM"/>

		</call-query>
	</resource>
	<query id="getProcesovariableRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PROCESO_VARIABLE.COMPANIA, PROCESO_VARIABLE.CODIGO, PROCESO_VARIABLE.CODIGO_PROCESO, PROCESOS.NOMBRE PROCESO_NOM, PROCESO_VARIABLE.TIPO_DATO, PROCESO_VARIABLE.ETIQUETA,(CASE PROCESO_VARIABLE.OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGATORIO,(CASE PROCESO_VARIABLE.MANEJA_ADJUNTO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_ADJUNTO,(CASE PROCESO_VARIABLE.ADJUNTO_OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) ADJUNTO_OBLIGATORIO, PROCESO_VARIABLE.ESTADO, PROCESO_VARIABLE.ADJUNTO,(CASE PROCESO_VARIABLE.MANEJA_RADICADO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RADICADO, PROCESO_VARIABLE.CREATED_BY, PROCESO_VARIABLE.MODIFIED_BY,(TO_CHAR(PROCESO_VARIABLE.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(PROCESO_VARIABLE.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PROCESO_VARIABLE INNER JOIN PROCESOS ON PROCESO_VARIABLE.COMPANIA = PROCESOS.COMPANIA AND PROCESO_VARIABLE.CODIGO_PROCESO = PROCESOS.CODIGO WHERE PROCESO_VARIABLE.COMPANIA= :KEY_COMPANIA AND PROCESO_VARIABLE.CODIGO_PROCESO= :KEY_CODIGO_PROCESO AND PROCESO_VARIABLE.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CODIGO_PROCESO":"$CODIGO_PROCESO","PROCESO_NOM":"$PROCESO_NOM","TIPO_DATO":"$TIPO_DATO(type:integer)","ETIQUETA":"$ETIQUETA","OBLIGATORIO":"$OBLIGATORIO(type:boolean)","MANEJA_ADJUNTO":"$MANEJA_ADJUNTO(type:boolean)","ADJUNTO_OBLIGATORIO":"$ADJUNTO_OBLIGATORIO(type:boolean)","ESTADO":"$ESTADO(type:integer)","ADJUNTO":"$ADJUNTO","MANEJA_RADICADO":"$MANEJA_RADICADO(type:boolean)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procesovariable/data">
		<call-query href="getProcesovariableRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_PROCESO" query-param="KEY_CODIGO_PROCESO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateProcesovariable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROCESO_VARIABLE SET COMPANIA=:COMPANIA, CODIGO_PROCESO=:CODIGO_PROCESO, CODIGO=:CODIGO, TIPO_DATO=:TIPO_DATO, ETIQUETA=:ETIQUETA, OBLIGATORIO=:OBLIGATORIO, MANEJA_ADJUNTO=:MANEJA_ADJUNTO, ESTADO=:ESTADO, MANEJA_RADICADO=:MANEJA_RADICADO, ADJUNTO=:ADJUNTO, ADJUNTO_OBLIGATORIO=:ADJUNTO_OBLIGATORIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PROCESO_VARIABLE.COMPANIA= :KEY_COMPANIA AND PROCESO_VARIABLE.CODIGO_PROCESO= :KEY_CODIGO_PROCESO AND PROCESO_VARIABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROCESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO_DATO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="OBLIGATORIO" sqlType="STRING"/>
		<param name="MANEJA_ADJUNTO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="MANEJA_RADICADO" sqlType="STRING"/>
		<param name="ADJUNTO" sqlType="STRING"/>
		<param name="ADJUNTO_OBLIGATORIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="procesovariable">
		<call-query href="updateProcesovariable">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROCESO" query-param="CODIGO_PROCESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPO_DATO" query-param="TIPO_DATO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="MANEJA_ADJUNTO" query-param="MANEJA_ADJUNTO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MANEJA_RADICADO" query-param="MANEJA_RADICADO"/>
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>
			<with-param name="ADJUNTO_OBLIGATORIO" query-param="ADJUNTO_OBLIGATORIO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_PROCESO" query-param="KEY_CODIGO_PROCESO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>