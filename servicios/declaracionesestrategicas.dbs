<data name="declaracionesestrategicas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDeclaracionesestrategicas" keyColumns="COMPANIA,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DECLARACIONESTRATEGICA (COMPANIA, ANO, PERSPECTIVA, VALORPAA, FECHA_ACTUALIZACION, MENOR_CUANTIA, MINIMA_CUANTIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :PERSPECTIVA, :VALORPAA, TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), :MENOR_CUANTIA, :MINIMA_CUANTIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERSPECTIVA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORPAA" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="MENOR_CUANTIA" sqlType="STRING"/>
		<param defaultValue="0" name="MINIMA_CUANTIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="declaracionesestrategicas">
		<call-query href="insertDeclaracionesestrategicas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERSPECTIVA" query-param="PERSPECTIVA"/>
			<with-param name="VALORPAA" query-param="VALORPAA"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="MENOR_CUANTIA" query-param="MENOR_CUANTIA"/>
			<with-param name="MINIMA_CUANTIA" query-param="MINIMA_CUANTIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getDeclaracionesestrategicasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, PERSPECTIVA, VALORPAA,(TO_CHAR(FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, MENOR_CUANTIA, MINIMA_CUANTIA  FROM DECLARACIONESTRATEGICA WHERE DECLARACIONESTRATEGICA.COMPANIA = :COMPANIA ORDER BY ANO DESC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PERSPECTIVA IS NULL THEN ' ' ELSE UPPER(PERSPECTIVA) END)  LIKE UPPER( '%' || :PERSPECTIVA || '%')  AND (CASE WHEN VALORPAA IS NULL THEN ' ' ELSE UPPER(VALORPAA) END)  LIKE UPPER( '%' || :VALORPAA || '%')  AND (CASE WHEN FECHA_ACTUALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_ACTUALIZACION) END)  LIKE UPPER( '%' || :FECHA_ACTUALIZACION || '%')  AND (CASE WHEN MENOR_CUANTIA IS NULL THEN ' ' ELSE UPPER(MENOR_CUANTIA) END)  LIKE UPPER( '%' || :MENOR_CUANTIA || '%')  AND (CASE WHEN MINIMA_CUANTIA IS NULL THEN ' ' ELSE UPPER(MINIMA_CUANTIA) END)  LIKE UPPER( '%' || :MINIMA_CUANTIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERSPECTIVA":"$PERSPECTIVA","VALORPAA":"$VALORPAA(type:double)","FECHA_ACTUALIZACION":"$FECHA_ACTUALIZACION","MENOR_CUANTIA":"$MENOR_CUANTIA(type:double)","MINIMA_CUANTIA":"$MINIMA_CUANTIA(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERSPECTIVA" sqlType="STRING"/>
		<param name="VALORPAA" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="MENOR_CUANTIA" sqlType="STRING"/>
		<param name="MINIMA_CUANTIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="declaracionesestrategicas">
		<call-query href="getDeclaracionesestrategicasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERSPECTIVA" query-param="PERSPECTIVA"/>
			<with-param name="VALORPAA" query-param="VALORPAA"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="MENOR_CUANTIA" query-param="MENOR_CUANTIA"/>
			<with-param name="MINIMA_CUANTIA" query-param="MINIMA_CUANTIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDeclaracionesestrategicasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO, PERSPECTIVA, VALORPAA,(TO_CHAR(FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, MENOR_CUANTIA, MINIMA_CUANTIA  FROM DECLARACIONESTRATEGICA WHERE DECLARACIONESTRATEGICA.COMPANIA = :COMPANIA ORDER BY ANO DESC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PERSPECTIVA IS NULL THEN ' ' ELSE UPPER(PERSPECTIVA) END)  LIKE UPPER( '%' || :PERSPECTIVA || '%')  AND (CASE WHEN VALORPAA IS NULL THEN ' ' ELSE UPPER(VALORPAA) END)  LIKE UPPER( '%' || :VALORPAA || '%')  AND (CASE WHEN FECHA_ACTUALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_ACTUALIZACION) END)  LIKE UPPER( '%' || :FECHA_ACTUALIZACION || '%')  AND (CASE WHEN MENOR_CUANTIA IS NULL THEN ' ' ELSE UPPER(MENOR_CUANTIA) END)  LIKE UPPER( '%' || :MENOR_CUANTIA || '%')  AND (CASE WHEN MINIMA_CUANTIA IS NULL THEN ' ' ELSE UPPER(MINIMA_CUANTIA) END)  LIKE UPPER( '%' || :MINIMA_CUANTIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERSPECTIVA" sqlType="STRING"/>
		<param name="VALORPAA" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="MENOR_CUANTIA" sqlType="STRING"/>
		<param name="MINIMA_CUANTIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="declaracionesestrategicas/numero">
		<call-query href="getDeclaracionesestrategicasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERSPECTIVA" query-param="PERSPECTIVA"/>
			<with-param name="VALORPAA" query-param="VALORPAA"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="MENOR_CUANTIA" query-param="MENOR_CUANTIA"/>
			<with-param name="MINIMA_CUANTIA" query-param="MINIMA_CUANTIA"/>

		</call-query>
	</resource>
	<query id="updateDeclaracionesestrategicas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DECLARACIONESTRATEGICA SET ANO=:ANO, PERSPECTIVA=:PERSPECTIVA, VALORPAA=:VALORPAA, FECHA_ACTUALIZACION=TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), MENOR_CUANTIA=:MENOR_CUANTIA, MINIMA_CUANTIA=:MINIMA_CUANTIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DECLARACIONESTRATEGICA.COMPANIA= :KEY_COMPANIA AND DECLARACIONESTRATEGICA.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="PERSPECTIVA" sqlType="STRING"/>
		<param name="VALORPAA" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="MENOR_CUANTIA" sqlType="STRING"/>
		<param name="MINIMA_CUANTIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="declaracionesestrategicas">
		<call-query href="updateDeclaracionesestrategicas">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERSPECTIVA" query-param="PERSPECTIVA"/>
			<with-param name="VALORPAA" query-param="VALORPAA"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="MENOR_CUANTIA" query-param="MENOR_CUANTIA"/>
			<with-param name="MINIMA_CUANTIA" query-param="MINIMA_CUANTIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>

</data>