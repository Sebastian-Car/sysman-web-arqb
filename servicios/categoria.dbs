	<query id="updateCategoriaSalarioAnterior" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CATEGORIA SET CATEGORIA.SALARIOANTERIOR = CATEGORIA.SALARIO_BASE WHERE CATEGORIA.COMPANIA=:COMPANIA AND CATEGORIA.ANO=:ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="categoria/salarioanterior">
		<call-query href="updateCategoriaSalarioAnterior">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateCategoriaRetroactivo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CATEGORIA SET CATEGORIA.SALARIO_BASE = CATEGORIA.SALARIO_RETROACTIVO WHERE CATEGORIA.COMPANIA=:COMPANIA AND CATEGORIA.ANO=:ANO AND CATEGORIA.SALARIO_RETROACTIVO &gt; 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="categoria/retroactivo">
		<call-query href="updateCategoriaRetroactivo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertCategoriaNivelEmpleado" keyColumns="COMPANIA,ESCALAFON,ID_DE_CATEGORIA,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CATEGORIA (VLREXTRA, PRIMATECNICA, ANO, NOMBRE_CATEGORIA, CODIGOGRADO, SALARIO_RETROACTIVO, VLR_INCREMENTO, GASTOSREPRESENTACION, SUBSALIMENTACION, SALARIO_BASE, GRADO, SALARIOANTERIOR, SUBSTRANSPORTE, ID_DE_CATEGORIA, ESCALAFON, COMPANIA, BONIFICACION_DOCENTE, CATEGORIA_REFERENCIA, DATE_CREATED, CREATED_BY) VALUES (:VLREXTRA, :PRIMATECNICA, :ANO, :NOMBRE_CATEGORIA, :CODIGOGRADO, :SALARIO_RETROACTIVO, :VLR_INCREMENTO, :GASTOSREPRESENTACION, :SUBSALIMENTACION, :SALARIO_BASE, :GRADO, :SALARIOANTERIOR, :SUBSTRANSPORTE, :ID_DE_CATEGORIA, :ESCALAFON, :COMPANIA, :BONIFICACION_DOCENTE, :CATEGORIA_REFERENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ESCALAFON":"$ESCALAFON","KEY_ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param defaultValue="0" name="VLREXTRA" sqlType="STRING"/>
		<param defaultValue="0" name="PRIMATECNICA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOGRADO" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIO_RETROACTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="VLR_INCREMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="GASTOSREPRESENTACION" sqlType="STRING"/>
		<param defaultValue="0" name="SUBSALIMENTACION" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIO_BASE" sqlType="STRING"/>
		<param defaultValue="0" name="GRADO" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIOANTERIOR" sqlType="STRING"/>
		<param defaultValue="0" name="SUBSTRANSPORTE" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
