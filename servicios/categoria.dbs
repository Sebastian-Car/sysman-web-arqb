	<query id="updateCategoriaNivelEmpleado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CATEGORIA SET VLREXTRA=:VLREXTRA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), PRIMATECNICA=:PRIMATECNICA, NOMBRE_CATEGORIA=:NOMBRE_CATEGORIA, ANO=:ANO, CODIGOGRADO=:CODIGOGRADO, SALARIO_RETROACTIVO=:SALARIO_RETROACTIVO, GASTOSREPRESENTACION=:GASTOSREPRESENTACION, SUBSALIMENTACION=:SUBSALIMENTACION, VLR_INCREMENTO=:VLR_INCREMENTO, SALARIO_BASE=:SALARIO_BASE, ESCALAFON=:ESCALAFON, GRADO=:GRADO, COMPANIA=:COMPANIA, SALARIOANTERIOR=:SALARIOANTERIOR, SUBSTRANSPORTE=:SUBSTRANSPORTE, VLR_INCREMENTO_XE=:VLR_INCREMENTO_XE, VRLEXTRA_ANTERIOR=:VRLEXTRA_ANTERIOR, MODIFIED_BY=:MODIFIED_BY, ID_DE_CATEGORIA=:ID_DE_CATEGORIA, BONIFICACION_DOCENTE=:BONIFICACION_DOCENTE, CATEGORIA_REFERENCIA=:CATEGORIA_REFERENCIA WHERE CATEGORIA.COMPANIA= :KEY_COMPANIA AND CATEGORIA.ESCALAFON= :KEY_ESCALAFON AND CATEGORIA.ID_DE_CATEGORIA= :KEY_ID_DE_CATEGORIA AND CATEGORIA.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VLREXTRA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PRIMATECNICA" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOGRADO" sqlType="STRING"/>
		<param name="SALARIO_RETROACTIVO" sqlType="STRING"/>
		<param name="GASTOSREPRESENTACION" sqlType="STRING"/>
		<param name="SUBSALIMENTACION" sqlType="STRING"/>
		<param name="VLR_INCREMENTO" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="GRADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SALARIOANTERIOR" sqlType="STRING"/>
		<param name="SUBSTRANSPORTE" sqlType="STRING"/>
		<param name="VLR_INCREMENTO_XE" sqlType="STRING"/>
		<param name="VRLEXTRA_ANTERIOR" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
