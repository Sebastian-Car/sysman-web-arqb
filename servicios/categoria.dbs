		</call-query>
	</resource>
	<query id="updateCategoriaCategoriaViaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CATEGORIA SET ANO=:ANO, ESCALAFON=:ESCALAFON, ID_DE_CATEGORIA=:ID_DE_CATEGORIA, NOMBRE_CATEGORIA=:NOMBRE_CATEGORIA, SALARIO_BASE=:SALARIO_BASE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CATEGORIA.COMPANIA= :KEY_COMPANIA AND CATEGORIA.ESCALAFON= :KEY_ESCALAFON AND CATEGORIA.ID_DE_CATEGORIA= :KEY_ID_DE_CATEGORIA AND CATEGORIA.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ESCALAFON" sqlType="STRING"/>
		<param name="KEY_ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="categoria/categoriaviaticos">
		<call-query href="updateCategoriaCategoriaViaticos">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ESCALAFON" query-param="KEY_ESCALAFON"/>
			<with-param name="KEY_ID_DE_CATEGORIA" query-param="KEY_ID_DE_CATEGORIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="insertCategoriaCategoriaViaticos" keyColumns="COMPANIA,ESCALAFON,ID_DE_CATEGORIA,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CATEGORIA (COMPANIA, ANO, ESCALAFON, ID_DE_CATEGORIA, NOMBRE_CATEGORIA, SALARIO_BASE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :ESCALAFON, :ID_DE_CATEGORIA, :NOMBRE_CATEGORIA, :SALARIO_BASE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ESCALAFON":"$ESCALAFON","KEY_ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIO_BASE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="categoria/categoriaviaticos">
		<call-query href="insertCategoriaCategoriaViaticos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getCategoriaNombrecategoriaporcategoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE_CATEGORIA  FROM CATEGORIA WHERE COMPANIA = :COMPANIA AND ID_DE_CATEGORIA = :CATEGORIA AND ROWNUM &lt;= 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="categoria/nombrecategoriaporcategoria">
		<call-query href="getCategoriaNombrecategoriaporcategoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>

		</call-query>
	</resource>
	<query id="getCategoriaReferenciaActivaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA, ESCALAFON.CODIGO, ESCALAFON.NOMBRE, COUNT(1) CANTIDAD  FROM CATEGORIA INNER JOIN ESCALAFON ON CATEGORIA.COMPANIA = ESCALAFON.COMPANIA AND CATEGORIA.ESCALAFON = ESCALAFON.CODIGO WHERE CATEGORIA.COMPANIA = :COMPANIA AND CATEGORIA.ANO = :ANO AND CATEGORIA_REFERENCIA IN (-1) GROUP BY CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA, ESCALAFON.CODIGO, ESCALAFON.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="categoria/referenciaactiva">
		<call-query href="getCategoriaReferenciaActivaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getCategoriaPagPorcategoriarefQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ID_DE_CATEGORIA, ESCALAFON,NOMBRE_CATEGORIA, SALARIO_BASE FROM CATEGORIA WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CATEGORIA_REFERENCIA &lt;&gt; 0) INI WHERE (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CATEGORIA), '%')) AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END) LIKE UPPER(CONCAT(:SALARIO_BASE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","ESCALAFON":"$ESCALAFON","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="categoria/porcategoriaref/pag">
		<call-query href="getCategoriaPagPorcategoriarefQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCategoriaNumPorcategoriarefQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ID_DE_CATEGORIA, ESCALAFON,NOMBRE_CATEGORIA, SALARIO_BASE FROM CATEGORIA WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CATEGORIA_REFERENCIA &lt;&gt; 0) INI WHERE (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CATEGORIA), '%')) AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END) LIKE UPPER(CONCAT(:SALARIO_BASE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="categoria/porcategoriaref/num">
		<call-query href="getCategoriaNumPorcategoriarefQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>

		</call-query>
	</resource>
	<query id="getCategoriaPagPoranoconescalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CATEGORIA.ID_DE_CATEGORIA,NOMBRE ESCALAFON, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE , ESCALAFON.CODIGO CODESCALAFON  FROM CATEGORIA INNER JOIN ESCALAFON ON CATEGORIA.COMPANIA= ESCALAFON.COMPANIA AND CATEGORIA.ESCALAFON = ESCALAFON.CODIGO WHERE CATEGORIA.COMPANIA = :COMPANIA AND CATEGORIA.ANO = :ANO) WHERE (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER( '%' || :ID_DE_CATEGORIA || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER( '%' || :ESCALAFON || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER( '%' || :SALARIO_BASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","ESCALAFON":"$ESCALAFON","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE","CODESCALAFON":"$CODESCALAFON"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="categoria/poranoconescalafon/pag">
		<call-query href="getCategoriaPagPoranoconescalafonQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCategoriaNumPoranoconescalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CATEGORIA.ID_DE_CATEGORIA,NOMBRE ESCALAFON, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE , ESCALAFON.CODIGO CODESCALAFON  FROM CATEGORIA INNER JOIN ESCALAFON ON CATEGORIA.COMPANIA= ESCALAFON.COMPANIA AND CATEGORIA.ESCALAFON = ESCALAFON.CODIGO WHERE CATEGORIA.COMPANIA = :COMPANIA AND CATEGORIA.ANO = :ANO) WHERE (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER( '%' || :ID_DE_CATEGORIA || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER( '%' || :ESCALAFON || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER( '%' || :SALARIO_BASE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="categoria/poranoconescalafon/num">
		<call-query href="getCategoriaNumPoranoconescalafonQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>

		</call-query>
	</resource>
	<query id="updateCategoriaRedondearalmil" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CATEGORIA SET SALARIO_BASE = FLOOR(SALARIO_BASE/1000)*1000, MODIFIED_BY = :MODIFIED_BY, DATE_MODIFIED = SYSDATE WHERE COMPANIA = :COMPANIA AND ANO &gt;= :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="categoria/redondearalmil">
		<call-query href="updateCategoriaRedondearalmil">
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	
</data>