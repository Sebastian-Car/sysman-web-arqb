	<query id="getCategoriaPagTodosPorCompaniaAnoEscalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.CODIGOGRADO, NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE, NVL(CATEGORIA.GASTOSREPRESENTACION,0) GASTOSREPRESENTACION  FROM CATEGORIA WHERE CATEGORIA.COMPANIA= :COMPANIA AND CATEGORIA.ANO = :ANO AND CATEGORIA.ESCALAFON = :ESCALAFON) WHERE (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN CODIGOGRADO IS NULL THEN ' ' ELSE UPPER(CODIGOGRADO) END)  LIKE UPPER(:CODIGOGRADO || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER(:SALARIO_BASE || '%')  AND (CASE WHEN GASTOSREPRESENTACION IS NULL THEN ' ' ELSE UPPER(GASTOSREPRESENTACION) END)  LIKE UPPER(:GASTOSREPRESENTACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","CODIGOGRADO":"$CODIGOGRADO","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE","GASTOSREPRESENTACION":"$GASTOSREPRESENTACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="CODIGOGRADO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="GASTOSREPRESENTACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="categoria/todosporcompaniaanoescalafon/pag">
		<call-query href="getCategoriaPagTodosPorCompaniaAnoEscalafonQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
