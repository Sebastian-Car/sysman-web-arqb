<data name="categoria" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCategoriaPagListartodaslascategoriasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CATEGORIA.COMPANIA, CATEGORIA.ESCALAFON, CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.ANO, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE, ROUND(CATEGORIA.SALARIO_BASE/30,2) VALORJORNAL, CATEGORIA.GASTOSREPRESENTACION, CATEGORIA.SALARIOANTERIOR, CATEGORIA.GRADO, CATEGORIA.CODIGOGRADO, CATEGORIA.VLREXTRA, CATEGORIA.VLR_INCREMENTO, CATEGORIA.SALARIO_RETROACTIVO, CATEGORIA.PRIMATECNICA, CATEGORIA.SUBSALIMENTACION, CATEGORIA.SUBSTRANSPORTE, CATEGORIA.VLR_INCREMENTO_XE, CATEGORIA.VRLEXTRA_ANTERIOR, CATEGORIA.BONIFICACION_DOCENTE,(CASE CATEGORIA.CATEGORIA_REFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) CATEGORIA_REFERENCIA, CATEGORIA.CREATED_BY,(TO_CHAR(CATEGORIA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CATEGORIA.MODIFIED_BY,(TO_CHAR(CATEGORIA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM categoria WHERE COMPANIA=:COMPANIA AND ESCALAFON =:CODIGO ORDER BY CATEGORIA.ANO DESC, CATEGORIA.ID_DE_CATEGORIA ASC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER(:ESCALAFON || '%')  AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER(:SALARIO_BASE || '%')  AND (CASE WHEN VALORJORNAL IS NULL THEN ' ' ELSE UPPER(VALORJORNAL) END)  LIKE UPPER(:VALORJORNAL || '%')  AND (CASE WHEN GASTOSREPRESENTACION IS NULL THEN ' ' ELSE UPPER(GASTOSREPRESENTACION) END)  LIKE UPPER(:GASTOSREPRESENTACION || '%')  AND (CASE WHEN SALARIOANTERIOR IS NULL THEN ' ' ELSE UPPER(SALARIOANTERIOR) END)  LIKE UPPER(:SALARIOANTERIOR || '%')  AND (CASE WHEN GRADO IS NULL THEN ' ' ELSE UPPER(GRADO) END)  LIKE UPPER(:GRADO || '%')  AND (CASE WHEN CODIGOGRADO IS NULL THEN ' ' ELSE UPPER(CODIGOGRADO) END)  LIKE UPPER(:CODIGOGRADO || '%')  AND (CASE WHEN VLREXTRA IS NULL THEN ' ' ELSE UPPER(VLREXTRA) END)  LIKE UPPER(:VLREXTRA || '%')  AND (CASE WHEN VLR_INCREMENTO IS NULL THEN ' ' ELSE UPPER(VLR_INCREMENTO) END)  LIKE UPPER(:VLR_INCREMENTO || '%')  AND (CASE WHEN SALARIO_RETROACTIVO IS NULL THEN ' ' ELSE UPPER(SALARIO_RETROACTIVO) END)  LIKE UPPER(:SALARIO_RETROACTIVO || '%')  AND (CASE WHEN PRIMATECNICA IS NULL THEN ' ' ELSE UPPER(PRIMATECNICA) END)  LIKE UPPER(:PRIMATECNICA || '%')  AND (CASE WHEN SUBSALIMENTACION IS NULL THEN ' ' ELSE UPPER(SUBSALIMENTACION) END)  LIKE UPPER(:SUBSALIMENTACION || '%')  AND (CASE WHEN SUBSTRANSPORTE IS NULL THEN ' ' ELSE UPPER(SUBSTRANSPORTE) END)  LIKE UPPER(:SUBSTRANSPORTE || '%')  AND (CASE WHEN VLR_INCREMENTO_XE IS NULL THEN ' ' ELSE UPPER(VLR_INCREMENTO_XE) END)  LIKE UPPER(:VLR_INCREMENTO_XE || '%')  AND (CASE WHEN VRLEXTRA_ANTERIOR IS NULL THEN ' ' ELSE UPPER(VRLEXTRA_ANTERIOR) END)  LIKE UPPER(:VRLEXTRA_ANTERIOR || '%')  AND (CASE WHEN BONIFICACION_DOCENTE IS NULL THEN ' ' ELSE UPPER(BONIFICACION_DOCENTE) END)  LIKE UPPER(:BONIFICACION_DOCENTE || '%')  AND (CASE WHEN CATEGORIA_REFERENCIA IS NULL THEN ' ' ELSE UPPER(CATEGORIA_REFERENCIA) END)  LIKE UPPER(:CATEGORIA_REFERENCIA || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER(:CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER(:DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER(:MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER(:DATE_MODIFIED || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ESCALAFON":"$ESCALAFON","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","ANO":"$ANO(type:integer)","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE","VALORJORNAL":"$VALORJORNAL","GASTOSREPRESENTACION":"$GASTOSREPRESENTACION","SALARIOANTERIOR":"$SALARIOANTERIOR","GRADO":"$GRADO","CODIGOGRADO":"$CODIGOGRADO","VLREXTRA":"$VLREXTRA","VLR_INCREMENTO":"$VLR_INCREMENTO","SALARIO_RETROACTIVO":"$SALARIO_RETROACTIVO","PRIMATECNICA":"$PRIMATECNICA","SUBSALIMENTACION":"$SUBSALIMENTACION","SUBSTRANSPORTE":"$SUBSTRANSPORTE","VLR_INCREMENTO_XE":"$VLR_INCREMENTO_XE","VRLEXTRA_ANTERIOR":"$VRLEXTRA_ANTERIOR","BONIFICACION_DOCENTE":"$BONIFICACION_DOCENTE","CATEGORIA_REFERENCIA":"$CATEGORIA_REFERENCIA(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="VALORJORNAL" sqlType="STRING"/>
		<param name="GASTOSREPRESENTACION" sqlType="STRING"/>
		<param name="SALARIOANTERIOR" sqlType="STRING"/>
		<param name="GRADO" sqlType="STRING"/>
		<param name="CODIGOGRADO" sqlType="STRING"/>
		<param name="VLREXTRA" sqlType="STRING"/>
		<param name="VLR_INCREMENTO" sqlType="STRING"/>
		<param name="SALARIO_RETROACTIVO" sqlType="STRING"/>
		<param name="PRIMATECNICA" sqlType="STRING"/>
		<param name="SUBSALIMENTACION" sqlType="STRING"/>
		<param name="SUBSTRANSPORTE" sqlType="STRING"/>
		<param name="VLR_INCREMENTO_XE" sqlType="STRING"/>
		<param name="VRLEXTRA_ANTERIOR" sqlType="STRING"/>
		<param name="BONIFICACION_DOCENTE" sqlType="STRING"/>
		<param name="CATEGORIA_REFERENCIA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="categoria/listartodaslascategorias/pag">
		<call-query href="getCategoriaPagListartodaslascategoriasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
