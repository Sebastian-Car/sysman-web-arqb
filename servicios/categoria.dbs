			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="GASTOSREPRESENTACION" query-param="GASTOSREPRESENTACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCategoriaNumTodosPorCompaniaAnoEscalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.CODIGOGRADO, NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE, NVL(CATEGORIA.GASTOSREPRESENTACION,0) GASTOSREPRESENTACION  FROM CATEGORIA WHERE CATEGORIA.COMPANIA= :COMPANIA AND CATEGORIA.ANO = :ANO AND CATEGORIA.ESCALAFON = :ESCALAFON) WHERE (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN CODIGOGRADO IS NULL THEN ' ' ELSE UPPER(CODIGOGRADO) END)  LIKE UPPER(:CODIGOGRADO || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER(:SALARIO_BASE || '%')  AND (CASE WHEN GASTOSREPRESENTACION IS NULL THEN ' ' ELSE UPPER(GASTOSREPRESENTACION) END)  LIKE UPPER(:GASTOSREPRESENTACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="CODIGOGRADO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="GASTOSREPRESENTACION" sqlType="STRING"/>

	</query>
