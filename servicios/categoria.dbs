			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateCategoriaRedondearalpeso" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CATEGORIA SET SALARIO_BASE  = ROUND(SALARIO_BASE,0),   SALARIOANTERIOR = ROUND(SALARIOANTERIOR,0),   MODIFIED_BY     = :MODIFIED_BY,   DATE_MODIFIED   = SYSDATE WHERE COMPANIA = :COMPANIA   AND ANO     &gt;= :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="categoria/redondearalpeso">
		<call-query href="updateCategoriaRedondearalpeso">
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getCategoriaPagCategoriaViaticosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CATEGORIA.COMPANIA, CATEGORIA.ANO, CATEGORIA.ESCALAFON, CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.SALARIO_BASE  FROM CATEGORIA WHERE CATEGORIA.COMPANIA = :COMPANIA ORDER BY CATEGORIA.ANO, CATEGORIA.ESCALAFON, CATEGORIA.ID_DE_CATEGORIA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER(:ESCALAFON || '%')  AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END)  LIKE UPPER( '%' || :SALARIO_BASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ESCALAFON":"$ESCALAFON","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
