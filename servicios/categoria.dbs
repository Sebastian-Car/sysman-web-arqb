	<query id="getCategoriaTodosporaniocalculoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ESCALAFON, ID_DE_CATEGORIA, ANO, NOMBRE_CATEGORIA, SALARIO_BASE, GASTOSREPRESENTACION, SALARIOANTERIOR, GRADO, CODIGOGRADO, VLREXTRA, VLR_INCREMENTO, SALARIO_RETROACTIVO, PRIMATECNICA, SUBSALIMENTACION, SUBSTRANSPORTE, VLR_INCREMENTO_XE, VRLEXTRA_ANTERIOR  FROM CATEGORIA WHERE COMPANIA = :COMPANIA AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ESCALAFON":"$ESCALAFON","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","ANO":"$ANO(type:integer)","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE","GASTOSREPRESENTACION":"$GASTOSREPRESENTACION","SALARIOANTERIOR":"$SALARIOANTERIOR","GRADO":"$GRADO","CODIGOGRADO":"$CODIGOGRADO","VLREXTRA":"$VLREXTRA","VLR_INCREMENTO":"$VLR_INCREMENTO","SALARIO_RETROACTIVO":"$SALARIO_RETROACTIVO","PRIMATECNICA":"$PRIMATECNICA","SUBSALIMENTACION":"$SUBSALIMENTACION","SUBSTRANSPORTE":"$SUBSTRANSPORTE","VLR_INCREMENTO_XE":"$VLR_INCREMENTO_XE","VRLEXTRA_ANTERIOR":"$VRLEXTRA_ANTERIOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
