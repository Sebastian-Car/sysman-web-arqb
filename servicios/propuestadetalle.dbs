<data name="propuestadetalle" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updatePropuestadetalleModdetalpropuesta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROPUESTA_DETALLE SET CANTIDAD=:CANTIDAD, VALORUNITARIO=:VALORUNITARIO, PORCIVA=:PORCIVA, PORCDESC=:PORCDESC, VLRTOTAL=:VLRTOTAL, MARCA=:MARCA, ESPECIFICACION=:ESPECIFICACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PROPUESTA_DETALLE.COD_PROPUESTA= :KEY_COD_PROPUESTA AND PROPUESTA_DETALLE.COD_REQUISICION= :KEY_COD_REQUISICION AND PROPUESTA_DETALLE.COMPANIA= :KEY_COMPANIA AND PROPUESTA_DETALLE.COD_DETALLE= :KEY_COD_DETALLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="PORCDESC" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COD_PROPUESTA" sqlType="STRING"/>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_DETALLE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="propuestadetalle/moddetalpropuesta">
		<call-query href="updatePropuestadetalleModdetalpropuesta">
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESC" query-param="PORCDESC"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COD_PROPUESTA" query-param="KEY_COD_PROPUESTA"/>
			<with-param name="KEY_COD_REQUISICION" query-param="KEY_COD_REQUISICION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_DETALLE" query-param="KEY_COD_DETALLE"/>

		</call-query>
	</resource>
	<query id="getPropuestadetallePrdetalinventQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PROPUESTA_DETALLE.COMPANIA, PROPUESTA_DETALLE.COD_PROPUESTA, PROPUESTA_DETALLE.COD_REQUISICION, PROPUESTA_DETALLE.COD_DETALLE, PROPUESTA_DETALLE.ORDENDESUMINISTRO, PROPUESTA_DETALLE.DEPENDENCIA, PROPUESTA_DETALLE.ELEMENTO, PROPUESTA_DETALLE.ESPECIFICACION, PROPUESTA_DETALLE.CENTRODECOSTO, PROPUESTA_DETALLE.CANTIDAD, PROPUESTA_DETALLE.SALDOCANT, PROPUESTA_DETALLE.VALORUNITARIO, PROPUESTA_DETALLE.PORCIVA, PROPUESTA_DETALLE.PORCDESC, PROPUESTA_DETALLE.VLRTOTAL, PROPUESTA_DETALLE.MARCA, PROPUESTA_DETALLE.CREATED_BY,(TO_CHAR(PROPUESTA_DETALLE.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, PROPUESTA_DETALLE.MODIFIED_BY,(TO_CHAR(PROPUESTA_DETALLE.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, INVENTARIO.NOMBRELARGO  FROM PROPUESTA_DETALLE LEFT JOIN INVENTARIO ON PROPUESTA_DETALLE.ELEMENTO = INVENTARIO.CODIGOELEMENTO AND PROPUESTA_DETALLE.COMPANIA = INVENTARIO.COMPANIA WHERE PROPUESTA_DETALLE.COMPANIA = :COMPANIA AND PROPUESTA_DETALLE.COD_PROPUESTA = :CODPRO AND PROPUESTA_DETALLE.COD_REQUISICION= :CODREQ ORDER BY PROPUESTA_DETALLE.COD_PROPUESTA, PROPUESTA_DETALLE.COD_REQUISICION, PROPUESTA_DETALLE.COMPANIA, PROPUESTA_DETALLE.COD_DETALLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PROPUESTA":"$COD_PROPUESTA(type:long)","COD_REQUISICION":"$COD_REQUISICION(type:long)","COD_DETALLE":"$COD_DETALLE(type:long)","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO(type:long)","DEPENDENCIA":"$DEPENDENCIA","ELEMENTO":"$ELEMENTO","ESPECIFICACION":"$ESPECIFICACION","CENTRODECOSTO":"$CENTRODECOSTO","CANTIDAD":"$CANTIDAD","SALDOCANT":"$SALDOCANT","VALORUNITARIO":"$VALORUNITARIO","PORCIVA":"$PORCIVA","PORCDESC":"$PORCDESC","VLRTOTAL":"$VLRTOTAL","MARCA":"$MARCA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODPRO" sqlType="STRING"/>
		<param name="CODREQ" sqlType="STRING"/>

	</query>
	<resource method="GET" path="propuestadetalle/prdetalinvent">
		<call-query href="getPropuestadetallePrdetalinventQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODPRO" query-param="CODPRO"/>
			<with-param name="CODREQ" query-param="CODREQ"/>

		</call-query>
	</resource>
	<query id="getPropuestadetallePagListadetalpropQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROPUESTA_DETALLE.COMPANIA, PROPUESTA_DETALLE.COD_PROPUESTA, PROPUESTA_DETALLE.COD_REQUISICION, PROPUESTA_DETALLE.COD_DETALLE, PROPUESTA_DETALLE.ORDENDESUMINISTRO, PROPUESTA_DETALLE.DEPENDENCIA, PROPUESTA_DETALLE.ELEMENTO, PROPUESTA_DETALLE.ESPECIFICACION, PROPUESTA_DETALLE.CENTRODECOSTO, PROPUESTA_DETALLE.CANTIDAD, PROPUESTA_DETALLE.SALDOCANT, PROPUESTA_DETALLE.VALORUNITARIO, PROPUESTA_DETALLE.PORCIVA, PROPUESTA_DETALLE.PORCDESC, PROPUESTA_DETALLE.VLRTOTAL, PROPUESTA_DETALLE.MARCA, INVENTARIO.NOMBRELARGO  FROM PROPUESTA_DETALLE LEFT JOIN INVENTARIO ON PROPUESTA_DETALLE.ELEMENTO = INVENTARIO.CODIGOELEMENTO AND PROPUESTA_DETALLE.COMPANIA = INVENTARIO.COMPANIA WHERE PROPUESTA_DETALLE.COMPANIA = :COMPANIA AND PROPUESTA_DETALLE.COD_PROPUESTA = :CODPRO AND PROPUESTA_DETALLE.COD_REQUISICION= :CODREQ ORDER BY PROPUESTA_DETALLE.COD_PROPUESTA, PROPUESTA_DETALLE.COD_REQUISICION, PROPUESTA_DETALLE.COMPANIA, PROPUESTA_DETALLE.COD_DETALLE) WHERE (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END)  LIKE UPPER(:ESPECIFICACION || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER( '%' || :CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN PORCIVA IS NULL THEN ' ' ELSE UPPER(PORCIVA) END)  LIKE UPPER(:PORCIVA || '%')  AND (CASE WHEN PORCDESC IS NULL THEN ' ' ELSE UPPER(PORCDESC) END)  LIKE UPPER(:PORCDESC || '%')  AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END)  LIKE UPPER(:VLRTOTAL || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PROPUESTA":"$COD_PROPUESTA(type:long)","COD_REQUISICION":"$COD_REQUISICION(type:long)","COD_DETALLE":"$COD_DETALLE(type:long)","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO(type:long)","DEPENDENCIA":"$DEPENDENCIA","ELEMENTO":"$ELEMENTO","ESPECIFICACION":"$ESPECIFICACION","CENTRODECOSTO":"$CENTRODECOSTO","CANTIDAD":"$CANTIDAD","SALDOCANT":"$SALDOCANT","VALORUNITARIO":"$VALORUNITARIO","PORCIVA":"$PORCIVA","PORCDESC":"$PORCDESC","VLRTOTAL":"$VLRTOTAL","MARCA":"$MARCA","NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODPRO" sqlType="STRING"/>
		<param name="CODREQ" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="PORCDESC" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="propuestadetalle/listadetalprop/pag">
		<call-query href="getPropuestadetallePagListadetalpropQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODPRO" query-param="CODPRO"/>
			<with-param name="CODREQ" query-param="CODREQ"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESC" query-param="PORCDESC"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPropuestadetalleNumListadetalpropQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROPUESTA_DETALLE.COMPANIA, PROPUESTA_DETALLE.COD_PROPUESTA, PROPUESTA_DETALLE.COD_REQUISICION, PROPUESTA_DETALLE.COD_DETALLE, PROPUESTA_DETALLE.ORDENDESUMINISTRO, PROPUESTA_DETALLE.DEPENDENCIA, PROPUESTA_DETALLE.ELEMENTO, PROPUESTA_DETALLE.ESPECIFICACION, PROPUESTA_DETALLE.CENTRODECOSTO, PROPUESTA_DETALLE.CANTIDAD, PROPUESTA_DETALLE.SALDOCANT, PROPUESTA_DETALLE.VALORUNITARIO, PROPUESTA_DETALLE.PORCIVA, PROPUESTA_DETALLE.PORCDESC, PROPUESTA_DETALLE.VLRTOTAL, PROPUESTA_DETALLE.MARCA, INVENTARIO.NOMBRELARGO  FROM PROPUESTA_DETALLE LEFT JOIN INVENTARIO ON PROPUESTA_DETALLE.ELEMENTO = INVENTARIO.CODIGOELEMENTO AND PROPUESTA_DETALLE.COMPANIA = INVENTARIO.COMPANIA WHERE PROPUESTA_DETALLE.COMPANIA = :COMPANIA AND PROPUESTA_DETALLE.COD_PROPUESTA = :CODPRO AND PROPUESTA_DETALLE.COD_REQUISICION= :CODREQ ORDER BY PROPUESTA_DETALLE.COD_PROPUESTA, PROPUESTA_DETALLE.COD_REQUISICION, PROPUESTA_DETALLE.COMPANIA, PROPUESTA_DETALLE.COD_DETALLE) WHERE (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END)  LIKE UPPER(:ESPECIFICACION || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER( '%' || :CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN PORCIVA IS NULL THEN ' ' ELSE UPPER(PORCIVA) END)  LIKE UPPER(:PORCIVA || '%')  AND (CASE WHEN PORCDESC IS NULL THEN ' ' ELSE UPPER(PORCDESC) END)  LIKE UPPER(:PORCDESC || '%')  AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END)  LIKE UPPER(:VLRTOTAL || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODPRO" sqlType="STRING"/>
		<param name="CODREQ" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="PORCDESC" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="propuestadetalle/listadetalprop/num">
		<call-query href="getPropuestadetalleNumListadetalpropQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODPRO" query-param="CODPRO"/>
			<with-param name="CODREQ" query-param="CODREQ"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESC" query-param="PORCDESC"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>

		</call-query>
	</resource>

</data>