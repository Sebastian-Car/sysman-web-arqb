<data name="spmultiusuarios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSpmultiusuarios" keyColumns="COMPANIA,CODIGORUTA,CICLO,USO,ESTRATO,ESTRATOASEO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_MULTIUSUARIOS (COMPANIA, CICLO, CODIGORUTA, CONSECUTIVO, USO, ESTRATO, CANTIDAD, ESTRATOASEO, PESOASEO, TAFNA_720, TAFA_720, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CICLO, :CODIGORUTA, :CONSECUTIVO, :USO, :ESTRATO, :CANTIDAD, :ESTRATOASEO, :PESOASEO, :TAFNA_720, :TAFA_720, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGORUTA":"$CODIGORUTA","KEY_CICLO":"$CICLO(type:integer)","KEY_USO":"$USO","KEY_ESTRATO":"$ESTRATO","KEY_ESTRATOASEO":"$ESTRATOASEO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param defaultValue="0" name="PESOASEO" sqlType="STRING"/>
		<param defaultValue="0" name="TAFNA_720" sqlType="STRING"/>
		<param defaultValue="0" name="TAFA_720" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spmultiusuarios">
		<call-query href="insertSpmultiusuarios">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="TAFNA_720" query-param="TAFNA_720"/>
			<with-param name="TAFA_720" query-param="TAFA_720"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSpmultiusuarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_MULTIUSUARIOS WHERE SP_MULTIUSUARIOS.COMPANIA= :KEY_COMPANIA AND SP_MULTIUSUARIOS.CODIGORUTA= :KEY_CODIGORUTA AND SP_MULTIUSUARIOS.CICLO= :KEY_CICLO AND SP_MULTIUSUARIOS.USO= :KEY_USO AND SP_MULTIUSUARIOS.ESTRATO= :KEY_ESTRATO AND SP_MULTIUSUARIOS.ESTRATOASEO= :KEY_ESTRATOASEO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="INTEGER"/>
		<param name="KEY_USO" sqlType="STRING"/>
		<param name="KEY_ESTRATO" sqlType="STRING"/>
		<param name="KEY_ESTRATOASEO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spmultiusuarios">
		<call-query href="deleteSpmultiusuarios">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_USO" query-param="KEY_USO"/>
			<with-param name="KEY_ESTRATO" query-param="KEY_ESTRATO"/>
			<with-param name="KEY_ESTRATOASEO" query-param="KEY_ESTRATOASEO"/>

		</call-query>
	</resource>
	<query id="getSpmultiusuariosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_MULTIUSUARIOS.COMPANIA, SP_MULTIUSUARIOS.CICLO, SP_MULTIUSUARIOS.CODIGORUTA, SP_MULTIUSUARIOS.CONSECUTIVO, SP_MULTIUSUARIOS.USO, SP_USOS.NOMBRE NOMBREUSO, SP_MULTIUSUARIOS.ESTRATO, SP_ESTRATOS.NOMBRE NOMBREESTRATO, SP_MULTIUSUARIOS.CANTIDAD, SP_MULTIUSUARIOS.ESTRATOASEO, ESTRATOS_1.NOMBRE NOMBREESTRATOASEO, SP_MULTIUSUARIOS.PESOASEO, SP_MULTIUSUARIOS.TAFNA_720, SP_MULTIUSUARIOS.TAFA_720  FROM SP_MULTIUSUARIOS LEFT JOIN SP_ESTRATOS ON SP_MULTIUSUARIOS.COMPANIA = SP_ESTRATOS.COMPANIA AND SP_MULTIUSUARIOS.USO = SP_ESTRATOS.USO AND SP_MULTIUSUARIOS.ESTRATO = SP_ESTRATOS.CODIGO LEFT JOIN SP_ESTRATOS ESTRATOS_1 ON SP_MULTIUSUARIOS.COMPANIA = ESTRATOS_1.COMPANIA AND SP_MULTIUSUARIOS.USO = ESTRATOS_1.USO AND SP_MULTIUSUARIOS.ESTRATOASEO = ESTRATOS_1.CODIGO LEFT JOIN SP_USOS ON SP_MULTIUSUARIOS.COMPANIA = SP_USOS.COMPANIA AND SP_MULTIUSUARIOS.USO = SP_USOS.CODIGO WHERE SP_MULTIUSUARIOS.COMPANIA = :COMPANIA AND SP_MULTIUSUARIOS.CICLO = :CICLO AND SP_MULTIUSUARIOS.CODIGORUTA = :CODIGORUTA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER(:CICLO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN USO IS NULL THEN ' ' ELSE UPPER(USO) END)  LIKE UPPER( '%' || :USO || '%')  AND (CASE WHEN NOMBREUSO IS NULL THEN ' ' ELSE UPPER(NOMBREUSO) END)  LIKE UPPER( '%' || :NOMBREUSO || '%')  AND (CASE WHEN ESTRATO IS NULL THEN ' ' ELSE UPPER(ESTRATO) END)  LIKE UPPER( '%' || :ESTRATO || '%')  AND (CASE WHEN NOMBREESTRATO IS NULL THEN ' ' ELSE UPPER(NOMBREESTRATO) END)  LIKE UPPER( '%' || :NOMBREESTRATO || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER( '%' || :CANTIDAD || '%')  AND (CASE WHEN ESTRATOASEO IS NULL THEN ' ' ELSE UPPER(ESTRATOASEO) END)  LIKE UPPER( '%' || :ESTRATOASEO || '%')  AND (CASE WHEN NOMBREESTRATOASEO IS NULL THEN ' ' ELSE UPPER(NOMBREESTRATOASEO) END)  LIKE UPPER( '%' || :NOMBREESTRATOASEO || '%')  AND (CASE WHEN PESOASEO IS NULL THEN ' ' ELSE UPPER(PESOASEO) END)  LIKE UPPER( '%' || :PESOASEO || '%')  AND (CASE WHEN TAFNA_720 IS NULL THEN ' ' ELSE UPPER(TAFNA_720) END)  LIKE UPPER( '%' || :TAFNA_720 || '%')  AND (CASE WHEN TAFA_720 IS NULL THEN ' ' ELSE UPPER(TAFA_720) END)  LIKE UPPER( '%' || :TAFA_720 || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","CONSECUTIVO":"$CONSECUTIVO","USO":"$USO","NOMBREUSO":"$NOMBREUSO","ESTRATO":"$ESTRATO","NOMBREESTRATO":"$NOMBREESTRATO","CANTIDAD":"$CANTIDAD","ESTRATOASEO":"$ESTRATOASEO","NOMBREESTRATOASEO":"$NOMBREESTRATOASEO","PESOASEO":"$PESOASEO","TAFNA_720":"$TAFNA_720","TAFA_720":"$TAFA_720"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="NOMBREUSO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="NOMBREESTRATO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param name="NOMBREESTRATOASEO" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="TAFNA_720" sqlType="STRING"/>
		<param name="TAFA_720" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spmultiusuarios">
		<call-query href="getSpmultiusuariosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="NOMBREUSO" query-param="NOMBREUSO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="NOMBREESTRATO" query-param="NOMBREESTRATO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="NOMBREESTRATOASEO" query-param="NOMBREESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="TAFNA_720" query-param="TAFNA_720"/>
			<with-param name="TAFA_720" query-param="TAFA_720"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpmultiusuariosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_MULTIUSUARIOS.COMPANIA, SP_MULTIUSUARIOS.CICLO, SP_MULTIUSUARIOS.CODIGORUTA, SP_MULTIUSUARIOS.CONSECUTIVO, SP_MULTIUSUARIOS.USO, SP_USOS.NOMBRE NOMBREUSO, SP_MULTIUSUARIOS.ESTRATO, SP_ESTRATOS.NOMBRE NOMBREESTRATO, SP_MULTIUSUARIOS.CANTIDAD, SP_MULTIUSUARIOS.ESTRATOASEO, ESTRATOS_1.NOMBRE NOMBREESTRATOASEO, SP_MULTIUSUARIOS.PESOASEO, SP_MULTIUSUARIOS.TAFNA_720, SP_MULTIUSUARIOS.TAFA_720  FROM SP_MULTIUSUARIOS LEFT JOIN SP_ESTRATOS ON SP_MULTIUSUARIOS.COMPANIA = SP_ESTRATOS.COMPANIA AND SP_MULTIUSUARIOS.USO = SP_ESTRATOS.USO AND SP_MULTIUSUARIOS.ESTRATO = SP_ESTRATOS.CODIGO LEFT JOIN SP_ESTRATOS ESTRATOS_1 ON SP_MULTIUSUARIOS.COMPANIA = ESTRATOS_1.COMPANIA AND SP_MULTIUSUARIOS.USO = ESTRATOS_1.USO AND SP_MULTIUSUARIOS.ESTRATOASEO = ESTRATOS_1.CODIGO LEFT JOIN SP_USOS ON SP_MULTIUSUARIOS.COMPANIA = SP_USOS.COMPANIA AND SP_MULTIUSUARIOS.USO = SP_USOS.CODIGO WHERE SP_MULTIUSUARIOS.COMPANIA = :COMPANIA AND SP_MULTIUSUARIOS.CICLO = :CICLO AND SP_MULTIUSUARIOS.CODIGORUTA = :CODIGORUTA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER( '%' || :CICLO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN USO IS NULL THEN ' ' ELSE UPPER(USO) END)  LIKE UPPER( '%' || :USO || '%')  AND (CASE WHEN NOMBREUSO IS NULL THEN ' ' ELSE UPPER(NOMBREUSO) END)  LIKE UPPER( '%' || :NOMBREUSO || '%')  AND (CASE WHEN ESTRATO IS NULL THEN ' ' ELSE UPPER(ESTRATO) END)  LIKE UPPER( '%' || :ESTRATO || '%')  AND (CASE WHEN NOMBREESTRATO IS NULL THEN ' ' ELSE UPPER(NOMBREESTRATO) END)  LIKE UPPER( '%' || :NOMBREESTRATO || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER( '%' || :CANTIDAD || '%')  AND (CASE WHEN ESTRATOASEO IS NULL THEN ' ' ELSE UPPER(ESTRATOASEO) END)  LIKE UPPER( '%' || :ESTRATOASEO || '%')  AND (CASE WHEN NOMBREESTRATOASEO IS NULL THEN ' ' ELSE UPPER(NOMBREESTRATOASEO) END)  LIKE UPPER( '%' || :NOMBREESTRATOASEO || '%')  AND (CASE WHEN PESOASEO IS NULL THEN ' ' ELSE UPPER(PESOASEO) END)  LIKE UPPER( '%' || :PESOASEO || '%')  AND (CASE WHEN TAFNA_720 IS NULL THEN ' ' ELSE UPPER(TAFNA_720) END)  LIKE UPPER( '%' || :TAFNA_720 || '%')  AND (CASE WHEN TAFA_720 IS NULL THEN ' ' ELSE UPPER(TAFA_720) END)  LIKE UPPER( '%' || :TAFA_720 || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="NOMBREUSO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="NOMBREESTRATO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param name="NOMBREESTRATOASEO" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="TAFNA_720" sqlType="STRING"/>
		<param name="TAFA_720" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmultiusuarios/numero">
		<call-query href="getSpmultiusuariosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="NOMBREUSO" query-param="NOMBREUSO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="NOMBREESTRATO" query-param="NOMBREESTRATO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="NOMBREESTRATOASEO" query-param="NOMBREESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="TAFNA_720" query-param="TAFNA_720"/>
			<with-param name="TAFA_720" query-param="TAFA_720"/>

		</call-query>
	</resource>
	<query id="updateSpmultiusuarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_MULTIUSUARIOS SET USO=:USO, ESTRATO=:ESTRATO, CANTIDAD=:CANTIDAD, ESTRATOASEO=:ESTRATOASEO, PESOASEO=:PESOASEO, TAFNA_720=:TAFNA_720, TAFA_720=:TAFA_720, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_MULTIUSUARIOS.COMPANIA= :KEY_COMPANIA AND SP_MULTIUSUARIOS.CODIGORUTA= :KEY_CODIGORUTA AND SP_MULTIUSUARIOS.CICLO= :KEY_CICLO AND SP_MULTIUSUARIOS.USO= :KEY_USO AND SP_MULTIUSUARIOS.ESTRATO= :KEY_ESTRATO AND SP_MULTIUSUARIOS.ESTRATOASEO= :KEY_ESTRATOASEO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="TAFNA_720" sqlType="STRING"/>
		<param name="TAFA_720" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_USO" sqlType="STRING"/>
		<param name="KEY_ESTRATO" sqlType="STRING"/>
		<param name="KEY_ESTRATOASEO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spmultiusuarios">
		<call-query href="updateSpmultiusuarios">
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="TAFNA_720" query-param="TAFNA_720"/>
			<with-param name="TAFA_720" query-param="TAFA_720"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_USO" query-param="KEY_USO"/>
			<with-param name="KEY_ESTRATO" query-param="KEY_ESTRATO"/>
			<with-param name="KEY_ESTRATOASEO" query-param="KEY_ESTRATOASEO"/>

		</call-query>
	</resource>

</data>