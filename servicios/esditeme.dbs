<data name="esditeme" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsditemeSumatoriaPorCoditemCodstudQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(CANTIDAD) AS CANTIDAD , SUM(SUBTOTAL) AS SUBTOTAL, SUM (VLRTOTAL) AS VLRTOTAL  FROM ES_DITEM_E WHERE COMPANIA = :COMPANIA AND COD_ITEM = :COD_ITEM AND COD_ESTUDIO = :COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD","SUBTOTAL":"$SUBTOTAL","VLRTOTAL":"$VLRTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esditeme/sumatoriaporcoditemcodstud">
		<call-query href="getEsditemeSumatoriaPorCoditemCodstudQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsditemeTotalYSubtotalPorEstudioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VLRTOTAL, PORCIVA, VALORUNITARIO, CANTIDAD, SUBTOTAL  FROM ES_DITEM_E WHERE COMPANIA = :COMPANIA AND COD_ESTUDIO = :COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLRTOTAL":"$VLRTOTAL","PORCIVA":"$PORCIVA","VALORUNITARIO":"$VALORUNITARIO","CANTIDAD":"$CANTIDAD","SUBTOTAL":"$SUBTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esditeme/totalysubtotalporestudio">
		<call-query href="getEsditemeTotalYSubtotalPorEstudioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsditemeElementosporestprevQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT (ES_DITEM_E.ELEMENTO) ELEMENTOS  FROM ES_DITEM_E INNER JOIN INVENTARIO ON ES_DITEM_E.COMPANIA = INVENTARIO.COMPANIA AND ES_DITEM_E.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE ES_DITEM_E.COMPANIA = :COMPANIA AND ES_DITEM_E.COD_ESTUDIO = :ESTUDIOPREVIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTOS":"$ELEMENTOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTUDIOPREVIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esditeme/elementosporestprev">
		<call-query href="getEsditemeElementosporestprevQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTUDIOPREVIO" query-param="ESTUDIOPREVIO"/>

		</call-query>
	</resource>
	<query id="insertEsditeme" keyColumns="COMPANIA,COD_DITEM,COD_ITEM,COD_ESTUDIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_DITEM_E (COMPANIA, COD_DITEM, COD_ITEM, COD_ESTUDIO, ELEMENTO, DEPENDENCIA, ESPECIFICACION, CANTIDAD, CANTIDADAPROBADA, CANTIDADPORENTREGAR, VALORUNITARIO, PORCIVA, PORCDESCUENTO, VLRTOTAL, VLRAPROBADO, VACIA, IND_REG, SELECCIONADA, OBSERVACIONES, NSOLICITUDDISPON, CONCEPTO, PLACA, SUBTOTAL, CREATED_BY, DATE_CREATED, ADMINISTRACION, IMPREVISTOS, UTILIDADES, CODIGOCUBS) VALUES (:COMPANIA, :COD_DITEM, :COD_ITEM, :COD_ESTUDIO, :ELEMENTO, :DEPENDENCIA, :ESPECIFICACION, :CANTIDAD, :CANTIDADAPROBADA, :CANTIDADPORENTREGAR, :VALORUNITARIO, :PORCIVA, :PORCDESCUENTO, :VLRTOTAL, :VLRAPROBADO, :VACIA, :IND_REG, :SELECCIONADA, :OBSERVACIONES, :NSOLICITUDDISPON, :CONCEPTO, :PLACA, :SUBTOTAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :ADMINISTRACION, :IMPREVISTOS, :UTILIDADES, :CODIGOCUBS)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_DITEM":"$COD_DITEM","KEY_COD_ITEM":"$COD_ITEM","KEY_COD_ESTUDIO":"$COD_ESTUDIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_DITEM" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param defaultValue="" name="ELEMENTO" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="ESPECIFICACION" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDADAPROBADA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDADPORENTREGAR" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCDESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VLRTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VLRAPROBADO" sqlType="STRING"/>
		<param defaultValue="0" name="VACIA" sqlType="STRING"/>
		<param defaultValue="0" name="IND_REG" sqlType="STRING"/>
		<param defaultValue="" name="SELECCIONADA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="NSOLICITUDDISPON" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="PLACA" sqlType="STRING"/>
		<param defaultValue="0" name="SUBTOTAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="ADMINISTRACION" sqlType="STRING"/>
		<param defaultValue="0" name="IMPREVISTOS" sqlType="STRING"/>
		<param defaultValue="0" name="UTILIDADES" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCUBS" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esditeme">
		<call-query href="insertEsditeme">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_DITEM" query-param="COD_DITEM"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="CANTIDADAPROBADA" query-param="CANTIDADAPROBADA"/>
			<with-param name="CANTIDADPORENTREGAR" query-param="CANTIDADPORENTREGAR"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESCUENTO" query-param="PORCDESCUENTO"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="VLRAPROBADO" query-param="VLRAPROBADO"/>
			<with-param name="VACIA" query-param="VACIA"/>
			<with-param name="IND_REG" query-param="IND_REG"/>
			<with-param name="SELECCIONADA" query-param="SELECCIONADA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NSOLICITUDDISPON" query-param="NSOLICITUDDISPON"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="SUBTOTAL" query-param="SUBTOTAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="ADMINISTRACION" query-param="ADMINISTRACION"/>
			<with-param name="IMPREVISTOS" query-param="IMPREVISTOS"/>
			<with-param name="UTILIDADES" query-param="UTILIDADES"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>

		</call-query>
	</resource>
	<query id="deleteEsditeme" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_DITEM_E WHERE ES_DITEM_E.COMPANIA= :KEY_COMPANIA AND ES_DITEM_E.COD_DITEM= :KEY_COD_DITEM AND ES_DITEM_E.COD_ITEM= :KEY_COD_ITEM AND ES_DITEM_E.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_DITEM" sqlType="STRING"/>
		<param name="KEY_COD_ITEM" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="esditeme">
		<call-query href="deleteEsditeme">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_DITEM" query-param="KEY_COD_DITEM"/>
			<with-param name="KEY_COD_ITEM" query-param="KEY_COD_ITEM"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsditemePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_DITEM_E.COMPANIA, ES_DITEM_E.COD_DITEM, ES_DITEM_E.COD_ITEM, ES_DITEM_E.COD_ESTUDIO, ES_DITEM_E.ELEMENTO, ES_DITEM_E.DEPENDENCIA , ES_DITEM_E.ESPECIFICACION, ES_DITEM_E.CANTIDAD, ES_DITEM_E.CANTIDADAPROBADA, ES_DITEM_E.CANTIDADPORENTREGAR, ES_DITEM_E.VALORUNITARIO, ES_DITEM_E.PORCIVA, ES_DITEM_E.PORCDESCUENTO, ES_DITEM_E.VLRTOTAL, ES_DITEM_E.VLRAPROBADO, ES_DITEM_E.VACIA,(CASE ES_DITEM_E.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG, ES_DITEM_E.SELECCIONADA, ES_DITEM_E.OBSERVACIONES, ES_DITEM_E.NSOLICITUDDISPON, ES_DITEM_E.CONCEPTO, ES_DITEM_E.PLACA, ES_DITEM_E.SUBTOTAL, ES_DITEM_E.CREATED_BY, ES_DITEM_E.MODIFIED_BY,(TO_CHAR(ES_DITEM_E.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(ES_DITEM_E.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ES_DITEM_E.ADMINISTRACION, ES_DITEM_E.IMPREVISTOS, ES_DITEM_E.UTILIDADES, ES_DITEM_E.CODIGOCUBS  FROM ES_DITEM_E INNER JOIN INVENTARIO ON ES_DITEM_E.ELEMENTO = INVENTARIO.CODIGOELEMENTO AND ES_DITEM_E.COMPANIA = INVENTARIO.COMPANIA WHERE ES_DITEM_E.COMPANIA = :COMPANIA AND ES_DITEM_E.COD_ITEM = :CODIGOITEM AND ES_DITEM_E.COD_ESTUDIO= :CODIGOESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_DITEM":"$COD_DITEM","COD_ITEM":"$COD_ITEM","COD_ESTUDIO":"$COD_ESTUDIO","ELEMENTO":"$ELEMENTO","DEPENDENCIA":"$DEPENDENCIA","ESPECIFICACION":"$ESPECIFICACION","CANTIDAD":"$CANTIDAD","CANTIDADAPROBADA":"$CANTIDADAPROBADA","CANTIDADPORENTREGAR":"$CANTIDADPORENTREGAR","VALORUNITARIO":"$VALORUNITARIO","PORCIVA":"$PORCIVA","PORCDESCUENTO":"$PORCDESCUENTO","VLRTOTAL":"$VLRTOTAL","VLRAPROBADO":"$VLRAPROBADO","VACIA":"$VACIA","IND_REG":"$IND_REG(type:boolean)","SELECCIONADA":"$SELECCIONADA","OBSERVACIONES":"$OBSERVACIONES","NSOLICITUDDISPON":"$NSOLICITUDDISPON","CONCEPTO":"$CONCEPTO","PLACA":"$PLACA","SUBTOTAL":"$SUBTOTAL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","ADMINISTRACION":"$ADMINISTRACION","IMPREVISTOS":"$IMPREVISTOS","UTILIDADES":"$UTILIDADES","CODIGOCUBS":"$CODIGOCUBS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOITEM" sqlType="STRING"/>
		<param name="CODIGOESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esditeme">
		<call-query href="getEsditemePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOITEM" query-param="CODIGOITEM"/>
			<with-param name="CODIGOESTUDIO" query-param="CODIGOESTUDIO"/>

		</call-query>
	</resource>
	<query id="updateEsditeme" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_DITEM_E SET COMPANIA=:COMPANIA, COD_DITEM=:COD_DITEM, COD_ITEM=:COD_ITEM, COD_ESTUDIO=:COD_ESTUDIO, ELEMENTO=:ELEMENTO, DEPENDENCIA=:DEPENDENCIA, ESPECIFICACION=:ESPECIFICACION, CANTIDAD=:CANTIDAD, CANTIDADAPROBADA=:CANTIDADAPROBADA, CANTIDADPORENTREGAR=:CANTIDADPORENTREGAR, VALORUNITARIO=:VALORUNITARIO, PORCIVA=:PORCIVA, PORCDESCUENTO=:PORCDESCUENTO, VLRTOTAL=:VLRTOTAL, VLRAPROBADO=:VLRAPROBADO, VACIA=:VACIA, IND_REG=:IND_REG, SELECCIONADA=:SELECCIONADA, OBSERVACIONES=:OBSERVACIONES, NSOLICITUDDISPON=:NSOLICITUDDISPON, CONCEPTO=:CONCEPTO, PLACA=:PLACA, SUBTOTAL=:SUBTOTAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), ADMINISTRACION=:ADMINISTRACION, IMPREVISTOS=:IMPREVISTOS, UTILIDADES=:UTILIDADES, CODIGOCUBS=:CODIGOCUBS WHERE ES_DITEM_E.COMPANIA= :KEY_COMPANIA AND ES_DITEM_E.COD_DITEM= :KEY_COD_DITEM AND ES_DITEM_E.COD_ITEM= :KEY_COD_ITEM AND ES_DITEM_E.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_DITEM" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="CANTIDADAPROBADA" sqlType="STRING"/>
		<param name="CANTIDADPORENTREGAR" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="PORCDESCUENTO" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="VLRAPROBADO" sqlType="STRING"/>
		<param name="VACIA" sqlType="STRING"/>
		<param name="IND_REG" sqlType="STRING"/>
		<param name="SELECCIONADA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NSOLICITUDDISPON" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="SUBTOTAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="ADMINISTRACION" sqlType="STRING"/>
		<param name="IMPREVISTOS" sqlType="STRING"/>
		<param name="UTILIDADES" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_DITEM" sqlType="STRING"/>
		<param name="KEY_COD_ITEM" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esditeme">
		<call-query href="updateEsditeme">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_DITEM" query-param="COD_DITEM"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="CANTIDADAPROBADA" query-param="CANTIDADAPROBADA"/>
			<with-param name="CANTIDADPORENTREGAR" query-param="CANTIDADPORENTREGAR"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESCUENTO" query-param="PORCDESCUENTO"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="VLRAPROBADO" query-param="VLRAPROBADO"/>
			<with-param name="VACIA" query-param="VACIA"/>
			<with-param name="IND_REG" query-param="IND_REG"/>
			<with-param name="SELECCIONADA" query-param="SELECCIONADA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NSOLICITUDDISPON" query-param="NSOLICITUDDISPON"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="SUBTOTAL" query-param="SUBTOTAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="ADMINISTRACION" query-param="ADMINISTRACION"/>
			<with-param name="IMPREVISTOS" query-param="IMPREVISTOS"/>
			<with-param name="UTILIDADES" query-param="UTILIDADES"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_DITEM" query-param="KEY_COD_DITEM"/>
			<with-param name="KEY_COD_ITEM" query-param="KEY_COD_ITEM"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>

</data>