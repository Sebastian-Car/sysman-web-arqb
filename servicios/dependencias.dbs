	<query id="getDependenciasPagPorCompaniaYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPENDENCIA.CODIGO CODIGODEPENDENCIA, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA INNER JOIN PLAN_DE_COMPRAS ON DEPENDENCIA.CODIGO = PLAN_DE_COMPRAS.DEPENDENCIA AND DEPENDENCIA.COMPANIA = PLAN_DE_COMPRAS.COMPANIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.MOVIMIENTO &lt;&gt; 0 AND DEPENDENCIA.ACTIVO NOT IN (0) AND PLAN_DE_COMPRAS.CODIGO = :CODIGO GROUP BY DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE, DEPENDENCIA.MOVIMIENTO, DEPENDENCIA.ACTIVO, PLAN_DE_COMPRAS.CODIGO) WHERE (CASE WHEN CODIGODEPENDENCIA IS NULL THEN ' ' ELSE UPPER(CODIGODEPENDENCIA) END)  LIKE UPPER(:CODIGODEPENDENCIA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGODEPENDENCIA":"$CODIGODEPENDENCIA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGODEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
