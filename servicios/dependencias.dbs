	<query id="getDependenciasPagPorVerbancoYMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  'T' COD, 'TODAS' NOM  FROM DEPENDENCIA UNION SELECT DISTINCT DEPENDENCIA.CODIGO COD, DEPENDENCIA.NOMBRE NOM FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.VERBANCO &lt;&gt; 0 AND DEPENDENCIA.MOVIMIENTO &lt;&gt; 0 ORDER BY COD) WHERE (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END)  LIKE UPPER(:COD || '%')  AND (CASE WHEN NOM IS NULL THEN ' ' ELSE UPPER(NOM) END)  LIKE UPPER( '%' || :NOM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD":"$COD","NOM":"$NOM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="NOM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
