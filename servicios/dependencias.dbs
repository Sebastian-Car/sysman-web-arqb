		</call-query>
	</resource>
	<query id="getDependenciasGetdependenciasporcompaniaanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DEPENDENCIA.COMPANIA, DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE,(CASE DEPENDENCIA.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, CENTRO_COSTO.CODIGO CC_CODIGO, CENTRO_COSTO.NOMBRE NOMCENTROCOSTO,(CASE DEPENDENCIA.VERSOLICITUD WHEN 0 THEN 'false' ELSE 'true' END) VERSOLICITUD FROM DEPENDENCIA INNER JOIN CENTRO_COSTO ON DEPENDENCIA.COMPANIA = CENTRO_COSTO.COMPANIA AND DEPENDENCIA.CENTRODECOSTO = CENTRO_COSTO.CODIGO WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO ORDER BY DEPENDENCIA.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","CC_CODIGO":"$CC_CODIGO","NOMCENTROCOSTO":"$NOMCENTROCOSTO","VERSOLICITUD":"$VERSOLICITUD(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/getdependenciasporcompaniaano">
		<call-query href="getDependenciasGetdependenciasporcompaniaanoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDependenciasXcompaniamovsiglaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO, NOMBRE,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, SIGLA, CENTRODECOSTO,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,(CASE VERBANCO WHEN 0 THEN 'false' ELSE 'true' END) VERBANCO FROM DEPENDENCIA WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","SIGLA":"$SIGLA","CENTRODECOSTO":"$CENTRODECOSTO","ACTIVO":"$ACTIVO(type:boolean)","VERBANCO":"$VERBANCO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/xcompaniamovsigla">
		<call-query href="getDependenciasXcompaniamovsiglaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getDependenciasMancompaniadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE MAN_COMPANIADES WHEN 0 THEN 'false' ELSE 'true' END) MAN_COMPANIADES, COMP_DESTINO, MOV_DESTINO FROM DEPENDENCIA WHERE COMPANIA = :COMPANIA AND CODIGO = :DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MAN_COMPANIADES":"$MAN_COMPANIADES(type:boolean)","COMP_DESTINO":"$COMP_DESTINO","MOV_DESTINO":"$MOV_DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/mancompaniades">
		<call-query href="getDependenciasMancompaniadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>

</data>