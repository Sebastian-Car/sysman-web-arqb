	<query id="getDependenciasPagJefesDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ROWNUM, DP.CODIGO DEPENDENCIA, DP.NOMBRE NOMBREDEPENDENCIA, DPR.RESPONSABLE, DPR.SUCURSAL SUCURSAL_RESPONSABLE, TT.NOMBRE NOMBRE_RESPONSABLE  FROM DEPENDENCIA DP INNER JOIN DEPENDENCIA_RESPONSABLE DPR ON DPR.COMPANIA = DP.COMPANIA AND DPR.DEPENDENCIA = DP.CODIGO INNER JOIN RESPONSABLE R ON R.COMPANIA = DPR.COMPANIA AND R.CEDULA = DPR.RESPONSABLE AND R.SUCURSAL = DPR.SUCURSAL INNER JOIN TERCERO TT ON R.COMPANIA = TT.COMPANIA AND R.CEDULA = TT.NIT AND R.SUCURSAL = TT.SUCURSAL WHERE DP.COMPANIA = :COMPANIA AND DPR.JEFEUNIDAD NOT IN (0)) WHERE (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN NOMBREDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBREDEPENDENCIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESPONSABLE) END)  LIKE UPPER( '%' || :NOMBRE_RESPONSABLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ROWNUM":"$ROWNUM(type:integer)","DEPENDENCIA":"$DEPENDENCIA","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL_RESPONSABLE":"$SUCURSAL_RESPONSABLE","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBREDEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE_RESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependencias/jefesdependencia/pag">
		<call-query href="getDependenciasPagJefesDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMBREDEPENDENCIA" query-param="NOMBREDEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE_RESPONSABLE" query-param="NOMBRE_RESPONSABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasNumJefesDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ROWNUM, DP.CODIGO DEPENDENCIA, DP.NOMBRE NOMBREDEPENDENCIA, DPR.RESPONSABLE, DPR.SUCURSAL SUCURSAL_RESPONSABLE, TT.NOMBRE NOMBRE_RESPONSABLE  FROM DEPENDENCIA DP INNER JOIN DEPENDENCIA_RESPONSABLE DPR ON DPR.COMPANIA = DP.COMPANIA AND DPR.DEPENDENCIA = DP.CODIGO INNER JOIN RESPONSABLE R ON R.COMPANIA = DPR.COMPANIA AND R.CEDULA = DPR.RESPONSABLE AND R.SUCURSAL = DPR.SUCURSAL INNER JOIN TERCERO TT ON R.COMPANIA = TT.COMPANIA AND R.CEDULA = TT.NIT AND R.SUCURSAL = TT.SUCURSAL WHERE DP.COMPANIA = :COMPANIA AND DPR.JEFEUNIDAD NOT IN (0)) WHERE (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN NOMBREDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBREDEPENDENCIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESPONSABLE) END)  LIKE UPPER( '%' || :NOMBRE_RESPONSABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBREDEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE_RESPONSABLE" sqlType="STRING"/>

	</query>
