	<query id="getDependenciasNumTodosPorCompaniaDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  RESPONSABLE.CEDULA, TERCERO.NOMBRE, RESPONSABLE.CARGO, RESPONSABLE.SUCURSAL  FROM DEPENDENCIA INNER JOIN (RESPONSABLE INNER JOIN DEPENDENCIA_RESPONSABLE ON RESPONSABLE.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND RESPONSABLE.CEDULA = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND RESPONSABLE.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL) ON DEPENDENCIA.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND DEPENDENCIA.CODIGO = DEPENDENCIA_RESPONSABLE.DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.CODIGO = :DEPENDENCIA) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
