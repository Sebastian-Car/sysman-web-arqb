	<query id="getDependenciasResponsableJefeUnidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE, DEPENDENCIA_RESPONSABLE.RESPONSABLE, DEPENDENCIA_RESPONSABLE.SUCURSAL,(CASE DEPENDENCIA.PRINCIPAL WHEN 0 THEN 'false' ELSE 'true' END) PRINCIPAL FROM DEPENDENCIA INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND DEPENDENCIA.CODIGO = DEPENDENCIA_RESPONSABLE.DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.JEFEUNIDAD NOT IN (0) AND DEPENDENCIA.MOVIMIENTO NOT IN (0) AND DEPENDENCIA.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","PRINCIPAL":"$PRINCIPAL(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/responsablejefeunidad">
		<call-query href="getDependenciasResponsableJefeUnidadQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getDependenciasNombreDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE  FROM DEPENDENCIA WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND MOVIMIENTO NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/nombredependencia">
		<call-query href="getDependenciasNombreDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getDependenciasPagTodosPorCompaniaYCodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CODIGO, NOMBRE  FROM DEPENDENCIA INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND DEPENDENCIA.CODIGO = DEPENDENCIA_RESPONSABLE.DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.MOVIMIENTO NOT IN(0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
