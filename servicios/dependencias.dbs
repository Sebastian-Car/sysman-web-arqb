	<query id="getDependenciasDependenciasporclasebodegapredecesorQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASE_BODEGA, CODIGO, NOMBRE FROM DEPENDENCIA WHERE COMPANIA = :COMPANIA AND INSTR(CASE WHEN :CLASE_BODEGA IN('70')THEN PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS('30,70') WHEN :CLASE_BODEGA IN('80','90')THEN PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS('80,90') ELSE CASE WHEN :CLASE_BODEGA IN('40','50','60')THEN CLASE_BODEGA ELSE :CLASE_BODEGA END END,CLASE_BODEGA,1)&gt; 0 AND PREDECESOR = :PREDECESOR ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASE_BODEGA":"$CLASE_BODEGA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/dependenciasporclasebodegapredecesor">
		<call-query href="getDependenciasDependenciasporclasebodegapredecesorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>

		</call-query>
	</resource>
