<data name="dependencias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDependenciasNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE  FROM DEPENDENCIA WHERE COMPANIA = :COMPANIA AND CODIGO = :DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/nombre">
		<call-query href="getDependenciasNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getDependenciasPagCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO,NOMBRE  FROM DEPENDENCIA WHERE COMPANIA= :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependencias/compania/pag">
		<call-query href="getDependenciasPagCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasNumCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO,NOMBRE  FROM DEPENDENCIA WHERE COMPANIA= :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/compania/num">
		<call-query href="getDependenciasNumCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getDependenciasPorCompaniaMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.MOVIMIENTO NOT IN(0) ORDER BY DEPENDENCIA.NOMBRE, DEPENDENCIA.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/porcompaniamovimiento">
		<call-query href="getDependenciasPorCompaniaMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getDependenciasPagTodosMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND MOVIMIENTO NOT IN (0) ORDER BY DEPENDENCIA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependencias/todosmovimiento/pag">
		<call-query href="getDependenciasPagTodosMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasNumTodosMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND MOVIMIENTO NOT IN (0) ORDER BY DEPENDENCIA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/todosmovimiento/num">
		<call-query href="getDependenciasNumTodosMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getDependenciasPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA ORDER BY DEPENDENCIA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependencias/todosporcompania/pag">
		<call-query href="getDependenciasPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA ORDER BY DEPENDENCIA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/todosporcompania/num">
		<call-query href="getDependenciasNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getDependenciasPagTodosPorCompaniaDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  RESPONSABLE.CEDULA, TERCERO.NOMBRE, RESPONSABLE.CARGO, RESPONSABLE.SUCURSAL  FROM DEPENDENCIA INNER JOIN (RESPONSABLE INNER JOIN DEPENDENCIA_RESPONSABLE ON RESPONSABLE.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND RESPONSABLE.CEDULA = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND RESPONSABLE.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL) ON DEPENDENCIA.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND DEPENDENCIA.CODIGO = DEPENDENCIA_RESPONSABLE.DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.CODIGO = :DEPENDENCIA) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CEDULA":"$CEDULA","NOMBRE":"$NOMBRE","CARGO":"$CARGO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependencias/todosporcompaniadependencia/pag">
		<call-query href="getDependenciasPagTodosPorCompaniaDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertDependencias" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DEPENDENCIA (COMPANIA, VERSOLICITUD, CODIGO, NOMBRE, MOVIMIENTO, SIGLA, CENTRODECOSTO, COMODATO, ACTIVO, VERBANCO, CREATED_BY, DATE_CREATED, PERMITE_VISITA, CLASE_BODEGA, CGR_DEPENDENCIA, CODIGO_EQUIVALENTE, PREDECESOR, MAN_PREDECESOR, GESTION_DOCUMENTAL, MAN_COMPANIADES, COMP_DESTINO, MOV_DESTINO) VALUES (:COMPANIA, :VERSOLICITUD, :CODIGO, :NOMBRE, :MOVIMIENTO, :SIGLA, :CENTRODECOSTO, :COMODATO, :ACTIVO, :VERBANCO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :PERMITE_VISITA, :CLASE_BODEGA, :CGR_DEPENDENCIA, :CODIGO_EQUIVALENTE, :PREDECESOR, :MAN_PREDECESOR, :GESTION_DOCUMENTAL, :MAN_COMPANIADES, :COMP_DESTINO, :MOV_DESTINO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="VERSOLICITUD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="SIGLA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRODECOSTO" sqlType="STRING"/>
		<param defaultValue="0" name="COMODATO" sqlType="STRING"/>
		<param defaultValue="0" name="ACTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="VERBANCO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="PERMITE_VISITA" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_BODEGA" sqlType="STRING"/>
		<param defaultValue="" name="CGR_DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_EQUIVALENTE" sqlType="STRING"/>
		<param defaultValue="" name="PREDECESOR" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_PREDECESOR" sqlType="STRING"/>
		<param defaultValue="0" name="GESTION_DOCUMENTAL" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_COMPANIADES" sqlType="STRING"/>
		<param defaultValue="" name="COMP_DESTINO" sqlType="STRING"/>
		<param defaultValue="" name="MOV_DESTINO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dependencias">
		<call-query href="insertDependencias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSOLICITUD" query-param="VERSOLICITUD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="CENTRODECOSTO" query-param="CENTRODECOSTO"/>
			<with-param name="COMODATO" query-param="COMODATO"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="VERBANCO" query-param="VERBANCO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="PERMITE_VISITA" query-param="PERMITE_VISITA"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="CGR_DEPENDENCIA" query-param="CGR_DEPENDENCIA"/>
			<with-param name="CODIGO_EQUIVALENTE" query-param="CODIGO_EQUIVALENTE"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>
			<with-param name="MAN_PREDECESOR" query-param="MAN_PREDECESOR"/>
			<with-param name="GESTION_DOCUMENTAL" query-param="GESTION_DOCUMENTAL"/>
			<with-param name="MAN_COMPANIADES" query-param="MAN_COMPANIADES"/>
			<with-param name="COMP_DESTINO" query-param="COMP_DESTINO"/>
			<with-param name="MOV_DESTINO" query-param="MOV_DESTINO"/>

		</call-query>
	</resource>
	<query id="deleteDependencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA= :KEY_COMPANIA AND DEPENDENCIA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dependencias">
		<call-query href="deleteDependencias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getDependenciasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DEPENDENCIA.COMPANIA, DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE,(CASE DEPENDENCIA.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, CENTRO_COSTO.NOMBRE NOMCENTROCOSTO,(CASE DEPENDENCIA.VERSOLICITUD WHEN 0 THEN 'false' ELSE 'true' END) VERSOLICITUD FROM DEPENDENCIA INNER JOIN CENTRO_COSTO ON DEPENDENCIA.COMPANIA = CENTRO_COSTO.COMPANIA AND DEPENDENCIA.CENTRODECOSTO = CENTRO_COSTO.CODIGO WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO ORDER BY DEPENDENCIA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MOVIMIENTO), '%')) AND (CASE WHEN NOMCENTROCOSTO IS NULL THEN ' ' ELSE UPPER(NOMCENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMCENTROCOSTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","NOMCENTROCOSTO":"$NOMCENTROCOSTO","VERSOLICITUD":"$VERSOLICITUD(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="NOMCENTROCOSTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependencias">
		<call-query href="getDependenciasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="NOMCENTROCOSTO" query-param="NOMCENTROCOSTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEPENDENCIA.COMPANIA, DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE,(CASE DEPENDENCIA.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, CENTRO_COSTO.NOMBRE NOMCENTROCOSTO,(CASE DEPENDENCIA.VERSOLICITUD WHEN 0 THEN 'false' ELSE 'true' END) VERSOLICITUD FROM DEPENDENCIA INNER JOIN CENTRO_COSTO ON DEPENDENCIA.COMPANIA = CENTRO_COSTO.COMPANIA AND DEPENDENCIA.CENTRODECOSTO = CENTRO_COSTO.CODIGO WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO ORDER BY DEPENDENCIA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MOVIMIENTO), '%')) AND (CASE WHEN NOMCENTROCOSTO IS NULL THEN ' ' ELSE UPPER(NOMCENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMCENTROCOSTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="NOMCENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/numero">
		<call-query href="getDependenciasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="NOMCENTROCOSTO" query-param="NOMCENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="getDependenciasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,(CASE VERSOLICITUD WHEN 0 THEN 'false' ELSE 'true' END) VERSOLICITUD, NOMBRE,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, SIGLA, CENTRODECOSTO,(CASE COMODATO WHEN 0 THEN 'false' ELSE 'true' END) COMODATO,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,(CASE VERBANCO WHEN 0 THEN 'false' ELSE 'true' END) VERBANCO, CLASE_BODEGA, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE PERMITE_VISITA WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_VISITA, CGR_DEPENDENCIA, cODIGO_EQUIVALENTE, PREDECESOR,(CASE MAN_PREDECESOR WHEN 0 THEN 'false' ELSE 'true' END) MAN_PREDECESOR,(CASE GESTION_DOCUMENTAL WHEN 0 THEN 'false' ELSE 'true' END) GESTION_DOCUMENTAL,(CASE MAN_COMPANIADES WHEN 0 THEN 'false' ELSE 'true' END) MAN_COMPANIADES, COMP_DESTINO, MOV_DESTINO FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA= :KEY_COMPANIA AND DEPENDENCIA.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","VERSOLICITUD":"$VERSOLICITUD(type:boolean)","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","SIGLA":"$SIGLA","CENTRODECOSTO":"$CENTRODECOSTO","COMODATO":"$COMODATO(type:boolean)","ACTIVO":"$ACTIVO(type:boolean)","VERBANCO":"$VERBANCO(type:boolean)","CLASE_BODEGA":"$CLASE_BODEGA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","PERMITE_VISITA":"$PERMITE_VISITA(type:boolean)","CGR_DEPENDENCIA":"$CGR_DEPENDENCIA","CODIGO_EQUIVALENTE":"$CODIGO_EQUIVALENTE","PREDECESOR":"$PREDECESOR","MAN_PREDECESOR":"$MAN_PREDECESOR(type:boolean)","GESTION_DOCUMENTAL":"$GESTION_DOCUMENTAL(type:boolean)","MAN_COMPANIADES":"$MAN_COMPANIADES(type:boolean)","COMP_DESTINO":"$COMP_DESTINO","MOV_DESTINO":"$MOV_DESTINO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/data">
		<call-query href="getDependenciasRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateDependencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEPENDENCIA SET CODIGO=:CODIGO, VERSOLICITUD=:VERSOLICITUD, NOMBRE=:NOMBRE, MOVIMIENTO=:MOVIMIENTO, SIGLA=:SIGLA, CENTRODECOSTO=:CENTRODECOSTO, COMODATO=:COMODATO, ACTIVO=:ACTIVO, VERBANCO=:VERBANCO, CLASE_BODEGA=:CLASE_BODEGA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), PERMITE_VISITA=:PERMITE_VISITA, CGR_DEPENDENCIA=:CGR_DEPENDENCIA, CODIGO_EQUIVALENTE=:CODIGO_EQUIVALENTE, PREDECESOR=:PREDECESOR, MAN_PREDECESOR=:MAN_PREDECESOR, GESTION_DOCUMENTAL=:GESTION_DOCUMENTAL, MAN_COMPANIADES=:MAN_COMPANIADES, COMP_DESTINO=:COMP_DESTINO, MOV_DESTINO=:MOV_DESTINO WHERE DEPENDENCIA.COMPANIA= :KEY_COMPANIA AND DEPENDENCIA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="VERSOLICITUD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="CENTRODECOSTO" sqlType="STRING"/>
		<param name="COMODATO" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="VERBANCO" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PERMITE_VISITA" sqlType="STRING"/>
		<param name="CGR_DEPENDENCIA" sqlType="STRING"/>
		<param name="CODIGO_EQUIVALENTE" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>
		<param name="MAN_PREDECESOR" sqlType="STRING"/>
		<param name="GESTION_DOCUMENTAL" sqlType="STRING"/>
		<param name="MAN_COMPANIADES" sqlType="STRING"/>
		<param name="COMP_DESTINO" sqlType="STRING"/>
		<param name="MOV_DESTINO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dependencias">
