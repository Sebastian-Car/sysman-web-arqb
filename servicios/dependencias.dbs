	</resource>
	<query id="getDependenciasNumPorVerbancoYMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  'T' COD, 'TODAS' NOM  FROM DEPENDENCIA UNION SELECT DISTINCT DEPENDENCIA.CODIGO COD, DEPENDENCIA.NOMBRE NOM FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.VERBANCO &lt;&gt; 0 AND DEPENDENCIA.MOVIMIENTO &lt;&gt; 0 ORDER BY COD) WHERE (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END)  LIKE UPPER(:COD || '%')  AND (CASE WHEN NOM IS NULL THEN ' ' ELSE UPPER(NOM) END)  LIKE UPPER( '%' || :NOM || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="NOM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependencias/porverbancoymovimiento/num">
		<call-query href="getDependenciasNumPorVerbancoYMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD" query-param="COD"/>
			<with-param name="NOM" query-param="NOM"/>

		</call-query>
	</resource>
	<query id="getDependenciasPagCodNomPorCiaConMovQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.MOVIMIENTO &lt;&gt; 0 UNION SELECT 'Todas' COD, 'Todas' NOM FROM DEPENDENCIA ORDER BY 1 DESC) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
