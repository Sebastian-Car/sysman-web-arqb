	<query id="getDependenciasPagGrillaDependenciabienesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPENDENCIA.COMPANIA, DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE, DEPENDENCIA.FACTOR_RIESGO, NAT_RIESGO_LABORAL.NOMBRE NOMBRE_RIESGO  FROM DEPENDENCIA LEFT JOIN NAT_RIESGO_LABORAL ON DEPENDENCIA.COMPANIA = NAT_RIESGO_LABORAL.COMPANIA AND DEPENDENCIA.FACTOR_RIESGO= NAT_RIESGO_LABORAL.ID_RIESGO WHERE DEPENDENCIA.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRE_RIESGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RIESGO) END)  LIKE UPPER( '%' || :NOMBRE_RIESGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FACTOR_RIESGO":"$FACTOR_RIESGO","NOMBRE_RIESGO":"$NOMBRE_RIESGO"}]}}		</result>
