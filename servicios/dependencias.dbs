	<query id="updateDependenciasUpdatedependencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEPENDENCIA SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, MOVIMIENTO=:MOVIMIENTO, SIGLA=:SIGLA, CENTRODECOSTO=:CENTRODECOSTO, COMODATO=:COMODATO, ACTIVO=:ACTIVO, VERBANCO=:VERBANCO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), PERMITE_VISITA=:PERMITE_VISITA, CGR_DEPENDENCIA=:CGR_DEPENDENCIA, VERSOLICITUD=:VERSOLICITUD, GESTION_DOCUMENTAL=:GESTION_DOCUMENTAL, MAN_COMPANIADES=:MAN_COMPANIADES, COMP_DESTINO=:COMP_DESTINO, MOV_DESTINO=:MOV_DESTINO WHERE DEPENDENCIA.COMPANIA= :KEY_COMPANIA AND DEPENDENCIA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="CENTRODECOSTO" sqlType="STRING"/>
		<param name="COMODATO" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="VERBANCO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PERMITE_VISITA" sqlType="STRING"/>
		<param name="CGR_DEPENDENCIA" sqlType="STRING"/>
		<param name="VERSOLICITUD" sqlType="STRING"/>
		<param name="GESTION_DOCUMENTAL" sqlType="STRING"/>
		<param name="MAN_COMPANIADES" sqlType="STRING"/>
		<param name="COMP_DESTINO" sqlType="STRING"/>
		<param name="MOV_DESTINO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
