	<query id="getDependenciasPorClaseBodegaValidaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASE_BODEGA, CODIGO, NOMBRE, PREDECESOR FROM DEPENDENCIA WHERE COMPANIA =:COMPANIA AND INSTR(CASE WHEN :CLASE_BODEGA IN('70') THEN PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS('30,70') WHEN :CLASE_BODEGA IN('80','90') THEN PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS('80,90') WHEN :CLASE_BODEGA IN('40','50') THEN PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS('40,50') ELSE CASE WHEN :CLASE_BODEGA IN('60') THEN CLASE_BODEGA ELSE :CLASE_BODEGA END END,CLASE_BODEGA,1) &gt; 0 ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASE_BODEGA":"$CLASE_BODEGA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PREDECESOR":"$PREDECESOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>

	</query>
