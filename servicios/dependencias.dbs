		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND CODIGO IN (SELECT DEPENDENCIA FROM PERSONAL INNER JOIN RESPONSABLE ON PERSONAL.COMPANIA = RESPONSABLE.COMPANIA AND PERSONAL.NUMERO_DCTO = RESPONSABLE.CEDULA INNER JOIN ESCALAFON ON ESCALAFON.COMPANIA = PERSONAL.COMPANIA AND ESCALAFON.CODIGO = PERSONAL.ESCALAFON WHERE PERSONAL.COMPANIA = :COMPANIA AND RESPONSABLE.ACTIVO NOT IN (0) AND ESCALAFON.CODIGO = '00' )) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
