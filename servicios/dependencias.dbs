	<query id="getDependenciasTodosPorCompacodQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPENDENCIA_RESPONSABLE.RESPONSABLE, TERCERO.NOMBRE, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND DEPENDENCIA.CODIGO = DEPENDENCIA_RESPONSABLE.DEPENDENCIA INNER JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLE.SUCURSAL INNER JOIN TERCERO ON TERCERO.COMPANIA = RESPONSABLE.COMPANIA AND TERCERO.NIT = RESPONSABLE.CEDULA AND TERCERO.SUCURSAL = RESPONSABLE.SUCURSAL WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
