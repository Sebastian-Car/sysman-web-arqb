	<query id="getDependenciasPagActivasConResponsablesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE  FROM DEPENDENCIA INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND DEPENDENCIA.CODIGO = DEPENDENCIA_RESPONSABLE.DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND DEPENDENCIA.ACTIVO NOT IN (0) GROUP BY DEPENDENCIA.CODIGO, DEPENDENCIA.NOMBRE ORDER BY 1) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
