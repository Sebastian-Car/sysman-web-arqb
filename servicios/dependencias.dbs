		<sql>SELECT  DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA  FROM DEPENDENCIA INNER JOIN NAT_APERTURA ON DEPENDENCIA.COMPANIA = NAT_APERTURA.COMPANIA AND DEPENDENCIA.CODIGO = NAT_APERTURA.DEPENDENCIA WHERE NAT_APERTURA.COMPANIA = :COMPANIA AND NAT_APERTURA.NRO_CONVOCATORIA = :NRO_CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA"}]}}		</result>
