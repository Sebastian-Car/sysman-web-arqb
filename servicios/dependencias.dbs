	<query id="updateDependenciasActualDependenciabienes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEPENDENCIA SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, FACTOR_RIESGO=:FACTOR_RIESGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEPENDENCIA.COMPANIA= :KEY_COMPANIA AND DEPENDENCIA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
