	<query id="getDependenciasPagCodNomEsc00ActivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM DEPENDENCIA WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND CODIGO IN (SELECT DEPENDENCIA FROM PERSONAL INNER JOIN RESPONSABLE ON PERSONAL.COMPANIA = RESPONSABLE.COMPANIA AND PERSONAL.NUMERO_DCTO = RESPONSABLE.CEDULA INNER JOIN ESCALAFON ON ESCALAFON.COMPANIA = PERSONAL.COMPANIA AND ESCALAFON.CODIGO = PERSONAL.ESCALAFON WHERE PERSONAL.COMPANIA = :COMPANIA AND RESPONSABLE.ACTIVO NOT IN (0) AND ESCALAFON.CODIGO = '00' )) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
