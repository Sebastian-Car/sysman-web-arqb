<data name="gnabancoaplicacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getGnabancoaplicacionPagPorcompaniayaplicacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  GNBA.BANCO, BANCO.NOMBREBANCO  FROM GN_BANCO_APLICACION GNBA INNER JOIN BANCO ON GNBA.COMPANIA = BANCO.COMPANIA AND GNBA.BANCO = BANCO.BANCO WHERE GNBA.COMPANIA = :COMPANIA AND GNBA.APLICACION = :APLICACION) WHERE (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END)  LIKE UPPER( '%' || :BANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BANCO":"$BANCO","NOMBREBANCO":"$NOMBREBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="gnabancoaplicacion/porcompaniayaplicacion/pag">
		<call-query href="getGnabancoaplicacionPagPorcompaniayaplicacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getGnabancoaplicacionNumPorcompaniayaplicacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  GNBA.BANCO, BANCO.NOMBREBANCO  FROM GN_BANCO_APLICACION GNBA INNER JOIN BANCO ON GNBA.COMPANIA = BANCO.COMPANIA AND GNBA.BANCO = BANCO.BANCO WHERE GNBA.COMPANIA = :COMPANIA AND GNBA.APLICACION = :APLICACION) WHERE (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END)  LIKE UPPER( '%' || :BANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="gnabancoaplicacion/porcompaniayaplicacion/num">
		<call-query href="getGnabancoaplicacionNumPorcompaniayaplicacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>

		</call-query>
	</resource>
	<query id="insertGnabancoaplicacion" keyColumns="COMPANIA,BANCO,APLICACION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO GN_BANCO_APLICACION (COMPANIA, BANCO, APLICACION, CUENTACONTABLE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :BANCO, :APLICACION, :CUENTACONTABLE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_BANCO":"$BANCO","KEY_APLICACION":"$APLICACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACONTABLE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="gnabancoaplicacion">
		<call-query href="insertGnabancoaplicacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="CUENTACONTABLE" query-param="CUENTACONTABLE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteGnabancoaplicacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM GN_BANCO_APLICACION WHERE GN_BANCO_APLICACION.COMPANIA= :KEY_COMPANIA AND GN_BANCO_APLICACION.BANCO= :KEY_BANCO AND GN_BANCO_APLICACION.APLICACION= :KEY_APLICACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_BANCO" sqlType="STRING"/>
		<param name="KEY_APLICACION" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="gnabancoaplicacion">
		<call-query href="deleteGnabancoaplicacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_BANCO" query-param="KEY_BANCO"/>
			<with-param name="KEY_APLICACION" query-param="KEY_APLICACION"/>

		</call-query>
	</resource>
	<query id="getGnabancoaplicacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  GN_BANCO_APLICACION.COMPANIA, GN_BANCO_APLICACION.BANCO, BANCO.NOMBREBANCO, APLICACION, CUENTACONTABLE  FROM GN_BANCO_APLICACION INNER JOIN BANCO ON BANCO.COMPANIA = GN_BANCO_APLICACION.COMPANIA AND BANCO.BANCO = GN_BANCO_APLICACION.BANCO WHERE GN_BANCO_APLICACION.COMPANIA = :COMPANIA AND APLICACION = :MODULO) WHERE (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN CUENTACONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTACONTABLE) END)  LIKE UPPER( '%' || :CUENTACONTABLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","BANCO":"$BANCO","NOMBREBANCO":"$NOMBREBANCO","APLICACION":"$APLICACION(type:integer)","CUENTACONTABLE":"$CUENTACONTABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="CUENTACONTABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="gnabancoaplicacion">
		<call-query href="getGnabancoaplicacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CUENTACONTABLE" query-param="CUENTACONTABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getGnabancoaplicacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  GN_BANCO_APLICACION.COMPANIA, GN_BANCO_APLICACION.BANCO, BANCO.NOMBREBANCO, APLICACION, CUENTACONTABLE  FROM GN_BANCO_APLICACION INNER JOIN BANCO ON BANCO.COMPANIA = GN_BANCO_APLICACION.COMPANIA AND BANCO.BANCO = GN_BANCO_APLICACION.BANCO WHERE GN_BANCO_APLICACION.COMPANIA = :COMPANIA AND APLICACION = :MODULO) WHERE (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN CUENTACONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTACONTABLE) END)  LIKE UPPER( '%' || :CUENTACONTABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="CUENTACONTABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="gnabancoaplicacion/numero">
		<call-query href="getGnabancoaplicacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CUENTACONTABLE" query-param="CUENTACONTABLE"/>

		</call-query>
	</resource>
	<query id="updateGnabancoaplicacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE GN_BANCO_APLICACION SET COMPANIA=:COMPANIA, BANCO=:BANCO, APLICACION=:APLICACION, CUENTACONTABLE=:CUENTACONTABLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE GN_BANCO_APLICACION.COMPANIA= :KEY_COMPANIA AND GN_BANCO_APLICACION.BANCO= :KEY_BANCO AND GN_BANCO_APLICACION.APLICACION= :KEY_APLICACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="CUENTACONTABLE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_BANCO" sqlType="STRING"/>
		<param name="KEY_APLICACION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="gnabancoaplicacion">
		<call-query href="updateGnabancoaplicacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="CUENTACONTABLE" query-param="CUENTACONTABLE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_BANCO" query-param="KEY_BANCO"/>
			<with-param name="KEY_APLICACION" query-param="KEY_APLICACION"/>

		</call-query>
	</resource>

</data>