<data name="sstmatrizriesgos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSstmatrizriesgosPagTodasPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_MATRIZ_RIESGOS.VERSION,(TO_CHAR(SST_MATRIZ_RIESGOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SST_MATRIZ_RIESGOS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, SST_MATRIZ_RIESGOS.ACTIVIDAD_ECONOMICA  FROM SST_MATRIZ_RIESGOS WHERE COMPANIA = :COMPANIA ORDER BY VERSION) WHERE (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VERSION":"$VERSION","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","ACTIVIDAD_ECONOMICA":"$ACTIVIDAD_ECONOMICA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstmatrizriesgos/todasporcompania/pag">
		<call-query href="getSstmatrizriesgosPagTodasPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstmatrizriesgosNumTodasPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_MATRIZ_RIESGOS.VERSION,(TO_CHAR(SST_MATRIZ_RIESGOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SST_MATRIZ_RIESGOS.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, SST_MATRIZ_RIESGOS.ACTIVIDAD_ECONOMICA  FROM SST_MATRIZ_RIESGOS WHERE COMPANIA = :COMPANIA ORDER BY VERSION) WHERE (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstmatrizriesgos/todasporcompania/num">
		<call-query href="getSstmatrizriesgosNumTodasPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>

		</call-query>
	</resource>
	<query id="insertSstmatrizriesgos" keyColumns="COMPANIA,VERSION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_MATRIZ_RIESGOS (COMPANIA, VERSION, TIEMPO, FECHA_INICIO, FECHA_FINAL, NOMBRE_ARL, ACTIVIDAD_ECONOMICA, FECHA_ELABORACION, FECHA_ACTUALIZACION, NUMERO_TRABAJADORES, ELABORACION, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :VERSION, :TIEMPO, TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), :NOMBRE_ARL, :ACTIVIDAD_ECONOMICA, TO_DATE(:FECHA_ELABORACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), :NUMERO_TRABAJADORES, :ELABORACION, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_VERSION":"$VERSION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param defaultValue="" name="TIEMPO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_ARL" sqlType="STRING"/>
		<param defaultValue="" name="ACTIVIDAD_ECONOMICA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ELABORACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param defaultValue="" name="NUMERO_TRABAJADORES" sqlType="STRING"/>
		<param defaultValue="" name="ELABORACION" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstmatrizriesgos">
		<call-query href="insertSstmatrizriesgos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIEMPO" query-param="TIEMPO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="NOMBRE_ARL" query-param="NOMBRE_ARL"/>
			<with-param name="ACTIVIDAD_ECONOMICA" query-param="ACTIVIDAD_ECONOMICA"/>
			<with-param name="FECHA_ELABORACION" query-param="FECHA_ELABORACION"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="NUMERO_TRABAJADORES" query-param="NUMERO_TRABAJADORES"/>
			<with-param name="ELABORACION" query-param="ELABORACION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSstmatrizriesgos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_MATRIZ_RIESGOS WHERE SST_MATRIZ_RIESGOS.COMPANIA= :KEY_COMPANIA AND SST_MATRIZ_RIESGOS.VERSION= :KEY_VERSION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sstmatrizriesgos">
		<call-query href="deleteSstmatrizriesgos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>

		</call-query>
	</resource>
	<query id="getSstmatrizriesgosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, VERSION,(TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, ACTIVIDAD_ECONOMICA  FROM SST_MATRIZ_RIESGOS WHERE COMPANIA =:COMPANIA) WHERE (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN ACTIVIDAD_ECONOMICA IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD_ECONOMICA) END)  LIKE UPPER( '%' || :ACTIVIDAD_ECONOMICA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VERSION":"$VERSION","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","ACTIVIDAD_ECONOMICA":"$ACTIVIDAD_ECONOMICA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="ACTIVIDAD_ECONOMICA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstmatrizriesgos">
		<call-query href="getSstmatrizriesgosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="ACTIVIDAD_ECONOMICA" query-param="ACTIVIDAD_ECONOMICA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstmatrizriesgosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, VERSION,(TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, ACTIVIDAD_ECONOMICA  FROM SST_MATRIZ_RIESGOS WHERE COMPANIA =:COMPANIA) WHERE (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN ACTIVIDAD_ECONOMICA IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD_ECONOMICA) END)  LIKE UPPER( '%' || :ACTIVIDAD_ECONOMICA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="ACTIVIDAD_ECONOMICA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstmatrizriesgos/numero">
		<call-query href="getSstmatrizriesgosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="ACTIVIDAD_ECONOMICA" query-param="ACTIVIDAD_ECONOMICA"/>

		</call-query>
	</resource>
	<query id="getSstmatrizriesgosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, VERSION, TIEMPO,(TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, NOMBRE_ARL, ACTIVIDAD_ECONOMICA,(TO_CHAR(FECHA_ELABORACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ELABORACION,(TO_CHAR(FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTUALIZACION, NUMERO_TRABAJADORES, ELABORACION, DESCRIPCION, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SST_MATRIZ_RIESGOS WHERE SST_MATRIZ_RIESGOS.COMPANIA= :KEY_COMPANIA AND SST_MATRIZ_RIESGOS.VERSION= :KEY_VERSION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VERSION":"$VERSION","TIEMPO":"$TIEMPO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","NOMBRE_ARL":"$NOMBRE_ARL","ACTIVIDAD_ECONOMICA":"$ACTIVIDAD_ECONOMICA","FECHA_ELABORACION":"$FECHA_ELABORACION","FECHA_ACTUALIZACION":"$FECHA_ACTUALIZACION","NUMERO_TRABAJADORES":"$NUMERO_TRABAJADORES(type:integer)","ELABORACION":"$ELABORACION","DESCRIPCION":"$DESCRIPCION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstmatrizriesgos/data">
		<call-query href="getSstmatrizriesgosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>

		</call-query>
	</resource>
	<query id="updateSstmatrizriesgos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_MATRIZ_RIESGOS SET COMPANIA=:COMPANIA, VERSION=:VERSION, TIEMPO=:TIEMPO, FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), NOMBRE_ARL=:NOMBRE_ARL, ACTIVIDAD_ECONOMICA=:ACTIVIDAD_ECONOMICA, FECHA_ELABORACION=TO_DATE(:FECHA_ELABORACION,'DD/MM/YYYY HH24:MI:SS'), FECHA_ACTUALIZACION=TO_DATE(:FECHA_ACTUALIZACION,'DD/MM/YYYY HH24:MI:SS'), NUMERO_TRABAJADORES=:NUMERO_TRABAJADORES, ELABORACION=:ELABORACION, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_MATRIZ_RIESGOS.COMPANIA= :KEY_COMPANIA AND SST_MATRIZ_RIESGOS.VERSION= :KEY_VERSION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="TIEMPO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="NOMBRE_ARL" sqlType="STRING"/>
		<param name="ACTIVIDAD_ECONOMICA" sqlType="STRING"/>
		<param name="FECHA_ELABORACION" sqlType="STRING"/>
		<param name="FECHA_ACTUALIZACION" sqlType="STRING"/>
		<param name="NUMERO_TRABAJADORES" sqlType="STRING"/>
		<param name="ELABORACION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstmatrizriesgos">
		<call-query href="updateSstmatrizriesgos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIEMPO" query-param="TIEMPO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="NOMBRE_ARL" query-param="NOMBRE_ARL"/>
			<with-param name="ACTIVIDAD_ECONOMICA" query-param="ACTIVIDAD_ECONOMICA"/>
			<with-param name="FECHA_ELABORACION" query-param="FECHA_ELABORACION"/>
			<with-param name="FECHA_ACTUALIZACION" query-param="FECHA_ACTUALIZACION"/>
			<with-param name="NUMERO_TRABAJADORES" query-param="NUMERO_TRABAJADORES"/>
			<with-param name="ELABORACION" query-param="ELABORACION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>

		</call-query>
	</resource>

</data>