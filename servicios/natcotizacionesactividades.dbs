<data name="natcotizacionesactividades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatcotizacionesactividadesPagNitnombreestablecimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CA.NITESTABLECIMIENTO , E.NOMBRE NOMBREESTABLECIMIENTO  FROM NAT_COTIZACIONESACTIVIDADES CA INNER JOIN TERCERO E ON CA.COMPANIA = E.COMPANIA AND CA.NITESTABLECIMIENTO = E.NIT AND CA.SUCURSAL = E.SUCURSAL WHERE CA.COMPANIA = :COMPANIA AND CA.IDEVENTO = :IDEVENTO AND CA.TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN NITESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NITESTABLECIMIENTO) END)  LIKE UPPER(:NITESTABLECIMIENTO || '%')  AND (CASE WHEN NOMBREESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBREESTABLECIMIENTO) END)  LIKE UPPER( '%' || :NOMBREESTABLECIMIENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NITESTABLECIMIENTO":"$NITESTABLECIMIENTO","NOMBREESTABLECIMIENTO":"$NOMBREESTABLECIMIENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="NOMBREESTABLECIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natcotizacionesactividades/nitnombreestablecimiento/pag">
		<call-query href="getNatcotizacionesactividadesPagNitnombreestablecimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NITESTABLECIMIENTO" query-param="NITESTABLECIMIENTO"/>
			<with-param name="NOMBREESTABLECIMIENTO" query-param="NOMBREESTABLECIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatcotizacionesactividadesNumNitnombreestablecimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CA.NITESTABLECIMIENTO , E.NOMBRE NOMBREESTABLECIMIENTO  FROM NAT_COTIZACIONESACTIVIDADES CA INNER JOIN TERCERO E ON CA.COMPANIA = E.COMPANIA AND CA.NITESTABLECIMIENTO = E.NIT AND CA.SUCURSAL = E.SUCURSAL WHERE CA.COMPANIA = :COMPANIA AND CA.IDEVENTO = :IDEVENTO AND CA.TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN NITESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NITESTABLECIMIENTO) END)  LIKE UPPER(:NITESTABLECIMIENTO || '%')  AND (CASE WHEN NOMBREESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBREESTABLECIMIENTO) END)  LIKE UPPER( '%' || :NOMBREESTABLECIMIENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="NOMBREESTABLECIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcotizacionesactividades/nitnombreestablecimiento/num">
		<call-query href="getNatcotizacionesactividadesNumNitnombreestablecimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NITESTABLECIMIENTO" query-param="NITESTABLECIMIENTO"/>
			<with-param name="NOMBREESTABLECIMIENTO" query-param="NOMBREESTABLECIMIENTO"/>

		</call-query>
	</resource>
	<query id="insertNatcotizacionesactividades" keyColumns="COMPANIA,IDEVENTO,TIPOEVENTO,NITESTABLECIMIENTO,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_COTIZACIONESACTIVIDADES (COMPANIA, IDEVENTO, TIPOEVENTO, FECHAINICIAL, NITESTABLECIMIENTO, SUCURSAL, OBSERVACIONES, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :IDEVENTO, :TIPOEVENTO, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), :NITESTABLECIMIENTO, :SUCURSAL, :OBSERVACIONES, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDEVENTO":"$IDEVENTO","KEY_TIPOEVENTO":"$TIPOEVENTO","KEY_FECHAINICIAL":"$FECHAINICIAL","KEY_NITESTABLECIMIENTO":"$NITESTABLECIMIENTO","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natcotizacionesactividades">
		<call-query href="insertNatcotizacionesactividades">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="NITESTABLECIMIENTO" query-param="NITESTABLECIMIENTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteNatcotizacionesactividades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_COTIZACIONESACTIVIDADES WHERE NAT_COTIZACIONESACTIVIDADES.COMPANIA= :KEY_COMPANIA AND NAT_COTIZACIONESACTIVIDADES.IDEVENTO= :KEY_IDEVENTO AND NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO= :KEY_NITESTABLECIMIENTO AND NAT_COTIZACIONESACTIVIDADES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natcotizacionesactividades">
		<call-query href="deleteNatcotizacionesactividades">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NITESTABLECIMIENTO" query-param="KEY_NITESTABLECIMIENTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatcotizacionesactividadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_COTIZACIONESACTIVIDADES.COMPANIA ,NAT_COTIZACIONESACTIVIDADES.IDEVENTO ,NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO ,(TO_CHAR(NAT_COTIZACIONESACTIVIDADES.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO ,NAT_COTIZACIONESACTIVIDADES.SUCURSAL ,TE.NOMBRE NOMBREESTABLECIMIENTO  FROM NAT_COTIZACIONESACTIVIDADES INNER JOIN NAT_ENTIDADESCAPACITACION EC ON NAT_COTIZACIONESACTIVIDADES.COMPANIA = EC.COMPANIA AND NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO = EC.NITESTABLECIMIENTO AND NAT_COTIZACIONESACTIVIDADES.SUCURSAL = EC.SUCURSAL INNER JOIN TERCERO TE ON EC.COMPANIA = TE.COMPANIA AND EC.NITESTABLECIMIENTO = TE.NIT AND EC.SUCURSAL = TE.SUCURSAL WHERE NAT_COTIZACIONESACTIVIDADES.COMPANIA = :COMPANIA AND NAT_COTIZACIONESACTIVIDADES.IDEVENTO = :IDEVENTO AND NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER( '%' || :FECHAINICIAL || '%')  AND (CASE WHEN NITESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NITESTABLECIMIENTO) END)  LIKE UPPER(:NITESTABLECIMIENTO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NOMBREESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBREESTABLECIMIENTO) END)  LIKE UPPER( '%' || :NOMBREESTABLECIMIENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","FECHAINICIAL":"$FECHAINICIAL","NITESTABLECIMIENTO":"$NITESTABLECIMIENTO","SUCURSAL":"$SUCURSAL","NOMBREESTABLECIMIENTO":"$NOMBREESTABLECIMIENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBREESTABLECIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natcotizacionesactividades">
		<call-query href="getNatcotizacionesactividadesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="NITESTABLECIMIENTO" query-param="NITESTABLECIMIENTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBREESTABLECIMIENTO" query-param="NOMBREESTABLECIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatcotizacionesactividadesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_COTIZACIONESACTIVIDADES.COMPANIA ,NAT_COTIZACIONESACTIVIDADES.IDEVENTO ,NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO ,(TO_CHAR(NAT_COTIZACIONESACTIVIDADES.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO ,NAT_COTIZACIONESACTIVIDADES.SUCURSAL ,TE.NOMBRE NOMBREESTABLECIMIENTO  FROM NAT_COTIZACIONESACTIVIDADES INNER JOIN NAT_ENTIDADESCAPACITACION EC ON NAT_COTIZACIONESACTIVIDADES.COMPANIA = EC.COMPANIA AND NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO = EC.NITESTABLECIMIENTO AND NAT_COTIZACIONESACTIVIDADES.SUCURSAL = EC.SUCURSAL INNER JOIN TERCERO TE ON EC.COMPANIA = TE.COMPANIA AND EC.NITESTABLECIMIENTO = TE.NIT AND EC.SUCURSAL = TE.SUCURSAL WHERE NAT_COTIZACIONESACTIVIDADES.COMPANIA = :COMPANIA AND NAT_COTIZACIONESACTIVIDADES.IDEVENTO = :IDEVENTO AND NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO = :TIPOEVENTO) WHERE (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END)  LIKE UPPER( '%' || :FECHAINICIAL || '%')  AND (CASE WHEN NITESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NITESTABLECIMIENTO) END)  LIKE UPPER(:NITESTABLECIMIENTO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NOMBREESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBREESTABLECIMIENTO) END)  LIKE UPPER( '%' || :NOMBREESTABLECIMIENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBREESTABLECIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcotizacionesactividades/numero">
		<call-query href="getNatcotizacionesactividadesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="NITESTABLECIMIENTO" query-param="NITESTABLECIMIENTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBREESTABLECIMIENTO" query-param="NOMBREESTABLECIMIENTO"/>

		</call-query>
	</resource>
	<query id="getNatcotizacionesactividadesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_COTIZACIONESACTIVIDADES.COMPANIA , NAT_COTIZACIONESACTIVIDADES.IDEVENTO , NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO ,(TO_CHAR(NAT_COTIZACIONESACTIVIDADES.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL, NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO , NAT_COTIZACIONESACTIVIDADES.SUCURSAL , TE.NOMBRE NOMBREESTABLECIMIENTO , TE.DIRECCION DIRECCIONESTABLECIMIENTO , TE.TELEFONOS TELEFONOESTABLECIMIENTO , TC.DIRECCION DIRECCIONCONTACTO , TC.TELEFONOS TELEFONOCONTACTO , NAT_COTIZACIONESACTIVIDADES.OBSERVACIONES , NAT_COTIZACIONESACTIVIDADES.CREATED_BY ,(TO_CHAR(NAT_COTIZACIONESACTIVIDADES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, NAT_COTIZACIONESACTIVIDADES.MODIFIED_BY ,(TO_CHAR(NAT_COTIZACIONESACTIVIDADES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM NAT_COTIZACIONESACTIVIDADES INNER JOIN NAT_ENTIDADESCAPACITACION EC ON NAT_COTIZACIONESACTIVIDADES.COMPANIA = EC.COMPANIA AND NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO = EC.NITESTABLECIMIENTO AND NAT_COTIZACIONESACTIVIDADES.SUCURSAL = EC.SUCURSAL INNER JOIN TERCERO TE ON EC.COMPANIA = TE.COMPANIA AND EC.NITESTABLECIMIENTO = TE.NIT AND EC.SUCURSAL = TE.SUCURSAL LEFT JOIN TERCERO TC ON EC.COMPANIA = TC.COMPANIA AND EC.PERSONACONTACTO = TC.NIT AND EC.SUCURSALCONTACTO = TC.SUCURSAL WHERE NAT_COTIZACIONESACTIVIDADES.COMPANIA= :KEY_COMPANIA AND NAT_COTIZACIONESACTIVIDADES.IDEVENTO= :KEY_IDEVENTO AND NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO= :KEY_NITESTABLECIMIENTO AND NAT_COTIZACIONESACTIVIDADES.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","FECHAINICIAL":"$FECHAINICIAL","NITESTABLECIMIENTO":"$NITESTABLECIMIENTO","SUCURSAL":"$SUCURSAL","NOMBREESTABLECIMIENTO":"$NOMBREESTABLECIMIENTO","DIRECCIONESTABLECIMIENTO":"$DIRECCIONESTABLECIMIENTO","TELEFONOESTABLECIMIENTO":"$TELEFONOESTABLECIMIENTO","DIRECCIONCONTACTO":"$DIRECCIONCONTACTO","TELEFONOCONTACTO":"$TELEFONOCONTACTO","OBSERVACIONES":"$OBSERVACIONES","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcotizacionesactividades/data">
		<call-query href="getNatcotizacionesactividadesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NITESTABLECIMIENTO" query-param="KEY_NITESTABLECIMIENTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateNatcotizacionesactividades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_COTIZACIONESACTIVIDADES SET NITESTABLECIMIENTO=:NITESTABLECIMIENTO, SUCURSAL=:SUCURSAL, OBSERVACIONES=:OBSERVACIONES, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_COTIZACIONESACTIVIDADES.COMPANIA= :KEY_COMPANIA AND NAT_COTIZACIONESACTIVIDADES.IDEVENTO= :KEY_IDEVENTO AND NAT_COTIZACIONESACTIVIDADES.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_COTIZACIONESACTIVIDADES.NITESTABLECIMIENTO= :KEY_NITESTABLECIMIENTO AND NAT_COTIZACIONESACTIVIDADES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NITESTABLECIMIENTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natcotizacionesactividades">
		<call-query href="updateNatcotizacionesactividades">
			<with-param name="NITESTABLECIMIENTO" query-param="NITESTABLECIMIENTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NITESTABLECIMIENTO" query-param="KEY_NITESTABLECIMIENTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>