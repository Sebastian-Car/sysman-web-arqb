<data name="preguntasnovedad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertPreguntasnovedad" keyColumns="COMPANIA,TIPONOVEDAD,CLASENOVEDAD,NOVEDAD,DEPENDENCIA,PREGUNTA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PREGUNTAS_NOVEDAD (COMPANIA, TIPONOVEDAD, CLASENOVEDAD, NOVEDAD, DEPENDENCIA, PREGUNTA, RESPUESTA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPONOVEDAD, :CLASENOVEDAD, :NOVEDAD, :DEPENDENCIA, :PREGUNTA, :RESPUESTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPONOVEDAD":"$TIPONOVEDAD","KEY_CLASENOVEDAD":"$CLASENOVEDAD","KEY_NOVEDAD":"$NOVEDAD","KEY_DEPENDENCIA":"$DEPENDENCIA","KEY_PREGUNTA":"$PREGUNTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPONOVEDAD" sqlType="STRING"/>
		<param name="CLASENOVEDAD" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PREGUNTA" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="preguntasnovedad">
		<call-query href="insertPreguntasnovedad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPONOVEDAD" query-param="TIPONOVEDAD"/>
			<with-param name="CLASENOVEDAD" query-param="CLASENOVEDAD"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PREGUNTA" query-param="PREGUNTA"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePreguntasnovedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PREGUNTAS_NOVEDAD WHERE PREGUNTAS_NOVEDAD.COMPANIA= :KEY_COMPANIA AND PREGUNTAS_NOVEDAD.TIPONOVEDAD= :KEY_TIPONOVEDAD AND PREGUNTAS_NOVEDAD.CLASENOVEDAD= :KEY_CLASENOVEDAD AND PREGUNTAS_NOVEDAD.NOVEDAD= :KEY_NOVEDAD AND PREGUNTAS_NOVEDAD.DEPENDENCIA= :KEY_DEPENDENCIA AND PREGUNTAS_NOVEDAD.PREGUNTA= :KEY_PREGUNTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPONOVEDAD" sqlType="STRING"/>
		<param name="KEY_CLASENOVEDAD" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_PREGUNTA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="preguntasnovedad">
		<call-query href="deletePreguntasnovedad">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPONOVEDAD" query-param="KEY_TIPONOVEDAD"/>
			<with-param name="KEY_CLASENOVEDAD" query-param="KEY_CLASENOVEDAD"/>
			<with-param name="KEY_NOVEDAD" query-param="KEY_NOVEDAD"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_PREGUNTA" query-param="KEY_PREGUNTA"/>

		</call-query>
	</resource>
	<query id="getPreguntasnovedadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PREGUNTAS_NOVEDAD.COMPANIA, PREGUNTAS_NOVEDAD.TIPONOVEDAD, PREGUNTAS_NOVEDAD.CLASENOVEDAD, PREGUNTAS_NOVEDAD.NOVEDAD, PREGUNTAS_NOVEDAD.DEPENDENCIA, PREGUNTAS_NOVEDAD.PREGUNTA, PREGUNTAS.NOMBRE, PREGUNTAS_NOVEDAD.RESPUESTA  FROM PREGUNTAS_NOVEDAD INNER JOIN PREGUNTAS ON PREGUNTAS_NOVEDAD.COMPANIA =PREGUNTAS.COMPANIA AND PREGUNTAS_NOVEDAD.PREGUNTA =PREGUNTAS.CODIGO WHERE PREGUNTAS_NOVEDAD.COMPANIA =:COMPANIA AND PREGUNTAS_NOVEDAD.TIPONOVEDAD = :TIPON AND PREGUNTAS_NOVEDAD.CLASENOVEDAD = :CLASEN AND PREGUNTAS_NOVEDAD.DEPENDENCIA = :DEPENDENCIAN AND PREGUNTAS_NOVEDAD.NOVEDAD =:CODIGONOVEDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPONOVEDAD":"$TIPONOVEDAD","CLASENOVEDAD":"$CLASENOVEDAD","NOVEDAD":"$NOVEDAD","DEPENDENCIA":"$DEPENDENCIA","PREGUNTA":"$PREGUNTA(type:integer)","NOMBRE":"$NOMBRE","RESPUESTA":"$RESPUESTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPON" sqlType="STRING"/>
		<param name="CLASEN" sqlType="STRING"/>
		<param name="DEPENDENCIAN" sqlType="STRING"/>
		<param name="CODIGONOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="preguntasnovedad">
		<call-query href="getPreguntasnovedadPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPON" query-param="TIPON"/>
			<with-param name="CLASEN" query-param="CLASEN"/>
			<with-param name="DEPENDENCIAN" query-param="DEPENDENCIAN"/>
			<with-param name="CODIGONOVEDAD" query-param="CODIGONOVEDAD"/>

		</call-query>
	</resource>
	<query id="getPreguntasnovedadRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PREGUNTAS_NOVEDAD.COMPANIA, PREGUNTAS_NOVEDAD.TIPONOVEDAD, PREGUNTAS_NOVEDAD.CLASENOVEDAD, PREGUNTAS_NOVEDAD.NOVEDAD, PREGUNTAS_NOVEDAD.DEPENDENCIA, PREGUNTAS_NOVEDAD.PREGUNTA, PREGUNTAS.NOMBRE,(CASE PREGUNTAS_NOVEDAD.RESPUESTA WHEN 0 THEN 'false' ELSE 'true' END) RESPUESTA FROM PREGUNTAS_NOVEDAD INNER JOIN PREGUNTAS ON PREGUNTAS_NOVEDAD.COMPANIA =PREGUNTAS.COMPANIA AND PREGUNTAS_NOVEDAD.PREGUNTA =PREGUNTAS.CODIGO WHERE PREGUNTAS_NOVEDAD.COMPANIA= :KEY_COMPANIA AND PREGUNTAS_NOVEDAD.TIPONOVEDAD= :KEY_TIPONOVEDAD AND PREGUNTAS_NOVEDAD.CLASENOVEDAD= :KEY_CLASENOVEDAD AND PREGUNTAS_NOVEDAD.NOVEDAD= :KEY_NOVEDAD AND PREGUNTAS_NOVEDAD.DEPENDENCIA= :KEY_DEPENDENCIA AND PREGUNTAS_NOVEDAD.PREGUNTA= :KEY_PREGUNTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPONOVEDAD":"$TIPONOVEDAD","CLASENOVEDAD":"$CLASENOVEDAD","NOVEDAD":"$NOVEDAD","DEPENDENCIA":"$DEPENDENCIA","PREGUNTA":"$PREGUNTA(type:integer)","NOMBRE":"$NOMBRE","RESPUESTA":"$RESPUESTA(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPONOVEDAD" sqlType="STRING"/>
		<param name="KEY_CLASENOVEDAD" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_PREGUNTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="preguntasnovedad/data">
		<call-query href="getPreguntasnovedadRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPONOVEDAD" query-param="KEY_TIPONOVEDAD"/>
			<with-param name="KEY_CLASENOVEDAD" query-param="KEY_CLASENOVEDAD"/>
			<with-param name="KEY_NOVEDAD" query-param="KEY_NOVEDAD"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_PREGUNTA" query-param="KEY_PREGUNTA"/>

		</call-query>
	</resource>
	<query id="updatePreguntasnovedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PREGUNTAS_NOVEDAD SET COMPANIA=:COMPANIA, TIPONOVEDAD=:TIPONOVEDAD, CLASENOVEDAD=:CLASENOVEDAD, NOVEDAD=:NOVEDAD, DEPENDENCIA=:DEPENDENCIA, PREGUNTA=:PREGUNTA, RESPUESTA=:RESPUESTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PREGUNTAS_NOVEDAD.COMPANIA= :KEY_COMPANIA AND PREGUNTAS_NOVEDAD.TIPONOVEDAD= :KEY_TIPONOVEDAD AND PREGUNTAS_NOVEDAD.CLASENOVEDAD= :KEY_CLASENOVEDAD AND PREGUNTAS_NOVEDAD.NOVEDAD= :KEY_NOVEDAD AND PREGUNTAS_NOVEDAD.DEPENDENCIA= :KEY_DEPENDENCIA AND PREGUNTAS_NOVEDAD.PREGUNTA= :KEY_PREGUNTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPONOVEDAD" sqlType="STRING"/>
		<param name="CLASENOVEDAD" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PREGUNTA" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPONOVEDAD" sqlType="STRING"/>
		<param name="KEY_CLASENOVEDAD" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_PREGUNTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="preguntasnovedad">
		<call-query href="updatePreguntasnovedad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPONOVEDAD" query-param="TIPONOVEDAD"/>
			<with-param name="CLASENOVEDAD" query-param="CLASENOVEDAD"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PREGUNTA" query-param="PREGUNTA"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPONOVEDAD" query-param="KEY_TIPONOVEDAD"/>
			<with-param name="KEY_CLASENOVEDAD" query-param="KEY_CLASENOVEDAD"/>
			<with-param name="KEY_NOVEDAD" query-param="KEY_NOVEDAD"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_PREGUNTA" query-param="KEY_PREGUNTA"/>

		</call-query>
	</resource>

</data>