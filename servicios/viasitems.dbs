<data name="viasitems" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getViasitemsSoloCoditemPorIdviaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO_ITEM  FROM VIAS_ITEMS WHERE COMPANIA= :COMPANIA AND ID_VIA = :ID_VIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_ITEM":"$CODIGO_ITEM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viasitems/solocoditemporidvia">
		<call-query href="getViasitemsSoloCoditemPorIdviaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>

		</call-query>
	</resource>
	<query id="insertViasitemsDatos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VIAS_ITEMS (COMPANIA,ID_VIA,CODIGO_ITEM,DATE_CREATED,CREATED_BY) VALUES (:COMPANIA,:ID_VIA,:CODIGO_ITEM,TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'),:CREATED_BY)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>
		<param name="CODIGO_ITEM" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="viasitems/datos">
		<call-query href="insertViasitemsDatos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>
			<with-param name="CODIGO_ITEM" query-param="CODIGO_ITEM"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteViasitems" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VIAS_ITEMS WHERE VIAS_ITEMS.COMPANIA= :KEY_COMPANIA AND VIAS_ITEMS.ID_VIA= :KEY_ID_VIA AND VIAS_ITEMS.CODIGO_ITEM= :KEY_CODIGO_ITEM</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_VIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_ITEM" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="viasitems">
		<call-query href="deleteViasitems">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_VIA" query-param="KEY_ID_VIA"/>
			<with-param name="KEY_CODIGO_ITEM" query-param="KEY_CODIGO_ITEM"/>

		</call-query>
	</resource>
	<query id="getViasitemsPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VIAS_ITEMS.COMPANIA, VIAS_ITEMS.ID_VIA, VIAS_ITEMS.CODIGO_ITEM, VIAS_ITEMS.ACABADO, VIAS_ITEMS.ESTADO, VIAS_ITEMS.LONGITUD, VIAS_ITEMS.ANCHO, ITEMS.DESCRIPCION  FROM VIAS_ITEMS LEFT JOIN ITEMS ON VIAS_ITEMS.COMPANIA = ITEMS.COMPANIA AND VIAS_ITEMS.CODIGO_ITEM = ITEMS.CODIGO_ITEM WHERE VIAS_ITEMS.COMPANIA =:COMPANIA AND ID_VIA = :ID_VIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_VIA":"$ID_VIA","CODIGO_ITEM":"$CODIGO_ITEM","ACABADO":"$ACABADO","ESTADO":"$ESTADO","LONGITUD":"$LONGITUD","ANCHO":"$ANCHO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viasitems">
		<call-query href="getViasitemsPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>

		</call-query>
	</resource>
	<query id="updateViasitems" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VIAS_ITEMS SET ACABADO=:ACABADO, ESTADO=:ESTADO, LONGITUD=:LONGITUD, ANCHO=:ANCHO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VIAS_ITEMS.COMPANIA= :KEY_COMPANIA AND VIAS_ITEMS.ID_VIA= :KEY_ID_VIA AND VIAS_ITEMS.CODIGO_ITEM= :KEY_CODIGO_ITEM</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ACABADO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="LONGITUD" sqlType="STRING"/>
		<param name="ANCHO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_VIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_ITEM" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="viasitems">
		<call-query href="updateViasitems">
			<with-param name="ACABADO" query-param="ACABADO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="LONGITUD" query-param="LONGITUD"/>
			<with-param name="ANCHO" query-param="ANCHO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_VIA" query-param="KEY_ID_VIA"/>
			<with-param name="KEY_CODIGO_ITEM" query-param="KEY_CODIGO_ITEM"/>

		</call-query>
	</resource>

</data>