	<query id="updateAlmacencontabilidadsccAlmacencontabilidadcc_niiif" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ALMACENCONTABILIDADCC SET NIIF_CUENTADEBITO=:NIIF_CUENTADEBITO, NIIF_CUENTACREDITO=:NIIF_CUENTACREDITO, NIIF_DEBITO_BASE=:NIIF_DEBITO_BASE, NIIF_CREDITO_BASE=:NIIF_CREDITO_BASE, NIIF_CREDITO_IVA=:NIIF_CREDITO_IVA, NIIF_DEBITO_IVA=:NIIF_DEBITO_IVA, NIIF_CUENTADEBITOAJUSTE=:NIIF_CUENTADEBITOAJUSTE, NIIF_CUENTACREDITOAJUSTE=:NIIF_CUENTACREDITOAJUSTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ALMACENCONTABILIDADCC.COMPANIA= :KEY_COMPANIA AND ALMACENCONTABILIDADCC.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND ALMACENCONTABILIDADCC.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND ALMACENCONTABILIDADCC.ANO= :KEY_ANO AND ALMACENCONTABILIDADCC.CENTRO_COSTO= :KEY_CENTRO_COSTO AND ALMACENCONTABILIDADCC.FUENTEDERECURSO= :KEY_FUENTEDERECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 
