	<query id="getAlmacencontabilidadsccNumAlmacencontabilidadniifQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ALMACENCONTABILIDADCC.COMPANIA, ALMACENCONTABILIDADCC.CODIGOELEMENTO, ALMACENCONTABILIDADCC.CENTRO_COSTO, ALMACENCONTABILIDADCC.FUENTEDERECURSO, ALMACENCONTABILIDADCC.TIPOMOVIMIENTO, TIPOMOVIMIENTO.NOMBRE, ALMACENCONTABILIDADCC.ANO, ALMACENCONTABILIDADCC.NIIF_CUENTADEBITO, ALMACENCONTABILIDADCC.NIIF_CUENTACREDITO, ALMACENCONTABILIDADCC.NIIF_DEBITO_BASE, ALMACENCONTABILIDADCC.NIIF_CREDITO_BASE, ALMACENCONTABILIDADCC.NIIF_CREDITO_IVA, ALMACENCONTABILIDADCC.NIIF_DEBITO_IVA FROM ALMACENCONTABILIDADCC LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDADCC.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND ALMACENCONTABILIDADCC.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE ALMACENCONTABILIDADCC.COMPANIA = :COMPANIA AND ALMACENCONTABILIDADCC.CODIGOELEMENTO = :CODIGOELEMENTO AND ALMACENCONTABILIDADCC.ANO = :ANO AND ALMACENCONTABILIDADCC.CENTRO_COSTO = :CENTRO_COSTO AND ALMACENCONTABILIDADCC.FUENTEDERECURSO = :FUENTE_RECURSO ORDER BY ALMACENCONTABILIDADCC.TIPOMOVIMIENTO) INI WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NIIF_CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTADEBITO) END) LIKE UPPER(CONCAT(:NIIF_CUENTADEBITO, '%')) AND (CASE WHEN NIIF_CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(NIIF_CUENTACREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:NIIF_CUENTACREDITO), '%')) AND (CASE WHEN NIIF_DEBITO_BASE IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_BASE) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_BASE, '%')) AND (CASE WHEN NIIF_CREDITO_BASE IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_BASE) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_BASE, '%')) AND (CASE WHEN NIIF_CREDITO_IVA IS NULL THEN ' ' ELSE UPPER(NIIF_CREDITO_IVA) END) LIKE UPPER(CONCAT(:NIIF_CREDITO_IVA, '%')) AND (CASE WHEN NIIF_DEBITO_IVA IS NULL THEN ' ' ELSE UPPER(NIIF_DEBITO_IVA) END) LIKE UPPER(CONCAT(:NIIF_DEBITO_IVA, '%')) ) A) FIN</sql>
