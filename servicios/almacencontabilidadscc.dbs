		<param name="NIIF_CUENTACREDITO" sqlType="STRING"/>
		<param name="NIIF_DEBITO_BASE" sqlType="STRING"/>
		<param name="NIIF_CREDITO_BASE" sqlType="STRING"/>
		<param name="NIIF_CREDITO_IVA" sqlType="STRING"/>
