	<query id="getAlmacencontabilidadsccNumInterfazTransaccionCentroCostoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ALMACENCONTABILIDADCC.COMPANIA, ALMACENCONTABILIDADCC.CODIGOELEMENTO, ALMACENCONTABILIDADCC.CENTRO_COSTO, ALMACENCONTABILIDADCC.FUENTEDERECURSO, ALMACENCONTABILIDADCC.TIPOMOVIMIENTO, TIPOMOVIMIENTO.NOMBRE, ALMACENCONTABILIDADCC.ANO, ALMACENCONTABILIDADCC.CUENTADEBITO, ALMACENCONTABILIDADCC.CUENTACREDITO, ALMACENCONTABILIDADCC.DEBITO_BASE, ALMACENCONTABILIDADCC.CREDITO_BASE, ALMACENCONTABILIDADCC.CREDITO_IVA, ALMACENCONTABILIDADCC.DEBITO_IVA FROM ALMACENCONTABILIDADCC LEFT JOIN TIPOMOVIMIENTO ON ALMACENCONTABILIDADCC.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND ALMACENCONTABILIDADCC.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE ALMACENCONTABILIDADCC.COMPANIA = :COMPANIA AND ALMACENCONTABILIDADCC.CODIGOELEMENTO = :CODIGOELEMENTO AND ALMACENCONTABILIDADCC.ANO = :ANO AND ALMACENCONTABILIDADCC.CENTRO_COSTO = :CENTRO_COSTO AND ALMACENCONTABILIDADCC.FUENTEDERECURSO = :FUENTE_RECURSO ORDER BY ALMACENCONTABILIDADCC.TIPOMOVIMIENTO) INI WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CUENTADEBITO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITO) END) LIKE UPPER(CONCAT(:CUENTADEBITO, '%')) AND (CASE WHEN CUENTACREDITO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITO) END) LIKE UPPER(CONCAT(:CUENTACREDITO, '%')) AND (CASE WHEN DEBITO_BASE IS NULL THEN ' ' ELSE UPPER(DEBITO_BASE) END) LIKE UPPER(CONCAT(:DEBITO_BASE, '%')) AND (CASE WHEN CREDITO_BASE IS NULL THEN ' ' ELSE UPPER(CREDITO_BASE) END) LIKE UPPER(CONCAT(:CREDITO_BASE, '%')) AND (CASE WHEN CREDITO_IVA IS NULL THEN ' ' ELSE UPPER(CREDITO_IVA) END) LIKE UPPER(CONCAT(:CREDITO_IVA, '%')) AND (CASE WHEN DEBITO_IVA IS NULL THEN ' ' ELSE UPPER(DEBITO_IVA) END) LIKE UPPER(CONCAT(:DEBITO_IVA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
