<data name="ssttipoactividad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSsttipoactividadPagActividadesporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_TIPO_ACTIVIDAD.CODIGO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD, SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION  FROM SST_TIPO_ACTIVIDAD WHERE SST_TIPO_ACTIVIDAD.COMPANIA = :COMPANIA AND SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION = :TIPOTRANSACCION ORDER BY SST_TIPO_ACTIVIDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttipoactividad/actividadesporcompania/pag">
		<call-query href="getSsttipoactividadPagActividadesporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadNumActividadesporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_TIPO_ACTIVIDAD.CODIGO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD, SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION  FROM SST_TIPO_ACTIVIDAD WHERE SST_TIPO_ACTIVIDAD.COMPANIA = :COMPANIA AND SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION = :TIPOTRANSACCION ORDER BY SST_TIPO_ACTIVIDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipoactividad/actividadesporcompania/num">
		<call-query href="getSsttipoactividadNumActividadesporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadPagTodosPorActividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, TIPO_TRANSACCION, CODIGO_PLANTILLA  FROM SST_TIPO_ACTIVIDAD WHERE COMPANIA = :COMPANIA AND TIPO_TRANSACCION = :TIPO_TRANSACCION AND CODIGO NOT IN ( SELECT ACTIVIDAD FROM SST_TRANSACCION_ACTIVIDAD WHERE COMPANIA = :COMPANIA AND TIPO_TRANSACCION = :TIPO_TRANSACCION)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CODIGO_PLANTILLA":"$CODIGO_PLANTILLA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttipoactividad/todosporactividades/pag">
		<call-query href="getSsttipoactividadPagTodosPorActividadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadNumTodosPorActividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, TIPO_TRANSACCION, CODIGO_PLANTILLA  FROM SST_TIPO_ACTIVIDAD WHERE COMPANIA = :COMPANIA AND TIPO_TRANSACCION = :TIPO_TRANSACCION AND CODIGO NOT IN ( SELECT ACTIVIDAD FROM SST_TRANSACCION_ACTIVIDAD WHERE COMPANIA = :COMPANIA AND TIPO_TRANSACCION = :TIPO_TRANSACCION)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipoactividad/todosporactividades/num">
		<call-query href="getSsttipoactividadNumTodosPorActividadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadPagCodNomPorActInicialFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, TIPO_TRANSACCION, CODIGO_PLANTILLA  FROM SST_TIPO_ACTIVIDAD WHERE COMPANIA = :COMPANIA AND TIPO_TRANSACCION = :TIPO_TRANSACCION AND CODIGO &gt;= :ACTIVIDADI) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
