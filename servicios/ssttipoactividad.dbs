	<query id="getSsttipoactividadPagCodNomPorCompQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_TIPO_ACTIVIDAD.CODIGO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD, SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION  FROM SST_TIPO_ACTIVIDAD WHERE SST_TIPO_ACTIVIDAD.COMPANIA = :COMPANIA ORDER BY SST_TIPO_ACTIVIDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)"}]}}		</result>
