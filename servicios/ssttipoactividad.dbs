			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertSsttipoactividad" keyColumns="COMPANIA,CODIGO,TIPO_TRANSACCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_TIPO_ACTIVIDAD (COMPANIA, CODIGO, NOMBRE, TIPO_TRANSACCION, CODIGO_PLANTILLA, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :TIPO_TRANSACCION, :CODIGO_PLANTILLA, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO(type:integer)","KEY_TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_PLANTILLA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ssttipoactividad">
		<call-query href="insertSsttipoactividad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSsttipoactividad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_TIPO_ACTIVIDAD WHERE SST_TIPO_ACTIVIDAD.COMPANIA= :KEY_COMPANIA AND SST_TIPO_ACTIVIDAD.CODIGO= :KEY_CODIGO AND SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="ssttipoactividad">
		<call-query href="deleteSsttipoactividad">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TA.COMPANIA, TA.CODIGO, TA.NOMBRE, TT.NOMBRE NOMBRETIPOTX, TA.TIPO_TRANSACCION, TA.CODIGO_PLANTILLA, TA.OBSERVACIONES  FROM SST_TIPO_ACTIVIDAD TA INNER JOIN SST_TIPO_TRANSACCION TT ON TA.COMPANIA = TT.COMPANIA AND TA.TIPO_TRANSACCION = TT.CODIGO WHERE TA.COMPANIA = :COMPANIA AND TIPO_TRANSACCION = :TIPOTRANSACCION) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRETIPOTX IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOTX) END)  LIKE UPPER(:NOMBRETIPOTX || '%')  AND (CASE WHEN CODIGO_PLANTILLA IS NULL THEN ' ' ELSE UPPER(CODIGO_PLANTILLA) END)  LIKE UPPER( '%' || :CODIGO_PLANTILLA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","NOMBRETIPOTX":"$NOMBRETIPOTX","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CODIGO_PLANTILLA":"$CODIGO_PLANTILLA","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRETIPOTX" sqlType="STRING"/>
		<param name="CODIGO_PLANTILLA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttipoactividad">
		<call-query href="getSsttipoactividadPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRETIPOTX" query-param="NOMBRETIPOTX"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TA.COMPANIA, TA.CODIGO, TA.NOMBRE, TT.NOMBRE NOMBRETIPOTX, TA.TIPO_TRANSACCION, TA.CODIGO_PLANTILLA, TA.OBSERVACIONES  FROM SST_TIPO_ACTIVIDAD TA INNER JOIN SST_TIPO_TRANSACCION TT ON TA.COMPANIA = TT.COMPANIA AND TA.TIPO_TRANSACCION = TT.CODIGO WHERE TA.COMPANIA = :COMPANIA AND TIPO_TRANSACCION = :TIPOTRANSACCION) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRETIPOTX IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOTX) END)  LIKE UPPER(:NOMBRETIPOTX || '%')  AND (CASE WHEN CODIGO_PLANTILLA IS NULL THEN ' ' ELSE UPPER(CODIGO_PLANTILLA) END)  LIKE UPPER( '%' || :CODIGO_PLANTILLA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRETIPOTX" sqlType="STRING"/>
		<param name="CODIGO_PLANTILLA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipoactividad/numero">
		<call-query href="getSsttipoactividadNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRETIPOTX" query-param="NOMBRETIPOTX"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="updateSsttipoactividad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_TIPO_ACTIVIDAD SET NOMBRE=:NOMBRE, CODIGO_PLANTILLA=:CODIGO_PLANTILLA, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_TIPO_ACTIVIDAD.COMPANIA= :KEY_COMPANIA AND SST_TIPO_ACTIVIDAD.CODIGO= :KEY_CODIGO AND SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_PLANTILLA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ssttipoactividad">
		<call-query href="updateSsttipoactividad">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadNumCodNomPorCompIniQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_TIPO_ACTIVIDAD.CODIGO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD, SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION  FROM SST_TIPO_ACTIVIDAD WHERE SST_TIPO_ACTIVIDAD.COMPANIA = :COMPANIA AND SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION = :TIPO_TRANSACCION ORDER BY SST_TIPO_ACTIVIDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipoactividad/codnomporcompini/num">
		<call-query href="getSsttipoactividadNumCodNomPorCompIniQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadPagCodNomPorCompFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_TIPO_ACTIVIDAD.CODIGO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD, SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION  FROM SST_TIPO_ACTIVIDAD WHERE SST_TIPO_ACTIVIDAD.COMPANIA = :COMPANIA AND SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION = :TIPO_TRANSACCION ORDER BY SST_TIPO_ACTIVIDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttipoactividad/codnomporcompfin/pag">
		<call-query href="getSsttipoactividadPagCodNomPorCompFinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttipoactividadNumCodNomPorCompFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_TIPO_ACTIVIDAD.CODIGO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD, SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION  FROM SST_TIPO_ACTIVIDAD WHERE SST_TIPO_ACTIVIDAD.COMPANIA = :COMPANIA AND SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION = :TIPO_TRANSACCION ORDER BY SST_TIPO_ACTIVIDAD.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttipoactividad/codnomporcompfin/num">
		<call-query href="getSsttipoactividadNumCodNomPorCompFinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>

