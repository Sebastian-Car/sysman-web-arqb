		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO_ACTUAL" sqlType="STRING"/>
		<param defaultValue="" name="DCTO_IDENTIDAD_A" sqlType="STRING"/>
		<param defaultValue="" name="PARENTESCO_A" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_A" sqlType="STRING"/>
		<param defaultValue="" name="SEXO_A" sqlType="STRING"/>
