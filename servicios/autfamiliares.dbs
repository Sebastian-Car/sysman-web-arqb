		<param defaultValue="0" name="SALUD_A" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE_A" sqlType="STRING"/>
		<param defaultValue="" name="OCUPACION_A" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO_A" sqlType="STRING"/>
		<param defaultValue="0" name="POS_A" sqlType="STRING"/>
		<param defaultValue="0" name="AUXILIO_EDUCATIVO_A" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO1_A" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO2_A" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION_A" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO_ACTUAL_A" sqlType="STRING"/>
