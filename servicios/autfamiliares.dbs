		<param defaultValue="999999999999999999" name="DESTINATARIO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_DESTINATARIO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_SOLICITUD" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_APROBACION" sqlType="STRING"/>
		<param defaultValue="0" name="ENVIADO" sqlType="STRING"/>
