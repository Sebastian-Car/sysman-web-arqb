	<query id="updateAutfamiliares" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE AUT_FAMILIARES SET COMPANIA=:COMPANIA, DCTO_EMPLEADO=:DCTO_EMPLEADO, SUCURSAL_EMPLEADO=:SUCURSAL_EMPLEADO, IDENTIFICACION=:IDENTIFICACION, SUCURSAL=:SUCURSAL, CONSECUTIVO=:CONSECUTIVO, DCTO_IDENTIDAD=:DCTO_IDENTIDAD, PARENTESCO=:PARENTESCO, NOMBRE=:NOMBRE, FECHANCTO=TO_DATE(:FECHANCTO,'DD/MM/YYYY HH24:MI:SS'), SEXO=:SEXO, OBSERVACIONES=:OBSERVACIONES, POLIZA=:POLIZA, SALUD=:SALUD, PORCENTAJE=:PORCENTAJE, OCUPACION=:OCUPACION, TELEFONO=:TELEFONO, POS=:POS, AUXILIO_EDUCATIVO=:AUXILIO_EDUCATIVO, APELLIDO1=:APELLIDO1, APELLIDO2=:APELLIDO2, DIRECCION=:DIRECCION, ESTADO_ACTUAL=:ESTADO_ACTUAL, DCTO_IDENTIDAD_A=:DCTO_IDENTIDAD_A, PARENTESCO_A=:PARENTESCO_A, NOMBRE_A=:NOMBRE_A, SEXO_A=:SEXO_A, OBSERVACIONES_A=:OBSERVACIONES_A, POLIZA_A=:POLIZA_A, SALUD_A=:SALUD_A, PORCENTAJE_A=:PORCENTAJE_A, OCUPACION_A=:OCUPACION_A, TELEFONO_A=:TELEFONO_A, POS_A=:POS_A, AUXILIO_EDUCATIVO_A=:AUXILIO_EDUCATIVO_A, APELLIDO1_A=:APELLIDO1_A, APELLIDO2_A=:APELLIDO2_A, DIRECCION_A=:DIRECCION_A, ESTADO_ACTUAL_A=:ESTADO_ACTUAL_A, ESTADO=:ESTADO, DESTINATARIO=:DESTINATARIO, SUCURSAL_DESTINATARIO=:SUCURSAL_DESTINATARIO, TIPO_SOLICITUD=:TIPO_SOLICITUD, FECHA_APROBACION=TO_DATE(:FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS'), ENVIADO=:ENVIADO, ACTUALIZADO=:ACTUALIZADO, RUTA=:RUTA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), N_IDENTIFICACION=:N_IDENTIFICACION, EDAD=:EDAD, EDAD_A=:EDAD_A WHERE AUT_FAMILIARES.COMPANIA= :KEY_COMPANIA AND AUT_FAMILIARES.DCTO_EMPLEADO= :KEY_DCTO_EMPLEADO AND AUT_FAMILIARES.SUCURSAL_EMPLEADO= :KEY_SUCURSAL_EMPLEADO AND AUT_FAMILIARES.IDENTIFICACION= :KEY_IDENTIFICACION AND AUT_FAMILIARES.SUCURSAL= :KEY_SUCURSAL AND AUT_FAMILIARES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

