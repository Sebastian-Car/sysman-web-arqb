	<query id="deleteAutfamiliares" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM AUT_FAMILIARES WHERE AUT_FAMILIARES.COMPANIA= :KEY_COMPANIA AND AUT_FAMILIARES.DCTO_EMPLEADO= :KEY_DCTO_EMPLEADO AND AUT_FAMILIARES.SUCURSAL_EMPLEADO= :KEY_SUCURSAL_EMPLEADO AND AUT_FAMILIARES.IDENTIFICACION= :KEY_IDENTIFICACION AND AUT_FAMILIARES.SUCURSAL= :KEY_SUCURSAL AND AUT_FAMILIARES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_IDENTIFICACION" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="autfamiliares">
		<call-query href="deleteAutfamiliares">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DCTO_EMPLEADO" query-param="KEY_DCTO_EMPLEADO"/>
			<with-param name="KEY_SUCURSAL_EMPLEADO" query-param="KEY_SUCURSAL_EMPLEADO"/>
			<with-param name="KEY_IDENTIFICACION" query-param="KEY_IDENTIFICACION"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getAutfamiliaresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CONSECUTIVO, DCTO_EMPLEADO, SUCURSAL_EMPLEADO, IDENTIFICACION, SUCURSAL, CONCAT(APELLIDO1,CONCAT(' ',APELLIDO2) ) APELLIDOS, NOMBRE NOMBRES, ESTADO,(CASE ACTUALIZADO WHEN 0 THEN 'false' ELSE 'true' END) ACTUALIZADO,(CASE ENVIADO WHEN 0 THEN 'false' ELSE 'true' END) ENVIADO, CASE WHEN ESTADO = 'T' AND FECHA_APROBACION IS NULL AND DESTINATARIO =:DESTINATARIO THEN 'T' ELSE CASE WHEN FECHA_APROBACION IS NULL THEN 'S' ELSE 'A' END END DESTINO FROM AUT_FAMILIARES WHERE COMPANIA =:COMPANIA AND DCTO_EMPLEADO = CASE WHEN :PORTRAMITAR = 1 THEN DCTO_EMPLEADO ELSE :NUMDOCUMENTO END AND DESTINATARIO = CASE WHEN :PORTRAMITAR = 1 THEN :DESTINATARIO ELSE DESTINATARIO END AND CASE WHEN :PORTRAMITAR = 1 THEN FECHA_APROBACION ELSE NULL END IS NULL AND CASE WHEN :PORTRAMITAR = 1 THEN ENVIADO ELSE 1 END NOT IN (0) ORDER BY CONSECUTIVO ASC) INI WHERE (CASE WHEN APELLIDOS IS NULL THEN ' ' ELSE UPPER(APELLIDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDOS), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","DCTO_EMPLEADO":"$DCTO_EMPLEADO","SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","IDENTIFICACION":"$IDENTIFICACION","SUCURSAL":"$SUCURSAL","APELLIDOS":"$APELLIDOS","NOMBRES":"$NOMBRES","ESTADO":"$ESTADO","ACTUALIZADO":"$ACTUALIZADO(type:boolean)","ENVIADO":"$ENVIADO(type:boolean)","DESTINO":"$DESTINO"}]}}		</result>
		<param name="DESTINATARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PORTRAMITAR" sqlType="STRING"/>
		<param name="NUMDOCUMENTO" sqlType="STRING"/>
		<param name="APELLIDOS" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="autfamiliares">
		<call-query href="getAutfamiliaresPaginaQuery">
			<with-param name="DESTINATARIO" query-param="DESTINATARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PORTRAMITAR" query-param="PORTRAMITAR"/>
			<with-param name="NUMDOCUMENTO" query-param="NUMDOCUMENTO"/>
			<with-param name="APELLIDOS" query-param="APELLIDOS"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAutfamiliaresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CONSECUTIVO, DCTO_EMPLEADO, SUCURSAL_EMPLEADO, IDENTIFICACION, SUCURSAL, CONCAT(APELLIDO1,CONCAT(' ',APELLIDO2) ) APELLIDOS, NOMBRE NOMBRES, ESTADO,(CASE ACTUALIZADO WHEN 0 THEN 'false' ELSE 'true' END) ACTUALIZADO,(CASE ENVIADO WHEN 0 THEN 'false' ELSE 'true' END) ENVIADO, CASE WHEN ESTADO = 'T' AND FECHA_APROBACION IS NULL AND DESTINATARIO =:DESTINATARIO THEN 'T' ELSE CASE WHEN FECHA_APROBACION IS NULL THEN 'S' ELSE 'A' END END DESTINO FROM AUT_FAMILIARES WHERE COMPANIA =:COMPANIA AND DCTO_EMPLEADO = CASE WHEN :PORTRAMITAR = 1 THEN DCTO_EMPLEADO ELSE :NUMDOCUMENTO END AND DESTINATARIO = CASE WHEN :PORTRAMITAR = 1 THEN :DESTINATARIO ELSE DESTINATARIO END AND CASE WHEN :PORTRAMITAR = 1 THEN FECHA_APROBACION ELSE NULL END IS NULL AND CASE WHEN :PORTRAMITAR = 1 THEN ENVIADO ELSE 1 END NOT IN (0) ORDER BY CONSECUTIVO ASC) INI WHERE (CASE WHEN APELLIDOS IS NULL THEN ' ' ELSE UPPER(APELLIDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDOS), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="DESTINATARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PORTRAMITAR" sqlType="STRING"/>
		<param name="NUMDOCUMENTO" sqlType="STRING"/>
		<param name="APELLIDOS" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="autfamiliares/numero">
		<call-query href="getAutfamiliaresNumeroQuery">
			<with-param name="DESTINATARIO" query-param="DESTINATARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PORTRAMITAR" query-param="PORTRAMITAR"/>
			<with-param name="NUMDOCUMENTO" query-param="NUMDOCUMENTO"/>
			<with-param name="APELLIDOS" query-param="APELLIDOS"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>

		</call-query>
	</resource>
	<query id="getAutfamiliaresRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  AUT_FAMILIARES.COMPANIA, AUT_FAMILIARES.DCTO_EMPLEADO, AUT_FAMILIARES.SUCURSAL_EMPLEADO, AUT_FAMILIARES.IDENTIFICACION, AUT_FAMILIARES.SUCURSAL, AUT_FAMILIARES.CONSECUTIVO, AUT_FAMILIARES.DCTO_IDENTIDAD, AUT_FAMILIARES.PARENTESCO, AUT_FAMILIARES.NOMBRE,(TO_CHAR(AUT_FAMILIARES.FECHANCTO,'DD/MM/YYYY HH24:MI:SS')) FECHANCTO, AUT_FAMILIARES.SEXO, AUT_FAMILIARES.OBSERVACIONES,(CASE AUT_FAMILIARES.POLIZA WHEN 0 THEN 'false' ELSE 'true' END) POLIZA,(CASE AUT_FAMILIARES.SALUD WHEN 0 THEN 'false' ELSE 'true' END) SALUD, AUT_FAMILIARES.PORCENTAJE, AUT_FAMILIARES.OCUPACION, AUT_FAMILIARES.TELEFONO,(CASE AUT_FAMILIARES.POS WHEN 0 THEN 'false' ELSE 'true' END) POS,(CASE AUT_FAMILIARES.AUXILIO_EDUCATIVO WHEN 0 THEN 'false' ELSE 'true' END) AUXILIO_EDUCATIVO, AUT_FAMILIARES.APELLIDO1, AUT_FAMILIARES.APELLIDO2, AUT_FAMILIARES.DIRECCION, AUT_FAMILIARES.ESTADO_ACTUAL, AUT_FAMILIARES.DCTO_IDENTIDAD_A, AUT_FAMILIARES.PARENTESCO_A, AUT_FAMILIARES.NOMBRE_A, AUT_FAMILIARES.SEXO_A, AUT_FAMILIARES.OBSERVACIONES_A,(CASE AUT_FAMILIARES.POLIZA_A WHEN 0 THEN 'false' ELSE 'true' END) POLIZA_A,(CASE AUT_FAMILIARES.SALUD_A WHEN 0 THEN 'false' ELSE 'true' END) SALUD_A, AUT_FAMILIARES.PORCENTAJE_A, AUT_FAMILIARES.OCUPACION_A, AUT_FAMILIARES.TELEFONO_A,(CASE AUT_FAMILIARES.POS_A WHEN 0 THEN 'false' ELSE 'true' END) POS_A,(CASE AUT_FAMILIARES.AUXILIO_EDUCATIVO_A WHEN 0 THEN 'false' ELSE 'true' END) AUXILIO_EDUCATIVO_A, AUT_FAMILIARES.APELLIDO1_A, AUT_FAMILIARES.APELLIDO2_A, AUT_FAMILIARES.DIRECCION_A, AUT_FAMILIARES.ESTADO_ACTUAL_A, AUT_FAMILIARES.ESTADO, AUT_FAMILIARES.DESTINATARIO, AUT_FAMILIARES.SUCURSAL_DESTINATARIO, AUT_FAMILIARES.TIPO_SOLICITUD,(TO_CHAR(AUT_FAMILIARES.FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_APROBACION,(CASE AUT_FAMILIARES.ENVIADO WHEN 0 THEN 'false' ELSE 'true' END) ENVIADO,(CASE AUT_FAMILIARES.ACTUALIZADO WHEN 0 THEN 'false' ELSE 'true' END) ACTUALIZADO, AUT_FAMILIARES.RUTA, AUT_FAMILIARES.CREATED_BY,(TO_CHAR(AUT_FAMILIARES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, AUT_FAMILIARES.MODIFIED_BY,(TO_CHAR(AUT_FAMILIARES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, AUT_FAMILIARES.N_IDENTIFICACION, AUT_FAMILIARES.EDAD, AUT_FAMILIARES.EDAD_A  FROM AUT_FAMILIARES WHERE AUT_FAMILIARES.COMPANIA= :KEY_COMPANIA AND AUT_FAMILIARES.DCTO_EMPLEADO= :KEY_DCTO_EMPLEADO AND AUT_FAMILIARES.SUCURSAL_EMPLEADO= :KEY_SUCURSAL_EMPLEADO AND AUT_FAMILIARES.IDENTIFICACION= :KEY_IDENTIFICACION AND AUT_FAMILIARES.SUCURSAL= :KEY_SUCURSAL AND AUT_FAMILIARES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DCTO_EMPLEADO":"$DCTO_EMPLEADO","SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","IDENTIFICACION":"$IDENTIFICACION","SUCURSAL":"$SUCURSAL","CONSECUTIVO":"$CONSECUTIVO(type:long)","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","PARENTESCO":"$PARENTESCO","NOMBRE":"$NOMBRE","FECHANCTO":"$FECHANCTO","SEXO":"$SEXO","OBSERVACIONES":"$OBSERVACIONES","POLIZA":"$POLIZA(type:boolean)","SALUD":"$SALUD(type:boolean)","PORCENTAJE":"$PORCENTAJE","OCUPACION":"$OCUPACION","TELEFONO":"$TELEFONO","POS":"$POS(type:boolean)","AUXILIO_EDUCATIVO":"$AUXILIO_EDUCATIVO(type:boolean)","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","DIRECCION":"$DIRECCION","ESTADO_ACTUAL":"$ESTADO_ACTUAL","DCTO_IDENTIDAD_A":"$DCTO_IDENTIDAD_A","PARENTESCO_A":"$PARENTESCO_A","NOMBRE_A":"$NOMBRE_A","SEXO_A":"$SEXO_A","OBSERVACIONES_A":"$OBSERVACIONES_A","POLIZA_A":"$POLIZA_A(type:boolean)","SALUD_A":"$SALUD_A(type:boolean)","PORCENTAJE_A":"$PORCENTAJE_A","OCUPACION_A":"$OCUPACION_A","TELEFONO_A":"$TELEFONO_A","POS_A":"$POS_A(type:boolean)","AUXILIO_EDUCATIVO_A":"$AUXILIO_EDUCATIVO_A(type:boolean)","APELLIDO1_A":"$APELLIDO1_A","APELLIDO2_A":"$APELLIDO2_A","DIRECCION_A":"$DIRECCION_A","ESTADO_ACTUAL_A":"$ESTADO_ACTUAL_A","ESTADO":"$ESTADO","DESTINATARIO":"$DESTINATARIO","SUCURSAL_DESTINATARIO":"$SUCURSAL_DESTINATARIO","TIPO_SOLICITUD":"$TIPO_SOLICITUD","FECHA_APROBACION":"$FECHA_APROBACION","ENVIADO":"$ENVIADO(type:boolean)","ACTUALIZADO":"$ACTUALIZADO(type:boolean)","RUTA":"$RUTA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","N_IDENTIFICACION":"$N_IDENTIFICACION","EDAD":"$EDAD(type:integer)","EDAD_A":"$EDAD_A(type:integer)"}]}}		</result>
