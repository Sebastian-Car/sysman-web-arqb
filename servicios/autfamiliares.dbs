<data name="autfamiliares" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertAutfamiliares" keyColumns="COMPANIA,DCTO_EMPLEADO,SUCURSAL_EMPLEADO,IDENTIFICACION,SUCURSAL,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO AUT_FAMILIARES (COMPANIA, DCTO_EMPLEADO, SUCURSAL_EMPLEADO, IDENTIFICACION, SUCURSAL, CONSECUTIVO, DCTO_IDENTIDAD, PARENTESCO, NOMBRE, FECHANCTO, SEXO, OBSERVACIONES, POLIZA, SALUD, PORCENTAJE, OCUPACION, TELEFONO, POS, AUXILIO_EDUCATIVO, APELLIDO1, APELLIDO2, DIRECCION, ESTADO_ACTUAL, DCTO_IDENTIDAD_A, PARENTESCO_A, NOMBRE_A, SEXO_A, OBSERVACIONES_A, POLIZA_A, SALUD_A, PORCENTAJE_A, OCUPACION_A, TELEFONO_A, POS_A, AUXILIO_EDUCATIVO_A, APELLIDO1_A, APELLIDO2_A, DIRECCION_A, ESTADO_ACTUAL_A, ESTADO, DESTINATARIO, SUCURSAL_DESTINATARIO, TIPO_SOLICITUD, FECHA_APROBACION, ENVIADO, ACTUALIZADO, RUTA, CREATED_BY, DATE_CREATED, N_IDENTIFICACION, EDAD, EDAD_A) VALUES (:COMPANIA, :DCTO_EMPLEADO, :SUCURSAL_EMPLEADO, :IDENTIFICACION, :SUCURSAL, :CONSECUTIVO, :DCTO_IDENTIDAD, :PARENTESCO, :NOMBRE, TO_DATE(:FECHANCTO,'DD/MM/YYYY HH24:MI:SS'), :SEXO, :OBSERVACIONES, :POLIZA, :SALUD, :PORCENTAJE, :OCUPACION, :TELEFONO, :POS, :AUXILIO_EDUCATIVO, :APELLIDO1, :APELLIDO2, :DIRECCION, :ESTADO_ACTUAL, :DCTO_IDENTIDAD_A, :PARENTESCO_A, :NOMBRE_A, :SEXO_A, :OBSERVACIONES_A, :POLIZA_A, :SALUD_A, :PORCENTAJE_A, :OCUPACION_A, :TELEFONO_A, :POS_A, :AUXILIO_EDUCATIVO_A, :APELLIDO1_A, :APELLIDO2_A, :DIRECCION_A, :ESTADO_ACTUAL_A, :ESTADO, :DESTINATARIO, :SUCURSAL_DESTINATARIO, :TIPO_SOLICITUD, TO_DATE(:FECHA_APROBACION,'DD/MM/YYYY HH24:MI:SS'), :ENVIADO, :ACTUALIZADO, :RUTA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :N_IDENTIFICACION, :EDAD, :EDAD_A)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DCTO_EMPLEADO":"$DCTO_EMPLEADO","KEY_SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","KEY_IDENTIFICACION":"$IDENTIFICACION","KEY_SUCURSAL":"$SUCURSAL","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="IDENTIFICACION" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="FECHANCTO" sqlType="STRING"/>
		<param defaultValue="" name="SEXO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="POLIZA" sqlType="STRING"/>
		<param defaultValue="0" name="SALUD" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE" sqlType="STRING"/>
		<param defaultValue="" name="OCUPACION" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO" sqlType="STRING"/>
