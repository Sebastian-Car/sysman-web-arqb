<data name="sprespuestamodelotipo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSprespuestamodelotipoTodosPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_RESPUESTA_MODELO_TIPO.COMPANIA, SP_RESPUESTA_MODELO_TIPO.CLASE, SP_RESPUESTA_MODELO_TIPO.CODIGO, SP_RESPUESTA_MODELO_TIPO.CONSECUTIVOCLASE, ' ' PREGUNTA, SP_RESPUESTA_MODELO_TIPO.RESPUESTA  FROM SP_RESPUESTA_MODELO_TIPO WHERE SP_RESPUESTA_MODELO_TIPO.COMPANIA = :COMPANIA AND SP_RESPUESTA_MODELO_TIPO.CLASE = :CLASE AND SP_RESPUESTA_MODELO_TIPO.CONSECUTIVOCLASE= :CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASE":"$CLASE","CODIGO":"$CODIGO(type:integer)","CONSECUTIVOCLASE":"$CONSECUTIVOCLASE","PREGUNTA":"$PREGUNTA","RESPUESTA":"$RESPUESTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sprespuestamodelotipo/todosportipo">
		<call-query href="getSprespuestamodelotipoTodosPorTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSprespuestamodelotipoPreguntasPorClase32YConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_RESPUESTA_MODELO_TIPO.COMPANIA, SP_RESPUESTA_MODELO_TIPO.CLASE, SP_RESPUESTA_MODELO_TIPO.CODIGO, SP_RESPUESTA_MODELO_TIPO.CONSECUTIVOCLASE, ' ' PREGUNTA, SP_RESPUESTA_MODELO_TIPO.RESPUESTA  FROM SP_RESPUESTA_MODELO_TIPO WHERE SP_RESPUESTA_MODELO_TIPO.COMPANIA = :COMPANIA AND SP_RESPUESTA_MODELO_TIPO.CLASE = '32' AND SP_RESPUESTA_MODELO_TIPO.CONSECUTIVOCLASE= :CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASE":"$CLASE","CODIGO":"$CODIGO(type:integer)","CONSECUTIVOCLASE":"$CONSECUTIVOCLASE","PREGUNTA":"$PREGUNTA","RESPUESTA":"$RESPUESTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sprespuestamodelotipo/preguntasporclase32yconsecutivo">
		<call-query href="getSprespuestamodelotipoPreguntasPorClase32YConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSprespuestamodelotipoConsultarExistenciaPorConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' X  FROM SP_RESPUESTA_MODELO_TIPO WHERE SP_RESPUESTA_MODELO_TIPO.COMPANIA = :COMPANIA AND SP_RESPUESTA_MODELO_TIPO.CLASE= :CLASE AND SP_RESPUESTA_MODELO_TIPO.CONSECUTIVOCLASE = :CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sprespuestamodelotipo/consultarexistenciaporconsecutivo">
		<call-query href="getSprespuestamodelotipoConsultarExistenciaPorConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="insertSprespuestamodelotipo" keyColumns="COMPANIA,CLASE,CODIGO,CONSECUTIVOCLASE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_RESPUESTA_MODELO_TIPO (COMPANIA, CLASE, CODIGO, CONSECUTIVOCLASE, RESPUESTA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASE, :CODIGO, :CONSECUTIVOCLASE, :RESPUESTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASE":"$CLASE","KEY_CODIGO":"$CODIGO(type:integer)","KEY_CONSECUTIVOCLASE":"$CONSECUTIVOCLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVOCLASE" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sprespuestamodelotipo">
		<call-query href="insertSprespuestamodelotipo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONSECUTIVOCLASE" query-param="CONSECUTIVOCLASE"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSprespuestamodelotipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_RESPUESTA_MODELO_TIPO WHERE SP_RESPUESTA_MODELO_TIPO.COMPANIA= :KEY_COMPANIA AND SP_RESPUESTA_MODELO_TIPO.CLASE= :KEY_CLASE AND SP_RESPUESTA_MODELO_TIPO.CODIGO= :KEY_CODIGO AND SP_RESPUESTA_MODELO_TIPO.CONSECUTIVOCLASE= :KEY_CONSECUTIVOCLASE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVOCLASE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sprespuestamodelotipo">
		<call-query href="deleteSprespuestamodelotipo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASE" query-param="KEY_CLASE"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CONSECUTIVOCLASE" query-param="KEY_CONSECUTIVOCLASE"/>

		</call-query>
	</resource>
	<query id="updateSprespuestamodelotipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_RESPUESTA_MODELO_TIPO SET RESPUESTA=:RESPUESTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_RESPUESTA_MODELO_TIPO.COMPANIA= :KEY_COMPANIA AND SP_RESPUESTA_MODELO_TIPO.CLASE= :KEY_CLASE AND SP_RESPUESTA_MODELO_TIPO.CODIGO= :KEY_CODIGO AND SP_RESPUESTA_MODELO_TIPO.CONSECUTIVOCLASE= :KEY_CONSECUTIVOCLASE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVOCLASE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sprespuestamodelotipo">
		<call-query href="updateSprespuestamodelotipo">
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASE" query-param="KEY_CLASE"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CONSECUTIVOCLASE" query-param="KEY_CONSECUTIVOCLASE"/>

		</call-query>
	</resource>

</data>