<data name="modelotipos" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getModelotiposPorModuloQuery"  useConfig="sysmanirisst">
		<sql>SELECT  MODELO_TIPO.CODIGO , MODELO_TIPO.NOMBRE  FROM MODELO_TIPO INNER JOIN MODELO_TIPO_APLICACION ON MODELO_TIPO.CODIGO = MODELO_TIPO_APLICACION.TIPO WHERE MODELO_TIPO_APLICACION.APLICACION=:MODULO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="modelotipos/pormodulo">
		<call-query href="getModelotiposPorModuloQuery">
			<with-param name="MODULO" query-param="MODULO"/>

		</call-query>
	</resource>
	<query id="getModelotiposPorModuloYTipoQuery"  useConfig="sysmanirisst">
		<sql>SELECT MODELO_TIPO.CODIGO, MODELO_TIPO.NOMBRE FROM MODELO_TIPO INNER JOIN MODELO_TIPO_APLICACION ON MODELO_TIPO.CODIGO = MODELO_TIPO_APLICACION.TIPO WHERE MODELO_TIPO_APLICACION.APLICACION =:MODULO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPO,' ','') ),CONCAT('',CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE (MODELO_TIPO_APLICACION.TIPO,' ','') ),'') ),1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="modelotipos/pormoduloytipo">
		<call-query href="getModelotiposPorModuloYTipoQuery">
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>

</data>