<data name="cacausacioning" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertCacausacioning" keyColumns="COMPANIA,ANO,TIPO,NUMERO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CA_CAUSACION_ING (COMPANIA, ANO, TIPO, NUMERO, CONSECUTIVO, CONCEPTO_ID, VALOR, TERCERO, SUCURSAL, AUXILIAR, REFERENCIA, FUENTE, CENTRO_COSTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO, :NUMERO, :CONSECUTIVO, :CONCEPTO_ID, :VALOR, :TERCERO, :SUCURSAL, :AUXILIAR, :REFERENCIA, :FUENTE, :CENTRO_COSTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONCEPTO_ID" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cacausacioning">
		<call-query href="insertCacausacioning">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONCEPTO_ID" query-param="CONCEPTO_ID"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteCacausacioning" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CA_CAUSACION_ING WHERE CA_CAUSACION_ING.COMPANIA= :KEY_COMPANIA AND CA_CAUSACION_ING.ANO= :KEY_ANO AND CA_CAUSACION_ING.TIPO= :KEY_TIPO AND CA_CAUSACION_ING.NUMERO= :KEY_NUMERO AND CA_CAUSACION_ING.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="cacausacioning">
		<call-query href="deleteCacausacioning">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getCacausacioningPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CA_CAUSACION_ING.COMPANIA, CA_CAUSACION_ING.ANO, CA_CAUSACION_ING.TIPO, CA_CAUSACION_ING.NUMERO, CA_CAUSACION_ING.CONSECUTIVO, CA_CAUSACION_ING.CONCEPTO_ID, CA_CONCEPTOS_ING.NOMBRE NOMBRECONCEPTO, CA_CAUSACION_ING.VALOR, CA_CAUSACION_ING.TERCERO, CA_CAUSACION_ING.SUCURSAL, CA_CAUSACION_ING.AUXILIAR, CA_CAUSACION_ING.REFERENCIA, CA_CAUSACION_ING.FUENTE, CA_CAUSACION_ING.CENTRO_COSTO FROM CA_CAUSACION_ING INNER JOIN CA_CONCEPTOS_ING ON CA_CAUSACION_ING.COMPANIA = CA_CONCEPTOS_ING.COMPANIA AND CA_CAUSACION_ING.CONCEPTO_ID = CA_CONCEPTOS_ING.CODIGO WHERE CA_CAUSACION_ING.COMPANIA = :COMPANIA AND CA_CAUSACION_ING.ANO = :ANO AND CA_CAUSACION_ING.TIPO = :TIPO AND CA_CAUSACION_ING.NUMERO = :NUMERO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN CONCEPTO_ID IS NULL THEN ' ' ELSE UPPER(CONCEPTO_ID) END) LIKE UPPER(CONCAT(:CONCEPTO_ID, '%')) AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECONCEPTO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END) LIKE UPPER(CONCAT(:FUENTE, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CONCEPTO_ID":"$CONCEPTO_ID","NOMBRECONCEPTO":"$NOMBRECONCEPTO","VALOR":"$VALOR","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE":"$FUENTE","CENTRO_COSTO":"$CENTRO_COSTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONCEPTO_ID" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cacausacioning">
		<call-query href="getCacausacioningPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONCEPTO_ID" query-param="CONCEPTO_ID"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCacausacioningNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CA_CAUSACION_ING.COMPANIA, CA_CAUSACION_ING.ANO, CA_CAUSACION_ING.TIPO, CA_CAUSACION_ING.NUMERO, CA_CAUSACION_ING.CONSECUTIVO, CA_CAUSACION_ING.CONCEPTO_ID, CA_CONCEPTOS_ING.NOMBRE NOMBRECONCEPTO, CA_CAUSACION_ING.VALOR, CA_CAUSACION_ING.TERCERO, CA_CAUSACION_ING.SUCURSAL, CA_CAUSACION_ING.AUXILIAR, CA_CAUSACION_ING.REFERENCIA, CA_CAUSACION_ING.FUENTE, CA_CAUSACION_ING.CENTRO_COSTO FROM CA_CAUSACION_ING INNER JOIN CA_CONCEPTOS_ING ON CA_CAUSACION_ING.COMPANIA = CA_CONCEPTOS_ING.COMPANIA AND CA_CAUSACION_ING.CONCEPTO_ID = CA_CONCEPTOS_ING.CODIGO WHERE CA_CAUSACION_ING.COMPANIA = :COMPANIA AND CA_CAUSACION_ING.ANO = :ANO AND CA_CAUSACION_ING.TIPO = :TIPO AND CA_CAUSACION_ING.NUMERO = :NUMERO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN CONCEPTO_ID IS NULL THEN ' ' ELSE UPPER(CONCEPTO_ID) END) LIKE UPPER(CONCAT(:CONCEPTO_ID, '%')) AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECONCEPTO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END) LIKE UPPER(CONCAT(:FUENTE, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONCEPTO_ID" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cacausacioning/numero">
		<call-query href="getCacausacioningNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONCEPTO_ID" query-param="CONCEPTO_ID"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>

		</call-query>
	</resource>
	<query id="updateCacausacioning" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CA_CAUSACION_ING SET COMPANIA=:COMPANIA, ANO=:ANO, TIPO=:TIPO, NUMERO=:NUMERO, CONSECUTIVO=:CONSECUTIVO, CONCEPTO_ID=:CONCEPTO_ID, VALOR=:VALOR, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, AUXILIAR=:AUXILIAR, REFERENCIA=:REFERENCIA, FUENTE=:FUENTE, CENTRO_COSTO=:CENTRO_COSTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CA_CAUSACION_ING.COMPANIA= :KEY_COMPANIA AND CA_CAUSACION_ING.ANO= :KEY_ANO AND CA_CAUSACION_ING.TIPO= :KEY_TIPO AND CA_CAUSACION_ING.NUMERO= :KEY_NUMERO AND CA_CAUSACION_ING.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONCEPTO_ID" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cacausacioning">
		<call-query href="updateCacausacioning">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONCEPTO_ID" query-param="CONCEPTO_ID"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>