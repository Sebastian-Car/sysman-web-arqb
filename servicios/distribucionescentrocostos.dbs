<data name="distribucionescentrocostos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDistribucionescentrocostosGeneralQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTRIBUCION_CENTROCOSTO.COMPANIA, DISTRIBUCION_CENTROCOSTO.ANO, DISTRIBUCION_CENTROCOSTO.CENTRO_COSTO, DISTRIBUCION_CENTROCOSTO.PORCENTAJE, (SELECT NOMBRE FROM CENTRO_COSTO WHERE COMPANIA = DISTRIBUCION_CENTROCOSTO.COMPANIA AND ANO = DISTRIBUCION_CENTROCOSTO.ANO AND CODIGO = DISTRIBUCION_CENTROCOSTO.CENTRO_COSTO ) NOMBRE_CCTO  FROM DISTRIBUCION_CENTROCOSTO WHERE COMPANIA=:COMPANIA AND ANO=:ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CENTRO_COSTO":"$CENTRO_COSTO","PORCENTAJE":"$PORCENTAJE","NOMBRE_CCTO":"$NOMBRE_CCTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="distribucionescentrocostos/general">
		<call-query href="getDistribucionescentrocostosGeneralQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertDistribucionescentrocostos" keyColumns="COMPANIA,ANO,CENTRO_COSTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DISTRIBUCION_CENTROCOSTO (COMPANIA, ANO, CENTRO_COSTO, PORCENTAJE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CENTRO_COSTO, :PORCENTAJE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CENTRO_COSTO":"$CENTRO_COSTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="distribucionescentrocostos">
		<call-query href="insertDistribucionescentrocostos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDistribucionescentrocostos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DISTRIBUCION_CENTROCOSTO WHERE DISTRIBUCION_CENTROCOSTO.COMPANIA= :KEY_COMPANIA AND DISTRIBUCION_CENTROCOSTO.ANO= :KEY_ANO AND DISTRIBUCION_CENTROCOSTO.CENTRO_COSTO= :KEY_CENTRO_COSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="distribucionescentrocostos">
		<call-query href="deleteDistribucionescentrocostos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>

		</call-query>
	</resource>
	<query id="getDistribucionescentrocostosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTRIBUCION_CENTROCOSTO.COMPANIA, DISTRIBUCION_CENTROCOSTO.ANO, DISTRIBUCION_CENTROCOSTO.CENTRO_COSTO, DISTRIBUCION_CENTROCOSTO.PORCENTAJE, (SELECT NOMBRE FROM CENTRO_COSTO WHERE COMPANIA = DISTRIBUCION_CENTROCOSTO.COMPANIA AND ANO = DISTRIBUCION_CENTROCOSTO.ANO AND CODIGO = DISTRIBUCION_CENTROCOSTO.CENTRO_COSTO ) NOMBRE_CCTO  FROM DISTRIBUCION_CENTROCOSTO WHERE COMPANIA=:COMPANIA AND ANO=:ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CENTRO_COSTO":"$CENTRO_COSTO","PORCENTAJE":"$PORCENTAJE","NOMBRE_CCTO":"$NOMBRE_CCTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="distribucionescentrocostos">
		<call-query href="getDistribucionescentrocostosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateDistribucionescentrocostos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DISTRIBUCION_CENTROCOSTO SET ANO=:ANO, CENTRO_COSTO=:CENTRO_COSTO, PORCENTAJE=:PORCENTAJE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DISTRIBUCION_CENTROCOSTO.COMPANIA= :KEY_COMPANIA AND DISTRIBUCION_CENTROCOSTO.ANO= :KEY_ANO AND DISTRIBUCION_CENTROCOSTO.CENTRO_COSTO= :KEY_CENTRO_COSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="distribucionescentrocostos">
		<call-query href="updateDistribucionescentrocostos">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>

		</call-query>
	</resource>

</data>