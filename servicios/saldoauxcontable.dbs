<data name="saldoauxcontable" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSaldoauxcontableDatosConciliacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SALDO_CONCILIACION ,(TO_CHAR(FECHA_CONCILIACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONCILIACION, OBSERV_CONCILIACION  FROM SALDO_AUX_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODCUENTA AND TERCERO = :TERCERO AND SUCURSAL = :SUCURSAL AND CENTRO_COSTO = :CENTRO_COSTO AND AUXILIAR = :AUXILIAR AND FUENTE_RECURSO = :FUENTE_RECURSO AND REFERENCIA = :REFERENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALDO_CONCILIACION":"$SALDO_CONCILIACION","FECHA_CONCILIACION":"$FECHA_CONCILIACION","OBSERV_CONCILIACION":"$OBSERV_CONCILIACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="saldoauxcontable/datosconciliacion">
		<call-query href="getSaldoauxcontableDatosConciliacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>

		</call-query>
	</resource>
	<query id="updateSaldoauxcontableDatosConciliacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SALDO_AUX_CONTABLE    SET FECHA_CONCILIACION  = TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS') ,        SALDO_CONCILIACION  = TO_NUMBER(:SALDOEXTRACTO) ,        OBSERV_CONCILIACION = :OBSERVACIONES,        DATE_MODIFIED       =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') ,        MODIFIED_BY         =:MODIFIED_BY  WHERE COMPANIA            = :COMPANIA    AND ANO                 = :ANO    AND CODIGO              = :CODCUENTA    AND TERCERO = :TERCERO    AND SUCURSAL = :SUCURSAL    AND CENTRO_COSTO = :CENTRO_COSTO    AND AUXILIAR = :AUXILIAR    AND FUENTE_RECURSO = :FUENTE_RECURSO    AND REFERENCIA = :REFERENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="SALDOEXTRACTO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="saldoauxcontable/datosconciliacion">
		<call-query href="updateSaldoauxcontableDatosConciliacion">
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="SALDOEXTRACTO" query-param="SALDOEXTRACTO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>

		</call-query>
	</resource>
	<query id="getSaldoauxcontableAjustePorMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  (CASE :MES WHEN '0' THEN AJUSTE0 WHEN '1' THEN AJUSTE1 WHEN '2' THEN AJUSTE2 WHEN '3' THEN AJUSTE3 WHEN '4' THEN AJUSTE4 WHEN '5' THEN AJUSTE5 WHEN '6' THEN AJUSTE6 WHEN '7' THEN AJUSTE7 WHEN '8' THEN AJUSTE8 WHEN '9' THEN AJUSTE9 WHEN '10' THEN AJUSTE10 WHEN '11' THEN AJUSTE11 WHEN '12' THEN AJUSTE12 WHEN '13' THEN AJUSTE13 END) AJUSTE  FROM SALDO_AUX_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODCUENTA AND TERCERO = :TERCERO AND SUCURSAL = :SUCURSAL AND CENTRO_COSTO = :CENTRO_COSTO AND AUXILIAR = :AUXILIAR AND FUENTE_RECURSO = :FUENTE_RECURSO AND REFERENCIA = :REFERENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"AJUSTE":"$AJUSTE"}]}}		</result>
		<param name="MES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="saldoauxcontable/ajustepormes">
		<call-query href="getSaldoauxcontableAjustePorMesQuery">
			<with-param name="MES" query-param="MES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>

		</call-query>
	</resource>
	<query id="updateSaldoauxcontableAjusteMes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SALDO_AUX_CONTABLE  SET AJUSTE0 =  CASE TO_CHAR(:MES) WHEN '0' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE0 END,  AJUSTE1 = CASE TO_CHAR(:MES) WHEN '1' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE1 END,  AJUSTE2 = CASE TO_CHAR(:MES) WHEN '2' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE2 END,    AJUSTE3 = CASE TO_CHAR(:MES) WHEN '3' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE3 END,  AJUSTE4 = CASE TO_CHAR(:MES) WHEN '4' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE4 END,   AJUSTE5 = CASE TO_CHAR(:MES) WHEN '5' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE5 END,     AJUSTE6 = CASE TO_CHAR(:MES) WHEN '6' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE6 END,    AJUSTE7 = CASE TO_CHAR(:MES) WHEN '7' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE7 END,    AJUSTE8 = CASE TO_CHAR(:MES) WHEN '8' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE8 END,    AJUSTE9 = CASE TO_CHAR(:MES) WHEN '9' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE9 END,    AJUSTE10 = CASE TO_CHAR(:MES) WHEN '10' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE10 END,   AJUSTE11 = CASE TO_CHAR(:MES) WHEN '11' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE11 END,   AJUSTE12 = CASE TO_CHAR(:MES) WHEN '12' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE12 END,   AJUSTE13 = CASE TO_CHAR(:MES) WHEN '13' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE13 END,  DATE_MODIFIED=TO_DATE(:DATE_MODIFIED, 'DD/MM/YYYY HH24:MI:SS') ,  MODIFIED_BY=:MODIFIED_BY   WHERE COMPANIA            = :COMPANIA      AND ANO                 = :ANO      AND CODIGO              = :CODCUENTA      AND TERCERO = :TERCERO      AND SUCURSAL = :SUCURSAL      AND CENTRO_COSTO = :CENTRO_COSTO      AND AUXILIAR = :AUXILIAR      AND FUENTE_RECURSO = :FUENTE_RECURSO      AND REFERENCIA = :REFERENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MES" sqlType="STRING"/>
		<param name="SALDOEXTRACTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="saldoauxcontable/ajustemes">
		<call-query href="updateSaldoauxcontableAjusteMes">
			<with-param name="MES" query-param="MES"/>
			<with-param name="SALDOEXTRACTO" query-param="SALDOEXTRACTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>

		</call-query>
	</resource>
	<query id="getSaldoauxcontableListsaldoauxcontableQuery"  useConfig="sysmandsunist">
		<sql>SELECT S.COMPANIA, S.ANO, S.CODIGO, S.CENTRO_COSTO, SUM(S.NETO1) AS NETO1, SUM(S.NETO2) AS NETO2, SUM(S.NETO3) AS NETO3, SUM(S.NETO4) AS NETO4, SUM(S.NETO5) AS NETO5, SUM(S.NETO6) AS NETO6, SUM(S.NETO7) AS NETO7, SUM(S.NETO8) AS NETO8, SUM(S.NETO9) AS NETO9, SUM(S.NETO10) AS NETO10, SUM(S.NETO11) AS NETO11, SUM(S.NETO12) AS NETO12 FROM SALDO_AUX_CONTABLE S INNER JOIN PLAN_CONTABLE P ON P.COMPANIA = S.COMPANIA AND P.ANO = S.ANO AND P.CODIGO = S.CODIGO INNER JOIN CLASECUENTA CC ON CC.CODIGO = P.CLASECUENTA WHERE S.COMPANIA = :COMPANIA AND S.ANO = :ANO AND CC.CODIGO IN ('G','V','R') GROUP BY S.COMPANIA, S.ANO, S.CODIGO, S.CENTRO_COSTO ORDER BY CODIGO, CENTRO_COSTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CENTRO_COSTO":"$CENTRO_COSTO","NETO1":"$NETO1","NETO2":"$NETO2","NETO3":"$NETO3","NETO4":"$NETO4","NETO5":"$NETO5","NETO6":"$NETO6","NETO7":"$NETO7","NETO8":"$NETO8","NETO9":"$NETO9","NETO10":"$NETO10","NETO11":"$NETO11","NETO12":"$NETO12"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="saldoauxcontable/listsaldoauxcontable">
		<call-query href="getSaldoauxcontableListsaldoauxcontableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>

</data>