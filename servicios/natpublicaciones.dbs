<data name="natpublicaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatpublicaciones" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,PU_CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_PUBLICACIONES (COMPANIA, DP_NUMEDOCU, SUCURSAL, PU_CONSECUTIVO, PB_CODIGOPERSONA, PU_TIPO, PU_DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :PU_CONSECUTIVO, :PB_CODIGOPERSONA, :PU_TIPO, :PU_DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_PU_CONSECUTIVO":"$PU_CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PU_CONSECUTIVO" sqlType="STRING"/>
		<param name="PB_CODIGOPERSONA" sqlType="STRING"/>
		<param defaultValue="" name="PU_TIPO" sqlType="STRING"/>
		<param defaultValue="" name="PU_DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natpublicaciones">
		<call-query href="insertNatpublicaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PU_CONSECUTIVO" query-param="PU_CONSECUTIVO"/>
			<with-param name="PB_CODIGOPERSONA" query-param="PB_CODIGOPERSONA"/>
			<with-param name="PU_TIPO" query-param="PU_TIPO"/>
			<with-param name="PU_DESCRIPCION" query-param="PU_DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatpublicaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_PUBLICACIONES WHERE NAT_PUBLICACIONES.COMPANIA= :KEY_COMPANIA AND NAT_PUBLICACIONES.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_PUBLICACIONES.SUCURSAL= :KEY_SUCURSAL AND NAT_PUBLICACIONES.PU_CONSECUTIVO= :KEY_PU_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_PU_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natpublicaciones">
		<call-query href="deleteNatpublicaciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_PU_CONSECUTIVO" query-param="KEY_PU_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getNatpublicacionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, DP_NUMEDOCU , SUCURSAL, PU_CONSECUTIVO, PB_CODIGOPERSONA, PU_TIPO, PU_DESCRIPCION  FROM NAT_PUBLICACIONES WHERE COMPANIA = :COMPANIA AND DP_NUMEDOCU = :DP_NUMEDOCU AND SUCURSAL = :SUCURSAL) WHERE (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN PU_CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(PU_CONSECUTIVO) END)  LIKE UPPER( '%' || :PU_CONSECUTIVO || '%')  AND (CASE WHEN PB_CODIGOPERSONA IS NULL THEN ' ' ELSE UPPER(PB_CODIGOPERSONA) END)  LIKE UPPER( '%' || :PB_CODIGOPERSONA || '%')  AND (CASE WHEN PU_TIPO IS NULL THEN ' ' ELSE UPPER(PU_TIPO) END)  LIKE UPPER( '%' || :PU_TIPO || '%')  AND (CASE WHEN PU_DESCRIPCION IS NULL THEN ' ' ELSE UPPER(PU_DESCRIPCION) END)  LIKE UPPER( '%' || :PU_DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","PU_CONSECUTIVO":"$PU_CONSECUTIVO","PB_CODIGOPERSONA":"$PB_CODIGOPERSONA","PU_TIPO":"$PU_TIPO","PU_DESCRIPCION":"$PU_DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PU_CONSECUTIVO" sqlType="STRING"/>
		<param name="PB_CODIGOPERSONA" sqlType="STRING"/>
		<param name="PU_TIPO" sqlType="STRING"/>
		<param name="PU_DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natpublicaciones">
		<call-query href="getNatpublicacionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PU_CONSECUTIVO" query-param="PU_CONSECUTIVO"/>
			<with-param name="PB_CODIGOPERSONA" query-param="PB_CODIGOPERSONA"/>
			<with-param name="PU_TIPO" query-param="PU_TIPO"/>
			<with-param name="PU_DESCRIPCION" query-param="PU_DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatpublicacionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, DP_NUMEDOCU , SUCURSAL, PU_CONSECUTIVO, PB_CODIGOPERSONA, PU_TIPO, PU_DESCRIPCION  FROM NAT_PUBLICACIONES WHERE COMPANIA = :COMPANIA AND DP_NUMEDOCU = :DP_NUMEDOCU AND SUCURSAL = :SUCURSAL) WHERE (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN PU_CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(PU_CONSECUTIVO) END)  LIKE UPPER( '%' || :PU_CONSECUTIVO || '%')  AND (CASE WHEN PB_CODIGOPERSONA IS NULL THEN ' ' ELSE UPPER(PB_CODIGOPERSONA) END)  LIKE UPPER( '%' || :PB_CODIGOPERSONA || '%')  AND (CASE WHEN PU_TIPO IS NULL THEN ' ' ELSE UPPER(PU_TIPO) END)  LIKE UPPER( '%' || :PU_TIPO || '%')  AND (CASE WHEN PU_DESCRIPCION IS NULL THEN ' ' ELSE UPPER(PU_DESCRIPCION) END)  LIKE UPPER( '%' || :PU_DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PU_CONSECUTIVO" sqlType="STRING"/>
		<param name="PB_CODIGOPERSONA" sqlType="STRING"/>
		<param name="PU_TIPO" sqlType="STRING"/>
		<param name="PU_DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natpublicaciones/numero">
		<call-query href="getNatpublicacionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PU_CONSECUTIVO" query-param="PU_CONSECUTIVO"/>
			<with-param name="PB_CODIGOPERSONA" query-param="PB_CODIGOPERSONA"/>
			<with-param name="PU_TIPO" query-param="PU_TIPO"/>
			<with-param name="PU_DESCRIPCION" query-param="PU_DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateNatpublicaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_PUBLICACIONES SET PU_TIPO=:PU_TIPO, PU_DESCRIPCION=:PU_DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_PUBLICACIONES.COMPANIA= :KEY_COMPANIA AND NAT_PUBLICACIONES.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_PUBLICACIONES.SUCURSAL= :KEY_SUCURSAL AND NAT_PUBLICACIONES.PU_CONSECUTIVO= :KEY_PU_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PU_TIPO" sqlType="STRING"/>
		<param name="PU_DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_PU_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natpublicaciones">
		<call-query href="updateNatpublicaciones">
			<with-param name="PU_TIPO" query-param="PU_TIPO"/>
			<with-param name="PU_DESCRIPCION" query-param="PU_DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_PU_CONSECUTIVO" query-param="KEY_PU_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>