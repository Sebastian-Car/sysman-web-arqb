<data name="reportes" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getReportesPagTodosPorCompaniaYModuloQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO_REPORTE, NOMBRE_REPORTE, REPORTES.CODIGO_CONSULTA  FROM REPORTES INNER JOIN CONSULTAS_RP ON CONSULTAS_RP.COMPANIA = REPORTES.COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA = REPORTES.CODIGO_CONSULTA WHERE REPORTES.COMPANIA = :COMPANIA AND CONSULTAS_RP.MODULO = :MODULO) WHERE (CASE WHEN CODIGO_REPORTE IS NULL THEN ' ' ELSE UPPER(CODIGO_REPORTE) END)  LIKE UPPER(:CODIGO_REPORTE || '%')  AND (CASE WHEN NOMBRE_REPORTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_REPORTE) END)  LIKE UPPER( '%' || :NOMBRE_REPORTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_REPORTE":"$CODIGO_REPORTE","NOMBRE_REPORTE":"$NOMBRE_REPORTE","CODIGO_CONSULTA":"$CODIGO_CONSULTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="reportes/todosporcompaniaymodulo/pag">
		<call-query href="getReportesPagTodosPorCompaniaYModuloQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getReportesNumTodosPorCompaniaYModuloQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO_REPORTE, NOMBRE_REPORTE, REPORTES.CODIGO_CONSULTA  FROM REPORTES INNER JOIN CONSULTAS_RP ON CONSULTAS_RP.COMPANIA = REPORTES.COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA = REPORTES.CODIGO_CONSULTA WHERE REPORTES.COMPANIA = :COMPANIA AND CONSULTAS_RP.MODULO = :MODULO) WHERE (CASE WHEN CODIGO_REPORTE IS NULL THEN ' ' ELSE UPPER(CODIGO_REPORTE) END)  LIKE UPPER(:CODIGO_REPORTE || '%')  AND (CASE WHEN NOMBRE_REPORTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_REPORTE) END)  LIKE UPPER( '%' || :NOMBRE_REPORTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reportes/todosporcompaniaymodulo/num">
		<call-query href="getReportesNumTodosPorCompaniaYModuloQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>

		</call-query>
	</resource>
	<query id="getReportesPagListadoReportesYConsultasQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  REPORTES.CODIGO_REPORTE, REPORTES.NOMBRE_REPORTE, CONSULTAS_RP.NOMBRE_CONSULTA  FROM REPORTES INNER JOIN CONSULTAS_RP ON CONSULTAS_RP.COMPANIA = REPORTES.COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA = REPORTES.CODIGO_CONSULTA WHERE REPORTES.COMPANIA = :COMPANIA AND CONSULTAS_RP.MODULO = :MODULO ORDER BY REPORTES.CODIGO_REPORTE) WHERE (CASE WHEN CODIGO_REPORTE IS NULL THEN ' ' ELSE UPPER(CODIGO_REPORTE) END)  LIKE UPPER(:CODIGO_REPORTE || '%')  AND (CASE WHEN NOMBRE_REPORTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_REPORTE) END)  LIKE UPPER( '%' || :NOMBRE_REPORTE || '%')  AND (CASE WHEN NOMBRE_CONSULTA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONSULTA) END)  LIKE UPPER( '%' || :NOMBRE_CONSULTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_REPORTE":"$CODIGO_REPORTE","NOMBRE_REPORTE":"$NOMBRE_REPORTE","NOMBRE_CONSULTA":"$NOMBRE_CONSULTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="reportes/listadoreportesyconsultas/pag">
		<call-query href="getReportesPagListadoReportesYConsultasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getReportesNumListadoReportesYConsultasQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  REPORTES.CODIGO_REPORTE, REPORTES.NOMBRE_REPORTE, CONSULTAS_RP.NOMBRE_CONSULTA  FROM REPORTES INNER JOIN CONSULTAS_RP ON CONSULTAS_RP.COMPANIA = REPORTES.COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA = REPORTES.CODIGO_CONSULTA WHERE REPORTES.COMPANIA = :COMPANIA AND CONSULTAS_RP.MODULO = :MODULO ORDER BY REPORTES.CODIGO_REPORTE) WHERE (CASE WHEN CODIGO_REPORTE IS NULL THEN ' ' ELSE UPPER(CODIGO_REPORTE) END)  LIKE UPPER(:CODIGO_REPORTE || '%')  AND (CASE WHEN NOMBRE_REPORTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_REPORTE) END)  LIKE UPPER( '%' || :NOMBRE_REPORTE || '%')  AND (CASE WHEN NOMBRE_CONSULTA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONSULTA) END)  LIKE UPPER( '%' || :NOMBRE_CONSULTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reportes/listadoreportesyconsultas/num">
		<call-query href="getReportesNumListadoReportesYConsultasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>

		</call-query>
	</resource>
	<query id="getReportesCantidadDeParametrosQuery"  useConfig="sysmanirisst">
		<sql>SELECT  COUNT(1) CANTIDAD  FROM REPORTES INNER JOIN D_PARAMETROS ON REPORTES.COMPANIA = D_PARAMETROS.COMPANIA AND REPORTES.CODIGO_REPORTE = D_PARAMETROS.CODIGO_REPORTE WHERE REPORTES.COMPANIA = :COMPANIA AND REPORTES.CODIGO_REPORTE = :CODIGO_REPORTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reportes/cantidaddeparametros">
		<call-query href="getReportesCantidadDeParametrosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>

		</call-query>
	</resource>
	<query id="getReportesCondicionYConsultaPorReporteQuery"  useConfig="sysmanirisst">
		<sql>SELECT  CONDICION, CODIGO_CONSULTA  FROM REPORTES WHERE COMPANIA = :COMPANIA AND CODIGO_REPORTE = :REPORTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONDICION":"$CONDICION","CODIGO_CONSULTA":"$CODIGO_CONSULTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="REPORTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reportes/condicionyconsultaporreporte">
		<call-query href="getReportesCondicionYConsultaPorReporteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="REPORTE" query-param="REPORTE"/>

		</call-query>
	</resource>
	<query id="insertReportes" keyColumns="CODIGO_REPORTE,COMPANIA" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO REPORTES (COMPANIA, CODIGO_REPORTE, CODIGO_CONSULTA, NOMBRE_REPORTE, RUTA_REPORTE, CONDICION, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO_REPORTE, :CODIGO_CONSULTA, :NOMBRE_REPORTE, :RUTA_REPORTE, :CONDICION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGO_REPORTE":"$CODIGO_REPORTE","KEY_COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_REPORTE" sqlType="STRING"/>
		<param defaultValue="" name="CONDICION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="reportes">
		<call-query href="insertReportes">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>
			<with-param name="RUTA_REPORTE" query-param="RUTA_REPORTE"/>
			<with-param name="CONDICION" query-param="CONDICION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteReportes" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM REPORTES WHERE REPORTES.CODIGO_REPORTE= :KEY_CODIGO_REPORTE AND REPORTES.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGO_REPORTE" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="reportes">
		<call-query href="deleteReportes">
			<with-param name="KEY_CODIGO_REPORTE" query-param="KEY_CODIGO_REPORTE"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>
	<query id="getReportesPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  REPORTES.COMPANIA, REPORTES.CODIGO_REPORTE, REPORTES.NOMBRE_REPORTE, CONSULTAS_RP.NOMBRE_CONSULTA  FROM REPORTES INNER JOIN CONSULTAS_RP ON CONSULTAS_RP.COMPANIA = REPORTES.COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA = REPORTES.CODIGO_CONSULTA WHERE REPORTES.COMPANIA = :COMPANIA AND CONSULTAS_RP.MODULO = :MODULO) WHERE (CASE WHEN CODIGO_REPORTE IS NULL THEN ' ' ELSE UPPER(CODIGO_REPORTE) END)  LIKE UPPER(:CODIGO_REPORTE || '%')  AND (CASE WHEN NOMBRE_REPORTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_REPORTE) END)  LIKE UPPER( '%' || :NOMBRE_REPORTE || '%')  AND (CASE WHEN NOMBRE_CONSULTA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONSULTA) END)  LIKE UPPER( '%' || :NOMBRE_CONSULTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_REPORTE":"$CODIGO_REPORTE","NOMBRE_REPORTE":"$NOMBRE_REPORTE","NOMBRE_CONSULTA":"$NOMBRE_CONSULTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="reportes">
		<call-query href="getReportesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getReportesNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  REPORTES.COMPANIA, REPORTES.CODIGO_REPORTE, REPORTES.NOMBRE_REPORTE, CONSULTAS_RP.NOMBRE_CONSULTA  FROM REPORTES INNER JOIN CONSULTAS_RP ON CONSULTAS_RP.COMPANIA = REPORTES.COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA = REPORTES.CODIGO_CONSULTA WHERE REPORTES.COMPANIA = :COMPANIA AND CONSULTAS_RP.MODULO = :MODULO) WHERE (CASE WHEN CODIGO_REPORTE IS NULL THEN ' ' ELSE UPPER(CODIGO_REPORTE) END)  LIKE UPPER(:CODIGO_REPORTE || '%')  AND (CASE WHEN NOMBRE_REPORTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_REPORTE) END)  LIKE UPPER( '%' || :NOMBRE_REPORTE || '%')  AND (CASE WHEN NOMBRE_CONSULTA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONSULTA) END)  LIKE UPPER( '%' || :NOMBRE_CONSULTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reportes/numero">
		<call-query href="getReportesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>

		</call-query>
	</resource>
	<query id="getReportesRegistroQuery"  useConfig="sysmanirisst">
		<sql>SELECT  REPORTES.COMPANIA, REPORTES.CODIGO_REPORTE, REPORTES.CODIGO_CONSULTA, REPORTES.NOMBRE_REPORTE, REPORTES.RUTA_REPORTE, CONDICION, REPORTES.CREATED_BY,(TO_CHAR(REPORTES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, REPORTES.MODIFIED_BY,(TO_CHAR(REPORTES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CONSULTAS_RP.NOMBRE_CONSULTA  FROM REPORTES INNER JOIN CONSULTAS_RP ON CONSULTAS_RP.COMPANIA = REPORTES.COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA = REPORTES.CODIGO_CONSULTA WHERE REPORTES.CODIGO_REPORTE= :KEY_CODIGO_REPORTE AND REPORTES.COMPANIA= :KEY_COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_REPORTE":"$CODIGO_REPORTE","CODIGO_CONSULTA":"$CODIGO_CONSULTA","NOMBRE_REPORTE":"$NOMBRE_REPORTE","RUTA_REPORTE":"$RUTA_REPORTE","CONDICION":"$CONDICION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE_CONSULTA":"$NOMBRE_CONSULTA"}]}}		</result>
		<param name="KEY_CODIGO_REPORTE" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reportes/data">
		<call-query href="getReportesRegistroQuery">
			<with-param name="KEY_CODIGO_REPORTE" query-param="KEY_CODIGO_REPORTE"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateReportes" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE REPORTES SET COMPANIA=:COMPANIA, CODIGO_REPORTE=:CODIGO_REPORTE, CODIGO_CONSULTA=:CODIGO_CONSULTA, NOMBRE_REPORTE=:NOMBRE_REPORTE, RUTA_REPORTE=:RUTA_REPORTE, CONDICION=:CONDICION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE REPORTES.CODIGO_REPORTE= :KEY_CODIGO_REPORTE AND REPORTES.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_REPORTE" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_REPORTE" sqlType="STRING"/>
		<param name="RUTA_REPORTE" sqlType="STRING"/>
		<param name="CONDICION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_CODIGO_REPORTE" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="reportes">
		<call-query href="updateReportes">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_REPORTE" query-param="CODIGO_REPORTE"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="NOMBRE_REPORTE" query-param="NOMBRE_REPORTE"/>
			<with-param name="RUTA_REPORTE" query-param="RUTA_REPORTE"/>
			<with-param name="CONDICION" query-param="CONDICION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_CODIGO_REPORTE" query-param="KEY_CODIGO_REPORTE"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>

</data>