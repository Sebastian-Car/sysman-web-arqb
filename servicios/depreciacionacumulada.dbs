<data name="depreciacionacumulada" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDepreciacionacumulada" keyColumns="COMPANIA,ELEMENTO,SERIE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DEPRECIACION_ACUMULADA (COMPANIA, ELEMENTO, SERIE, PERIODO, VALOR_ACUMULADO, VALOR_LIBROS, NIIF_VLRLIBROS, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ELEMENTO, :SERIE, TO_DATE(:PERIODO,'DD/MM/YYYY HH24:MI:SS'), :VALOR_ACUMULADO, :VALOR_LIBROS, :NIIF_VLRLIBROS, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ELEMENTO":"$ELEMENTO","KEY_SERIE":"$SERIE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param defaultValue="" name="PERIODO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_ACUMULADO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_LIBROS" sqlType="STRING"/>
		<param defaultValue="" name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="depreciacionacumulada">
		<call-query href="insertDepreciacionacumulada">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="VALOR_ACUMULADO" query-param="VALOR_ACUMULADO"/>
			<with-param name="VALOR_LIBROS" query-param="VALOR_LIBROS"/>
			<with-param name="NIIF_VLRLIBROS" query-param="NIIF_VLRLIBROS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDepreciacionacumulada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DEPRECIACION_ACUMULADA WHERE DEPRECIACION_ACUMULADA.COMPANIA= :KEY_COMPANIA AND DEPRECIACION_ACUMULADA.ELEMENTO= :KEY_ELEMENTO AND DEPRECIACION_ACUMULADA.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="depreciacionacumulada">
		<call-query href="deleteDepreciacionacumulada">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getDepreciacionacumuladaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DA.COMPANIA, DA.ELEMENTO, I.NOMBRELARGO NOMBREELEMENTO, DA.SERIE, D.VALOR VALOR_HISTORICO, D.NIIF_VIDA_UTIL VIDA_UTIL,(TO_CHAR(DA.PERIODO,'DD/MM/YYYY HH24:MI:SS')) PERIODO, DA.VALOR_ACUMULADO, DA.VALOR_LIBROS, DA.OBSERVACIONES, DA.NIIF_VLRLIBROS FROM DEPRECIACION_ACUMULADA DA INNER JOIN INVENTARIO I ON I.COMPANIA = DA.COMPANIA AND I.CODIGOELEMENTO = DA.ELEMENTO INNER JOIN DEVOLUTIVO D ON D.COMPANIA = DA.COMPANIA AND D.ELEMENTO = DA.ELEMENTO AND D.SERIE = DA.SERIE WHERE DA.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN NOMBREELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREELEMENTO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR_HISTORICO IS NULL THEN ' ' ELSE UPPER(VALOR_HISTORICO) END) LIKE UPPER(CONCAT(:VALOR_HISTORICO, '%')) AND (CASE WHEN VIDA_UTIL IS NULL THEN ' ' ELSE UPPER(VIDA_UTIL) END) LIKE UPPER(CONCAT(:VIDA_UTIL, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN VALOR_ACUMULADO IS NULL THEN ' ' ELSE UPPER(VALOR_ACUMULADO) END) LIKE UPPER(CONCAT(:VALOR_ACUMULADO, '%')) AND (CASE WHEN VALOR_LIBROS IS NULL THEN ' ' ELSE UPPER(VALOR_LIBROS) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_LIBROS), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","NOMBREELEMENTO":"$NOMBREELEMENTO","SERIE":"$SERIE","VALOR_HISTORICO":"$VALOR_HISTORICO","VIDA_UTIL":"$VIDA_UTIL","PERIODO":"$PERIODO","VALOR_ACUMULADO":"$VALOR_ACUMULADO","VALOR_LIBROS":"$VALOR_LIBROS","OBSERVACIONES":"$OBSERVACIONES","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBREELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR_HISTORICO" sqlType="STRING"/>
		<param name="VIDA_UTIL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="VALOR_ACUMULADO" sqlType="STRING"/>
		<param name="VALOR_LIBROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="depreciacionacumulada">
		<call-query href="getDepreciacionacumuladaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBREELEMENTO" query-param="NOMBREELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="VALOR_HISTORICO" query-param="VALOR_HISTORICO"/>
			<with-param name="VIDA_UTIL" query-param="VIDA_UTIL"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="VALOR_ACUMULADO" query-param="VALOR_ACUMULADO"/>
			<with-param name="VALOR_LIBROS" query-param="VALOR_LIBROS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDepreciacionacumuladaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DA.COMPANIA, DA.ELEMENTO, I.NOMBRELARGO NOMBREELEMENTO, DA.SERIE, D.VALOR VALOR_HISTORICO, D.NIIF_VIDA_UTIL VIDA_UTIL,(TO_CHAR(DA.PERIODO,'DD/MM/YYYY HH24:MI:SS')) PERIODO, DA.VALOR_ACUMULADO, DA.VALOR_LIBROS, DA.OBSERVACIONES, DA.NIIF_VLRLIBROS FROM DEPRECIACION_ACUMULADA DA INNER JOIN INVENTARIO I ON I.COMPANIA = DA.COMPANIA AND I.CODIGOELEMENTO = DA.ELEMENTO INNER JOIN DEVOLUTIVO D ON D.COMPANIA = DA.COMPANIA AND D.ELEMENTO = DA.ELEMENTO AND D.SERIE = DA.SERIE WHERE DA.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN NOMBREELEMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREELEMENTO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN VALOR_HISTORICO IS NULL THEN ' ' ELSE UPPER(VALOR_HISTORICO) END) LIKE UPPER(CONCAT(:VALOR_HISTORICO, '%')) AND (CASE WHEN VIDA_UTIL IS NULL THEN ' ' ELSE UPPER(VIDA_UTIL) END) LIKE UPPER(CONCAT(:VIDA_UTIL, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN VALOR_ACUMULADO IS NULL THEN ' ' ELSE UPPER(VALOR_ACUMULADO) END) LIKE UPPER(CONCAT(:VALOR_ACUMULADO, '%')) AND (CASE WHEN VALOR_LIBROS IS NULL THEN ' ' ELSE UPPER(VALOR_LIBROS) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_LIBROS), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBREELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="VALOR_HISTORICO" sqlType="STRING"/>
		<param name="VIDA_UTIL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="VALOR_ACUMULADO" sqlType="STRING"/>
		<param name="VALOR_LIBROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciacionacumulada/numero">
		<call-query href="getDepreciacionacumuladaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBREELEMENTO" query-param="NOMBREELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="VALOR_HISTORICO" query-param="VALOR_HISTORICO"/>
			<with-param name="VIDA_UTIL" query-param="VIDA_UTIL"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="VALOR_ACUMULADO" query-param="VALOR_ACUMULADO"/>
			<with-param name="VALOR_LIBROS" query-param="VALOR_LIBROS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="updateDepreciacionacumulada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEPRECIACION_ACUMULADA SET COMPANIA=:COMPANIA, ELEMENTO=:ELEMENTO, SERIE=:SERIE, PERIODO=TO_DATE(:PERIODO,'DD/MM/YYYY HH24:MI:SS'), VALOR_ACUMULADO=:VALOR_ACUMULADO, VALOR_LIBROS=:VALOR_LIBROS, NIIF_VLRLIBROS=:NIIF_VLRLIBROS, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEPRECIACION_ACUMULADA.COMPANIA= :KEY_COMPANIA AND DEPRECIACION_ACUMULADA.ELEMENTO= :KEY_ELEMENTO AND DEPRECIACION_ACUMULADA.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="VALOR_ACUMULADO" sqlType="STRING"/>
		<param name="VALOR_LIBROS" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="depreciacionacumulada">
		<call-query href="updateDepreciacionacumulada">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="VALOR_ACUMULADO" query-param="VALOR_ACUMULADO"/>
			<with-param name="VALOR_LIBROS" query-param="VALOR_LIBROS"/>
			<with-param name="NIIF_VLRLIBROS" query-param="NIIF_VLRLIBROS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>

</data>