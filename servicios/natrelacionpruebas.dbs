<data name="natrelacionpruebas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatrelacionpruebasPruebasPorConvocatoriaYCompQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PRUEBA, VALOR_CONCURSO  FROM NAT_RELACION_PRUEBAS WHERE COMPANIA = :COMPANIA AND NRO_CONVOCATORIA =:CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRUEBA":"$PRUEBA","VALOR_CONCURSO":"$VALOR_CONCURSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natrelacionpruebas/pruebasporconvocatoriaycomp">
		<call-query href="getNatrelacionpruebasPruebasPorConvocatoriaYCompQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="getNatrelacionpruebasPorvalordeconcursoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PUNMAX  FROM NAT_RELACION_PRUEBAS WHERE COMPANIA = :COMPANIA AND NRO_CONVOCATORIA =:CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PUNMAX":"$PUNMAX(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natrelacionpruebas/porvalordeconcurso">
		<call-query href="getNatrelacionpruebasPorvalordeconcursoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="insertNatrelacionpruebas" keyColumns="COMPANIA,NRO_CONVOCATORIA,PRUEBA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_RELACION_PRUEBAS (COMPANIA, NRO_CONVOCATORIA, PRUEBA, CARACTER, VALOR_CONCURSO, CALIFICACION, PUNMAX, EDUCACION, EXPERIENCIA, CONSECUTIVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NRO_CONVOCATORIA, :PRUEBA, :CARACTER, :VALOR_CONCURSO, :CALIFICACION, :PUNMAX, :EDUCACION, :EXPERIENCIA, :CONSECUTIVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","KEY_PRUEBA":"$PRUEBA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param defaultValue="" name="CARACTER" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_CONCURSO" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFICACION" sqlType="STRING"/>
		<param defaultValue="0" name="PUNMAX" sqlType="STRING"/>
		<param defaultValue="0" name="EDUCACION" sqlType="STRING"/>
		<param defaultValue="0" name="EXPERIENCIA" sqlType="STRING"/>
		<param defaultValue="" name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natrelacionpruebas">
		<call-query href="insertNatrelacionpruebas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="CARACTER" query-param="CARACTER"/>
			<with-param name="VALOR_CONCURSO" query-param="VALOR_CONCURSO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="PUNMAX" query-param="PUNMAX"/>
			<with-param name="EDUCACION" query-param="EDUCACION"/>
			<with-param name="EXPERIENCIA" query-param="EXPERIENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatrelacionpruebas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_RELACION_PRUEBAS WHERE NAT_RELACION_PRUEBAS.COMPANIA= :KEY_COMPANIA AND NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_RELACION_PRUEBAS.PRUEBA= :KEY_PRUEBA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_PRUEBA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natrelacionpruebas">
		<call-query href="deleteNatrelacionpruebas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_PRUEBA" query-param="KEY_PRUEBA"/>

		</call-query>
	</resource>
	<query id="getNatrelacionpruebasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_RELACION_PRUEBAS.COMPANIA, NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA, NAT_RELACION_PRUEBAS.PRUEBA, NAT_CLASES_DE_PRUEBA.DESCRIPCION NOMBRE_PRUEBA, CARACTER, CASE NAT_RELACION_PRUEBAS.CARACTER WHEN 'E' THEN 'Eliminatoria' WHEN 'C' THEN 'Clasificatoria' END NOMBRE_CARACTER, NAT_RELACION_PRUEBAS.VALOR_CONCURSO, NAT_RELACION_PRUEBAS.CALIFICACION, NAT_RELACION_PRUEBAS.PUNMAX  FROM NAT_RELACION_PRUEBAS LEFT JOIN NAT_CLASES_DE_PRUEBA ON NAT_RELACION_PRUEBAS.COMPANIA = NAT_CLASES_DE_PRUEBA.COMPANIA AND NAT_RELACION_PRUEBAS.PRUEBA = NAT_CLASES_DE_PRUEBA.PRUEBA WHERE NAT_RELACION_PRUEBAS.COMPANIA =:COMPANIA AND NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA = :CONVOCATORIA) WHERE (CASE WHEN PRUEBA IS NULL THEN ' ' ELSE UPPER(PRUEBA) END)  LIKE UPPER(:PRUEBA || '%')  AND (CASE WHEN NOMBRE_PRUEBA IS NULL THEN ' ' ELSE UPPER(NOMBRE_PRUEBA) END)  LIKE UPPER( '%' || :NOMBRE_PRUEBA || '%')  AND (CASE WHEN CARACTER IS NULL THEN ' ' ELSE UPPER(CARACTER) END)  LIKE UPPER(:CARACTER || '%')  AND (CASE WHEN NOMBRE_CARACTER IS NULL THEN ' ' ELSE UPPER(NOMBRE_CARACTER) END)  LIKE UPPER(:NOMBRE_CARACTER || '%')  AND (CASE WHEN VALOR_CONCURSO IS NULL THEN ' ' ELSE UPPER(VALOR_CONCURSO) END)  LIKE UPPER(:VALOR_CONCURSO || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%')  AND (CASE WHEN PUNMAX IS NULL THEN ' ' ELSE UPPER(PUNMAX) END)  LIKE UPPER(:PUNMAX || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","PRUEBA":"$PRUEBA","NOMBRE_PRUEBA":"$NOMBRE_PRUEBA","CARACTER":"$CARACTER","NOMBRE_CARACTER":"$NOMBRE_CARACTER","VALOR_CONCURSO":"$VALOR_CONCURSO","CALIFICACION":"$CALIFICACION","PUNMAX":"$PUNMAX(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="NOMBRE_PRUEBA" sqlType="STRING"/>
		<param name="CARACTER" sqlType="STRING"/>
		<param name="NOMBRE_CARACTER" sqlType="STRING"/>
		<param name="VALOR_CONCURSO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="PUNMAX" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natrelacionpruebas">
		<call-query href="getNatrelacionpruebasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="NOMBRE_PRUEBA" query-param="NOMBRE_PRUEBA"/>
			<with-param name="CARACTER" query-param="CARACTER"/>
			<with-param name="NOMBRE_CARACTER" query-param="NOMBRE_CARACTER"/>
			<with-param name="VALOR_CONCURSO" query-param="VALOR_CONCURSO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="PUNMAX" query-param="PUNMAX"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatrelacionpruebasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_RELACION_PRUEBAS.COMPANIA, NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA, NAT_RELACION_PRUEBAS.PRUEBA, NAT_CLASES_DE_PRUEBA.DESCRIPCION NOMBRE_PRUEBA, CARACTER, CASE NAT_RELACION_PRUEBAS.CARACTER WHEN 'E' THEN 'Eliminatoria' WHEN 'C' THEN 'Clasificatoria' END NOMBRE_CARACTER, NAT_RELACION_PRUEBAS.VALOR_CONCURSO, NAT_RELACION_PRUEBAS.CALIFICACION, NAT_RELACION_PRUEBAS.PUNMAX  FROM NAT_RELACION_PRUEBAS LEFT JOIN NAT_CLASES_DE_PRUEBA ON NAT_RELACION_PRUEBAS.COMPANIA = NAT_CLASES_DE_PRUEBA.COMPANIA AND NAT_RELACION_PRUEBAS.PRUEBA = NAT_CLASES_DE_PRUEBA.PRUEBA WHERE NAT_RELACION_PRUEBAS.COMPANIA =:COMPANIA AND NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA = :CONVOCATORIA) WHERE (CASE WHEN PRUEBA IS NULL THEN ' ' ELSE UPPER(PRUEBA) END)  LIKE UPPER(:PRUEBA || '%')  AND (CASE WHEN NOMBRE_PRUEBA IS NULL THEN ' ' ELSE UPPER(NOMBRE_PRUEBA) END)  LIKE UPPER( '%' || :NOMBRE_PRUEBA || '%')  AND (CASE WHEN CARACTER IS NULL THEN ' ' ELSE UPPER(CARACTER) END)  LIKE UPPER(:CARACTER || '%')  AND (CASE WHEN NOMBRE_CARACTER IS NULL THEN ' ' ELSE UPPER(NOMBRE_CARACTER) END)  LIKE UPPER(:NOMBRE_CARACTER || '%')  AND (CASE WHEN VALOR_CONCURSO IS NULL THEN ' ' ELSE UPPER(VALOR_CONCURSO) END)  LIKE UPPER(:VALOR_CONCURSO || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%')  AND (CASE WHEN PUNMAX IS NULL THEN ' ' ELSE UPPER(PUNMAX) END)  LIKE UPPER(:PUNMAX || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="PRUEBA" sqlType="STRING"/>
		<param name="NOMBRE_PRUEBA" sqlType="STRING"/>
		<param name="CARACTER" sqlType="STRING"/>
		<param name="NOMBRE_CARACTER" sqlType="STRING"/>
		<param name="VALOR_CONCURSO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="PUNMAX" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natrelacionpruebas/numero">
		<call-query href="getNatrelacionpruebasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="NOMBRE_PRUEBA" query-param="NOMBRE_PRUEBA"/>
			<with-param name="CARACTER" query-param="CARACTER"/>
			<with-param name="NOMBRE_CARACTER" query-param="NOMBRE_CARACTER"/>
			<with-param name="VALOR_CONCURSO" query-param="VALOR_CONCURSO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="PUNMAX" query-param="PUNMAX"/>

		</call-query>
	</resource>
	<query id="updateNatrelacionpruebas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_RELACION_PRUEBAS SET PRUEBA=:PRUEBA, CARACTER=:CARACTER, VALOR_CONCURSO=:VALOR_CONCURSO, CALIFICACION=:CALIFICACION, PUNMAX=:PUNMAX, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_RELACION_PRUEBAS.COMPANIA= :KEY_COMPANIA AND NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_RELACION_PRUEBAS.PRUEBA= :KEY_PRUEBA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PRUEBA" sqlType="STRING"/>
		<param name="CARACTER" sqlType="STRING"/>
		<param name="VALOR_CONCURSO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="PUNMAX" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_PRUEBA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natrelacionpruebas">
		<call-query href="updateNatrelacionpruebas">
			<with-param name="PRUEBA" query-param="PRUEBA"/>
			<with-param name="CARACTER" query-param="CARACTER"/>
			<with-param name="VALOR_CONCURSO" query-param="VALOR_CONCURSO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="PUNMAX" query-param="PUNMAX"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_PRUEBA" query-param="KEY_PRUEBA"/>

		</call-query>
	</resource>

</data>