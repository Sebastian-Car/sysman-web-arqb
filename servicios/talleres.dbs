<data name="talleres" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTalleresPagNitYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TALLER.NIT, TALLER.NOMBRE, TALLER.SUCURSAL  FROM TALLER WHERE TALLER.COMPANIA = :COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="talleres/nitynombre/pag">
		<call-query href="getTalleresPagNitYNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTalleresNumNitYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TALLER.NIT, TALLER.NOMBRE, TALLER.SUCURSAL  FROM TALLER WHERE TALLER.COMPANIA = :COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="talleres/nitynombre/num">
		<call-query href="getTalleresNumNitYNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTalleresPagCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TALLER.NIT, TALLER.NOMBRE  FROM TALLER WHERE TALLER.COMPANIA = :COMPANIA AND TALLER.NIT &gt;= :CODIGO) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="talleres/codigoynombrefinal/pag">
		<call-query href="getTalleresPagCodigoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTalleresNumCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TALLER.NIT, TALLER.NOMBRE  FROM TALLER WHERE TALLER.COMPANIA = :COMPANIA AND TALLER.NIT &gt;= :CODIGO) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="talleres/codigoynombrefinal/num">
		<call-query href="getTalleresNumCodigoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTalleresPagTallerConResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT TALLER.NIT, TALLER.NOMBRE, TALLER.SUCURSAL  FROM TALLER INNER JOIN RESPONSABLES_TALLERES ON TALLER.COMPANIA = RESPONSABLES_TALLERES.COMPANIA AND TALLER.NIT = RESPONSABLES_TALLERES.TALLER AND TALLER.SUCURSAL = RESPONSABLES_TALLERES.SUCURSAL_TALLER WHERE TALLER.COMPANIA = :COMPANIA ORDER BY TALLER.NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="talleres/tallerconresponsable/pag">
		<call-query href="getTalleresPagTallerConResponsableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTalleresNumTallerConResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT TALLER.NIT, TALLER.NOMBRE, TALLER.SUCURSAL  FROM TALLER INNER JOIN RESPONSABLES_TALLERES ON TALLER.COMPANIA = RESPONSABLES_TALLERES.COMPANIA AND TALLER.NIT = RESPONSABLES_TALLERES.TALLER AND TALLER.SUCURSAL = RESPONSABLES_TALLERES.SUCURSAL_TALLER WHERE TALLER.COMPANIA = :COMPANIA ORDER BY TALLER.NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="talleres/tallerconresponsable/num">
		<call-query href="getTalleresNumTallerConResponsableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertTalleres" keyColumns="COMPANIA,NIT,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TALLER (NIT, SUCURSAL, NOMBRE, DIRECCION, TELEFONO, FAX, PROPIETARIO, COMPANIA, SUCURSAL_PROPIETARIO, DATE_CREATED, CREATED_BY) VALUES (:NIT, :SUCURSAL, :NOMBRE, :DIRECCION, :TELEFONO, :FAX, :PROPIETARIO, :COMPANIA, :SUCURSAL_PROPIETARIO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO" sqlType="STRING"/>
		<param defaultValue="" name="FAX" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="PROPIETARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_PROPIETARIO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="talleres">
		<call-query href="insertTalleres">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FAX" query-param="FAX"/>
			<with-param name="PROPIETARIO" query-param="PROPIETARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL_PROPIETARIO" query-param="SUCURSAL_PROPIETARIO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTalleres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TALLER WHERE TALLER.COMPANIA= :KEY_COMPANIA AND TALLER.NIT= :KEY_NIT AND TALLER.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="talleres">
		<call-query href="deleteTalleres">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getTalleresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TALLER.COMPANIA, TALLER.SUCURSAL, TALLER.NIT, TALLER.NOMBRE, TALLER.DIRECCION, TALLER.TELEFONO, TALLER.FAX, TALLER.PROPIETARIO  FROM TALLER WHERE TALLER.COMPANIA = :COMPANIA ORDER BY TALLER.COMPANIA, TALLER.NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END)  LIKE UPPER( '%' || :TELEFONO || '%')  AND (CASE WHEN FAX IS NULL THEN ' ' ELSE UPPER(FAX) END)  LIKE UPPER( '%' || :FAX || '%')  AND (CASE WHEN PROPIETARIO IS NULL THEN ' ' ELSE UPPER(PROPIETARIO) END)  LIKE UPPER( '%' || :PROPIETARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NIT":"$NIT","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","TELEFONO":"$TELEFONO","FAX":"$FAX","PROPIETARIO":"$PROPIETARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="FAX" sqlType="STRING"/>
		<param name="PROPIETARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="talleres">
		<call-query href="getTalleresPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FAX" query-param="FAX"/>
			<with-param name="PROPIETARIO" query-param="PROPIETARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTalleresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TALLER.COMPANIA, TALLER.SUCURSAL, TALLER.NIT, TALLER.NOMBRE, TALLER.DIRECCION, TALLER.TELEFONO, TALLER.FAX, TALLER.PROPIETARIO  FROM TALLER WHERE TALLER.COMPANIA = :COMPANIA ORDER BY TALLER.COMPANIA, TALLER.NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END)  LIKE UPPER( '%' || :TELEFONO || '%')  AND (CASE WHEN FAX IS NULL THEN ' ' ELSE UPPER(FAX) END)  LIKE UPPER( '%' || :FAX || '%')  AND (CASE WHEN PROPIETARIO IS NULL THEN ' ' ELSE UPPER(PROPIETARIO) END)  LIKE UPPER( '%' || :PROPIETARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="FAX" sqlType="STRING"/>
		<param name="PROPIETARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="talleres/numero">
		<call-query href="getTalleresNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FAX" query-param="FAX"/>
			<with-param name="PROPIETARIO" query-param="PROPIETARIO"/>

		</call-query>
	</resource>
	<query id="getTalleresRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TALLER.NIT, TALLER.SUCURSAL, TALLER.NOMBRE, TALLER.DIRECCION, TALLER.TELEFONO, TALLER.FAX, TALLER.PROPIETARIO, TALLER.COMPANIA, TALLER.SUCURSAL_PROPIETARIO, TERCERO.NOMBRE NOMBREPROPIETARIO  FROM TALLER LEFT JOIN TERCERO ON TALLER.PROPIETARIO=TERCERO.NIT WHERE TALLER.COMPANIA= :KEY_COMPANIA AND TALLER.NIT= :KEY_NIT AND TALLER.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","TELEFONO":"$TELEFONO","FAX":"$FAX","PROPIETARIO":"$PROPIETARIO","COMPANIA":"$COMPANIA","SUCURSAL_PROPIETARIO":"$SUCURSAL_PROPIETARIO","NOMBREPROPIETARIO":"$NOMBREPROPIETARIO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="talleres/data">
		<call-query href="getTalleresRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateTalleres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TALLER SET NIT=:NIT, SUCURSAL=:SUCURSAL, NOMBRE=:NOMBRE, DIRECCION=:DIRECCION, TELEFONO=:TELEFONO, FAX=:FAX, PROPIETARIO=:PROPIETARIO, SUCURSAL_PROPIETARIO=:SUCURSAL_PROPIETARIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TALLER.COMPANIA= :KEY_COMPANIA AND TALLER.NIT= :KEY_NIT AND TALLER.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="FAX" sqlType="STRING"/>
		<param name="PROPIETARIO" sqlType="STRING"/>
		<param name="SUCURSAL_PROPIETARIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="talleres">
		<call-query href="updateTalleres">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FAX" query-param="FAX"/>
			<with-param name="PROPIETARIO" query-param="PROPIETARIO"/>
			<with-param name="SUCURSAL_PROPIETARIO" query-param="SUCURSAL_PROPIETARIO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>