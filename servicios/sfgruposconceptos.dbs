<data name="sfgruposconceptos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfgruposconceptosPagTodosPorCompaniaYTipocobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_GRUPOS_CONCEPTOS WHERE COMPANIA = :COMPANIA AND TIPOCOBRO = :TIPOCONTRATO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfgruposconceptos/todosporcompaniaytipocobro/pag">
		<call-query href="getSfgruposconceptosPagTodosPorCompaniaYTipocobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfgruposconceptosNumTodosPorCompaniaYTipocobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_GRUPOS_CONCEPTOS WHERE COMPANIA = :COMPANIA AND TIPOCOBRO = :TIPOCONTRATO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfgruposconceptos/todosporcompaniaytipocobro/num">
		<call-query href="getSfgruposconceptosNumTodosPorCompaniaYTipocobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSfgruposconceptosPagTodosPorCompaniaYCodigoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_GRUPOS_CONCEPTOS WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :CODIGOINICIAL AND TIPOCOBRO = :TIPOCONTRATO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfgruposconceptos/todosporcompaniaycodigoinicial/pag">
		<call-query href="getSfgruposconceptosPagTodosPorCompaniaYCodigoinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfgruposconceptosNumTodosPorCompaniaYCodigoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_GRUPOS_CONCEPTOS WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :CODIGOINICIAL AND TIPOCOBRO = :TIPOCONTRATO ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfgruposconceptos/todosporcompaniaycodigoinicial/num">
		<call-query href="getSfgruposconceptosNumTodosPorCompaniaYCodigoinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSfgruposconceptosTodosPorTipocobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM SF_GRUPOS_CONCEPTOS WHERE COMPANIA = :COMPANIA AND TIPOCOBRO = :TIPOCOBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfgruposconceptos/todosportipocobro">
		<call-query href="getSfgruposconceptosTodosPorTipocobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="insertSfgruposconceptos" keyColumns="COMPANIA,TIPOCOBRO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_GRUPOS_CONCEPTOS (COMPANIA, TIPOCOBRO, CODIGO, NOMBRE, CANT_IGUALES, APLICABASEF, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOCOBRO, :CODIGO, :NOMBRE, :CANT_IGUALES, :APLICABASEF, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="CANT_IGUALES" sqlType="STRING"/>
		<param defaultValue="0" name="APLICABASEF" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfgruposconceptos">
		<call-query href="insertSfgruposconceptos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CANT_IGUALES" query-param="CANT_IGUALES"/>
			<with-param name="APLICABASEF" query-param="APLICABASEF"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSfgruposconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_GRUPOS_CONCEPTOS WHERE SF_GRUPOS_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_GRUPOS_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_GRUPOS_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="sfgruposconceptos">
		<call-query href="deleteSfgruposconceptos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSfgruposconceptosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_GRUPOS_CONCEPTOS.COMPANIA, SF_GRUPOS_CONCEPTOS.TIPOCOBRO, SF_GRUPOS_CONCEPTOS.CODIGO, SF_GRUPOS_CONCEPTOS.NOMBRE,(CASE SF_GRUPOS_CONCEPTOS.CANT_IGUALES WHEN 0 THEN 'false' ELSE 'true' END) CANT_IGUALES,(CASE SF_GRUPOS_CONCEPTOS.APLICABASEF WHEN 0 THEN 'false' ELSE 'true' END) APLICABASEF FROM SF_GRUPOS_CONCEPTOS WHERE SF_GRUPOS_CONCEPTOS.COMPANIA = :COMPANIA AND SF_GRUPOS_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CANT_IGUALES IS NULL THEN ' ' ELSE UPPER(CANT_IGUALES) END)  LIKE UPPER(:CANT_IGUALES || '%')  AND (CASE WHEN APLICABASEF IS NULL THEN ' ' ELSE UPPER(APLICABASEF) END)  LIKE UPPER(:APLICABASEF || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOBRO":"$TIPOCOBRO","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","CANT_IGUALES":"$CANT_IGUALES(type:boolean)","APLICABASEF":"$APLICABASEF(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CANT_IGUALES" sqlType="STRING"/>
		<param name="APLICABASEF" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfgruposconceptos">
		<call-query href="getSfgruposconceptosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CANT_IGUALES" query-param="CANT_IGUALES"/>
			<with-param name="APLICABASEF" query-param="APLICABASEF"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfgruposconceptosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_GRUPOS_CONCEPTOS.COMPANIA, SF_GRUPOS_CONCEPTOS.TIPOCOBRO, SF_GRUPOS_CONCEPTOS.CODIGO, SF_GRUPOS_CONCEPTOS.NOMBRE,(CASE SF_GRUPOS_CONCEPTOS.CANT_IGUALES WHEN 0 THEN 'false' ELSE 'true' END) CANT_IGUALES,(CASE SF_GRUPOS_CONCEPTOS.APLICABASEF WHEN 0 THEN 'false' ELSE 'true' END) APLICABASEF FROM SF_GRUPOS_CONCEPTOS WHERE SF_GRUPOS_CONCEPTOS.COMPANIA = :COMPANIA AND SF_GRUPOS_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CANT_IGUALES IS NULL THEN ' ' ELSE UPPER(CANT_IGUALES) END)  LIKE UPPER(:CANT_IGUALES || '%')  AND (CASE WHEN APLICABASEF IS NULL THEN ' ' ELSE UPPER(APLICABASEF) END)  LIKE UPPER(:APLICABASEF || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CANT_IGUALES" sqlType="STRING"/>
		<param name="APLICABASEF" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfgruposconceptos/numero">
		<call-query href="getSfgruposconceptosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CANT_IGUALES" query-param="CANT_IGUALES"/>
			<with-param name="APLICABASEF" query-param="APLICABASEF"/>

		</call-query>
	</resource>
	<query id="getSfgruposconceptosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SF_GRUPOS_CONCEPTOS.COMPANIA, SF_GRUPOS_CONCEPTOS.TIPOCOBRO, SF_GRUPOS_CONCEPTOS.CODIGO, SF_GRUPOS_CONCEPTOS.NOMBRE,(CASE SF_GRUPOS_CONCEPTOS.CANT_IGUALES WHEN 0 THEN 'false' ELSE 'true' END) CANT_IGUALES,(CASE SF_GRUPOS_CONCEPTOS.APLICABASEF WHEN 0 THEN 'false' ELSE 'true' END) APLICABASEF, SF_GRUPOS_CONCEPTOS.CREATED_BY,(TO_CHAR(SF_GRUPOS_CONCEPTOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_GRUPOS_CONCEPTOS.MODIFIED_BY,(TO_CHAR(SF_GRUPOS_CONCEPTOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SF_GRUPOS_CONCEPTOS WHERE SF_GRUPOS_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_GRUPOS_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_GRUPOS_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOBRO":"$TIPOCOBRO","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","CANT_IGUALES":"$CANT_IGUALES(type:boolean)","APLICABASEF":"$APLICABASEF(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfgruposconceptos/data">
		<call-query href="getSfgruposconceptosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateSfgruposconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_GRUPOS_CONCEPTOS SET TIPOCOBRO=:TIPOCOBRO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, CANT_IGUALES=:CANT_IGUALES, APLICABASEF=:APLICABASEF, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_GRUPOS_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_GRUPOS_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_GRUPOS_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CANT_IGUALES" sqlType="STRING"/>
		<param name="APLICABASEF" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfgruposconceptos">
		<call-query href="updateSfgruposconceptos">
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CANT_IGUALES" query-param="CANT_IGUALES"/>
			<with-param name="APLICABASEF" query-param="APLICABASEF"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>