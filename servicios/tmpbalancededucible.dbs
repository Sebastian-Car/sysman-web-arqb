<data name="tmpbalancededucible" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTmpbalancededucibleGetcantidadregistrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, ID, CODIGO, NATURALEZA, CLASE, SALDO, SALDO1, NOMBRE, DEBITO, CREDITO, SALDOANTDEBITO, SALDOANTCREDITO, SALDONUEDEBITO, SALDONUECREDITO, SALDONUEDEBITONODEDUCIBLE, SALDONUECREDITONODEDUCIBLE, SALDOFISCAL, SALDODEBITOFISCAL, SALDOCREDITOFISCAL,(CASE DEDUCIBLE WHEN 0 THEN 'false' ELSE 'true' END) DEDUCIBLE, TERCERO, AUXILIAR, CENTRO_COSTO, REFERENCIA_CONTABLE FROM TMPBALANCEDEDUCIBLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ID":"$ID","CODIGO":"$CODIGO","NATURALEZA":"$NATURALEZA","CLASE":"$CLASE","SALDO":"$SALDO","SALDO1":"$SALDO1","NOMBRE":"$NOMBRE","DEBITO":"$DEBITO","CREDITO":"$CREDITO","SALDOANTDEBITO":"$SALDOANTDEBITO","SALDOANTCREDITO":"$SALDOANTCREDITO","SALDONUEDEBITO":"$SALDONUEDEBITO","SALDONUECREDITO":"$SALDONUECREDITO","SALDONUEDEBITONODEDUCIBLE":"$SALDONUEDEBITONODEDUCIBLE","SALDONUECREDITONODEDUCIBLE":"$SALDONUECREDITONODEDUCIBLE","SALDOFISCAL":"$SALDOFISCAL","SALDODEBITOFISCAL":"$SALDODEBITOFISCAL","SALDOCREDITOFISCAL":"$SALDOCREDITOFISCAL","DEDUCIBLE":"$DEDUCIBLE(type:boolean)","TERCERO":"$TERCERO","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","REFERENCIA_CONTABLE":"$REFERENCIA_CONTABLE"}]}}		</result>
 
	</query>
	<resource method="GET" path="tmpbalancededucible/getcantidadregistros">
		<call-query href="getTmpbalancededucibleGetcantidadregistrosQuery">
 
		</call-query>
	</resource>
	<query id="getTmpbalancededucibleGetcomprobantesfiscaleslistQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPROBANTE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, (DEBITO+CREDITO) VALOR, OBSERVACIONES,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO FROM BALANCE_FISCAL WHERE Compania = :COMPANIA AND BALANCE_FISCAL.ANO = :ANOTRABAJO AND BALANCE_FISCAL.MES = :MESTRABAJO ORDER BY BALANCE_FISCAL.COMPANIA DESC , BALANCE_FISCAL.ANO DESC , BALANCE_FISCAL.MES DESC , BALANCE_FISCAL.DIA DESC , BALANCE_FISCAL.COMPROBANTE DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE","FECHA":"$FECHA","VALOR":"$VALOR(type:integer)","OBSERVACIONES":"$OBSERVACIONES","IMPRESO":"$IMPRESO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOTRABAJO" sqlType="STRING"/>
		<param name="MESTRABAJO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tmpbalancededucible/getcomprobantesfiscaleslist">
		<call-query href="getTmpbalancededucibleGetcomprobantesfiscaleslistQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOTRABAJO" query-param="ANOTRABAJO"/>
			<with-param name="MESTRABAJO" query-param="MESTRABAJO"/>

		</call-query>
	</resource>
	<query id="deleteTmpbalancededucibleDeteletmpbalancededucible" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TMPBALANCEDEDUCIBLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

 
	</query>
	<resource method="DELETE" path="tmpbalancededucible/deteletmpbalancededucible">
		<call-query href="deleteTmpbalancededucibleDeteletmpbalancededucible">
 
		</call-query>
	</resource>

</data>