		<sql>SELECT  CARGOS.NOMBRE_DEL_CARGO NOMBRE_DEL_CARGO  FROM CARGOS INNER JOIN NAT_APERTURA ON CARGOS.COMPANIA = NAT_APERTURA.COMPANIA AND CARGOS.ID_DE_CARGO = NAT_APERTURA.CODIGOCARGO AND CARGOS.GRADO = NAT_APERTURA.GRADOCARGO WHERE NAT_APERTURA.COMPANIA = :COMPANIA AND NAT_APERTURA.NRO_CONVOCATORIA = :NRO_CONVOCATORIA</sql>
