	<query id="getCargosPagCargosDeJefeDeUnidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO , CARGOS.NOMBRE_DEL_CARGO, PERSONAL.ESCALAFON , ESCALAFON.NOMBRE NOMBREESCALAFON, PERSONAL.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA NOMBRECATEGORIA  FROM CARGOS INNER JOIN PERSONAL ON CARGOS.COMPANIA = PERSONAL.COMPANIA AND CARGOS.ID_DE_CARGO = PERSONAL.ID_DE_CARGO INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = PERSONAL.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = PERSONAL.NUMERO_DCTO AND DEPENDENCIA_RESPONSABLE.SUCURSAL = PERSONAL.SUCURSAL INNER JOIN ESCALAFON ON PERSONAL.COMPANIA = ESCALAFON.COMPANIA AND PERSONAL.ESCALAFON = ESCALAFON.CODIGO INNER JOIN CATEGORIA ON PERSONAL.COMPANIA =CATEGORIA.COMPANIA AND PERSONAL.ESCALAFON =CATEGORIA.ESCALAFON AND PERSONAL.ID_DE_CATEGORIA = CATEGORIA.ID_DE_CATEGORIA AND PERSONAL.ANO = CATEGORIA.ANO WHERE CARGOS.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.JEFEUNIDAD NOT IN(0)) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","ESCALAFON":"$ESCALAFON","NOMBREESCALAFON":"$NOMBREESCALAFON","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","NOMBRECATEGORIA":"$NOMBRECATEGORIA"}]}}		</result>
