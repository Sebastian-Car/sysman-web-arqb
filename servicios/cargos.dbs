	<query id="getCargosCargoRetiroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO  FROM CARGOS INNER JOIN PERSONAL ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO LEFT JOIN NAT_DATOS_PERSONALES ON NAT_DATOS_PERSONALES.COMPANIA = PERSONAL.COMPANIA AND NAT_DATOS_PERSONALES.CODIGO = PERSONAL.ID_DE_EMPLEADO WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.NUMERO_DCTO = :NUMERO_DCTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>

	</query>
