	<query id="insertCargosSinFactorRiesgos" keyColumns="COMPANIA,ID_DE_CARGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CARGOS (COMPANIA, ID_DE_CARGO, ESCALAFON, NOMBRE_DEL_CARGO, PLAZAS, FUNCIONES, ENCARRERA, TIPO, ESTADOCARGO, RESOLUCIONCARGO, FECHARESOLUCION, GRADO, RESOLUCIONFUNCION, CODIGOCARGO, VALOR_HORA, CGR_TIPO_VINCULACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_CARGO, :ESCALAFON, :NOMBRE_DEL_CARGO, :PLAZAS, :FUNCIONES, :ENCARRERA, :TIPO, :ESTADOCARGO, :RESOLUCIONCARGO, TO_DATE(:FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS'), :GRADO, :RESOLUCIONFUNCION, :CODIGOCARGO, :VALOR_HORA, :CGR_TIPO_VINCULACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_CARGO":"$ID_DE_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZAS" sqlType="STRING"/>
		<param defaultValue="" name="FUNCIONES" sqlType="STRING"/>
		<param defaultValue="0" name="ENCARRERA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="0" name="ESTADOCARGO" sqlType="STRING"/>
		<param defaultValue="" name="RESOLUCIONCARGO" sqlType="STRING"/>
		<param defaultValue="" name="FECHARESOLUCION" sqlType="STRING"/>
		<param defaultValue="" name="GRADO" sqlType="STRING"/>
		<param defaultValue="" name="RESOLUCIONFUNCION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCARGO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_HORA" sqlType="STRING"/>
		<param defaultValue="" name="CGR_TIPO_VINCULACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
