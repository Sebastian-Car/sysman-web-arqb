	<query id="getCargosPagCargosjefeinmediatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_DE_CARGO COD, NOMBRE, ID_DE_CARGO, NOMBRE_DEL_CARGO, ESCALAFON, NOMBREESCALAFON, ID_DE_CATEGORIA, NOMBRECATEGORIA  FROM ( SELECT DISTINCT TERCERO.NOMBRE, CARGOS.ID_DE_CARGO , CARGOS.NOMBRE_DEL_CARGO, PERSONAL.ESCALAFON , ESCALAFON.NOMBRE NOMBREESCALAFON, PERSONAL.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA NOMBRECATEGORIA FROM CARGOS INNER JOIN PERSONAL ON CARGOS.COMPANIA = PERSONAL.COMPANIA AND CARGOS.ID_DE_CARGO = PERSONAL.ID_DE_CARGO INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = PERSONAL.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = PERSONAL.NUMERO_DCTO AND DEPENDENCIA_RESPONSABLE.SUCURSAL = PERSONAL.SUCURSAL INNER JOIN TERCERO ON DEPENDENCIA_RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = TERCERO.NIT AND DEPENDENCIA_RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL INNER JOIN ESCALAFON ON PERSONAL.COMPANIA = ESCALAFON.COMPANIA AND PERSONAL.ESCALAFON = ESCALAFON.CODIGO INNER JOIN CATEGORIA ON PERSONAL.COMPANIA = CATEGORIA.COMPANIA AND PERSONAL.ESCALAFON = CATEGORIA.ESCALAFON AND PERSONAL.ID_DE_CATEGORIA = CATEGORIA.ID_DE_CATEGORIA AND PERSONAL.ANO = CATEGORIA.ANO WHERE CARGOS.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.JEFEUNIDAD NOT IN(0) )) WHERE (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END)  LIKE UPPER(:COD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER(:ESCALAFON || '%')  AND (CASE WHEN NOMBREESCALAFON IS NULL THEN ' ' ELSE UPPER(NOMBREESCALAFON) END)  LIKE UPPER( '%' || :NOMBREESCALAFON || '%')  AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN NOMBRECATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRECATEGORIA) END)  LIKE UPPER( '%' || :NOMBRECATEGORIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD":"$COD","NOMBRE":"$NOMBRE","ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","ESCALAFON":"$ESCALAFON","NOMBREESCALAFON":"$NOMBREESCALAFON","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","NOMBRECATEGORIA":"$NOMBRECATEGORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBREESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="NOMBRECATEGORIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
