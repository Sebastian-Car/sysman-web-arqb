<data name="cargos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateCargosNivelesYCategorias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CARGOS SET COMPANIA          =:COMPANIA,   ID_DE_CARGO         =:ID_DE_CARGO,   ESCALAFON           =:ESCALAFON,   NOMBRE_DEL_CARGO    =:NOMBRE_DEL_CARGO,    MODIFIED_BY         =:MODIFIED_BY,   DATE_MODIFIED       =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE CARGOS.COMPANIA = :COMPANIA AND CARGOS.ID_DE_CARGO= :ID_DE_CARGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cargos/nivelesycategorias">
		<call-query href="updateCargosNivelesYCategorias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>

		</call-query>
	</resource>
	<query id="getCargosTodosPorCompaniaYEscalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO FROM CARGOS WHERE CARGOS.COMPANIA = :COMPANIA AND CARGOS.ESCALAFON = :ESCALAFON AND CARGOS.ESTADOCARGO IN ('1')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/todosporcompaniayescalafon">
		<call-query href="getCargosTodosPorCompaniaYEscalafonQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>

		</call-query>
	</resource>
	<query id="getCargosPagCodigoYNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO  FROM CARGOS WHERE CARGOS.COMPANIA = :COMPANIA ORDER BY CARGOS.NOMBRE_DEL_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cargos/codigoynombreporcompania/pag">
		<call-query href="getCargosPagCodigoYNombrePorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCargosNumCodigoYNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO  FROM CARGOS WHERE CARGOS.COMPANIA = :COMPANIA ORDER BY CARGOS.NOMBRE_DEL_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/codigoynombreporcompania/num">
		<call-query href="getCargosNumCodigoYNombrePorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>

		</call-query>
	</resource>
	<query id="insertCargosEscalafon" keyColumns="COMPANIA,ID_DE_CARGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CARGOS (COMPANIA, ID_DE_CARGO, ESCALAFON, NOMBRE_DEL_CARGO, PLAZAS, ENCARRERA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_CARGO, :ESCALAFON, :NOMBRE_DEL_CARGO, :PLAZAS, :ENCARRERA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_CARGO":"$ID_DE_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZAS" sqlType="STRING"/>
		<param defaultValue="0" name="ENCARRERA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cargos/escalafon">
		<call-query href="insertCargosEscalafon">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="PLAZAS" query-param="PLAZAS"/>
			<with-param name="ENCARRERA" query-param="ENCARRERA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getCargosPagCargosPorEscalafonInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.NOMBRE  FROM CARGOS LEFT JOIN ESCALAFON ON CARGOS.COMPANIA = ESCALAFON.COMPANIA AND CARGOS.ESCALAFON = ESCALAFON.CODIGO WHERE CARGOS.COMPANIA = :COMPANIA ORDER BY CARGOS.ID_DE_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cargos/cargosporescalafoninicial/pag">
		<call-query href="getCargosPagCargosPorEscalafonInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCargosNumCargosPorEscalafonInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.NOMBRE  FROM CARGOS LEFT JOIN ESCALAFON ON CARGOS.COMPANIA = ESCALAFON.COMPANIA AND CARGOS.ESCALAFON = ESCALAFON.CODIGO WHERE CARGOS.COMPANIA = :COMPANIA ORDER BY CARGOS.ID_DE_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/cargosporescalafoninicial/num">
		<call-query href="getCargosNumCargosPorEscalafonInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCargosPagCargosPorEscalafonFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.NOMBRE  FROM CARGOS LEFT JOIN ESCALAFON ON CARGOS.COMPANIA = ESCALAFON.COMPANIA AND CARGOS.ESCALAFON = ESCALAFON.CODIGO WHERE CARGOS.COMPANIA = :COMPANIA AND CARGOS.ID_DE_CARGO &gt;= :CARGOINICIAL ORDER BY CARGOS.ID_DE_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CARGOINICIAL" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cargos/cargosporescalafonfinal/pag">
		<call-query href="getCargosPagCargosPorEscalafonFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CARGOINICIAL" query-param="CARGOINICIAL"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCargosNumCargosPorEscalafonFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.NOMBRE  FROM CARGOS LEFT JOIN ESCALAFON ON CARGOS.COMPANIA = ESCALAFON.COMPANIA AND CARGOS.ESCALAFON = ESCALAFON.CODIGO WHERE CARGOS.COMPANIA = :COMPANIA AND CARGOS.ID_DE_CARGO &gt;= :CARGOINICIAL ORDER BY CARGOS.ID_DE_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CARGOINICIAL" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/cargosporescalafonfinal/num">
		<call-query href="getCargosNumCargosPorEscalafonFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CARGOINICIAL" query-param="CARGOINICIAL"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertCargos" keyColumns="COMPANIA,ID_DE_CARGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CARGOS (COMPANIA, ID_DE_CARGO, ESCALAFON, NOMBRE_DEL_CARGO, PLAZAS, GRADO, FUNCIONES, ENCARRERA, TIPO, ESTADOCARGO, RESOLUCIONCARGO, FECHARESOLUCION, RESOLUCIONFUNCION, CODIGOCARGO, VALOR_HORA, FACTOR_RIESGO, CGR_TIPO_VINCULACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_CARGO, :ESCALAFON, :NOMBRE_DEL_CARGO, :PLAZAS, :GRADO, :FUNCIONES, :ENCARRERA, :TIPO, :ESTADOCARGO, :RESOLUCIONCARGO, TO_DATE(:FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS'), :RESOLUCIONFUNCION, :CODIGOCARGO, :VALOR_HORA, :FACTOR_RIESGO, :CGR_TIPO_VINCULACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_CARGO":"$ID_DE_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZAS" sqlType="STRING"/>
		<param defaultValue="" name="GRADO" sqlType="STRING"/>
		<param defaultValue="" name="FUNCIONES" sqlType="STRING"/>
		<param defaultValue="0" name="ENCARRERA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="0" name="ESTADOCARGO" sqlType="STRING"/>
		<param defaultValue="" name="RESOLUCIONCARGO" sqlType="STRING"/>
		<param defaultValue="" name="FECHARESOLUCION" sqlType="STRING"/>
		<param defaultValue="" name="RESOLUCIONFUNCION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCARGO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_HORA" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR_RIESGO" sqlType="STRING"/>
		<param defaultValue="" name="CGR_TIPO_VINCULACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cargos">
		<call-query href="insertCargos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="PLAZAS" query-param="PLAZAS"/>
			<with-param name="GRADO" query-param="GRADO"/>
			<with-param name="FUNCIONES" query-param="FUNCIONES"/>
			<with-param name="ENCARRERA" query-param="ENCARRERA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ESTADOCARGO" query-param="ESTADOCARGO"/>
			<with-param name="RESOLUCIONCARGO" query-param="RESOLUCIONCARGO"/>
			<with-param name="FECHARESOLUCION" query-param="FECHARESOLUCION"/>
			<with-param name="RESOLUCIONFUNCION" query-param="RESOLUCIONFUNCION"/>
			<with-param name="CODIGOCARGO" query-param="CODIGOCARGO"/>
			<with-param name="VALOR_HORA" query-param="VALOR_HORA"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>
			<with-param name="CGR_TIPO_VINCULACION" query-param="CGR_TIPO_VINCULACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteCargos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CARGOS WHERE CARGOS.COMPANIA= :KEY_COMPANIA AND CARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="cargos">
		<call-query href="deleteCargos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CARGO" query-param="KEY_ID_DE_CARGO"/>

		</call-query>
	</resource>
	<query id="getCargosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CARGOS.COMPANIA, CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.NOMBRE ESCALAFON_LB,(CASE CARGOS.ENCARRERA WHEN 0 THEN 'false' ELSE 'true' END) ENCARRERA, CARGOS.FACTOR_RIESGO, CARGOS.GRADO  FROM CARGOS INNER JOIN ESCALAFON ON CARGOS.COMPANIA = ESCALAFON.COMPANIA AND CARGOS.ESCALAFON = ESCALAFON.CODIGO WHERE CARGOS.COMPANIA = :COMPANIA ORDER BY CARGOS.ID_DE_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN ESCALAFON_LB IS NULL THEN ' ' ELSE UPPER(ESCALAFON_LB) END)  LIKE UPPER( '%' || :ESCALAFON_LB || '%')  AND (CASE WHEN ENCARRERA IS NULL THEN ' ' ELSE UPPER(ENCARRERA) END)  LIKE UPPER(:ENCARRERA || '%')  AND (CASE WHEN FACTOR_RIESGO IS NULL THEN ' ' ELSE UPPER(FACTOR_RIESGO) END)  LIKE UPPER(:FACTOR_RIESGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","ESCALAFON_LB":"$ESCALAFON_LB","ENCARRERA":"$ENCARRERA(type:boolean)","FACTOR_RIESGO":"$FACTOR_RIESGO","GRADO":"$GRADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON_LB" sqlType="STRING"/>
		<param name="ENCARRERA" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cargos">
		<call-query href="getCargosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="ESCALAFON_LB" query-param="ESCALAFON_LB"/>
			<with-param name="ENCARRERA" query-param="ENCARRERA"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCargosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CARGOS.COMPANIA, CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.NOMBRE ESCALAFON_LB,(CASE CARGOS.ENCARRERA WHEN 0 THEN 'false' ELSE 'true' END) ENCARRERA, CARGOS.FACTOR_RIESGO, CARGOS.GRADO  FROM CARGOS INNER JOIN ESCALAFON ON CARGOS.COMPANIA = ESCALAFON.COMPANIA AND CARGOS.ESCALAFON = ESCALAFON.CODIGO WHERE CARGOS.COMPANIA = :COMPANIA ORDER BY CARGOS.ID_DE_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN ESCALAFON_LB IS NULL THEN ' ' ELSE UPPER(ESCALAFON_LB) END)  LIKE UPPER( '%' || :ESCALAFON_LB || '%')  AND (CASE WHEN ENCARRERA IS NULL THEN ' ' ELSE UPPER(ENCARRERA) END)  LIKE UPPER(:ENCARRERA || '%')  AND (CASE WHEN FACTOR_RIESGO IS NULL THEN ' ' ELSE UPPER(FACTOR_RIESGO) END)  LIKE UPPER(:FACTOR_RIESGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON_LB" sqlType="STRING"/>
		<param name="ENCARRERA" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/numero">
		<call-query href="getCargosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="ESCALAFON_LB" query-param="ESCALAFON_LB"/>
			<with-param name="ENCARRERA" query-param="ENCARRERA"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>

		</call-query>
	</resource>
	<query id="getCargosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ID_DE_CARGO, ESCALAFON, NOMBRE_DEL_CARGO, PLAZAS, FUNCIONES,(CASE ENCARRERA WHEN 0 THEN 'false' ELSE 'true' END) ENCARRERA, TIPO, ESTADOCARGO, RESOLUCIONCARGO,(TO_CHAR(FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHARESOLUCION, RESOLUCIONFUNCION, CODIGOCARGO, VALOR_HORA, GRADO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ( CARGOS.PLAZAS - ( SELECT COUNT(0) FROM PERSONAL WHERE PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO AND PERSONAL.ESTADO_ACTUAL = 1 ) ) VACANTES, FACTOR_RIESGO, CGR_TIPO_VINCULACION FROM CARGOS WHERE CARGOS.COMPANIA= :KEY_COMPANIA AND CARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_CARGO":"$ID_DE_CARGO","ESCALAFON":"$ESCALAFON","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","PLAZAS":"$PLAZAS","FUNCIONES":"$FUNCIONES","ENCARRERA":"$ENCARRERA(type:boolean)","TIPO":"$TIPO","ESTADOCARGO":"$ESTADOCARGO(type:integer)","RESOLUCIONCARGO":"$RESOLUCIONCARGO","FECHARESOLUCION":"$FECHARESOLUCION","RESOLUCIONFUNCION":"$RESOLUCIONFUNCION","CODIGOCARGO":"$CODIGOCARGO","VALOR_HORA":"$VALOR_HORA","GRADO":"$GRADO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","VACANTES":"$VACANTES(type:integer)","FACTOR_RIESGO":"$FACTOR_RIESGO","CGR_TIPO_VINCULACION":"$CGR_TIPO_VINCULACION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/data">
		<call-query href="getCargosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CARGO" query-param="KEY_ID_DE_CARGO"/>

		</call-query>
	</resource>
	<query id="updateCargos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CARGOS SET COMPANIA=:COMPANIA, ID_DE_CARGO=:ID_DE_CARGO, ESCALAFON=:ESCALAFON, NOMBRE_DEL_CARGO=:NOMBRE_DEL_CARGO, PLAZAS=:PLAZAS, FUNCIONES=:FUNCIONES, ENCARRERA=:ENCARRERA, TIPO=:TIPO, ESTADOCARGO=:ESTADOCARGO, RESOLUCIONCARGO=:RESOLUCIONCARGO, FECHARESOLUCION=TO_DATE(:FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS'), RESOLUCIONFUNCION=:RESOLUCIONFUNCION, CODIGOCARGO=:CODIGOCARGO, VALOR_HORA=:VALOR_HORA, GRADO=:GRADO, FACTOR_RIESGO=:FACTOR_RIESGO, CGR_TIPO_VINCULACION=:CGR_TIPO_VINCULACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CARGOS.COMPANIA= :KEY_COMPANIA AND CARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="PLAZAS" sqlType="STRING"/>
		<param name="FUNCIONES" sqlType="STRING"/>
		<param name="ENCARRERA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ESTADOCARGO" sqlType="STRING"/>
		<param name="RESOLUCIONCARGO" sqlType="STRING"/>
		<param name="FECHARESOLUCION" sqlType="STRING"/>
		<param name="RESOLUCIONFUNCION" sqlType="STRING"/>
		<param name="CODIGOCARGO" sqlType="STRING"/>
		<param name="VALOR_HORA" sqlType="STRING"/>
		<param name="GRADO" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="CGR_TIPO_VINCULACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cargos">
		<call-query href="updateCargos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
