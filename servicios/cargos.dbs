	</resource>
	<query id="getCargosPagCargostemporalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, CARGOS.RESOLUCIONCARGO, TO_CHAR(CARGOS.FECHARESOLUCION,'DD/MM/YYYY') AS FECHARESOLUCION FROM CARGOS WHERE CARGOS.COMPANIA = :COMPANIA AND CARGOS.ESCALAFON = :ESCALAFON) INI WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_CARGO), '%')) AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEL_CARGO), '%')) AND (CASE WHEN RESOLUCIONCARGO IS NULL THEN ' ' ELSE UPPER(RESOLUCIONCARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:RESOLUCIONCARGO), '%')) AND (CASE WHEN FECHARESOLUCION IS NULL THEN ' ' ELSE UPPER(FECHARESOLUCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHARESOLUCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","RESOLUCIONCARGO":"$RESOLUCIONCARGO","FECHARESOLUCION":"$FECHARESOLUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="RESOLUCIONCARGO" sqlType="STRING"/>
		<param name="FECHARESOLUCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
