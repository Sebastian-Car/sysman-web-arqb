	<query id="getCargosPagEncargoscomisionidipronQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, CARGOS.CODIGOCARGO, CARGOS.GRADO, CARGOS.RESOLUCIONCARGO, TO_CHAR(CARGOS.FECHARESOLUCION,'DD/MM/YYYY') FECHARESOLUCION FROM CARGOS WHERE CARGOS.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_CARGO), '%')) AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEL_CARGO), '%')) AND (CASE WHEN CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(CODIGOCARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCARGO), '%')) AND (CASE WHEN GRADO IS NULL THEN ' ' ELSE UPPER(GRADO) END) LIKE UPPER(CONCAT(CONCAT('%',:GRADO), '%')) AND (CASE WHEN RESOLUCIONCARGO IS NULL THEN ' ' ELSE UPPER(RESOLUCIONCARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:RESOLUCIONCARGO), '%')) AND (CASE WHEN FECHARESOLUCION IS NULL THEN ' ' ELSE UPPER(FECHARESOLUCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHARESOLUCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","CODIGOCARGO":"$CODIGOCARGO","GRADO":"$GRADO","RESOLUCIONCARGO":"$RESOLUCIONCARGO","FECHARESOLUCION":"$FECHARESOLUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="CODIGOCARGO" sqlType="STRING"/>
		<param name="GRADO" sqlType="STRING"/>
		<param name="RESOLUCIONCARGO" sqlType="STRING"/>
		<param name="FECHARESOLUCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cargos/encargoscomisionidipron/pag">
		<call-query href="getCargosPagEncargoscomisionidipronQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="CODIGOCARGO" query-param="CODIGOCARGO"/>
			<with-param name="GRADO" query-param="GRADO"/>
			<with-param name="RESOLUCIONCARGO" query-param="RESOLUCIONCARGO"/>
			<with-param name="FECHARESOLUCION" query-param="FECHARESOLUCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCargosNumEncargoscomisionidipronQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, CARGOS.CODIGOCARGO, CARGOS.GRADO, CARGOS.RESOLUCIONCARGO, TO_CHAR(CARGOS.FECHARESOLUCION,'DD/MM/YYYY') FECHARESOLUCION FROM CARGOS WHERE CARGOS.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_CARGO), '%')) AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEL_CARGO), '%')) AND (CASE WHEN CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(CODIGOCARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCARGO), '%')) AND (CASE WHEN GRADO IS NULL THEN ' ' ELSE UPPER(GRADO) END) LIKE UPPER(CONCAT(CONCAT('%',:GRADO), '%')) AND (CASE WHEN RESOLUCIONCARGO IS NULL THEN ' ' ELSE UPPER(RESOLUCIONCARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:RESOLUCIONCARGO), '%')) AND (CASE WHEN FECHARESOLUCION IS NULL THEN ' ' ELSE UPPER(FECHARESOLUCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHARESOLUCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="CODIGOCARGO" sqlType="STRING"/>
		<param name="GRADO" sqlType="STRING"/>
		<param name="RESOLUCIONCARGO" sqlType="STRING"/>
		<param name="FECHARESOLUCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/encargoscomisionidipron/num">
