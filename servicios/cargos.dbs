	<query id="getCargosNumTodosLosCargosDeSeleccionpersQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID_DE_CARGO CODIGOCARGO, NOMBRE_DEL_CARGO NOMBRE_CARGO, GRADO, DATE_CREATED AS FECHA_CREACION, DENOMINACION  FROM CARGOS WHERE COMPANIA=:COMPANIA ORDER BY GRADO) WHERE (CASE WHEN CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(CODIGOCARGO) END)  LIKE UPPER(:CODIGOCARGO || '%')  AND (CASE WHEN NOMBRE_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_CARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOCARGO" sqlType="STRING"/>
		<param name="NOMBRE_CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/todosloscargosdeseleccionpers/num">
		<call-query href="getCargosNumTodosLosCargosDeSeleccionpersQuery">
