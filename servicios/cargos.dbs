	<query id="getCargosPagCodigocargocategoriaanoescalafonsalarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CATEGORIA.ID_DE_CATEGORIA CODIGOCARGO, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.ANO, CATEGORIA.ESCALAFON, CATEGORIA.SALARIO_BASE, CATEGORIA.GRADO, CARGOS.PLAZAS, EV_REQUISITOS.TIPO_REQUISITO, EV_REQUISITOS.ALTERNATIVA, EV_REQUISITOS.DESCRIPCION, EV_MANUAL.NUMERO_MANUAL  FROM CATEGORIA INNER JOIN CARGOS ON CATEGORIA.COMPANIA = CARGOS.COMPANIA AND CATEGORIA.ID_DE_CATEGORIA = SUBSTR(CARGOS.ID_DE_CARGO,-3) AND CATEGORIA.ESCALAFON = CARGOS.ESCALAFON INNER JOIN EV_MANUAL ON CATEGORIA.COMPANIA = EV_MANUAL.COMPANIA AND CATEGORIA.ESCALAFON = EV_MANUAL.ESCALAFON LEFT JOIN EV_MANUAL EV1 ON CARGOS.COMPANIA = EV1.COMPANIA AND CARGOS.ESCALAFON = EV1.ESCALAFON AND CARGOS.ID_DE_CARGO = EV1.CARGO INNER JOIN EV_REQUISITOS ON EV_MANUAL.COMPANIA = EV_REQUISITOS.COMPANIA AND EV_MANUAL.NUMERO_MANUAL = EV_REQUISITOS.NUMERO_MANUAL AND EV_MANUAL.VERSION = EV_REQUISITOS.VERSION WHERE CATEGORIA.COMPANIA =:COMPANIA AND CARGOS.ESTADOCARGO IN ('1') AND CARGOS.PLAZAS &gt; '0' AND EV_REQUISITOS.TIPO_REQUISITO IN ('00001','00002') AND CATEGORIA.ANO = :ANO ORDER BY CARGOS.ID_DE_CARGO, CATEGORIA.ANO) WHERE (CASE WHEN CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(CODIGOCARGO) END)  LIKE UPPER(:CODIGOCARGO || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPO_REQUISITO IS NULL THEN ' ' ELSE UPPER(TIPO_REQUISITO) END)  LIKE UPPER(:TIPO_REQUISITO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOCARGO":"$CODIGOCARGO","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","ANO":"$ANO(type:integer)","ESCALAFON":"$ESCALAFON","SALARIO_BASE":"$SALARIO_BASE","GRADO":"$GRADO","PLAZAS":"$PLAZAS","TIPO_REQUISITO":"$TIPO_REQUISITO","ALTERNATIVA":"$ALTERNATIVA(type:integer)","DESCRIPCION":"$DESCRIPCION","NUMERO_MANUAL":"$NUMERO_MANUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOCARGO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="TIPO_REQUISITO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
