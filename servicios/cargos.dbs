		</call-query>
	</resource>
	<query id="getCargosPagCargosYCategoriasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO CODIGOCARGO, CARGOS.NOMBRE_DEL_CARGO NOMBRE_CARGO, CATEGORIA.ANO , CARGOS.GRADO, CARGOS.ESCALAFON, CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.SALARIO_BASE, CARGOS.PLAZAS  FROM CARGOS LEFT JOIN CATEGORIA ON CATEGORIA.COMPANIA = CARGOS.COMPANIA AND CATEGORIA.ESCALAFON = CARGOS.ESCALAFON AND CATEGORIA.GRADO = CARGOS.GRADO WHERE CARGOS.COMPANIA =:COMPANIA AND CARGOS.ESTADOCARGO IN ('1') ORDER BY CARGOS.ID_DE_CARGO, CATEGORIA.ANO) WHERE (CASE WHEN CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(CODIGOCARGO) END)  LIKE UPPER(:CODIGOCARGO || '%')  AND (CASE WHEN NOMBRE_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_CARGO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PLAZAS IS NULL THEN ' ' ELSE UPPER(PLAZAS) END)  LIKE UPPER( '%' || :PLAZAS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOCARGO":"$CODIGOCARGO","NOMBRE_CARGO":"$NOMBRE_CARGO","ANO":"$ANO(type:integer)","GRADO":"$GRADO","ESCALAFON":"$ESCALAFON","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE","PLAZAS":"$PLAZAS"}]}}		</result>
