 ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN NOMBRECATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRECATEGORIA) END)  LIKE UPPER( '%' || :NOMBRECATEGORIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
