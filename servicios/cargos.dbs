	<query id="getCargosPagCargosnombreanoescalafonsalariobaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CATEGORIA.ID_DE_CATEGORIA CODIGOCARGO, CATEGORIA.NOMBRE_CATEGORIA, CATEGORIA.ANO, CATEGORIA.ESCALAFON, CATEGORIA.SALARIO_BASE, CATEGORIA.GRADO, CARGOS.PLAZAS  FROM CATEGORIA INNER JOIN CARGOS ON CATEGORIA.COMPANIA = CARGOS.COMPANIA AND CATEGORIA.ID_DE_CATEGORIA = SUBSTR(CARGOS.ID_DE_CARGO,-3) AND CATEGORIA.ESCALAFON = CARGOS.ESCALAFON WHERE CATEGORIA.COMPANIA =:COMPANIA AND CARGOS.ESTADOCARGO IN ('1') AND CARGOS.PLAZAS &gt; '0' ORDER BY CARGOS.ID_DE_CARGO, CATEGORIA.ANO) WHERE (CASE WHEN CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(CODIGOCARGO) END)  LIKE UPPER(:CODIGOCARGO || '%')  AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END)  LIKE UPPER( '%' || :NOMBRE_CATEGORIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOCARGO":"$CODIGOCARGO","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","ANO":"$ANO(type:integer)","ESCALAFON":"$ESCALAFON","SALARIO_BASE":"$SALARIO_BASE","GRADO":"$GRADO","PLAZAS":"$PLAZAS"}]}}		</result>
