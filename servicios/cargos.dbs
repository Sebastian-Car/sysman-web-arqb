	</resource>
	<query id="getCargosPagCargoporescalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, CARGOS.ESCALAFON  FROM CARGOS WHERE CARGOS.ESCALAFON= :ESCALAFON AND CARGOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER(:ESCALAFON || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","ESCALAFON":"$ESCALAFON"}]}}		</result>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cargos/cargoporescalafon/pag">
		<call-query href="getCargosPagCargoporescalafonQuery">
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCargosNumCargoporescalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, CARGOS.ESCALAFON  FROM CARGOS WHERE CARGOS.ESCALAFON= :ESCALAFON AND CARGOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER(:ESCALAFON || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cargos/cargoporescalafon/num">
		<call-query href="getCargosNumCargoporescalafonQuery">
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>

		</call-query>
	</resource>
	<query id="getCargosPagTodosLosCargosDeSeleccionpersQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_DE_CARGO CODIGOCARGO, NOMBRE_DEL_CARGO NOMBRE_CARGO, GRADO, DATE_CREATED AS FECHA_CREACION, DENOMINACION  FROM CARGOS WHERE COMPANIA=:COMPANIA ORDER BY GRADO) WHERE (CASE WHEN CODIGOCARGO IS NULL THEN ' ' ELSE UPPER(CODIGOCARGO) END)  LIKE UPPER(:CODIGOCARGO || '%')  AND (CASE WHEN NOMBRE_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_CARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOCARGO":"$CODIGOCARGO","NOMBRE_CARGO":"$NOMBRE_CARGO","GRADO":"$GRADO","FECHA_CREACION":"$FECHA_CREACION","DENOMINACION":"$DENOMINACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOCARGO" sqlType="STRING"/>
		<param name="NOMBRE_CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
