	<query id="getOrdenesdesuministroPagTpmovimientoclasenumerofechadescQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TM.CODIGO CLASEDOC, OS.NUMERO, TO_CHAR(OS.FECHA, 'DD/MM/YYYY') FECHA, OS.DESCRIPCION  FROM ORDENDESUMINISTRO OS INNER JOIN DEPENDENCIA DEP ON DEP.COMPANIA = OS.COMPANIA AND DEP.CODIGO = OS.DEPENDENCIA INNER JOIN CLASE_BODEGA CB ON CB.CODIGO = DEP.CLASE_BODEGA INNER JOIN TIPOMOVIMIENTO TM ON TM.CLASE_BODEGA_ORIGEN = CB.CODIGO WHERE OS.COMPANIA = :COMPANIA ORDER BY OS.NUMERO DESC) WHERE (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END)  LIKE UPPER(:CLASEDOC || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEDOC":"$CLASEDOC","NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
