		<sql>UPDATE ORDENDESUMINISTRO SET VACIA = :VALOR,     DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),     MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA   AND NUMERO = :ORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
