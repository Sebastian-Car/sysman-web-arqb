		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT ORDENDESUMINISTRO.COMPANIA, ORDENDESUMINISTRO.NUMERO, TO_CHAR( FECHA, 'DD/MM/YYYY' ) FECHA, DEPENDENCIA.NOMBRE, VALORESTIMADO, DESCRIPCION,(CASE D_ORDENDESUMINISTRO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG FROM ORDENDESUMINISTRO INNER JOIN DEPENDENCIA ON ORDENDESUMINISTRO.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDESUMINISTRO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN D_ORDENDESUMINISTRO ON ORDENDESUMINISTRO.COMPANIA = D_ORDENDESUMINISTRO.COMPANIA AND ORDENDESUMINISTRO.NUMERO = D_ORDENDESUMINISTRO.ORDENDESUMINISTRO WHERE ORDENDESUMINISTRO.COMPANIA = :COMPANIA AND DEPENDENCIA.CODIGO = :DEPENDENCIA ORDER BY ORDENDESUMINISTRO.COMPANIA, NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALORESTIMADO IS NULL THEN ' ' ELSE UPPER(VALORESTIMADO) END)  LIKE UPPER(:VALORESTIMADO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
