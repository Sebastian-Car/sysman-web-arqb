	<query id="getOrdenesdesuministroPagPorDocAsociadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  :DOCASOCIADO CLASEDOC, T.NUMERO, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, T.DESCRIPCION  FROM ORDENDESUMINISTRO T WHERE T.COMPANIA = :COMPANIA ORDER BY T.NUMERO DESC) WHERE (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END)  LIKE UPPER(:CLASEDOC || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEDOC":"$CLASEDOC","NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="DOCASOCIADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
