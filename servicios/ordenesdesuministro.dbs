	<query id="updateOrdenesdesuministroVaciaYCantidadPorNumero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDESUMINISTRO SET VACIA = :VACIA, CANTIDADPORENTREGAR = :CANTIDAD,    DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),     MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA   AND NUMERO = :NUMERO AND CODIGO = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VACIA" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenesdesuministro/vaciaycantidadpornumero">
		<call-query href="updateOrdenesdesuministroVaciaYCantidadPorNumero">
			<with-param name="VACIA" query-param="VACIA"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertOrdenesdesuministro" keyColumns="COMPANIA,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ORDENDESUMINISTRO (COMPANIA, NUMERO, FECHA, DEPENDENCIA, TERCERO, SUCURSAL, VALORESTIMADO, DESCRIPCION, OBSERVACIONES, PLAZO, UNIDAD_TIEMPO, PERIODICIDAD, NUMERO_ENTREGAS, CLASE_BODEGA, AUXILIAR, ESTADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :DEPENDENCIA, :TERCERO, :SUCURSAL, :VALORESTIMADO, :DESCRIPCION, :OBSERVACIONES, :PLAZO, :UNIDAD_TIEMPO, :PERIODICIDAD, :NUMERO_ENTREGAS, :CLASE_BODEGA, :AUXILIAR, :ESTADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORESTIMADO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZO" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD_TIEMPO" sqlType="STRING"/>
		<param defaultValue="" name="PERIODICIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO_ENTREGAS" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_BODEGA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ordenesdesuministro">
		<call-query href="insertOrdenesdesuministro">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="VALORESTIMADO" query-param="VALORESTIMADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PLAZO" query-param="PLAZO"/>
			<with-param name="UNIDAD_TIEMPO" query-param="UNIDAD_TIEMPO"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="NUMERO_ENTREGAS" query-param="NUMERO_ENTREGAS"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteOrdenesdesuministro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ORDENDESUMINISTRO WHERE ORDENDESUMINISTRO.COMPANIA= :KEY_COMPANIA AND ORDENDESUMINISTRO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ordenesdesuministro">
		<call-query href="deleteOrdenesdesuministro">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getOrdenesdesuministroPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT ORDENDESUMINISTRO.COMPANIA, ORDENDESUMINISTRO.NUMERO, TO_CHAR( FECHA, 'DD/MM/YYYY' ) FECHA, DEPENDENCIA.NOMBRE, VALORESTIMADO, DESCRIPCION,(CASE D_ORDENDESUMINISTRO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG, ORDENDESUMINISTRO.ESTADO FROM ORDENDESUMINISTRO INNER JOIN DEPENDENCIA ON ORDENDESUMINISTRO.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDESUMINISTRO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN D_ORDENDESUMINISTRO ON ORDENDESUMINISTRO.COMPANIA = D_ORDENDESUMINISTRO.COMPANIA AND ORDENDESUMINISTRO.NUMERO = D_ORDENDESUMINISTRO.ORDENDESUMINISTRO WHERE ORDENDESUMINISTRO.COMPANIA = :COMPANIA ORDER BY ORDENDESUMINISTRO.COMPANIA, NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VALORESTIMADO IS NULL THEN ' ' ELSE UPPER(VALORESTIMADO) END) LIKE UPPER(CONCAT(:VALORESTIMADO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO","FECHA":"$FECHA","NOMBRE":"$NOMBRE","VALORESTIMADO":"$VALORESTIMADO","DESCRIPCION":"$DESCRIPCION","IND_REG":"$IND_REG(type:boolean)","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALORESTIMADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

