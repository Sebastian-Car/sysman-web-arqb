<data name="ordenesdesuministro" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateOrdenesdesuministroSeleccionadas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDESUMINISTRO SET SELECCIONADA=:SELECCIONADA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ORDENDESUMINISTRO.COMPANIA= :KEY_COMPANIA AND ORDENDESUMINISTRO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SELECCIONADA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenesdesuministro/seleccionadas">
		<call-query href="updateOrdenesdesuministroSeleccionadas">
			<with-param name="SELECCIONADA" query-param="SELECCIONADA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getOrdenesdesuministroPagVaciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDESUMINISTRO.COMPANIA,(CASE ORDENDESUMINISTRO.VACIA WHEN 0 THEN 'false' ELSE 'true' END) VACIA, ORDENDESUMINISTRO.NUMERO,(TO_CHAR(ORDENDESUMINISTRO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ORDENDESUMINISTRO.DESCRIPCION,(CASE ORDENDESUMINISTRO.SELECCIONADA WHEN 0 THEN 'false' ELSE 'true' END) SELECCIONADA FROM ORDENDESUMINISTRO INNER JOIN D_ORDENDESUMINISTRO ON (ORDENDESUMINISTRO.NUMERO = D_ORDENDESUMINISTRO.ORDENDESUMINISTRO) AND (ORDENDESUMINISTRO.COMPANIA = D_ORDENDESUMINISTRO.COMPANIA) WHERE ORDENDESUMINISTRO.COMPANIA = :COMPANIA AND ORDENDESUMINISTRO.VACIA IN 0 AND (CASE WHEN :MENU = '400204' THEN ORDENDESUMINISTRO.SELECCIONADA ELSE 0 END) IN 0 GROUP BY ORDENDESUMINISTRO.COMPANIA, ORDENDESUMINISTRO.VACIA, ORDENDESUMINISTRO.NUMERO, ORDENDESUMINISTRO.FECHA, ORDENDESUMINISTRO.DESCRIPCION, ORDENDESUMINISTRO.SELECCIONADA HAVING SUM(D_ORDENDESUMINISTRO.CANTIDADPORENTREGAR) &gt; 0 ORDER BY ORDENDESUMINISTRO.COMPANIA) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN SELECCIONADA IS NULL THEN ' ' ELSE UPPER(SELECCIONADA) END)  LIKE UPPER(:SELECCIONADA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VACIA":"$VACIA(type:boolean)","NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","SELECCIONADA":"$SELECCIONADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MENU" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="SELECCIONADA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenesdesuministro/vacias/pag">
		<call-query href="getOrdenesdesuministroPagVaciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MENU" query-param="MENU"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="SELECCIONADA" query-param="SELECCIONADA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenesdesuministroNumVaciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ORDENDESUMINISTRO.COMPANIA,(CASE ORDENDESUMINISTRO.VACIA WHEN 0 THEN 'false' ELSE 'true' END) VACIA, ORDENDESUMINISTRO.NUMERO,(TO_CHAR(ORDENDESUMINISTRO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ORDENDESUMINISTRO.DESCRIPCION,(CASE ORDENDESUMINISTRO.SELECCIONADA WHEN 0 THEN 'false' ELSE 'true' END) SELECCIONADA FROM ORDENDESUMINISTRO INNER JOIN D_ORDENDESUMINISTRO ON (ORDENDESUMINISTRO.NUMERO = D_ORDENDESUMINISTRO.ORDENDESUMINISTRO) AND (ORDENDESUMINISTRO.COMPANIA = D_ORDENDESUMINISTRO.COMPANIA) WHERE ORDENDESUMINISTRO.COMPANIA = :COMPANIA AND ORDENDESUMINISTRO.VACIA IN 0 AND (CASE WHEN :MENU = '400204' THEN ORDENDESUMINISTRO.SELECCIONADA ELSE 0 END) IN 0 GROUP BY ORDENDESUMINISTRO.COMPANIA, ORDENDESUMINISTRO.VACIA, ORDENDESUMINISTRO.NUMERO, ORDENDESUMINISTRO.FECHA, ORDENDESUMINISTRO.DESCRIPCION, ORDENDESUMINISTRO.SELECCIONADA HAVING SUM(D_ORDENDESUMINISTRO.CANTIDADPORENTREGAR) &gt; 0 ORDER BY ORDENDESUMINISTRO.COMPANIA) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN SELECCIONADA IS NULL THEN ' ' ELSE UPPER(SELECCIONADA) END)  LIKE UPPER( '%' || :SELECCIONADA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MENU" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="SELECCIONADA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenesdesuministro/vacias/num">
		<call-query href="getOrdenesdesuministroNumVaciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MENU" query-param="MENU"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="SELECCIONADA" query-param="SELECCIONADA"/>

		</call-query>
	</resource>
	<query id="getOrdenesdesuministroCantidadTotalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(D_ORDENDESUMINISTRO.CANTIDADTT) CANTIDADTOTAL, D_ORDENDESUMINISTRO.ORDENDESUMINISTRO  FROM D_ORDENDESUMINISTRO WHERE D_ORDENDESUMINISTRO.COMPANIA = :COMPANIA GROUP BY D_ORDENDESUMINISTRO.ORDENDESUMINISTRO, D_ORDENDESUMINISTRO.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDADTOTAL":"$CANTIDADTOTAL(type:integer)","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenesdesuministro/cantidadtotal">
		<call-query href="getOrdenesdesuministroCantidadTotalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getOrdenesdesuministroSinSeleccionarConCantidadPorEntregarQuery"  useConfig="sysmandsunist">
		<sql>SELECT  D_ORDENDESUMINISTRO.COMPANIA, NVL(D_ORDENDESUMINISTRO.ORDENDESUMINISTRO,0) AS ORDENDESUMINISTRO, NVL(D_ORDENDESUMINISTRO.CODIGO,0) AS CODIGO, NVL(D_ORDENDESUMINISTRO.ELEMENTO,'') AS ELEMENTO, D_ORDENDESUMINISTRO.ESPECIFICACION, NVL(CANTIDADPORENTREGAR,0) AS CANTORDENADA , D_ORDENDESUMINISTRO.DEPENDENCIA, ORDENDESUMINISTRO.DESCRIPCION , NVL(D_ORDENDESUMINISTRO.CODIGOCUBS,'') AS CUBS, ORDENDESUMINISTRO.PERIODICIDAD, NVL(ORDENDESUMINISTRO.NUMERO_ENTREGAS,0) AS NUMERO_ENTREGAS, ORDENDESUMINISTRO.UNIDAD_TIEMPO, NVL(ORDENDESUMINISTRO.PLAZO,0) AS PLAZO  FROM ORDENDESUMINISTRO INNER JOIN D_ORDENDESUMINISTRO ON (ORDENDESUMINISTRO.NUMERO = D_ORDENDESUMINISTRO.ORDENDESUMINISTRO) AND (ORDENDESUMINISTRO.COMPANIA = D_ORDENDESUMINISTRO.COMPANIA) WHERE ORDENDESUMINISTRO.SELECCIONADA &lt;&gt; 0 AND CANTIDADPORENTREGAR &gt; 0 AND D_ORDENDESUMINISTRO.COMPANIA = :COMPANIA ORDER BY D_ORDENDESUMINISTRO.COMPANIA, D_ORDENDESUMINISTRO.ORDENDESUMINISTRO, D_ORDENDESUMINISTRO.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO(type:integer)","CODIGO":"$CODIGO(type:integer)","ELEMENTO":"$ELEMENTO","ESPECIFICACION":"$ESPECIFICACION","CANTORDENADA":"$CANTORDENADA(type:integer)","DEPENDENCIA":"$DEPENDENCIA","DESCRIPCION":"$DESCRIPCION","CUBS":"$CUBS","PERIODICIDAD":"$PERIODICIDAD","NUMERO_ENTREGAS":"$NUMERO_ENTREGAS(type:integer)","UNIDAD_TIEMPO":"$UNIDAD_TIEMPO","PLAZO":"$PLAZO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenesdesuministro/sinseleccionarconcantidadporentregar">
		<call-query href="getOrdenesdesuministroSinSeleccionarConCantidadPorEntregarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateOrdenesdesuministroVaciasYSeleccionadas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDESUMINISTRO SET SELECCIONADA = :VALOR,     DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),     MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA   AND VACIA &lt;&gt; 0   AND SELECCIONADA &lt;&gt; 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenesdesuministro/vaciasyseleccionadas">
		<call-query href="updateOrdenesdesuministroVaciasYSeleccionadas">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
