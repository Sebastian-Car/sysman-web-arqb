	<query id="getOrdenesdesuministroPagPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDESUMINISTRO.NUMERO, ORDENDESUMINISTRO.DESCRIPCION,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM ORDENDESUMINISTRO WHERE ORDENDESUMINISTRO.COMPANIA =:COMPANIA ORDER BY ORDENDESUMINISTRO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA"}]}}		</result>
