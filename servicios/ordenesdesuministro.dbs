	<query id="getOrdenesdesuministroNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT ORDENDESUMINISTRO.COMPANIA, ORDENDESUMINISTRO.NUMERO, TO_CHAR( FECHA, 'DD/MM/YYYY' ) FECHA, DEPENDENCIA.NOMBRE, VALORESTIMADO, DESCRIPCION,(CASE D_ORDENDESUMINISTRO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG, ORDENDESUMINISTRO.ESTADO FROM ORDENDESUMINISTRO INNER JOIN DEPENDENCIA ON ORDENDESUMINISTRO.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDESUMINISTRO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN D_ORDENDESUMINISTRO ON ORDENDESUMINISTRO.COMPANIA = D_ORDENDESUMINISTRO.COMPANIA AND ORDENDESUMINISTRO.NUMERO = D_ORDENDESUMINISTRO.ORDENDESUMINISTRO WHERE ORDENDESUMINISTRO.COMPANIA = :COMPANIA ORDER BY ORDENDESUMINISTRO.COMPANIA, NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VALORESTIMADO IS NULL THEN ' ' ELSE UPPER(VALORESTIMADO) END) LIKE UPPER(CONCAT(:VALORESTIMADO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALORESTIMADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenesdesuministro/numero">
