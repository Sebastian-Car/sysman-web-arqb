	<resource method="PUT" path="ordenesdesuministro/indicadorseleccionada">
		<call-query href="updateOrdenesdesuministroIndicadorSeleccionada">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
