	<query id="getOrdenesdesuministroPagListarpordependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT ORDENDESUMINISTRO.COMPANIA, ORDENDESUMINISTRO.NUMERO, TO_CHAR( FECHA, 'DD/MM/YYYY' ) FECHA, DEPENDENCIA.NOMBRE, VALORESTIMADO, DESCRIPCION,(CASE D_ORDENDESUMINISTRO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG FROM ORDENDESUMINISTRO INNER JOIN DEPENDENCIA ON ORDENDESUMINISTRO.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDESUMINISTRO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN D_ORDENDESUMINISTRO ON ORDENDESUMINISTRO.COMPANIA = D_ORDENDESUMINISTRO.COMPANIA AND ORDENDESUMINISTRO.NUMERO = D_ORDENDESUMINISTRO.ORDENDESUMINISTRO WHERE ORDENDESUMINISTRO.COMPANIA = :COMPANIA AND DEPENDENCIA.CODIGO = :DEPENDENCIA ORDER BY ORDENDESUMINISTRO.COMPANIA, NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALORESTIMADO IS NULL THEN ' ' ELSE UPPER(VALORESTIMADO) END)  LIKE UPPER(:VALORESTIMADO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO","FECHA":"$FECHA","NOMBRE":"$NOMBRE","VALORESTIMADO":"$VALORESTIMADO","DESCRIPCION":"$DESCRIPCION","IND_REG":"$IND_REG(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALORESTIMADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
