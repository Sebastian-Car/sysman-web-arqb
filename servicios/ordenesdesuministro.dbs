	<query id="updateOrdenesdesuministroIndicadorSeleccionada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDESUMINISTRO SET SELECCIONADA = :VALOR,     DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),     MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA   AND SELECCIONADA NOT IN 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
