			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getOrdenesdesuministroRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, NUMERO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DEPENDENCIA, TERCERO, SUCURSAL, VALORESTIMADO, DESCRIPCION, OBSERVACIONES, PLAZO, UNIDAD_TIEMPO, PERIODICIDAD, NUMERO_ENTREGAS, CLASE_BODEGA, AUXILIAR, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ESTADO FROM ORDENDESUMINISTRO WHERE ORDENDESUMINISTRO.COMPANIA= :KEY_COMPANIA AND ORDENDESUMINISTRO.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DEPENDENCIA":"$DEPENDENCIA","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","VALORESTIMADO":"$VALORESTIMADO(type:double)","DESCRIPCION":"$DESCRIPCION","OBSERVACIONES":"$OBSERVACIONES","PLAZO":"$PLAZO(type:long)","UNIDAD_TIEMPO":"$UNIDAD_TIEMPO","PERIODICIDAD":"$PERIODICIDAD","NUMERO_ENTREGAS":"$NUMERO_ENTREGAS(type:long)","CLASE_BODEGA":"$CLASE_BODEGA","AUXILIAR":"$AUXILIAR","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","ESTADO":"$ESTADO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenesdesuministro/data">
		<call-query href="getOrdenesdesuministroRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateOrdenesdesuministro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDESUMINISTRO SET COMPANIA=:COMPANIA, NUMERO=:NUMERO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA=:DEPENDENCIA, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, VALORESTIMADO=:VALORESTIMADO, DESCRIPCION=:DESCRIPCION, OBSERVACIONES=:OBSERVACIONES, PLAZO=:PLAZO, UNIDAD_TIEMPO=:UNIDAD_TIEMPO, PERIODICIDAD=:PERIODICIDAD, NUMERO_ENTREGAS=:NUMERO_ENTREGAS, CLASE_BODEGA=:CLASE_BODEGA, AUXILIAR=:AUXILIAR, ESTADO=:ESTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ORDENDESUMINISTRO.COMPANIA= :KEY_COMPANIA AND ORDENDESUMINISTRO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="VALORESTIMADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PLAZO" sqlType="STRING"/>
		<param name="UNIDAD_TIEMPO" sqlType="STRING"/>
		<param name="PERIODICIDAD" sqlType="STRING"/>
		<param name="NUMERO_ENTREGAS" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
