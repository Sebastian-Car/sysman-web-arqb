	<query id="getOrdenesdesuministroPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDESUMINISTRO.NUMERO, ORDENDESUMINISTRO.DESCRIPCION, ORDENDESUMINISTRO.VALORESTIMADO, ORDENDESUMINISTRO.NSOLICITUDDISPON, ORDENDESUMINISTRO.CONCEPTO, TRIM(TERCERO.NOMBRE) NOMBRERESPONSABLE, DEPENDENCIA.NOMBRE DEPENDENCIANOMBRE  FROM ORDENDESUMINISTRO LEFT JOIN DEPENDENCIA ON ORDENDESUMINISTRO.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDESUMINISTRO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN RESPONSABLE ON ORDENDESUMINISTRO.COMPANIA = RESPONSABLE.COMPANIA AND ORDENDESUMINISTRO.TERCERO = RESPONSABLE.CEDULA AND ORDENDESUMINISTRO.SUCURSAL = RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON TERCERO.COMPANIA =RESPONSABLE.COMPANIA AND TERCERO.NIT =RESPONSABLE.CEDULA AND TERCERO.SUCURSAL =RESPONSABLE.SUCURSAL WHERE ORDENDESUMINISTRO.COMPANIA =:COMPANIA ORDER BY ORDENDESUMINISTRO.COMPANIA, ORDENDESUMINISTRO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DESCRIPCION":"$DESCRIPCION","VALORESTIMADO":"$VALORESTIMADO","NSOLICITUDDISPON":"$NSOLICITUDDISPON","CONCEPTO":"$CONCEPTO","NOMBRERESPONSABLE":"$NOMBRERESPONSABLE","DEPENDENCIANOMBRE":"$DEPENDENCIANOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
