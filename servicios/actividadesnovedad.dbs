<data name="actividadesnovedad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getActividadesnovedadGetporcentajeacumuladoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(PORCENTAJE_CUMPLIMIENTO) AS PORC_ACUM  FROM ACTIVIDADES_NOVEDAD WHERE CODIGO_ACTIVIDAD = :CODIGO_ACTIVIDAD AND COD_CONTRATO = :COD_CONTRATO AND TIPO_CONTRATO = :TIPO_CONTRATO AND CODIGO_NOVEDAD = :CODIGO_NOVEDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PORC_ACUM":"$PORC_ACUM(type:integer)"}]}}		</result>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="COD_CONTRATO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="CODIGO_NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="actividadesnovedad/getporcentajeacumulado">
		<call-query href="getActividadesnovedadGetporcentajeacumuladoQuery">
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="COD_CONTRATO" query-param="COD_CONTRATO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="CODIGO_NOVEDAD" query-param="CODIGO_NOVEDAD"/>

		</call-query>
	</resource>
	<query id="updateActividadesnovedadUpdateporcentajeacumulado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ACTIVIDADES_NOVEDAD SET PORCENTAJE_ACUMULADO = :PORCENTAJE_ACUMULADO,   MODIFIED_BY   = :USUARIO,   DATE_MODIFIED = SYSDATE WHERE COMPANIA       = :COMPANIA AND COD_CONTRATO     = :COD_CONTRATO AND TIPO_CONTRATO    = :TIPO_CONTRATO AND CODIGO_ACTA NOT IN (:CODIGO_ACTA)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PORCENTAJE_ACUMULADO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_CONTRATO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="CODIGO_ACTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="actividadesnovedad/updateporcentajeacumulado">
		<call-query href="updateActividadesnovedadUpdateporcentajeacumulado">
			<with-param name="PORCENTAJE_ACUMULADO" query-param="PORCENTAJE_ACUMULADO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_CONTRATO" query-param="COD_CONTRATO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="CODIGO_ACTA" query-param="CODIGO_ACTA"/>

		</call-query>
	</resource>
	<query id="deleteActividadesnovedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ACTIVIDADES_NOVEDAD WHERE ACTIVIDADES_NOVEDAD.COMPANIA= :KEY_COMPANIA AND ACTIVIDADES_NOVEDAD.CODIGO_ACTIVIDAD= :KEY_CODIGO_ACTIVIDAD AND ACTIVIDADES_NOVEDAD.CODIGO_ACTA= :KEY_CODIGO_ACTA AND ACTIVIDADES_NOVEDAD.CODIGO_NOVEDAD= :KEY_CODIGO_NOVEDAD AND ACTIVIDADES_NOVEDAD.TIPO_NOVEDAD= :KEY_TIPO_NOVEDAD AND ACTIVIDADES_NOVEDAD.COD_CONTRATO= :KEY_COD_CONTRATO AND ACTIVIDADES_NOVEDAD.TIPO_CONTRATO= :KEY_TIPO_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="KEY_CODIGO_ACTA" sqlType="STRING"/>
		<param name="KEY_CODIGO_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_TIPO_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_COD_CONTRATO" sqlType="STRING"/>
		<param name="KEY_TIPO_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="actividadesnovedad">
		<call-query href="deleteActividadesnovedad">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_ACTIVIDAD" query-param="KEY_CODIGO_ACTIVIDAD"/>
			<with-param name="KEY_CODIGO_ACTA" query-param="KEY_CODIGO_ACTA"/>
			<with-param name="KEY_CODIGO_NOVEDAD" query-param="KEY_CODIGO_NOVEDAD"/>
			<with-param name="KEY_TIPO_NOVEDAD" query-param="KEY_TIPO_NOVEDAD"/>
			<with-param name="KEY_COD_CONTRATO" query-param="KEY_COD_CONTRATO"/>
			<with-param name="KEY_TIPO_CONTRATO" query-param="KEY_TIPO_CONTRATO"/>

		</call-query>
	</resource>
	<query id="getActividadesnovedadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , CODIGO_ACTIVIDAD, CODIGO_ACTA, CODIGO_NOVEDAD, TIPO_NOVEDAD, COD_CONTRATO, TIPO_CONTRATO, PORCENTAJE_CUMPLIMIENTO, PORCENTAJE_ACUMULADO  FROM ACTIVIDADES_NOVEDAD WHERE COMPANIA = :COMPANIA AND CODIGO_ACTA = :CODIGO_ACTA AND CODIGO_NOVEDAD = :CODIGO_NOVEDAD AND TIPO_NOVEDAD = :TIPO_NOVEDAD AND COD_CONTRATO = :COD_CONTRATO AND TIPO_CONTRATO = :TIPO_CONTRATO) WHERE (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END)  LIKE UPPER( '%' || :CODIGO_ACTIVIDAD || '%')  AND (CASE WHEN PORCENTAJE_CUMPLIMIENTO IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_CUMPLIMIENTO) END)  LIKE UPPER(:PORCENTAJE_CUMPLIMIENTO || '%')  AND (CASE WHEN PORCENTAJE_ACUMULADO IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_ACUMULADO) END)  LIKE UPPER(:PORCENTAJE_ACUMULADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_ACTIVIDAD":"$CODIGO_ACTIVIDAD","CODIGO_ACTA":"$CODIGO_ACTA","CODIGO_NOVEDAD":"$CODIGO_NOVEDAD","TIPO_NOVEDAD":"$TIPO_NOVEDAD","COD_CONTRATO":"$COD_CONTRATO","TIPO_CONTRATO":"$TIPO_CONTRATO","PORCENTAJE_CUMPLIMIENTO":"$PORCENTAJE_CUMPLIMIENTO(type:double)","PORCENTAJE_ACUMULADO":"$PORCENTAJE_ACUMULADO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_ACTA" sqlType="STRING"/>
		<param name="CODIGO_NOVEDAD" sqlType="STRING"/>
		<param name="TIPO_NOVEDAD" sqlType="STRING"/>
		<param name="COD_CONTRATO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="PORCENTAJE_CUMPLIMIENTO" sqlType="STRING"/>
		<param name="PORCENTAJE_ACUMULADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="actividadesnovedad">
		<call-query href="getActividadesnovedadPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_ACTA" query-param="CODIGO_ACTA"/>
			<with-param name="CODIGO_NOVEDAD" query-param="CODIGO_NOVEDAD"/>
			<with-param name="TIPO_NOVEDAD" query-param="TIPO_NOVEDAD"/>
			<with-param name="COD_CONTRATO" query-param="COD_CONTRATO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="PORCENTAJE_CUMPLIMIENTO" query-param="PORCENTAJE_CUMPLIMIENTO"/>
			<with-param name="PORCENTAJE_ACUMULADO" query-param="PORCENTAJE_ACUMULADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getActividadesnovedadNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , CODIGO_ACTIVIDAD, CODIGO_ACTA, CODIGO_NOVEDAD, TIPO_NOVEDAD, COD_CONTRATO, TIPO_CONTRATO, PORCENTAJE_CUMPLIMIENTO, PORCENTAJE_ACUMULADO  FROM ACTIVIDADES_NOVEDAD WHERE COMPANIA = :COMPANIA AND CODIGO_ACTA = :CODIGO_ACTA AND CODIGO_NOVEDAD = :CODIGO_NOVEDAD AND TIPO_NOVEDAD = :TIPO_NOVEDAD AND COD_CONTRATO = :COD_CONTRATO AND TIPO_CONTRATO = :TIPO_CONTRATO) WHERE (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END)  LIKE UPPER( '%' || :CODIGO_ACTIVIDAD || '%')  AND (CASE WHEN PORCENTAJE_CUMPLIMIENTO IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_CUMPLIMIENTO) END)  LIKE UPPER(:PORCENTAJE_CUMPLIMIENTO || '%')  AND (CASE WHEN PORCENTAJE_ACUMULADO IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_ACUMULADO) END)  LIKE UPPER(:PORCENTAJE_ACUMULADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_ACTA" sqlType="STRING"/>
		<param name="CODIGO_NOVEDAD" sqlType="STRING"/>
		<param name="TIPO_NOVEDAD" sqlType="STRING"/>
		<param name="COD_CONTRATO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="PORCENTAJE_CUMPLIMIENTO" sqlType="STRING"/>
		<param name="PORCENTAJE_ACUMULADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="actividadesnovedad/numero">
		<call-query href="getActividadesnovedadNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_ACTA" query-param="CODIGO_ACTA"/>
			<with-param name="CODIGO_NOVEDAD" query-param="CODIGO_NOVEDAD"/>
			<with-param name="TIPO_NOVEDAD" query-param="TIPO_NOVEDAD"/>
			<with-param name="COD_CONTRATO" query-param="COD_CONTRATO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="PORCENTAJE_CUMPLIMIENTO" query-param="PORCENTAJE_CUMPLIMIENTO"/>
			<with-param name="PORCENTAJE_ACUMULADO" query-param="PORCENTAJE_ACUMULADO"/>

		</call-query>
	</resource>
	<query id="updateActividadesnovedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ACTIVIDADES_NOVEDAD SET COMPANIA=:COMPANIA, CODIGO_ACTIVIDAD=:CODIGO_ACTIVIDAD, CODIGO_ACTA=:CODIGO_ACTA, CODIGO_NOVEDAD=:CODIGO_NOVEDAD, TIPO_NOVEDAD=:TIPO_NOVEDAD, COD_CONTRATO=:COD_CONTRATO, TIPO_CONTRATO=:TIPO_CONTRATO, PORCENTAJE_CUMPLIMIENTO=:PORCENTAJE_CUMPLIMIENTO, PORCENTAJE_ACUMULADO=:PORCENTAJE_ACUMULADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ACTIVIDADES_NOVEDAD.COMPANIA= :KEY_COMPANIA AND ACTIVIDADES_NOVEDAD.CODIGO_ACTIVIDAD= :KEY_CODIGO_ACTIVIDAD AND ACTIVIDADES_NOVEDAD.CODIGO_ACTA= :KEY_CODIGO_ACTA AND ACTIVIDADES_NOVEDAD.CODIGO_NOVEDAD= :KEY_CODIGO_NOVEDAD AND ACTIVIDADES_NOVEDAD.TIPO_NOVEDAD= :KEY_TIPO_NOVEDAD AND ACTIVIDADES_NOVEDAD.COD_CONTRATO= :KEY_COD_CONTRATO AND ACTIVIDADES_NOVEDAD.TIPO_CONTRATO= :KEY_TIPO_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="CODIGO_ACTA" sqlType="STRING"/>
		<param name="CODIGO_NOVEDAD" sqlType="STRING"/>
		<param name="TIPO_NOVEDAD" sqlType="STRING"/>
		<param name="COD_CONTRATO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="PORCENTAJE_CUMPLIMIENTO" sqlType="STRING"/>
		<param name="PORCENTAJE_ACUMULADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="KEY_CODIGO_ACTA" sqlType="STRING"/>
		<param name="KEY_CODIGO_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_TIPO_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_COD_CONTRATO" sqlType="STRING"/>
		<param name="KEY_TIPO_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="actividadesnovedad">
		<call-query href="updateActividadesnovedad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="CODIGO_ACTA" query-param="CODIGO_ACTA"/>
			<with-param name="CODIGO_NOVEDAD" query-param="CODIGO_NOVEDAD"/>
			<with-param name="TIPO_NOVEDAD" query-param="TIPO_NOVEDAD"/>
			<with-param name="COD_CONTRATO" query-param="COD_CONTRATO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="PORCENTAJE_CUMPLIMIENTO" query-param="PORCENTAJE_CUMPLIMIENTO"/>
			<with-param name="PORCENTAJE_ACUMULADO" query-param="PORCENTAJE_ACUMULADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_ACTIVIDAD" query-param="KEY_CODIGO_ACTIVIDAD"/>
			<with-param name="KEY_CODIGO_ACTA" query-param="KEY_CODIGO_ACTA"/>
			<with-param name="KEY_CODIGO_NOVEDAD" query-param="KEY_CODIGO_NOVEDAD"/>
			<with-param name="KEY_TIPO_NOVEDAD" query-param="KEY_TIPO_NOVEDAD"/>
			<with-param name="KEY_COD_CONTRATO" query-param="KEY_COD_CONTRATO"/>
			<with-param name="KEY_TIPO_CONTRATO" query-param="KEY_TIPO_CONTRATO"/>

		</call-query>
	</resource>

</data>