<data name="tipoinformesentes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoinformesentesTodospornombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,NOMBRE FROM TIPO_INFORMES_ENTES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="tipoinformesentes/todospornombre">
		<call-query href="getTipoinformesentesTodospornombreQuery">
 
		</call-query>
	</resource>
	<query id="updateTipoinformesentesActpermiteconsolidar" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPO_INFORMES_ENTES SET PERMITE_CONSOLIDAR=:PERMITE_CONSOLIDAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPO_INFORMES_ENTES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PERMITE_CONSOLIDAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipoinformesentes/actpermiteconsolidar">
		<call-query href="updateTipoinformesentesActpermiteconsolidar">
			<with-param name="PERMITE_CONSOLIDAR" query-param="PERMITE_CONSOLIDAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getTipoinformesentesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE, OBSERVACION,(CASE PERMITE_CONSOLIDAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_CONSOLIDAR FROM TIPO_INFORMES_ENTES ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACION), '%')) AND (CASE WHEN PERMITE_CONSOLIDAR IS NULL THEN ' ' ELSE UPPER(PERMITE_CONSOLIDAR) END) LIKE UPPER(CONCAT(:PERMITE_CONSOLIDAR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","OBSERVACION":"$OBSERVACION","PERMITE_CONSOLIDAR":"$PERMITE_CONSOLIDAR(type:boolean)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="PERMITE_CONSOLIDAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoinformesentes">
		<call-query href="getTipoinformesentesPaginaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="PERMITE_CONSOLIDAR" query-param="PERMITE_CONSOLIDAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoinformesentesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE, OBSERVACION,(CASE PERMITE_CONSOLIDAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_CONSOLIDAR FROM TIPO_INFORMES_ENTES ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACION), '%')) AND (CASE WHEN PERMITE_CONSOLIDAR IS NULL THEN ' ' ELSE UPPER(PERMITE_CONSOLIDAR) END) LIKE UPPER(CONCAT(:PERMITE_CONSOLIDAR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="PERMITE_CONSOLIDAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoinformesentes/numero">
		<call-query href="getTipoinformesentesNumeroQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="PERMITE_CONSOLIDAR" query-param="PERMITE_CONSOLIDAR"/>

		</call-query>
	</resource>

</data>