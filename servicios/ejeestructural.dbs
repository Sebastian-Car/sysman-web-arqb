<data name="ejeestructural" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEjeestructuralPagBpejesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO_EJE,DESCRIPCION_EJE FROM EJE_ESTRUCTURAL WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN DESCRIPCION_EJE IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_EJE) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_EJE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_EJE":"$CODIGO_EJE(type:integer)","DESCRIPCION_EJE":"$DESCRIPCION_EJE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="DESCRIPCION_EJE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ejeestructural/bpejes/pag">
		<call-query href="getEjeestructuralPagBpejesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="DESCRIPCION_EJE" query-param="DESCRIPCION_EJE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEjeestructuralNumBpejesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO_EJE,DESCRIPCION_EJE FROM EJE_ESTRUCTURAL WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN DESCRIPCION_EJE IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_EJE) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_EJE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="DESCRIPCION_EJE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ejeestructural/bpejes/num">
		<call-query href="getEjeestructuralNumBpejesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="DESCRIPCION_EJE" query-param="DESCRIPCION_EJE"/>

		</call-query>
	</resource>
	<query id="insertEjeestructural" keyColumns="COMPANIA,CODIGO_EJE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EJE_ESTRUCTURAL (COMPANIA, CODIGO_EJE, DESCRIPCION_EJE, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO_EJE, :DESCRIPCION_EJE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_EJE":"$CODIGO_EJE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_EJE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ejeestructural">
		<call-query href="insertEjeestructural">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="DESCRIPCION_EJE" query-param="DESCRIPCION_EJE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteEjeestructural" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EJE_ESTRUCTURAL WHERE EJE_ESTRUCTURAL.COMPANIA= :KEY_COMPANIA AND EJE_ESTRUCTURAL.CODIGO_EJE= :KEY_CODIGO_EJE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_EJE" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="ejeestructural">
		<call-query href="deleteEjeestructural">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>

		</call-query>
	</resource>
	<query id="getEjeestructuralPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO_EJE, DESCRIPCION_EJE FROM EJE_ESTRUCTURAL WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN DESCRIPCION_EJE IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_EJE) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_EJE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_EJE":"$CODIGO_EJE(type:integer)","DESCRIPCION_EJE":"$DESCRIPCION_EJE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="DESCRIPCION_EJE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ejeestructural">
		<call-query href="getEjeestructuralPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="DESCRIPCION_EJE" query-param="DESCRIPCION_EJE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEjeestructuralNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO_EJE, DESCRIPCION_EJE FROM EJE_ESTRUCTURAL WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO_EJE IS NULL THEN ' ' ELSE UPPER(CODIGO_EJE) END) LIKE UPPER(CONCAT(:CODIGO_EJE, '%')) AND (CASE WHEN DESCRIPCION_EJE IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_EJE) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_EJE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="DESCRIPCION_EJE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ejeestructural/numero">
		<call-query href="getEjeestructuralNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="DESCRIPCION_EJE" query-param="DESCRIPCION_EJE"/>

		</call-query>
	</resource>
	<query id="getEjeestructuralRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO_EJE, DESCRIPCION_EJE, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM EJE_ESTRUCTURAL WHERE EJE_ESTRUCTURAL.COMPANIA= :KEY_COMPANIA AND EJE_ESTRUCTURAL.CODIGO_EJE= :KEY_CODIGO_EJE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_EJE":"$CODIGO_EJE(type:integer)","DESCRIPCION_EJE":"$DESCRIPCION_EJE","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_EJE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ejeestructural/data">
		<call-query href="getEjeestructuralRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>

		</call-query>
	</resource>
	<query id="updateEjeestructural" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EJE_ESTRUCTURAL SET COMPANIA=:COMPANIA, CODIGO_EJE=:CODIGO_EJE, DESCRIPCION_EJE=:DESCRIPCION_EJE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE EJE_ESTRUCTURAL.COMPANIA= :KEY_COMPANIA AND EJE_ESTRUCTURAL.CODIGO_EJE= :KEY_CODIGO_EJE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_EJE" sqlType="STRING"/>
		<param name="DESCRIPCION_EJE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_EJE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ejeestructural">
		<call-query href="updateEjeestructural">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_EJE" query-param="CODIGO_EJE"/>
			<with-param name="DESCRIPCION_EJE" query-param="DESCRIPCION_EJE"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_EJE" query-param="KEY_CODIGO_EJE"/>

		</call-query>
	</resource>

</data>