	<query id="getSpmedidorConsultarCantidadDeMedidoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(CODIGO) CODIGO  FROM SP_MEDIDOR WHERE COMPANIA= :COMPANIA AND CODIGO= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)"}]}}		</result>
