	<query id="getSpmedidorExisteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) TOTAL  FROM SP_MEDIDOR WHERE CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/existe">
		<call-query href="getSpmedidorExisteQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpmedidorMedidorPorCodigorutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO.CODIGORUTA, SP_MEDIDOR.CODIGO COD  FROM SP_MEDIDOR INNER JOIN SP_USUARIO ON (SP_MEDIDOR.COMPANIA = SP_USUARIO.COMPANIA AND SP_MEDIDOR.CODIGORUTA = SP_USUARIO.CODIGORUTA AND SP_MEDIDOR.CICLO = SP_USUARIO.CICLO) WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CICLO = :CICLO AND SP_USUARIO.CODIGORUTA = :CODIGORUTA AND SP_MEDIDOR.CODIGO &lt;&gt; :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","COD":"$COD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/medidorporcodigoruta">
		<call-query href="getSpmedidorMedidorPorCodigorutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpmedidorMaximoConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(MAX(CONSECUTIVO),0)+1 CONSECUTIVO  FROM SP_MEDIDOR WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/maximoconsecutivo">
		<call-query href="getSpmedidorMaximoConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpmedidorExistePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO  FROM SP_MEDIDOR WHERE COMPANIA= :COMPANIA AND CODIGO= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
