	<query id="getSpmedidorNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_MEDIDOR.COMPANIA, SP_MEDIDOR.ANO, SP_MEDIDOR.CICLO, SP_MEDIDOR.CLASE, SP_MEDIDOR.CLASIFICACION, SP_MEDIDOR.CODIGO, SP_MEDIDOR.CODIGORUTA, SP_MEDIDOR.CONSECUTIVO, SP_MEDIDOR.CREATED_BY,(TO_CHAR(SP_MEDIDOR.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(SP_MEDIDOR.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SP_MEDIDOR.DIAMETRO, SP_MEDIDOR.DIGITOS, SP_MEDIDOR.ELEMCAMBIO, CASE SP_MEDIDOR.ESTADO WHEN 'B' THEN 'Medidor en buen estado' WHEN 'M' THEN 'Medidor dañado' ELSE ' ' END ESTADOLABEL, SP_MEDIDOR.ESTADO,(TO_CHAR(SP_MEDIDOR.FECHACOMPRA,'DD/MM/YYYY HH24:MI:SS')) FECHACOMPRA,(TO_CHAR(SP_MEDIDOR.FECHAINST,'DD/MM/YYYY HH24:MI:SS')) FECHAINST,(TO_CHAR(SP_MEDIDOR.FECHA_REG,'DD/MM/YYYY HH24:MI:SS')) FECHA_REG, SP_MEDIDOR.GEO_ALTITUD, SP_MEDIDOR.GEO_LATITUD, SP_MEDIDOR.GEO_LONGITUD, SP_MEDIDOR.GEO_VERTICE, SP_MEDIDOR.LECTACTUAL, NVL(SP_MEDIDOR.LECTMEDANT,0) LECTMEDANT, SP_MEDIDOR.LECTURAFINALVIEJO, SP_MEDIDOR.LECTURAINICIAL, SP_MEDIDOR.LECTURAPROMEDIO, SP_MEDIDOR.LOCALIZACION, SP_MEDIDOR.LONGITUD, SP_MEDIDOR.MARCA, SP_MEDIDOR.MEDIDORNUEVO, SP_MEDIDOR.MODIFIED_BY, SP_MEDIDOR.NOORDENINST, SP_MEDIDOR.NUMCERTIFICACION, SP_MEDIDOR.NUMFACTURA, SP_MEDIDOR.PERIODO, SP_MEDIDOR.POSICION, SP_MEDIDOR.PROMEDIO, SP_MEDIDOR.RADIO, CASE SP_MEDIDOR.TIPO WHEN 'V' THEN 'Volumétrico' WHEN 'T' THEN 'Turbina' ELSE ' ' END TIPOLABEL, SP_MEDIDOR.TIPO, SP_USUARIO.CODIGOINTERNO  FROM SP_MEDIDOR LEFT JOIN SP_USUARIO ON SP_MEDIDOR.COMPANIA = SP_USUARIO.COMPANIA AND SP_MEDIDOR.CICLO = SP_USUARIO.CICLO AND SP_MEDIDOR.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_MEDIDOR.COMPANIA = :COMPANIA AND SP_MEDIDOR.CICLO = TO_NUMBER(:CICLO) AND NVL(SP_MEDIDOR.CODIGORUTA,'-1') = :CODIGOINICIAL ORDER BY SP_MEDIDOR.CONSECUTIVO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN DIAMETRO IS NULL THEN ' ' ELSE UPPER(DIAMETRO) END)  LIKE UPPER( '%' || :DIAMETRO || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%')  AND (CASE WHEN ELEMCAMBIO IS NULL THEN ' ' ELSE UPPER(ELEMCAMBIO) END)  LIKE UPPER( '%' || :ELEMCAMBIO || '%')  AND (CASE WHEN ESTADOLABEL IS NULL THEN ' ' ELSE UPPER(ESTADOLABEL) END)  LIKE UPPER(:ESTADOLABEL || '%')  AND (CASE WHEN FECHACOMPRA IS NULL THEN ' ' ELSE UPPER(FECHACOMPRA) END)  LIKE UPPER( '%' || :FECHACOMPRA || '%')  AND (CASE WHEN FECHAINST IS NULL THEN ' ' ELSE UPPER(FECHAINST) END)  LIKE UPPER( '%' || :FECHAINST || '%')  AND (CASE WHEN FECHA_REG IS NULL THEN ' ' ELSE UPPER(FECHA_REG) END)  LIKE UPPER( '%' || :FECHA_REG || '%')  AND (CASE WHEN GEO_ALTITUD IS NULL THEN ' ' ELSE UPPER(GEO_ALTITUD) END)  LIKE UPPER( '%' || :GEO_ALTITUD || '%')  AND (CASE WHEN GEO_LATITUD IS NULL THEN ' ' ELSE UPPER(GEO_LATITUD) END)  LIKE UPPER( '%' || :GEO_LATITUD || '%')  AND (CASE WHEN GEO_LONGITUD IS NULL THEN ' ' ELSE UPPER(GEO_LONGITUD) END)  LIKE UPPER(:GEO_LONGITUD || '%')  AND (CASE WHEN GEO_VERTICE IS NULL THEN ' ' ELSE UPPER(GEO_VERTICE) END)  LIKE UPPER(:GEO_VERTICE || '%')  AND (CASE WHEN LECTACTUAL IS NULL THEN ' ' ELSE UPPER(LECTACTUAL) END)  LIKE UPPER( '%' || :LECTACTUAL || '%')  AND (CASE WHEN LECTURAFINALVIEJO IS NULL THEN ' ' ELSE UPPER(LECTURAFINALVIEJO) END)  LIKE UPPER( '%' || :LECTURAFINALVIEJO || '%')  AND (CASE WHEN LECTURAINICIAL IS NULL THEN ' ' ELSE UPPER(LECTURAINICIAL) END)  LIKE UPPER( '%' || :LECTURAINICIAL || '%')  AND (CASE WHEN LECTURAPROMEDIO IS NULL THEN ' ' ELSE UPPER(LECTURAPROMEDIO) END)  LIKE UPPER( '%' || :LECTURAPROMEDIO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER(:MARCA || '%')  AND (CASE WHEN MEDIDORNUEVO IS NULL THEN ' ' ELSE UPPER(MEDIDORNUEVO) END)  LIKE UPPER(:MEDIDORNUEVO || '%')  AND (CASE WHEN NUMFACTURA IS NULL THEN ' ' ELSE UPPER(NUMFACTURA) END)  LIKE UPPER(:NUMFACTURA || '%')  AND (CASE WHEN PROMEDIO IS NULL THEN ' ' ELSE UPPER(PROMEDIO) END)  LIKE UPPER(:PROMEDIO || '%')  AND (CASE WHEN TIPOLABEL IS NULL THEN ' ' ELSE UPPER(TIPOLABEL) END)  LIKE UPPER(:TIPOLABEL || '%')  AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END)  LIKE UPPER( '%' || :CODIGOINTERNO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
