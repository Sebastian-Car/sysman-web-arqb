	<query id="updateSpmedidorActualizarMedidors" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_MEDIDOR SET CODIGO=:CODIGO, MARCA=:MARCA, FECHACOMPRA=TO_DATE(:FECHACOMPRA,'DD/MM/YYYY HH24:MI:SS'), DIGITOS=:DIGITOS, LECTURAINICIAL=:LECTURAINICIAL, ANO=:ANO, PERIODO=:PERIODO, ESTADO=:ESTADO, CICLO=:CICLO, CODIGORUTA=:CODIGORUTA, LECTMEDANT=:LECTMEDANT, LECTACTUAL=:LECTACTUAL, NUMFACTURA=:NUMFACTURA, ELEMCAMBIO=:ELEMCAMBIO, FECHAINST=TO_DATE(:FECHAINST,'DD/MM/YYYY HH24:MI:SS'), NOORDENINST=:NOORDENINST, TIPO=:TIPO, FECHA_REG=TO_DATE(:FECHA_REG,'DD/MM/YYYY HH24:MI:SS'), GEO_VERTICE=:GEO_VERTICE, GEO_LONGITUD=:GEO_LONGITUD, GEO_LATITUD=:GEO_LATITUD, GEO_ALTITUD=:GEO_ALTITUD, LECTURAFINALVIEJO=:LECTURAFINALVIEJO, DIAMETRO=:DIAMETRO, LECTURAPROMEDIO=:LECTURAPROMEDIO, PROMEDIO=:PROMEDIO, LONGITUD=:LONGITUD, MEDIDORNUEVO=:MEDIDORNUEVO, CLASIFICACION=:CLASIFICACION, NUMCERTIFICACION=:NUMCERTIFICACION, POSICION=:POSICION, RADIO=:RADIO, CLASE=:CLASE, LOCALIZACION=:LOCALIZACION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_MEDIDOR.COMPANIA= :KEY_COMPANIA AND SP_MEDIDOR.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="FECHACOMPRA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="LECTURAINICIAL" sqlType="STRING"/>
