		</call-query>
	</resource>
	<query id="updateSpmedidorSinMedidor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_MEDIDOR SET ESTADO =:ESTADO, CICLO = :CICLO, CODIGORUTA = :CODIGORUTA,MARCA = :MARCA, DATE_MODIFIED= SYSDATE, MODIFIED_BY=:MODIFIED_BY WHERE CODIGO=:CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spmedidor/sinmedidor">
		<call-query href="updateSpmedidorSinMedidor">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertSpmedidorSinMedidor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_MEDIDOR ( COMPANIA, CLASE, LOCALIZACION, CODIGO, MARCA, ESTADO, CICLO, CODIGORUTA, CONSECUTIVO, DIGITOS, DATE_CREATED,CREATED_BY)   VALUES (:COMPANIA,:CLASE, :LOCALIZACION,:CODIGO, :MARCA, :ESTADO, :CICLO, :CODIGORUTA, :CONSECUTIVO, :DIGITOS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'),:CREATED_BY)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="LOCALIZACION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="MARCA" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="CICLO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spmedidor/sinmedidor">
		<call-query href="insertSpmedidorSinMedidor">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="LOCALIZACION" query-param="LOCALIZACION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getSpmedidorPagCodigoMarcaEstadoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, MARCA, DIGITOS, ESTADO ESTADO_MEDIDOR  FROM SP_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN ESTADO_MEDIDOR IS NULL THEN ' ' ELSE UPPER(ESTADO_MEDIDOR) END)  LIKE UPPER( '%' || :ESTADO_MEDIDOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","MARCA":"$MARCA","DIGITOS":"$DIGITOS(type:integer)","ESTADO_MEDIDOR":"$ESTADO_MEDIDOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="ESTADO_MEDIDOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spmedidor/codigomarcaestadoporcompania/pag">
		<call-query href="getSpmedidorPagCodigoMarcaEstadoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="ESTADO_MEDIDOR" query-param="ESTADO_MEDIDOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpmedidorNumCodigoMarcaEstadoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, MARCA, DIGITOS, ESTADO ESTADO_MEDIDOR  FROM SP_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN ESTADO_MEDIDOR IS NULL THEN ' ' ELSE UPPER(ESTADO_MEDIDOR) END)  LIKE UPPER( '%' || :ESTADO_MEDIDOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="ESTADO_MEDIDOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/codigomarcaestadoporcompania/num">
		<call-query href="getSpmedidorNumCodigoMarcaEstadoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="ESTADO_MEDIDOR" query-param="ESTADO_MEDIDOR"/>

		</call-query>
	</resource>
	<query id="getSpmedidorPagPorcodigorutanullQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, MARCA, CONSECUTIVO  FROM SP_MEDIDOR MEDIDOR WHERE MEDIDOR.COMPANIA = :COMPANIA AND MEDIDOR.CODIGORUTA IS NULL AND MEDIDOR.CLASIFICACION = 'P') WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","MARCA":"$MARCA","CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spmedidor/porcodigorutanull/pag">
		<call-query href="getSpmedidorPagPorcodigorutanullQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpmedidorNumPorcodigorutanullQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, MARCA, CONSECUTIVO  FROM SP_MEDIDOR MEDIDOR WHERE MEDIDOR.COMPANIA = :COMPANIA AND MEDIDOR.CODIGORUTA IS NULL AND MEDIDOR.CLASIFICACION = 'P') WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/porcodigorutanull/num">
		<call-query href="getSpmedidorNumPorcodigorutanullQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>

		</call-query>
	</resource>
	<query id="updateSpmedidorEstadoDaniado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_MEDIDOR SET ESTADO      = :ESTADO, DATE_MODIFIED= SYSDATE,  MODIFIED_BY=:MODIFIED_BY  WHERE COMPANIA  = :COMPANIA AND CONSECUTIVO = :CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spmedidor/estadodaniado">
		<call-query href="updateSpmedidorEstadoDaniado">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>

</data>