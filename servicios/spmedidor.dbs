	<query id="updateSpmedidor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_MEDIDOR SET COMPANIA=:COMPANIA, ANO=:ANO, CICLO=:CICLO, CLASE=:CLASE, CLASIFICACION=:CLASIFICACION, CODIGO=:CODIGO, CODIGORUTA=:CODIGORUTA, CONSECUTIVO=:CONSECUTIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), DIAMETRO=:DIAMETRO, DIGITOS=:DIGITOS, ELEMCAMBIO=:ELEMCAMBIO, ESTADO=:ESTADO, FECHACOMPRA=TO_DATE(:FECHACOMPRA,'DD/MM/YYYY HH24:MI:SS'), FECHAINST=TO_DATE(:FECHAINST,'DD/MM/YYYY HH24:MI:SS'), FECHA_REG=TO_DATE(:FECHA_REG,'DD/MM/YYYY HH24:MI:SS'), GEO_ALTITUD=:GEO_ALTITUD, GEO_LATITUD=:GEO_LATITUD, GEO_LONGITUD=:GEO_LONGITUD, GEO_VERTICE=:GEO_VERTICE, LECTACTUAL=:LECTACTUAL, LECTMEDANT=:LECTMEDANT, LECTURAFINALVIEJO=:LECTURAFINALVIEJO, LECTURAINICIAL=:LECTURAINICIAL, LECTURAPROMEDIO=:LECTURAPROMEDIO, LOCALIZACION=:LOCALIZACION, LONGITUD=:LONGITUD, MARCA=:MARCA, MEDIDORNUEVO=:MEDIDORNUEVO, MODIFIED_BY=:MODIFIED_BY, NOORDENINST=:NOORDENINST, NUMCERTIFICACION=:NUMCERTIFICACION, NUMFACTURA=:NUMFACTURA, PERIODO=:PERIODO, POSICION=:POSICION, PROMEDIO=:PROMEDIO, RADIO=:RADIO, TIPO=:TIPO WHERE SP_MEDIDOR.COMPANIA= :KEY_COMPANIA AND SP_MEDIDOR.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CLASIFICACION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
