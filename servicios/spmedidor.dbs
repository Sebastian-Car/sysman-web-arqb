<data name="spmedidor" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpmedidorPorCicloYCodigorutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CONSECUTIVO, CODIGO, MARCA, DIGITOS, TO_CHAR(FECHACOMPRA,'DD/MM/YYYY') FECHACOMPRA, ELEMCAMBIO, NUMFACTURA, LECTURAINICIAL, ANO, PERIODO, LECTMEDANT, LECTURAFINALVIEJO, TO_CHAR(FECHAINST,'DD/MM/YYYY') FECHAINST, NOORDENINST, CLASIFICACION, CASE CLASIFICACION WHEN 'P' THEN 'PRINCIPAL' ELSE 'TEMPORAL' END CLASIFICACIONLABEL  FROM SP_MEDIDOR WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","CODIGO":"$CODIGO","MARCA":"$MARCA","DIGITOS":"$DIGITOS(type:integer)","FECHACOMPRA":"$FECHACOMPRA","ELEMCAMBIO":"$ELEMCAMBIO","NUMFACTURA":"$NUMFACTURA","LECTURAINICIAL":"$LECTURAINICIAL","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","LECTMEDANT":"$LECTMEDANT","LECTURAFINALVIEJO":"$LECTURAFINALVIEJO","FECHAINST":"$FECHAINST","NOORDENINST":"$NOORDENINST","CLASIFICACION":"$CLASIFICACION","CLASIFICACIONLABEL":"$CLASIFICACIONLABEL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/porcicloycodigoruta">
		<call-query href="getSpmedidorPorCicloYCodigorutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpmedidorTodosPorGeiverticeInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT SP_MEDIDOR.GEO_VERTICE  FROM SP_MEDIDOR WHERE SP_MEDIDOR.COMPANIA = :COMPANIA ORDER BY SP_MEDIDOR.GEO_VERTICE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"GEO_VERTICE":"$GEO_VERTICE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/todosporgeiverticeinicial">
		<call-query href="getSpmedidorTodosPorGeiverticeInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpmedidorTodosPorGeoverticeFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT SP_MEDIDOR.GEO_VERTICE  FROM SP_MEDIDOR WHERE SP_MEDIDOR.COMPANIA = :COMPANIA AND SP_MEDIDOR.GEO_VERTICE &gt;= :VERTICEINICIAL ORDER BY SP_MEDIDOR.GEO_VERTICE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"GEO_VERTICE":"$GEO_VERTICE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERTICEINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/todosporgeoverticefinal">
		<call-query href="getSpmedidorTodosPorGeoverticeFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERTICEINICIAL" query-param="VERTICEINICIAL"/>

		</call-query>
	</resource>
	<query id="getSpmedidorPagListarMedidorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CONSECUTIVO, CODIGO, MARCA,(TO_CHAR(FECHACOMPRA,'DD/MM/YYYY HH24:MI:SS')) FECHACOMPRA, DIGITOS, LECTURAINICIAL, ANO, PERIODO, ESTADO, (CASE ESTADO WHEN 'B' THEN 'Medidor en buen estado' WHEN 'M' THEN 'Medidor dañado' END) NOMBREESTADO, CICLO, CODIGORUTA, LECTMEDANT, LECTACTUAL, NUMFACTURA, ELEMCAMBIO,(TO_CHAR(FECHAINST,'DD/MM/YYYY HH24:MI:SS')) FECHAINST, NOORDENINST, TIPO,(TO_CHAR(FECHA_REG,'DD/MM/YYYY HH24:MI:SS')) FECHA_REG, GEO_VERTICE, GEO_LONGITUD, GEO_LATITUD, GEO_ALTITUD, LECTURAFINALVIEJO, DIAMETRO, LECTURAPROMEDIO, PROMEDIO, LONGITUD, MEDIDORNUEVO, CLASIFICACION, NUMCERTIFICACION, POSICION, RADIO, CLASE, LOCALIZACION, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY COMPANIA, CONSECUTIVO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN FECHACOMPRA IS NULL THEN ' ' ELSE UPPER(FECHACOMPRA) END)  LIKE UPPER( '%' || :FECHACOMPRA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%')  AND (CASE WHEN LECTURAINICIAL IS NULL THEN ' ' ELSE UPPER(LECTURAINICIAL) END)  LIKE UPPER( '%' || :LECTURAINICIAL || '%')  AND (CASE WHEN NOMBREESTADO IS NULL THEN ' ' ELSE UPPER(NOMBREESTADO) END)  LIKE UPPER( '%' || :NOMBREESTADO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN LECTMEDANT IS NULL THEN ' ' ELSE UPPER(LECTMEDANT) END)  LIKE UPPER( '%' || :LECTMEDANT || '%')  AND (CASE WHEN LECTACTUAL IS NULL THEN ' ' ELSE UPPER(LECTACTUAL) END)  LIKE UPPER( '%' || :LECTACTUAL || '%')  AND (CASE WHEN NUMFACTURA IS NULL THEN ' ' ELSE UPPER(NUMFACTURA) END)  LIKE UPPER( '%' || :NUMFACTURA || '%')  AND (CASE WHEN ELEMCAMBIO IS NULL THEN ' ' ELSE UPPER(ELEMCAMBIO) END)  LIKE UPPER( '%' || :ELEMCAMBIO || '%')  AND (CASE WHEN FECHAINST IS NULL THEN ' ' ELSE UPPER(FECHAINST) END)  LIKE UPPER( '%' || :FECHAINST || '%')  AND (CASE WHEN NOORDENINST IS NULL THEN ' ' ELSE UPPER(NOORDENINST) END)  LIKE UPPER( '%' || :NOORDENINST || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN GEO_VERTICE IS NULL THEN ' ' ELSE UPPER(GEO_VERTICE) END)  LIKE UPPER( '%' || :GEO_VERTICE || '%')  AND (CASE WHEN GEO_LONGITUD IS NULL THEN ' ' ELSE UPPER(GEO_LONGITUD) END)  LIKE UPPER( '%' || :GEO_LONGITUD || '%')  AND (CASE WHEN GEO_LATITUD IS NULL THEN ' ' ELSE UPPER(GEO_LATITUD) END)  LIKE UPPER( '%' || :GEO_LATITUD || '%')  AND (CASE WHEN GEO_ALTITUD IS NULL THEN ' ' ELSE UPPER(GEO_ALTITUD) END)  LIKE UPPER( '%' || :GEO_ALTITUD || '%')  AND (CASE WHEN LECTURAFINALVIEJO IS NULL THEN ' ' ELSE UPPER(LECTURAFINALVIEJO) END)  LIKE UPPER( '%' || :LECTURAFINALVIEJO || '%')  AND (CASE WHEN DIAMETRO IS NULL THEN ' ' ELSE UPPER(DIAMETRO) END)  LIKE UPPER( '%' || :DIAMETRO || '%')  AND (CASE WHEN PROMEDIO IS NULL THEN ' ' ELSE UPPER(PROMEDIO) END)  LIKE UPPER( '%' || :PROMEDIO || '%')  AND (CASE WHEN LONGITUD IS NULL THEN ' ' ELSE UPPER(LONGITUD) END)  LIKE UPPER( '%' || :LONGITUD || '%')  AND (CASE WHEN MEDIDORNUEVO IS NULL THEN ' ' ELSE UPPER(MEDIDORNUEVO) END)  LIKE UPPER( '%' || :MEDIDORNUEVO || '%')  AND (CASE WHEN CLASIFICACION IS NULL THEN ' ' ELSE UPPER(CLASIFICACION) END)  LIKE UPPER( '%' || :CLASIFICACION || '%')  AND (CASE WHEN NUMCERTIFICACION IS NULL THEN ' ' ELSE UPPER(NUMCERTIFICACION) END)  LIKE UPPER( '%' || :NUMCERTIFICACION || '%')  AND (CASE WHEN RADIO IS NULL THEN ' ' ELSE UPPER(RADIO) END)  LIKE UPPER( '%' || :RADIO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN LOCALIZACION IS NULL THEN ' ' ELSE UPPER(LOCALIZACION) END)  LIKE UPPER( '%' || :LOCALIZACION || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER( '%' || :DATE_MODIFIED || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","CODIGO":"$CODIGO","MARCA":"$MARCA","FECHACOMPRA":"$FECHACOMPRA","DIGITOS":"$DIGITOS(type:integer)","LECTURAINICIAL":"$LECTURAINICIAL","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","LECTMEDANT":"$LECTMEDANT","LECTACTUAL":"$LECTACTUAL","NUMFACTURA":"$NUMFACTURA","ELEMCAMBIO":"$ELEMCAMBIO","FECHAINST":"$FECHAINST","NOORDENINST":"$NOORDENINST","TIPO":"$TIPO","FECHA_REG":"$FECHA_REG","GEO_VERTICE":"$GEO_VERTICE","GEO_LONGITUD":"$GEO_LONGITUD","GEO_LATITUD":"$GEO_LATITUD","GEO_ALTITUD":"$GEO_ALTITUD","LECTURAFINALVIEJO":"$LECTURAFINALVIEJO","DIAMETRO":"$DIAMETRO","LECTURAPROMEDIO":"$LECTURAPROMEDIO","PROMEDIO":"$PROMEDIO","LONGITUD":"$LONGITUD","MEDIDORNUEVO":"$MEDIDORNUEVO","CLASIFICACION":"$CLASIFICACION","NUMCERTIFICACION":"$NUMCERTIFICACION","POSICION":"$POSICION","RADIO":"$RADIO","CLASE":"$CLASE(type:integer)","LOCALIZACION":"$LOCALIZACION(type:integer)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="FECHACOMPRA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="LECTURAINICIAL" sqlType="STRING"/>
		<param name="NOMBREESTADO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="LECTMEDANT" sqlType="STRING"/>
		<param name="LECTACTUAL" sqlType="STRING"/>
		<param name="NUMFACTURA" sqlType="STRING"/>
		<param name="ELEMCAMBIO" sqlType="STRING"/>
		<param name="FECHAINST" sqlType="STRING"/>
		<param name="NOORDENINST" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="GEO_VERTICE" sqlType="STRING"/>
		<param name="GEO_LONGITUD" sqlType="STRING"/>
		<param name="GEO_LATITUD" sqlType="STRING"/>
		<param name="GEO_ALTITUD" sqlType="STRING"/>
		<param name="LECTURAFINALVIEJO" sqlType="STRING"/>
		<param name="DIAMETRO" sqlType="STRING"/>
		<param name="PROMEDIO" sqlType="STRING"/>
		<param name="LONGITUD" sqlType="STRING"/>
		<param name="MEDIDORNUEVO" sqlType="STRING"/>
		<param name="CLASIFICACION" sqlType="STRING"/>
		<param name="NUMCERTIFICACION" sqlType="STRING"/>
		<param name="RADIO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="LOCALIZACION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spmedidor/listarmedidor/pag">
		<call-query href="getSpmedidorPagListarMedidorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="FECHACOMPRA" query-param="FECHACOMPRA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="LECTURAINICIAL" query-param="LECTURAINICIAL"/>
			<with-param name="NOMBREESTADO" query-param="NOMBREESTADO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="LECTMEDANT" query-param="LECTMEDANT"/>
			<with-param name="LECTACTUAL" query-param="LECTACTUAL"/>
			<with-param name="NUMFACTURA" query-param="NUMFACTURA"/>
			<with-param name="ELEMCAMBIO" query-param="ELEMCAMBIO"/>
			<with-param name="FECHAINST" query-param="FECHAINST"/>
			<with-param name="NOORDENINST" query-param="NOORDENINST"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="GEO_VERTICE" query-param="GEO_VERTICE"/>
			<with-param name="GEO_LONGITUD" query-param="GEO_LONGITUD"/>
			<with-param name="GEO_LATITUD" query-param="GEO_LATITUD"/>
			<with-param name="GEO_ALTITUD" query-param="GEO_ALTITUD"/>
			<with-param name="LECTURAFINALVIEJO" query-param="LECTURAFINALVIEJO"/>
			<with-param name="DIAMETRO" query-param="DIAMETRO"/>
			<with-param name="PROMEDIO" query-param="PROMEDIO"/>
			<with-param name="LONGITUD" query-param="LONGITUD"/>
			<with-param name="MEDIDORNUEVO" query-param="MEDIDORNUEVO"/>
			<with-param name="CLASIFICACION" query-param="CLASIFICACION"/>
			<with-param name="NUMCERTIFICACION" query-param="NUMCERTIFICACION"/>
			<with-param name="RADIO" query-param="RADIO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="LOCALIZACION" query-param="LOCALIZACION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpmedidorNumListarMedidorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CONSECUTIVO, CODIGO, MARCA,(TO_CHAR(FECHACOMPRA,'DD/MM/YYYY HH24:MI:SS')) FECHACOMPRA, DIGITOS, LECTURAINICIAL, ANO, PERIODO, ESTADO, (CASE ESTADO WHEN 'B' THEN 'Medidor en buen estado' WHEN 'M' THEN 'Medidor dañado' END) NOMBREESTADO, CICLO, CODIGORUTA, LECTMEDANT, LECTACTUAL, NUMFACTURA, ELEMCAMBIO,(TO_CHAR(FECHAINST,'DD/MM/YYYY HH24:MI:SS')) FECHAINST, NOORDENINST, TIPO,(TO_CHAR(FECHA_REG,'DD/MM/YYYY HH24:MI:SS')) FECHA_REG, GEO_VERTICE, GEO_LONGITUD, GEO_LATITUD, GEO_ALTITUD, LECTURAFINALVIEJO, DIAMETRO, LECTURAPROMEDIO, PROMEDIO, LONGITUD, MEDIDORNUEVO, CLASIFICACION, NUMCERTIFICACION, POSICION, RADIO, CLASE, LOCALIZACION, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_MEDIDOR WHERE COMPANIA = :COMPANIA ORDER BY COMPANIA, CONSECUTIVO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN FECHACOMPRA IS NULL THEN ' ' ELSE UPPER(FECHACOMPRA) END)  LIKE UPPER( '%' || :FECHACOMPRA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%')  AND (CASE WHEN LECTURAINICIAL IS NULL THEN ' ' ELSE UPPER(LECTURAINICIAL) END)  LIKE UPPER( '%' || :LECTURAINICIAL || '%')  AND (CASE WHEN NOMBREESTADO IS NULL THEN ' ' ELSE UPPER(NOMBREESTADO) END)  LIKE UPPER( '%' || :NOMBREESTADO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN LECTMEDANT IS NULL THEN ' ' ELSE UPPER(LECTMEDANT) END)  LIKE UPPER( '%' || :LECTMEDANT || '%')  AND (CASE WHEN LECTACTUAL IS NULL THEN ' ' ELSE UPPER(LECTACTUAL) END)  LIKE UPPER( '%' || :LECTACTUAL || '%')  AND (CASE WHEN NUMFACTURA IS NULL THEN ' ' ELSE UPPER(NUMFACTURA) END)  LIKE UPPER( '%' || :NUMFACTURA || '%')  AND (CASE WHEN ELEMCAMBIO IS NULL THEN ' ' ELSE UPPER(ELEMCAMBIO) END)  LIKE UPPER( '%' || :ELEMCAMBIO || '%')  AND (CASE WHEN FECHAINST IS NULL THEN ' ' ELSE UPPER(FECHAINST) END)  LIKE UPPER( '%' || :FECHAINST || '%')  AND (CASE WHEN NOORDENINST IS NULL THEN ' ' ELSE UPPER(NOORDENINST) END)  LIKE UPPER( '%' || :NOORDENINST || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN GEO_VERTICE IS NULL THEN ' ' ELSE UPPER(GEO_VERTICE) END)  LIKE UPPER( '%' || :GEO_VERTICE || '%')  AND (CASE WHEN GEO_LONGITUD IS NULL THEN ' ' ELSE UPPER(GEO_LONGITUD) END)  LIKE UPPER( '%' || :GEO_LONGITUD || '%')  AND (CASE WHEN GEO_LATITUD IS NULL THEN ' ' ELSE UPPER(GEO_LATITUD) END)  LIKE UPPER( '%' || :GEO_LATITUD || '%')  AND (CASE WHEN GEO_ALTITUD IS NULL THEN ' ' ELSE UPPER(GEO_ALTITUD) END)  LIKE UPPER( '%' || :GEO_ALTITUD || '%')  AND (CASE WHEN LECTURAFINALVIEJO IS NULL THEN ' ' ELSE UPPER(LECTURAFINALVIEJO) END)  LIKE UPPER( '%' || :LECTURAFINALVIEJO || '%')  AND (CASE WHEN DIAMETRO IS NULL THEN ' ' ELSE UPPER(DIAMETRO) END)  LIKE UPPER( '%' || :DIAMETRO || '%')  AND (CASE WHEN PROMEDIO IS NULL THEN ' ' ELSE UPPER(PROMEDIO) END)  LIKE UPPER( '%' || :PROMEDIO || '%')  AND (CASE WHEN LONGITUD IS NULL THEN ' ' ELSE UPPER(LONGITUD) END)  LIKE UPPER( '%' || :LONGITUD || '%')  AND (CASE WHEN MEDIDORNUEVO IS NULL THEN ' ' ELSE UPPER(MEDIDORNUEVO) END)  LIKE UPPER( '%' || :MEDIDORNUEVO || '%')  AND (CASE WHEN CLASIFICACION IS NULL THEN ' ' ELSE UPPER(CLASIFICACION) END)  LIKE UPPER( '%' || :CLASIFICACION || '%')  AND (CASE WHEN NUMCERTIFICACION IS NULL THEN ' ' ELSE UPPER(NUMCERTIFICACION) END)  LIKE UPPER( '%' || :NUMCERTIFICACION || '%')  AND (CASE WHEN RADIO IS NULL THEN ' ' ELSE UPPER(RADIO) END)  LIKE UPPER( '%' || :RADIO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN LOCALIZACION IS NULL THEN ' ' ELSE UPPER(LOCALIZACION) END)  LIKE UPPER( '%' || :LOCALIZACION || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER( '%' || :DATE_MODIFIED || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="FECHACOMPRA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="LECTURAINICIAL" sqlType="STRING"/>
		<param name="NOMBREESTADO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="LECTMEDANT" sqlType="STRING"/>
		<param name="LECTACTUAL" sqlType="STRING"/>
		<param name="NUMFACTURA" sqlType="STRING"/>
		<param name="ELEMCAMBIO" sqlType="STRING"/>
		<param name="FECHAINST" sqlType="STRING"/>
		<param name="NOORDENINST" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="GEO_VERTICE" sqlType="STRING"/>
		<param name="GEO_LONGITUD" sqlType="STRING"/>
		<param name="GEO_LATITUD" sqlType="STRING"/>
		<param name="GEO_ALTITUD" sqlType="STRING"/>
		<param name="LECTURAFINALVIEJO" sqlType="STRING"/>
		<param name="DIAMETRO" sqlType="STRING"/>
		<param name="PROMEDIO" sqlType="STRING"/>
		<param name="LONGITUD" sqlType="STRING"/>
		<param name="MEDIDORNUEVO" sqlType="STRING"/>
		<param name="CLASIFICACION" sqlType="STRING"/>
		<param name="NUMCERTIFICACION" sqlType="STRING"/>
		<param name="RADIO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="LOCALIZACION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spmedidor/listarmedidor/num">
		<call-query href="getSpmedidorNumListarMedidorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
