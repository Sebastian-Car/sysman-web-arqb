	<query id="insertSpmedidorInsertarMedidors" keyColumns="COMPANIA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_MEDIDOR (COMPANIA, CONSECUTIVO, CODIGO, MARCA, FECHACOMPRA, DIGITOS, LECTURAINICIAL, ANO, PERIODO, ESTADO, CICLO, CODIGORUTA, LECTMEDANT, LECTACTUAL, NUMFACTURA, ELEMCAMBIO, FECHAINST, NOORDENINST, TIPO, FECHA_REG, GEO_VERTICE, GEO_LONGITUD, GEO_LATITUD, GEO_ALTITUD, LECTURAFINALVIEJO, DIAMETRO, LECTURAPROMEDIO, PROMEDIO, LONGITUD, MEDIDORNUEVO, CLASIFICACION, NUMCERTIFICACION, POSICION, RADIO, CLASE, LOCALIZACION, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CONSECUTIVO, :CODIGO, :MARCA, TO_DATE(:FECHACOMPRA,'DD/MM/YYYY HH24:MI:SS'), :DIGITOS, :LECTURAINICIAL, :ANO, :PERIODO, :ESTADO, :CICLO, :CODIGORUTA, :LECTMEDANT, :LECTACTUAL, :NUMFACTURA, :ELEMCAMBIO, TO_DATE(:FECHAINST,'DD/MM/YYYY HH24:MI:SS'), :NOORDENINST, :TIPO, TO_DATE(:FECHA_REG,'DD/MM/YYYY HH24:MI:SS'), :GEO_VERTICE, :GEO_LONGITUD, :GEO_LATITUD, :GEO_ALTITUD, :LECTURAFINALVIEJO, :DIAMETRO, :LECTURAPROMEDIO, :PROMEDIO, :LONGITUD, :MEDIDORNUEVO, :CLASIFICACION, :NUMCERTIFICACION, :POSICION, :RADIO, :CLASE, :LOCALIZACION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
