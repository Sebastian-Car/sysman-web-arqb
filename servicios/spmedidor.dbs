			<with-param name="LONGITUD" query-param="LONGITUD"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="MEDIDORNUEVO" query-param="MEDIDORNUEVO"/>
			<with-param name="NOORDENINST" query-param="NOORDENINST"/>
			<with-param name="NUMCERTIFICACION" query-param="NUMCERTIFICACION"/>
			<with-param name="NUMFACTURA" query-param="NUMFACTURA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="POSICION" query-param="POSICION"/>
			<with-param name="PROMEDIO" query-param="PROMEDIO"/>
			<with-param name="RADIO" query-param="RADIO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="deleteSpmedidor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_MEDIDOR WHERE SP_MEDIDOR.COMPANIA= :KEY_COMPANIA AND SP_MEDIDOR.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spmedidor">
		<call-query href="deleteSpmedidor">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSpmedidorPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_MEDIDOR.COMPANIA, SP_MEDIDOR.ANO, SP_MEDIDOR.CICLO, SP_MEDIDOR.CLASE, SP_MEDIDOR.CLASIFICACION, SP_MEDIDOR.CODIGO, SP_MEDIDOR.CODIGORUTA, SP_MEDIDOR.CONSECUTIVO, SP_MEDIDOR.CREATED_BY,(TO_CHAR(SP_MEDIDOR.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(SP_MEDIDOR.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SP_MEDIDOR.DIAMETRO, SP_MEDIDOR.DIGITOS, SP_MEDIDOR.ELEMCAMBIO, CASE SP_MEDIDOR.ESTADO WHEN 'B' THEN 'Medidor en buen estado' WHEN 'M' THEN 'Medidor dañado' ELSE ' ' END ESTADOLABEL, SP_MEDIDOR.ESTADO,(TO_CHAR(SP_MEDIDOR.FECHACOMPRA,'DD/MM/YYYY HH24:MI:SS')) FECHACOMPRA,(TO_CHAR(SP_MEDIDOR.FECHAINST,'DD/MM/YYYY HH24:MI:SS')) FECHAINST,(TO_CHAR(SP_MEDIDOR.FECHA_REG,'DD/MM/YYYY HH24:MI:SS')) FECHA_REG, SP_MEDIDOR.GEO_ALTITUD, SP_MEDIDOR.GEO_LATITUD, SP_MEDIDOR.GEO_LONGITUD, SP_MEDIDOR.GEO_VERTICE, SP_MEDIDOR.LECTACTUAL, NVL(SP_MEDIDOR.LECTMEDANT,0) LECTMEDANT, SP_MEDIDOR.LECTURAFINALVIEJO, SP_MEDIDOR.LECTURAINICIAL, SP_MEDIDOR.LECTURAPROMEDIO, SP_MEDIDOR.LOCALIZACION, SP_MEDIDOR.LONGITUD, SP_MEDIDOR.MARCA, SP_MEDIDOR.MEDIDORNUEVO, SP_MEDIDOR.MODIFIED_BY, SP_MEDIDOR.NOORDENINST, SP_MEDIDOR.NUMCERTIFICACION, SP_MEDIDOR.NUMFACTURA, SP_MEDIDOR.PERIODO, SP_MEDIDOR.POSICION, SP_MEDIDOR.PROMEDIO, SP_MEDIDOR.RADIO, CASE SP_MEDIDOR.TIPO WHEN 'V' THEN 'Volumétrico' WHEN 'T' THEN 'Turbina' ELSE ' ' END TIPOLABEL, SP_MEDIDOR.TIPO, SP_USUARIO.CODIGOINTERNO  FROM SP_MEDIDOR LEFT JOIN SP_USUARIO ON SP_MEDIDOR.COMPANIA = SP_USUARIO.COMPANIA AND SP_MEDIDOR.CICLO = SP_USUARIO.CICLO AND SP_MEDIDOR.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_MEDIDOR.COMPANIA = :COMPANIA AND SP_MEDIDOR.CICLO = TO_NUMBER(:CICLO) AND NVL(SP_MEDIDOR.CODIGORUTA,'-1') = :CODIGOINICIAL ORDER BY SP_MEDIDOR.CONSECUTIVO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN DIAMETRO IS NULL THEN ' ' ELSE UPPER(DIAMETRO) END)  LIKE UPPER( '%' || :DIAMETRO || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%')  AND (CASE WHEN ELEMCAMBIO IS NULL THEN ' ' ELSE UPPER(ELEMCAMBIO) END)  LIKE UPPER( '%' || :ELEMCAMBIO || '%')  AND (CASE WHEN ESTADOLABEL IS NULL THEN ' ' ELSE UPPER(ESTADOLABEL) END)  LIKE UPPER(:ESTADOLABEL || '%')  AND (CASE WHEN FECHACOMPRA IS NULL THEN ' ' ELSE UPPER(FECHACOMPRA) END)  LIKE UPPER( '%' || :FECHACOMPRA || '%')  AND (CASE WHEN FECHAINST IS NULL THEN ' ' ELSE UPPER(FECHAINST) END)  LIKE UPPER( '%' || :FECHAINST || '%')  AND (CASE WHEN FECHA_REG IS NULL THEN ' ' ELSE UPPER(FECHA_REG) END)  LIKE UPPER( '%' || :FECHA_REG || '%')  AND (CASE WHEN GEO_ALTITUD IS NULL THEN ' ' ELSE UPPER(GEO_ALTITUD) END)  LIKE UPPER( '%' || :GEO_ALTITUD || '%')  AND (CASE WHEN GEO_LATITUD IS NULL THEN ' ' ELSE UPPER(GEO_LATITUD) END)  LIKE UPPER( '%' || :GEO_LATITUD || '%')  AND (CASE WHEN GEO_LONGITUD IS NULL THEN ' ' ELSE UPPER(GEO_LONGITUD) END)  LIKE UPPER(:GEO_LONGITUD || '%')  AND (CASE WHEN GEO_VERTICE IS NULL THEN ' ' ELSE UPPER(GEO_VERTICE) END)  LIKE UPPER(:GEO_VERTICE || '%')  AND (CASE WHEN LECTACTUAL IS NULL THEN ' ' ELSE UPPER(LECTACTUAL) END)  LIKE UPPER( '%' || :LECTACTUAL || '%')  AND (CASE WHEN LECTURAFINALVIEJO IS NULL THEN ' ' ELSE UPPER(LECTURAFINALVIEJO) END)  LIKE UPPER( '%' || :LECTURAFINALVIEJO || '%')  AND (CASE WHEN LECTURAINICIAL IS NULL THEN ' ' ELSE UPPER(LECTURAINICIAL) END)  LIKE UPPER( '%' || :LECTURAINICIAL || '%')  AND (CASE WHEN LECTURAPROMEDIO IS NULL THEN ' ' ELSE UPPER(LECTURAPROMEDIO) END)  LIKE UPPER( '%' || :LECTURAPROMEDIO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER(:MARCA || '%')  AND (CASE WHEN MEDIDORNUEVO IS NULL THEN ' ' ELSE UPPER(MEDIDORNUEVO) END)  LIKE UPPER(:MEDIDORNUEVO || '%')  AND (CASE WHEN NUMFACTURA IS NULL THEN ' ' ELSE UPPER(NUMFACTURA) END)  LIKE UPPER(:NUMFACTURA || '%')  AND (CASE WHEN PROMEDIO IS NULL THEN ' ' ELSE UPPER(PROMEDIO) END)  LIKE UPPER(:PROMEDIO || '%')  AND (CASE WHEN TIPOLABEL IS NULL THEN ' ' ELSE UPPER(TIPOLABEL) END)  LIKE UPPER(:TIPOLABEL || '%')  AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END)  LIKE UPPER( '%' || :CODIGOINTERNO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CICLO":"$CICLO(type:integer)","CLASE":"$CLASE(type:integer)","CLASIFICACION":"$CLASIFICACION","CODIGO":"$CODIGO","CODIGORUTA":"$CODIGORUTA","CONSECUTIVO":"$CONSECUTIVO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","DIAMETRO":"$DIAMETRO","DIGITOS":"$DIGITOS(type:integer)","ELEMCAMBIO":"$ELEMCAMBIO","ESTADOLABEL":"$ESTADOLABEL","ESTADO":"$ESTADO","FECHACOMPRA":"$FECHACOMPRA","FECHAINST":"$FECHAINST","FECHA_REG":"$FECHA_REG","GEO_ALTITUD":"$GEO_ALTITUD","GEO_LATITUD":"$GEO_LATITUD","GEO_LONGITUD":"$GEO_LONGITUD","GEO_VERTICE":"$GEO_VERTICE","LECTACTUAL":"$LECTACTUAL","LECTMEDANT":"$LECTMEDANT(type:integer)","LECTURAFINALVIEJO":"$LECTURAFINALVIEJO","LECTURAINICIAL":"$LECTURAINICIAL","LECTURAPROMEDIO":"$LECTURAPROMEDIO","LOCALIZACION":"$LOCALIZACION(type:integer)","LONGITUD":"$LONGITUD","MARCA":"$MARCA","MEDIDORNUEVO":"$MEDIDORNUEVO","MODIFIED_BY":"$MODIFIED_BY","NOORDENINST":"$NOORDENINST","NUMCERTIFICACION":"$NUMCERTIFICACION","NUMFACTURA":"$NUMFACTURA","PERIODO":"$PERIODO","POSICION":"$POSICION","PROMEDIO":"$PROMEDIO","RADIO":"$RADIO","TIPOLABEL":"$TIPOLABEL","TIPO":"$TIPO","CODIGOINTERNO":"$CODIGOINTERNO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DIAMETRO" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="ELEMCAMBIO" sqlType="STRING"/>
		<param name="ESTADOLABEL" sqlType="STRING"/>
		<param name="FECHACOMPRA" sqlType="STRING"/>
		<param name="FECHAINST" sqlType="STRING"/>
		<param name="FECHA_REG" sqlType="STRING"/>
		<param name="GEO_ALTITUD" sqlType="STRING"/>
		<param name="GEO_LATITUD" sqlType="STRING"/>
		<param name="GEO_LONGITUD" sqlType="STRING"/>
		<param name="GEO_VERTICE" sqlType="STRING"/>
		<param name="LECTACTUAL" sqlType="STRING"/>
		<param name="LECTURAFINALVIEJO" sqlType="STRING"/>
		<param name="LECTURAINICIAL" sqlType="STRING"/>
		<param name="LECTURAPROMEDIO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="MEDIDORNUEVO" sqlType="STRING"/>
		<param name="NUMFACTURA" sqlType="STRING"/>
		<param name="PROMEDIO" sqlType="STRING"/>
		<param name="TIPOLABEL" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
