<data name="sfconfigsycdet" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfconfigsycdetContardetallesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(COMPANIA) CUENTA FROM SF_CONFIG_SYC_DET WHERE COMPANIA =:COMPANIA AND CODIGO_SYC = :CODIGO_SYC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_SYC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconfigsycdet/contardetalles">
		<call-query href="getSfconfigsycdetContardetallesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_SYC" query-param="CODIGO_SYC"/>

		</call-query>
	</resource>
	<query id="insertSfconfigsycdet" keyColumns="COMPANIA,CODIGO_SYC,CONCEPTO_SYC,GRUPO_SYS,COD_BANCO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_CONFIG_SYC_DET (COMPANIA, CODIGO_SYC, CONCEPTO_SYC, GRUPO_SYS, COD_BANCO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_SYC, :CONCEPTO_SYC, :GRUPO_SYS, :COD_BANCO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_SYC":"$CODIGO_SYC(type:integer)","KEY_CONCEPTO_SYC":"$CONCEPTO_SYC(type:integer)","KEY_GRUPO_SYS":"$GRUPO_SYS(type:integer)","KEY_COD_BANCO":"$COD_BANCO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_SYC" sqlType="STRING"/>
		<param name="CONCEPTO_SYC" sqlType="STRING"/>
		<param name="GRUPO_SYS" sqlType="STRING"/>
		<param name="COD_BANCO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfconfigsycdet">
		<call-query href="insertSfconfigsycdet">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_SYC" query-param="CODIGO_SYC"/>
			<with-param name="CONCEPTO_SYC" query-param="CONCEPTO_SYC"/>
			<with-param name="GRUPO_SYS" query-param="GRUPO_SYS"/>
			<with-param name="COD_BANCO" query-param="COD_BANCO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSfconfigsycdet" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_CONFIG_SYC_DET WHERE SF_CONFIG_SYC_DET.COMPANIA= :KEY_COMPANIA AND SF_CONFIG_SYC_DET.CODIGO_SYC= :KEY_CODIGO_SYC AND SF_CONFIG_SYC_DET.CONCEPTO_SYC= :KEY_CONCEPTO_SYC AND SF_CONFIG_SYC_DET.GRUPO_SYS= :KEY_GRUPO_SYS AND SF_CONFIG_SYC_DET.COD_BANCO= :KEY_COD_BANCO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_SYC" sqlType="INTEGER"/>
		<param name="KEY_CONCEPTO_SYC" sqlType="INTEGER"/>
		<param name="KEY_GRUPO_SYS" sqlType="INTEGER"/>
		<param name="KEY_COD_BANCO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="sfconfigsycdet">
		<call-query href="deleteSfconfigsycdet">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_SYC" query-param="KEY_CODIGO_SYC"/>
			<with-param name="KEY_CONCEPTO_SYC" query-param="KEY_CONCEPTO_SYC"/>
			<with-param name="KEY_GRUPO_SYS" query-param="KEY_GRUPO_SYS"/>
			<with-param name="KEY_COD_BANCO" query-param="KEY_COD_BANCO"/>

		</call-query>
	</resource>
	<query id="getSfconfigsycdetPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO_SYC, CONCEPTO_SYC , GRUPO_SYS, COD_BANCO FROM SF_CONFIG_SYC_DET WHERE COMPANIA =:COMPANIA AND CODIGO_SYC = :CODIGO_SYC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO_SYC IS NULL THEN ' ' ELSE UPPER(CODIGO_SYC) END) LIKE UPPER(CONCAT(:CODIGO_SYC, '%')) AND (CASE WHEN CONCEPTO_SYC IS NULL THEN ' ' ELSE UPPER(CONCEPTO_SYC) END) LIKE UPPER(CONCAT(:CONCEPTO_SYC, '%')) AND (CASE WHEN GRUPO_SYS IS NULL THEN ' ' ELSE UPPER(GRUPO_SYS) END) LIKE UPPER(CONCAT(:GRUPO_SYS, '%')) AND (CASE WHEN COD_BANCO IS NULL THEN ' ' ELSE UPPER(COD_BANCO) END) LIKE UPPER(CONCAT(:COD_BANCO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_SYC":"$CODIGO_SYC(type:integer)","CONCEPTO_SYC":"$CONCEPTO_SYC(type:integer)","GRUPO_SYS":"$GRUPO_SYS(type:integer)","COD_BANCO":"$COD_BANCO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_SYC" sqlType="STRING"/>
		<param name="CONCEPTO_SYC" sqlType="STRING"/>
		<param name="GRUPO_SYS" sqlType="STRING"/>
		<param name="COD_BANCO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfconfigsycdet">
		<call-query href="getSfconfigsycdetPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_SYC" query-param="CODIGO_SYC"/>
			<with-param name="CONCEPTO_SYC" query-param="CONCEPTO_SYC"/>
			<with-param name="GRUPO_SYS" query-param="GRUPO_SYS"/>
			<with-param name="COD_BANCO" query-param="COD_BANCO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfconfigsycdetNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO_SYC, CONCEPTO_SYC , GRUPO_SYS, COD_BANCO FROM SF_CONFIG_SYC_DET WHERE COMPANIA =:COMPANIA AND CODIGO_SYC = :CODIGO_SYC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO_SYC IS NULL THEN ' ' ELSE UPPER(CODIGO_SYC) END) LIKE UPPER(CONCAT(:CODIGO_SYC, '%')) AND (CASE WHEN CONCEPTO_SYC IS NULL THEN ' ' ELSE UPPER(CONCEPTO_SYC) END) LIKE UPPER(CONCAT(:CONCEPTO_SYC, '%')) AND (CASE WHEN GRUPO_SYS IS NULL THEN ' ' ELSE UPPER(GRUPO_SYS) END) LIKE UPPER(CONCAT(:GRUPO_SYS, '%')) AND (CASE WHEN COD_BANCO IS NULL THEN ' ' ELSE UPPER(COD_BANCO) END) LIKE UPPER(CONCAT(:COD_BANCO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_SYC" sqlType="STRING"/>
		<param name="CONCEPTO_SYC" sqlType="STRING"/>
		<param name="GRUPO_SYS" sqlType="STRING"/>
		<param name="COD_BANCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconfigsycdet/numero">
		<call-query href="getSfconfigsycdetNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_SYC" query-param="CODIGO_SYC"/>
			<with-param name="CONCEPTO_SYC" query-param="CONCEPTO_SYC"/>
			<with-param name="GRUPO_SYS" query-param="GRUPO_SYS"/>
			<with-param name="COD_BANCO" query-param="COD_BANCO"/>

		</call-query>
	</resource>
	<query id="updateSfconfigsycdet" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CONFIG_SYC_DET SET COMPANIA=:COMPANIA, CODIGO_SYC=:CODIGO_SYC, CONCEPTO_SYC=:CONCEPTO_SYC, GRUPO_SYS=:GRUPO_SYS, COD_BANCO=:COD_BANCO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_CONFIG_SYC_DET.COMPANIA= :KEY_COMPANIA AND SF_CONFIG_SYC_DET.CODIGO_SYC= :KEY_CODIGO_SYC AND SF_CONFIG_SYC_DET.CONCEPTO_SYC= :KEY_CONCEPTO_SYC AND SF_CONFIG_SYC_DET.GRUPO_SYS= :KEY_GRUPO_SYS AND SF_CONFIG_SYC_DET.COD_BANCO= :KEY_COD_BANCO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_SYC" sqlType="STRING"/>
		<param name="CONCEPTO_SYC" sqlType="STRING"/>
		<param name="GRUPO_SYS" sqlType="STRING"/>
		<param name="COD_BANCO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_SYC" sqlType="STRING"/>
		<param name="KEY_CONCEPTO_SYC" sqlType="STRING"/>
		<param name="KEY_GRUPO_SYS" sqlType="STRING"/>
		<param name="KEY_COD_BANCO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfconfigsycdet">
		<call-query href="updateSfconfigsycdet">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_SYC" query-param="CODIGO_SYC"/>
			<with-param name="CONCEPTO_SYC" query-param="CONCEPTO_SYC"/>
			<with-param name="GRUPO_SYS" query-param="GRUPO_SYS"/>
			<with-param name="COD_BANCO" query-param="COD_BANCO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_SYC" query-param="KEY_CODIGO_SYC"/>
			<with-param name="KEY_CONCEPTO_SYC" query-param="KEY_CONCEPTO_SYC"/>
			<with-param name="KEY_GRUPO_SYS" query-param="KEY_GRUPO_SYS"/>
			<with-param name="KEY_COD_BANCO" query-param="KEY_COD_BANCO"/>

		</call-query>
	</resource>

</data>