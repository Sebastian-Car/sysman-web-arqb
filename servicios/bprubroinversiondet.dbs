	<query id="getBprubroinversiondetPagTodosPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_RUBRO_INVERSION_DET.RUBRO, BP_RUBRO_INVERSION_DET.DESCRIPCION, PLAN_PRESUPUESTAL.FUENTE_RECURSO, BP_RUBRO_INVERSION_DET.VIGENCIA  FROM BP_RUBRO_INVERSION_DET INNER JOIN V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL ON BP_RUBRO_INVERSION_DET.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND BP_RUBRO_INVERSION_DET.VIGENCIA = PLAN_PRESUPUESTAL.ANO AND BP_RUBRO_INVERSION_DET.RUBRO = PLAN_PRESUPUESTAL.CODIGO WHERE BP_RUBRO_INVERSION_DET.COMPANIA = :COMPANIA AND BP_RUBRO_INVERSION_DET.VIGENCIA = :ANO AND PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0)) WHERE (CASE WHEN RUBRO IS NULL THEN ' ' ELSE UPPER(RUBRO) END)  LIKE UPPER(:RUBRO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER( '%' || :FUENTE_RECURSO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUBRO":"$RUBRO","DESCRIPCION":"$DESCRIPCION","FUENTE_RECURSO":"$FUENTE_RECURSO","VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bprubroinversiondet/todosporvigencia/pag">
		<call-query href="getBprubroinversiondetPagTodosPorVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBprubroinversiondetNumTodosPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_RUBRO_INVERSION_DET.RUBRO, BP_RUBRO_INVERSION_DET.DESCRIPCION, PLAN_PRESUPUESTAL.FUENTE_RECURSO, BP_RUBRO_INVERSION_DET.VIGENCIA  FROM BP_RUBRO_INVERSION_DET INNER JOIN V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL ON BP_RUBRO_INVERSION_DET.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND BP_RUBRO_INVERSION_DET.VIGENCIA = PLAN_PRESUPUESTAL.ANO AND BP_RUBRO_INVERSION_DET.RUBRO = PLAN_PRESUPUESTAL.CODIGO WHERE BP_RUBRO_INVERSION_DET.COMPANIA = :COMPANIA AND BP_RUBRO_INVERSION_DET.VIGENCIA = :ANO AND PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0)) WHERE (CASE WHEN RUBRO IS NULL THEN ' ' ELSE UPPER(RUBRO) END)  LIKE UPPER(:RUBRO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER( '%' || :FUENTE_RECURSO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>

	</query>
