	</resource>
	<query id="getBprubroinversiondetPagTodosporvigenciafullcamposQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BP_RUBRO_INVERSION_DET.RUBRO, BP_RUBRO_INVERSION_DET.DESCRIPCION, PLAN_PRESUPUESTAL.FUENTE_RECURSO, PLAN_PRESUPUESTAL.CENTRO_COSTO, PLAN_PRESUPUESTAL.REFERENCIA, PLAN_PRESUPUESTAL.CENTRO_COSTO, PLAN_PRESUPUESTAL.AUXILIAR, BP_RUBRO_INVERSION_DET.VIGENCIA FROM BP_RUBRO_INVERSION_DET INNER JOIN V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL ON BP_RUBRO_INVERSION_DET.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND BP_RUBRO_INVERSION_DET.VIGENCIA = PLAN_PRESUPUESTAL.ANO AND BP_RUBRO_INVERSION_DET.RUBRO = PLAN_PRESUPUESTAL.CODIGO WHERE BP_RUBRO_INVERSION_DET.COMPANIA = :COMPANIA AND BP_RUBRO_INVERSION_DET.VIGENCIA = :ANO AND PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0)) INI WHERE (CASE WHEN RUBRO IS NULL THEN ' ' ELSE UPPER(RUBRO) END) LIKE UPPER(CONCAT(:RUBRO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUBRO":"$RUBRO","DESCRIPCION":"$DESCRIPCION","FUENTE_RECURSO":"$FUENTE_RECURSO","CENTRO_COSTO":"$CENTRO_COSTO","REFERENCIA":"$REFERENCIA","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
