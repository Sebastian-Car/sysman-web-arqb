<data name="documentospresentados" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDocumentospresentados" keyColumns="COMPANIA,NUMERO_DCTO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DOCUMENTOS_PRESENTADOS (COMPANIA, SUCURSAL, NUMERO_DCTO, CODIGO, PRESENTADO, FOLIOS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :SUCURSAL, :NUMERO_DCTO, :CODIGO, :PRESENTADO, :FOLIOS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="0" name="PRESENTADO" sqlType="STRING"/>
		<param defaultValue="" name="FOLIOS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="documentospresentados">
		<call-query href="insertDocumentospresentados">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PRESENTADO" query-param="PRESENTADO"/>
			<with-param name="FOLIOS" query-param="FOLIOS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getDocumentospresentadosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DP.COMPANIA, DP.NUMERO_DCTO, DP.CODIGO, DR.NOMBRE,(CASE DP.PRESENTADO WHEN 0 THEN 'false' ELSE 'true' END) PRESENTADO, DP.FOLIOS FROM DOCUMENTOS_PRESENTADOS DP INNER JOIN DOCUMENTOS_REQUERIDOS DR ON DP.COMPANIA = DR.COMPANIA AND DP.CODIGO = DR.CONSECUTIVO WHERE DP.COMPANIA = :COMPANIA AND DP.SUCURSAL = :SUCURSAL AND DP.NUMERO_DCTO = :DOCNUM) INI WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PRESENTADO IS NULL THEN ' ' ELSE UPPER(PRESENTADO) END) LIKE UPPER(CONCAT(:PRESENTADO, '%')) AND (CASE WHEN FOLIOS IS NULL THEN ' ' ELSE UPPER(FOLIOS) END) LIKE UPPER(CONCAT(:FOLIOS, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PRESENTADO":"$PRESENTADO(type:boolean)","FOLIOS":"$FOLIOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PRESENTADO" sqlType="STRING"/>
		<param name="FOLIOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="documentospresentados">
		<call-query href="getDocumentospresentadosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PRESENTADO" query-param="PRESENTADO"/>
			<with-param name="FOLIOS" query-param="FOLIOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDocumentospresentadosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DP.COMPANIA, DP.NUMERO_DCTO, DP.CODIGO, DR.NOMBRE,(CASE DP.PRESENTADO WHEN 0 THEN 'false' ELSE 'true' END) PRESENTADO, DP.FOLIOS FROM DOCUMENTOS_PRESENTADOS DP INNER JOIN DOCUMENTOS_REQUERIDOS DR ON DP.COMPANIA = DR.COMPANIA AND DP.CODIGO = DR.CONSECUTIVO WHERE DP.COMPANIA = :COMPANIA AND DP.SUCURSAL = :SUCURSAL AND DP.NUMERO_DCTO = :DOCNUM) INI WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PRESENTADO IS NULL THEN ' ' ELSE UPPER(PRESENTADO) END) LIKE UPPER(CONCAT(:PRESENTADO, '%')) AND (CASE WHEN FOLIOS IS NULL THEN ' ' ELSE UPPER(FOLIOS) END) LIKE UPPER(CONCAT(:FOLIOS, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PRESENTADO" sqlType="STRING"/>
		<param name="FOLIOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="documentospresentados/numero">
		<call-query href="getDocumentospresentadosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PRESENTADO" query-param="PRESENTADO"/>
			<with-param name="FOLIOS" query-param="FOLIOS"/>

		</call-query>
	</resource>
	<query id="updateDocumentospresentados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DOCUMENTOS_PRESENTADOS SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, PRESENTADO=:PRESENTADO, NUMERO_DCTO=:NUMERO_DCTO, FOLIOS=:FOLIOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DOCUMENTOS_PRESENTADOS.COMPANIA= :KEY_COMPANIA AND DOCUMENTOS_PRESENTADOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND DOCUMENTOS_PRESENTADOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PRESENTADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="FOLIOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="documentospresentados">
		<call-query href="updateDocumentospresentados">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PRESENTADO" query-param="PRESENTADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="FOLIOS" query-param="FOLIOS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>