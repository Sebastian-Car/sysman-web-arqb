			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>

		</call-query>
	</resource>
	<query id="getSftarifaPagTarifafinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SF_TARIFA.CODIGO, SF_TARIFA.NOMBRE  FROM SF_TARIFA WHERE SF_TARIFA.COMPANIA=:COMPANIA AND SF_TARIFA.ANO=:ANO AND SF_TARIFA.TIPOCOBRO=:TIPOCOBRO AND SF_TARIFA.CODIGO &gt;= :CONCEPTORELACIONADO ORDER BY SF_TARIFA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTORELACIONADO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftarifa/tarifafinal/pag">
		<call-query href="getSftarifaPagTarifafinalQuery">
