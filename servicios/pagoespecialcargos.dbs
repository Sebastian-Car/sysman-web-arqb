<data name="pagoespecialcargos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPagoespecialcargosPagPrincipalsubQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PC.COMPANIA, PC.CODIGOPAGOESP, PC.CODIGODETALLEPAGO, PC.ID_DE_CARGO, D.DESCRIPCION, D.ANO, CRG.NOMBRE_DEL_CARGO FROM PAGOESPECIAL_CARGOS PC INNER JOIN DETALLEPAGOESPECIAL D ON PC.COMPANIA = D.COMPANIA AND PC.CODIGOPAGOESP = D.CODIGOPAGOESP AND PC.CODIGODETALLEPAGO = D.CONSECUTIVO INNER JOIN CARGOS CRG ON PC.COMPANIA = CRG.COMPANIA AND PC.ID_DE_CARGO = CRG.ID_DE_CARGO WHERE PC.COMPANIA =:COMPANIA AND PC.CODIGOPAGOESP =:PAGO) INI WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEL_CARGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOPAGOESP":"$CODIGOPAGOESP(type:integer)","CODIGODETALLEPAGO":"$CODIGODETALLEPAGO(type:integer)","ID_DE_CARGO":"$ID_DE_CARGO","DESCRIPCION":"$DESCRIPCION","ANO":"$ANO(type:integer)","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="pagoespecialcargos/principalsub/pag">
		<call-query href="getPagoespecialcargosPagPrincipalsubQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPagoespecialcargosNumPrincipalsubQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PC.COMPANIA, PC.CODIGOPAGOESP, PC.CODIGODETALLEPAGO, PC.ID_DE_CARGO, D.DESCRIPCION, D.ANO, CRG.NOMBRE_DEL_CARGO FROM PAGOESPECIAL_CARGOS PC INNER JOIN DETALLEPAGOESPECIAL D ON PC.COMPANIA = D.COMPANIA AND PC.CODIGOPAGOESP = D.CODIGOPAGOESP AND PC.CODIGODETALLEPAGO = D.CONSECUTIVO INNER JOIN CARGOS CRG ON PC.COMPANIA = CRG.COMPANIA AND PC.ID_DE_CARGO = CRG.ID_DE_CARGO WHERE PC.COMPANIA =:COMPANIA AND PC.CODIGOPAGOESP =:PAGO) INI WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEL_CARGO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pagoespecialcargos/principalsub/num">
		<call-query href="getPagoespecialcargosNumPrincipalsubQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>

		</call-query>
	</resource>
	<query id="insertPagoespecialcargosPrincipalsub" keyColumns="COMPANIA,CODIGOPAGOESP,CODIGODETALLEPAGO,ID_DE_CARGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PAGOESPECIAL_CARGOS (COMPANIA, CODIGOPAGOESP, CODIGODETALLEPAGO, ID_DE_CARGO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGOPAGOESP, :CODIGODETALLEPAGO, :ID_DE_CARGO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOPAGOESP":"$CODIGOPAGOESP(type:integer)","KEY_CODIGODETALLEPAGO":"$CODIGODETALLEPAGO(type:integer)","KEY_ID_DE_CARGO":"$ID_DE_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPAGOESP" sqlType="STRING"/>
		<param name="CODIGODETALLEPAGO" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="pagoespecialcargos/principalsub">
		<call-query href="insertPagoespecialcargosPrincipalsub">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPAGOESP" query-param="CODIGOPAGOESP"/>
			<with-param name="CODIGODETALLEPAGO" query-param="CODIGODETALLEPAGO"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updatePagoespecialcargosPrincipalsubquery" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PAGOESPECIAL_CARGOS SET COMPANIA=:COMPANIA, CODIGOPAGOESP=:CODIGOPAGOESP, CODIGODETALLEPAGO=:CODIGODETALLEPAGO, ID_DE_CARGO=:ID_DE_CARGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PAGOESPECIAL_CARGOS.COMPANIA= :KEY_COMPANIA AND PAGOESPECIAL_CARGOS.CODIGOPAGOESP= :KEY_CODIGOPAGOESP AND PAGOESPECIAL_CARGOS.CODIGODETALLEPAGO= :KEY_CODIGODETALLEPAGO AND PAGOESPECIAL_CARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPAGOESP" sqlType="STRING"/>
		<param name="CODIGODETALLEPAGO" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPAGOESP" sqlType="STRING"/>
		<param name="KEY_CODIGODETALLEPAGO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="pagoespecialcargos/principalsubquery">
		<call-query href="updatePagoespecialcargosPrincipalsubquery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPAGOESP" query-param="CODIGOPAGOESP"/>
			<with-param name="CODIGODETALLEPAGO" query-param="CODIGODETALLEPAGO"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPAGOESP" query-param="KEY_CODIGOPAGOESP"/>
			<with-param name="KEY_CODIGODETALLEPAGO" query-param="KEY_CODIGODETALLEPAGO"/>
			<with-param name="KEY_ID_DE_CARGO" query-param="KEY_ID_DE_CARGO"/>

		</call-query>
	</resource>
	<query id="deletePagoespecialcargosPrincipalsubquery" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PAGOESPECIAL_CARGOS WHERE COMPANIA = :KEY_COMPANIA AND CODIGOPAGOESP= :KEY_CODIGOPAGOESP AND CODIGODETALLEPAGO= :KEY_CODIGODETALLEPAGO AND ID_DE_CARGO= :KEY_ID_DE_CARGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPAGOESP" sqlType="STRING"/>
		<param name="KEY_CODIGODETALLEPAGO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="pagoespecialcargos/principalsubquery">
		<call-query href="deletePagoespecialcargosPrincipalsubquery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPAGOESP" query-param="KEY_CODIGOPAGOESP"/>
			<with-param name="KEY_CODIGODETALLEPAGO" query-param="KEY_CODIGODETALLEPAGO"/>
			<with-param name="KEY_ID_DE_CARGO" query-param="KEY_ID_DE_CARGO"/>

		</call-query>
	</resource>

</data>