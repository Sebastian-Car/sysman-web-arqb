	<query id="getEstadonominaNumListanominaeliminacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUMERO, TIPO_NOMINA, ESTADO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, NUMERO_DOCUMENTO, CUNE FROM ESTADO_NOM WHERE TIPO_NOMINA = 'T_NE_AJUSTE_EL') INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TIPO_NOMINA IS NULL THEN ' ' ELSE UPPER(TIPO_NOMINA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_NOMINA), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NUMERO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_DOCUMENTO), '%')) AND (CASE WHEN CUNE IS NULL THEN ' ' ELSE UPPER(CUNE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUNE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
