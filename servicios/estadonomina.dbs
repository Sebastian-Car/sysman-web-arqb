		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO, TIPO_NOMINA, ESTADO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,NUMERO_DOCUMENTO, CUNE FROM ESTADO_NOM WHERE TIPO_NOMINA = 'T_NE_AJUSTE_RE') INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TIPO_NOMINA IS NULL THEN ' ' ELSE UPPER(TIPO_NOMINA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_NOMINA), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NUMERO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_DOCUMENTO), '%')) AND (CASE WHEN CUNE IS NULL THEN ' ' ELSE UPPER(CUNE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUNE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","TIPO_NOMINA":"$TIPO_NOMINA","ESTADO":"$ESTADO","FECHA":"$FECHA","NUMERO_DOCUMENTO":"$NUMERO_DOCUMENTO(type:long)","CUNE":"$CUNE"}]}}		</result>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO_NOMINA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMERO_DOCUMENTO" sqlType="STRING"/>
