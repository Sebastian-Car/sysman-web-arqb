	<query id="updateEstadonominaActualizalistaestados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ESTADO_NOM 
SET 
    NUMERO_DOCUMENTO = :NUMERO_DOCUMENTO,
    ESTADO = :ESTADO,
    CUNE = :CUNE,
    FECHA = TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'),
    TIPO_NOMINA = :TIPO_NOMINA,
    CODIGO_TRABAJADOR = :CODIGO_TRABAJADOR,
    OBSERVACIONES = :OBSERVACIONES 
WHERE NUMERO = :NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO_DOCUMENTO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CUNE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TIPO_NOMINA" sqlType="STRING"/>
		<param name="CODIGO_TRABAJADOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="estadonomina/actualizalistaestados">
		<call-query href="updateEstadonominaActualizalistaestados">
			<with-param name="NUMERO_DOCUMENTO" query-param="NUMERO_DOCUMENTO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CUNE" query-param="CUNE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="TIPO_NOMINA" query-param="TIPO_NOMINA"/>
			<with-param name="CODIGO_TRABAJADOR" query-param="CODIGO_TRABAJADOR"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getEstadonominaExistelistaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(NUMERO) TOTAL  FROM ESTADO_NOM WHERE NUMERO =:NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estadonomina/existelista">
		<call-query href="getEstadonominaExistelistaQuery">
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
</data>