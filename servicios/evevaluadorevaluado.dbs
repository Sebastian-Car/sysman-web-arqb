	<query id="getEvevaluadorevaluadoNumCargosEvaluadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, EV_EVALUADOR_EVALUADO.TIPO_EVALUACION  FROM EV_EVALUADOR_EVALUADO LEFT JOIN CARGOS ON EV_EVALUADOR_EVALUADO.COMPANIA = CARGOS.COMPANIA AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADO = CARGOS.ESCALAFON AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADO = CARGOS.ID_DE_CARGO WHERE EV_EVALUADOR_EVALUADO.COMPANIA = :COMPANIA AND CARGOS.ESCALAFON = :ESCALAFON AND EV_EVALUADOR_EVALUADO.CLASE_EVALUACION = :CLASE ORDER BY ID_DE_CARGO) WHERE (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%') ))</sql>
