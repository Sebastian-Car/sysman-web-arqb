	<query id="insertEvevaluadorevaluado" keyColumns="COMPANIA,CODIGO_EMPLEADO_EVALUADOR,CARGO_EVALUADOR,ESCALAFON_EVALUADOR,CODIGO_EMPLEADO_EVALUADO,CARGO_EVALUADO,ESCALAFON_EVALUADO,CLASE_EVALUACION,TIPO_EVALUACION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_EVALUADOR_EVALUADO (COMPANIA, CARGO_EVALUADOR, GRUPO_APLICAR, CARGO_EVALUADO, ESCALAFON_EVALUADOR, ESCALAFON_EVALUADO, CLASE_EVALUACION, TIPO_EVALUACION, CODIGO_EMPLEADO_EVALUADO, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CODIGO_EMPLEADO_EVALUADOR, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CARGO_EVALUADOR, :GRUPO_APLICAR, :CARGO_EVALUADO, :ESCALAFON_EVALUADOR, :ESCALAFON_EVALUADO, :CLASE_EVALUACION, :TIPO_EVALUACION, :CODIGO_EMPLEADO_EVALUADO, :CEDULA_EVALUADO, :SUCURSAL_EVALUADO, :CODIGO_EMPLEADO_EVALUADOR, :CEDULA_EVALUADOR, :SUCURSAL_EVALUADOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_EMPLEADO_EVALUADOR":"$CODIGO_EMPLEADO_EVALUADOR","KEY_CARGO_EVALUADOR":"$CARGO_EVALUADOR","KEY_ESCALAFON_EVALUADOR":"$ESCALAFON_EVALUADOR","KEY_CODIGO_EMPLEADO_EVALUADO":"$CODIGO_EMPLEADO_EVALUADO","KEY_CARGO_EVALUADO":"$CARGO_EVALUADO","KEY_ESCALAFON_EVALUADO":"$ESCALAFON_EVALUADO","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","KEY_TIPO_EVALUACION":"$TIPO_EVALUACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CARGO_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="" name="GRUPO_APLICAR" sqlType="STRING"/>
		<param name="CARGO_EVALUADO" sqlType="STRING"/>
		<param name="ESCALAFON_EVALUADOR" sqlType="STRING"/>
		<param name="ESCALAFON_EVALUADO" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="CODIGO_EMPLEADO_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CODIGO_EMPLEADO_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evevaluadorevaluado">
		<call-query href="insertEvevaluadorevaluado">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CARGO_EVALUADOR" query-param="CARGO_EVALUADOR"/>
			<with-param name="GRUPO_APLICAR" query-param="GRUPO_APLICAR"/>
			<with-param name="CARGO_EVALUADO" query-param="CARGO_EVALUADO"/>
			<with-param name="ESCALAFON_EVALUADOR" query-param="ESCALAFON_EVALUADOR"/>
			<with-param name="ESCALAFON_EVALUADO" query-param="ESCALAFON_EVALUADO"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CODIGO_EMPLEADO_EVALUADO" query-param="CODIGO_EMPLEADO_EVALUADO"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CODIGO_EMPLEADO_EVALUADOR" query-param="CODIGO_EMPLEADO_EVALUADOR"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="SUCURSAL_EVALUADOR" query-param="SUCURSAL_EVALUADOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
