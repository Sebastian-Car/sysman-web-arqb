	<query id="updateEvevaluadorevaluado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_EVALUADOR_EVALUADO SET CODIGO_EMPLEADO_EVALUADO=:CODIGO_EMPLEADO_EVALUADO, CEDULA_EVALUADO=:CEDULA_EVALUADO, GRUPO_APLICAR=:GRUPO_APLICAR, SUCURSAL_EVALUADO=:SUCURSAL_EVALUADO, CODIGO_EMPLEADO_EVALUADOR=:CODIGO_EMPLEADO_EVALUADOR, CEDULA_EVALUADOR=:CEDULA_EVALUADOR, SUCURSAL_EVALUADOR=:SUCURSAL_EVALUADOR, ESCALAFON_EVALUADOR=:ESCALAFON_EVALUADOR, ESCALAFON_EVALUADO=:ESCALAFON_EVALUADO, CARGO_EVALUADO=:CARGO_EVALUADO, CARGO_EVALUADOR=:CARGO_EVALUADOR, CLASE_EVALUACION=:CLASE_EVALUACION, TIPO_EVALUACION=:TIPO_EVALUACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_EVALUADOR_EVALUADO.COMPANIA= :KEY_COMPANIA AND EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADOR= :KEY_CODIGO_EMPLEADO_EVALUADOR AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADOR= :KEY_CARGO_EVALUADOR AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADOR= :KEY_ESCALAFON_EVALUADOR AND EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADO= :KEY_CODIGO_EMPLEADO_EVALUADO AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADO= :KEY_CARGO_EVALUADO AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADO= :KEY_ESCALAFON_EVALUADO AND EV_EVALUADOR_EVALUADO.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_EVALUADOR_EVALUADO.TIPO_EVALUACION= :KEY_TIPO_EVALUACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

