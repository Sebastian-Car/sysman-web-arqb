	<query id="getEvevaluadorevaluadoPagPorCompaniaYEscalafonQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADO, PERSONAL.NOMBRECOMPLETO NOMBREEMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.SUCURSAL, EV_EVALUADOR_EVALUADO.TIPO_EVALUACION, CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.NOMBRE, ESCALAFON.CODIGO, PERSONAL.DEPENDENCIA FROM EV_EVALUADOR_EVALUADO INNER JOIN PERSONAL ON EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADO = PERSONAL.ID_DE_EMPLEADO AND EV_EVALUADOR_EVALUADO.CEDULA_EVALUADO = PERSONAL.NUMERO_DCTO AND EV_EVALUADOR_EVALUADO.SUCURSAL_EVALUADO = PERSONAL.SUCURSAL AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADO = PERSONAL.ID_DE_CARGO INNER JOIN CARGOS ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO INNER JOIN ESCALAFON ON PERSONAL.COMPANIA = ESCALAFON.COMPANIA AND PERSONAL.ESCALAFON = ESCALAFON.CODIGO WHERE EV_EVALUADOR_EVALUADO.COMPANIA =:COMPANIA AND EV_EVALUADOR_EVALUADO.CLASE_EVALUACION =:CLASE AND EV_EVALUADOR_EVALUADO.CEDULA_EVALUADOR =:NUMERO_DCTO AND EV_EVALUADOR_EVALUADO.TIPO_EVALUACION =:TIPO) INI WHERE (CASE WHEN CODIGO_EMPLEADO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CODIGO_EMPLEADO_EVALUADO) END) LIKE UPPER(CONCAT(:CODIGO_EMPLEADO_EVALUADO, '%')) AND (CASE WHEN NOMBREEMPLEADO IS NULL THEN ' ' ELSE UPPER(NOMBREEMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREEMPLEADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_EMPLEADO_EVALUADO":"$CODIGO_EMPLEADO_EVALUADO","NOMBREEMPLEADO":"$NOMBREEMPLEADO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","TIPO_EVALUACION":"$TIPO_EVALUACION","ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","NOMBRE":"$NOMBRE","CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO_EMPLEADO_EVALUADO" sqlType="STRING"/>
		<param name="NOMBREEMPLEADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
