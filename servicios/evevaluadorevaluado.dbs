<data name="evevaluadorevaluado" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEvevaluadorevaluadoPagEscalafoncodigonombreporevaluadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT ESC.CODIGO, ESC.NOMBRE  FROM EV_EVALUADOR_EVALUADO EVAL INNER JOIN ESCALAFON ESC ON ESC.COMPANIA = EVAL.COMPANIA AND ESC.CODIGO = EVAL.ESCALAFON_EVALUADOR WHERE EVAL.COMPANIA = :COMPANIA AND EVAL.CLASE_EVALUACION = :CLASEEVALUACION AND CARGO_EVALUADOR = :CARGOEVALUADOR ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CARGOEVALUADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evevaluadorevaluado/escalafoncodigonombreporevaluador/pag">
		<call-query href="getEvevaluadorevaluadoPagEscalafoncodigonombreporevaluadorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="CARGOEVALUADOR" query-param="CARGOEVALUADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvevaluadorevaluadoNumEscalafoncodigonombreporevaluadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT ESC.CODIGO, ESC.NOMBRE  FROM EV_EVALUADOR_EVALUADO EVAL INNER JOIN ESCALAFON ESC ON ESC.COMPANIA = EVAL.COMPANIA AND ESC.CODIGO = EVAL.ESCALAFON_EVALUADOR WHERE EVAL.COMPANIA = :COMPANIA AND EVAL.CLASE_EVALUACION = :CLASEEVALUACION AND CARGO_EVALUADOR = :CARGOEVALUADOR ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="CARGOEVALUADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evevaluadorevaluado/escalafoncodigonombreporevaluador/num">
		<call-query href="getEvevaluadorevaluadoNumEscalafoncodigonombreporevaluadorQuery">
