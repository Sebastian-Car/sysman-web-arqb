	<query id="getEvevaluadorevaluadoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TER2.NOMBRE NOMBREEVALUADOR, TER1.NOMBRE NOMBREEVALUADO, EV_EVALUADOR_EVALUADO.GRUPO_APLICAR, EV_GRUPO.DESCRIPCION, EV_EVALUADOR_EVALUADO.COMPANIA, EV_EVALUADOR_EVALUADO.CARGO_EVALUADOR, CARG.NOMBRE_DEL_CARGO NOMBRECARGOEVALUADOR, EV_EVALUADOR_EVALUADO.CARGO_EVALUADO, CARG2.NOMBRE_DEL_CARGO NOMBRECARGORVALUADO, EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADOR, ESCA.NOMBRE NOMBREESCALAFONEVALUADOR, EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADO, ESCA2.NOMBRE NOMBREESCALAFONEVALUADO, EV_EVALUADOR_EVALUADO.CLASE_EVALUACION, EVAL.NOMBRE NOMBREEVALUACION, EV_EVALUADOR_EVALUADO.TIPO_EVALUACION, EV_EVALUADOR_EVALUADO.CEDULA_EVALUADO, EV_EVALUADOR_EVALUADO.SUCURSAL_EVALUADO, EV_EVALUADOR_EVALUADO.CEDULA_EVALUADOR, EV_EVALUADOR_EVALUADO.SUCURSAL_EVALUADOR, EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADOR, EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADO  FROM EV_EVALUADOR_EVALUADO INNER JOIN ESCALAFON ESCA ON EV_EVALUADOR_EVALUADO.COMPANIA = ESCA.COMPANIA AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADOR = ESCA.CODIGO INNER JOIN ESCALAFON ESCA2 ON EV_EVALUADOR_EVALUADO.COMPANIA = ESCA2.COMPANIA AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADO = ESCA2.CODIGO INNER JOIN CARGOS CARG ON EV_EVALUADOR_EVALUADO.COMPANIA = CARG.COMPANIA AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADOR = CARG.ID_DE_CARGO INNER JOIN CARGOS CARG2 ON EV_EVALUADOR_EVALUADO.COMPANIA = CARG2.COMPANIA AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADO = CARG2.ID_DE_CARGO INNER JOIN EV_TIPO_DE_EVALUACION EVAL ON EV_EVALUADOR_EVALUADO.COMPANIA = EVAL.COMPANIA AND EV_EVALUADOR_EVALUADO.TIPO_EVALUACION = EVAL.CODIGO AND EV_EVALUADOR_EVALUADO.CLASE_EVALUACION = EVAL.CLASE_EVALUACION INNER JOIN TERCERO TER1 ON EV_EVALUADOR_EVALUADO.COMPANIA = TER1.COMPANIA AND EV_EVALUADOR_EVALUADO.CEDULA_EVALUADO = TER1.NIT AND EV_EVALUADOR_EVALUADO.SUCURSAL_EVALUADO = TER1.SUCURSAL INNER JOIN TERCERO TER2 ON EV_EVALUADOR_EVALUADO.COMPANIA = TER2.COMPANIA AND EV_EVALUADOR_EVALUADO.CEDULA_EVALUADOR = TER2.NIT AND EV_EVALUADOR_EVALUADO.SUCURSAL_EVALUADOR = TER2.SUCURSAL LEFT JOIN EV_GRUPO ON EV_EVALUADOR_EVALUADO.COMPANIA = EV_GRUPO.COMPANIA AND EV_EVALUADOR_EVALUADO.GRUPO_APLICAR = EV_GRUPO.GRUPO AND EV_EVALUADOR_EVALUADO.CLASE_EVALUACION = EV_GRUPO.CLASE_EVALUACION WHERE EV_EVALUADOR_EVALUADO.COMPANIA= :KEY_COMPANIA AND EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADOR= :KEY_CODIGO_EMPLEADO_EVALUADOR AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADOR= :KEY_CARGO_EVALUADOR AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADOR= :KEY_ESCALAFON_EVALUADOR AND EV_EVALUADOR_EVALUADO.CODIGO_EMPLEADO_EVALUADO= :KEY_CODIGO_EMPLEADO_EVALUADO AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADO= :KEY_CARGO_EVALUADO AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADO= :KEY_ESCALAFON_EVALUADO AND EV_EVALUADOR_EVALUADO.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_EVALUADOR_EVALUADO.TIPO_EVALUACION= :KEY_TIPO_EVALUACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBREEVALUADOR":"$NOMBREEVALUADOR","NOMBREEVALUADO":"$NOMBREEVALUADO","GRUPO_APLICAR":"$GRUPO_APLICAR(type:integer)","DESCRIPCION":"$DESCRIPCION","COMPANIA":"$COMPANIA","CARGO_EVALUADOR":"$CARGO_EVALUADOR","NOMBRECARGOEVALUADOR":"$NOMBRECARGOEVALUADOR","CARGO_EVALUADO":"$CARGO_EVALUADO","NOMBRECARGORVALUADO":"$NOMBRECARGORVALUADO","ESCALAFON_EVALUADOR":"$ESCALAFON_EVALUADOR","NOMBREESCALAFONEVALUADOR":"$NOMBREESCALAFONEVALUADOR","ESCALAFON_EVALUADO":"$ESCALAFON_EVALUADO","NOMBREESCALAFONEVALUADO":"$NOMBREESCALAFONEVALUADO","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","NOMBREEVALUACION":"$NOMBREEVALUACION","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR","CODIGO_EMPLEADO_EVALUADOR":"$CODIGO_EMPLEADO_EVALUADOR","CODIGO_EMPLEADO_EVALUADO":"$CODIGO_EMPLEADO_EVALUADO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_EMPLEADO_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CARGO_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_ESCALAFON_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CODIGO_EMPLEADO_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CARGO_EVALUADO" sqlType="STRING"/>
		<param name="KEY_ESCALAFON_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>

	</query>
