	<query id="getEvevaluadorevaluadoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TER2.NOMBRE NOMBRE_EVALUADOR, TER1.NOMBRE NOMBRE_EVALUADO, EVEE.COMPANIA, EVEE.GRUPO_APLICAR, EV_GRUPO.DESCRIPCION, EVEE.CARGO_EVALUADOR, CARG.NOMBRE_DEL_CARGO NOMBRE_CARGO_EVALUADOR, EVEE.CARGO_EVALUADO, CARG2.NOMBRE_DEL_CARGO NOMBRE_CARGO_EVALUADO, EVEE.ESCALAFON_EVALUADOR, ESCA.NOMBRE NOMBRE_ESCALAFON_EVALUADOR, EVEE.ESCALAFON_EVALUADO, ESCA2.NOMBRE NOMBRE_ESCALAFON_EVALUADO, EVEE.CLASE_EVALUACION, EVAL.NOMBRE EVALUACION, EVEE.TIPO_EVALUACION, EVEE.CODIGO_EMPLEADO_EVALUADO, EVEE.CODIGO_EMPLEADO_EVALUADOR, EVEE.CEDULA_EVALUADO, EVEE.SUCURSAL_EVALUADO, EVEE.CEDULA_EVALUADOR, EVEE.SUCURSAL_EVALUADOR  FROM EV_EVALUADOR_EVALUADO EVEE INNER JOIN ESCALAFON ESCA ON EVEE.COMPANIA = ESCA.COMPANIA AND EVEE.ESCALAFON_EVALUADOR = ESCA.CODIGO INNER JOIN ESCALAFON ESCA2 ON EVEE.COMPANIA = ESCA2.COMPANIA AND EVEE.ESCALAFON_EVALUADO = ESCA2.CODIGO INNER JOIN CARGOS CARG ON EVEE.COMPANIA = CARG.COMPANIA AND EVEE.CARGO_EVALUADOR = CARG.ID_DE_CARGO INNER JOIN CARGOS CARG2 ON EVEE.COMPANIA = CARG2.COMPANIA AND EVEE.CARGO_EVALUADO = CARG2.ID_DE_CARGO INNER JOIN EV_TIPO_DE_EVALUACION EVAL ON EVEE.COMPANIA = EVAL.COMPANIA AND EVEE.TIPO_EVALUACION = EVAL.CODIGO AND EVEE.CLASE_EVALUACION = EVAL.CLASE_EVALUACION INNER JOIN TERCERO TER1 ON EVEE.COMPANIA = TER1.COMPANIA AND EVEE.CEDULA_EVALUADO = TER1.NIT AND EVEE.SUCURSAL_EVALUADO = TER1.SUCURSAL INNER JOIN TERCERO TER2 ON EVEE.COMPANIA = TER2.COMPANIA AND EVEE.CEDULA_EVALUADOR = TER2.NIT AND EVEE.SUCURSAL_EVALUADOR = TER2.SUCURSAL LEFT JOIN EV_GRUPO ON EVEE.COMPANIA = EV_GRUPO.COMPANIA AND EVEE.GRUPO_APLICAR = EV_GRUPO.GRUPO AND EVEE.CLASE_EVALUACION = EV_GRUPO.CLASE_EVALUACION WHERE EVEE.COMPANIA =:COMPANIA AND EVEE.CLASE_EVALUACION =:CLASEEVALUACION) WHERE (CASE WHEN NOMBRE_EVALUADOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_EVALUADOR) END)  LIKE UPPER( '%' || :NOMBRE_EVALUADOR || '%')  AND (CASE WHEN NOMBRE_EVALUADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_EVALUADO) END)  LIKE UPPER( '%' || :NOMBRE_EVALUADO || '%')  AND (CASE WHEN GRUPO_APLICAR IS NULL THEN ' ' ELSE UPPER(GRUPO_APLICAR) END)  LIKE UPPER( '%' || :GRUPO_APLICAR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CARGO_EVALUADOR IS NULL THEN ' ' ELSE UPPER(CARGO_EVALUADOR) END)  LIKE UPPER( '%' || :CARGO_EVALUADOR || '%')  AND (CASE WHEN NOMBRE_CARGO_EVALUADOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_CARGO_EVALUADOR) END)  LIKE UPPER( '%' || :NOMBRE_CARGO_EVALUADOR || '%')  AND (CASE WHEN CARGO_EVALUADO IS NULL THEN ' ' ELSE UPPER(CARGO_EVALUADO) END)  LIKE UPPER( '%' || :CARGO_EVALUADO || '%')  AND (CASE WHEN NOMBRE_CARGO_EVALUADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CARGO_EVALUADO) END)  LIKE UPPER( '%' || :NOMBRE_CARGO_EVALUADO || '%')  AND (CASE WHEN ESCALAFON_EVALUADOR IS NULL THEN ' ' ELSE UPPER(ESCALAFON_EVALUADOR) END)  LIKE UPPER( '%' || :ESCALAFON_EVALUADOR || '%')  AND (CASE WHEN NOMBRE_ESCALAFON_EVALUADOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESCALAFON_EVALUADOR) END)  LIKE UPPER( '%' || :NOMBRE_ESCALAFON_EVALUADOR || '%')  AND (CASE WHEN ESCALAFON_EVALUADO IS NULL THEN ' ' ELSE UPPER(ESCALAFON_EVALUADO) END)  LIKE UPPER( '%' || :ESCALAFON_EVALUADO || '%')  AND (CASE WHEN NOMBRE_ESCALAFON_EVALUADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESCALAFON_EVALUADO) END)  LIKE UPPER( '%' || :NOMBRE_ESCALAFON_EVALUADO || '%')  AND (CASE WHEN CLASE_EVALUACION IS NULL THEN ' ' ELSE UPPER(CLASE_EVALUACION) END)  LIKE UPPER( '%' || :CLASE_EVALUACION || '%')  AND (CASE WHEN EVALUACION IS NULL THEN ' ' ELSE UPPER(EVALUACION) END)  LIKE UPPER( '%' || :EVALUACION || '%')  AND (CASE WHEN TIPO_EVALUACION IS NULL THEN ' ' ELSE UPPER(TIPO_EVALUACION) END)  LIKE UPPER( '%' || :TIPO_EVALUACION || '%')  AND (CASE WHEN CODIGO_EMPLEADO_EVALUADOR IS NULL THEN ' ' ELSE UPPER(CODIGO_EMPLEADO_EVALUADOR) END)  LIKE UPPER( '%' || :CODIGO_EMPLEADO_EVALUADOR || '%')  AND (CASE WHEN CEDULA_EVALUADO IS NULL THEN ' ' ELSE UPPER(CEDULA_EVALUADO) END)  LIKE UPPER( '%' || :CEDULA_EVALUADO || '%')  AND (CASE WHEN SUCURSAL_EVALUADO IS NULL THEN ' ' ELSE UPPER(SUCURSAL_EVALUADO) END)  LIKE UPPER( '%' || :SUCURSAL_EVALUADO || '%')  AND (CASE WHEN CEDULA_EVALUADOR IS NULL THEN ' ' ELSE UPPER(CEDULA_EVALUADOR) END)  LIKE UPPER( '%' || :CEDULA_EVALUADOR || '%')  AND (CASE WHEN SUCURSAL_EVALUADOR IS NULL THEN ' ' ELSE UPPER(SUCURSAL_EVALUADOR) END)  LIKE UPPER( '%' || :SUCURSAL_EVALUADOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_EVALUADOR":"$NOMBRE_EVALUADOR","NOMBRE_EVALUADO":"$NOMBRE_EVALUADO","COMPANIA":"$COMPANIA","GRUPO_APLICAR":"$GRUPO_APLICAR(type:integer)","DESCRIPCION":"$DESCRIPCION","CARGO_EVALUADOR":"$CARGO_EVALUADOR","NOMBRE_CARGO_EVALUADOR":"$NOMBRE_CARGO_EVALUADOR","CARGO_EVALUADO":"$CARGO_EVALUADO","NOMBRE_CARGO_EVALUADO":"$NOMBRE_CARGO_EVALUADO","ESCALAFON_EVALUADOR":"$ESCALAFON_EVALUADOR","NOMBRE_ESCALAFON_EVALUADOR":"$NOMBRE_ESCALAFON_EVALUADOR","ESCALAFON_EVALUADO":"$ESCALAFON_EVALUADO","NOMBRE_ESCALAFON_EVALUADO":"$NOMBRE_ESCALAFON_EVALUADO","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","EVALUACION":"$EVALUACION","TIPO_EVALUACION":"$TIPO_EVALUACION","CODIGO_EMPLEADO_EVALUADO":"$CODIGO_EMPLEADO_EVALUADO","CODIGO_EMPLEADO_EVALUADOR":"$CODIGO_EMPLEADO_EVALUADOR","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR"}]}}		</result>
