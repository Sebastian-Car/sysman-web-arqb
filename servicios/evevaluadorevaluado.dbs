	<query id="deleteEvevaluadorevaluado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_EVALUADOR_EVALUADO WHERE EV_EVALUADOR_EVALUADO.COMPANIA= :KEY_COMPANIA AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADOR= :KEY_CARGO_EVALUADOR AND EV_EVALUADOR_EVALUADO.CARGO_EVALUADO= :KEY_CARGO_EVALUADO AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADOR= :KEY_ESCALAFON_EVALUADOR AND EV_EVALUADOR_EVALUADO.ESCALAFON_EVALUADO= :KEY_ESCALAFON_EVALUADO AND EV_EVALUADOR_EVALUADO.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_EVALUADOR_EVALUADO.TIPO_EVALUACION= :KEY_TIPO_EVALUACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

