			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CLASE" query-param="KEY_CLASE"/>
			<with-param name="KEY_PROBLEMA" query-param="KEY_PROBLEMA"/>

		</call-query>
	</resource>
	<query id="insertSpusuarioproblemaAgregaProblemaUsuario" keyColumns="COMPANIA,ANO,PERIODO,CICLO,CODIGORUTA,CLASE,PROBLEMA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_USUARIO_PROBLEMA (CLASE, LECTURA, PROBLEMA, OBSERVACION, COMPANIA, CODIGORUTA, CICLO, ANO, PERIODO, DATE_CREATED, CREATED_BY) VALUES (:CLASE, :LECTURA, :PROBLEMA, :OBSERVACION, :COMPANIA, :CODIGORUTA, :CICLO, :ANO, :PERIODO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_CLASE":"$CLASE","KEY_PROBLEMA":"$PROBLEMA"}]}}		</result>
		<param name="CLASE" sqlType="STRING"/>
		<param defaultValue="0" name="LECTURA" sqlType="STRING"/>
		<param name="PROBLEMA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spusuarioproblema/agregaproblemausuario">
		<call-query href="insertSpusuarioproblemaAgregaProblemaUsuario">
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="LECTURA" query-param="LECTURA"/>
			<with-param name="PROBLEMA" query-param="PROBLEMA"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="insertSpusuarioproblema" keyColumns="COMPANIA,ANO,PERIODO,CICLO,CODIGORUTA,CLASE,PROBLEMA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_USUARIO_PROBLEMA (COMPANIA, ANO, PERIODO, CICLO, CODIGORUTA, PROBLEMA, CLASE, LECTURA, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ANO, :PERIODO, :CICLO, :CODIGORUTA, :PROBLEMA, :CLASE, :LECTURA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_CLASE":"$CLASE","KEY_PROBLEMA":"$PROBLEMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PROBLEMA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param defaultValue="0" name="LECTURA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spusuarioproblema">
