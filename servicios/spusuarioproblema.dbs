	<query id="getSpusuarioproblemaUsuarioCoreccionProblemaGQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.SOLUCION  FROM SP_USUARIO_PROBLEMA LEFT JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO WHERE SP_USUARIO_PROBLEMA.COMPANIA = :COMPANIA AND SP_USUARIO_PROBLEMA.ANO = :ANO AND SP_USUARIO_PROBLEMA.PERIODO = :PERIODO AND SP_USUARIO_PROBLEMA.CICLO = :CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = :CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","NOMBRE":"$NOMBRE","SOLUCION":"$SOLUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarioproblema/usuariocoreccionproblemag">
		<call-query href="getSpusuarioproblemaUsuarioCoreccionProblemaGQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpusuarioproblemaPagUsuarioCorreccionProblemaGQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.SOLUCION  FROM SP_USUARIO_PROBLEMA LEFT JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO WHERE SP_USUARIO_PROBLEMA.COMPANIA = :COMPANIA AND SP_USUARIO_PROBLEMA.ANO = :ANO AND SP_USUARIO_PROBLEMA.PERIODO = :PERIODO AND SP_USUARIO_PROBLEMA.CICLO = :CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = :CODIGORUTA AND SP_USUARIO_PROBLEMA.CLASE = :CLASE) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER(:CICLO || '%')  AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN PROBLEMA IS NULL THEN ' ' ELSE UPPER(PROBLEMA) END)  LIKE UPPER(:PROBLEMA || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SOLUCION IS NULL THEN ' ' ELSE UPPER(SOLUCION) END)  LIKE UPPER( '%' || :SOLUCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","NOMBRE":"$NOMBRE","SOLUCION":"$SOLUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="PROBLEMA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SOLUCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarioproblema/usuariocorreccionproblemag/pag">
		<call-query href="getSpusuarioproblemaPagUsuarioCorreccionProblemaGQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
