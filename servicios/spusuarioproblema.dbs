		<sql>SELECT  SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.OBSERVACION, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.SOLUCION  FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA WHERE SP_USUARIO_PROBLEMA.COMPANIA = :COMPANIA AND SP_USUARIO_PROBLEMA.ANO = :ANO AND SP_USUARIO_PROBLEMA.PERIODO = :PERIODO AND SP_USUARIO_PROBLEMA.CICLO = :CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = :CODIGORUTA ORDER BY SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO DESC, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.PROBLEMA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","OBSERVACION":"$OBSERVACION","NOMBRE":"$NOMBRE","SOLUCION":"$SOLUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarioproblema/prolemaspqrusuarioparamet">
		<call-query href="getSpusuarioproblemaProlemaspqrusuarioparametQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="updateSpusuarioproblemaProblemaUsuario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO_PROBLEMA SET PROBLEMA=:PROBLEMA, OBSERVACION=:OBSERVACION, LECTURA=:LECTURA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO_PROBLEMA.COMPANIA= :KEY_COMPANIA AND SP_USUARIO_PROBLEMA.ANO= :KEY_ANO AND SP_USUARIO_PROBLEMA.PERIODO= :KEY_PERIODO AND SP_USUARIO_PROBLEMA.CICLO= :KEY_CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA= :KEY_CODIGORUTA AND SP_USUARIO_PROBLEMA.CLASE= :KEY_CLASE AND SP_USUARIO_PROBLEMA.PROBLEMA= :KEY_PROBLEMA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PROBLEMA" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="LECTURA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>
		<param name="KEY_PROBLEMA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarioproblema/problemausuario">
		<call-query href="updateSpusuarioproblemaProblemaUsuario">
			<with-param name="PROBLEMA" query-param="PROBLEMA"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="LECTURA" query-param="LECTURA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_CLASE" query-param="KEY_CLASE"/>
			<with-param name="KEY_PROBLEMA" query-param="KEY_PROBLEMA"/>

		</call-query>
	</resource>
	<query id="deleteSpusuarioproblemaProblemaUsuario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE SP_USUARIO_PROBLEMA WHERE COMPANIA = :KEY_COMPANIA AND CICLO      =:KEY_CICLO AND CODIGORUTA = :KEY_CODIGORUTA AND PERIODO    =:KEY_PERIODO AND ANO        = :KEY_ANO AND CLASE      = :KEY_CLASE AND PROBLEMA   = :KEY_PROBLEMA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CLASE" sqlType="STRING"/>
		<param name="KEY_PROBLEMA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spusuarioproblema/problemausuario">
		<call-query href="deleteSpusuarioproblemaProblemaUsuario">
