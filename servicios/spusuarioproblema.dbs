<data name="spusuarioproblema" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpusuarioproblemaInnerSpproblemaPorClaseCodigoAnoPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.LECTURA, SP_USUARIO_PROBLEMA.OBSERVACION, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_PROBLEMA.NOMBRE FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO WHERE SP_USUARIO_PROBLEMA.COMPANIA =:COMPANIA AND CONCAT(SP_USUARIO_PROBLEMA.ANO,SP_USUARIO_PROBLEMA.PERIODO) = CONCAT(:ANOSIGUIENTE,:PERIODOSIGUIENTE) AND SP_USUARIO_PROBLEMA.CICLO =:CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA =:CODIGORUTA AND SP_USUARIO_PROBLEMA.CLASE =:CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","LECTURA":"$LECTURA","OBSERVACION":"$OBSERVACION","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOSIGUIENTE" sqlType="STRING"/>
		<param name="PERIODOSIGUIENTE" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarioproblema/innerspproblemaporclasecodigoanoperiodo">
		<call-query href="getSpusuarioproblemaInnerSpproblemaPorClaseCodigoAnoPeriodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOSIGUIENTE" query-param="ANOSIGUIENTE"/>
			<with-param name="PERIODOSIGUIENTE" query-param="PERIODOSIGUIENTE"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="getSpusuarioproblemaSolucionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.SOLUCION  FROM SP_USUARIO_PROBLEMA LEFT JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO WHERE SP_USUARIO_PROBLEMA.COMPANIA = :COMPANIA AND SP_USUARIO_PROBLEMA.ANO = :ANO AND SP_USUARIO_PROBLEMA.PERIODO = :PERIODO AND SP_USUARIO_PROBLEMA.CICLO = :CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = :CODIGORUTA AND SP_USUARIO_PROBLEMA.CLASE = :CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","NOMBRE":"$NOMBRE","SOLUCION":"$SOLUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarioproblema/solucion">
		<call-query href="getSpusuarioproblemaSolucionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="getSpusuarioproblemaAforoPeriodoAnteriorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.CODIGO  FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO INNER JOIN SP_USUARIO ON SP_USUARIO_PROBLEMA.COMPANIA = SP_USUARIO.COMPANIA AND SP_USUARIO_PROBLEMA.CICLO = SP_USUARIO.CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CICLO = :CICLO AND SP_USUARIO.CODIGORUTA = :CODIGORUTA AND SP_USUARIO_PROBLEMA.PERIODO = :PERIODO AND SP_USUARIO_PROBLEMA.ANO = :ANO AND SP_USUARIO_PROBLEMA.CLASE = :CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","NOMBRE":"$NOMBRE","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarioproblema/aforoperiodoanterior">
		<call-query href="getSpusuarioproblemaAforoPeriodoAnteriorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="updateSpusuarioproblemaCambiarProblema" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO_PROBLEMA    SET PROBLEMA      = :PROBLEMA,        DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),         MODIFIED_BY   = :MODIFIED_BY  WHERE COMPANIA   = :COMPANIA    AND ANO        = :ANO    AND PERIODO    = :PERIODO    AND CICLO      = :CICLO    AND CODIGORUTA = :CODIGORUTA    AND CLASE      = :CLASE    AND PROBLEMA   = :PROBLEMA_ANT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PROBLEMA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="PROBLEMA_ANT" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarioproblema/cambiarproblema">
		<call-query href="updateSpusuarioproblemaCambiarProblema">
			<with-param name="PROBLEMA" query-param="PROBLEMA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="PROBLEMA_ANT" query-param="PROBLEMA_ANT"/>

		</call-query>
	</resource>
	<query id="getSpusuarioproblemaProlemaspqrusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.OBSERVACION, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.SOLUCION  FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA WHERE SP_USUARIO_PROBLEMA.COMPANIA = :COMPANIA AND SP_USUARIO_PROBLEMA.CICLO = :CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = :CODIGORUTA ORDER BY SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO DESC, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.PROBLEMA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","OBSERVACION":"$OBSERVACION","NOMBRE":"$NOMBRE","SOLUCION":"$SOLUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarioproblema/prolemaspqrusuario">
		<call-query href="getSpusuarioproblemaProlemaspqrusuarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
