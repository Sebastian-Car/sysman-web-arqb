	</resource>
	<query id="getFuentesfutNumCodigoNombrePorNaturalezaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FUENTESFUT.CODIGOFU_FUT, FUENTESFUT.NOMBREFU_FUT, FUENTESFUT.NATURALEZA_FUT, FUENTESFUT.DESTINO  FROM FUENTESFUT WHERE FUENTESFUT.COMPANIA = :COMPANIA AND FUENTESFUT.NATURALEZA_FUT = :NATURALEZA AND FUENTESFUT.DESTINO = :DESTINO AND FUENTESFUT.ANO = :ANO ORDER BY CODIGOFU_FUT) WHERE (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END)  LIKE UPPER(:CODIGOFU_FUT || '%')  AND (CASE WHEN NOMBREFU_FUT IS NULL THEN ' ' ELSE UPPER(NOMBREFU_FUT) END)  LIKE UPPER( '%' || :NOMBREFU_FUT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBREFU_FUT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfut/codigonombrepornaturaleza/num">
		<call-query href="getFuentesfutNumCodigoNombrePorNaturalezaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBREFU_FUT" query-param="NOMBREFU_FUT"/>

		</call-query>
	</resource>
	<query id="insertFuentesfut" keyColumns="COMPANIA,ANO,CODIGOFU_FUT,DESTINO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FUENTESFUT (COMPANIA, ANO, CODIGOFU_FUT, NOMBREFU_FUT, DESTINO, NATURALEZA_FUT, COVID, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGOFU_FUT, :NOMBREFU_FUT, :DESTINO, :NATURALEZA_FUT, :COVID, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGOFU_FUT":"$CODIGOFU_FUT(type:integer)","KEY_DESTINO":"$DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBREFU_FUT" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="NATURALEZA_FUT" sqlType="STRING"/>
		<param defaultValue="0" name="COVID" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="fuentesfut">
		<call-query href="insertFuentesfut">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBREFU_FUT" query-param="NOMBREFU_FUT"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="NATURALEZA_FUT" query-param="NATURALEZA_FUT"/>
			<with-param name="COVID" query-param="COVID"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteFuentesfut" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FUENTESFUT WHERE FUENTESFUT.COMPANIA= :KEY_COMPANIA AND FUENTESFUT.ANO= :KEY_ANO AND FUENTESFUT.CODIGOFU_FUT= :KEY_CODIGOFU_FUT AND FUENTESFUT.DESTINO= :KEY_DESTINO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGOFU_FUT" sqlType="INTEGER"/>
		<param name="KEY_DESTINO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="fuentesfut">
		<call-query href="deleteFuentesfut">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGOFU_FUT" query-param="KEY_CODIGOFU_FUT"/>
			<with-param name="KEY_DESTINO" query-param="KEY_DESTINO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, CODIGOFU_FUT, NOMBREFU_FUT, DESTINO, CASE DESTINO WHEN 'F' THEN 'Funcionamiento' WHEN 'I' THEN 'Inversión' WHEN 'S' THEN 'Servicio de la Deuda' WHEN 'L' THEN 'Libre Destinación' ELSE ' ' END DESTINOAUX, NATURALEZA_FUT, CASE WHEN NATURALEZA_FUT IN ('D') THEN 'Gastos' ELSE 'Inversión' END NATURALEZA_FUTAUX ,(CASE COVID WHEN 0 THEN 'false' ELSE 'true' END) COVID FROM FUENTESFUT WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END) LIKE UPPER(CONCAT(:CODIGOFU_FUT, '%')) AND (CASE WHEN NOMBREFU_FUT IS NULL THEN ' ' ELSE UPPER(NOMBREFU_FUT) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFU_FUT), '%')) AND (CASE WHEN DESTINOAUX IS NULL THEN ' ' ELSE UPPER(DESTINOAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:DESTINOAUX), '%')) AND (CASE WHEN NATURALEZA_FUTAUX IS NULL THEN ' ' ELSE UPPER(NATURALEZA_FUTAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NATURALEZA_FUTAUX), '%')) AND (CASE WHEN COVID IS NULL THEN ' ' ELSE UPPER(COVID) END) LIKE UPPER(CONCAT(:COVID, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGOFU_FUT":"$CODIGOFU_FUT(type:integer)","NOMBREFU_FUT":"$NOMBREFU_FUT","DESTINO":"$DESTINO","DESTINOAUX":"$DESTINOAUX","NATURALEZA_FUT":"$NATURALEZA_FUT","NATURALEZA_FUTAUX":"$NATURALEZA_FUTAUX","COVID":"$COVID(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBREFU_FUT" sqlType="STRING"/>
		<param name="DESTINOAUX" sqlType="STRING"/>
		<param name="NATURALEZA_FUTAUX" sqlType="STRING"/>
		<param name="COVID" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuentesfut">
		<call-query href="getFuentesfutPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBREFU_FUT" query-param="NOMBREFU_FUT"/>
			<with-param name="DESTINOAUX" query-param="DESTINOAUX"/>
			<with-param name="NATURALEZA_FUTAUX" query-param="NATURALEZA_FUTAUX"/>
			<with-param name="COVID" query-param="COVID"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO, CODIGOFU_FUT, NOMBREFU_FUT, DESTINO, CASE DESTINO WHEN 'F' THEN 'Funcionamiento' WHEN 'I' THEN 'Inversión' WHEN 'S' THEN 'Servicio de la Deuda' WHEN 'L' THEN 'Libre Destinación' ELSE ' ' END DESTINOAUX, NATURALEZA_FUT, CASE WHEN NATURALEZA_FUT IN ('D') THEN 'Gastos' ELSE 'Inversión' END NATURALEZA_FUTAUX  FROM FUENTESFUT WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END)  LIKE UPPER(:CODIGOFU_FUT || '%')  AND (CASE WHEN NOMBREFU_FUT IS NULL THEN ' ' ELSE UPPER(NOMBREFU_FUT) END)  LIKE UPPER( '%' || :NOMBREFU_FUT || '%')  AND (CASE WHEN DESTINOAUX IS NULL THEN ' ' ELSE UPPER(DESTINOAUX) END)  LIKE UPPER( '%' || :DESTINOAUX || '%')  AND (CASE WHEN NATURALEZA_FUTAUX IS NULL THEN ' ' ELSE UPPER(NATURALEZA_FUTAUX) END)  LIKE UPPER( '%' || :NATURALEZA_FUTAUX || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBREFU_FUT" sqlType="STRING"/>
		<param name="DESTINOAUX" sqlType="STRING"/>
		<param name="NATURALEZA_FUTAUX" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfut/numero">
		<call-query href="getFuentesfutNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBREFU_FUT" query-param="NOMBREFU_FUT"/>
			<with-param name="DESTINOAUX" query-param="DESTINOAUX"/>
			<with-param name="NATURALEZA_FUTAUX" query-param="NATURALEZA_FUTAUX"/>

		</call-query>
	</resource>
	<query id="updateFuentesfut" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FUENTESFUT SET NOMBREFU_FUT=:NOMBREFU_FUT, DESTINO=:DESTINO, NATURALEZA_FUT=:NATURALEZA_FUT, COVID=:COVID, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FUENTESFUT.COMPANIA= :KEY_COMPANIA AND FUENTESFUT.ANO= :KEY_ANO AND FUENTESFUT.CODIGOFU_FUT= :KEY_CODIGOFU_FUT AND FUENTESFUT.DESTINO= :KEY_DESTINO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBREFU_FUT" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
