<data name="fuentesfut" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFuentesfutPagTodosCodigos,nombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGOFU_FUT, NOMBREFU_FUT NOMBRE, NATURALEZA_FUT, DESTINO  FROM FUENTESFUT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NATURALEZA_FUT = :NATURALEZA AND DESTINO = :DESTINO) WHERE (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END)  LIKE UPPER(:CODIGOFU_FUT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOFU_FUT":"$CODIGOFU_FUT(type:integer)","NOMBRE":"$NOMBRE","NATURALEZA_FUT":"$NATURALEZA_FUT","DESTINO":"$DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuentesfut/todoscodigos,nombre/pag">
		<call-query href="getFuentesfutPagTodosCodigos,nombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutNumTodosCodigos,nombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGOFU_FUT, NOMBREFU_FUT NOMBRE, NATURALEZA_FUT, DESTINO  FROM FUENTESFUT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NATURALEZA_FUT = :NATURALEZA AND DESTINO = :DESTINO) WHERE (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END)  LIKE UPPER(:CODIGOFU_FUT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfut/todoscodigos,nombre/num">
		<call-query href="getFuentesfutNumTodosCodigos,nombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getFuentesfutPagCodigos,nombrePorAnioDestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGOFU_FUT, NOMBREFU_FUT NOMBRE, NATURALEZA_FUT, DESTINO  FROM FUENTESFUT WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND DESTINO = :DESTINO ORDER BY CODIGOFU_FUT) WHERE (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END)  LIKE UPPER(:CODIGOFU_FUT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOFU_FUT":"$CODIGOFU_FUT(type:integer)","NOMBRE":"$NOMBRE","NATURALEZA_FUT":"$NATURALEZA_FUT","DESTINO":"$DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuentesfut/codigos,nombreporaniodestino/pag">
		<call-query href="getFuentesfutPagCodigos,nombrePorAnioDestinoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutNumCodigos,nombrePorAnioDestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGOFU_FUT, NOMBREFU_FUT NOMBRE, NATURALEZA_FUT, DESTINO  FROM FUENTESFUT WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND DESTINO = :DESTINO ORDER BY CODIGOFU_FUT) WHERE (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END)  LIKE UPPER(:CODIGOFU_FUT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfut/codigos,nombreporaniodestino/num">
		<call-query href="getFuentesfutNumCodigos,nombrePorAnioDestinoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getFuentesfutListaConcatenadaPorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT FUENTESFUT.CODIGOFU_FUT, CONCAT(CODIGOFU_FUT,CONCAT(' - ',NOMBREFU_FUT) ) NOMBRE, FUENTESFUT.NATURALEZA_FUT, FUENTESFUT.DESTINO FROM FUENTESFUT WHERE COMPANIA =:COMPANIA AND ANO =:ANO ORDER BY FUENTESFUT.CODIGOFU_FUT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOFU_FUT":"$CODIGOFU_FUT(type:integer)","NOMBRE":"$NOMBRE","NATURALEZA_FUT":"$NATURALEZA_FUT","DESTINO":"$DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfut/listaconcatenadaporanio">
		<call-query href="getFuentesfutListaConcatenadaPorAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutPagCodigoNombrePorNaturalezaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FUENTESFUT.CODIGOFU_FUT, FUENTESFUT.NOMBREFU_FUT, FUENTESFUT.NATURALEZA_FUT, FUENTESFUT.DESTINO  FROM FUENTESFUT WHERE FUENTESFUT.COMPANIA = :COMPANIA AND FUENTESFUT.NATURALEZA_FUT = :NATURALEZA AND FUENTESFUT.DESTINO = :DESTINO AND FUENTESFUT.ANO = :ANO ORDER BY CODIGOFU_FUT) WHERE (CASE WHEN CODIGOFU_FUT IS NULL THEN ' ' ELSE UPPER(CODIGOFU_FUT) END)  LIKE UPPER(:CODIGOFU_FUT || '%')  AND (CASE WHEN NOMBREFU_FUT IS NULL THEN ' ' ELSE UPPER(NOMBREFU_FUT) END)  LIKE UPPER( '%' || :NOMBREFU_FUT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOFU_FUT":"$CODIGOFU_FUT(type:integer)","NOMBREFU_FUT":"$NOMBREFU_FUT","NATURALEZA_FUT":"$NATURALEZA_FUT","DESTINO":"$DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="DESTINO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOFU_FUT" sqlType="STRING"/>
		<param name="NOMBREFU_FUT" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuentesfut/codigonombrepornaturaleza/pag">
		<call-query href="getFuentesfutPagCodigoNombrePorNaturalezaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOFU_FUT" query-param="CODIGOFU_FUT"/>
			<with-param name="NOMBREFU_FUT" query-param="NOMBREFU_FUT"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

