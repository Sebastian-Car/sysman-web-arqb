<data name="usuariosd" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getUsuariosdUsuarioPorGrupoQuery"  useConfig="sysmanirisst">
		<sql>SELECT  USUARIO  FROM USUARIO_D WHERE GRUPO= :GRUPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"USUARIO":"$USUARIO"}]}}		</result>
		<param name="GRUPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuariosd/usuarioporgrupo">
		<call-query href="getUsuariosdUsuarioPorGrupoQuery">
			<with-param name="GRUPO" query-param="GRUPO"/>

		</call-query>
	</resource>
	<query id="getUsuariosdNivelUsuarioPorAplicacionQuery"  useConfig="sysmanirisst">
		<sql>SELECT  NIVEL_USUARIO  FROM USUARIO_D WHERE APLICACION = :APLICACION AND USUARIO = :USUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIVEL_USUARIO":"$NIVEL_USUARIO(type:integer)"}]}}		</result>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuariosd/nivelusuarioporaplicacion">
		<call-query href="getUsuariosdNivelUsuarioPorAplicacionQuery">
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="getUsuariosdValidargrupotesoreriaQuery"  useConfig="sysmanirisst">
		<sql>SELECT P.VALOR VALOR FROM USUARIO_D U INNER JOIN PARAMETRO P ON U.GRUPO=P.VALOR WHERE P.NOMBRE='NOMBRE GRUPO TESORERIA' AND U.USUARIO=:USUARIO AND P.MODULO=:MODULO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuariosd/validargrupotesoreria">
		<call-query href="getUsuariosdValidargrupotesoreriaQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="MODULO" query-param="MODULO"/>

		</call-query>
	</resource>
	<query id="getUsuariosdGruposporusuarioQuery"  useConfig="sysmanirisst">
		<sql>SELECT GRUPO FROM USUARIO_D WHERE USUARIO=:USUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"GRUPO":"$GRUPO"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuariosd/gruposporusuario">
		<call-query href="getUsuariosdGruposporusuarioQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="insertUsuariosd" keyColumns="USUARIO,APLICACION" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO USUARIO_D (USUARIO, GRUPO, NIVEL_USUARIO, APLICACION, MOD_COMPROBANTE, DATE_CREATED, CREATED_BY) VALUES (:USUARIO, :GRUPO, :NIVEL_USUARIO, :APLICACION, :MOD_COMPROBANTE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_USUARIO":"$USUARIO","KEY_APLICACION":"$APLICACION(type:integer)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param defaultValue="" name="NIVEL_USUARIO" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param defaultValue="0" name="MOD_COMPROBANTE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="usuariosd">
		<call-query href="insertUsuariosd">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="NIVEL_USUARIO" query-param="NIVEL_USUARIO"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="MOD_COMPROBANTE" query-param="MOD_COMPROBANTE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteUsuariosd" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM USUARIO_D WHERE USUARIO_D.USUARIO= :KEY_USUARIO AND USUARIO_D.APLICACION= :KEY_APLICACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_USUARIO" sqlType="STRING"/>
		<param name="KEY_APLICACION" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="usuariosd">
		<call-query href="deleteUsuariosd">
			<with-param name="KEY_USUARIO" query-param="KEY_USUARIO"/>
			<with-param name="KEY_APLICACION" query-param="KEY_APLICACION"/>

		</call-query>
	</resource>
	<query id="getUsuariosdPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT  USUARIO, GRUPO, NIVEL_USUARIO, D.APLICACION, A.NOMBRE,(CASE MOD_COMPROBANTE WHEN 0 THEN 'false' ELSE 'true' END) MOD_COMPROBANTE FROM USUARIO_D D INNER JOIN APLICACIONES A ON (D.APLICACION=A.APLICACION) WHERE USUARIO = :USUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"USUARIO":"$USUARIO","GRUPO":"$GRUPO","NIVEL_USUARIO":"$NIVEL_USUARIO(type:integer)","APLICACION":"$APLICACION(type:integer)","NOMBRE":"$NOMBRE","MOD_COMPROBANTE":"$MOD_COMPROBANTE(type:boolean)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuariosd">
		<call-query href="getUsuariosdPaginaQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="updateUsuariosd" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE USUARIO_D SET USUARIO=:USUARIO, GRUPO=:GRUPO, NIVEL_USUARIO=:NIVEL_USUARIO, APLICACION=:APLICACION, MOD_COMPROBANTE=:MOD_COMPROBANTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE USUARIO_D.USUARIO= :KEY_USUARIO AND USUARIO_D.APLICACION= :KEY_APLICACION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="USUARIO" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="NIVEL_USUARIO" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="MOD_COMPROBANTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_USUARIO" sqlType="STRING"/>
		<param name="KEY_APLICACION" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="usuariosd">
		<call-query href="updateUsuariosd">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="NIVEL_USUARIO" query-param="NIVEL_USUARIO"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="MOD_COMPROBANTE" query-param="MOD_COMPROBANTE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_USUARIO" query-param="KEY_USUARIO"/>
			<with-param name="KEY_APLICACION" query-param="KEY_APLICACION"/>

		</call-query>
	</resource>
	<query id="getUsuariosdValidargruponominaQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(*) AS EXISTE FROM USUARIO_D U WHERE U.GRUPO = 'ADMIN_NOMINA' AND U.USUARIO=:USUARIO AND U.APLICACION = 6</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="usuariosd/validargruponomina">
		<call-query href="getUsuariosdValidargruponominaQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>

</data>