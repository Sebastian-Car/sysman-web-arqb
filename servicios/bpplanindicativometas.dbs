	<query id="getBpplanindicativometasPagTodosPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_METAS.ID_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, BP_PLAN_INDICATIVO_METAS.DESCRIPCION, BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN  FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO_METAS ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO_METAS.VIGENCIA_META WHERE BP_NIVEL_PLAN_IND.COMPANIA = :COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = :ANO AND BP_NIVEL_PLAN_IND.META_PRODUC IN ('-1') AND LENGTH(BP_PLAN_INDICATIVO_METAS.ID_PLAN) IN BP_NIVEL_PLAN_IND.DIGITOS) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN VIGENCIA_META IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META) END)  LIKE UPPER(:VIGENCIA_META || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN":"$ID_PLAN","VIGENCIA_META":"$VIGENCIA_META(type:integer)","DESCRIPCION":"$DESCRIPCION","VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
