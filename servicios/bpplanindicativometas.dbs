	<query id="deleteBpplanindicativometas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_PLAN_INDICATIVO_METAS WHERE BP_PLAN_INDICATIVO_METAS.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN= :KEY_ID_PLAN AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN= :KEY_VIGENCIA_PLAN AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_META= :KEY_VIGENCIA_META</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_PLAN" sqlType="INTEGER"/>
		<param name="KEY_VIGENCIA_META" sqlType="INTEGER"/>

