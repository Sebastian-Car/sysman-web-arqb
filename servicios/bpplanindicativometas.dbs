	<query id="updateBpplanindicativometas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PLAN_INDICATIVO_METAS SET COMPANIA=:COMPANIA, ID_PLAN=:ID_PLAN, VIGENCIA_PLAN=:VIGENCIA_PLAN, VIGENCIA_META=:VIGENCIA_META, PONDERACION_META=:PONDERACION_META, META_BRUTA=:META_BRUTA, CANTIDAD_PROGRAMADA=:CANTIDAD_PROGRAMADA, CANTIDAD_EJECUTADA=:CANTIDAD_EJECUTADA, VALOR_PROGRAMADO_META=:VALOR_PROGRAMADO_META, VALOR_PROGRAMADO_META_OTROS=:VALOR_PROGRAMADO_META_OTROS, VALOR_EJECUTADO_META=:VALOR_EJECUTADO_META, CODIGO_FUT=:CODIGO_FUT, DESCRIPCION=:DESCRIPCION, DESCRIPCION2=:DESCRIPCION2, DEPENDENCIA=:DEPENDENCIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_PLAN_INDICATIVO_METAS.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN= :KEY_ID_PLAN AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN= :KEY_VIGENCIA_PLAN AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_META= :KEY_VIGENCIA_META</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="PONDERACION_META" sqlType="STRING"/>
		<param name="META_BRUTA" sqlType="STRING"/>
