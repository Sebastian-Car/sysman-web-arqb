	<resource method="DELETE" path="bpplanindicativometas">
		<call-query href="deleteBpplanindicativometas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_VIGENCIA_PLAN" query-param="KEY_VIGENCIA_PLAN"/>
			<with-param name="KEY_VIGENCIA_META" query-param="KEY_VIGENCIA_META"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_METAS.COMPANIA, BP_PLAN_INDICATIVO_METAS.ID_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, CASE WHEN BP_PLAN_INDICATIVO_METAS.PONDERACION_META &lt; 1 THEN TO_CHAR(BP_PLAN_INDICATIVO_METAS.PONDERACION_META,'FM0.99') ELSE TRIM(TO_CHAR(BP_PLAN_INDICATIVO_METAS.PONDERACION_META,'999999999999999999.99')) END PONDERACION_META, BP_PLAN_INDICATIVO_METAS.META_BRUTA, CASE WHEN BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA &lt; 1 THEN TO_CHAR(BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA,'FM0.99') ELSE TRIM(TO_CHAR(BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA,'999999999999999999.99')) END CANTIDAD_PROGRAMADA, BP_PLAN_INDICATIVO_METAS.CANTIDAD_EJECUTADA, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META_OTROS, BP_PLAN_INDICATIVO_METAS.VALOR_EJECUTADO_META, BP_PLAN_INDICATIVO_METAS.CODIGO_FUT  FROM BP_PLAN_INDICATIVO_METAS WHERE BP_PLAN_INDICATIVO_METAS.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN = :VIGENCIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN = :CODIGO) WHERE (CASE WHEN VIGENCIA_META IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META) END)  LIKE UPPER(:VIGENCIA_META || '%')  AND (CASE WHEN PONDERACION_META IS NULL THEN ' ' ELSE UPPER(PONDERACION_META) END)  LIKE UPPER(:PONDERACION_META || '%')  AND (CASE WHEN META_BRUTA IS NULL THEN ' ' ELSE UPPER(META_BRUTA) END)  LIKE UPPER(:META_BRUTA || '%')  AND (CASE WHEN CANTIDAD_PROGRAMADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PROGRAMADA) END)  LIKE UPPER(:CANTIDAD_PROGRAMADA || '%')  AND (CASE WHEN CANTIDAD_EJECUTADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJECUTADA) END)  LIKE UPPER(:CANTIDAD_EJECUTADA || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META) END)  LIKE UPPER(:VALOR_PROGRAMADO_META || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META_OTROS IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META_OTROS) END)  LIKE UPPER(:VALOR_PROGRAMADO_META_OTROS || '%')  AND (CASE WHEN VALOR_EJECUTADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_META) END)  LIKE UPPER(:VALOR_EJECUTADO_META || '%')  AND (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER(:CODIGO_FUT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_PLAN":"$ID_PLAN","VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","VIGENCIA_META":"$VIGENCIA_META(type:integer)","PONDERACION_META":"$PONDERACION_META","META_BRUTA":"$META_BRUTA","CANTIDAD_PROGRAMADA":"$CANTIDAD_PROGRAMADA","CANTIDAD_EJECUTADA":"$CANTIDAD_EJECUTADA","VALOR_PROGRAMADO_META":"$VALOR_PROGRAMADO_META","VALOR_PROGRAMADO_META_OTROS":"$VALOR_PROGRAMADO_META_OTROS","VALOR_EJECUTADO_META":"$VALOR_EJECUTADO_META","CODIGO_FUT":"$CODIGO_FUT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="PONDERACION_META" sqlType="STRING"/>
		<param name="META_BRUTA" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADA" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META_OTROS" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativometas">
		<call-query href="getBpplanindicativometasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA_META" query-param="VIGENCIA_META"/>
			<with-param name="PONDERACION_META" query-param="PONDERACION_META"/>
			<with-param name="META_BRUTA" query-param="META_BRUTA"/>
			<with-param name="CANTIDAD_PROGRAMADA" query-param="CANTIDAD_PROGRAMADA"/>
			<with-param name="CANTIDAD_EJECUTADA" query-param="CANTIDAD_EJECUTADA"/>
			<with-param name="VALOR_PROGRAMADO_META" query-param="VALOR_PROGRAMADO_META"/>
			<with-param name="VALOR_PROGRAMADO_META_OTROS" query-param="VALOR_PROGRAMADO_META_OTROS"/>
			<with-param name="VALOR_EJECUTADO_META" query-param="VALOR_EJECUTADO_META"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_METAS.COMPANIA, BP_PLAN_INDICATIVO_METAS.ID_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, CASE WHEN BP_PLAN_INDICATIVO_METAS.PONDERACION_META &lt; 1 THEN TO_CHAR(BP_PLAN_INDICATIVO_METAS.PONDERACION_META,'FM0.99') ELSE TRIM(TO_CHAR(BP_PLAN_INDICATIVO_METAS.PONDERACION_META,'999999999999999999.99')) END PONDERACION_META, BP_PLAN_INDICATIVO_METAS.META_BRUTA, CASE WHEN BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA &lt; 1 THEN TO_CHAR(BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA,'FM0.99') ELSE TRIM(TO_CHAR(BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA,'999999999999999999.99')) END CANTIDAD_PROGRAMADA, BP_PLAN_INDICATIVO_METAS.CANTIDAD_EJECUTADA, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META_OTROS, BP_PLAN_INDICATIVO_METAS.VALOR_EJECUTADO_META, BP_PLAN_INDICATIVO_METAS.CODIGO_FUT  FROM BP_PLAN_INDICATIVO_METAS WHERE BP_PLAN_INDICATIVO_METAS.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN = :VIGENCIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN = :CODIGO) WHERE (CASE WHEN VIGENCIA_META IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META) END)  LIKE UPPER(:VIGENCIA_META || '%')  AND (CASE WHEN PONDERACION_META IS NULL THEN ' ' ELSE UPPER(PONDERACION_META) END)  LIKE UPPER(:PONDERACION_META || '%')  AND (CASE WHEN META_BRUTA IS NULL THEN ' ' ELSE UPPER(META_BRUTA) END)  LIKE UPPER(:META_BRUTA || '%')  AND (CASE WHEN CANTIDAD_PROGRAMADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PROGRAMADA) END)  LIKE UPPER(:CANTIDAD_PROGRAMADA || '%')  AND (CASE WHEN CANTIDAD_EJECUTADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJECUTADA) END)  LIKE UPPER(:CANTIDAD_EJECUTADA || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META) END)  LIKE UPPER(:VALOR_PROGRAMADO_META || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META_OTROS IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META_OTROS) END)  LIKE UPPER(:VALOR_PROGRAMADO_META_OTROS || '%')  AND (CASE WHEN VALOR_EJECUTADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_META) END)  LIKE UPPER(:VALOR_EJECUTADO_META || '%')  AND (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER(:CODIGO_FUT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="PONDERACION_META" sqlType="STRING"/>
		<param name="META_BRUTA" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADA" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META_OTROS" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>

	</query>
