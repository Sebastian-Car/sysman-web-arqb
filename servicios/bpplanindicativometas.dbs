		<result outputType="json">{"elementos":{"elemento":[{"PONDERACION_META":"$PONDERACION_META","META_BRUTA":"$META_BRUTA","CANTIDAD_PROGRAMADA":"$CANTIDAD_PROGRAMADA","CANTIDAD_EJECUTADA":"$CANTIDAD_EJECUTADA","VALOR_PROGRAMADO_META":"$VALOR_PROGRAMADO_META","VALOR_PROGRAMADO_META_OTROS":"$VALOR_PROGRAMADO_META_OTROS","VALOR_EJECUTADO_META":"$VALOR_EJECUTADO_META"}]}}		</result>
