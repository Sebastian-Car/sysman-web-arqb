	<query id="getBpplanindicativometasVigenciaMetaPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT BPM.VIGENCIA_META  FROM BP_PLAN_INDICATIVO_METAS BPM, ( SELECT C.CODIGOPROYECTO, C.VIGENCIA FROM BP_TIPOSCOMPONENTES BPC INNER JOIN COMPONENTES C ON C.COMPANIA = BPC.COMPANIA AND C.TIPOCOMPONENTE = BPC.CODIGO WHERE C.COMPANIA = :COMPANIA AND C.CODIGOPROYECTO = :CODIGOPROYECTO) COM WHERE BPM.VIGENCIA_META=COM.VIGENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA_META":"$VIGENCIA_META(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/vigenciametaporcodigo">
		<call-query href="getBpplanindicativometasVigenciaMetaPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasTodosPorCompaniaMetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT BP_PLAN_INDICATIVO_METAS.VIGENCIA_META  FROM BP_PLAN_INDICATIVO INNER JOIN BP_PLAN_INDICATIVO_METAS ON BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN AND BP_PLAN_INDICATIVO.ID = BP_PLAN_INDICATIVO_METAS.ID_PLAN AND BP_PLAN_INDICATIVO.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.TIPO_META_PLAN = '002' AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_META NOT IN 0 ORDER BY BP_PLAN_INDICATIVO_METAS.VIGENCIA_META</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA_META":"$VIGENCIA_META(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/todosporcompaniameta">
		<call-query href="getBpplanindicativometasTodosPorCompaniaMetaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertBpplanindicativometas" keyColumns="COMPANIA,ID_PLAN,VIGENCIA_PLAN,VIGENCIA_META" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_PLAN_INDICATIVO_METAS (COMPANIA, ID_PLAN, VIGENCIA_PLAN, VIGENCIA_META, PONDERACION_META, META_BRUTA, CANTIDAD_PROGRAMADA, CANTIDAD_EJECUTADA, VALOR_PROGRAMADO_META, VALOR_PROGRAMADO_META_OTROS, VALOR_EJECUTADO_META, CODIGO_FUT, DESCRIPCION, DESCRIPCION2, DEPENDENCIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_PLAN, :VIGENCIA_PLAN, :VIGENCIA_META, :PONDERACION_META, :META_BRUTA, :CANTIDAD_PROGRAMADA, :CANTIDAD_EJECUTADA, :VALOR_PROGRAMADO_META, :VALOR_PROGRAMADO_META_OTROS, :VALOR_EJECUTADO_META, :CODIGO_FUT, :DESCRIPCION, :DESCRIPCION2, :DEPENDENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_PLAN":"$ID_PLAN","KEY_VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","KEY_VIGENCIA_META":"$VIGENCIA_META(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_META" sqlType="STRING"/>
		<param defaultValue="0" name="PONDERACION_META" sqlType="STRING"/>
		<param defaultValue="0" name="META_BRUTA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD_PROGRAMADA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD_EJECUTADA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROGRAMADO_META_OTROS" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_FUT" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION2" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
