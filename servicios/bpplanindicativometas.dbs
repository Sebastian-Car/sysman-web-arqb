<data name="bpplanindicativometas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpplanindicativometasPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P, BP_PROYECTO_PLAN_INDICATIVO.DESCRIPCION_META, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P, BP_PROYECTO_PLAN_INDICATIVO.CANTIDAD_PROGRAMADA_P, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P, ORDENDECOMPRA_AUXILIAR.AUXILIAR  FROM BP_PLAN_INDICATIVO_METAS INNER JOIN BP_PROYECTO_PLAN_INDICATIVO ON BP_PLAN_INDICATIVO_METAS.COMPANIA = BP_PROYECTO_PLAN_INDICATIVO.COMPANIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN = BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN = BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_META = BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P INNER JOIN ORDENDECOMPRA_AUXILIAR ON BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = ORDENDECOMPRA_AUXILIAR.COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = ORDENDECOMPRA_AUXILIAR.AUXILIAR WHERE ORDENDECOMPRA_AUXILIAR.COMPANIA = :COMPANIA AND ORDENDECOMPRA_AUXILIAR.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA_AUXILIAR.ORDENDECOMPRA = :NUMERO_ORDEN ORDER BY BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P DESC) WHERE (CASE WHEN ID_PLAN_P IS NULL THEN ' ' ELSE UPPER(ID_PLAN_P) END)  LIKE UPPER( '%' || :ID_PLAN_P || '%')  AND (CASE WHEN DESCRIPCION_META IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_META) END)  LIKE UPPER( '%' || :DESCRIPCION_META || '%')  AND (CASE WHEN VIGENCIA_META_P IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META_P) END)  LIKE UPPER( '%' || :VIGENCIA_META_P || '%')  AND (CASE WHEN CANTIDAD_PROGRAMADA_P IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PROGRAMADA_P) END)  LIKE UPPER(:CANTIDAD_PROGRAMADA_P || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN_P":"$ID_PLAN_P","DESCRIPCION_META":"$DESCRIPCION_META","VIGENCIA_META_P":"$VIGENCIA_META_P(type:integer)","CANTIDAD_PROGRAMADA_P":"$CANTIDAD_PROGRAMADA_P","VIGENCIA_PLAN_P":"$VIGENCIA_PLAN_P(type:integer)","AUXILIAR":"$AUXILIAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>
		<param name="VIGENCIA_META_P" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA_P" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/todosporcompania/pag">
		<call-query href="getBpplanindicativometasPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="ID_PLAN_P" query-param="ID_PLAN_P"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="VIGENCIA_META_P" query-param="VIGENCIA_META_P"/>
			<with-param name="CANTIDAD_PROGRAMADA_P" query-param="CANTIDAD_PROGRAMADA_P"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P, BP_PROYECTO_PLAN_INDICATIVO.DESCRIPCION_META, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P, BP_PROYECTO_PLAN_INDICATIVO.CANTIDAD_PROGRAMADA_P, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P, ORDENDECOMPRA_AUXILIAR.AUXILIAR  FROM BP_PLAN_INDICATIVO_METAS INNER JOIN BP_PROYECTO_PLAN_INDICATIVO ON BP_PLAN_INDICATIVO_METAS.COMPANIA = BP_PROYECTO_PLAN_INDICATIVO.COMPANIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN = BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN = BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_META = BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P INNER JOIN ORDENDECOMPRA_AUXILIAR ON BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = ORDENDECOMPRA_AUXILIAR.COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = ORDENDECOMPRA_AUXILIAR.AUXILIAR WHERE ORDENDECOMPRA_AUXILIAR.COMPANIA = :COMPANIA AND ORDENDECOMPRA_AUXILIAR.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA_AUXILIAR.ORDENDECOMPRA = :NUMERO_ORDEN ORDER BY BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P DESC) WHERE (CASE WHEN ID_PLAN_P IS NULL THEN ' ' ELSE UPPER(ID_PLAN_P) END)  LIKE UPPER( '%' || :ID_PLAN_P || '%')  AND (CASE WHEN DESCRIPCION_META IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_META) END)  LIKE UPPER( '%' || :DESCRIPCION_META || '%')  AND (CASE WHEN VIGENCIA_META_P IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META_P) END)  LIKE UPPER( '%' || :VIGENCIA_META_P || '%')  AND (CASE WHEN CANTIDAD_PROGRAMADA_P IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PROGRAMADA_P) END)  LIKE UPPER(:CANTIDAD_PROGRAMADA_P || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>
		<param name="VIGENCIA_META_P" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA_P" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/todosporcompania/num">
		<call-query href="getBpplanindicativometasNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="ID_PLAN_P" query-param="ID_PLAN_P"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="VIGENCIA_META_P" query-param="VIGENCIA_META_P"/>
			<with-param name="CANTIDAD_PROGRAMADA_P" query-param="CANTIDAD_PROGRAMADA_P"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasPagProgramacionIndicadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_METAS.COMPANIA, BP_PLAN_INDICATIVO_METAS.ID_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, BP_PLAN_INDICATIVO_METAS.DESCRIPCION, BP_PLAN_INDICATIVO_METAS.DEPENDENCIA, BP_PLAN_INDICATIVO_METAS.PONDERACION_META, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META, BP_PLAN_INDICATIVO_METAS.VALOR_EJECUTADO_META, BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA, BP_PLAN_INDICATIVO_METAS.CANTIDAD_EJECUTADA, BP_PLAN_INDICATIVO_METAS.DESCRIPCION2, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META_OTROS, BP_PLAN_INDICATIVO_METAS.META_BRUTA  FROM BP_PLAN_INDICATIVO_METAS) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN VIGENCIA_PLAN IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PLAN) END)  LIKE UPPER(:VIGENCIA_PLAN || '%')  AND (CASE WHEN VIGENCIA_META IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META) END)  LIKE UPPER(:VIGENCIA_META || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN PONDERACION_META IS NULL THEN ' ' ELSE UPPER(PONDERACION_META) END)  LIKE UPPER(:PONDERACION_META || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META) END)  LIKE UPPER(:VALOR_PROGRAMADO_META || '%')  AND (CASE WHEN VALOR_EJECUTADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_META) END)  LIKE UPPER(:VALOR_EJECUTADO_META || '%')  AND (CASE WHEN CANTIDAD_PROGRAMADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PROGRAMADA) END)  LIKE UPPER(:CANTIDAD_PROGRAMADA || '%')  AND (CASE WHEN CANTIDAD_EJECUTADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJECUTADA) END)  LIKE UPPER(:CANTIDAD_EJECUTADA || '%')  AND (CASE WHEN META_BRUTA IS NULL THEN ' ' ELSE UPPER(META_BRUTA) END)  LIKE UPPER(:META_BRUTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_PLAN":"$ID_PLAN","VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","VIGENCIA_META":"$VIGENCIA_META(type:integer)","DESCRIPCION":"$DESCRIPCION","DEPENDENCIA":"$DEPENDENCIA","PONDERACION_META":"$PONDERACION_META","VALOR_PROGRAMADO_META":"$VALOR_PROGRAMADO_META","VALOR_EJECUTADO_META":"$VALOR_EJECUTADO_META","CANTIDAD_PROGRAMADA":"$CANTIDAD_PROGRAMADA","CANTIDAD_EJECUTADA":"$CANTIDAD_EJECUTADA","DESCRIPCION2":"$DESCRIPCION2","VALOR_PROGRAMADO_META_OTROS":"$VALOR_PROGRAMADO_META_OTROS","META_BRUTA":"$META_BRUTA"}]}}		</result>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PONDERACION_META" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADA" sqlType="STRING"/>
		<param name="META_BRUTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/programacionindicador/pag">
		<call-query href="getBpplanindicativometasPagProgramacionIndicadorQuery">
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_PLAN" query-param="VIGENCIA_PLAN"/>
			<with-param name="VIGENCIA_META" query-param="VIGENCIA_META"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PONDERACION_META" query-param="PONDERACION_META"/>
			<with-param name="VALOR_PROGRAMADO_META" query-param="VALOR_PROGRAMADO_META"/>
			<with-param name="VALOR_EJECUTADO_META" query-param="VALOR_EJECUTADO_META"/>
			<with-param name="CANTIDAD_PROGRAMADA" query-param="CANTIDAD_PROGRAMADA"/>
			<with-param name="CANTIDAD_EJECUTADA" query-param="CANTIDAD_EJECUTADA"/>
			<with-param name="META_BRUTA" query-param="META_BRUTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasNumProgramacionIndicadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_METAS.COMPANIA, BP_PLAN_INDICATIVO_METAS.ID_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, BP_PLAN_INDICATIVO_METAS.DESCRIPCION, BP_PLAN_INDICATIVO_METAS.DEPENDENCIA, BP_PLAN_INDICATIVO_METAS.PONDERACION_META, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META, BP_PLAN_INDICATIVO_METAS.VALOR_EJECUTADO_META, BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA, BP_PLAN_INDICATIVO_METAS.CANTIDAD_EJECUTADA, BP_PLAN_INDICATIVO_METAS.DESCRIPCION2, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META_OTROS, BP_PLAN_INDICATIVO_METAS.META_BRUTA  FROM BP_PLAN_INDICATIVO_METAS) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN VIGENCIA_PLAN IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PLAN) END)  LIKE UPPER(:VIGENCIA_PLAN || '%')  AND (CASE WHEN VIGENCIA_META IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META) END)  LIKE UPPER(:VIGENCIA_META || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN PONDERACION_META IS NULL THEN ' ' ELSE UPPER(PONDERACION_META) END)  LIKE UPPER(:PONDERACION_META || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META) END)  LIKE UPPER(:VALOR_PROGRAMADO_META || '%')  AND (CASE WHEN VALOR_EJECUTADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_META) END)  LIKE UPPER(:VALOR_EJECUTADO_META || '%')  AND (CASE WHEN CANTIDAD_PROGRAMADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PROGRAMADA) END)  LIKE UPPER(:CANTIDAD_PROGRAMADA || '%')  AND (CASE WHEN CANTIDAD_EJECUTADA IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJECUTADA) END)  LIKE UPPER(:CANTIDAD_EJECUTADA || '%')  AND (CASE WHEN META_BRUTA IS NULL THEN ' ' ELSE UPPER(META_BRUTA) END)  LIKE UPPER(:META_BRUTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PONDERACION_META" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADA" sqlType="STRING"/>
		<param name="META_BRUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/programacionindicador/num">
		<call-query href="getBpplanindicativometasNumProgramacionIndicadorQuery">
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_PLAN" query-param="VIGENCIA_PLAN"/>
			<with-param name="VIGENCIA_META" query-param="VIGENCIA_META"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PONDERACION_META" query-param="PONDERACION_META"/>
			<with-param name="VALOR_PROGRAMADO_META" query-param="VALOR_PROGRAMADO_META"/>
			<with-param name="VALOR_EJECUTADO_META" query-param="VALOR_EJECUTADO_META"/>
			<with-param name="CANTIDAD_PROGRAMADA" query-param="CANTIDAD_PROGRAMADA"/>
			<with-param name="CANTIDAD_EJECUTADA" query-param="CANTIDAD_EJECUTADA"/>
			<with-param name="META_BRUTA" query-param="META_BRUTA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasVigenciametaPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT VIGENCIA_META  FROM BP_PLAN_INDICATIVO_METAS WHERE COMPANIA = :COMPANIA AND VIGENCIA_META &lt;&gt; 0 ORDER BY VIGENCIA_META</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA_META":"$VIGENCIA_META(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/vigenciametaporcompania">
		<call-query href="getBpplanindicativometasVigenciametaPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT VIGENCIA_META  FROM BP_PLAN_INDICATIVO_METAS WHERE COMPANIA = :COMPANIA AND VIGENCIA_META NOT IN (0) ORDER BY VIGENCIA_META</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA_META":"$VIGENCIA_META(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/todosporcompania">
		<call-query href="getBpplanindicativometasTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativometasTodosPorVigenciaMetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION NOMBREMETAPRODUCTO, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, NVL(CANTIDAD_EJECUTADA,0) CANTIDAD_EJECUTADA1, NVL(NOMBRE,'Sin unidad de medida') NOMBRE_MEDIDA, NVL(META_BRUTA,0) META_BRUTA_AUX, SUM(NVL(BP_D_NOVEDADPROYECTO.CANTIDAD,0)) CANTIDAD_AUX, BP_D_NOVEDADPROYECTO.COMPONENTE  FROM BP_D_NOVEDADPROYECTO INNER JOIN BP_PLAN_INDICATIVO ON BP_D_NOVEDADPROYECTO.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = BP_PLAN_INDICATIVO.ID LEFT JOIN BP_PLAN_INDICATIVO_METAS ON BP_PLAN_INDICATIVO.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA AND BP_PLAN_INDICATIVO.ID = BP_PLAN_INDICATIVO_METAS.ID_PLAN AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN LEFT JOIN UNIDADPROYECTOS ON BP_PLAN_INDICATIVO.COMPANIA = UNIDADPROYECTOS.COMPANIA AND BP_PLAN_INDICATIVO.UNIDAD_MEDIDA = UNIDADPROYECTOS.UNIDAD WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.CLASET ='B' AND BP_D_NOVEDADPROYECTO.TIPOT = 'SVP' AND BP_D_NOVEDADPROYECTO.NOVEDAD = :NUMERO AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYECTO AND VIGENCIA_META = CASE WHEN :VIGENCIA = 'TODAS' THEN VIGENCIA_META ELSE TO_NUMBER(:VIGENCIA) END GROUP BY BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.PROYECTO, VIGENCIA_META, BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, CANTIDAD_EJECUTADA, NOMBRE, META_BRUTA, BP_D_NOVEDADPROYECTO.COMPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_META_PRODUCTO":"$ID_META_PRODUCTO","NOMBREMETAPRODUCTO":"$NOMBREMETAPRODUCTO","VIGENCIA_META":"$VIGENCIA_META(type:integer)","CANTIDAD_EJECUTADA1":"$CANTIDAD_EJECUTADA1(type:integer)","NOMBRE_MEDIDA":"$NOMBRE_MEDIDA","META_BRUTA_AUX":"$META_BRUTA_AUX(type:integer)","CANTIDAD_AUX":"$CANTIDAD_AUX(type:integer)","COMPONENTE":"$COMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativometas/todosporvigenciameta">
