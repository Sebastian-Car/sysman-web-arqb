	<query id="getBpplanindicativometasPagTodoPorCompaniaVigenciaPlanQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO_METAS.ID_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, BP_PLAN_INDICATIVO_METAS.DESCRIPCION DESCRIPCION_AUX, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META, BP_PLAN_INDICATIVO_METAS.DEPENDENCIA  FROM BP_PLAN_INDICATIVO INNER JOIN BP_PLAN_INDICATIVO_METAS ON (BP_PLAN_INDICATIVO.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA) AND (BP_PLAN_INDICATIVO.ID = BP_PLAN_INDICATIVO_METAS.ID_PLAN) AND (BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN) WHERE BP_PLAN_INDICATIVO_METAS.VIGENCIA_META = :VIGENCIAMETAP AND BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.TIPO_META_PLAN = '002' ORDER BY BP_PLAN_INDICATIVO_METAS.VIGENCIA_META DESC) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN VIGENCIA_PLAN IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PLAN) END)  LIKE UPPER(:VIGENCIA_PLAN || '%')  AND (CASE WHEN VIGENCIA_META IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META) END)  LIKE UPPER(:VIGENCIA_META || '%')  AND (CASE WHEN DESCRIPCION_AUX IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_AUX) END)  LIKE UPPER( '%' || :DESCRIPCION_AUX || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META) END)  LIKE UPPER(:VALOR_PROGRAMADO_META || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN":"$ID_PLAN","VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","VIGENCIA_META":"$VIGENCIA_META(type:integer)","DESCRIPCION_AUX":"$DESCRIPCION_AUX","VALOR_PROGRAMADO_META":"$VALOR_PROGRAMADO_META","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param name="VIGENCIAMETAP" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="DESCRIPCION_AUX" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
