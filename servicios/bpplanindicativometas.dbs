	<query id="getBpplanindicativometasTamanioIdPlanPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LENGTH(BP_PLAN_INDICATIVO.ID) AS LARGO  FROM BP_PLAN_INDICATIVO_METAS INNER JOIN BP_PLAN_INDICATIVO ON BP_PLAN_INDICATIVO_METAS.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN = BP_PLAN_INDICATIVO.ID AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA GROUP BY LENGTH(BP_PLAN_INDICATIVO.ID)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LARGO":"$LARGO(type:integer)"}]}}		</result>
