	<query id="updateSfdetallecontrato" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_CONTRATO SET TIPO=:TIPO, NUMERO=:NUMERO, CONCEPTO=:CONCEPTO, TARIFA=:TARIFA, CANTIDAD=:CANTIDAD, VALOR_BASE=:VALOR_BASE, VALOR_IVA=:VALOR_IVA, VALOR_RETE=:VALOR_RETE, VALOR_ICA=:VALOR_ICA, VALOR_DESCUENTO=:VALOR_DESCUENTO, VALOR_NETO=:VALOR_NETO, VALOR_COMPRA=:VALOR_COMPRA, VALOR_UTILIDAD=:VALOR_UTILIDAD, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, VALOR_UNITARIO=:VALOR_UNITARIO, ESTRATO=:ESTRATO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), ANO=:ANO, FUENTE_RECURSO=:FUENTE_RECURSO, REFERENCIA=:REFERENCIA, CUENTA_BANCO=:CUENTA_BANCO, VALOR_IMPOCONSUMO=:VALOR_IMPOCONSUMO, BASE_FIJA=:BASE_FIJA, SALDO_ACTUAL=:SALDO_ACTUAL, CENTRO_UTILIDAD=:CENTRO_UTILIDAD, INMUEBLE=:INMUEBLE WHERE SF_DETALLE_CONTRATO.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_CONTRATO.TIPO= :KEY_TIPO AND SF_DETALLE_CONTRATO.NUMERO= :KEY_NUMERO AND SF_DETALLE_CONTRATO.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_CONTRATO.INMUEBLE= :KEY_INMUEBLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
