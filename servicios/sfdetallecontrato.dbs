		</call-query>
	</resource>
	<query id="getSfdetallecontratoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_DETALLE_CONTRATO.ANO, SF_DETALLE_CONTRATO.AUXILIAR, SF_DETALLE_CONTRATO.CANTIDAD, SF_DETALLE_CONTRATO.CENTRO_COSTO, SF_DETALLE_CONTRATO.COMPANIA, SF_DETALLE_CONTRATO.CONCEPTO, SF_CONCEPTOS.NOMBRE NOMBRECONCEPTO, SF_DETALLE_CONTRATO.ESTRATO, SF_DETALLE_CONTRATO.NUMERO, SF_DETALLE_CONTRATO.SUCURSAL, SF_DETALLE_CONTRATO.TARIFA, SF_DETALLE_CONTRATO.TERCERO, SF_DETALLE_CONTRATO.TIPO, SF_DETALLE_CONTRATO.VALOR_BASE, SF_DETALLE_CONTRATO.VALOR_COMPRA, SF_DETALLE_CONTRATO.VALOR_DESCUENTO, SF_DETALLE_CONTRATO.VALOR_ICA, SF_DETALLE_CONTRATO.VALOR_IVA, SF_DETALLE_CONTRATO.VALOR_NETO, SF_DETALLE_CONTRATO.VALOR_RETE, SF_DETALLE_CONTRATO.VALOR_UNITARIO, SF_DETALLE_CONTRATO.VALOR_UTILIDAD, SF_DETALLE_CONTRATO.FUENTE_RECURSO, SF_DETALLE_CONTRATO.REFERENCIA, SF_DETALLE_CONTRATO.VALOR_IMPOCONSUMO, SF_DETALLE_CONTRATO.CUENTA_BANCO, SF_DETALLE_CONTRATO.BASE_FIJA, SF_DETALLE_CONTRATO.CENTRO_UTILIDAD, SF_DETALLE_CONTRATO.INMUEBLE FROM SF_DETALLE_CONTRATO INNER JOIN SF_CONCEPTOS ON SF_DETALLE_CONTRATO.COMPANIA = SF_CONCEPTOS.COMPANIA AND SF_DETALLE_CONTRATO.ANO = SF_CONCEPTOS.ANO AND SF_DETALLE_CONTRATO.TIPO = SF_CONCEPTOS.TIPOCOBRO AND SF_DETALLE_CONTRATO.CONCEPTO = SF_CONCEPTOS.CODIGO WHERE SF_DETALLE_CONTRATO.COMPANIA =:COMPANIA AND SF_DETALLE_CONTRATO.ANO =:ANO AND SF_DETALLE_CONTRATO.NUMERO =:NUMERO AND SF_DETALLE_CONTRATO.TIPO =:TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","AUXILIAR":"$AUXILIAR","CANTIDAD":"$CANTIDAD","CENTRO_COSTO":"$CENTRO_COSTO","COMPANIA":"$COMPANIA","CONCEPTO":"$CONCEPTO","NOMBRECONCEPTO":"$NOMBRECONCEPTO","ESTRATO":"$ESTRATO","NUMERO":"$NUMERO(type:long)","SUCURSAL":"$SUCURSAL","TARIFA":"$TARIFA","TERCERO":"$TERCERO","TIPO":"$TIPO","VALOR_BASE":"$VALOR_BASE","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_ICA":"$VALOR_ICA","VALOR_IVA":"$VALOR_IVA","VALOR_NETO":"$VALOR_NETO","VALOR_RETE":"$VALOR_RETE","VALOR_UNITARIO":"$VALOR_UNITARIO","VALOR_UTILIDAD":"$VALOR_UTILIDAD","FUENTE_RECURSO":"$FUENTE_RECURSO","REFERENCIA":"$REFERENCIA","VALOR_IMPOCONSUMO":"$VALOR_IMPOCONSUMO","CUENTA_BANCO":"$CUENTA_BANCO","BASE_FIJA":"$BASE_FIJA","CENTRO_UTILIDAD":"$CENTRO_UTILIDAD","INMUEBLE":"$INMUEBLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecontrato">
		<call-query href="getSfdetallecontratoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecontratoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT ANO, AUXILIAR, CANTIDAD, CENTRO_COSTO, COMPANIA, CONCEPTO, ESTRATO, NUMERO, SUCURSAL, TARIFA, TERCERO, TIPO, VALOR_BASE, VALOR_COMPRA, VALOR_DESCUENTO, VALOR_ICA, VALOR_IVA, VALOR_NETO, VALOR_RETE, VALOR_UNITARIO, VALOR_UTILIDAD , CENTRO_UTILIDAD FROM SF_DETALLE_CONTRATO WHERE SF_DETALLE_CONTRATO.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_CONTRATO.TIPO= :KEY_TIPO AND SF_DETALLE_CONTRATO.NUMERO= :KEY_NUMERO AND SF_DETALLE_CONTRATO.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_CONTRATO.INMUEBLE= :KEY_INMUEBLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","AUXILIAR":"$AUXILIAR","CANTIDAD":"$CANTIDAD","CENTRO_COSTO":"$CENTRO_COSTO","COMPANIA":"$COMPANIA","CONCEPTO":"$CONCEPTO","ESTRATO":"$ESTRATO","NUMERO":"$NUMERO(type:long)","SUCURSAL":"$SUCURSAL","TARIFA":"$TARIFA","TERCERO":"$TERCERO","TIPO":"$TIPO","VALOR_BASE":"$VALOR_BASE","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_ICA":"$VALOR_ICA","VALOR_IVA":"$VALOR_IVA","VALOR_NETO":"$VALOR_NETO","VALOR_RETE":"$VALOR_RETE","VALOR_UNITARIO":"$VALOR_UNITARIO","VALOR_UTILIDAD":"$VALOR_UTILIDAD","CENTRO_UTILIDAD":"$CENTRO_UTILIDAD"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_INMUEBLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecontrato/data">
		<call-query href="getSfdetallecontratoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
