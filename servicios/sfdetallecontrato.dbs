<data name="sfdetallecontrato" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfdetallecontratoSumaValoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(NVL(SUM(VALOR_BASE),0),'99,999,999,999,999,990.90') TVALBASE, TO_CHAR(NVL(SUM(VALOR_IVA),0),'99,999,999,999,999,990.90') TIVA, TO_CHAR(NVL(SUM(VALOR_RETE),0),'99,999,999,999,999,990.90') TRETE, TO_CHAR(NVL(SUM(VALOR_ICA),0),'99,999,999,999,999,990.90') TICA, TO_CHAR(NVL(SUM(VALOR_DESCUENTO),0),'99,999,999,999,999,990.90') TDES, TO_CHAR(NVL(SUM(VALOR_NETO),0),'99,999,999,999,999,990.90') TNET, TO_CHAR(NVL(SUM(VALOR_UNITARIO),0),'99,999,999,999,999,990.90') TUNIT, TO_CHAR(NVL(SUM(VALOR_IMPOCONSUMO),0),'99,999,999,999,999,990.90') TIMPOCONSUMO FROM SF_DETALLE_CONTRATO WHERE COMPANIA =:COMPANIA AND TIPO =:TIPO AND NUMERO =:NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TVALBASE":"$TVALBASE","TIVA":"$TIVA","TRETE":"$TRETE","TICA":"$TICA","TDES":"$TDES","TNET":"$TNET","TUNIT":"$TUNIT","TIMPOCONSUMO":"$TIMPOCONSUMO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecontrato/sumavalores">
		<call-query href="getSfdetallecontratoSumaValoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecontratoGetdetallecontratoinmuebleporcontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCEPTO, CANTIDAD, VALOR_BASE, VALOR_IVA, VALOR_UNITARIO, VALOR_NETO, TERCERO, '001' SUCURSAL FROM SF_DETALLE_CONTRATO WHERE COMPANIA = :COMPANIA AND NUMERO = :NUMERO AND TIPO = :TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONCEPTO":"$CONCEPTO","CANTIDAD":"$CANTIDAD","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_UNITARIO":"$VALOR_UNITARIO","VALOR_NETO":"$VALOR_NETO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecontrato/getdetallecontratoinmuebleporcontrato">
		<call-query href="getSfdetallecontratoGetdetallecontratoinmuebleporcontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecontratoGetmaxycountparaalmacenamietoalternoQuery"  useConfig="sysmandsunist">
		<sql>SELECT MAX(INMUEBLE) CONSEC, COUNT(NUMERO) EXISTE FROM SF_DETALLE_CONTRATO WHERE COMPANIA = :COMPANIA AND NUMERO = :NUMERO AND CONCEPTO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSEC":"$CONSEC","EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecontrato/getmaxycountparaalmacenamietoalterno">
		<call-query href="getSfdetallecontratoGetmaxycountparaalmacenamietoalternoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="insertSfdetallecontrato" keyColumns="COMPANIA,TIPO,NUMERO,CONCEPTO,INMUEBLE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_DETALLE_CONTRATO (COMPANIA, TIPO, NUMERO, CONCEPTO, TARIFA, CANTIDAD, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_ICA, VALOR_DESCUENTO, VALOR_NETO, VALOR_COMPRA, VALOR_UTILIDAD, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, VALOR_UNITARIO, ESTRATO, CREATED_BY, DATE_CREATED, ANO, FUENTE_RECURSO, REFERENCIA, CUENTA_BANCO, VALOR_IMPOCONSUMO, BASE_FIJA, SALDO_ACTUAL, CENTRO_UTILIDAD, INMUEBLE) VALUES (:COMPANIA, :TIPO, :NUMERO, :CONCEPTO, :TARIFA, :CANTIDAD, :VALOR_BASE, :VALOR_IVA, :VALOR_RETE, :VALOR_ICA, :VALOR_DESCUENTO, :VALOR_NETO, :VALOR_COMPRA, :VALOR_UTILIDAD, :TERCERO, :SUCURSAL, :CENTRO_COSTO, :AUXILIAR, :VALOR_UNITARIO, :ESTRATO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :ANO, :FUENTE_RECURSO, :REFERENCIA, :CUENTA_BANCO, :VALOR_IMPOCONSUMO, :BASE_FIJA, :SALDO_ACTUAL, :CENTRO_UTILIDAD, :INMUEBLE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_CONCEPTO":"$CONCEPTO","KEY_INMUEBLE":"$INMUEBLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="TARIFA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_BASE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_IVA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_RETE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_ICA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_NETO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_COMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UTILIDAD" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UNITARIO" sqlType="STRING"/>
		<param defaultValue="" name="ESTRATO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_RECURSO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_BANCO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_IMPOCONSUMO" sqlType="STRING"/>
		<param defaultValue="0" name="BASE_FIJA" sqlType="STRING"/>
		<param defaultValue="0" name="SALDO_ACTUAL" sqlType="STRING"/>
		<param defaultValue="" name="CENTRO_UTILIDAD" sqlType="STRING"/>
		<param name="INMUEBLE" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfdetallecontrato">
		<call-query href="insertSfdetallecontrato">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
