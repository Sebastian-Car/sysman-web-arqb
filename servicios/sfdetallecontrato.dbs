	<query id="deleteSfdetallecontrato" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_DETALLE_CONTRATO WHERE SF_DETALLE_CONTRATO.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_CONTRATO.TIPO= :KEY_TIPO AND SF_DETALLE_CONTRATO.NUMERO= :KEY_NUMERO AND SF_DETALLE_CONTRATO.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_CONTRATO.INMUEBLE= :KEY_INMUEBLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_INMUEBLE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfdetallecontrato">
