	</resource>
	<query id="getViconceptosviaticosNumCodNomTipoPorCiaAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE, VI_CONCEPTO_VIATICOS.TIPO_CONCEPTO  FROM VI_CONCEPTO_VIATICOS WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO = :ANO) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(TIPO_CONCEPTO) END)  LIKE UPPER(:TIPO_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/codnomtipoporciaano/num">
		<call-query href="getViconceptosviaticosNumCodNomTipoPorCiaAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_CONCEPTO" query-param="TIPO_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosPagIndicadorOrigenDestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE,(CASE VI_CONCEPTO_VIATICOS.IND_ORIGEN_DESTINO WHEN 0 THEN 'false' ELSE 'true' END) IND_ORIGEN_DESTINO FROM VI_CONCEPTO_VIATICOS WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO = :ANO) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_ORIGEN_DESTINO IS NULL THEN ' ' ELSE UPPER(IND_ORIGEN_DESTINO) END)  LIKE UPPER( '%' || :IND_ORIGEN_DESTINO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE":"$NOMBRE","IND_ORIGEN_DESTINO":"$IND_ORIGEN_DESTINO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_ORIGEN_DESTINO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/indicadororigendestino/pag">
		<call-query href="getViconceptosviaticosPagIndicadorOrigenDestinoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_ORIGEN_DESTINO" query-param="IND_ORIGEN_DESTINO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosNumIndicadorOrigenDestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE,(CASE VI_CONCEPTO_VIATICOS.IND_ORIGEN_DESTINO WHEN 0 THEN 'false' ELSE 'true' END) IND_ORIGEN_DESTINO FROM VI_CONCEPTO_VIATICOS WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO = :ANO) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_ORIGEN_DESTINO IS NULL THEN ' ' ELSE UPPER(IND_ORIGEN_DESTINO) END)  LIKE UPPER( '%' || :IND_ORIGEN_DESTINO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_ORIGEN_DESTINO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/indicadororigendestino/num">
		<call-query href="getViconceptosviaticosNumIndicadorOrigenDestinoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_ORIGEN_DESTINO" query-param="IND_ORIGEN_DESTINO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosPagConsecutivoPorEscalafonYCategoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE, VI_CONCEPTO_VIATICOS.TIPO_CONCEPTO, VI_DETALLE_CATEGORIA_CONCEPTO.CONSECUTIVO  FROM VI_CONCEPTO_VIATICOS LEFT JOIN VI_DETALLE_CATEGORIA_CONCEPTO ON VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = VI_CONCEPTO_VIATICOS.COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = VI_CONCEPTO_VIATICOS.ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO = VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO = :ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = :ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = :CATEGORIA) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE":"$NOMBRE","TIPO_CONCEPTO":"$TIPO_CONCEPTO","CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/consecutivoporescalafonycategoria/pag">
		<call-query href="getViconceptosviaticosPagConsecutivoPorEscalafonYCategoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosNumConsecutivoPorEscalafonYCategoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE, VI_CONCEPTO_VIATICOS.TIPO_CONCEPTO, VI_DETALLE_CATEGORIA_CONCEPTO.CONSECUTIVO  FROM VI_CONCEPTO_VIATICOS LEFT JOIN VI_DETALLE_CATEGORIA_CONCEPTO ON VI_DETALLE_CATEGORIA_CONCEPTO.COMPANIA = VI_CONCEPTO_VIATICOS.COMPANIA AND VI_DETALLE_CATEGORIA_CONCEPTO.ANO = VI_CONCEPTO_VIATICOS.ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.CODIGO_CONCEPTO = VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO = :ANO AND VI_DETALLE_CATEGORIA_CONCEPTO.ESCALAFON = :ESCALAFON AND VI_DETALLE_CATEGORIA_CONCEPTO.ID_CATEGORIA = :CATEGORIA) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/consecutivoporescalafonycategoria/num">
		<call-query href="getViconceptosviaticosNumConsecutivoPorEscalafonYCategoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertViconceptosviaticos" keyColumns="COMPANIA,ANO,CODIGO_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VI_CONCEPTO_VIATICOS (COMPANIA, ANO, CODIGO_CONCEPTO, NOMBRE, CUENTA_CAUSACION_DEBITO, CUENTA_CAUSACION_CREDITO, CUENTA_LEGALIZACION_DEBITO, CUENTA_LEGALIZACION_CREDITO, IND_ORIGEN_DESTINO, TIPO_CPTE_PPTAL, COMPROBANTE_DISPON, CUENTA_PPTAL, TIPO_CPTE_CNT, TIPO_CPTE_CNT_TES, TIPO_CPTE_CNT_LEG, CENTRO_COSTO, AUXILIAR, FUENTE_RECURSO, REFERENCIA, TIPO_CONCEPTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO_CONCEPTO, :NOMBRE, :CUENTA_CAUSACION_DEBITO, :CUENTA_CAUSACION_CREDITO, :CUENTA_LEGALIZACION_DEBITO, :CUENTA_LEGALIZACION_CREDITO, :IND_ORIGEN_DESTINO, :TIPO_CPTE_PPTAL, :COMPROBANTE_DISPON, :CUENTA_PPTAL, :TIPO_CPTE_CNT, :TIPO_CPTE_CNT_TES, :TIPO_CPTE_CNT_LEG, :CENTRO_COSTO, :AUXILIAR, :FUENTE_RECURSO, :REFERENCIA, :TIPO_CONCEPTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO_CONCEPTO":"$CODIGO_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_CAUSACION_DEBITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_CAUSACION_CREDITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_LEGALIZACION_DEBITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_LEGALIZACION_CREDITO" sqlType="STRING"/>
		<param defaultValue="0" name="IND_ORIGEN_DESTINO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CPTE_PPTAL" sqlType="STRING"/>
		<param defaultValue="" name="COMPROBANTE_DISPON" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_PPTAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CPTE_CNT" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CPTE_CNT_TES" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CPTE_CNT_LEG" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_RECURSO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CONCEPTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="viconceptosviaticos">
		<call-query href="insertViconceptosviaticos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CUENTA_CAUSACION_DEBITO" query-param="CUENTA_CAUSACION_DEBITO"/>
			<with-param name="CUENTA_CAUSACION_CREDITO" query-param="CUENTA_CAUSACION_CREDITO"/>
			<with-param name="CUENTA_LEGALIZACION_DEBITO" query-param="CUENTA_LEGALIZACION_DEBITO"/>
			<with-param name="CUENTA_LEGALIZACION_CREDITO" query-param="CUENTA_LEGALIZACION_CREDITO"/>
			<with-param name="IND_ORIGEN_DESTINO" query-param="IND_ORIGEN_DESTINO"/>
			<with-param name="TIPO_CPTE_PPTAL" query-param="TIPO_CPTE_PPTAL"/>
			<with-param name="COMPROBANTE_DISPON" query-param="COMPROBANTE_DISPON"/>
			<with-param name="CUENTA_PPTAL" query-param="CUENTA_PPTAL"/>
			<with-param name="TIPO_CPTE_CNT" query-param="TIPO_CPTE_CNT"/>
			<with-param name="TIPO_CPTE_CNT_TES" query-param="TIPO_CPTE_CNT_TES"/>
			<with-param name="TIPO_CPTE_CNT_LEG" query-param="TIPO_CPTE_CNT_LEG"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="TIPO_CONCEPTO" query-param="TIPO_CONCEPTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteViconceptosviaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VI_CONCEPTO_VIATICOS WHERE VI_CONCEPTO_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_CONCEPTO_VIATICOS.ANO= :KEY_ANO AND VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="viconceptosviaticos">
		<call-query href="deleteViconceptosviaticos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO_CONCEPTO" query-param="KEY_CODIGO_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CV.COMPANIA, CV.ANO, CV.CODIGO_CONCEPTO, CV.NOMBRE , TC.NOMBRE TIPO_CONCEPTO  FROM vi_concepto_viaticos CV LEFT JOIN VI_TIPO_CONCEPTO TC ON CV.COMPANIA = TC.COMPANIA AND CV.TIPO_CONCEPTO = TC.CODIGO WHERE CV.COMPANIA = :COMPANIA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(TIPO_CONCEPTO) END)  LIKE UPPER( '%' || :TIPO_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE":"$NOMBRE","TIPO_CONCEPTO":"$TIPO_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viconceptosviaticos">
		<call-query href="getViconceptosviaticosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_CONCEPTO" query-param="TIPO_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CV.COMPANIA, CV.ANO, CV.CODIGO_CONCEPTO, CV.NOMBRE , TC.NOMBRE TIPO_CONCEPTO  FROM vi_concepto_viaticos CV LEFT JOIN VI_TIPO_CONCEPTO TC ON CV.COMPANIA = TC.COMPANIA AND CV.TIPO_CONCEPTO = TC.CODIGO WHERE CV.COMPANIA = :COMPANIA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(TIPO_CONCEPTO) END)  LIKE UPPER( '%' || :TIPO_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/numero">
		<call-query href="getViconceptosviaticosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_CONCEPTO" query-param="TIPO_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,ANO, CODIGO_CONCEPTO, NOMBRE, CUENTA_CAUSACION_DEBITO, CUENTA_CAUSACION_CREDITO, CUENTA_LEGALIZACION_DEBITO, CUENTA_LEGALIZACION_CREDITO,(CASE IND_ORIGEN_DESTINO WHEN 0 THEN 'false' ELSE 'true' END) IND_ORIGEN_DESTINO, TIPO_CPTE_PPTAL, COMPROBANTE_DISPON, CUENTA_PPTAL, TIPO_CPTE_CNT, TIPO_CPTE_CNT_TES, TIPO_CPTE_CNT_LEG, CENTRO_COSTO, AUXILIAR, FUENTE_RECURSO, REFERENCIA, TIPO_CONCEPTO,CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM vi_concepto_viaticos WHERE VI_CONCEPTO_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_CONCEPTO_VIATICOS.ANO= :KEY_ANO AND VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE":"$NOMBRE","CUENTA_CAUSACION_DEBITO":"$CUENTA_CAUSACION_DEBITO","CUENTA_CAUSACION_CREDITO":"$CUENTA_CAUSACION_CREDITO","CUENTA_LEGALIZACION_DEBITO":"$CUENTA_LEGALIZACION_DEBITO","CUENTA_LEGALIZACION_CREDITO":"$CUENTA_LEGALIZACION_CREDITO","IND_ORIGEN_DESTINO":"$IND_ORIGEN_DESTINO(type:boolean)","TIPO_CPTE_PPTAL":"$TIPO_CPTE_PPTAL","COMPROBANTE_DISPON":"$COMPROBANTE_DISPON(type:long)","CUENTA_PPTAL":"$CUENTA_PPTAL","TIPO_CPTE_CNT":"$TIPO_CPTE_CNT","TIPO_CPTE_CNT_TES":"$TIPO_CPTE_CNT_TES","TIPO_CPTE_CNT_LEG":"$TIPO_CPTE_CNT_LEG","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","FUENTE_RECURSO":"$FUENTE_RECURSO","REFERENCIA":"$REFERENCIA","TIPO_CONCEPTO":"$TIPO_CONCEPTO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/data">
		<call-query href="getViconceptosviaticosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO_CONCEPTO" query-param="KEY_CODIGO_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateViconceptosviaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_CONCEPTO_VIATICOS SET NOMBRE=:NOMBRE, CUENTA_CAUSACION_DEBITO=:CUENTA_CAUSACION_DEBITO, CUENTA_CAUSACION_CREDITO=:CUENTA_CAUSACION_CREDITO, CUENTA_LEGALIZACION_DEBITO=:CUENTA_LEGALIZACION_DEBITO, CUENTA_LEGALIZACION_CREDITO=:CUENTA_LEGALIZACION_CREDITO, IND_ORIGEN_DESTINO=:IND_ORIGEN_DESTINO, TIPO_CPTE_PPTAL=:TIPO_CPTE_PPTAL, COMPROBANTE_DISPON=:COMPROBANTE_DISPON, CUENTA_PPTAL=:CUENTA_PPTAL, TIPO_CPTE_CNT=:TIPO_CPTE_CNT, TIPO_CPTE_CNT_TES=:TIPO_CPTE_CNT_TES, TIPO_CPTE_CNT_LEG=:TIPO_CPTE_CNT_LEG, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, FUENTE_RECURSO=:FUENTE_RECURSO, REFERENCIA=:REFERENCIA, TIPO_CONCEPTO=:TIPO_CONCEPTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VI_CONCEPTO_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_CONCEPTO_VIATICOS.ANO= :KEY_ANO AND VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CUENTA_CAUSACION_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_CAUSACION_CREDITO" sqlType="STRING"/>
		<param name="CUENTA_LEGALIZACION_DEBITO" sqlType="STRING"/>
		<param name="CUENTA_LEGALIZACION_CREDITO" sqlType="STRING"/>
		<param name="IND_ORIGEN_DESTINO" sqlType="STRING"/>
		<param name="TIPO_CPTE_PPTAL" sqlType="STRING"/>
		<param name="COMPROBANTE_DISPON" sqlType="STRING"/>
		<param name="CUENTA_PPTAL" sqlType="STRING"/>
		<param name="TIPO_CPTE_CNT" sqlType="STRING"/>
		<param name="TIPO_CPTE_CNT_TES" sqlType="STRING"/>
		<param name="TIPO_CPTE_CNT_LEG" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="TIPO_CONCEPTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="viconceptosviaticos">
		<call-query href="updateViconceptosviaticos">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CUENTA_CAUSACION_DEBITO" query-param="CUENTA_CAUSACION_DEBITO"/>
			<with-param name="CUENTA_CAUSACION_CREDITO" query-param="CUENTA_CAUSACION_CREDITO"/>
			<with-param name="CUENTA_LEGALIZACION_DEBITO" query-param="CUENTA_LEGALIZACION_DEBITO"/>
			<with-param name="CUENTA_LEGALIZACION_CREDITO" query-param="CUENTA_LEGALIZACION_CREDITO"/>
