<data name="viconceptosviaticos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getViconceptosviaticosPagConceptosSegunAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE, VI_CONCEPTO_VIATICOS.ANO  FROM VI_CONCEPTO_VIATICOS WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO =:ANO) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/conceptossegunano/pag">
		<call-query href="getViconceptosviaticosPagConceptosSegunAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosNumConceptosSegunAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE, VI_CONCEPTO_VIATICOS.ANO  FROM VI_CONCEPTO_VIATICOS WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO =:ANO) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/conceptossegunano/num">
		<call-query href="getViconceptosviaticosNumConceptosSegunAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getViconceptosviaticosPagCodNomTipoPorCiaAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE, VI_CONCEPTO_VIATICOS.TIPO_CONCEPTO  FROM VI_CONCEPTO_VIATICOS WHERE VI_CONCEPTO_VIATICOS.COMPANIA = :COMPANIA AND VI_CONCEPTO_VIATICOS.ANO = :ANO) WHERE (CASE WHEN CODIGO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(CODIGO_CONCEPTO) END)  LIKE UPPER(:CODIGO_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_CONCEPTO IS NULL THEN ' ' ELSE UPPER(TIPO_CONCEPTO) END)  LIKE UPPER(:TIPO_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRE":"$NOMBRE","TIPO_CONCEPTO":"$TIPO_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="viconceptosviaticos/codnomtipoporciaano/pag">
		<call-query href="getViconceptosviaticosPagCodNomTipoPorCiaAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_CONCEPTO" query-param="TIPO_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
