<data name="sfcreeconceptos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfcreeconceptosExisteConceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM SF_CREE_CONCEPTOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO AND CONCEPTO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcreeconceptos/existeconcepto">
		<call-query href="getSfcreeconceptosExisteConceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getSfcreeconceptosCalculavalorcreeQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CASE WHEN APLICACREE NOT IN (0) THEN PCK_SYSMAN_UTL.FC_ROUND(PCK_SYSMAN_UTL.FC_EVAL(FORMULA) * PORCENTAJECREE /100,0) ELSE 0 END CREE  FROM SF_CREE_CONCEPTOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO AND CONCEPTO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREE":"$CREE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcreeconceptos/calculavalorcree">
		<call-query href="getSfcreeconceptosCalculavalorcreeQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="insertSfcreeconceptos" keyColumns="COMPANIA,ANO,TIPOCOBRO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_CREE_CONCEPTOS (COMPANIA, ANO, TIPOCOBRO, CONCEPTO, APLICACREE, PORCENTAJECREE, FORMULA, CUENTADEBITOBASE, CUENTACREDITOBASE, CUENTADEBITOBASE_AV, CUENTACREDITOBASE_AV, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPOCOBRO, :CONCEPTO, :APLICACREE, :PORCENTAJECREE, :FORMULA, :CUENTADEBITOBASE, :CUENTACREDITOBASE, :CUENTADEBITOBASE_AV, :CUENTACREDITOBASE_AV, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_CONCEPTO":"$CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="APLICACREE" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJECREE" sqlType="STRING"/>
		<param defaultValue="" name="FORMULA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADEBITOBASE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACREDITOBASE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADEBITOBASE_AV" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACREDITOBASE_AV" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfcreeconceptos">
		<call-query href="insertSfcreeconceptos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="APLICACREE" query-param="APLICACREE"/>
			<with-param name="PORCENTAJECREE" query-param="PORCENTAJECREE"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="CUENTADEBITOBASE" query-param="CUENTADEBITOBASE"/>
			<with-param name="CUENTACREDITOBASE" query-param="CUENTACREDITOBASE"/>
			<with-param name="CUENTADEBITOBASE_AV" query-param="CUENTADEBITOBASE_AV"/>
			<with-param name="CUENTACREDITOBASE_AV" query-param="CUENTACREDITOBASE_AV"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSfcreeconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_CREE_CONCEPTOS WHERE SF_CREE_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_CREE_CONCEPTOS.ANO= :KEY_ANO AND SF_CREE_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CREE_CONCEPTOS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfcreeconceptos">
		<call-query href="deleteSfcreeconceptos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getSfcreeconceptosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SF_CREE_CONCEPTOS.COMPANIA, SF_CREE_CONCEPTOS.ANO, SF_CREE_CONCEPTOS.TIPOCOBRO, SF_CREE_CONCEPTOS.CONCEPTO,(CASE SF_CREE_CONCEPTOS.APLICACREE WHEN 0 THEN 'false' ELSE 'true' END) APLICACREE, SF_CREE_CONCEPTOS.PORCENTAJECREE, SF_CREE_CONCEPTOS.FORMULA, SF_CREE_CONCEPTOS.CUENTADEBITOBASE, SF_CREE_CONCEPTOS.CUENTACREDITOBASE, SF_CREE_CONCEPTOS.CUENTADEBITOBASE_AV, SF_CREE_CONCEPTOS.CUENTACREDITOBASE_AV  FROM SF_CREE_CONCEPTOS WHERE SF_CREE_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_CREE_CONCEPTOS.ANO= :KEY_ANO AND SF_CREE_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CREE_CONCEPTOS.CONCEPTO= :KEY_CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CONCEPTO":"$CONCEPTO","APLICACREE":"$APLICACREE(type:boolean)","PORCENTAJECREE":"$PORCENTAJECREE","FORMULA":"$FORMULA","CUENTADEBITOBASE":"$CUENTADEBITOBASE","CUENTACREDITOBASE":"$CUENTACREDITOBASE","CUENTADEBITOBASE_AV":"$CUENTADEBITOBASE_AV","CUENTACREDITOBASE_AV":"$CUENTACREDITOBASE_AV"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcreeconceptos/data">
		<call-query href="getSfcreeconceptosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateSfcreeconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CREE_CONCEPTOS SET APLICACREE=:APLICACREE, PORCENTAJECREE=:PORCENTAJECREE, FORMULA=:FORMULA, CUENTADEBITOBASE=:CUENTADEBITOBASE, CUENTACREDITOBASE=:CUENTACREDITOBASE, CUENTADEBITOBASE_AV=:CUENTADEBITOBASE_AV, CUENTACREDITOBASE_AV=:CUENTACREDITOBASE_AV, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_CREE_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_CREE_CONCEPTOS.ANO= :KEY_ANO AND SF_CREE_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CREE_CONCEPTOS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="APLICACREE" sqlType="STRING"/>
		<param name="PORCENTAJECREE" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
		<param name="CUENTADEBITOBASE" sqlType="STRING"/>
		<param name="CUENTACREDITOBASE" sqlType="STRING"/>
		<param name="CUENTADEBITOBASE_AV" sqlType="STRING"/>
		<param name="CUENTACREDITOBASE_AV" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfcreeconceptos">
		<call-query href="updateSfcreeconceptos">
			<with-param name="APLICACREE" query-param="APLICACREE"/>
			<with-param name="PORCENTAJECREE" query-param="PORCENTAJECREE"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="CUENTADEBITOBASE" query-param="CUENTADEBITOBASE"/>
			<with-param name="CUENTACREDITOBASE" query-param="CUENTACREDITOBASE"/>
			<with-param name="CUENTADEBITOBASE_AV" query-param="CUENTADEBITOBASE_AV"/>
			<with-param name="CUENTACREDITOBASE_AV" query-param="CUENTACREDITOBASE_AV"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>

</data>