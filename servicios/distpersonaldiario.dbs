	<query id="updateDistpersonaldiario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DISTPERSONALDIARIO SET COMPANIA=:COMPANIA, ID_DE_PROCESO=:ID_DE_PROCESO, ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_CENTRO_DE_COSTO=:ID_CENTRO_DE_COSTO, HORAST=:HORAST, MINUTOST=:MINUTOST, TIEMPOTRABAJADO=:TIEMPOTRABAJADO, ID_AUXILIAR=:ID_AUXILIAR, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS') WHERE DISTPERSONALDIARIO.COMPANIA= :KEY_COMPANIA AND DISTPERSONALDIARIO.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND DISTPERSONALDIARIO.ANO= :KEY_ANO AND DISTPERSONALDIARIO.MES= :KEY_MES AND DISTPERSONALDIARIO.PERIODO= :KEY_PERIODO AND DISTPERSONALDIARIO.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND DISTPERSONALDIARIO.ID_CENTRO_DE_COSTO= :KEY_ID_CENTRO_DE_COSTO AND DISTPERSONALDIARIO.ID_AUXILIAR= :KEY_ID_AUXILIAR AND DISTPERSONALDIARIO.FECHA= TO_DATE(:KEY_FECHA,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="HORAST" sqlType="STRING"/>
		<param name="MINUTOST" sqlType="STRING"/>
		<param name="TIEMPOTRABAJADO" sqlType="STRING"/>
		<param name="ID_AUXILIAR" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="KEY_ID_AUXILIAR" sqlType="STRING"/>
		<param name="KEY_FECHA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="distpersonaldiario">
		<call-query href="updateDistpersonaldiario">
