<data name="profesiones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getProfesionesPagTodasLasProfesionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION, PROFESIONES.DESCRIPCIONPROF, PROFESIONES.TIPO  FROM PROFESIONES) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%')  AND (CASE WHEN DESCRIPCIONPROF IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONPROF) END)  LIKE UPPER( '%' || :DESCRIPCIONPROF || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOPROF":"$CODIGOPROF","NOMBRE_PROFESION":"$NOMBRE_PROFESION","DESCRIPCIONPROF":"$DESCRIPCIONPROF","TIPO":"$TIPO"}]}}		</result>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="DESCRIPCIONPROF" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="profesiones/todaslasprofesiones/pag">
		<call-query href="getProfesionesPagTodasLasProfesionesQuery">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="DESCRIPCIONPROF" query-param="DESCRIPCIONPROF"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProfesionesNumTodasLasProfesionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION, PROFESIONES.DESCRIPCIONPROF, PROFESIONES.TIPO  FROM PROFESIONES) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%')  AND (CASE WHEN DESCRIPCIONPROF IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONPROF) END)  LIKE UPPER( '%' || :DESCRIPCIONPROF || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="DESCRIPCIONPROF" sqlType="STRING"/>

	</query>
	<resource method="GET" path="profesiones/todaslasprofesiones/num">
		<call-query href="getProfesionesNumTodasLasProfesionesQuery">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="DESCRIPCIONPROF" query-param="DESCRIPCIONPROF"/>

		</call-query>
	</resource>
	<query id="getProfesionesPagCodigoYNombreIncialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION  FROM PROFESIONES ORDER BY PROFESIONES.CODIGOPROF) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOPROF":"$CODIGOPROF","NOMBRE_PROFESION":"$NOMBRE_PROFESION"}]}}		</result>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="profesiones/codigoynombreincial/pag">
		<call-query href="getProfesionesPagCodigoYNombreIncialQuery">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProfesionesNumCodigoYNombreIncialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION  FROM PROFESIONES ORDER BY PROFESIONES.CODIGOPROF) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="profesiones/codigoynombreincial/num">
		<call-query href="getProfesionesNumCodigoYNombreIncialQuery">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>

		</call-query>
	</resource>
	<query id="getProfesionesPagCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION  FROM PROFESIONES WHERE PROFESIONES.CODIGOPROF&gt;= :PROFESIONINICIAL ORDER BY PROFESIONES.CODIGOPROF) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOPROF":"$CODIGOPROF","NOMBRE_PROFESION":"$NOMBRE_PROFESION"}]}}		</result>
		<param name="PROFESIONINICIAL" sqlType="STRING"/>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="profesiones/codigoynombrefinal/pag">
		<call-query href="getProfesionesPagCodigoYNombreFinalQuery">
			<with-param name="PROFESIONINICIAL" query-param="PROFESIONINICIAL"/>
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProfesionesNumCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION  FROM PROFESIONES WHERE PROFESIONES.CODIGOPROF&gt;= :PROFESIONINICIAL ORDER BY PROFESIONES.CODIGOPROF) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="PROFESIONINICIAL" sqlType="STRING"/>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="profesiones/codigoynombrefinal/num">
		<call-query href="getProfesionesNumCodigoYNombreFinalQuery">
			<with-param name="PROFESIONINICIAL" query-param="PROFESIONINICIAL"/>
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>

		</call-query>
	</resource>
	<query id="getProfesionesPagProfesionportipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION FROM PROFESIONES WHERE TIPO IN (:TIPO) ORDER BY PROFESIONES.CODIGOPROF) INI WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END) LIKE UPPER(CONCAT(:CODIGOPROF, '%')) AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROFESION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOPROF":"$CODIGOPROF","NOMBRE_PROFESION":"$NOMBRE_PROFESION"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="profesiones/profesionportipo/pag">
		<call-query href="getProfesionesPagProfesionportipoQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProfesionesNumProfesionportipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION FROM PROFESIONES WHERE TIPO IN (:TIPO) ORDER BY PROFESIONES.CODIGOPROF) INI WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END) LIKE UPPER(CONCAT(:CODIGOPROF, '%')) AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROFESION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="profesiones/profesionportipo/num">
		<call-query href="getProfesionesNumProfesionportipoQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>

		</call-query>
	</resource>
	<query id="insertProfesiones" keyColumns="CODIGOPROF" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PROFESIONES (CODIGOPROF, NOMBRE_PROFESION, DESCRIPCIONPROF, TIPO, DATE_CREATED, CREATED_BY) VALUES (:CODIGOPROF, :NOMBRE_PROFESION, :DESCRIPCIONPROF, :TIPO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGOPROF":"$CODIGOPROF"}]}}		</result>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="DESCRIPCIONPROF" sqlType="STRING"/>
		<param defaultValue="P" name="TIPO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="profesiones">
		<call-query href="insertProfesiones">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="DESCRIPCIONPROF" query-param="DESCRIPCIONPROF"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteProfesiones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PROFESIONES WHERE PROFESIONES.CODIGOPROF= :KEY_CODIGOPROF</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGOPROF" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="profesiones">
		<call-query href="deleteProfesiones">
			<with-param name="KEY_CODIGOPROF" query-param="KEY_CODIGOPROF"/>

		</call-query>
	</resource>
	<query id="getProfesionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION, PROFESIONES.DESCRIPCIONPROF, ( CASE PROFESIONES.TIPO WHEN 'P' THEN 'Profesiones' WHEN 'G' THEN 'Posgrados' WHEN 'M' THEN 'Maestrías' ELSE 'Otro' END ) TIPO_LB, TIPO  FROM PROFESIONES ORDER BY PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%')  AND (CASE WHEN DESCRIPCIONPROF IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONPROF) END)  LIKE UPPER( '%' || :DESCRIPCIONPROF || '%')  AND (CASE WHEN TIPO_LB IS NULL THEN ' ' ELSE UPPER(TIPO_LB) END)  LIKE UPPER( '%' || :TIPO_LB || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOPROF":"$CODIGOPROF","NOMBRE_PROFESION":"$NOMBRE_PROFESION","DESCRIPCIONPROF":"$DESCRIPCIONPROF","TIPO_LB":"$TIPO_LB","TIPO":"$TIPO"}]}}		</result>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="DESCRIPCIONPROF" sqlType="STRING"/>
		<param name="TIPO_LB" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="profesiones">
		<call-query href="getProfesionesPaginaQuery">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="DESCRIPCIONPROF" query-param="DESCRIPCIONPROF"/>
			<with-param name="TIPO_LB" query-param="TIPO_LB"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProfesionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION, PROFESIONES.DESCRIPCIONPROF, ( CASE PROFESIONES.TIPO WHEN 'P' THEN 'Profesiones' WHEN 'G' THEN 'Posgrados' WHEN 'M' THEN 'Maestrías' ELSE 'Otro' END ) TIPO_LB, TIPO  FROM PROFESIONES ORDER BY PROFESIONES.CODIGOPROF, PROFESIONES.NOMBRE_PROFESION) WHERE (CASE WHEN CODIGOPROF IS NULL THEN ' ' ELSE UPPER(CODIGOPROF) END)  LIKE UPPER(:CODIGOPROF || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%')  AND (CASE WHEN DESCRIPCIONPROF IS NULL THEN ' ' ELSE UPPER(DESCRIPCIONPROF) END)  LIKE UPPER( '%' || :DESCRIPCIONPROF || '%')  AND (CASE WHEN TIPO_LB IS NULL THEN ' ' ELSE UPPER(TIPO_LB) END)  LIKE UPPER( '%' || :TIPO_LB || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="DESCRIPCIONPROF" sqlType="STRING"/>
		<param name="TIPO_LB" sqlType="STRING"/>

	</query>
	<resource method="GET" path="profesiones/numero">
		<call-query href="getProfesionesNumeroQuery">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="DESCRIPCIONPROF" query-param="DESCRIPCIONPROF"/>
			<with-param name="TIPO_LB" query-param="TIPO_LB"/>

		</call-query>
	</resource>
	<query id="updateProfesiones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROFESIONES SET CODIGOPROF=:CODIGOPROF, NOMBRE_PROFESION=:NOMBRE_PROFESION, DESCRIPCIONPROF=:DESCRIPCIONPROF, TIPO=:TIPO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PROFESIONES.CODIGOPROF= :KEY_CODIGOPROF</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOPROF" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="DESCRIPCIONPROF" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGOPROF" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="profesiones">
		<call-query href="updateProfesiones">
			<with-param name="CODIGOPROF" query-param="CODIGOPROF"/>
			<with-param name="NOMBRE_PROFESION" query-param="NOMBRE_PROFESION"/>
			<with-param name="DESCRIPCIONPROF" query-param="DESCRIPCIONPROF"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGOPROF" query-param="KEY_CODIGOPROF"/>

		</call-query>
	</resource>

</data>