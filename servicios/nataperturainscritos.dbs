<data name="nataperturainscritos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNataperturainscritosPagDocumentoYNombreParaCalificarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_APERTURA_INSCRITOS.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.NOMBRE, NAT_APERTURA_INSCRITOS.SUCURSAL  FROM NAT_APERTURA_INSCRITOS WHERE NAT_APERTURA_INSCRITOS.COMPANIA =:COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA =:CONVOCATORIA AND NAT_APERTURA_INSCRITOS.RECHAZOEXPERIENCIA IN ( 0 ) AND NAT_APERTURA_INSCRITOS.RECHAZOESTUDIOS IN ( 0 ) AND NAT_APERTURA_INSCRITOS.RECHAZOOTROS IN ( 0 ) ORDER BY NAT_APERTURA_INSCRITOS.NUMERO_DCTO) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nataperturainscritos/documentoynombreparacalificar/pag">
		<call-query href="getNataperturainscritosPagDocumentoYNombreParaCalificarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosNumDocumentoYNombreParaCalificarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA_INSCRITOS.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.NOMBRE, NAT_APERTURA_INSCRITOS.SUCURSAL  FROM NAT_APERTURA_INSCRITOS WHERE NAT_APERTURA_INSCRITOS.COMPANIA =:COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA =:CONVOCATORIA AND NAT_APERTURA_INSCRITOS.RECHAZOEXPERIENCIA IN ( 0 ) AND NAT_APERTURA_INSCRITOS.RECHAZOESTUDIOS IN ( 0 ) AND NAT_APERTURA_INSCRITOS.RECHAZOOTROS IN ( 0 ) ORDER BY NAT_APERTURA_INSCRITOS.NUMERO_DCTO) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nataperturainscritos/documentoynombreparacalificar/num">
		<call-query href="getNataperturainscritosNumDocumentoYNombreParaCalificarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosPagGrillaAperturainscrQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_APERTURA_INSCRITOS.COMPANIA, NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA, NAT_APERTURA_INSCRITOS.SUCURSAL, NAT_APERTURA_INSCRITOS.NUMERO_DCTO, TERCERO.NOMBRE NOMBRES,(CASE NAT_APERTURA_INSCRITOS.RECHAZOEXPERIENCIA WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOEXPERIENCIA,(CASE NAT_APERTURA_INSCRITOS.RECHAZOESTUDIOS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOESTUDIOS,(CASE NAT_APERTURA_INSCRITOS.RECHAZOOTROS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOOTROS, NAT_APERTURA_INSCRITOS.OBSERVACIONES  FROM NAT_APERTURA_INSCRITOS LEFT JOIN TERCERO ON NAT_APERTURA_INSCRITOS.COMPANIA = TERCERO.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = TERCERO.NIT AND NAT_APERTURA_INSCRITOS.SUCURSAL = TERCERO.SUCURSAL WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :KEY_NRO_CONVOCATORIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER( '%' || :NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER(:NOMBRES || '%')  AND (CASE WHEN RECHAZOEXPERIENCIA IS NULL THEN ' ' ELSE UPPER(RECHAZOEXPERIENCIA) END)  LIKE UPPER(:RECHAZOEXPERIENCIA || '%')  AND (CASE WHEN RECHAZOESTUDIOS IS NULL THEN ' ' ELSE UPPER(RECHAZOESTUDIOS) END)  LIKE UPPER(:RECHAZOESTUDIOS || '%')  AND (CASE WHEN RECHAZOOTROS IS NULL THEN ' ' ELSE UPPER(RECHAZOOTROS) END)  LIKE UPPER( '%' || :RECHAZOOTROS || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","SUCURSAL":"$SUCURSAL","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRES":"$NOMBRES","RECHAZOEXPERIENCIA":"$RECHAZOEXPERIENCIA(type:boolean)","RECHAZOESTUDIOS":"$RECHAZOESTUDIOS(type:boolean)","RECHAZOOTROS":"$RECHAZOOTROS(type:boolean)","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="RECHAZOEXPERIENCIA" sqlType="STRING"/>
		<param name="RECHAZOESTUDIOS" sqlType="STRING"/>
		<param name="RECHAZOOTROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nataperturainscritos/grillaaperturainscr/pag">
		<call-query href="getNataperturainscritosPagGrillaAperturainscrQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="RECHAZOEXPERIENCIA" query-param="RECHAZOEXPERIENCIA"/>
			<with-param name="RECHAZOESTUDIOS" query-param="RECHAZOESTUDIOS"/>
			<with-param name="RECHAZOOTROS" query-param="RECHAZOOTROS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosNumGrillaAperturainscrQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA_INSCRITOS.COMPANIA, NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA, NAT_APERTURA_INSCRITOS.SUCURSAL, NAT_APERTURA_INSCRITOS.NUMERO_DCTO, TERCERO.NOMBRE NOMBRES,(CASE NAT_APERTURA_INSCRITOS.RECHAZOEXPERIENCIA WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOEXPERIENCIA,(CASE NAT_APERTURA_INSCRITOS.RECHAZOESTUDIOS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOESTUDIOS,(CASE NAT_APERTURA_INSCRITOS.RECHAZOOTROS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOOTROS, NAT_APERTURA_INSCRITOS.OBSERVACIONES  FROM NAT_APERTURA_INSCRITOS LEFT JOIN TERCERO ON NAT_APERTURA_INSCRITOS.COMPANIA = TERCERO.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = TERCERO.NIT AND NAT_APERTURA_INSCRITOS.SUCURSAL = TERCERO.SUCURSAL WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :KEY_NRO_CONVOCATORIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER( '%' || :NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER(:NOMBRES || '%')  AND (CASE WHEN RECHAZOEXPERIENCIA IS NULL THEN ' ' ELSE UPPER(RECHAZOEXPERIENCIA) END)  LIKE UPPER(:RECHAZOEXPERIENCIA || '%')  AND (CASE WHEN RECHAZOESTUDIOS IS NULL THEN ' ' ELSE UPPER(RECHAZOESTUDIOS) END)  LIKE UPPER(:RECHAZOESTUDIOS || '%')  AND (CASE WHEN RECHAZOOTROS IS NULL THEN ' ' ELSE UPPER(RECHAZOOTROS) END)  LIKE UPPER( '%' || :RECHAZOOTROS || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="RECHAZOEXPERIENCIA" sqlType="STRING"/>
		<param name="RECHAZOESTUDIOS" sqlType="STRING"/>
		<param name="RECHAZOOTROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nataperturainscritos/grillaaperturainscr/num">
		<call-query href="getNataperturainscritosNumGrillaAperturainscrQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="RECHAZOEXPERIENCIA" query-param="RECHAZOEXPERIENCIA"/>
			<with-param name="RECHAZOESTUDIOS" query-param="RECHAZOESTUDIOS"/>
			<with-param name="RECHAZOOTROS" query-param="RECHAZOOTROS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="updateNataperturainscritosActuaAperturainscr" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_APERTURA_INSCRITOS SET COMPANIA=:COMPANIA, NRO_CONVOCATORIA=:NRO_CONVOCATORIA, SUCURSAL=:SUCURSAL, NUMERO_DCTO=:NUMERO_DCTO, RECHAZOEXPERIENCIA=:RECHAZOEXPERIENCIA, RECHAZOESTUDIOS=:RECHAZOESTUDIOS, RECHAZOOTROS=:RECHAZOOTROS, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_APERTURA_INSCRITOS.COMPANIA= :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_APERTURA_INSCRITOS.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="RECHAZOEXPERIENCIA" sqlType="STRING"/>
		<param name="RECHAZOESTUDIOS" sqlType="STRING"/>
		<param name="RECHAZOOTROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="nataperturainscritos/actuaaperturainscr">
		<call-query href="updateNataperturainscritosActuaAperturainscr">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="RECHAZOEXPERIENCIA" query-param="RECHAZOEXPERIENCIA"/>
			<with-param name="RECHAZOESTUDIOS" query-param="RECHAZOESTUDIOS"/>
			<with-param name="RECHAZOOTROS" query-param="RECHAZOOTROS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="deleteNataperturainscritosBorrarAperturainscr" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_APERTURA_INSCRITOS WHERE NAT_APERTURA_INSCRITOS.COMPANIA       = :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :KEY_NRO_CONVOCATORIA AND NUMERO_DCTO                             = :KEY_NUMERO_DCTO AND SUCURSAL                                = :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="nataperturainscritos/borraraperturainscr">
		<call-query href="deleteNataperturainscritosBorrarAperturainscr">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosFechaenvioporconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NAT_APERTURA_INSCRITOS.FECHA_ENVIO_CORREO_INSCRITOS,'dd/MM/yyyy') FECHA_ENVIO_CORREO  FROM NAT_APERTURA_INSCRITOS WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :NRO_CONVOCATORIA AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA_ENVIO_CORREO":"$FECHA_ENVIO_CORREO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nataperturainscritos/fechaenvioporconvocatoria">
		<call-query href="getNataperturainscritosFechaenvioporconvocatoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosFechacorreosrechazadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NAT_APERTURA_INSCRITOS.FECHA_ENVIO_CORREO_RECHAZADOS,'dd/MM/yyyy') FECHA_ENVIO_CORREO_RECHAZADOS, TO_CHAR(NAT_APERTURA_INSCRITOS.FECHA_ENVIO_CORREO_APROBADOS,'dd/MM/yyyy') FECHA_ENVIO_CORREO_APROBADOS  FROM NAT_APERTURA_INSCRITOS WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :NRO_CONVOCATORIA AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA_ENVIO_CORREO_RECHAZADOS":"$FECHA_ENVIO_CORREO_RECHAZADOS","FECHA_ENVIO_CORREO_APROBADOS":"$FECHA_ENVIO_CORREO_APROBADOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nataperturainscritos/fechacorreosrechazados">
		<call-query href="getNataperturainscritosFechacorreosrechazadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosPagEvaluaciondedocumentosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_APERTURA_INSCRITOS.COMPANIA, NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA, NAT_APERTURA_INSCRITOS.CONSECUTIVO, NAT_APERTURA_INSCRITOS.SUCURSAL, NAT_APERTURA_INSCRITOS.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.NOMBRE NOMBRES,(CASE NAT_APERTURA_INSCRITOS.RECHAZOEXPERIENCIA WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOEXPERIENCIA,(CASE NAT_APERTURA_INSCRITOS.RECHAZOESTUDIOS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOESTUDIOS,(CASE NAT_APERTURA_INSCRITOS.RECHAZOOTROS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOOTROS, NAT_APERTURA_INSCRITOS.OBSERVACIONES,(CASE NAT_APERTURA.CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA, (SELECT COUNT (1) FROM NAT_CALIFICACION_PRUEBAS WHERE NAT_CALIFICACION_PRUEBAS.COMPANIA = NAT_APERTURA_INSCRITOS.COMPANIA AND NAT_CALIFICACION_PRUEBAS.NRO_CONVOCATORIA = NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA AND NAT_CALIFICACION_PRUEBAS.SUCURSAL = NAT_APERTURA_INSCRITOS.SUCURSAL AND NAT_CALIFICACION_PRUEBAS.NUMERO_DCTO = NAT_APERTURA_INSCRITOS.NUMERO_DCTO ) AS CANTIDAD_CAL  FROM NAT_APERTURA_INSCRITOS LEFT JOIN TERCERO ON NAT_APERTURA_INSCRITOS.COMPANIA = TERCERO.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = TERCERO.NIT AND NAT_APERTURA_INSCRITOS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN NAT_APERTURA ON NAT_APERTURA_INSCRITOS.COMPANIA = NAT_APERTURA.COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = NAT_APERTURA.NRO_CONVOCATORIA WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :KEY_NRO_CONVOCATORIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN RECHAZOEXPERIENCIA IS NULL THEN ' ' ELSE UPPER(RECHAZOEXPERIENCIA) END)  LIKE UPPER(:RECHAZOEXPERIENCIA || '%')  AND (CASE WHEN RECHAZOESTUDIOS IS NULL THEN ' ' ELSE UPPER(RECHAZOESTUDIOS) END)  LIKE UPPER(:RECHAZOESTUDIOS || '%')  AND (CASE WHEN RECHAZOOTROS IS NULL THEN ' ' ELSE UPPER(RECHAZOOTROS) END)  LIKE UPPER(:RECHAZOOTROS || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN CERRADA IS NULL THEN ' ' ELSE UPPER(CERRADA) END)  LIKE UPPER( '%' || :CERRADA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","SUCURSAL":"$SUCURSAL","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRES":"$NOMBRES","RECHAZOEXPERIENCIA":"$RECHAZOEXPERIENCIA(type:boolean)","RECHAZOESTUDIOS":"$RECHAZOESTUDIOS(type:boolean)","RECHAZOOTROS":"$RECHAZOOTROS(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","CERRADA":"$CERRADA(type:boolean)","CANTIDAD_CAL":"$CANTIDAD_CAL(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="RECHAZOEXPERIENCIA" sqlType="STRING"/>
		<param name="RECHAZOESTUDIOS" sqlType="STRING"/>
		<param name="RECHAZOOTROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="CERRADA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
