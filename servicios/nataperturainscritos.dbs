	<query id="getNataperturainscritosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT NAT_APERTURA_INSCRITOS.COMPANIA, NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA, NAT_APERTURA_INSCRITOS.SUCURSAL, NAT_APERTURA_INSCRITOS.NRO_FORMULARIO, NAT_APERTURA_INSCRITOS.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.FOLIOS, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',TERCERO.NOMBRE) ) ) ) NOMBRES, TERCERO.DIRECCION, TERCERO.TELEFONOS TELEFONO, NAT_APERTURA_INSCRITOS.DIRECCIONEMAIL FROM NAT_APERTURA_INSCRITOS LEFT JOIN TERCERO ON NAT_APERTURA_INSCRITOS.COMPANIA = TERCERO.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = TERCERO.NIT AND NAT_APERTURA_INSCRITOS.SUCURSAL = TERCERO.SUCURSAL WHERE NAT_APERTURA_INSCRITOS.COMPANIA= :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_APERTURA_INSCRITOS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","SUCURSAL":"$SUCURSAL","NRO_FORMULARIO":"$NRO_FORMULARIO","NUMERO_DCTO":"$NUMERO_DCTO","FOLIOS":"$FOLIOS","NOMBRES":"$NOMBRES","DIRECCION":"$DIRECCION","TELEFONO":"$TELEFONO","DIRECCIONEMAIL":"$DIRECCIONEMAIL"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nataperturainscritos/data">
