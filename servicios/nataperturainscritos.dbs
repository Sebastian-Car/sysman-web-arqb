			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateNataperturainscritos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_APERTURA_INSCRITOS SET CONSECUTIVO=:CONSECUTIVO, DIRECCION=:DIRECCION, DIRECCIONEMAIL=:DIRECCIONEMAIL, FOLIOS=:FOLIOS, NOMBRE=:NOMBRE, NRO_FORMULARIO=:NRO_FORMULARIO, NRO_CONVOCATORIA=:NRO_CONVOCATORIA, NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, TELEFONO=:TELEFONO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_APERTURA_INSCRITOS.COMPANIA= :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_APERTURA_INSCRITOS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="DIRECCIONEMAIL" sqlType="STRING"/>
		<param name="FOLIOS" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NRO_FORMULARIO" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
