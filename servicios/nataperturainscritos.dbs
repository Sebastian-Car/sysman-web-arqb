	<query id="insertNataperturainscritos" keyColumns="COMPANIA,NRO_CONVOCATORIA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_APERTURA_INSCRITOS (COMPANIA, CONSECUTIVO, DIRECCION, DIRECCIONEMAIL, FECHA_RECIBO, FOLIOS, NOMBRE, NRO_CONVOCATORIA, NRO_FORMULARIO, NUMERO_DCTO, SUCURSAL, TELEFONO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONSECUTIVO, :DIRECCION, :DIRECCIONEMAIL, TO_DATE(:FECHA_RECIBO,'DD/MM/YYYY HH24:MI:SS'), :FOLIOS, :NOMBRE, :NRO_CONVOCATORIA, :NRO_FORMULARIO, :NUMERO_DCTO, :SUCURSAL, :TELEFONO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCIONEMAIL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_RECIBO" sqlType="STRING"/>
		<param defaultValue="0" name="FOLIOS" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param defaultValue="" name="NRO_FORMULARIO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
