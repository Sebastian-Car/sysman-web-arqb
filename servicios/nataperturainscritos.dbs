	<query id="getNataperturainscritosCorreodenoaprobadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LISTAGG(DIRECCIONEMAIL, ',') WITHIN GROUP (ORDER BY DIRECCIONEMAIL) CORREOS_DESTINO  FROM NAT_APERTURA_INSCRITOS WHERE COMPANIA = :COMPANIA AND NRO_CONVOCATORIA = :NRO_CONVOCATORIA AND (RECHAZOEXPERIENCIA IN (-1) OR RECHAZOESTUDIOS IN (-1) OR RECHAZOOTROS IN (-1))</sql>
