	<query id="getNataperturainscritosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA_INSCRITOS.COMPANIA, NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA, NAT_APERTURA_INSCRITOS.CONSECUTIVO, NAT_APERTURA_INSCRITOS.SUCURSAL, NAT_APERTURA_INSCRITOS.NRO_FORMULARIO, NAT_APERTURA_INSCRITOS.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.FOLIOS, NAT_APERTURA_INSCRITOS.DIRECCIONEMAIL, NAT_APERTURA_INSCRITOS.NOMBRE , NAT_APERTURA_INSCRITOS.DIRECCION, NAT_APERTURA_INSCRITOS.TELEFONO,(CASE NAT_APERTURA.CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA, (SELECT COUNT (1) FROM NAT_CALIFICACION_PRUEBAS WHERE NAT_CALIFICACION_PRUEBAS.COMPANIA = NAT_APERTURA_INSCRITOS.COMPANIA AND NAT_CALIFICACION_PRUEBAS.NRO_CONVOCATORIA = NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA AND NAT_CALIFICACION_PRUEBAS.SUCURSAL = NAT_APERTURA_INSCRITOS.SUCURSAL AND NAT_CALIFICACION_PRUEBAS.NUMERO_DCTO = NAT_APERTURA_INSCRITOS.NUMERO_DCTO ) AS CANTIDAD_CAL  FROM NAT_APERTURA_INSCRITOS LEFT JOIN TERCERO ON NAT_APERTURA_INSCRITOS.COMPANIA = TERCERO.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = TERCERO.NIT AND NAT_APERTURA_INSCRITOS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN NAT_APERTURA ON NAT_APERTURA_INSCRITOS.COMPANIA = NAT_APERTURA.COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = NAT_APERTURA.NRO_CONVOCATORIA WHERE NAT_APERTURA_INSCRITOS.COMPANIA =:COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :CONVOCATORIA ORDER BY NAT_APERTURA_INSCRITOS.NRO_FORMULARIO, NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%')  AND (CASE WHEN NRO_FORMULARIO IS NULL THEN ' ' ELSE UPPER(NRO_FORMULARIO) END)  LIKE UPPER( '%' || :NRO_FORMULARIO || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER( '%' || :NUMERO_DCTO || '%')  AND (CASE WHEN FOLIOS IS NULL THEN ' ' ELSE UPPER(FOLIOS) END)  LIKE UPPER( '%' || :FOLIOS || '%')  AND (CASE WHEN DIRECCIONEMAIL IS NULL THEN ' ' ELSE UPPER(DIRECCIONEMAIL) END)  LIKE UPPER( '%' || :DIRECCIONEMAIL || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END)  LIKE UPPER( '%' || :TELEFONO || '%')  AND (CASE WHEN CERRADA IS NULL THEN ' ' ELSE UPPER(CERRADA) END)  LIKE UPPER( '%' || :CERRADA || '%')  AND (CASE WHEN CANTIDAD_CAL IS NULL THEN ' ' ELSE UPPER(CANTIDAD_CAL) END)  LIKE UPPER( '%' || :CANTIDAD_CAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NRO_FORMULARIO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="FOLIOS" sqlType="STRING"/>
		<param name="DIRECCIONEMAIL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="CERRADA" sqlType="STRING"/>
		<param name="CANTIDAD_CAL" sqlType="STRING"/>

	</query>
