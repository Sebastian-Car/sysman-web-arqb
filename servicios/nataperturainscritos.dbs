	<query id="getNataperturainscritosCorreosfechaconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NAT_APERTURA_INSCRITOS.FECHA_ENVIO_ACP,'dd/MM/yyyy') FECHA_ENVIO_ACP, TO_CHAR(NAT_APERTURA_INSCRITOS.FECHA_ENVIO_RCZ,'dd/MM/yyyy') FECHA_ENVIO_RCZ  FROM NAT_APERTURA_INSCRITOS WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :NRO_CONVOCATORIA AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA_ENVIO_ACP":"$FECHA_ENVIO_ACP","FECHA_ENVIO_RCZ":"$FECHA_ENVIO_RCZ"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
