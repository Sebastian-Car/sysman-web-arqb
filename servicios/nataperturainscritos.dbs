	<query id="getNataperturainscritosCorreodeaprobadosevaluacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LISTAGG(NAT_APERTURA_INSCRITOS.DIRECCIONEMAIL,',') WITHIN GROUP (ORDER BY DIRECCIONEMAIL) CORREOS_DESTINO  FROM NAT_ELEGIBLES INNER JOIN NAT_APERTURA_INSCRITOS ON NAT_ELEGIBLES.COMPANIA = NAT_APERTURA_INSCRITOS.COMPANIA AND NAT_ELEGIBLES.NUMERO_DCTO = NAT_APERTURA_INSCRITOS.NUMERO_DCTO WHERE NAT_ELEGIBLES.COMPANIA = :COMPANIA AND NAT_ELEGIBLES.NRO_CONVOCATORIA = :NRO_CONVOCATORIA AND NAT_APERTURA_INSCRITOS.DIRECCIONEMAIL IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CORREOS_DESTINO":"$CORREOS_DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nataperturainscritos/correodeaprobadosevaluacion">
		<call-query href="getNataperturainscritosCorreodeaprobadosevaluacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosCorreodenoaprobadosevaluacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LISTAGG(NAT_APERTURA_INSCRITOS.DIRECCIONEMAIL,',') WITHIN GROUP ( ORDER BY DIRECCIONEMAIL) CORREOS_DESTINO  FROM NAT_APERTURA_INSCRITOS WHERE NUMERO_DCTO IN ( SELECT NUMERO_DCTO FROM ( SELECT NUMERO_DCTO FROM NAT_APERTURA_INSCRITOS WHERE COMPANIA = :COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :NRO_CONVOCATORIA AND RECHAZOEXPERIENCIA IN (0) AND RECHAZOESTUDIOS IN (0) AND RECHAZOOTROS IN (0) ) WHERE COMPANIA = :COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :NRO_CONVOCATORIA MINUS SELECT NUMERO_DCTO FROM NAT_ELEGIBLES WHERE COMPANIA = :COMPANIA AND NRO_CONVOCATORIA = :NRO_CONVOCATORIA ) AND DIRECCIONEMAIL IS NOT NULL AND NRO_CONVOCATORIA = :NRO_CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CORREOS_DESTINO":"$CORREOS_DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nataperturainscritos/correodenoaprobadosevaluacion">
		<call-query href="getNataperturainscritosCorreodenoaprobadosevaluacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="getNataperturainscritosValidarinscritosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM NAT_APERTURA_INSCRITOS WHERE COMPANIA = :COMPANIA AND NRO_CONVOCATORIA = :NRO_CONVOCATORIA AND NUMERO_DCTO = :NUMERO_DCTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>

	</query>
