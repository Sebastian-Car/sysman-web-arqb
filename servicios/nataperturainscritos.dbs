	<query id="getNataperturainscritosCorreosporconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LISTAGG(DIRECCIONEMAIL, ',') WITHIN GROUP (ORDER BY DIRECCIONEMAIL) CORREOS_DESTINO  FROM NAT_APERTURA_INSCRITOS WHERE COMPANIA = :COMPANIA AND NRO_CONVOCATORIA = :NRO_CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CORREOS_DESTINO":"$CORREOS_DESTINO"}]}}		</result>
