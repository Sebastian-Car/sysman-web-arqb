		</call-query>
	</resource>
	<query id="getNataperturainscritosNumEvaluaciondedocumentosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA_INSCRITOS.COMPANIA, NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA, NAT_APERTURA_INSCRITOS.CONSECUTIVO, NAT_APERTURA_INSCRITOS.SUCURSAL, NAT_APERTURA_INSCRITOS.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.NOMBRE NOMBRES,(CASE NAT_APERTURA_INSCRITOS.RECHAZOEXPERIENCIA WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOEXPERIENCIA,(CASE NAT_APERTURA_INSCRITOS.RECHAZOESTUDIOS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOESTUDIOS,(CASE NAT_APERTURA_INSCRITOS.RECHAZOOTROS WHEN 0 THEN 'false' ELSE 'true' END) RECHAZOOTROS, NAT_APERTURA_INSCRITOS.OBSERVACIONES,(CASE NAT_APERTURA.CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA, (SELECT COUNT (1) FROM NAT_CALIFICACION_PRUEBAS WHERE NAT_CALIFICACION_PRUEBAS.COMPANIA = NAT_APERTURA_INSCRITOS.COMPANIA AND NAT_CALIFICACION_PRUEBAS.NRO_CONVOCATORIA = NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA AND NAT_CALIFICACION_PRUEBAS.SUCURSAL = NAT_APERTURA_INSCRITOS.SUCURSAL AND NAT_CALIFICACION_PRUEBAS.NUMERO_DCTO = NAT_APERTURA_INSCRITOS.NUMERO_DCTO ) AS CANTIDAD_CAL  FROM NAT_APERTURA_INSCRITOS LEFT JOIN TERCERO ON NAT_APERTURA_INSCRITOS.COMPANIA = TERCERO.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = TERCERO.NIT AND NAT_APERTURA_INSCRITOS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN NAT_APERTURA ON NAT_APERTURA_INSCRITOS.COMPANIA = NAT_APERTURA.COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = NAT_APERTURA.NRO_CONVOCATORIA WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :KEY_COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :KEY_NRO_CONVOCATORIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN RECHAZOEXPERIENCIA IS NULL THEN ' ' ELSE UPPER(RECHAZOEXPERIENCIA) END)  LIKE UPPER(:RECHAZOEXPERIENCIA || '%')  AND (CASE WHEN RECHAZOESTUDIOS IS NULL THEN ' ' ELSE UPPER(RECHAZOESTUDIOS) END)  LIKE UPPER(:RECHAZOESTUDIOS || '%')  AND (CASE WHEN RECHAZOOTROS IS NULL THEN ' ' ELSE UPPER(RECHAZOOTROS) END)  LIKE UPPER(:RECHAZOOTROS || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN CERRADA IS NULL THEN ' ' ELSE UPPER(CERRADA) END)  LIKE UPPER( '%' || :CERRADA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="RECHAZOEXPERIENCIA" sqlType="STRING"/>
		<param name="RECHAZOESTUDIOS" sqlType="STRING"/>
		<param name="RECHAZOOTROS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="CERRADA" sqlType="STRING"/>

	</query>
