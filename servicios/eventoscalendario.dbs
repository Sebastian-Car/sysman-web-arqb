<data name="eventoscalendario" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getEventoscalendarioOrdenPorFechasQuery"  useConfig="sysmanirisst">
		<sql>SELECT  DESCRIPCION,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL FROM EVENTOS_CALENDARIO WHERE ( ( (FECHA_INICIAL &gt;= TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS') AND FECHA_INICIAL &lt; TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) OR (FECHA_FINAL &gt; TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS') AND FECHA_FINAL &lt;= TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) ) OR ( (TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS') &gt;= FECHA_INICIAL AND TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS') &lt; FECHA_FINAL) OR (TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') &gt; FECHA_INICIAL AND TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') &lt;= FECHA_FINAL)) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION":"$DESCRIPCION","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL"}]}}		</result>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="eventoscalendario/ordenporfechas">
		<call-query href="getEventoscalendarioOrdenPorFechasQuery">
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>

		</call-query>
	</resource>
	<query id="updateEventoscalendarioUpdateleido" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE EVENTOS_CALENDARIO    SET LEIDO = :CODIGO  WHERE CODIGO IN (     SELECT CODIGO       FROM EVENTOS_CALENDARIO      WHERE TRUNC(SYSDATE) BETWEEN TRUNC(FECHA_INICIAL) AND TRUNC(FECHA_FINAL)        AND BANNER &lt;&gt; 0  )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="eventoscalendario/updateleido">
		<call-query href="updateEventoscalendarioUpdateleido">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getEventoscalendarioNotificacionespordiaQuery"  useConfig="sysmanirisst">
		<sql>SELECT  CODIGO,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,DESCRIPCION  FROM EVENTOS_CALENDARIO WHERE TRUNC(SYSDATE) BETWEEN TRUNC(FECHA_INICIAL) AND TRUNC(FECHA_FINAL) AND BANNER &lt;&gt; 0 AND LEIDO = 0 ORDER BY FECHA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
 
	</query>
	<resource method="GET" path="eventoscalendario/notificacionespordia">
		<call-query href="getEventoscalendarioNotificacionespordiaQuery">
 
		</call-query>
	</resource>
	<query id="insertEventoscalendario" keyColumns="CODIGO" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO EVENTOS_CALENDARIO (FECHA_INICIAL, FECHA_FINAL, DESCRIPCION, BANNER, DATE_CREATED, CREATED_BY) VALUES (TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, :BANNER, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="BANNER" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="eventoscalendario">
		<call-query href="insertEventoscalendario">
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="BANNER" query-param="BANNER"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEventoscalendario" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM EVENTOS_CALENDARIO WHERE EVENTOS_CALENDARIO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="eventoscalendario">
		<call-query href="deleteEventoscalendario">
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getEventoscalendarioPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, DESCRIPCION ,(CASE BANNER WHEN 0 THEN 'false' ELSE 'true' END) BANNER FROM EVENTOS_CALENDARIO ORDER BY EVENTOS_CALENDARIO.FECHA_INICIAL, EVENTOS_CALENDARIO.FECHA_FINAL) INI WHERE (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END) LIKE UPPER(CONCAT(:FECHA_INICIAL, '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(:FECHA_FINAL, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN BANNER IS NULL THEN ' ' ELSE UPPER(BANNER) END) LIKE UPPER(CONCAT(:BANNER, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","DESCRIPCION":"$DESCRIPCION","BANNER":"$BANNER(type:boolean)"}]}}		</result>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="BANNER" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="eventoscalendario">
		<call-query href="getEventoscalendarioPaginaQuery">
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="BANNER" query-param="BANNER"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEventoscalendarioNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, DESCRIPCION ,(CASE BANNER WHEN 0 THEN 'false' ELSE 'true' END) BANNER FROM EVENTOS_CALENDARIO ORDER BY EVENTOS_CALENDARIO.FECHA_INICIAL, EVENTOS_CALENDARIO.FECHA_FINAL) INI WHERE (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END) LIKE UPPER(CONCAT(:FECHA_INICIAL, '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(:FECHA_FINAL, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN BANNER IS NULL THEN ' ' ELSE UPPER(BANNER) END) LIKE UPPER(CONCAT(:BANNER, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="BANNER" sqlType="STRING"/>

	</query>
	<resource method="GET" path="eventoscalendario/numero">
		<call-query href="getEventoscalendarioNumeroQuery">
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="BANNER" query-param="BANNER"/>

		</call-query>
	</resource>
	<query id="updateEventoscalendario" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE EVENTOS_CALENDARIO SET FECHA_INICIAL=TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, BANNER=:BANNER, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EVENTOS_CALENDARIO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="BANNER" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="eventoscalendario">
		<call-query href="updateEventoscalendario">
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="BANNER" query-param="BANNER"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>