		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","RESPONSABLEALMACEN":"$RESPONSABLEALMACEN(type:boolean)","SUCURSAL":"$SUCURSAL"}]}}		</result>
