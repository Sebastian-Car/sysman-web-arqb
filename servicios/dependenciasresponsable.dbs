	<query id="getDependenciasresponsableJefeunidadporusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT DEPENDENCIA FROM DEPENDENCIA_RESPONSABLE DT LEFT JOIN USUARIO U ON DT.RESPONSABLE = U.CEDULA AND DT.SUCURSAL = U.SUCURSAL WHERE DT.COMPANIA = :COMPANIA AND U.CODIGO = :CODIGO AND DT.JEFEUNIDAD NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
