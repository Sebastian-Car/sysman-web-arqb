	<query id="getDependenciasresponsableNumResponsablenombrecargodependenciasucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, TERCERO.NOMBRE, RESPONSABLE.CARGO, DEPENDENCIA_RESPONSABLE.DEPENDENCIA, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE LEFT JOIN RESPONSABLE ON (DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA) AND (DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA) LEFT JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
