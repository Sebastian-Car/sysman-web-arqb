		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, RESTER.CARGO, RESTER.SUCURSAL, ( CASE WHEN DEPENDENCIA_RESPONSABLE.JEFEUNIDAD NOT IN ( 0 ) THEN 'SI' ELSE 'NO' END ) JEFEUNIDAD, (CONCAT(RESTER.NOMBRE1 ,CONCAT( ' ' ,CONCAT( RESTER.NOMBRE2 ,CONCAT( ' ' ,CONCAT( RESTER.APELLIDO1 ,CONCAT( ' ' ,RESTER.APELLIDO2))) )))) NOMBRE FROM DEPENDENCIA_RESPONSABLE LEFT JOIN ( SELECT RESPONSABLE.COMPANIA, RESPONSABLE.CEDULA, RESPONSABLE.SUCURSAL, TERCERO.NOMBRE1, TERCERO.NOMBRE2, TERCERO.APELLIDO1, TERCERO.APELLIDO2, RESPONSABLE.CARGO FROM RESPONSABLE INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL ) RESTER ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESTER.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESTER.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESTER.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA =:COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA =:DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.JEFEUNIDAD NOT IN ( 0 ) ORDER BY NOMBRE) INI WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(:RESPONSABLE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
