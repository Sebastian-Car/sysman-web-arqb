	<query id="getDependenciasresponsableCargardependenciaresponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT DEPENDENCIA_RESPONSABLE.DEPENDENCIA, DEPENDENCIA.NOMBRE FROM DEPENDENCIA_RESPONSABLE INNER JOIN DEPENDENCIA ON DEPENDENCIA_RESPONSABLE.COMPANIA =DEPENDENCIA.COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA =DEPENDENCIA.CODIGO WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = :RESPONSABLE ORDER BY DEPENDENCIA_RESPONSABLE.DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEPENDENCIA":"$DEPENDENCIA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>

	</query>
