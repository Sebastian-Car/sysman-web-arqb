	<query id="getDependenciasresponsableNumResponsablepordepenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DEPENDENCIA_RESPONSABLE.COMPANIA, DEPENDENCIA_RESPONSABLE.DEPENDENCIA, DEPENDENCIA_RESPONSABLE.RESPONSABLE, DEPENDENCIA_RESPONSABLE.SUCURSAL, TERCERO.NOMBRE NOMRESPONSABLE, DEPENDENCIA_RESPONSABLE.CARGO,(CASE DEPENDENCIA_RESPONSABLE.RESPONSABLEALMACEN WHEN 0 THEN 'false' ELSE 'true' END) RESPONSABLEALMACEN,(CASE DEPENDENCIA_RESPONSABLE.JEFEUNIDAD WHEN 0 THEN 'false' ELSE 'true' END) JEFEUNIDAD,(CASE DEPENDENCIA_RESPONSABLE.ACTIVO_RECEP WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO_RECEP, DEPENDENCIA_RESPONSABLE.SUPERVISOR, DEPENDENCIA_RESPONSABLE.SUCURSAL_SUPERVISOR, TER_SUP.NOMBRE NOMBRESUPERVISOR FROM DEPENDENCIA_RESPONSABLE LEFT JOIN TERCERO ON TERCERO.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND TERCERO.NIT = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND TERCERO.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN TERCERO TER_SUP ON TER_SUP.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND TER_SUP.NIT = DEPENDENCIA_RESPONSABLE.SUPERVISOR AND TER_SUP.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL_SUPERVISOR WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA) INI WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(:RESPONSABLE, '%')) AND (CASE WHEN NOMRESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMRESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMRESPONSABLE), '%')) AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CARGO), '%')) AND (CASE WHEN RESPONSABLEALMACEN IS NULL THEN ' ' ELSE UPPER(RESPONSABLEALMACEN) END) LIKE UPPER(CONCAT(:RESPONSABLEALMACEN, '%')) AND (CASE WHEN JEFEUNIDAD IS NULL THEN ' ' ELSE UPPER(JEFEUNIDAD) END) LIKE UPPER(CONCAT(:JEFEUNIDAD, '%')) AND (CASE WHEN ACTIVO_RECEP IS NULL THEN ' ' ELSE UPPER(ACTIVO_RECEP) END) LIKE UPPER(CONCAT(:ACTIVO_RECEP, '%')) AND (CASE WHEN SUPERVISOR IS NULL THEN ' ' ELSE UPPER(SUPERVISOR) END) LIKE UPPER(CONCAT(:SUPERVISOR, '%')) AND (CASE WHEN SUCURSAL_SUPERVISOR IS NULL THEN ' ' ELSE UPPER(SUCURSAL_SUPERVISOR) END) LIKE UPPER(CONCAT(:SUCURSAL_SUPERVISOR, '%')) AND (CASE WHEN NOMBRESUPERVISOR IS NULL THEN ' ' ELSE UPPER(NOMBRESUPERVISOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRESUPERVISOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMRESPONSABLE" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="RESPONSABLEALMACEN" sqlType="STRING"/>
		<param name="JEFEUNIDAD" sqlType="STRING"/>
