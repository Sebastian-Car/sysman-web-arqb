	<query id="getDependenciasresponsableCargousuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CARGO  FROM DEPENDENCIA_RESPONSABLE WHERE COMPANIA = :COMPANIA AND RESPONSABLE = :RESPONSABLE AND RESPONSABLEALMACEN IN (-1)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CARGO":"$CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>

	</query>
