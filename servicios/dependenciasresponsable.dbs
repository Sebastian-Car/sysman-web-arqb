	<query id="getDependenciasresponsableConsultarJefeDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT DEPENDENCIA_RESPONSABLE.DEPENDENCIA CODAMISIONAL, DEPENDENCIA_RESPONSABLE.RESPONSABLE FUNCIONARIO  FROM DEPENDENCIA_RESPONSABLE INNER JOIN RESPONSABLE ON RESPONSABLE.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND RESPONSABLE.CEDULA = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND RESPONSABLE.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL INNER JOIN DEPENDENCIA ON DEPENDENCIA_RESPONSABLE.COMPANIA = DEPENDENCIA.COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN PERSONAL ON RESPONSABLE.COMPANIA = PERSONAL.COMPANIA AND RESPONSABLE.CEDULA = PERSONAL.NUMERO_DCTO AND RESPONSABLE.SUCURSAL = PERSONAL.SUCURSAL WHERE RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA.CODIGO = :DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.JEFEUNIDAD NOT IN (0) AND PERSONAL.ESTADO_ACTUAL NOT IN (3)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODAMISIONAL":"$CODAMISIONAL","FUNCIONARIO":"$FUNCIONARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
