<data name="dependenciasresponsable" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDependenciasresponsableSubdependenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPENDENCIA_RESPONSABLE.COMPANIA, DEPENDENCIA_RESPONSABLE.DEPENDENCIA, DEPENDENCIA_RESPONSABLE.RESPONSABLE, DEPENDENCIA_RESPONSABLE.SUCURSAL, (SELECT TERCERO.NOMBRE FROM TERCERO WHERE COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND NIT = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL) NOMRESPONSABLE, DEPENDENCIA_RESPONSABLE.CARGO,(CASE DEPENDENCIA_RESPONSABLE.RESPONSABLEALMACEN WHEN 0 THEN 'false' ELSE 'true' END) RESPONSABLEALMACEN,(CASE DEPENDENCIA_RESPONSABLE.JEFEUNIDAD WHEN 0 THEN 'false' ELSE 'true' END) JEFEUNIDAD,(CASE DEPENDENCIA_RESPONSABLE.ACTIVO_RECEP WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO_RECEP FROM DEPENDENCIA_RESPONSABLE WHERE COMPANIA= :COMPANIA AND DEPENDENCIA= :DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","NOMRESPONSABLE":"$NOMRESPONSABLE","CARGO":"$CARGO","RESPONSABLEALMACEN":"$RESPONSABLEALMACEN(type:boolean)","JEFEUNIDAD":"$JEFEUNIDAD(type:boolean)","ACTIVO_RECEP":"$ACTIVO_RECEP(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/subdependencias">
		<call-query href="getDependenciasresponsableSubdependenciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsablePagTerceroResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, TERCERO.NOMBRE, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE INNER JOIN TERCERO ON DEPENDENCIA_RESPONSABLE.COMPANIA=TERCERO.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE=TERCERO.NIT AND DEPENDENCIA_RESPONSABLE.SUCURSAL=TERCERO.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/terceroresponsable/pag">
		<call-query href="getDependenciasresponsablePagTerceroResponsableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsableNumTerceroResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, TERCERO.NOMBRE, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE INNER JOIN TERCERO ON DEPENDENCIA_RESPONSABLE.COMPANIA=TERCERO.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE=TERCERO.NIT AND DEPENDENCIA_RESPONSABLE.SUCURSAL=TERCERO.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/terceroresponsable/num">
		<call-query href="getDependenciasresponsableNumTerceroResponsableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsableDependenciaResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT DEPENDENCIA_RESPONSABLE.DEPENDENCIA, DEPENDENCIA.NOMBRE FROM DEPENDENCIA_RESPONSABLE INNER JOIN DEPENDENCIA ON DEPENDENCIA_RESPONSABLE.COMPANIA=DEPENDENCIA.COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA=DEPENDENCIA.CODIGO WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = :RESPONSABLE AND DEPENDENCIA_RESPONSABLE.SUCURSAL= :SUCURSAL ORDER BY DEPENDENCIA_RESPONSABLE.DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEPENDENCIA":"$DEPENDENCIA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/dependenciaresponsable">
		<call-query href="getDependenciasresponsableDependenciaResponsableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsableTodosPorCargoResponsableQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPENDENCIA_RESPONSABLE.CARGO  FROM DEPENDENCIA_RESPONSABLE WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA =:DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.CARGO IS NOT NULL ORDER BY DEPENDENCIA_RESPONSABLE.COMPANIA, DEPENDENCIA_RESPONSABLE.DEPENDENCIA, DEPENDENCIA_RESPONSABLE.CARGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CARGO":"$CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/todosporcargoresponsable">
		<call-query href="getDependenciasresponsableTodosPorCargoResponsableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsablePagTodosPorDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPENDENCIA_RESPONSABLE.RESPONSABLE, TRIM(TERCERO.NOMBRE) NOMBRE, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE LEFT JOIN TERCERO ON DEPENDENCIA_RESPONSABLE.RESPONSABLE = TERCERO.NIT AND DEPENDENCIA_RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA ORDER BY DEPENDENCIA_RESPONSABLE.RESPONSABLE) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/todospordependencia/pag">
		<call-query href="getDependenciasresponsablePagTodosPorDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsableNumTodosPorDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEPENDENCIA_RESPONSABLE.RESPONSABLE, TRIM(TERCERO.NOMBRE) NOMBRE, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE LEFT JOIN TERCERO ON DEPENDENCIA_RESPONSABLE.RESPONSABLE = TERCERO.NIT AND DEPENDENCIA_RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA ORDER BY DEPENDENCIA_RESPONSABLE.RESPONSABLE) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/todospordependencia/num">
		<call-query href="getDependenciasresponsableNumTodosPorDependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsablePagTodosPorCompaniaYDependQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, TERCERO.NOMBRE, CASE WHEN DEPENDENCIA_RESPONSABLE.JEFEUNIDAD &lt;&gt;0 THEN 'SI' ELSE 'NO' END AS JEFEUNIDAD, RESPONSABLE.CEDULA, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL INNER JOIN DEPENDENCIA ON DEPENDENCIA_RESPONSABLE.COMPANIA = DEPENDENCIA.COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRE":"$NOMBRE","JEFEUNIDAD":"$JEFEUNIDAD","CEDULA":"$CEDULA","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/todosporcompaniaydepend/pag">
		<call-query href="getDependenciasresponsablePagTodosPorCompaniaYDependQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsableNumTodosPorCompaniaYDependQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, TERCERO.NOMBRE, CASE WHEN DEPENDENCIA_RESPONSABLE.JEFEUNIDAD &lt;&gt;0 THEN 'SI' ELSE 'NO' END AS JEFEUNIDAD, RESPONSABLE.CEDULA, DEPENDENCIA_RESPONSABLE.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL INNER JOIN DEPENDENCIA ON DEPENDENCIA_RESPONSABLE.COMPANIA = DEPENDENCIA.COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/todosporcompaniaydepend/num">
		<call-query href="getDependenciasresponsableNumTodosPorCompaniaYDependQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertDependenciasresponsable" keyColumns="COMPANIA,DEPENDENCIA,RESPONSABLE,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DEPENDENCIA_RESPONSABLE (COMPANIA, DEPENDENCIA, RESPONSABLE, SUCURSAL, CARGO, RESPONSABLEALMACEN, JEFEUNIDAD, ACTIVO_RECEP, SUPERVISOR, SUCURSAL_SUPERVISOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DEPENDENCIA, :RESPONSABLE, :SUCURSAL, :CARGO, :RESPONSABLEALMACEN, :JEFEUNIDAD, :ACTIVO_RECEP, :SUPERVISOR, :SUCURSAL_SUPERVISOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DEPENDENCIA":"$DEPENDENCIA","KEY_RESPONSABLE":"$RESPONSABLE","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="CARGO" sqlType="STRING"/>
		<param defaultValue="0" name="RESPONSABLEALMACEN" sqlType="STRING"/>
		<param defaultValue="0" name="JEFEUNIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="ACTIVO_RECEP" sqlType="STRING"/>
		<param defaultValue="" name="SUPERVISOR" sqlType="STRING"/>
		<param defaultValue="" name="SUCURSAL_SUPERVISOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dependenciasresponsable">
		<call-query href="insertDependenciasresponsable">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="RESPONSABLEALMACEN" query-param="RESPONSABLEALMACEN"/>
			<with-param name="JEFEUNIDAD" query-param="JEFEUNIDAD"/>
			<with-param name="ACTIVO_RECEP" query-param="ACTIVO_RECEP"/>
			<with-param name="SUPERVISOR" query-param="SUPERVISOR"/>
			<with-param name="SUCURSAL_SUPERVISOR" query-param="SUCURSAL_SUPERVISOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDependenciasresponsable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DEPENDENCIA_RESPONSABLE WHERE DEPENDENCIA_RESPONSABLE.COMPANIA= :KEY_COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA= :KEY_DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE= :KEY_RESPONSABLE AND DEPENDENCIA_RESPONSABLE.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dependenciasresponsable">
		<call-query href="deleteDependenciasresponsable">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_RESPONSABLE" query-param="KEY_RESPONSABLE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsablePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DR.COMPANIA, TRIM(DR.DEPENDENCIA) DEPENDENCIA, TRIM(D.NOMBRE) NOMDEPENDENCIA, DR.RESPONSABLE,(CASE DR.RESPONSABLEALMACEN WHEN 0 THEN 'false' ELSE 'true' END) RESPONSABLEALMACEN,(CASE DR.JEFEUNIDAD WHEN 0 THEN 'false' ELSE 'true' END) JEFEUNIDAD,(CASE DR.ACTIVO_RECEP WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO_RECEP, DR.CARGO, DR.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE DR INNER JOIN DEPENDENCIA D ON DR.COMPANIA = D.COMPANIA AND DR.DEPENDENCIA = D.CODIGO WHERE DR.COMPANIA = :COMPANIA AND DR.RESPONSABLE = :CEDULA) WHERE (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN NOMDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMDEPENDENCIA || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DEPENDENCIA":"$DEPENDENCIA","NOMDEPENDENCIA":"$NOMDEPENDENCIA","RESPONSABLE":"$RESPONSABLE","RESPONSABLEALMACEN":"$RESPONSABLEALMACEN(type:boolean)","JEFEUNIDAD":"$JEFEUNIDAD(type:boolean)","ACTIVO_RECEP":"$ACTIVO_RECEP(type:boolean)","CARGO":"$CARGO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMDEPENDENCIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependenciasresponsable">
		<call-query href="getDependenciasresponsablePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMDEPENDENCIA" query-param="NOMDEPENDENCIA"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsableNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DR.COMPANIA, TRIM(DR.DEPENDENCIA) DEPENDENCIA, TRIM(D.NOMBRE) NOMDEPENDENCIA, DR.RESPONSABLE,(CASE DR.RESPONSABLEALMACEN WHEN 0 THEN 'false' ELSE 'true' END) RESPONSABLEALMACEN,(CASE DR.JEFEUNIDAD WHEN 0 THEN 'false' ELSE 'true' END) JEFEUNIDAD,(CASE DR.ACTIVO_RECEP WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO_RECEP, DR.CARGO, DR.SUCURSAL  FROM DEPENDENCIA_RESPONSABLE DR INNER JOIN DEPENDENCIA D ON DR.COMPANIA = D.COMPANIA AND DR.DEPENDENCIA = D.CODIGO WHERE DR.COMPANIA = :COMPANIA AND DR.RESPONSABLE = :CEDULA) WHERE (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN NOMDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMDEPENDENCIA || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMDEPENDENCIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/numero">
		<call-query href="getDependenciasresponsableNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMDEPENDENCIA" query-param="NOMDEPENDENCIA"/>
			<with-param name="CARGO" query-param="CARGO"/>

		</call-query>
	</resource>
	<query id="updateDependenciasresponsable" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEPENDENCIA_RESPONSABLE SET COMPANIA=:COMPANIA, DEPENDENCIA=:DEPENDENCIA, RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, CARGO=:CARGO, RESPONSABLEALMACEN=:RESPONSABLEALMACEN, JEFEUNIDAD=:JEFEUNIDAD, ACTIVO_RECEP=:ACTIVO_RECEP, SUPERVISOR=:SUPERVISOR, SUCURSAL_SUPERVISOR=:SUCURSAL_SUPERVISOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEPENDENCIA_RESPONSABLE.COMPANIA= :KEY_COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA= :KEY_DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE= :KEY_RESPONSABLE AND DEPENDENCIA_RESPONSABLE.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="RESPONSABLEALMACEN" sqlType="STRING"/>
		<param name="JEFEUNIDAD" sqlType="STRING"/>
		<param name="ACTIVO_RECEP" sqlType="STRING"/>
		<param name="SUPERVISOR" sqlType="STRING"/>
		<param name="SUCURSAL_SUPERVISOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dependenciasresponsable">
		<call-query href="updateDependenciasresponsable">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="RESPONSABLEALMACEN" query-param="RESPONSABLEALMACEN"/>
			<with-param name="JEFEUNIDAD" query-param="JEFEUNIDAD"/>
			<with-param name="ACTIVO_RECEP" query-param="ACTIVO_RECEP"/>
			<with-param name="SUPERVISOR" query-param="SUPERVISOR"/>
			<with-param name="SUCURSAL_SUPERVISOR" query-param="SUCURSAL_SUPERVISOR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_RESPONSABLE" query-param="KEY_RESPONSABLE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getDependenciasresponsablePagSucursalPorDependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, TERCERO.NOMBRE, RESPONSABLE.CARGO, RESPONSABLE.SUCURSAL, (CASE WHEN DEPENDENCIA_RESPONSABLE.JEFEUNIDAD NOT IN (0) THEN 'SI' ELSE 'NO' END ) JEFEUNIDAD, RESPONSABLE.CEDULA  FROM DEPENDENCIA_RESPONSABLE LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA ORDER BY TERCERO.NOMBRE) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRE":"$NOMBRE","CARGO":"$CARGO","SUCURSAL":"$SUCURSAL","JEFEUNIDAD":"$JEFEUNIDAD","CEDULA":"$CEDULA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dependenciasresponsable/sucursalpordependencia/pag">
