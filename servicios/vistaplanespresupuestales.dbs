	<query id="getVistaplanespresupuestalesNumRubrosparacaquetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.MOVIMIENTO, V_PLAN_PRESUPUESTAL.AUXILIAR, V_PLAN_PRESUPUESTAL.SUCURSAL, V_PLAN_PRESUPUESTAL.TERCERO, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO "FUENTE", V_PLAN_PRESUPUESTAL.CENTRO_COSTO, V_PLAN_PRESUPUESTAL.REFERENCIA, V_PLAN_PRESUPUESTAL.MAN_AUX_GEN, V_PLAN_PRESUPUESTAL.MAN_AUX_TER, V_PLAN_PRESUPUESTAL.MAN_AUX_REF, V_PLAN_PRESUPUESTAL.MAN_CEN_CTO, V_PLAN_PRESUPUESTAL.MAN_AUX_FUE, V_PLAN_PRESUPUESTAL.DESTINO, CASE WHEN V_PLAN_PRESUPUESTAL.DESTINO = 'F' THEN 'FUNCIONAMIENTO' ELSE 'LIBRE DESTINACION' END NOMBRE_DESTINO FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.DESTINO IN ('L','F','S') AND V_PLAN_PRESUPUESTAL.NATURALEZA IN ('D') AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) AND V_PLAN_PRESUPUESTAL.TIPOVIGENCIA = 'VA' ORDER BY V_PLAN_PRESUPUESTAL.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END) LIKE UPPER(CONCAT(:FUENTE, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_GEN), '%')) AND (CASE WHEN MAN_AUX_TER IS NULL THEN ' ' ELSE UPPER(MAN_AUX_TER) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_TER), '%')) AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_REF), '%')) AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_CEN_CTO), '%')) AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_FUE), '%')) AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END) LIKE UPPER(CONCAT(CONCAT('%',:DESTINO), '%')) AND (CASE WHEN NOMBRE_DESTINO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DESTINO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DESTINO), '%')) ) A) FIN</sql>
