	<resource method="GET" path="vistaplanespresupuestales/rubrosparacaqueta/num">
		<call-query href="getVistaplanespresupuestalesNumRubrosparacaquetaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="MAN_AUX_GEN" query-param="MAN_AUX_GEN"/>
			<with-param name="MAN_AUX_TER" query-param="MAN_AUX_TER"/>
			<with-param name="MAN_AUX_REF" query-param="MAN_AUX_REF"/>
			<with-param name="MAN_CEN_CTO" query-param="MAN_CEN_CTO"/>
			<with-param name="MAN_AUX_FUE" query-param="MAN_AUX_FUE"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
