	</resource>
	<query id="getVistaplanespresupuestalesNumSaldosDisRegObPorCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CASE V_SALDO_PLAN_PPTAL.MES WHEN 1 THEN 'Enero' WHEN 2 THEN 'Febrero' WHEN 3 THEN 'Marzo' WHEN 4 THEN 'Abril' WHEN 5 THEN 'Mayo' WHEN 6 THEN 'Junio' WHEN 7 THEN 'Julio' WHEN 8 THEN 'Agosto' WHEN 9 THEN 'Septiembre' WHEN 10 THEN 'Octubre' WHEN 11 THEN 'Noviembre' WHEN 12 THEN 'Diciembre' END  MES, (DISPONIBILIDAD - ((REG_CONTRACT + REG_NO_CONTRACT) + (MODIF_REG_CONT + MODIF_REG_NOCONT))) SALDODISPONIBILIDAD, ((REG_CONTRACT + REG_NO_CONTRACT) + (MODIF_REG_CONT + MODIF_REG_NOCONT))-(REGISTRO_OBLIGACION + MODIF_REGISTRO_OBLIGACION) SALDOREGISTROS, (REGISTRO_OBLIGACION + MODIF_REGISTRO_OBLIGACION)-(CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END) SALDOREGOBLIGACION FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :ID_PLAN AND V_SALDO_PLAN_PPTAL.MES BETWEEN 1 AND 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) INI WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) AND (CASE WHEN SALDODISPONIBILIDAD IS NULL THEN ' ' ELSE UPPER(SALDODISPONIBILIDAD) END) LIKE UPPER(CONCAT(:SALDODISPONIBILIDAD, '%')) AND (CASE WHEN SALDOREGISTROS IS NULL THEN ' ' ELSE UPPER(SALDOREGISTROS) END) LIKE UPPER(CONCAT(:SALDOREGISTROS, '%')) AND (CASE WHEN SALDOREGOBLIGACION IS NULL THEN ' ' ELSE UPPER(SALDOREGOBLIGACION) END) LIKE UPPER(CONCAT(:SALDOREGOBLIGACION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="SALDODISPONIBILIDAD" sqlType="STRING"/>
		<param name="SALDOREGISTROS" sqlType="STRING"/>
		<param name="SALDOREGOBLIGACION" sqlType="STRING"/>

	</query>
