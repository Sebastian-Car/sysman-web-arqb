	<query id="getVistaplanespresupuestalesRevisaPacQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA ='D' THEN MODIF_PAC_DEBITO-MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO-MODIF_PAC_DEBITO END) AS MODIFPAC, SUM(PAC_APROPIADO) AS PACAPROPIADO, SUM(PAC_APROPIADO + CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA ='D' THEN MODIF_PAC_DEBITO-MODIF_PAC_CREDITO ELSE MODIF_PAC_CREDITO-MODIF_PAC_DEBITO END) AS TOTALPAC, SUM(CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA ='D' THEN EJE_PPT_DEBITO-EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO-EJE_PPT_DEBITO END) AS EJECUCIONPPT, SUM(CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA='D' THEN EJE_CNT_DEBITO-EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO-EJE_CNT_DEBITO END) AS EJECUCIONCNT  FROM V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL SALDO_PLAN_PPTAL ON PLAN_PRESUPUESTAL.ID = SALDO_PLAN_PPTAL.ID AND PLAN_PRESUPUESTAL.ANO = SALDO_PLAN_PPTAL.ANO AND PLAN_PRESUPUESTAL.COMPANIA = SALDO_PLAN_PPTAL.COMPANIA WHERE SALDO_PLAN_PPTAL.COMPANIA =:COMPANIA AND SALDO_PLAN_PPTAL.ANO = :ANO AND LENGTH(SALDO_PLAN_PPTAL.ID) &lt;= LENGTH(:CUENTA) AND SALDO_PLAN_PPTAL.ID = LPAD(:CUENTA, LENGTH(SALDO_PLAN_PPTAL.ID)) AND SALDO_PLAN_PPTAL.MES &lt;= :MES AND MAN_PAC NOT IN(0) GROUP BY SALDO_PLAN_PPTAL.COMPANIA, SALDO_PLAN_PPTAL.ANO, SALDO_PLAN_PPTAL.ID, PLAN_PRESUPUESTAL.NATURALEZA ORDER BY SALDO_PLAN_PPTAL.COMPANIA, SALDO_PLAN_PPTAL.ANO, SALDO_PLAN_PPTAL.ID DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MODIFPAC":"$MODIFPAC(type:integer)","PACAPROPIADO":"$PACAPROPIADO(type:integer)","TOTALPAC":"$TOTALPAC(type:integer)","EJECUCIONPPT":"$EJECUCIONPPT(type:integer)","EJECUCIONCNT":"$EJECUCIONCNT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/revisapac">
		<call-query href="getVistaplanespresupuestalesRevisaPacQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesPagListarLosRubrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT V_PLAN_PRESUPUESTAL.CODIGO ID, V_PLAN_PRESUPUESTAL.NOMBRE, ( NVL(V_PLAN_PRESUPUESTAL.FUENTE_RECURSO,BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO) ) FUENTERECURSOSRUBROF, V_PLAN_PRESUPUESTAL.AUXILIAR FROM V_PLAN_PRESUPUESTAL LEFT JOIN BP_PROYECTOSRUBROS ON V_PLAN_PRESUPUESTAL.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_PLAN_PRESUPUESTAL.VIGENCIA = BP_PROYECTOSRUBROS.VIGENCIA AND V_PLAN_PRESUPUESTAL.ID = BP_PROYECTOSRUBROS.RUBROPPTALES LEFT JOIN ES_RUBROS_PROY ON V_PLAN_PRESUPUESTAL.ANO = ES_RUBROS_PROY.VIGENCIA AND V_PLAN_PRESUPUESTAL.ID = ES_RUBROS_PROY.ID_RUBRO AND V_PLAN_PRESUPUESTAL.COMPANIA = ES_RUBROS_PROY.COMPANIA WHERE V_PLAN_PRESUPUESTAL.COMPANIA =:COMPANIA AND V_PLAN_PRESUPUESTAL.VIGENCIA =:ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','') ),CONCAT('', CONCAT(SUBSTR(V_PLAN_PRESUPUESTAL.CODIGO,1,2),'')),1) &gt; 0 AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) ORDER BY V_PLAN_PRESUPUESTAL.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FUENTERECURSOSRUBROF IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBROF) END) LIKE UPPER(CONCAT(:FUENTERECURSOSRUBROF, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","FUENTERECURSOSRUBROF":"$FUENTERECURSOSRUBROF","AUXILIAR":"$AUXILIAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBROF" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/listarlosrubros/pag">
		<call-query href="getVistaplanespresupuestalesPagListarLosRubrosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FUENTERECURSOSRUBROF" query-param="FUENTERECURSOSRUBROF"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesNumListarLosRubrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT V_PLAN_PRESUPUESTAL.CODIGO ID, V_PLAN_PRESUPUESTAL.NOMBRE, ( NVL(V_PLAN_PRESUPUESTAL.FUENTE_RECURSO,BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO) ) FUENTERECURSOSRUBROF, V_PLAN_PRESUPUESTAL.AUXILIAR FROM V_PLAN_PRESUPUESTAL LEFT JOIN BP_PROYECTOSRUBROS ON V_PLAN_PRESUPUESTAL.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_PLAN_PRESUPUESTAL.VIGENCIA = BP_PROYECTOSRUBROS.VIGENCIA AND V_PLAN_PRESUPUESTAL.ID = BP_PROYECTOSRUBROS.RUBROPPTALES LEFT JOIN ES_RUBROS_PROY ON V_PLAN_PRESUPUESTAL.ANO = ES_RUBROS_PROY.VIGENCIA AND V_PLAN_PRESUPUESTAL.ID = ES_RUBROS_PROY.ID_RUBRO AND V_PLAN_PRESUPUESTAL.COMPANIA = ES_RUBROS_PROY.COMPANIA WHERE V_PLAN_PRESUPUESTAL.COMPANIA =:COMPANIA AND V_PLAN_PRESUPUESTAL.VIGENCIA =:ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','') ),CONCAT('', CONCAT(SUBSTR(V_PLAN_PRESUPUESTAL.CODIGO,1,2),'')),1) &gt; 0 AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) ORDER BY V_PLAN_PRESUPUESTAL.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FUENTERECURSOSRUBROF IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBROF) END) LIKE UPPER(CONCAT(:FUENTERECURSOSRUBROF, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBROF" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/listarlosrubros/num">
		<call-query href="getVistaplanespresupuestalesNumListarLosRubrosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
