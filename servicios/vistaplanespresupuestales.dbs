<query id="getVistaplanespresupuestalesPagRubroscompletosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.MOVIMIENTO, V_PLAN_PRESUPUESTAL.AUXILIAR, V_PLAN_PRESUPUESTAL.SUCURSAL, V_PLAN_PRESUPUESTAL.TERCERO, V_PLAN_PRESUPUESTAL.REFERENCIA, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO "FUENTE", V_PLAN_PRESUPUESTAL.MAN_AUX_GEN, V_PLAN_PRESUPUESTAL.MAN_AUX_TER, V_PLAN_PRESUPUESTAL.MAN_AUX_REF, V_PLAN_PRESUPUESTAL.MAN_CEN_CTO, V_PLAN_PRESUPUESTAL.MAN_AUX_FUE, V_PLAN_PRESUPUESTAL.DESTINO, CASE WHEN V_PLAN_PRESUPUESTAL.DESTINO = 'I' THEN 'INVERSION'ELSE CASE WHEN V_PLAN_PRESUPUESTAL.DESTINO = 'F' THEN 'FUNCIONAMIENTO'ELSE CASE WHEN V_PLAN_PRESUPUESTAL.DESTINO = 'S' THEN 'Servicio de la Deuda'ELSE 'LIBRE DESTINACIÓN'END END END NOMBRE_DESTINO FROM V_PLAN_PRESUPUESTAL INNER JOIN ( SELECT DISTINCT COMPANIA, ANO, ID FROM SALDO_AUX_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO )SALDOS ON V_PLAN_PRESUPUESTAL.COMPANIA = SALDOS.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = SALDOS.ANO AND V_PLAN_PRESUPUESTAL.ID = SALDOS.ID WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) AND V_PLAN_PRESUPUESTAL.DESTINO IN ( 'I', 'L', 'F', 'S' ) AND V_PLAN_PRESUPUESTAL.NATURALEZA IN ( 'D' ) ORDER BY V_PLAN_PRESUPUESTAL.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END) LIKE UPPER(CONCAT(:FUENTE, '%')) AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_GEN), '%')) AND (CASE WHEN MAN_AUX_TER IS NULL THEN ' ' ELSE UPPER(MAN_AUX_TER) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_TER), '%')) AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_REF), '%')) AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_CEN_CTO), '%')) AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_FUE), '%')) AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END) LIKE UPPER(CONCAT(CONCAT('%',:DESTINO), '%')) AND (CASE WHEN NOMBRE_DESTINO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DESTINO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DESTINO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:double)","AUXILIAR":"$AUXILIAR","SUCURSAL":"$SUCURSAL","TERCERO":"$TERCERO","REFERENCIA":"$REFERENCIA","CENTRO_COSTO":"$CENTRO_COSTO","FUENTE":"$FUENTE","MAN_AUX_GEN":"$MAN_AUX_GEN(type:double)","MAN_AUX_TER":"$MAN_AUX_TER(type:double)","MAN_AUX_REF":"$MAN_AUX_REF(type:double)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:double)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:double)","DESTINO":"$DESTINO","NOMBRE_DESTINO":"$NOMBRE_DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
