<data name="vistaplanespresupuestales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVistaplanespresupuestalesPagTodosNaturalezaDQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN(0) ORDER BY V_PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/todosnaturalezad/pag">
		<call-query href="getVistaplanespresupuestalesPagTodosNaturalezaDQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesNumTodosNaturalezaDQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN(0) ORDER BY V_PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/todosnaturalezad/num">
		<call-query href="getVistaplanespresupuestalesNumTodosNaturalezaDQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesPagTodosNaturalezaDEntreCuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO BETWEEN :CUENTAINICIAL AND :CUENTAFINAL AND V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' ORDER BY V_PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="CUENTAFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/todosnaturalezadentrecuentas/pag">
		<call-query href="getVistaplanespresupuestalesPagTodosNaturalezaDEntreCuentasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="CUENTAFINAL" query-param="CUENTAFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesNumTodosNaturalezaDEntreCuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO BETWEEN :CUENTAINICIAL AND :CUENTAFINAL AND V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' ORDER BY V_PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="CUENTAFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/todosnaturalezadentrecuentas/num">
		<call-query href="getVistaplanespresupuestalesNumTodosNaturalezaDEntreCuentasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="CUENTAFINAL" query-param="CUENTAFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesPagTodosAcumuladosPptalingQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DECODE(V_SALDO_PLAN_PPTAL.MES,0,'Inicial',1,'Enero',2,'Febrero',3,'Marzo',4,'Abril',5,'Mayo',6,'Junio',7,'Julio',8,'Agosto',9,'Septiembre',10,'Octubre',11,'Noviembre',12,'Diciembre') MES, V_PLAN_PRESUPUESTAL.NATURALEZA, V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS CAUSACION, CASE WHEN NATURALEZA='D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO + MODIF_INGRESOS ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO + MODIF_INGRESOS END RECAUDOPPTAL, NVL(DETALLE_COMPROBANTE_CNTAUX.CONTABLE,0) RECAUDOCONTABLE  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID LEFT JOIN (SELECT COMPANIA, MES, ANO, CUENTAPPTAL, SUM(EJECUCION_CREDITO-DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO) CONTABLE FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTAPPTAL = :CODIGO GROUP BY COMPANIA, MES, ANO, CUENTAPPTAL ) DETALLE_COMPROBANTE_CNTAUX ON V_SALDO_PLAN_PPTAL.MES = DETALLE_COMPROBANTE_CNTAUX.MES WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt;= 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN CAUSACION IS NULL THEN ' ' ELSE UPPER(CAUSACION) END)  LIKE UPPER(:CAUSACION || '%')  AND (CASE WHEN RECAUDOPPTAL IS NULL THEN ' ' ELSE UPPER(RECAUDOPPTAL) END)  LIKE UPPER(:RECAUDOPPTAL || '%')  AND (CASE WHEN RECAUDOCONTABLE IS NULL THEN ' ' ELSE UPPER(RECAUDOCONTABLE) END)  LIKE UPPER(:RECAUDOCONTABLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES","NATURALEZA":"$NATURALEZA","CAUSACION":"$CAUSACION","RECAUDOPPTAL":"$RECAUDOPPTAL","RECAUDOCONTABLE":"$RECAUDOCONTABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CAUSACION" sqlType="STRING"/>
		<param name="RECAUDOPPTAL" sqlType="STRING"/>
		<param name="RECAUDOCONTABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/todosacumuladospptaling/pag">
		<call-query href="getVistaplanespresupuestalesPagTodosAcumuladosPptalingQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CAUSACION" query-param="CAUSACION"/>
			<with-param name="RECAUDOPPTAL" query-param="RECAUDOPPTAL"/>
			<with-param name="RECAUDOCONTABLE" query-param="RECAUDOCONTABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesNumTodosAcumuladosPptalingQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DECODE(V_SALDO_PLAN_PPTAL.MES,0,'Inicial',1,'Enero',2,'Febrero',3,'Marzo',4,'Abril',5,'Mayo',6,'Junio',7,'Julio',8,'Agosto',9,'Septiembre',10,'Octubre',11,'Noviembre',12,'Diciembre') MES, V_PLAN_PRESUPUESTAL.NATURALEZA, V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS CAUSACION, CASE WHEN NATURALEZA='D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO + MODIF_INGRESOS ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO + MODIF_INGRESOS END RECAUDOPPTAL, NVL(DETALLE_COMPROBANTE_CNTAUX.CONTABLE,0) RECAUDOCONTABLE  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID LEFT JOIN (SELECT COMPANIA, MES, ANO, CUENTAPPTAL, SUM(EJECUCION_CREDITO-DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO) CONTABLE FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTAPPTAL = :CODIGO GROUP BY COMPANIA, MES, ANO, CUENTAPPTAL ) DETALLE_COMPROBANTE_CNTAUX ON V_SALDO_PLAN_PPTAL.MES = DETALLE_COMPROBANTE_CNTAUX.MES WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt;= 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN CAUSACION IS NULL THEN ' ' ELSE UPPER(CAUSACION) END)  LIKE UPPER( '%' || :CAUSACION || '%')  AND (CASE WHEN RECAUDOPPTAL IS NULL THEN ' ' ELSE UPPER(RECAUDOPPTAL) END)  LIKE UPPER( '%' || :RECAUDOPPTAL || '%')  AND (CASE WHEN RECAUDOCONTABLE IS NULL THEN ' ' ELSE UPPER(RECAUDOCONTABLE) END)  LIKE UPPER( '%' || :RECAUDOCONTABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CAUSACION" sqlType="STRING"/>
		<param name="RECAUDOPPTAL" sqlType="STRING"/>
		<param name="RECAUDOCONTABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/todosacumuladospptaling/num">
		<call-query href="getVistaplanespresupuestalesNumTodosAcumuladosPptalingQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CAUSACION" query-param="CAUSACION"/>
			<with-param name="RECAUDOPPTAL" query-param="RECAUDOPPTAL"/>
			<with-param name="RECAUDOCONTABLE" query-param="RECAUDOCONTABLE"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesActualizaTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NVL(SUM(V_SALDO_PLAN_PPTAL.INGRESOS_CAUSADOS),0), '99,999,999,999,999,990.90') CAUSACION, TO_CHAR(NVL(SUM( CASE WHEN NATURALEZA='D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO + MODIF_INGRESOS ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO + MODIF_INGRESOS END),0), '99,999,999,999,999,990.90') RECAUDOPPTAL, TO_CHAR(NVL(SUM(NVL(DETALLE_COMPROBANTE_CNTAUX.CONTABLE,0)),0), '99,999,999,999,999,990.90') RECAUDOCONTABLE  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID LEFT JOIN (SELECT COMPANIA, MES, ANO, CUENTAPPTAL, SUM(EJECUCION_CREDITO-DETALLE_COMPROBANTE_CNT.EJECUCION_DEBITO) CONTABLE FROM DETALLE_COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTAPPTAL = :CODIGO GROUP BY COMPANIA, MES, ANO, CUENTAPPTAL )DETALLE_COMPROBANTE_CNTAUX ON V_SALDO_PLAN_PPTAL.MES = DETALLE_COMPROBANTE_CNTAUX.MES WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt;= 12 ORDER BY V_SALDO_PLAN_PPTAL.MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CAUSACION":"$CAUSACION","RECAUDOPPTAL":"$RECAUDOPPTAL","RECAUDOCONTABLE":"$RECAUDOCONTABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/actualizatotales">
		<call-query href="getVistaplanespresupuestalesActualizaTotalesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesPagPorAnoCompaniaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VPP.ID, VPP.NOMBRE  FROM V_PLAN_PRESUPUESTAL VPP WHERE VPP.COMPANIA = :COMPANIA AND VPP.ANO = :ANO ORDER BY VPP.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
