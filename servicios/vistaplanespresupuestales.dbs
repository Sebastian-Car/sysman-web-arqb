 LIKE UPPER( '%' || :TERCERONOM || '%')  AND (CASE WHEN FUENTENOM IS NULL THEN ' ' ELSE UPPER(FUENTENOM) END)  LIKE UPPER( '%' || :FUENTENOM || '%')  AND (CASE WHEN REFERENCIANOM IS NULL THEN ' ' ELSE UPPER(REFERENCIANOM) END)  LIKE UPPER( '%' || :REFERENCIANOM || '%') ))</sql>
