	<query id="getVistaplanespresupuestalesPagReconocimientosPorMesYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.NATURALEZA, V_SALDO_PLAN_PPTAL.RECONOCIMIENTOS, CASE WHEN V_SALDO_PLAN_PPTAL.MES = 0 THEN 'Vigencia anterior' WHEN V_SALDO_PLAN_PPTAL.MES = 1 THEN 'Enero' WHEN V_SALDO_PLAN_PPTAL.MES = 2 THEN 'Febrero' WHEN V_SALDO_PLAN_PPTAL.MES = 3 THEN 'Marzo' WHEN V_SALDO_PLAN_PPTAL.MES = 4 THEN 'Abril' WHEN V_SALDO_PLAN_PPTAL.MES = 5 THEN 'Mayo' WHEN V_SALDO_PLAN_PPTAL.MES = 6 THEN 'Junio' WHEN V_SALDO_PLAN_PPTAL.MES = 7 THEN 'Julio' WHEN V_SALDO_PLAN_PPTAL.MES = 8 THEN 'Agosto' WHEN V_SALDO_PLAN_PPTAL.MES = 9 THEN 'Septiembre' WHEN V_SALDO_PLAN_PPTAL.MES = 10 THEN 'Octubre' WHEN V_SALDO_PLAN_PPTAL.MES = 11 THEN 'Noviembre' WHEN V_SALDO_PLAN_PPTAL.MES = 12 THEN 'Diciembre' END MES  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN 0 AND 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN RECONOCIMIENTOS IS NULL THEN ' ' ELSE UPPER(RECONOCIMIENTOS) END)  LIKE UPPER( '%' || :RECONOCIMIENTOS || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NATURALEZA":"$NATURALEZA","RECONOCIMIENTOS":"$RECONOCIMIENTOS","MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="RECONOCIMIENTOS" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
