	<query id="getVistaplanespresupuestalesTodosPorCompaniaAnoTipocomprobanteNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT('X') AS CONTEO  FROM V_PLAN_PRESUPUESTAL LEFT JOIN DETALLE_COMPROBANTE_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = DETALLE_COMPROBANTE_PPTAL.CUENTA WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA =:COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO =:ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE =:STRTIPOCOMPROBANTE AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE =:NUMERO AND V_PLAN_PRESUPUESTAL.MANEJA_PROYECTOS NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
