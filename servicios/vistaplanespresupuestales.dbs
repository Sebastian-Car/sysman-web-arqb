			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="RECONOCIMIENTOS" query-param="RECONOCIMIENTOS"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesNumReconocimientosPorMesYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.NATURALEZA, V_SALDO_PLAN_PPTAL.RECONOCIMIENTOS, CASE WHEN V_SALDO_PLAN_PPTAL.MES = 0 THEN 'Vigencia anterior' WHEN V_SALDO_PLAN_PPTAL.MES = 1 THEN 'Enero' WHEN V_SALDO_PLAN_PPTAL.MES = 2 THEN 'Febrero' WHEN V_SALDO_PLAN_PPTAL.MES = 3 THEN 'Marzo' WHEN V_SALDO_PLAN_PPTAL.MES = 4 THEN 'Abril' WHEN V_SALDO_PLAN_PPTAL.MES = 5 THEN 'Mayo' WHEN V_SALDO_PLAN_PPTAL.MES = 6 THEN 'Junio' WHEN V_SALDO_PLAN_PPTAL.MES = 7 THEN 'Julio' WHEN V_SALDO_PLAN_PPTAL.MES = 8 THEN 'Agosto' WHEN V_SALDO_PLAN_PPTAL.MES = 9 THEN 'Septiembre' WHEN V_SALDO_PLAN_PPTAL.MES = 10 THEN 'Octubre' WHEN V_SALDO_PLAN_PPTAL.MES = 11 THEN 'Noviembre' WHEN V_SALDO_PLAN_PPTAL.MES = 12 THEN 'Diciembre' END MES  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN 0 AND 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN RECONOCIMIENTOS IS NULL THEN ' ' ELSE UPPER(RECONOCIMIENTOS) END)  LIKE UPPER( '%' || :RECONOCIMIENTOS || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="RECONOCIMIENTOS" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/reconocimientospormesycodigo/num">
		<call-query href="getVistaplanespresupuestalesNumReconocimientosPorMesYCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="RECONOCIMIENTOS" query-param="RECONOCIMIENTOS"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesTotalReconocimientosPorMesYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NVL(SUM(V_SALDO_PLAN_PPTAL.RECONOCIMIENTOS),0), '99,999,999,999,999,990.90') TOTAL  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN 0 And 12</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
