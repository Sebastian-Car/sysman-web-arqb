		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.ID, PLAN_PRESUPUESTAL.NOMBRE, AUXILIAR.NOMBRE AUXILIARNOM, CENTRO_COSTO.NOMBRE CENTRONOM, TRIM(TERCERO.NOMBRE) TERCERONOM, FUENTE_RECURSOS.NOMBRE FUENTENOM, REFERENCIA.NOMBRE REFERENCIANOM  FROM V_PLAN_PRESUPUESTAL LEFT JOIN CENTRO_COSTO ON V_PLAN_PRESUPUESTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = CENTRO_COSTO.ANO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON V_PLAN_PRESUPUESTAL.COMPANIA = AUXILIAR.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = AUXILIAR.ANO AND V_PLAN_PRESUPUESTAL.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN FUENTE_RECURSOS ON V_PLAN_PRESUPUESTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = FUENTE_RECURSOS.ANO AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO LEFT JOIN TERCERO ON V_PLAN_PRESUPUESTAL.COMPANIA = TERCERO.COMPANIA AND V_PLAN_PRESUPUESTAL.TERCERO = TERCERO.NIT AND V_PLAN_PRESUPUESTAL.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN REFERENCIA ON V_PLAN_PRESUPUESTAL.COMPANIA = REFERENCIA.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = REFERENCIA.ANO AND V_PLAN_PRESUPUESTAL.REFERENCIA = REFERENCIA.CODIGO INNER JOIN PLAN_PRESUPUESTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = PLAN_PRESUPUESTAL.ANO AND V_PLAN_PRESUPUESTAL.CODIGO = PLAN_PRESUPUESTAL.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO = :CODIGO ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN AUXILIARNOM IS NULL THEN ' ' ELSE UPPER(AUXILIARNOM) END)  LIKE UPPER( '%' || :AUXILIARNOM || '%')  AND (CASE WHEN CENTRONOM IS NULL THEN ' ' ELSE UPPER(CENTRONOM) END)  LIKE UPPER( '%' || :CENTRONOM || '%')  AND (CASE WHEN TERCERONOM IS NULL THEN ' ' ELSE UPPER(TERCERONOM) END)  LIKE UPPER( '%' || :TERCERONOM || '%')  AND (CASE WHEN FUENTENOM IS NULL THEN ' ' ELSE UPPER(FUENTENOM) END)  LIKE UPPER( '%' || :FUENTENOM || '%')  AND (CASE WHEN REFERENCIANOM IS NULL THEN ' ' ELSE UPPER(REFERENCIANOM) END)  LIKE UPPER( '%' || :REFERENCIANOM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","AUXILIARNOM":"$AUXILIARNOM","CENTRONOM":"$CENTRONOM","TERCERONOM":"$TERCERONOM","FUENTENOM":"$FUENTENOM","REFERENCIANOM":"$REFERENCIANOM"}]}}		</result>
