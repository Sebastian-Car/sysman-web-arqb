	<query id="getVistaplanespresupuestalesSumatoriaNaturalezaDQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(SALDO_PLAN_PPTAL.DISPONIBILIDAD) SUMADISP, SUM(SALDO_PLAN_PPTAL.PAC_APROPIADO) PAC, SUM(REGISTRO_OBLIGACION+MODIF_REGISTRO_OBLIGACION) REO, SUM(EJE_PPT_DEBITO -EJE_PPT_CREDITO) EGR, SUM(REG_CONTRACT +REG_NO_CONTRACT+MODIF_REG_CONT+MODIF_REG_NOCONT) REG  FROM V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL SALDO_PLAN_PPTAL ON PLAN_PRESUPUESTAL.COMPANIA = SALDO_PLAN_PPTAL.COMPANIA AND PLAN_PRESUPUESTAL.ANO = SALDO_PLAN_PPTAL.ANO AND PLAN_PRESUPUESTAL.ID = SALDO_PLAN_PPTAL.ID WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.ID = :CODIGO AND PLAN_PRESUPUESTAL.NATURALEZA = 'D'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMADISP":"$SUMADISP(type:integer)","PAC":"$PAC(type:integer)","REO":"$REO(type:integer)","EGR":"$EGR(type:integer)","REG":"$REG(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/sumatorianaturalezad">
		<call-query href="getVistaplanespresupuestalesSumatoriaNaturalezaDQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesPagEjecucionespresupuestalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DECODE(V_SALDO_PLAN_PPTAL.MES, 1, 'Enero', 2, 'Febrero', 3, 'Marzo', 4, 'Abril', 5, 'Mayo', 6, 'Junio', 7, 'Julio', 8, 'Agosto', 9, 'Septiembre', 10, 'Octubre', 11, 'Noviembre', 12, 'Diciembre') MES, ( CASE WHEN NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONPPT, ( CASE WHEN NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONCNT, SUM( CASE WHEN NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) OVER( ORDER BY V_SALDO_PLAN_PPTAL.MES ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW ) GIROSACUMULADOS  FROM V_SALDO_PLAN_PPTAL WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN 1 AND 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN EJECUCIONPPT IS NULL THEN ' ' ELSE UPPER(EJECUCIONPPT) END)  LIKE UPPER(:EJECUCIONPPT || '%')  AND (CASE WHEN EJECUCIONCNT IS NULL THEN ' ' ELSE UPPER(EJECUCIONCNT) END)  LIKE UPPER(:EJECUCIONCNT || '%')  AND (CASE WHEN GIROSACUMULADOS IS NULL THEN ' ' ELSE UPPER(GIROSACUMULADOS) END)  LIKE UPPER(:GIROSACUMULADOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES","EJECUCIONPPT":"$EJECUCIONPPT(type:double)","EJECUCIONCNT":"$EJECUCIONCNT(type:double)","GIROSACUMULADOS":"$GIROSACUMULADOS(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="EJECUCIONPPT" sqlType="STRING"/>
		<param name="EJECUCIONCNT" sqlType="STRING"/>
		<param name="GIROSACUMULADOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
