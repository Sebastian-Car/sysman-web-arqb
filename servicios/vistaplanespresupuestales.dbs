	<query id="getVistaplanespresupuestalesConsultarApropiacionInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APROPIACION_DEBITO -APROPIACION_CREDITO ELSE APROPIACION_CREDITO-APROPIACION_DEBITO END) +SUM(V_SALDO_PLAN_PPTAL.ADICION)+SUM(V_SALDO_PLAN_PPTAL.REDUCCION)+SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN APLAZAM_DEBITO -APLAZAM_CREDITO ELSE APLAZAM_CREDITO-APLAZAM_DEBITO END) +SUM( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN TRASLADO_DEBITO -TRASLADO_CREDITO ELSE TRASLADO_CREDITO-TRASLADO_DEBITO END) APRINICIAL  FROM V_PLAN_PRESUPUESTAL LEFT JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt; :MES GROUP BY V_SALDO_PLAN_PPTAL.COMPANIA, V_SALDO_PLAN_PPTAL.ANO, V_SALDO_PLAN_PPTAL.ID, V_PLAN_PRESUPUESTAL.NATURALEZA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APRINICIAL":"$APRINICIAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/consultarapropiacioninicial">
		<call-query href="getVistaplanespresupuestalesConsultarApropiacionInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
