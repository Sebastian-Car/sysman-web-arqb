	<query id="getVistaplanespresupuestalesPagGrubropresupuestalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(CONCAT(CONCAT(S.CODIGO, S.AUXILIAR), S.REFERENCIA),S.CENTRO_COSTO) ID, S.CODIGO AS CODIGO, P.NOMBRE, S.AUXILIAR, S.REFERENCIA, S.CENTRO_COSTO, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO AS FUENTE_RECURSO, TRIM(TO_CHAR(SUM(S.APROPIACION_DEBITO + S.ADICION+S.REDUCCION +(S.TRASLADO_DEBITO -S.TRASLADO_CREDITO) +(S.APLAZAM_DEBITO - S.APLAZAM_CREDITO)- S.DISPONIBILIDAD) , '999G999G999G999G999D99' , 'NLS_NUMERIC_CHARACTERS = .,')) SALDO, SUM(S.REINTEGRO) REINTEGRO, SUM(S.DISPONIBILIDAD - (S.REG_NO_CONTRACT + S.MODIF_REG_NOCONT + S.REG_CONTRACT + S.MODIF_REG_CONT)) SALDODIS, SUM (S.DISPONIBILIDAD) TOTALDIS,P.CLASECLASIFICADOR FROM SALDO_AUX_PPTAL S INNER JOIN PLAN_PRESUPUESTAL P ON S.COMPANIA=P.COMPANIA AND S.ANO=P.ANO AND S.CODIGO=P.CODIGO INNER JOIN BP_PROYECTOSRUBROS ON S.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND S.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND S.CODIGO = BP_PROYECTOSRUBROS.RUBROPPTALES AND S.FUENTE_RECURSO = CASE WHEN P.MAN_AUX_FUE NOT IN (0) THEN BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO ELSE '99999999999999999999' END AND S.CENTRO_COSTO = CASE WHEN P.MAN_AUX_FUE NOT IN (0) THEN BP_PROYECTOSRUBROS.CENTRO_COSTO ELSE '99999999999999999999' END AND S.REFERENCIA = CASE WHEN P.MAN_AUX_FUE NOT IN (0) THEN BP_PROYECTOSRUBROS.REFERENCIA ELSE '99999999999999999999' END AND S.AUXILIAR = CASE WHEN P.MAN_AUX_FUE NOT IN (0) THEN BP_PROYECTOSRUBROS.AUXILIAR ELSE '99999999999999999999' END WHERE S.COMPANIA = :COMPANIA AND S.ANO = :VIGENCIA AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = :FUENTE AND P.DESTINO IN ('I','L') AND P.NATURALEZA IN ('D') AND S.MES &lt;= 12 GROUP BY S.CODIGO, P.NOMBRE, S.AUXILIAR, S.REFERENCIA, S.CENTRO_COSTO, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO,P.CLASECLASIFICADOR) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN REINTEGRO IS NULL THEN ' ' ELSE UPPER(REINTEGRO) END) LIKE UPPER(CONCAT(CONCAT('%',:REINTEGRO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","CENTRO_COSTO":"$CENTRO_COSTO","FUENTE_RECURSO":"$FUENTE_RECURSO","SALDO":"$SALDO","REINTEGRO":"$REINTEGRO(type:double)","SALDODIS":"$SALDODIS(type:double)","TOTALDIS":"$TOTALDIS(type:double)","CLASECLASIFICADOR":"$CLASECLASIFICADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="REINTEGRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
