	<query id="getVistaplanespresupuestalesPagPresupuestalrubrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT V_RESUMENPPTO_BASE.CODIGO ID, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO FUENTE_RECURSO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD + V_RESUMENPPTO_BASE.REINTEGRO) SALDO, SUM(V_RESUMENPPTO_BASE.REINTEGRO) REINTEGRO, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD - V_RESUMENPPTO_BASE.COMPROMISOSACUM) SALDODIS, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) TOTALDIS FROM V_RESUMENPPTO_BASE INNER JOIN PLAN_PRESUPUESTAL ON V_RESUMENPPTO_BASE.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND V_RESUMENPPTO_BASE.ANO = PLAN_PRESUPUESTAL.ANO AND V_RESUMENPPTO_BASE.CODIGO = PLAN_PRESUPUESTAL.CODIGO INNER JOIN BP_PROYECTOSRUBROS ON V_RESUMENPPTO_BASE.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND V_RESUMENPPTO_BASE.CODIGO = BP_PROYECTOSRUBROS.RUBROPPTALES AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_FUE NOT IN(0) THEN BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO ELSE '99999999999999999999' END INNER JOIN FUENTE_RECURSOS ON V_RESUMENPPTO_BASE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = FUENTE_RECURSOS.ANO AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO WHERE V_RESUMENPPTO_BASE.COMPANIA = :COMPANIA AND V_RESUMENPPTO_BASE.ANO = :VIGENCIA AND V_RESUMENPPTO_BASE.DESTINO IN ('I','L') AND V_RESUMENPPTO_BASE.NATURALEZA IN ('D') AND V_RESUMENPPTO_BASE.MES &lt;= TO_CHAR(SYSDATE,'MM') AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = :FUENTE GROUP BY V_RESUMENPPTO_BASE.CODIGO, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN REINTEGRO IS NULL THEN ' ' ELSE UPPER(REINTEGRO) END) LIKE UPPER(CONCAT(CONCAT('%',:REINTEGRO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","FUENTE_RECURSO":"$FUENTE_RECURSO","SALDO":"$SALDO(type:integer)","REINTEGRO":"$REINTEGRO(type:integer)","SALDODIS":"$SALDODIS(type:integer)","TOTALDIS":"$TOTALDIS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="REINTEGRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
