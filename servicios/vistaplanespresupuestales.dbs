	<query id="getVistaplanespresupuestalesPorRubrosCompaniaYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA= :COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','')),V_PLAN_PRESUPUESTAL.ANO,1) &gt;0 AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:RUBRO,' ','')),V_PLAN_PRESUPUESTAL.ID,1) &gt;0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/porrubroscompaniayvigencia">
		<call-query href="getVistaplanespresupuestalesPorRubrosCompaniaYVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="RUBRO" query-param="RUBRO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesPorVigenciaProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ANO, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE NOMBREPLAN, V_PLAN_PRESUPUESTAL.APROPIACIONINICIAL, NVL(VALORSOLICITADO_AUX1,0) VALORSOLICITADO_AUX, NVL(TOTAL_DISPONIBLE_PPTAL.TOTALDIS,0) TOTALDIS1  FROM V_PLAN_PRESUPUESTAL LEFT JOIN ( SELECT SALDO_PLAN_PPTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, SUM(SALDO_PLAN_PPTAL.DISPONIBILIDAD) TOTALDIS FROM V_PLAN_PRESUPUESTAL INNER JOIN SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = SALDO_PLAN_PPTAL.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CODIGO,' ','')),V_PLAN_PRESUPUESTAL.CODIGO,1) &gt;0 AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','')),SALDO_PLAN_PPTAL.ANO,1) &gt;0 AND SALDO_PLAN_PPTAL.MES &lt;= EXTRACT (MONTH FROM SYSDATE) GROUP BY SALDO_PLAN_PPTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.MOVIMIENTO) TOTAL_DISPONIBLE_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = TOTAL_DISPONIBLE_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ID = TOTAL_DISPONIBLE_PPTAL.ID LEFT JOIN (SELECT BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL, SUM(BP_D_NOVEDADPROYECTO.VALORSOLICITADO) VALORSOLICITADO_AUX1, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, BP_D_NOVEDADPROYECTO.ANORUBRO FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = 'SVP' AND BP_D_NOVEDADPROYECTO.CLASET = 'B' AND BP_D_NOVEDADPROYECTO.NOVEDAD = :NOVEDAD GROUP BY BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, BP_D_NOVEDADPROYECTO.ANORUBRO) RUBROS_NOVEDAD ON V_PLAN_PRESUPUESTAL.COMPANIA = RUBROS_NOVEDAD.COMPANIA AND V_PLAN_PRESUPUESTAL.ID = RUBROS_NOVEDAD.RUBROPRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA= :COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','')),V_PLAN_PRESUPUESTAL.ANO,1) &gt; 0 AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CODIGO,' ','')),V_PLAN_PRESUPUESTAL.CODIGO,1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ID":"$ID","CODIGO":"$CODIGO","NOMBREPLAN":"$NOMBREPLAN","APROPIACIONINICIAL":"$APROPIACIONINICIAL","VALORSOLICITADO_AUX":"$VALORSOLICITADO_AUX(type:integer)","TOTALDIS1":"$TOTALDIS1(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>

