	<query id="getVistaplanespresupuestalesPagTodosPorNaturalezaDYCodiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID, CODIGO, NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND NATURALEZA = 'D' AND ANO = :ANO AND ID &gt;= :CUENTAINICIAL ORDER BY ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
