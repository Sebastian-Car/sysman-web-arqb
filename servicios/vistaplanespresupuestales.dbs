	<query id="getVistaplanespresupuestalesActualizarTotalesAcumuladopptalsQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NVL(SUM(V_SALDO_PLAN_PPTAL.DISPONIBILIDAD),0), '99,999,999,999,999,990.90') DISPONIBILIDAD, TO_CHAR(NVL(SUM(((V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT + V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT ) + (V_SALDO_PLAN_PPTAL.REG_CONTRACT + V_SALDO_PLAN_PPTAL.MODIF_REG_CONT))),0), '99,999,999,999,999,990.90') REGISTRO, TO_CHAR(NVL(SUM((V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION + V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION)),0), '99,999,999,999,999,990.90') REGISTROOBLIGACION, TO_CHAR(NVL(SUM(( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END)),0), '99,999,999,999,999,990.90') PACPAGOS, TO_CHAR(NVL(SUM(( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END)),0), '99,999,999,999,999,990.90') GIROSACUMULADOS  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt;= 12</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DISPONIBILIDAD":"$DISPONIBILIDAD","REGISTRO":"$REGISTRO","REGISTROOBLIGACION":"$REGISTROOBLIGACION","PACPAGOS":"$PACPAGOS","GIROSACUMULADOS":"$GIROSACUMULADOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
