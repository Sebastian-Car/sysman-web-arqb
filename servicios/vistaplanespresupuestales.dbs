	<query id="getVistaplanespresupuestalesPagActualizaTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DECODE(V_SALDO_PLAN_PPTAL.MES,0,'Inicial',1,'Enero',2,'Febrero',3,'Marzo',4,'Abril',5,'Mayo',6,'Junio',7,'Julio',8,'Agosto',9,'Septiembre',10,'Octubre',11,'Noviembre',12,'Diciembre') MES, V_SALDO_PLAN_PPTAL.DISPONIBILIDAD DISPONIBILIDAD, ((V_SALDO_PLAN_PPTAL.REG_NO_CONTRACT + V_SALDO_PLAN_PPTAL.MODIF_REG_NOCONT ) + (V_SALDO_PLAN_PPTAL.REG_CONTRACT + V_SALDO_PLAN_PPTAL.MODIF_REG_CONT)) REGISTRO, (V_SALDO_PLAN_PPTAL.REGISTRO_OBLIGACION + V_SALDO_PLAN_PPTAL.MODIF_REGISTRO_OBLIGACION ) REGISTROOBLIGACION, ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END) PACPAGOS, ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END) GIROSACUMULADOS  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES &lt;= 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN DISPONIBILIDAD IS NULL THEN ' ' ELSE UPPER(DISPONIBILIDAD) END)  LIKE UPPER(:DISPONIBILIDAD || '%')  AND (CASE WHEN REGISTRO IS NULL THEN ' ' ELSE UPPER(REGISTRO) END)  LIKE UPPER(:REGISTRO || '%')  AND (CASE WHEN REGISTROOBLIGACION IS NULL THEN ' ' ELSE UPPER(REGISTROOBLIGACION) END)  LIKE UPPER(:REGISTROOBLIGACION || '%')  AND (CASE WHEN PACPAGOS IS NULL THEN ' ' ELSE UPPER(PACPAGOS) END)  LIKE UPPER(:PACPAGOS || '%')  AND (CASE WHEN GIROSACUMULADOS IS NULL THEN ' ' ELSE UPPER(GIROSACUMULADOS) END)  LIKE UPPER(:GIROSACUMULADOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES","DISPONIBILIDAD":"$DISPONIBILIDAD(type:double)","REGISTRO":"$REGISTRO(type:integer)","REGISTROOBLIGACION":"$REGISTROOBLIGACION(type:integer)","PACPAGOS":"$PACPAGOS(type:integer)","GIROSACUMULADOS":"$GIROSACUMULADOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DISPONIBILIDAD" sqlType="STRING"/>
		<param name="REGISTRO" sqlType="STRING"/>
		<param name="REGISTROOBLIGACION" sqlType="STRING"/>
		<param name="PACPAGOS" sqlType="STRING"/>
		<param name="GIROSACUMULADOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
