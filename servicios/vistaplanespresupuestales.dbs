	<query id="getVistaplanespresupuestalesNumDetallerubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT V_PLAN_PRESUPUESTAL.ID, FUENTE_RECURSOS.CODIGO FUENTE, FUENTE_RECURSOS.NOMBRE NOMBRE_FUENTE, AUXILIAR.CODIGO AUXILIAR, AUXILIAR.NOMBRE NOMBRE_AUXILIAR, CENTRO_COSTO.CODIGO CENTRO_COSTO, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, TERCERO.NIT TERCERO, TERCERO.SUCURSAL SUCURSAL, TRIM(TERCERO.NOMBRE) NOMBRE_TERCERO, REFERENCIA.CODIGO REFERENCIA, REFERENCIA.NOMBRE NOMBRE_REFERENCIA FROM V_PLAN_PRESUPUESTAL LEFT JOIN CENTRO_COSTO ON V_PLAN_PRESUPUESTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = CENTRO_COSTO.ANO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON V_PLAN_PRESUPUESTAL.COMPANIA = AUXILIAR.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = AUXILIAR.ANO AND V_PLAN_PRESUPUESTAL.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN FUENTE_RECURSOS ON V_PLAN_PRESUPUESTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = FUENTE_RECURSOS.ANO AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO LEFT JOIN TERCERO ON V_PLAN_PRESUPUESTAL.COMPANIA = TERCERO.COMPANIA AND V_PLAN_PRESUPUESTAL.TERCERO = TERCERO.NIT AND V_PLAN_PRESUPUESTAL.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN REFERENCIA ON V_PLAN_PRESUPUESTAL.COMPANIA = REFERENCIA.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = REFERENCIA.ANO AND V_PLAN_PRESUPUESTAL.REFERENCIA = REFERENCIA.CODIGO INNER JOIN PLAN_PRESUPUESTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = PLAN_PRESUPUESTAL.ANO AND V_PLAN_PRESUPUESTAL.CODIGO = PLAN_PRESUPUESTAL.CODIGO INNER JOIN SALDO_AUX_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = SALDO_AUX_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = SALDO_AUX_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.CODIGO = SALDO_AUX_PPTAL.CODIGO AND V_PLAN_PRESUPUESTAL.ID=SALDO_AUX_PPTAL.ID AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = SALDO_AUX_PPTAL.FUENTE_RECURSO AND V_PLAN_PRESUPUESTAL.REFERENCIA= SALDO_AUX_PPTAL.REFERENCIA AND V_PLAN_PRESUPUESTAL.AUXILIAR=SALDO_AUX_PPTAL.AUXILIAR AND V_PLAN_PRESUPUESTAL.TERCERO=SALDO_AUX_PPTAL.TERCERO AND V_PLAN_PRESUPUESTAL.SUCURSAL=SALDO_AUX_PPTAL.SUCURSAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO = :CODIGO GROUP BY V_PLAN_PRESUPUESTAL.ID, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, AUXILIAR.CODIGO, AUXILIAR.NOMBRE, CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE, TERCERO.NIT, TERCERO.SUCURSAL, TRIM(TERCERO.NOMBRE), REFERENCIA.CODIGO, REFERENCIA.NOMBRE HAVING SUM(ADICION + REDUCCION + PAC_APROPIADO + PAC_PROGRAMADO + DISPONIBILIDAD + DISPONIBILIDADADD + ABS(DISPONIBILIDADDMD) + REG_NO_CONTRACT + REG_CONTRACT + REG_REVERSION + MODIF_PAC_DEBITO + MODIF_PAC_CREDITO + MODIF_REG_CONT + MODIF_REG_NOCONT + MODIF_REG_CONTADR + MODIF_REG_NOCONTADR + MODIF_REG_CONTDMR + MODIF_REG_NOCONTDMR + REINTEGRO + VIGENCIAANTERIOR + VIGENCIAFUTURA + TRASLADO_DEBITO + TRASLADO_CREDITO + APLAZAM_DEBITO + APLAZAM_CREDITO + EJE_CNT_DEBITO + EJE_CNT_CREDITO + APROPIACION_DEBITO + APROPIACION_CREDITO + EJE_PPT_DEBITO + EJE_PPT_CREDITO + EJE_PPT_DEBITOAEG + EJE_PPT_DEBITODEG + REGISTRO_OBLIGACION + MODIF_REGISTRO_OBLIGACION + MODIF_REGISTRO_OBLIGACIONARO + MODIF_REGISTRO_OBLIGACIONDRO + INGRESOS_EFECTIVO + INGRESOS_PAPELES + MODIF_INGRESOS_EFECTIVO + MODIF_INGRESOS_PAPELES + INGRESOS_CAUSADOS + MODIF_INGRESOS_CAUSADOS + MODIF_INGRESOS + NETOEGRESO + RECONOCIMIENTOS + PACTESORERIA + PAC_EJECUTADO + PAC_COMPROMETIDO) &lt;&gt; 0 UNION ALL SELECT PLAN_PRESUPUESTAL.CODIGO ID, '' FUENTE, '' NOMBRE_FUENTE, '' AUXILIAR, '' NOMBRE_AUXILIAR, '' CENTRO_COSTO, '' NOMBRE_CENTRO_COSTO, '' TERCERO, '' SUCURSAL, '' NOMBRE_TERCERO, '' REFERENCIA, '' NOMBRE_REFERENCIA FROM PLAN_PRESUPUESTAL INNER JOIN SALDO_PLAN_PPTAL ON PLAN_PRESUPUESTAL.COMPANIA = SALDO_PLAN_PPTAL.COMPANIA AND PLAN_PRESUPUESTAL.ANO = SALDO_PLAN_PPTAL.ANO AND PLAN_PRESUPUESTAL.CODIGO=SALDO_PLAN_PPTAL.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.ANO = :ANO AND PLAN_PRESUPUESTAL.CODIGO = :CODIGO AND MES=0 AND PLAN_PRESUPUESTAL.MOVIMIENTO=0 ORDER BY ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(CONCAT('%',:ID), '%')) AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END) LIKE UPPER(CONCAT(:FUENTE, '%')) AND (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FUENTE), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN NOMBRE_AUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUXILIAR), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN NOMBRE_CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CENTRO_COSTO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN NOMBRE_REFERENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_REFERENCIA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="NOMBRE_FUENTE" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="NOMBRE_AUXILIAR" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="NOMBRE_CENTRO_COSTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="NOMBRE_REFERENCIA" sqlType="STRING"/>

	</query>
