	<query id="getVistaplanespresupuestalesPagTodosPorUnaNaturalezaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_PRESUPUESTAL.CODIGO ID, PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL WHERE PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND PLAN_PRESUPUESTAL.NATURALEZA = :NATURALEZA AND PLAN_PRESUPUESTAL.ANO = :ANO ORDER BY PLAN_PRESUPUESTAL.COMPANIA, PLAN_PRESUPUESTAL.ANO, PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE"}]}}		</result>
