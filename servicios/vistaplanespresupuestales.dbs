:FUENTE_RECURSO, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN REINTEGRO IS NULL THEN ' ' ELSE UPPER(REINTEGRO) END) LIKE UPPER(CONCAT(CONCAT('%',:REINTEGRO), '%')) ) A) FIN</sql>
