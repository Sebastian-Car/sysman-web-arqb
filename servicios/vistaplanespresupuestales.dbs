	<query id="getVistaplanespresupuestalesPagApropiacionSaldoPptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END) APROPIACION, ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END) APLAZAMIENTO, ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END) TRASLADO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(V_SALDO_PLAN_PPTAL.MES) MES, V_SALDO_PLAN_PPTAL.ADICION, V_SALDO_PLAN_PPTAL.REDUCCION  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN 0 AND 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN APROPIACION IS NULL THEN ' ' ELSE UPPER(APROPIACION) END)  LIKE UPPER(:APROPIACION || '%')  AND (CASE WHEN APLAZAMIENTO IS NULL THEN ' ' ELSE UPPER(APLAZAMIENTO) END)  LIKE UPPER(:APLAZAMIENTO || '%')  AND (CASE WHEN TRASLADO IS NULL THEN ' ' ELSE UPPER(TRASLADO) END)  LIKE UPPER(:TRASLADO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN ADICION IS NULL THEN ' ' ELSE UPPER(ADICION) END)  LIKE UPPER(:ADICION || '%')  AND (CASE WHEN REDUCCION IS NULL THEN ' ' ELSE UPPER(REDUCCION) END)  LIKE UPPER(:REDUCCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APROPIACION":"$APROPIACION","APLAZAMIENTO":"$APLAZAMIENTO(type:integer)","TRASLADO":"$TRASLADO(type:integer)","MES":"$MES","ADICION":"$ADICION","REDUCCION":"$REDUCCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="APROPIACION" sqlType="STRING"/>
		<param name="APLAZAMIENTO" sqlType="STRING"/>
		<param name="TRASLADO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ADICION" sqlType="STRING"/>
		<param name="REDUCCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/apropiacionsaldopptal/pag">
		<call-query href="getVistaplanespresupuestalesPagApropiacionSaldoPptalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="APROPIACION" query-param="APROPIACION"/>
			<with-param name="APLAZAMIENTO" query-param="APLAZAMIENTO"/>
			<with-param name="TRASLADO" query-param="TRASLADO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ADICION" query-param="ADICION"/>
			<with-param name="REDUCCION" query-param="REDUCCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanespresupuestalesNumApropiacionSaldoPptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END) APROPIACION, ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN APLAZAM_DEBITO - APLAZAM_CREDITO ELSE APLAZAM_CREDITO - APLAZAM_DEBITO END) APLAZAMIENTO, ( CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END) TRASLADO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(V_SALDO_PLAN_PPTAL.MES) MES, V_SALDO_PLAN_PPTAL.ADICION, V_SALDO_PLAN_PPTAL.REDUCCION  FROM V_PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = V_SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = V_SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = V_SALDO_PLAN_PPTAL.ID WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN 0 AND 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN APROPIACION IS NULL THEN ' ' ELSE UPPER(APROPIACION) END)  LIKE UPPER(:APROPIACION || '%')  AND (CASE WHEN APLAZAMIENTO IS NULL THEN ' ' ELSE UPPER(APLAZAMIENTO) END)  LIKE UPPER(:APLAZAMIENTO || '%')  AND (CASE WHEN TRASLADO IS NULL THEN ' ' ELSE UPPER(TRASLADO) END)  LIKE UPPER(:TRASLADO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN ADICION IS NULL THEN ' ' ELSE UPPER(ADICION) END)  LIKE UPPER(:ADICION || '%')  AND (CASE WHEN REDUCCION IS NULL THEN ' ' ELSE UPPER(REDUCCION) END)  LIKE UPPER(:REDUCCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="APROPIACION" sqlType="STRING"/>
		<param name="APLAZAMIENTO" sqlType="STRING"/>
		<param name="TRASLADO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ADICION" sqlType="STRING"/>
		<param name="REDUCCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanespresupuestales/apropiacionsaldopptal/num">
		<call-query href="getVistaplanespresupuestalesNumApropiacionSaldoPptalQuery">
