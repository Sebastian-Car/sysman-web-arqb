	<query id="getVistaplanespresupuestalesNumEjecucionespresupuestalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DECODE(V_SALDO_PLAN_PPTAL.MES, 1, 'Enero', 2, 'Febrero', 3, 'Marzo', 4, 'Abril', 5, 'Mayo', 6, 'Junio', 7, 'Julio', 8, 'Agosto', 9, 'Septiembre', 10, 'Octubre', 11, 'Noviembre', 12, 'Diciembre') MES, ( CASE WHEN NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONPPT, ( CASE WHEN NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONCNT, SUM( CASE WHEN NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) OVER( ORDER BY V_SALDO_PLAN_PPTAL.MES ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW ) GIROSACUMULADOS  FROM V_SALDO_PLAN_PPTAL WHERE V_SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND V_SALDO_PLAN_PPTAL.ANO = :ANO AND V_SALDO_PLAN_PPTAL.ID = :CODIGO AND V_SALDO_PLAN_PPTAL.MES BETWEEN 1 AND 12 ORDER BY V_SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN EJECUCIONPPT IS NULL THEN ' ' ELSE UPPER(EJECUCIONPPT) END)  LIKE UPPER(:EJECUCIONPPT || '%')  AND (CASE WHEN EJECUCIONCNT IS NULL THEN ' ' ELSE UPPER(EJECUCIONCNT) END)  LIKE UPPER(:EJECUCIONCNT || '%')  AND (CASE WHEN GIROSACUMULADOS IS NULL THEN ' ' ELSE UPPER(GIROSACUMULADOS) END)  LIKE UPPER(:GIROSACUMULADOS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="EJECUCIONPPT" sqlType="STRING"/>
		<param name="EJECUCIONCNT" sqlType="STRING"/>
		<param name="GIROSACUMULADOS" sqlType="STRING"/>

	</query>
