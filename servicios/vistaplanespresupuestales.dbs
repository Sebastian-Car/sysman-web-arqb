	<query id="getVistaplanespresupuestalesNumTodosPorNaturalezaDYCodiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID, CODIGO, NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND NATURALEZA = 'D' AND ANO = :ANO AND ID &gt;= :CUENTAINICIAL ORDER BY ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
