	<query id="getVistaplanespresupuestalesNumBancoDeProyectosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.NATURALEZA, V_PLAN_PRESUPUESTAL.DESTINO, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO, V_PLAN_PRESUPUESTAL.CODIGO_EQUIV, V_PLAN_PRESUPUESTAL.CODIGO_EQUIV2, CASE V_PLAN_PRESUPUESTAL.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END MOVIMIENTO, CASE V_PLAN_PRESUPUESTAL.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END MAN_CEN_CTO, CASE V_PLAN_PRESUPUESTAL.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END MAN_AUX_TER, CASE V_PLAN_PRESUPUESTAL.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END MAN_AUX_GEN, CASE V_PLAN_PRESUPUESTAL.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END MAN_AUX_REF, CASE V_PLAN_PRESUPUESTAL.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END MAN_AUX_FUE, CASE V_PLAN_PRESUPUESTAL.MAN_PAC WHEN 0 THEN 'false' ELSE 'true' END MAN_PAC, V_PLAN_PRESUPUESTAL.TIPOVIGENCIA, V_PLAN_PRESUPUESTAL.VIGENCIA, V_PLAN_PRESUPUESTAL.DEPENDENCIAASOCIADA, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, V_PLAN_PRESUPUESTAL.TERCERO, V_PLAN_PRESUPUESTAL.SUCURSAL, V_PLAN_PRESUPUESTAL.AUXILIAR, V_PLAN_PRESUPUESTAL.INDECONOMICO,(CASE V_PLAN_PRESUPUESTAL.INFORME WHEN 0 THEN 'false' ELSE 'true' END) INFORME,(CASE V_PLAN_PRESUPUESTAL.INFORMESHACIENDA WHEN 0 THEN 'false' ELSE 'true' END) INFORMESHACIENDA, TERCERO.NOMBRE NOMBRETERCERO, CENTRO_COSTO.NOMBRE NOMBRECENTROCOSTO, CENTRO_COSTO.TIPO TIPOCENTROCOSTO, AUXILIAR.NOMBRE NOMBREAUXILIAR, V_PLAN_PRESUPUESTAL.COD_SIGUIENTE_VIGENCIA  FROM V_PLAN_PRESUPUESTAL LEFT JOIN TERCERO ON V_PLAN_PRESUPUESTAL.COMPANIA = TERCERO.COMPANIA AND V_PLAN_PRESUPUESTAL.TERCERO = TERCERO.NIT AND V_PLAN_PRESUPUESTAL.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN CENTRO_COSTO ON V_PLAN_PRESUPUESTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = CENTRO_COSTO.ANO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON V_PLAN_PRESUPUESTAL.COMPANIA = AUXILIAR.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = AUXILIAR.ANO AND V_PLAN_PRESUPUESTAL.AUXILIAR = AUXILIAR.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END)  LIKE UPPER(:NATURALEZA || '%')  AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END)  LIKE UPPER(:DESTINO || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER( '%' || :FUENTE_RECURSO || '%')  AND (CASE WHEN CODIGO_EQUIV IS NULL THEN ' ' ELSE UPPER(CODIGO_EQUIV) END)  LIKE UPPER( '%' || :CODIGO_EQUIV || '%')  AND (CASE WHEN CODIGO_EQUIV2 IS NULL THEN ' ' ELSE UPPER(CODIGO_EQUIV2) END)  LIKE UPPER(:CODIGO_EQUIV2 || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END)  LIKE UPPER(:MAN_CEN_CTO || '%')  AND (CASE WHEN MAN_AUX_TER IS NULL THEN ' ' ELSE UPPER(MAN_AUX_TER) END)  LIKE UPPER(:MAN_AUX_TER || '%')  AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END)  LIKE UPPER(:MAN_AUX_GEN || '%')  AND (CASE WHEN MAN_PAC IS NULL THEN ' ' ELSE UPPER(MAN_PAC) END)  LIKE UPPER( '%' || :MAN_PAC || '%')  AND (CASE WHEN TIPOVIGENCIA IS NULL THEN ' ' ELSE UPPER(TIPOVIGENCIA) END)  LIKE UPPER( '%' || :TIPOVIGENCIA || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%')  AND (CASE WHEN DEPENDENCIAASOCIADA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIAASOCIADA) END)  LIKE UPPER(:DEPENDENCIAASOCIADA || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN INDECONOMICO IS NULL THEN ' ' ELSE UPPER(INDECONOMICO) END)  LIKE UPPER( '%' || :INDECONOMICO || '%')  AND (CASE WHEN INFORME IS NULL THEN ' ' ELSE UPPER(INFORME) END)  LIKE UPPER(:INFORME || '%')  AND (CASE WHEN INFORMESHACIENDA IS NULL THEN ' ' ELSE UPPER(INFORMESHACIENDA) END)  LIKE UPPER( '%' || :INFORMESHACIENDA || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN NOMBRECENTROCOSTO IS NULL THEN ' ' ELSE UPPER(NOMBRECENTROCOSTO) END)  LIKE UPPER( '%' || :NOMBRECENTROCOSTO || '%')  AND (CASE WHEN TIPOCENTROCOSTO IS NULL THEN ' ' ELSE UPPER(TIPOCENTROCOSTO) END)  LIKE UPPER( '%' || :TIPOCENTROCOSTO || '%')  AND (CASE WHEN NOMBREAUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBREAUXILIAR) END)  LIKE UPPER( '%' || :NOMBREAUXILIAR || '%')  AND (CASE WHEN COD_SIGUIENTE_VIGENCIA IS NULL THEN ' ' ELSE UPPER(COD_SIGUIENTE_VIGENCIA) END)  LIKE UPPER( '%' || :COD_SIGUIENTE_VIGENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
