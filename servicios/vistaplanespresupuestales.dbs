	<query id="getVistaplanespresupuestalesPagCuentascondestinoilfQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.MOVIMIENTO, V_PLAN_PRESUPUESTAL.AUXILIAR, V_PLAN_PRESUPUESTAL.SUCURSAL, V_PLAN_PRESUPUESTAL.TERCERO, V_PLAN_PRESUPUESTAL.REFERENCIA, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, V_PLAN_PRESUPUESTAL.FUENTE, V_PLAN_PRESUPUESTAL.MAN_AUX_GEN, V_PLAN_PRESUPUESTAL.MAN_AUX_TER, V_PLAN_PRESUPUESTAL.MAN_AUX_REF, V_PLAN_PRESUPUESTAL.MAN_CEN_CTO, V_PLAN_PRESUPUESTAL.MAN_AUX_FUE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.DESTINO IN ('I','L','F') AND V_PLAN_PRESUPUESTAL.NATURALEZA IN ('D') AND V_PLAN_PRESUPUESTAL.ID NOT IN (SELECT DISTINCT(RUBRO) FROM D_SOLICITUDDISPONIBILIDAD WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NUMERO = :NUMERO ) AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END)  LIKE UPPER(:REFERENCIA || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER(:FUENTE || '%')  AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MA