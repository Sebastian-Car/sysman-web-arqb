	<query id="getIpusuariospredialPagTodosPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.NOMBRE, IP_USUARIOS_PREDIAL.CODIGO  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_USUARIOS_PREDIAL.NOMBRE IS NOT NULL AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN (0) ORDER BY IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.NOMBRE) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","CODIGO":"$CODIGO"}]}}		</result>
