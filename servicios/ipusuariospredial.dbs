			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="MINIT" query-param="MINIT"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialConsultarIndborradoPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE INDBORRADO WHEN 0 THEN 'false' ELSE 'true' END) INDBORRADO FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND CODIGO = :PREDIO AND NUMERO_ORDEN = :NUMERO_ORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"INDBORRADO":"$INDBORRADO(type:boolean)"}]}}		</result>
