		<result outputType="json">{"elementos":{"elemento":[{"DIRECCION":"$DIRECCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="DIRECCIONINICIAL" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
