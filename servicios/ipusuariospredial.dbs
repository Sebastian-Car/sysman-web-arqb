		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_USUARIOS_PREDIAL.PAGO_ANO &lt; EXTRACT (YEAR FROM SYSDATE) AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) ORDER BY IP_USUARIOS_PREDIAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
