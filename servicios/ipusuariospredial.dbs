	<query id="getIpusuariospredialConsultarPrediosUltimofacturadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  USUARIOS_PREDIAL.CODIGO, USUARIOS_PREDIAL.NIT, USUARIOS_PREDIAL.NOMBRE, NVL(PREDIOS_ULTIMOFACTURADO.ULTIMO_FACTURADO,0)-USUARIOS_PREDIAL.PAGO_ANO DIF  FROM IP_USUARIOS_PREDIAL USUARIOS_PREDIAL LEFT JOIN ( SELECT COMPANIA,CODIGO, NUMERO_ORDEN, MAX(PREANO)ULTIMO_FACTURADO FROM IP_FACTURADOS GROUP BY COMPANIA,CODIGO, NUMERO_ORDEN ) PREDIOS_ULTIMOFACTURADO ON USUARIOS_PREDIAL.COMPANIA = PREDIOS_ULTIMOFACTURADO.COMPANIA AND USUARIOS_PREDIAL.CODIGO = PREDIOS_ULTIMOFACTURADO.CODIGO AND USUARIOS_PREDIAL.NUMERO_ORDEN = PREDIOS_ULTIMOFACTURADO.NUMERO_ORDEN WHERE USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN (0) AND USUARIOS_PREDIAL.INDBORRADO IN (0) AND USUARIOS_PREDIAL.INDEXE + USUARIOS_PREDIAL.INDCAR + USUARIOS_PREDIAL.INDEXEOTROS &lt; 0 AND (NVL(PREDIOS_ULTIMOFACTURADO.ULTIMO_FACTURADO,0) - USUARIOS_PREDIAL.PAGO_ANO) &lt;&gt; 0 ORDER BY USUARIOS_PREDIAL.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NIT":"$NIT","NOMBRE":"$NOMBRE","DIF":"$DIF(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/consultarprediosultimofacturado">
		<call-query href="getIpusuariospredialConsultarPrediosUltimofacturadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateIpusuariospredialQuitarCerosALaIzquierdaNit" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_USUARIOS_PREDIAL SET NIT =NVL(LTRIM(NIT,'0'),NIT),DATE_MODIFIED     =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY       =:MODIFIED_BY  WHERE COMPANIA = :COMPANIA AND INDBORRADO = 0 AND CODIGO_NO_ACTIVO = 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipusuariospredial/quitarcerosalaizquierdanit">
		<call-query href="updateIpusuariospredialQuitarCerosALaIzquierdaNit">
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
