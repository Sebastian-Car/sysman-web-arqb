	<query id="getIpusuariospredialPreanoPorPredioInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOS.PREANO  FROM IP_USUARIOS_PREDIAL INNER JOIN IP_FACTURADOS ON IP_USUARIOS_PREDIAL.COMPANIA = IP_FACTURADOS.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = IP_FACTURADOS.CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = IP_FACTURADOS.NUMERO_ORDEN WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_FACTURADOS.PREANO &gt; IP_USUARIOS_PREDIAL.PAGO_ANO AND IP_USUARIOS_PREDIAL.CODIGO = :PREDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
