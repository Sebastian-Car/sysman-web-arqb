	<query id="updateIpusuariospredialIndicadorDeFacturado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_USUARIOS_PREDIAL SET IND_FACTURAR=:IND_FACTURAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_USUARIOS_PREDIAL.COMPANIA= :KEY_COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO= :KEY_CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN= :KEY_NUMERO_ORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IND_FACTURAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>

	</query>
