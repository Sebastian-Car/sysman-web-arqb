	<query id="getIpusuariospredialPorcentajeReservaPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT IP_FACTURADOS.PORCENTAJE_RESERVA ,IP_FACTURADOS.RESOLUCION_RESERVA  FROM IP_USUARIOS_PREDIAL INNER JOIN IP_FACTURADOS ON IP_USUARIOS_PREDIAL.COMPANIA = IP_FACTURADOS.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = IP_FACTURADOS.CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = IP_FACTURADOS.NUMERO_ORDEN WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = :CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_USUARIOS_PREDIAL.INDICADOR_RESERVA NOT IN(0) AND IP_FACTURADOS.PREANO = :PREANO AND NVL(IP_FACTURADOS.PORCENTAJE_RESERVA,0) &gt; 0 AND IP_FACTURADOS.RESOLUCION_RESERVA IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PORCENTAJE_RESERVA":"$PORCENTAJE_RESERVA","RESOLUCION_RESERVA":"$RESOLUCION_RESERVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>

	</query>
