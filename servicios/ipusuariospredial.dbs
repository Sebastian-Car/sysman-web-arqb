		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO,NOMBRE,NUM_COM,(TO_CHAR(PAG_FEC,'DD/MM/YYYY HH24:MI:SS')) PAG_FEC,PAGO_ANO,(CASE INDBORRADO WHEN 0 THEN 'false' ELSE 'true' END) INDBORRADO,(CASE CODIGO_NO_ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) CODIGO_NO_ACTIVO,DIRECCION,(CASE INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE,NIT,CODIGOANT1,(CASE ACUERDO_PAGO WHEN 0 THEN 'false' ELSE 'true' END) ACUERDO_PAGO,(CASE IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO_ORDEN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
