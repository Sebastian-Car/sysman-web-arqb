		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.INDBORRADO IN(0) AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN(0) ORDER BY IP_USUARIOS_PREDIAL.NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
