	<query id="getIpusuariospredialNumCodNomPorNumFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  USUARIOS_PREDIAL.CODIGO, USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL USUARIOS_PREDIAL WHERE USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND USUARIOS_PREDIAL.CODIGO &gt;= :CODIGOINICIAL AND USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO GROUP BY USUARIOS_PREDIAL.CODIGO, USUARIOS_PREDIAL.NOMBRE ORDER BY USUARIOS_PREDIAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
