	<query id="getIpusuariospredialPagTodosAuditoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE, IP_USUARIOS_PREDIAL.NIT  FROM IP_USUARIOS_PREDIAL INNER JOIN IP_AUDITORIA ON IP_USUARIOS_PREDIAL.COMPANIA = IP_AUDITORIA.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO =IP_AUDITORIA.MODCOD WHERE IP_USUARIOS_PREDIAL.COMPANIA=:COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN=:NUMERO_ORDEN AND TRUNC(IP_AUDITORIA.MODFEC) BETWEEN TO_DATE(:FECHAINICIAL,'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL,'DD/MM/YYYY') AND LENGTH(IP_AUDITORIA.MODCOD) = 15) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NIT":"$NIT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipusuariospredial/todosauditoria/pag">
		<call-query href="getIpusuariospredialPagTodosAuditoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialNumTodosAuditoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE, IP_USUARIOS_PREDIAL.NIT  FROM IP_USUARIOS_PREDIAL INNER JOIN IP_AUDITORIA ON IP_USUARIOS_PREDIAL.COMPANIA = IP_AUDITORIA.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO =IP_AUDITORIA.MODCOD WHERE IP_USUARIOS_PREDIAL.COMPANIA=:COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN=:NUMERO_ORDEN AND TRUNC(IP_AUDITORIA.MODFEC) BETWEEN TO_DATE(:FECHAINICIAL,'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL,'DD/MM/YYYY') AND LENGTH(IP_AUDITORIA.MODCOD) = 15) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
