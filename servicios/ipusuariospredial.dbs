	<query id="getIpusuariospredialNumCopropietariosIndboOCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NUMERO_ORDEN, NOMBRE, TIPO_NIT, NIT, DIRECCION_CORRESPONDENCIA  FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND NUMERO_ORDEN NOT IN(:NUMORDEN) AND (INDBORRADO NOT IN(0) OR CODIGO_NO_ACTIVO NOT IN(0))) WHERE (CASE WHEN NUMERO_ORDEN IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDEN) END)  LIKE UPPER( '%' || :NUMERO_ORDEN || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_NIT IS NULL THEN ' ' ELSE UPPER(TIPO_NIT) END)  LIKE UPPER( '%' || :TIPO_NIT || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN DIRECCION_CORRESPONDENCIA IS NULL THEN ' ' ELSE UPPER(DIRECCION_CORRESPONDENCIA) END)  LIKE UPPER( '%' || :DIRECCION_CORRESPONDENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_NIT" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="DIRECCION_CORRESPONDENCIA" sqlType="STRING"/>

	</query>
