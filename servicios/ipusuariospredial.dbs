	<query id="getIpusuariospredialPagNitNombrePorCiaPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIT, NOMBRE, CODIGO, NUMERO_ORDEN,(CASE INDBORRADO WHEN 0 THEN 'false' ELSE 'true' END) INDBORRADO,(CASE CODIGO_NO_ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) CODIGO_NO_ACTIVO, DIRECCION, NUM_COM, TO_CHAR(PAG_FEC,'DD/MM/YYYY') PAG_FEC,(CASE INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND CODIGO = :PREDIO AND INDBORRADO IN (0) AND CODIGO_NO_ACTIVO IN (0)) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NUMERO_ORDEN IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDEN) END)  LIKE UPPER( '%' || :NUMERO_ORDEN || '%')  AND (CASE WHEN INDBORRADO IS NULL THEN ' ' ELSE UPPER(INDBORRADO) END)  LIKE UPPER( '%' || :INDBORRADO || '%')  AND (CASE WHEN CODIGO_NO_ACTIVO IS NULL THEN ' ' ELSE UPPER(CODIGO_NO_ACTIVO) END)  LIKE UPPER( '%' || :CODIGO_NO_ACTIVO || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN NUM_COM IS NULL THEN ' ' ELSE UPPER(NUM_COM) END)  LIKE UPPER( '%' || :NUM_COM || '%')  AND (CASE WHEN PAG_FEC IS NULL THEN ' ' ELSE UPPER(PAG_FEC) END)  LIKE UPPER( '%' || :PAG_FEC || '%')  AND (CASE WHEN INDEXE IS NULL THEN ' ' ELSE UPPER(INDEXE) END)  LIKE UPPER( '%' || :INDEXE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","INDBORRADO":"$INDBORRADO(type:boolean)","CODIGO_NO_ACTIVO":"$CODIGO_NO_ACTIVO(type:boolean)","DIRECCION":"$DIRECCION","NUM_COM":"$NUM_COM","PAG_FEC":"$PAG_FEC","INDEXE":"$INDEXE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
