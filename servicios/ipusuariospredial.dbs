	<query id="getIpusuariospredialPagTodosPorCompaniaNumeroOrdenIndborradoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  USUARIOS_PREDIAL.CODIGO, USUARIOS_PREDIAL.NIT, USUARIOS_PREDIAL.NOMBRE,(CASE USUARIOS_PREDIAL.PERMITE_EXP_CERT WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_EXP_CERT, USUARIOS_PREDIAL.FORMATO_ESTRATO, USUARIOS_PREDIAL.DIRECCION, USUARIOS_PREDIAL.ESTRATO_SOCIOECONOMICO, USUARIOS_PREDIAL.SUCURSAL  FROM IP_USUARIOS_PREDIAL USUARIOS_PREDIAL LEFT JOIN IP_FORMATO_CERTIFICADOS FORMATO_CERTIFICADOS ON USUARIOS_PREDIAL.FORMATO_ESTRATO = FORMATO_CERTIFICADOS.FORMATO WHERE USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND USUARIOS_PREDIAL.INDBORRADO IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN PERMITE_EXP_CERT IS NULL THEN ' ' ELSE UPPER(PERMITE_EXP_CERT) END)  LIKE UPPER(:PERMITE_EXP_CERT || '%')  AND (CASE WHEN FORMATO_ESTRATO IS NULL THEN ' ' ELSE UPPER(FORMATO_ESTRATO) END)  LIKE UPPER(:FORMATO_ESTRATO || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN ESTRATO_SOCIOECONOMICO IS NULL THEN ' ' ELSE UPPER(ESTRATO_SOCIOECONOMICO) END)  LIKE UPPER(:ESTRATO_SOCIOECONOMICO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NIT":"$NIT","NOMBRE":"$NOMBRE","PERMITE_EXP_CERT":"$PERMITE_EXP_CERT(type:boolean)","FORMATO_ESTRATO":"$FORMATO_ESTRATO","DIRECCION":"$DIRECCION","ESTRATO_SOCIOECONOMICO":"$ESTRATO_SOCIOECONOMICO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PERMITE_EXP_CERT" sqlType="STRING"/>
		<param name="FORMATO_ESTRATO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="ESTRATO_SOCIOECONOMICO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
