	<query id="updateIpusuariospredialPorIndicadorDeFacturar" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_USUARIOS_PREDIAL SET IND_FACTURAR = 0  WHERE COMPANIA = :COMPANIA AND IND_FACTURAR NOT IN(0)</sql>
