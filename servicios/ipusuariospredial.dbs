	<query id="getIpusuariospredialPagCodpornreciboQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE, IP_RECIBOS_DE_PAGO.DOCNUM, IP_USUARIOS_PREDIAL.RECIBO_ACTUAL, IP_USUARIOS_PREDIAL.PAGO_ANO, IP_USUARIOS_PREDIAL.TOTAL,(TO_CHAR(IP_USUARIOS_PREDIAL.PAG_FEC,'DD/MM/YYYY HH24:MI:SS')) PAG_FEC, IP_USUARIOS_PREDIAL.PAG_VAL  FROM IP_USUARIOS_PREDIAL INNER JOIN IP_RECIBOS_DE_PAGO ON IP_USUARIOS_PREDIAL.COMPANIA = IP_RECIBOS_DE_PAGO.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = IP_RECIBOS_DE_PAGO.PRECOD WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND ANULADO IN (0) AND PAGO IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
