	<query id="getIpusuariospredialPreanoPorCodYNumordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOS.PREANO  FROM IP_USUARIOS_PREDIAL INNER JOIN IP_FACTURADOS ON IP_USUARIOS_PREDIAL.COMPANIA = IP_FACTURADOS.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = IP_FACTURADOS.CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = IP_FACTURADOS.NUMERO_ORDEN WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = :CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_FACTURADOS.PREANO &gt; IP_USUARIOS_PREDIAL.PAGO_ANO AND IP_FACTURADOS.PREANO &gt; 2013</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANO":"$PREANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/preanoporcodynumorden">
		<call-query href="getIpusuariospredialPreanoPorCodYNumordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialPagPorPagoanoEIndborradoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_USUARIOS_PREDIAL.PAGO_ANO &lt; EXTRACT (YEAR FROM SYSDATE) AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) ORDER BY IP_USUARIOS_PREDIAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
