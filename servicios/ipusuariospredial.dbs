	<query id="getIpusuariospredialPagTodosPorDatosBasicosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO,NOMBRE,NUM_COM,(TO_CHAR(PAG_FEC,'DD/MM/YYYY HH24:MI:SS')) PAG_FEC,PAGO_ANO,(CASE INDBORRADO WHEN 0 THEN 'false' ELSE 'true' END) INDBORRADO,(CASE CODIGO_NO_ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) CODIGO_NO_ACTIVO,DIRECCION,(CASE INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE,NIT,CODIGOANT1,(CASE ACUERDO_PAGO WHEN 0 THEN 'false' ELSE 'true' END) ACUERDO_PAGO,(CASE IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO_ORDEN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NUM_COM":"$NUM_COM","PAG_FEC":"$PAG_FEC","PAGO_ANO":"$PAGO_ANO(type:integer)","INDBORRADO":"$INDBORRADO(type:boolean)","CODIGO_NO_ACTIVO":"$CODIGO_NO_ACTIVO(type:boolean)","DIRECCION":"$DIRECCION","INDEXE":"$INDEXE(type:boolean)","NIT":"$NIT","CODIGOANT1":"$CODIGOANT1","ACUERDO_PAGO":"$ACUERDO_PAGO(type:boolean)","IND_PROCESOJUD":"$IND_PROCESOJUD(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
