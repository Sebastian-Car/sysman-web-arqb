	<query id="getIpusuariospredialPagPredPorCiaNumQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, NUM_COM, TO_CHAR(PAG_FEC,'DD/MM/YYYY') PAG_FEC, PAGO_ANO,(CASE INDBORRADO WHEN 0 THEN 'false' ELSE 'true' END) INDBORRADO,(CASE CODIGO_NO_ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) CODIGO_NO_ACTIVO, DIRECCION,(CASE INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE, NIT, CODIGOANT1,(CASE ACUERDO_PAGO WHEN 0 THEN 'false' ELSE 'true' END) ACUERDO_PAGO,(CASE IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD,(CASE BLOQUEADO WHEN 0 THEN 'false' ELSE 'true' END) BLOQUEADO,(CASE PROCESO_DE_COBRO WHEN 0 THEN 'false' ELSE 'true' END) PROCESO_DE_COBRO FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN PAG_FEC IS NULL THEN ' ' ELSE UPPER(PAG_FEC) END)  LIKE UPPER( '%' || :PAG_FEC || '%')  AND (CASE WHEN PAGO_ANO IS NULL THEN ' ' ELSE UPPER(PAGO_ANO) END)  LIKE UPPER( '%' || :PAGO_ANO || '%')  AND (CASE WHEN INDBORRADO IS NULL THEN ' ' ELSE UPPER(INDBORRADO) END)  LIKE UPPER( '%' || :INDBORRADO || '%')  AND (CASE WHEN CODIGO_NO_ACTIVO IS NULL THEN ' ' ELSE UPPER(CODIGO_NO_ACTIVO) END)  LIKE UPPER( '%' || :CODIGO_NO_ACTIVO || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN INDEXE IS NULL THEN ' ' ELSE UPPER(INDEXE) END)  LIKE UPPER( '%' || :INDEXE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN CODIGOANT1 IS NULL THEN ' ' ELSE UPPER(CODIGOANT1) END)  LIKE UPPER( '%' || :CODIGOANT1 || '%')  AND (CASE WHEN ACUERDO_PAGO IS NULL THEN ' ' ELSE UPPER(ACUERDO_PAGO) END)  LIKE UPPER( '%' || :ACUERDO_PAGO || '%')  AND (CASE WHEN IND_PROCESOJUD IS NULL THEN ' ' ELSE UPPER(IND_PROCESOJUD) END)  LIKE UPPER( '%' || :IND_PROCESOJUD || '%')  AND (CASE WHEN BLOQUEADO IS NULL THEN ' ' ELSE UPPER(BLOQUEADO) END)  LIKE UPPER( '%' || :BLOQUEADO || '%')  AND (CASE WHEN PROCESO_DE_COBRO IS NULL THEN ' ' ELSE UPPER(PROCESO_DE_COBRO) END)  LIKE UPPER( '%' || :PROCESO_DE_COBRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NUM_COM":"$NUM_COM","PAG_FEC":"$PAG_FEC","PAGO_ANO":"$PAGO_ANO(type:integer)","INDBORRADO":"$INDBORRADO(type:boolean)","CODIGO_NO_ACTIVO":"$CODIGO_NO_ACTIVO(type:boolean)","DIRECCION":"$DIRECCION","INDEXE":"$INDEXE(type:boolean)","NIT":"$NIT","CODIGOANT1":"$CODIGOANT1","ACUERDO_PAGO":"$ACUERDO_PAGO(type:boolean)","IND_PROCESOJUD":"$IND_PROCESOJUD(type:boolean)","BLOQUEADO":"$BLOQUEADO(type:boolean)","PROCESO_DE_COBRO":"$PROCESO_DE_COBRO(type:boolean)"}]}}		</result>
