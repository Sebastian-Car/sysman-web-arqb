	<query id="getIpusuariospredialNumTodosPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.NOMBRE, IP_USUARIOS_PREDIAL.CODIGO  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_USUARIOS_PREDIAL.NOMBRE IS NOT NULL AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN (0) ORDER BY IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.NOMBRE) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/todospornombre/num">
		<call-query href="getIpusuariospredialNumTodosPorNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialGeneralRecibosPorPropietarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_USUARIOS_PREDIAL.COMPANIA, IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NUMERO_ORDEN, IP_USUARIOS_PREDIAL.DIRECCION, IP_USUARIOS_PREDIAL.AVALUO_ANO, IP_USUARIOS_PREDIAL.TRPCOD, IP_USUARIOS_PREDIAL.PAGO_ANO,(CASE IP_USUARIOS_PREDIAL.IND_FACTURAR WHEN 0 THEN 'false' ELSE 'true' END) IND_FACTURAR FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN(0) AND IP_USUARIOS_PREDIAL.INDBORRADO IN(0) AND IP_USUARIOS_PREDIAL.NIT = :NITUSUARIO AND IP_USUARIOS_PREDIAL.NOMBRE = :NOMBREUSUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","DIRECCION":"$DIRECCION","AVALUO_ANO":"$AVALUO_ANO","TRPCOD":"$TRPCOD","PAGO_ANO":"$PAGO_ANO(type:integer)","IND_FACTURAR":"$IND_FACTURAR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITUSUARIO" sqlType="STRING"/>
		<param name="NOMBREUSUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/generalrecibosporpropietario">
		<call-query href="getIpusuariospredialGeneralRecibosPorPropietarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITUSUARIO" query-param="NITUSUARIO"/>
			<with-param name="NOMBREUSUARIO" query-param="NOMBREUSUARIO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialDetalleRecibosPorPropietarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_USUARIOS_PREDIAL.COMPANIA, IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NUMERO_ORDEN, IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.DIRECCION, IP_USUARIOS_PREDIAL.AVALUO_ANO, IP_USUARIOS_PREDIAL.TRPCOD, IP_USUARIOS_PREDIAL.PAGO_ANO, SUM(IP_FACTURADOS.TOTAL) TOTAL  FROM IP_USUARIOS_PREDIAL LEFT JOIN IP_FACTURADOS ON IP_USUARIOS_PREDIAL.COMPANIA = IP_FACTURADOS.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = IP_FACTURADOS.CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = IP_FACTURADOS.NUMERO_ORDEN WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN(0) AND IP_USUARIOS_PREDIAL.INDBORRADO IN(0) AND IP_USUARIOS_PREDIAL.IND_FACTURAR NOT IN(0) AND IP_FACTURADOS.INDPAGO_ACPAG IN(0) GROUP BY IP_USUARIOS_PREDIAL.COMPANIA, IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NUMERO_ORDEN, IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.DIRECCION, IP_USUARIOS_PREDIAL.AVALUO_ANO, IP_USUARIOS_PREDIAL.TRPCOD, IP_USUARIOS_PREDIAL.PAGO_ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","NIT":"$NIT","DIRECCION":"$DIRECCION","AVALUO_ANO":"$AVALUO_ANO","TRPCOD":"$TRPCOD","PAGO_ANO":"$PAGO_ANO(type:integer)","TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/detallerecibosporpropietario">
		<call-query href="getIpusuariospredialDetalleRecibosPorPropietarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialPagUsuariosActivosPorNitQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.INDBORRADO IN(0) AND IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO IN(0) ORDER BY IP_USUARIOS_PREDIAL.NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipusuariospredial/usuariosactivospornit/pag">
