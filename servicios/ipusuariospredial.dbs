<data name="ipusuariospredial" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpusuariospredialExistePorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) PREDIO  FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO_ORDEN AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREDIO":"$PREDIO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/existeporcodigo">
		<call-query href="getIpusuariospredialExistePorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialPagPorcompanianumordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_USUARIOS_PREDIAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipusuariospredial/porcompanianumorden/pag">
		<call-query href="getIpusuariospredialPagPorcompanianumordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialNumPorcompanianumordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_USUARIOS_PREDIAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/porcompanianumorden/num">
		<call-query href="getIpusuariospredialNumPorcompanianumordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialPagUsuariosActivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) AND CODIGO_NO_ACTIVO IN (0) ORDER BY IP_USUARIOS_PREDIAL.NUMERO_ORDEN,IP_USUARIOS_PREDIAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipusuariospredial/usuariosactivos/pag">
		<call-query href="getIpusuariospredialPagUsuariosActivosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialNumUsuariosActivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.INDBORRADO IN (0) AND CODIGO_NO_ACTIVO IN (0) ORDER BY IP_USUARIOS_PREDIAL.NUMERO_ORDEN,IP_USUARIOS_PREDIAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/usuariosactivos/num">
		<call-query href="getIpusuariospredialNumUsuariosActivosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialPagGeneralUsuariosNoActivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NUMERO_ORDEN, NIT, NOMBRE, DIRECCION, CASE NUMERO_ORDEN WHEN '001' THEN 'Principal' ELSE 'Copropietario' END TIPO_PROPIETARIO, PAGO_ANO  FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND INDBORRADO NOT IN (0) OR CODIGO_NO_ACTIVO NOT IN (0) ORDER BY CODIGO, NUMERO_ORDEN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN TIPO_PROPIETARIO IS NULL THEN ' ' ELSE UPPER(TIPO_PROPIETARIO) END)  LIKE UPPER( '%' || :TIPO_PROPIETARIO || '%')  AND (CASE WHEN PAGO_ANO IS NULL THEN ' ' ELSE UPPER(PAGO_ANO) END)  LIKE UPPER(:PAGO_ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","NIT":"$NIT","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","TIPO_PROPIETARIO":"$TIPO_PROPIETARIO","PAGO_ANO":"$PAGO_ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TIPO_PROPIETARIO" sqlType="STRING"/>
		<param name="PAGO_ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipusuariospredial/generalusuariosnoactivos/pag">
		<call-query href="getIpusuariospredialPagGeneralUsuariosNoActivosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TIPO_PROPIETARIO" query-param="TIPO_PROPIETARIO"/>
			<with-param name="PAGO_ANO" query-param="PAGO_ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialNumGeneralUsuariosNoActivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NUMERO_ORDEN, NIT, NOMBRE, DIRECCION, CASE NUMERO_ORDEN WHEN '001' THEN 'Principal' ELSE 'Copropietario' END TIPO_PROPIETARIO, PAGO_ANO  FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND INDBORRADO NOT IN (0) OR CODIGO_NO_ACTIVO NOT IN (0) ORDER BY CODIGO, NUMERO_ORDEN) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN TIPO_PROPIETARIO IS NULL THEN ' ' ELSE UPPER(TIPO_PROPIETARIO) END)  LIKE UPPER( '%' || :TIPO_PROPIETARIO || '%')  AND (CASE WHEN PAGO_ANO IS NULL THEN ' ' ELSE UPPER(PAGO_ANO) END)  LIKE UPPER(:PAGO_ANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TIPO_PROPIETARIO" sqlType="STRING"/>
		<param name="PAGO_ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/generalusuariosnoactivos/num">
		<call-query href="getIpusuariospredialNumGeneralUsuariosNoActivosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TIPO_PROPIETARIO" query-param="TIPO_PROPIETARIO"/>
			<with-param name="PAGO_ANO" query-param="PAGO_ANO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialNombrePorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_USUARIOS_PREDIAL.NOMBRE  FROM IP_USUARIOS_PREDIAL WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = :CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = :NUMERO_ORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/nombreporcodigo">
		<call-query href="getIpusuariospredialNombrePorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialPagNombreynitpornumordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NOMBRE, NIT  FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO_ORDEN AND INDBORRADO IN (0) AND CODIGO_NO_ACTIVO IN (0) ORDER BY NOMBRE) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","NIT":"$NIT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipusuariospredial/nombreynitpornumorden/pag">
		<call-query href="getIpusuariospredialPagNombreynitpornumordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO, NUMERO_ORDEN, NIT, NOMBRE, DIRECCION, CASE NUMERO_ORDEN WHEN '001' THEN 'Principal' ELSE 'Copropietario' END TIPO_PROPIETARIO, PAGO_ANO FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND INDBORRADO IN ( 0 ) AND CODIGO_NO_ACTIVO IN ( 0 ) ORDER BY COMPANIA, CODIGO, NUMERO_ORDEN) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN TIPO_PROPIETARIO IS NULL THEN ' ' ELSE UPPER(TIPO_PROPIETARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_PROPIETARIO), '%')) AND (CASE WHEN PAGO_ANO IS NULL THEN ' ' ELSE UPPER(PAGO_ANO) END) LIKE UPPER(CONCAT(:PAGO_ANO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","NIT":"$NIT","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","TIPO_PROPIETARIO":"$TIPO_PROPIETARIO","PAGO_ANO":"$PAGO_ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TIPO_PROPIETARIO" sqlType="STRING"/>
		<param name="PAGO_ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipusuariospredial">
		<call-query href="getIpusuariospredialPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TIPO_PROPIETARIO" query-param="TIPO_PROPIETARIO"/>
			<with-param name="PAGO_ANO" query-param="PAGO_ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO, NUMERO_ORDEN, NIT, NOMBRE, DIRECCION, CASE NUMERO_ORDEN WHEN '001' THEN 'Principal' ELSE 'Copropietario' END TIPO_PROPIETARIO, PAGO_ANO FROM IP_USUARIOS_PREDIAL WHERE COMPANIA = :COMPANIA AND INDBORRADO IN ( 0 ) AND CODIGO_NO_ACTIVO IN ( 0 ) ORDER BY COMPANIA, CODIGO, NUMERO_ORDEN) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN TIPO_PROPIETARIO IS NULL THEN ' ' ELSE UPPER(TIPO_PROPIETARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_PROPIETARIO), '%')) AND (CASE WHEN PAGO_ANO IS NULL THEN ' ' ELSE UPPER(PAGO_ANO) END) LIKE UPPER(CONCAT(:PAGO_ANO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TIPO_PROPIETARIO" sqlType="STRING"/>
		<param name="PAGO_ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipusuariospredial/numero">
		<call-query href="getIpusuariospredialNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TIPO_PROPIETARIO" query-param="TIPO_PROPIETARIO"/>
			<with-param name="PAGO_ANO" query-param="PAGO_ANO"/>

		</call-query>
	</resource>
	<query id="getIpusuariospredialRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT IP_USUARIOS_PREDIAL.COMPANIA, IP_USUARIOS_PREDIAL.CODIGO, IP_USUARIOS_PREDIAL.NUMERO_ORDEN, IP_USUARIOS_PREDIAL.DIGITO,(TO_CHAR(IP_USUARIOS_PREDIAL.PAGFEC_CUOTA2,'DD/MM/YYYY HH24:MI:SS')) PAGFEC_CUOTA2, IP_USUARIOS_PREDIAL.PAGO_NCUOTA2, IP_USUARIOS_PREDIAL.OBSERVACIONES_ACUERDO, IP_USUARIOS_PREDIAL.OBSERVACIO,(TO_CHAR(IP_USUARIOS_PREDIAL.FECHA_ADQ,'DD/MM/YYYY HH24:MI:SS')) FECHA_ADQ, IP_USUARIOS_PREDIAL.NOTARIA, IP_USUARIOS_PREDIAL.ESCRITURA, IP_USUARIOS_PREDIAL.DIR_COB, IP_USUARIOS_PREDIAL.CLASE_PRE, IP_USUARIOS_PREDIAL.TARIFA_ANTERIOR, IP_USUARIOS_PREDIAL.AVALUO_ANT,(CASE IP_USUARIOS_PREDIAL.OTROSDESC WHEN 0 THEN 'false' ELSE 'true' END) OTROSDESC, IP_USUARIOS_PREDIAL.PROINDIV, IP_USUARIOS_PREDIAL.TRPCOD_COPY, IP_USUARIOS_PREDIAL.TEMPORAL, IP_USUARIOS_PREDIAL.ANOHASTA, IP_USUARIOS_PREDIAL.S1, IP_USUARIOS_PREDIAL.S2, IP_USUARIOS_PREDIAL.S3, IP_USUARIOS_PREDIAL.S4, IP_USUARIOS_PREDIAL.S5, IP_USUARIOS_PREDIAL.S6, IP_USUARIOS_PREDIAL.S7, IP_USUARIOS_PREDIAL.S8, IP_USUARIOS_PREDIAL.S9, IP_USUARIOS_PREDIAL.S10, IP_USUARIOS_PREDIAL.S11, IP_USUARIOS_PREDIAL.S12, IP_USUARIOS_PREDIAL.S13, IP_USUARIOS_PREDIAL.S14, IP_USUARIOS_PREDIAL.S15, IP_USUARIOS_PREDIAL.S16, IP_USUARIOS_PREDIAL.S17, IP_USUARIOS_PREDIAL.S18, IP_USUARIOS_PREDIAL.S19, IP_USUARIOS_PREDIAL.S20, IP_USUARIOS_PREDIAL.AREA_CONST_ANT, IP_USUARIOS_PREDIAL.OBSERVACION_COBRO_COACTIVO, IP_USUARIOS_PREDIAL.EXOFINAL, IP_USUARIOS_PREDIAL.TRPRAN, IP_USUARIOS_PREDIAL.EXOINICIAL,(CASE IP_USUARIOS_PREDIAL.EXONERADO WHEN 0 THEN 'false' ELSE 'true' END) EXONERADO,(CASE IP_USUARIOS_PREDIAL.INDEXEOTROS WHEN 0 THEN 'false' ELSE 'true' END) INDEXEOTROS, IP_USUARIOS_PREDIAL.NUMERO_PROCESO,(CASE IP_USUARIOS_PREDIAL.IND_PROCESOJUD WHEN 0 THEN 'false' ELSE 'true' END) IND_PROCESOJUD, IP_USUARIOS_PREDIAL.ETAPA_PROCESOJUD,(CASE IP_USUARIOS_PREDIAL.IND_EXEINT WHEN 0 THEN 'false' ELSE 'true' END) IND_EXEINT,(TO_CHAR(IP_USUARIOS_PREDIAL.FECINICIAL_EXEINT,'DD/MM/YYYY HH24:MI:SS')) FECINICIAL_EXEINT,(TO_CHAR(IP_USUARIOS_PREDIAL.FECFINAL_EXEINT,'DD/MM/YYYY HH24:MI:SS')) FECFINAL_EXEINT,(CASE IP_USUARIOS_PREDIAL.BLOQUEADO WHEN 0 THEN 'false' ELSE 'true' END) BLOQUEADO, IP_USUARIOS_PREDIAL.OBS_BLOQUEADO, IP_USUARIOS_PREDIAL.COD_POSTAL, IP_USUARIOS_PREDIAL.FECHA_CAMBIO_AVALUO, IP_USUARIOS_PREDIAL.CAMBIO_AVALUO, IP_USUARIOS_PREDIAL.CODIGO_EQUIVALENTE, IP_USUARIOS_PREDIAL.RESOLUCION_INCAUTA,(CASE IP_USUARIOS_PREDIAL.PLUSVALIA WHEN 0 THEN 'false' ELSE 'true' END) PLUSVALIA,(CASE IP_USUARIOS_PREDIAL.INDICADOR_RESERVA WHEN 0 THEN 'false' ELSE 'true' END) INDICADOR_RESERVA, IP_USUARIOS_PREDIAL.PORCENTAJE_RESERVA * 100 PORCENTAJE_RESERVA,(CASE IP_USUARIOS_PREDIAL.TERCERO_RECIPROCO WHEN 0 THEN 'false' ELSE 'true' END) TERCERO_RECIPROCO,(CASE IP_USUARIOS_PREDIAL.IND_EXEINT_DUP WHEN 0 THEN 'false' ELSE 'true' END) IND_EXEINT_DUP, IP_USUARIOS_PREDIAL.RESOLUCION_EXTINT_DUP,(CASE IP_USUARIOS_PREDIAL.AUTOAVALUO WHEN 0 THEN 'false' ELSE 'true' END) AUTOAVALUO,(CASE IP_USUARIOS_PREDIAL.PERMITE_EXP_CERT WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_EXP_CERT, IP_USUARIOS_PREDIAL.FORMATO_ESTRATO,(CASE IP_USUARIOS_PREDIAL.UPAPROBADOFISC WHEN 0 THEN 'false' ELSE 'true' END) UPAPROBADOFISC, IP_USUARIOS_PREDIAL.TIPO_TRAMITE, IP_USUARIOS_PREDIAL.ESPACIO, IP_USUARIOS_PREDIAL.TIPO_MUTACION, IP_USUARIOS_PREDIAL.PAIS_NOTIFICACION, IP_USUARIOS_PREDIAL.DEPARTAMENTO_NOTIFICACION, IP_USUARIOS_PREDIAL.CIUDAD_NOTIFICACION,(CASE IP_USUARIOS_PREDIAL.IND_LEY10032015 WHEN 0 THEN 'false' ELSE 'true' END) IND_LEY10032015, IP_USUARIOS_PREDIAL.CREATED_BY,(TO_CHAR(IP_USUARIOS_PREDIAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, IP_USUARIOS_PREDIAL.MODIFIED_BY,(TO_CHAR(IP_USUARIOS_PREDIAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, IP_USUARIOS_PREDIAL.PAG_VAL2,(TO_CHAR(IP_USUARIOS_PREDIAL.PAG_FEC2,'DD/MM/YYYY HH24:MI:SS')) PAG_FEC2, IP_USUARIOS_PREDIAL.NUM_COM1,(CASE IP_USUARIOS_PREDIAL.INDHIP WHEN 0 THEN 'false' ELSE 'true' END) INDHIP,(CASE IP_USUARIOS_PREDIAL.INDCAR WHEN 0 THEN 'false' ELSE 'true' END) INDCAR,(CASE IP_USUARIOS_PREDIAL.INDEXE WHEN 0 THEN 'false' ELSE 'true' END) INDEXE,(CASE IP_USUARIOS_PREDIAL.INDBORRADO WHEN 0 THEN 'false' ELSE 'true' END) INDBORRADO,(TO_CHAR(IP_USUARIOS_PREDIAL.FECHABORRADO,'DD/MM/YYYY HH24:MI:SS')) FECHABORRADO, IP_USUARIOS_PREDIAL.BORRADOPOR, IP_USUARIOS_PREDIAL.TRPCOD, IP_TARIFAS.TRPDES, IP_USUARIOS_PREDIAL.TRPANO,(CASE IP_USUARIOS_PREDIAL.INDEXD WHEN 0 THEN 'false' ELSE 'true' END) INDEXD, IP_USUARIOS_PREDIAL.IMPCAR, IP_USUARIOS_PREDIAL.CREDITO, IP_USUARIOS_PREDIAL.SOBRETCAR, IP_USUARIOS_PREDIAL.SOBRETBOM, IP_USUARIOS_PREDIAL.SOBRETALU, IP_USUARIOS_PREDIAL.PREDCO, IP_USUARIOS_PREDIAL.PREUSO,(CASE IP_USUARIOS_PREDIAL.ANTERIOR_RURAL WHEN 0 THEN 'false' ELSE 'true' END) ANTERIOR_RURAL,(CASE IP_USUARIOS_PREDIAL.CODIGO_NO_ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) CODIGO_NO_ACTIVO, IP_USUARIOS_PREDIAL.TOTAL, IP_USUARIOS_PREDIAL.C1, IP_USUARIOS_PREDIAL.C2, IP_USUARIOS_PREDIAL.C3, IP_USUARIOS_PREDIAL.C4, IP_USUARIOS_PREDIAL.C5, IP_USUARIOS_PREDIAL.C6, IP_USUARIOS_PREDIAL.C7, IP_USUARIOS_PREDIAL.C8, IP_USUARIOS_PREDIAL.C9, IP_USUARIOS_PREDIAL.C10, IP_USUARIOS_PREDIAL.C11, IP_USUARIOS_PREDIAL.C12, IP_USUARIOS_PREDIAL.C13, IP_USUARIOS_PREDIAL.C14, IP_USUARIOS_PREDIAL.C15, IP_USUARIOS_PREDIAL.C16, IP_USUARIOS_PREDIAL.C17, IP_USUARIOS_PREDIAL.C18, IP_USUARIOS_PREDIAL.C19, IP_USUARIOS_PREDIAL.C20, IP_USUARIOS_PREDIAL.DANE_CODIGO, IP_USUARIOS_PREDIAL.DIRECCION_CORRESPONDENCIA,(CASE IP_USUARIOS_PREDIAL.INDPAGOANOANTE WHEN 0 THEN 'false' ELSE 'true' END) INDPAGOANOANTE, IP_USUARIOS_PREDIAL.TOTAL1, IP_USUARIOS_PREDIAL.VALORPAGADOIMP, IP_USUARIOS_PREDIAL.VALORPAGADOCAR,(CASE IP_USUARIOS_PREDIAL.INDPAGOAUTOMATICO WHEN 0 THEN 'false' ELSE 'true' END) INDPAGOAUTOMATICO,(CASE IP_USUARIOS_PREDIAL.INDMANDAMIENTOPAGO WHEN 0 THEN 'false' ELSE 'true' END) INDMANDAMIENTOPAGO, IP_USUARIOS_PREDIAL.M_INMOBILIARIA, IP_USUARIOS_PREDIAL.CLASE_PREDIO,(CASE IP_USUARIOS_PREDIAL.DAMNIFICADO WHEN 0 THEN 'false' ELSE 'true' END) DAMNIFICADO, IP_USUARIOS_PREDIAL.CODIGOANT1, IP_USUARIOS_PREDIAL.CODIGOANT2, IP_USUARIOS_PREDIAL.CODIGOANT3, IP_USUARIOS_PREDIAL.UBICACION,(CASE IP_USUARIOS_PREDIAL.NOLEY44 WHEN 0 THEN 'false' ELSE 'true' END) NOLEY44, IP_USUARIOS_PREDIAL.ANO_CONSTRUCCION,(TO_CHAR(IP_USUARIOS_PREDIAL.FECHACALCULO,'DD/MM/YYYY HH24:MI:SS')) FECHACALCULO, IP_USUARIOS_PREDIAL.NUM_COM2, IP_USUARIOS_PREDIAL.OBSERVACIONES_DE_PAGOS, IP_USUARIOS_PREDIAL.RURAL_O_URBANO, IP_USUARIOS_PREDIAL.USO_SUELO, IP_USUARIOS_PREDIAL.ZONA_GEO,(CASE IP_USUARIOS_PREDIAL.ACUERDO_PAGO WHEN 0 THEN 'false' ELSE 'true' END) ACUERDO_PAGO, IP_USUARIOS_PREDIAL.DIRECCION, IP_USUARIOS_PREDIAL.MATRICULA_INMOBILIARIA, IP_USUARIOS_PREDIAL.PAG_BAN1, IP_USUARIOS_PREDIAL.PAG_BAN2, IP_USUARIOS_PREDIAL.RESOLUCION, IP_USUARIOS_PREDIAL.COMUNA, IP_USUARIOS_PREDIAL.RADICACION, IP_USUARIOS_PREDIAL.ESTADO_CIVIL, IP_USUARIOS_PREDIAL.UNICO_ANO_A_PAGAR, IP_USUARIOS_PREDIAL.RECIBO_ACTUAL, IP_USUARIOS_PREDIAL.PAGO_ANO_ABONO, IP_USUARIOS_PREDIAL.VALORULTIMOABONO,(TO_CHAR(IP_USUARIOS_PREDIAL.FECHAULTIMOABONO,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMOABONO, IP_USUARIOS_PREDIAL.FACTURAULTIMOABONO, IP_USUARIOS_PREDIAL.BANCOULTIMOABONO,(CASE IP_USUARIOS_PREDIAL.PROCESO_DE_COBRO WHEN 0 THEN 'false' ELSE 'true' END) PROCESO_DE_COBRO, IP_USUARIOS_PREDIAL.EXINICIAL, IP_USUARIOS_PREDIAL.EXFINAL, IP_USUARIOS_PREDIAL.FACTURA_ACUERDO, IP_USUARIOS_PREDIAL.TOTAL_ACUERDO, IP_USUARIOS_PREDIAL.PAGO_ANO_ABONO1, IP_USUARIOS_PREDIAL.VALORULTIMOABONO1,(TO_CHAR(IP_USUARIOS_PREDIAL.FECHAULTIMOABONO1,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMOABONO1, IP_USUARIOS_PREDIAL.FACTURAULTIMOABONO1, IP_USUARIOS_PREDIAL.BANCOULTIMOABONO1, IP_USUARIOS_PREDIAL.PAGO_ANO_ABONO2, IP_USUARIOS_PREDIAL.VALORULTIMOABONO2,(TO_CHAR(IP_USUARIOS_PREDIAL.FECHAULTIMOABONO2,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMOABONO2, IP_USUARIOS_PREDIAL.FACTURAULTIMOABONO2, IP_USUARIOS_PREDIAL.BANCOULTIMOABONO2,(CASE IP_USUARIOS_PREDIAL.PAGO_CUOTAS WHEN 0 THEN 'false' ELSE 'true' END) PAGO_CUOTAS,(CASE IP_USUARIOS_PREDIAL.PAGO_ACUERDO WHEN 0 THEN 'false' ELSE 'true' END) PAGO_ACUERDO, IP_USUARIOS_PREDIAL.PAGO_ANO_CUOTA, IP_USUARIOS_PREDIAL.FACTURA_CUOTA, IP_USUARIOS_PREDIAL.TOTAL_CUOTA, IP_USUARIOS_PREDIAL.PAGBAN_CUOTA,(TO_CHAR(IP_USUARIOS_PREDIAL.PAGFEC_CUOTA,'DD/MM/YYYY HH24:MI:SS')) PAGFEC_CUOTA, IP_USUARIOS_PREDIAL.PAGO_NCUOTA, IP_USUARIOS_PREDIAL.PAGO_ANO_CUOTA1, IP_USUARIOS_PREDIAL.FACTURA_CUOTA1, IP_USUARIOS_PREDIAL.TOTAL_CUOTA1, IP_USUARIOS_PREDIAL.PAGBAN_CUOTA1,(TO_CHAR(IP_USUARIOS_PREDIAL.PAGFEC_CUOTA1,'DD/MM/YYYY HH24:MI:SS')) PAGFEC_CUOTA1, IP_USUARIOS_PREDIAL.PAGO_NCUOTA1, IP_USUARIOS_PREDIAL.PAGO_ANO_CUOTA2, IP_USUARIOS_PREDIAL.FACTURA_CUOTA2, IP_USUARIOS_PREDIAL.TOTAL_CUOTA2, IP_USUARIOS_PREDIAL.PAGBAN_CUOTA2, IP_USUARIOS_PREDIAL.PAIS, IP_USUARIOS_PREDIAL.DEPARTAMENTO, IP_USUARIOS_PREDIAL.MUNICIPIO, IP_USUARIOS_PREDIAL.TIPO, IP_USUARIOS_PREDIAL.NUMERO_REGISTROS, IP_USUARIOS_PREDIAL.TIPO_NIT, IP_USUARIOS_PREDIAL.NIT, IP_USUARIOS_PREDIAL.SUCURSAL, IP_USUARIOS_PREDIAL.NOMBRE, IP_USUARIOS_PREDIAL.DESTINO_ECONOMICO, IP_USUARIOS_PREDIAL.AREA_HA, IP_USUARIOS_PREDIAL.AREA_M2, IP_USUARIOS_PREDIAL.AREA_CONSTRUIDA, IP_USUARIOS_PREDIAL.AVALUO_ANO, IP_USUARIOS_PREDIAL.CONDICION_TRIBUTARIA, IP_USUARIOS_PREDIAL.NOVEDAD, IP_USUARIOS_PREDIAL.MUTACION,(TO_CHAR(IP_USUARIOS_PREDIAL.FECHA_MOVIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_MOVIMIENTO, IP_USUARIOS_PREDIAL.CODIGO_MAPA, IP_USUARIOS_PREDIAL.TELEFONO_PROPIETARIO, IP_USUARIOS_PREDIAL.DIRECCION_EMAIL, IP_USUARIOS_PREDIAL.CODIGO_RUTA_ALTERNO, IP_USUARIOS_PREDIAL.ESTRATO_SOCIOECONOMICO, IP_USUARIOS_PREDIAL.VIGENCIA, IP_USUARIOS_PREDIAL.PAGO_ANO, IP_USUARIOS_PREDIAL.TARIFA_ULTIMO_PAGO, IP_USUARIOS_PREDIAL.AVALUO_ULTIMO_PAGO, IP_USUARIOS_PREDIAL.PAG_VAL,(TO_CHAR(IP_USUARIOS_PREDIAL.PAG_FEC,'DD/MM/YYYY HH24:MI:SS')) PAG_FEC, IP_USUARIOS_PREDIAL.PAG_BAN, IP_USUARIOS_PREDIAL.NUMERO_FACTURA, IP_USUARIOS_PREDIAL.NUM_COM, IP_USUARIOS_PREDIAL.PAGO_ANO1, IP_USUARIOS_PREDIAL.PAG_VAL1,(TO_CHAR(IP_USUARIOS_PREDIAL.PAG_FEC1,'DD/MM/YYYY HH24:MI:SS')) PAG_FEC1, IP_USUARIOS_PREDIAL.PAGO_ANO2,(CASE IP_USUARIOS_PREDIAL.INDPAGOALUMBRADO WHEN 0 THEN 'false' ELSE 'true' END) INDPAGOALUMBRADO FROM IP_USUARIOS_PREDIAL LEFT JOIN IP_TARIFAS ON IP_USUARIOS_PREDIAL.COMPANIA = IP_TARIFAS.COMPANIA AND IP_USUARIOS_PREDIAL.TRPCOD = IP_TARIFAS.TRPCOD AND IP_USUARIOS_PREDIAL.TRPANO = IP_TARIFAS.TRPANO AND IP_USUARIOS_PREDIAL.TRPRAN = IP_TARIFAS.TRPRAN WHERE IP_USUARIOS_PREDIAL.COMPANIA= :KEY_COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO= :KEY_CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN= :KEY_NUMERO_ORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NUMERO_ORDEN":"$NUMERO_ORDEN","DIGITO":"$DIGITO(type:long)","PAGFEC_CUOTA2":"$PAGFEC_CUOTA2","PAGO_NCUOTA2":"$PAGO_NCUOTA2","OBSERVACIONES_ACUERDO":"$OBSERVACIONES_ACUERDO","OBSERVACIO":"$OBSERVACIO","FECHA_ADQ":"$FECHA_ADQ","NOTARIA":"$NOTARIA","ESCRITURA":"$ESCRITURA","DIR_COB":"$DIR_COB","CLASE_PRE":"$CLASE_PRE","TARIFA_ANTERIOR":"$TARIFA_ANTERIOR","AVALUO_ANT":"$AVALUO_ANT","OTROSDESC":"$OTROSDESC(type:boolean)","PROINDIV":"$PROINDIV","TRPCOD_COPY":"$TRPCOD_COPY","TEMPORAL":"$TEMPORAL","ANOHASTA":"$ANOHASTA(type:integer)","S1":"$S1","S2":"$S2","S3":"$S3","S4":"$S4","S5":"$S5","S6":"$S6","S7":"$S7","S8":"$S8","S9":"$S9","S10":"$S10","S11":"$S11","S12":"$S12","S13":"$S13","S14":"$S14","S15":"$S15","S16":"$S16","S17":"$S17","S18":"$S18","S19":"$S19","S20":"$S20","AREA_CONST_ANT":"$AREA_CONST_ANT","OBSERVACION_COBRO_COACTIVO":"$OBSERVACION_COBRO_COACTIVO","EXOFINAL":"$EXOFINAL","TRPRAN":"$TRPRAN","EXOINICIAL":"$EXOINICIAL","EXONERADO":"$EXONERADO(type:boolean)","INDEXEOTROS":"$INDEXEOTROS(type:boolean)","NUMERO_PROCESO":"$NUMERO_PROCESO","IND_PROCESOJUD":"$IND_PROCESOJUD(type:boolean)","ETAPA_PROCESOJUD":"$ETAPA_PROCESOJUD","IND_EXEINT":"$IND_EXEINT(type:boolean)","FECINICIAL_EXEINT":"$FECINICIAL_EXEINT","FECFINAL_EXEINT":"$FECFINAL_EXEINT","BLOQUEADO":"$BLOQUEADO(type:boolean)","OBS_BLOQUEADO":"$OBS_BLOQUEADO","COD_POSTAL":"$COD_POSTAL","FECHA_CAMBIO_AVALUO":"$FECHA_CAMBIO_AVALUO","CAMBIO_AVALUO":"$CAMBIO_AVALUO","CODIGO_EQUIVALENTE":"$CODIGO_EQUIVALENTE","RESOLUCION_INCAUTA":"$RESOLUCION_INCAUTA","PLUSVALIA":"$PLUSVALIA(type:boolean)","INDICADOR_RESERVA":"$INDICADOR_RESERVA(type:boolean)","PORCENTAJE_RESERVA":"$PORCENTAJE_RESERVA(type:double)","TERCERO_RECIPROCO":"$TERCERO_RECIPROCO(type:boolean)","IND_EXEINT_DUP":"$IND_EXEINT_DUP(type:boolean)","RESOLUCION_EXTINT_DUP":"$RESOLUCION_EXTINT_DUP","AUTOAVALUO":"$AUTOAVALUO(type:boolean)","PERMITE_EXP_CERT":"$PERMITE_EXP_C