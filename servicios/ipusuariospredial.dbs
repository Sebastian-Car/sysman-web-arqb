	<query id="getIpusuariospredialTotalAFacturarQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(SUM(IP_FACTURADOS.TOTAL), '99,999,999,999,999,990.90') TFACTURAR  FROM IP_USUARIOS_PREDIAL LEFT JOIN IP_FACTURADOS ON IP_USUARIOS_PREDIAL.COMPANIA = IP_FACTURADOS.COMPANIA AND IP_USUARIOS_PREDIAL.CODIGO = IP_FACTURADOS.CODIGO AND IP_USUARIOS_PREDIAL.NUMERO_ORDEN = IP_FACTURADOS.NUMERO_ORDEN WHERE IP_USUARIOS_PREDIAL.COMPANIA = :COMPANIA AND IP_USUARIOS_PREDIAL.IND_FACTURAR NOT IN (0) AND IP_FACTURADOS.INDPAGO_ACPAG IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TFACTURAR":"$TFACTURAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
