	<query id="deleteVacaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VACACIONES WHERE VACACIONES.COMPANIA= :KEY_COMPANIA AND VACACIONES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND VACACIONES.ANO= :KEY_ANO AND VACACIONES.MES= :KEY_MES AND VACACIONES.PERIODO= :KEY_PERIODO AND VACACIONES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND VACACIONES.ACTO= :KEY_ACTO AND VACACIONES.INICIO_DISFRUTE= TO_DATE(:KEY_INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ACTO" sqlType="STRING"/>
		<param name="KEY_INICIO_DISFRUTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vacaciones">
		<call-query href="deleteVacaciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ACTO" query-param="KEY_ACTO"/>
			<with-param name="KEY_INICIO_DISFRUTE" query-param="KEY_INICIO_DISFRUTE"/>

		</call-query>
	</resource>
	<query id="getVacacionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT VACACIONES.COMPANIA, VACACIONES.ID_DE_PROCESO, VACACIONES.ANO, VACACIONES.MES, VACACIONES.PERIODO, VACACIONES.ID_DE_EMPLEADO, VACACIONES.ID_DE_CONCEPTO,(TO_CHAR(VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, VACACIONES.ACTO,(TO_CHAR(VACACIONES.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, VACACIONES.DIAS,(CASE VACACIONES.ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) ENDINERO,(TO_CHAR(VACACIONES.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, VACACIONES.DIASHABILES, VACACIONES.NUMPERIODOS, VACACIONES.DIASDINERO, VACACIONES.OBSERVACION_V, VACACIONES.DIASPENDIENTESDEDISFRUTE, VACACIONES.CREATED_BY,(TO_CHAR(VACACIONES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VACACIONES.MODIFIED_BY,(TO_CHAR(VACACIONES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM VACACIONES WHERE VACACIONES.COMPANIA=:COMPANIA AND VACACIONES.ID_DE_EMPLEADO = :ID_DE_EMPLEADO ORDER BY VACACIONES.FECHAPAGO DESC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_PROCESO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_EMPLEADO), '%')) AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_CONCEPTO), '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIO), '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINAL), '%')) AND (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END) LIKE UPPER(CONCAT(CONCAT('%',:INICIO_DISFRUTE), '%')) AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END) LIKE UPPER(CONCAT(CONCAT('%',:FINAL_DISFRUTE), '%')) AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END) LIKE UPPER(CONCAT(:ACTO, '%')) AND (CASE WHEN FECHA_ACTO IS NULL THEN ' ' ELSE UPPER(FECHA_ACTO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_ACTO), '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(CONCAT('%',:DIAS), '%')) AND (CASE WHEN ENDINERO IS NULL THEN ' ' ELSE UPPER(ENDINERO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENDINERO), '%')) AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAPAGO), '%')) AND (CASE WHEN DIASHABILES IS NULL THEN ' ' ELSE UPPER(DIASHABILES) END) LIKE UPPER(CONCAT(CONCAT('%',:DIASHABILES), '%')) AND (CASE WHEN NUMPERIODOS IS NULL THEN ' ' ELSE UPPER(NUMPERIODOS) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMPERIODOS), '%')) AND (CASE WHEN DIASDINERO IS NULL THEN ' ' ELSE UPPER(DIASDINERO) END) LIKE UPPER(CONCAT(CONCAT('%',:DIASDINERO), '%')) AND (CASE WHEN OBSERVACION_V IS NULL THEN ' ' ELSE UPPER(OBSERVACION_V) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACION_V), '%')) AND (CASE WHEN DIASPENDIENTESDEDISFRUTE IS NULL THEN ' ' ELSE UPPER(DIASPENDIENTESDEDISFRUTE) END) LIKE UPPER(CONCAT(CONCAT('%',:DIASPENDIENTESDEDISFRUTE), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:CREATED_BY), '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_CREATED), '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFIED_BY), '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_MODIFIED), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","ACTO":"$ACTO","FECHA_ACTO":"$FECHA_ACTO","DIAS":"$DIAS","ENDINERO":"$ENDINERO(type:boolean)","FECHAPAGO":"$FECHAPAGO","DIASHABILES":"$DIASHABILES","NUMPERIODOS":"$NUMPERIODOS","DIASDINERO":"$DIASDINERO","OBSERVACION_V":"$OBSERVACION_V","DIASPENDIENTESDEDISFRUTE":"$DIASPENDIENTESDEDISFRUTE","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
