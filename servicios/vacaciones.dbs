	<query id="getVacacionesTotaldiasvacacionesporperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(FECHA_INICIO, 'YYYY') AS ANIO, ID_DE_EMPLEADO, SUM(DIASHABILES) DIASHABILES, SUM(DIASHABILES + DIASDINERO) AS TOTAL_DIAS,(TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, NUMPERIODOS FROM VACACIONES WHERE COMPANIA = :COMPANIA AND ID_DE_EMPLEADO = :IDEMPLEADO AND TO_CHAR(FECHA_INICIO, 'YYYY') = :FECHAINI AND TO_CHAR(FECHA_FINAL, 'YYYY') = :FECHAFIN GROUP BY TO_CHAR(FECHA_INICIO, 'YYYY'), ID_DE_EMPLEADO, FECHA_INICIO, FECHA_FINAL, NUMPERIODOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANIO":"$ANIO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","DIASHABILES":"$DIASHABILES(type:integer)","TOTAL_DIAS":"$TOTAL_DIAS(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","NUMPERIODOS":"$NUMPERIODOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEMPLEADO" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vacaciones/totaldiasvacacionesporperiodo">
