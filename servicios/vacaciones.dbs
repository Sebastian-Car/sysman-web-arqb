 <data name="vacaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVacacionesTodosPorEmpleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE FROM VACACIONES WHERE COMPANIA =:COMPANIA AND ID_DE_EMPLEADO= :ID_EMPLEADO AND FECHA_INICIO = TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vacaciones/todosporempleado">
		<call-query href="getVacacionesTodosPorEmpleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="deleteVacacionesTodosPorCompaniaIdEmpledoFechaPago" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VACACIONES WHERE VACACIONES.COMPANIA              = :COMPANIA AND VACACIONES.ID_DE_EMPLEADO          = :ID_DE_EMPLEADO AND VACACIONES.FECHA_INICIO            =:FECHA_INICIO AND VACACIONES.FECHA_FINAL             =:FECHA_FINAL AND VACACIONES.DIASPENDIENTESDEDISFRUTE=:DIASPENDIENTESDEDISFRUTE AND VACACIONES.FECHAPAGO               =:FECHAPAGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="DIASPENDIENTESDEDISFRUTE" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vacaciones/todosporcompaniaidempledofechapago">
		<call-query href="deleteVacacionesTodosPorCompaniaIdEmpledoFechaPago">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="DIASPENDIENTESDEDISFRUTE" query-param="DIASPENDIENTESDEDISFRUTE"/>
			<with-param name="FECHAPAGO" query-param="FECHAPAGO"/>

		</call-query>
	</resource>
	<query id="getVacacionesPorpersonalcalculoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO,(TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, ACTO,(TO_CHAR(FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, DIAS,(CASE ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) ENDINERO,(TO_CHAR(FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, DIASHABILES, NUMPERIODOS,(CASE INDRTVAC WHEN 0 THEN 'false' ELSE 'true' END) INDRTVAC,(TO_CHAR(FECHARTVAC,'DD/MM/YYYY HH24:MI:SS')) FECHARTVAC, DIASRTVAC,(TO_CHAR(F_PAGORTVAC,'DD/MM/YYYY HH24:MI:SS')) F_PAGORTVAC, DIASDINERO, DIASPENDIENTESDEDISFRUTE  FROM VACACIONES WHERE COMPANIA = :COMPANIA AND ID_DE_EMPLEADO IN ( SELECT ID_DE_EMPLEADO FROM PERSONAL,PERIODOS WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO BETWEEN :EMPLEADOINI AND :EMPLEADOFIN AND PERSONAL.DEPENDENCIA BETWEEN :DEPENDENCIAINI AND :DEPENDENCIAFIN AND PERSONAL.ID_DE_TIPO BETWEEN :TIPOINI AND :TIPOFIN AND PERSONAL.ID_CENTRO_DE_COSTO BETWEEN :CENTROINI AND :CENTROFIN AND PERIODOS.COMPANIA=:COMPANIA AND PERIODOS.ID_DE_PROCESO=:PROCESO AND PERIODOS.ANO=:ANO AND PERIODOS.MES=:MES AND PERIODOS.PERIODO=:PERIODO AND ( PERSONAL.FECHA_DE_INGRESO &lt;= PERIODOS.FECHAFINAL AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 OR PERSONAL.FECHA_DE_RETIRO &gt;=PERIODOS.FECHAFINAL AND PERSONAL.FECHA_DE_INGRESO &lt;=PERIODOS.FECHAINICIO AND PERSONAL.ESTADO_ACTUAL = 3 ) ) ORDER BY ID_DE_EMPLEADO , ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","ACTO":"$ACTO","FECHA_ACTO":"$FECHA_ACTO","DIAS":"$DIAS","ENDINERO":"$ENDINERO(type:boolean)","FECHAPAGO":"$FECHAPAGO","DIASHABILES":"$DIASHABILES","NUMPERIODOS":"$NUMPERIODOS","INDRTVAC":"$INDRTVAC(type:boolean)","FECHARTVAC":"$FECHARTVAC","DIASRTVAC":"$DIASRTVAC","F_PAGORTVAC":"$F_PAGORTVAC","DIASDINERO":"$DIASDINERO","DIASPENDIENTESDEDISFRUTE":"$DIASPENDIENTESDEDISFRUTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPLEADOINI" sqlType="STRING"/>
		<param name="EMPLEADOFIN" sqlType="STRING"/>
		<param name="DEPENDENCIAINI" sqlType="STRING"/>
		<param name="DEPENDENCIAFIN" sqlType="STRING"/>
		<param name="TIPOINI" sqlType="STRING"/>
		<param name="TIPOFIN" sqlType="STRING"/>
		<param name="CENTROINI" sqlType="STRING"/>
		<param name="CENTROFIN" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vacaciones/porpersonalcalculo">
		<call-query href="getVacacionesPorpersonalcalculoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPLEADOINI" query-param="EMPLEADOINI"/>
			<with-param name="EMPLEADOFIN" query-param="EMPLEADOFIN"/>
			<with-param name="DEPENDENCIAINI" query-param="DEPENDENCIAINI"/>
			<with-param name="DEPENDENCIAFIN" query-param="DEPENDENCIAFIN"/>
			<with-param name="TIPOINI" query-param="TIPOINI"/>
			<with-param name="TIPOFIN" query-param="TIPOFIN"/>
			<with-param name="CENTROINI" query-param="CENTROINI"/>
			<with-param name="CENTROFIN" query-param="CENTROFIN"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getVacacionesPagVacacionporempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VACACIONES.COMPANIA, VACACIONES.ID_DE_PROCESO, VACACIONES.ANO, VACACIONES.MES, VACACIONES.PERIODO, VACACIONES.ID_DE_EMPLEADO, VACACIONES.ACTO, TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY') INICIO_DISFRUTE, TO_CHAR(VACACIONES. FINAL_DISFRUTE,'DD/MM/YYYY') FINAL_DISFRUTE, NAT_ACCION_VACACIONES.NOMBREACCION, VACACIONES.DIAS, VACACIONES.NUMPERIODOS, VACACIONES.VALOR, NAT_CLASE_NOVEDAD_VACACIONES.NOVEDAD_VACACIONES  FROM VACACIONES LEFT JOIN NAT_ACCION_VACACIONES ON VACACIONES.ACCION = NAT_ACCION_VACACIONES.CODIGO LEFT JOIN NAT_CLASE_NOVEDAD_VACACIONES ON VACACIONES.NOVEDAD = NAT_CLASE_NOVEDAD_VACACIONES.CODIGO WHERE VACACIONES.COMPANIA = :COMPANIA AND VACACIONES.ID_DE_EMPLEADO = :DOCUMENTO) WHERE (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :INICIO_DISFRUTE || '%')  AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END)  LIKE UPPER( '%' || :FINAL_DISFRUTE || '%')  AND (CASE WHEN NOMBREACCION IS NULL THEN ' ' ELSE UPPER(NOMBREACCION) END)  LIKE UPPER(:NOMBREACCION || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN NUMPERIODOS IS NULL THEN ' ' ELSE UPPER(NUMPERIODOS) END)  LIKE UPPER(:NUMPERIODOS || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN NOVEDAD_VACACIONES IS NULL THEN ' ' ELSE UPPER(NOVEDAD_VACACIONES) END)  LIKE UPPER( '%' || :NOVEDAD_VACACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ACTO":"$ACTO","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","NOMBREACCION":"$NOMBREACCION","DIAS":"$DIAS","NUMPERIODOS":"$NUMPERIODOS","VALOR":"$VALOR(type:integer)","NOVEDAD_VACACIONES":"$NOVEDAD_VACACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="NOMBREACCION" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="NUMPERIODOS" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="NOVEDAD_VACACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vacaciones/vacacionporempleado/pag">
		<call-query href="getVacacionesPagVacacionporempleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="INICIO_DISFRUTE" query-param="INICIO_DISFRUTE"/>
			<with-param name="FINAL_DISFRUTE" query-param="FINAL_DISFRUTE"/>
			<with-param name="NOMBREACCION" query-param="NOMBREACCION"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="NUMPERIODOS" query-param="NUMPERIODOS"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="NOVEDAD_VACACIONES" query-param="NOVEDAD_VACACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVacacionesNumVacacionporempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VACACIONES.COMPANIA, VACACIONES.ID_DE_PROCESO, VACACIONES.ANO, VACACIONES.MES, VACACIONES.PERIODO, VACACIONES.ID_DE_EMPLEADO, VACACIONES.ACTO, TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY') INICIO_DISFRUTE, TO_CHAR(VACACIONES. FINAL_DISFRUTE,'DD/MM/YYYY') FINAL_DISFRUTE, NAT_ACCION_VACACIONES.NOMBREACCION, VACACIONES.DIAS, VACACIONES.NUMPERIODOS, VACACIONES.VALOR, NAT_CLASE_NOVEDAD_VACACIONES.NOVEDAD_VACACIONES  FROM VACACIONES LEFT JOIN NAT_ACCION_VACACIONES ON VACACIONES.ACCION = NAT_ACCION_VACACIONES.CODIGO LEFT JOIN NAT_CLASE_NOVEDAD_VACACIONES ON VACACIONES.NOVEDAD = NAT_CLASE_NOVEDAD_VACACIONES.CODIGO WHERE VACACIONES.COMPANIA = :COMPANIA AND VACACIONES.ID_DE_EMPLEADO = :DOCUMENTO) WHERE (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :INICIO_DISFRUTE || '%')  AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END)  LIKE UPPER( '%' || :FINAL_DISFRUTE || '%')  AND (CASE WHEN NOMBREACCION IS NULL THEN ' ' ELSE UPPER(NOMBREACCION) END)  LIKE UPPER(:NOMBREACCION || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN NUMPERIODOS IS NULL THEN ' ' ELSE UPPER(NUMPERIODOS) END)  LIKE UPPER(:NUMPERIODOS || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN NOVEDAD_VACACIONES IS NULL THEN ' ' ELSE UPPER(NOVEDAD_VACACIONES) END)  LIKE UPPER( '%' || :NOVEDAD_VACACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="NOMBREACCION" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="NUMPERIODOS" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="NOVEDAD_VACACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vacaciones/vacacionporempleado/num">
		<call-query href="getVacacionesNumVacacionporempleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="INICIO_DISFRUTE" query-param="INICIO_DISFRUTE"/>
			<with-param name="FINAL_DISFRUTE" query-param="FINAL_DISFRUTE"/>
			<with-param name="NOMBREACCION" query-param="NOMBREACCION"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="NUMPERIODOS" query-param="NUMPERIODOS"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="NOVEDAD_VACACIONES" query-param="NOVEDAD_VACACIONES"/>

		</call-query>
	</resource>
	<query id="getVacacionesRegistroporempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VACACIONES.NUMERO_DCTO, VACACIONES.ID_DE_EMPLEADO, VACACIONES.NUMEROPERIODO,(TO_CHAR(VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, VACACIONES.DIASTOMADOS, VACACIONES.MODO,(TO_CHAR(VACACIONES.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO,(TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, VACACIONES.ACTO,(TO_CHAR(VACACIONES.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, VACACIONES.NUMEROACTO, VACACIONES.OBSERVACION_V, VACACIONES.VALOR, VACACIONES.NOVEDAD, VACACIONES.DIASDINERO, VACACIONES.DIAS, VACACIONES.DIASHABILES, VACACIONES.DIASPENDIENTESDEDISFRUTE, VACACIONES.NUMPERIODOS, VACACIONES.ACCION, NAT_TIPO_ACTO_ADTIVO.CODIGO, NAT_TIPO_ACTO_ADTIVO.TIPOACTOADTIVO, NAT_ACCION_VACACIONES.NOMBREACCION, NAT_CLASE_NOVEDAD_VACACIONES.NOVEDAD_VACACIONES, NAT_ACCION_VACACIONES.CODIGO CODIGOACCION, NAT_CLASE_NOVEDAD_VACACIONES.CODIGO CODNOVED  FROM VACACIONES LEFT JOIN NAT_TIPO_ACTO_ADTIVO ON VACACIONES.ACTO = NAT_TIPO_ACTO_ADTIVO.CODIGO LEFT JOIN NAT_ACCION_VACACIONES ON VACACIONES.ACCION = NAT_ACCION_VACACIONES.CODIGO LEFT JOIN NAT_CLASE_NOVEDAD_VACACIONES ON VACACIONES.NOVEDAD = NAT_CLASE_NOVEDAD_VACACIONES.CODIGO WHERE VACACIONES.COMPANIA = :KEY_COMPANIA AND VACACIONES.ID_DE_PROCESO = :KEY_ID_DE_PROCESO AND VACACIONES.ANO = :KEY_ANO AND VACACIONES.MES = :KEY_MES AND VACACIONES.PERIODO = :KEY_PERIODO AND VACACIONES.ID_DE_EMPLEADO = :KEY_ID_DE_EMPLEADO AND VACACIONES.ACTO = :KEY_ACTO AND VACACIONES.INICIO_DISFRUTE= TO_DATE(:KEY_INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMEROPERIODO":"$NUMEROPERIODO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","DIASTOMADOS":"$DIASTOMADOS(type:integer)","MODO":"$MODO","FECHAPAGO":"$FECHAPAGO","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","ACTO":"$ACTO","FECHA_ACTO":"$FECHA_ACTO","NUMEROACTO":"$NUMEROACTO","OBSERVACION_V":"$OBSERVACION_V","VALOR":"$VALOR(type:integer)","NOVEDAD":"$NOVEDAD","DIASDINERO":"$DIASDINERO","DIAS":"$DIAS","DIASHABILES":"$DIASHABILES","DIASPENDIENTESDEDISFRUTE":"$DIASPENDIENTESDEDISFRUTE","NUMPERIODOS":"$NUMPERIODOS","ACCION":"$ACCION","CODIGO":"$CODIGO(type:integer)","TIPOACTOADTIVO":"$TIPOACTOADTIVO","NOMBREACCION":"$NOMBREACCION","NOVEDAD_VACACIONES":"$NOVEDAD_VACACIONES","CODIGOACCION":"$CODIGOACCION","CODNOVED":"$CODNOVED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ACTO" sqlType="STRING"/>
		<param name="KEY_INICIO_DISFRUTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vacaciones/registroporempleado">
		<call-query href="getVacacionesRegistroporempleadoQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ACTO" query-param="KEY_ACTO"/>
			<with-param name="KEY_INICIO_DISFRUTE" query-param="KEY_INICIO_DISFRUTE"/>

		</call-query>
	</resource>
	<query id="getVacacionesPagListaidempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VACACIONES.COMPANIA, VACACIONES.ID_DE_PROCESO, VACACIONES.ANO, VACACIONES.MES, VACACIONES.PERIODO, VACACIONES.ID_DE_EMPLEADO,(TO_CHAR(VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, VACACIONES.ACTO,(TO_CHAR(VACACIONES.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO,(TO_CHAR(VACACIONES.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO FROM VACACIONES WHERE VACACIONES.COMPANIA = :COMPANIA AND VACACIONES.ID_DE_EMPLEADO= :IDEMPLEADO) WHERE (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :INICIO_DISFRUTE || '%')  AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END)  LIKE UPPER( '%' || :FINAL_DISFRUTE || '%')  AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END)  LIKE UPPER(:ACTO || '%')  AND (CASE WHEN FECHA_ACTO IS NULL THEN ' ' ELSE UPPER(FECHA_ACTO) END)  LIKE UPPER( '%' || :FECHA_ACTO || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","ACTO":"$ACTO","FECHA_ACTO":"$FECHA_ACTO","FECHAPAGO":"$FECHAPAGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEMPLEADO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>
		<param name="FECHA_ACTO" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vacaciones/listaidempleado/pag">
