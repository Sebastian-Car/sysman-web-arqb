			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEMPLEADO" query-param="IDEMPLEADO"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>

		</call-query>
	</resource>
	<query id="insertVacaciones" keyColumns="COMPANIA,ID_DE_PROCESO,ANO,MES,PERIODO,ID_DE_EMPLEADO,ACTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VACACIONES (COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO, FECHA_INICIO, FECHA_FINAL, INICIO_DISFRUTE, FINAL_DISFRUTE, ACTO, FECHA_ACTO, DIAS, ENDINERO, FECHAPAGO, DIASHABILES, NUMPERIODOS, DIASDINERO, OBSERVACION_V, DIASPENDIENTESDEDISFRUTE, CREATED_BY, DATE_CREATED, QUITARPILA, APLICA_BONIFICACION) VALUES (:COMPANIA, :ID_DE_PROCESO, :ANO, :MES, :PERIODO, :ID_DE_EMPLEADO, :ID_DE_CONCEPTO, TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), :ACTO, TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), :DIAS, :ENDINERO, TO_DATE(:FECHAPAGO,'DD/MM/YYYY HH24:MI:SS'), :DIASHABILES, :NUMPERIODOS, :DIASDINERO, :OBSERVACION_V, :DIASPENDIENTESDEDISFRUTE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :QUITARPILA, :APLICA_BONIFICACION)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_PERIODO":"$PERIODO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ACTO":"$ACTO","KEY_INICIO_DISFRUTE":"$INICIO_DISFRUTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="1" name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param defaultValue="1" name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="403" name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param defaultValue="" name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param defaultValue="0000" name="ACTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ACTO" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="0" name="ENDINERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAPAGO" sqlType="STRING"/>
		<param defaultValue="0" name="DIASHABILES" sqlType="STRING"/>
		<param defaultValue="" name="NUMPERIODOS" sqlType="STRING"/>
		<param defaultValue="0" name="DIASDINERO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION_V" sqlType="STRING"/>
		<param defaultValue="0" name="DIASPENDIENTESDEDISFRUTE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="QUITARPILA" sqlType="STRING"/>
		<param defaultValue="0" name="APLICA_BONIFICACION" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vacaciones">
		<call-query href="insertVacaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
