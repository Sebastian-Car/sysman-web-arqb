	<query id="updateVacaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VACACIONES SET COMPANIA=:COMPANIA, ID_DE_PROCESO=:ID_DE_PROCESO, ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), INICIO_DISFRUTE=TO_DATE(:INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), FINAL_DISFRUTE=TO_DATE(:FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), ACTO=:ACTO, FECHA_ACTO=TO_DATE(:FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS'), DIAS=:DIAS, ENDINERO=:ENDINERO, FECHAPAGO=TO_DATE(:FECHAPAGO,'DD/MM/YYYY HH24:MI:SS'), DIASHABILES=:DIASHABILES, NUMPERIODOS=:NUMPERIODOS, DIASDINERO=:DIASDINERO, OBSERVACION_V=:OBSERVACION_V, QUITARPILA=:QUITARPILA, DIASPENDIENTESDEDISFRUTE=:DIASPENDIENTESDEDISFRUTE, APLICA_BONIFICACION=:APLICA_BONIFICACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VACACIONES.COMPANIA= :KEY_COMPANIA AND VACACIONES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND VACACIONES.ANO= :KEY_ANO AND VACACIONES.MES= :KEY_MES AND VACACIONES.PERIODO= :KEY_PERIODO AND VACACIONES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND VACACIONES.ACTO= :KEY_ACTO AND VACACIONES.INICIO_DISFRUTE= TO_DATE(:KEY_INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
