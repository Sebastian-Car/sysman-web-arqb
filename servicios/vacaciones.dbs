	<query id="getVacacionesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VACACIONES.COMPANIA, VACACIONES.ID_DE_PROCESO, VACACIONES.ANO, VACACIONES.MES, VACACIONES.PERIODO, VACACIONES.ID_DE_EMPLEADO, VACACIONES.ID_DE_CONCEPTO,(TO_CHAR(VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, VACACIONES.ACTO,(TO_CHAR(VACACIONES.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, VACACIONES.DIAS,(CASE VACACIONES.ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) ENDINERO,(TO_CHAR(VACACIONES.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, VACACIONES.DIASHABILES, VACACIONES.NUMPERIODOS, VACACIONES.DIASDINERO, VACACIONES.OBSERVACION_V, VACACIONES.DIASPENDIENTESDEDISFRUTE, VACACIONES.CREATED_BY,(TO_CHAR(VACACIONES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VACACIONES.MODIFIED_BY,(TO_CHAR(VACACIONES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE VACACIONES.QUITARPILA WHEN 0 THEN 'false' ELSE 'true' END) QUITARPILA,(CASE VACACIONES.APLICA_BONIFICACION WHEN 0 THEN 'false' ELSE 'true' END) APLICA_BONIFICACION FROM VACACIONES WHERE VACACIONES.COMPANIA= :KEY_COMPANIA AND VACACIONES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND VACACIONES.ANO= :KEY_ANO AND VACACIONES.MES= :KEY_MES AND VACACIONES.PERIODO= :KEY_PERIODO AND VACACIONES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND VACACIONES.ACTO= :KEY_ACTO AND VACACIONES.INICIO_DISFRUTE= TO_DATE(:KEY_INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","ACTO":"$ACTO","FECHA_ACTO":"$FECHA_ACTO","DIAS":"$DIAS","ENDINERO":"$ENDINERO(type:boolean)","FECHAPAGO":"$FECHAPAGO","DIASHABILES":"$DIASHABILES","NUMPERIODOS":"$NUMPERIODOS","DIASDINERO":"$DIASDINERO","OBSERVACION_V":"$OBSERVACION_V","DIASPENDIENTESDEDISFRUTE":"$DIASPENDIENTESDEDISFRUTE","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","QUITARPILA":"$QUITARPILA(type:boolean)","APLICA_BONIFICACION":"$APLICA_BONIFICACION(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ACTO" sqlType="STRING"/>
		<param name="KEY_INICIO_DISFRUTE" sqlType="STRING"/>

	</query>
