	<query id="getVacacionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT VACACIONES.COMPANIA, VACACIONES.ID_DE_PROCESO, VACACIONES.ANO, VACACIONES.MES, VACACIONES.PERIODO, VACACIONES.ID_DE_EMPLEADO, VACACIONES.ID_DE_CONCEPTO,(TO_CHAR(VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, VACACIONES.ACTO,(TO_CHAR(VACACIONES.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO, VACACIONES.DIAS,(CASE VACACIONES.ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) ENDINERO,(TO_CHAR(VACACIONES.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, VACACIONES.DIASHABILES, VACACIONES.NUMPERIODOS, VACACIONES.DIASDINERO, VACACIONES.OBSERVACION_V, VACACIONES.DIASPENDIENTESDEDISFRUTE, VACACIONES.CREATED_BY,(TO_CHAR(VACACIONES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VACACIONES.MODIFIED_BY,(TO_CHAR(VACACIONES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM VACACIONES WHERE VACACIONES.COMPANIA=:COMPANIA AND VACACIONES.ID_DE_EMPLEADO = :ID_DE_EMPLEADO ORDER BY VACACIONES.FECHAPAGO DESC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_PROCESO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_EMPLEADO), '%')) AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_CONCEPTO), '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIO), '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINAL), '%')) AND (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END) LIKE UPPER(CONCAT(CONCAT('%',:INICIO_DISFRUTE), '%')) AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END) LIKE UPPER(CONCAT(CONCAT('%',:FINAL_DISFRUTE), '%')) AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END) LIKE UPPER(CONCAT(:ACTO, '%')) AND (CASE WHEN FECHA_ACTO IS NULL THEN ' ' ELSE UPPER(FECHA_ACTO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_ACTO), '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(CONCAT('%',:DIAS), '%')) AND (CASE WHEN ENDINERO IS NULL THEN ' ' ELSE UPPER(ENDINERO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENDINERO), '%')) AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAPAGO), '%')) AND (CASE WHEN DIASHABILES IS NULL THEN ' ' ELSE UPPER(DIASHABILES) END) LIKE UPPER(CONCAT(CONCAT('%',:DIASHABILES), '%')) AND (CASE WHEN NUMPERIODOS IS NULL THEN ' ' ELSE UPPER(NUMPERIODOS) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMPERIODOS), '%')) AND (CASE WHEN DIASDINERO IS NULL THEN ' ' ELSE UPPER(DIASDINERO) END) LIKE UPPER(CONCAT(CONCAT('%',:DIASDINERO), '%')) AND (CASE WHEN OBSERVACION_V IS NULL THEN ' ' ELSE UPPER(OBSERVACION_V) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACION_V), '%')) AND (CASE WHEN DIASPENDIENTESDEDISFRUTE IS NULL THEN ' ' ELSE UPPER(DIASPENDIENTESDEDISFRUTE) END) LIKE UPPER(CONCAT(CONCAT('%',:DIASPENDIENTESDEDISFRUTE), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:CREATED_BY), '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_CREATED), '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFIED_BY), '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_MODIFIED), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>
		<param name="FECHA_ACTO" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ENDINERO" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="DIASHABILES" sqlType="STRING"/>
		<param name="NUMPERIODOS" sqlType="STRING"/>
