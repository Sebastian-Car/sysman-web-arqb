	<query id="getVacacionesNumListaidempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VACACIONES.COMPANIA, VACACIONES.ID_DE_PROCESO, VACACIONES.ANO, VACACIONES.MES, VACACIONES.PERIODO, VACACIONES.ID_DE_EMPLEADO,(TO_CHAR(VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, VACACIONES.ACTO,(TO_CHAR(VACACIONES.FECHA_ACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTO,(TO_CHAR(VACACIONES.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO FROM VACACIONES WHERE VACACIONES.COMPANIA = :COMPANIA AND VACACIONES.ID_DE_EMPLEADO= :IDEMPLEADO) WHERE (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :INICIO_DISFRUTE || '%')  AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END)  LIKE UPPER( '%' || :FINAL_DISFRUTE || '%')  AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END)  LIKE UPPER(:ACTO || '%')  AND (CASE WHEN FECHA_ACTO IS NULL THEN ' ' ELSE UPPER(FECHA_ACTO) END)  LIKE UPPER( '%' || :FECHA_ACTO || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEMPLEADO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>
		<param name="FECHA_ACTO" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>

	</query>
