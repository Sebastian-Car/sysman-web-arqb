<data name="iptarifasespeciales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertIptarifasespeciales" keyColumns="COMPANIA,ANO,CONCEPTO,PREDIO,NUMERO_ORDEN" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_TARIFAS_ESPECIALES (COMPANIA, ANO, CONCEPTO, PREDIO, NUMERO_ORDEN, PORCENTAJE, FECHALIMITE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CONCEPTO, :PREDIO, :NUMERO_ORDEN, :PORCENTAJE, TO_DATE(:FECHALIMITE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CONCEPTO":"$CONCEPTO(type:integer)","KEY_PREDIO":"$PREDIO","KEY_NUMERO_ORDEN":"$NUMERO_ORDEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE" sqlType="STRING"/>
		<param defaultValue="" name="FECHALIMITE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="iptarifasespeciales">
		<call-query href="insertIptarifasespeciales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="FECHALIMITE" query-param="FECHALIMITE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteIptarifasespeciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_TARIFAS_ESPECIALES WHERE IP_TARIFAS_ESPECIALES.COMPANIA= :KEY_COMPANIA AND IP_TARIFAS_ESPECIALES.ANO= :KEY_ANO AND IP_TARIFAS_ESPECIALES.CONCEPTO= :KEY_CONCEPTO AND IP_TARIFAS_ESPECIALES.PREDIO= :KEY_PREDIO AND IP_TARIFAS_ESPECIALES.NUMERO_ORDEN= :KEY_NUMERO_ORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CONCEPTO" sqlType="INTEGER"/>
		<param name="KEY_PREDIO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="iptarifasespeciales">
		<call-query href="deleteIptarifasespeciales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_PREDIO" query-param="KEY_PREDIO"/>
			<with-param name="KEY_NUMERO_ORDEN" query-param="KEY_NUMERO_ORDEN"/>

		</call-query>
	</resource>
	<query id="getIptarifasespecialesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT IP_TARIFAS_ESPECIALES.COMPANIA, IP_TARIFAS_ESPECIALES.ANO, IP_TARIFAS_ESPECIALES.CONCEPTO, IP_TARIFAS_ESPECIALES.PREDIO, IP_TARIFAS_ESPECIALES.NUMERO_ORDEN, TRIM(TO_CHAR(IP_TARIFAS_ESPECIALES.PORCENTAJE,CONCAT( RPAD('9',18,'9'), '0D99')) ) PORCENTAJE,(TO_CHAR(IP_TARIFAS_ESPECIALES.FECHALIMITE,'DD/MM/YYYY HH24:MI:SS')) FECHALIMITE FROM IP_TARIFAS_ESPECIALES WHERE IP_TARIFAS_ESPECIALES.COMPANIA =:COMPANIA ORDER BY IP_TARIFAS_ESPECIALES.ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END) LIKE UPPER(CONCAT(:PREDIO, '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE), '%')) AND (CASE WHEN FECHALIMITE IS NULL THEN ' ' ELSE UPPER(FECHALIMITE) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHALIMITE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONCEPTO":"$CONCEPTO(type:integer)","PREDIO":"$PREDIO","NUMERO_ORDEN":"$NUMERO_ORDEN","PORCENTAJE":"$PORCENTAJE","FECHALIMITE":"$FECHALIMITE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="FECHALIMITE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="iptarifasespeciales">
		<call-query href="getIptarifasespecialesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="FECHALIMITE" query-param="FECHALIMITE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIptarifasespecialesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT IP_TARIFAS_ESPECIALES.COMPANIA, IP_TARIFAS_ESPECIALES.ANO, IP_TARIFAS_ESPECIALES.CONCEPTO, IP_TARIFAS_ESPECIALES.PREDIO, IP_TARIFAS_ESPECIALES.NUMERO_ORDEN, TRIM(TO_CHAR(IP_TARIFAS_ESPECIALES.PORCENTAJE,CONCAT( RPAD('9',18,'9'), '0D99')) ) PORCENTAJE,(TO_CHAR(IP_TARIFAS_ESPECIALES.FECHALIMITE,'DD/MM/YYYY HH24:MI:SS')) FECHALIMITE FROM IP_TARIFAS_ESPECIALES WHERE IP_TARIFAS_ESPECIALES.COMPANIA =:COMPANIA ORDER BY IP_TARIFAS_ESPECIALES.ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END) LIKE UPPER(CONCAT(:PREDIO, '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE), '%')) AND (CASE WHEN FECHALIMITE IS NULL THEN ' ' ELSE UPPER(FECHALIMITE) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHALIMITE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="FECHALIMITE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="iptarifasespeciales/numero">
		<call-query href="getIptarifasespecialesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="FECHALIMITE" query-param="FECHALIMITE"/>

		</call-query>
	</resource>
	<query id="updateIptarifasespeciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_TARIFAS_ESPECIALES SET COMPANIA=:COMPANIA, ANO=:ANO, CONCEPTO=:CONCEPTO, PREDIO=:PREDIO, NUMERO_ORDEN=:NUMERO_ORDEN, PORCENTAJE=:PORCENTAJE, FECHALIMITE=TO_DATE(:FECHALIMITE,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_TARIFAS_ESPECIALES.COMPANIA= :KEY_COMPANIA AND IP_TARIFAS_ESPECIALES.ANO= :KEY_ANO AND IP_TARIFAS_ESPECIALES.CONCEPTO= :KEY_CONCEPTO AND IP_TARIFAS_ESPECIALES.PREDIO= :KEY_PREDIO AND IP_TARIFAS_ESPECIALES.NUMERO_ORDEN= :KEY_NUMERO_ORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="FECHALIMITE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_PREDIO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="iptarifasespeciales">
		<call-query href="updateIptarifasespeciales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="FECHALIMITE" query-param="FECHALIMITE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_PREDIO" query-param="KEY_PREDIO"/>
			<with-param name="KEY_NUMERO_ORDEN" query-param="KEY_NUMERO_ORDEN"/>

		</call-query>
	</resource>

</data>