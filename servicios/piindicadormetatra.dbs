<data name="piindicadormetatra" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPiindicadormetatraPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPO, NUMERO, VIGENCIA_INICIAL, ID_PLAN, INDICADOR, NOMBRE, LB_FIN, REFERENTE_FIN, META_CUATRENIO_FIN, META1_FIN, META2_FIN, META3_FIN, META4_FIN, AVANCE1_FIN, AVANCE2_FIN, AVANCE3_FIN, AVANCE4_FIN FROM PI_INDICADOR_META_TRA WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND NUMERO = :NUMERO AND VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND ID_PLAN = :ID_PLAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","ID_PLAN":"$ID_PLAN","INDICADOR":"$INDICADOR","NOMBRE":"$NOMBRE","LB_FIN":"$LB_FIN","REFERENTE_FIN":"$REFERENTE_FIN","META_CUATRENIO_FIN":"$META_CUATRENIO_FIN","META1_FIN":"$META1_FIN","META2_FIN":"$META2_FIN","META3_FIN":"$META3_FIN","META4_FIN":"$META4_FIN","AVANCE1_FIN":"$AVANCE1_FIN","AVANCE2_FIN":"$AVANCE2_FIN","AVANCE3_FIN":"$AVANCE3_FIN","AVANCE4_FIN":"$AVANCE4_FIN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piindicadormetatra">
		<call-query href="getPiindicadormetatraPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>

		</call-query>
	</resource>
	<query id="updatePiindicadormetatra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_INDICADOR_META_TRA SET META1_FIN=:META1_FIN, META2_FIN=:META2_FIN, META3_FIN=:META3_FIN, META4_FIN=:META4_FIN, AVANCE1_FIN=:AVANCE1_FIN, AVANCE2_FIN=:AVANCE2_FIN, AVANCE3_FIN=:AVANCE3_FIN, AVANCE4_FIN=:AVANCE4_FIN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_INDICADOR_META_TRA.COMPANIA= :KEY_COMPANIA AND PI_INDICADOR_META_TRA.TIPO= :KEY_TIPO AND PI_INDICADOR_META_TRA.NUMERO= :KEY_NUMERO AND PI_INDICADOR_META_TRA.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_INDICADOR_META_TRA.ID_PLAN= :KEY_ID_PLAN AND PI_INDICADOR_META_TRA.INDICADOR= :KEY_INDICADOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="META1_FIN" sqlType="STRING"/>
		<param name="META2_FIN" sqlType="STRING"/>
		<param name="META3_FIN" sqlType="STRING"/>
		<param name="META4_FIN" sqlType="STRING"/>
		<param name="AVANCE1_FIN" sqlType="STRING"/>
		<param name="AVANCE2_FIN" sqlType="STRING"/>
		<param name="AVANCE3_FIN" sqlType="STRING"/>
		<param name="AVANCE4_FIN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_INDICADOR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="piindicadormetatra">
		<call-query href="updatePiindicadormetatra">
			<with-param name="META1_FIN" query-param="META1_FIN"/>
			<with-param name="META2_FIN" query-param="META2_FIN"/>
			<with-param name="META3_FIN" query-param="META3_FIN"/>
			<with-param name="META4_FIN" query-param="META4_FIN"/>
			<with-param name="AVANCE1_FIN" query-param="AVANCE1_FIN"/>
			<with-param name="AVANCE2_FIN" query-param="AVANCE2_FIN"/>
			<with-param name="AVANCE3_FIN" query-param="AVANCE3_FIN"/>
			<with-param name="AVANCE4_FIN" query-param="AVANCE4_FIN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_INDICADOR" query-param="KEY_INDICADOR"/>

		</call-query>
	</resource>

</data>