			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MESINICIAL" query-param="MESINICIAL"/>

		</call-query>
	</resource>
	<query id="getMesesTodospornumeronombremesfinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MES.NUMERO, MES.NOMBRE NOMBREMES  FROM MES WHERE MES.COMPANIA = :COMPANIA AND MES.ANO = :ANIO AND MES.NUMERO &gt;= :MESINICIAL AND MES.NUMERO NOT IN(0, 13)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","NOMBREMES":"$NOMBREMES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/todospornumeronombremesfinal">
