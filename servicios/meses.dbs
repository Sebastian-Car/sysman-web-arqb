		<param name="EXPRESION1" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/listadogeneral/num">
		<call-query href="getMesesNumListadoGeneralQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="EXPRESION1" query-param="EXPRESION1"/>

		</call-query>
	</resource>
	<query id="getMesesNumNomPorMesAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.MES, MES.NOMBRE  FROM MES INNER JOIN PERIODOS ON MES.NUMERO = PERIODOS.MES AND MES.COMPANIA = PERIODOS.COMPANIA AND MES.ANO = PERIODOS.ANO WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO = :ANO AND PERIODOS.MES NOT IN (0) ORDER BY PERIODOS.MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/numnompormesano">
		<call-query href="getMesesNumNomPorMesAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getMesesPagNumNomPorMesAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT PERIODOS.MES, MES.NOMBRE  FROM MES INNER JOIN PERIODOS ON MES.NUMERO = PERIODOS.MES AND MES.COMPANIA = PERIODOS.COMPANIA AND MES.ANO = PERIODOS.ANO WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO = :ANO AND PERIODOS.MES NOT IN (0) ORDER BY PERIODOS.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="meses/numnompormesano/pag">
		<call-query href="getMesesPagNumNomPorMesAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMesesNumNumNomPorMesAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT PERIODOS.MES, MES.NOMBRE  FROM MES INNER JOIN PERIODOS ON MES.NUMERO = PERIODOS.MES AND MES.COMPANIA = PERIODOS.COMPANIA AND MES.ANO = PERIODOS.ANO WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO = :ANO AND PERIODOS.MES NOT IN (0) ORDER BY PERIODOS.MES) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/numnompormesano/num">
		<call-query href="getMesesNumNumNomPorMesAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getMesesTodospornombremesinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE  FROM MES WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NUMERO NOT IN (0,13) ORDER BY NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/todospornombremesinicial">
		<call-query href="getMesesTodospornombremesinicialQuery">
