		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ANO CODIGO, NUMERO NOMBRE, PCK_SYSMAN_UTL.FC_NOMBRE_MES(NUMERO) EXPRESION1  FROM MES WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN EXPRESION1 IS NULL THEN ' ' ELSE UPPER(EXPRESION1) END)  LIKE UPPER( '%' || :EXPRESION1 || '%') ))</sql>
