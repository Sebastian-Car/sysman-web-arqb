			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getMesesTodospornombremesfinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE  FROM MES WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NUMERO NOT IN (0,13) AND NUMERO &gt;= :MESINICIAL ORDER BY NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/todospornombremesfinal">
