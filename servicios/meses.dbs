	<query id="getMesesEstadoDeConciliacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PCK_SYSMAN_UTL.FC_VERIFICAR_ESTADOMES(COMPANIA, ANO, NUMERO,1,2) ESTADO  FROM MES WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND NUMERO = :MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/estadodeconciliacion">
		<call-query href="getMesesEstadoDeConciliacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getMesesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,ANO,NUMERO,CASE ESTADOCONCILIACION WHEN 'A' THEN 'Activo' WHEN 'C' THEN 'Cerrado' END ESTADOCONCILIACIONLB,ESTADOCONCILIACION,CASE ESTADOALMACEN WHEN 'A' THEN 'Activo' WHEN 'C' THEN 'Cerrado' END ESTADOALMACENLB,ESTADOALMACEN,CASE ESTADOPRESUPUESTO WHEN 'A' THEN 'Activo' WHEN 'C' THEN 'Cerrado' END ESTADOPRESUPUESTOLB,ESTADOPRESUPUESTO,PAAG_MENSUAL,PAAG_ACUMULADO,PAAG_ANUAL  FROM MES WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ESTADOCONCILIACIONLB IS NULL THEN ' ' ELSE UPPER(ESTADOCONCILIACIONLB) END)  LIKE UPPER( '%' || :ESTADOCONCILIACIONLB || '%')  AND (CASE WHEN ESTADOALMACENLB IS NULL THEN ' ' ELSE UPPER(ESTADOALMACENLB) END)  LIKE UPPER( '%' || :ESTADOALMACENLB || '%')  AND (CASE WHEN ESTADOPRESUPUESTOLB IS NULL THEN ' ' ELSE UPPER(ESTADOPRESUPUESTOLB) END)  LIKE UPPER( '%' || :ESTADOPRESUPUESTOLB || '%')  AND (CASE WHEN PAAG_MENSUAL IS NULL THEN ' ' ELSE UPPER(PAAG_MENSUAL) END)  LIKE UPPER(:PAAG_MENSUAL || '%')  AND (CASE WHEN PAAG_ACUMULADO IS NULL THEN ' ' ELSE UPPER(PAAG_ACUMULADO) END)  LIKE UPPER(:PAAG_ACUMULADO || '%')  AND (CASE WHEN PAAG_ANUAL IS NULL THEN ' ' ELSE UPPER(PAAG_ANUAL) END)  LIKE UPPER(:PAAG_ANUAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:integer)","ESTADOCONCILIACIONLB":"$ESTADOCONCILIACIONLB","ESTADOCONCILIACION":"$ESTADOCONCILIACION","ESTADOALMACENLB":"$ESTADOALMACENLB","ESTADOALMACEN":"$ESTADOALMACEN","ESTADOPRESUPUESTOLB":"$ESTADOPRESUPUESTOLB","ESTADOPRESUPUESTO":"$ESTADOPRESUPUESTO","PAAG_MENSUAL":"$PAAG_MENSUAL","PAAG_ACUMULADO":"$PAAG_ACUMULADO","PAAG_ANUAL":"$PAAG_ANUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ESTADOCONCILIACIONLB" sqlType="STRING"/>
		<param name="ESTADOALMACENLB" sqlType="STRING"/>
		<param name="ESTADOPRESUPUESTOLB" sqlType="STRING"/>
		<param name="PAAG_MENSUAL" sqlType="STRING"/>
		<param name="PAAG_ACUMULADO" sqlType="STRING"/>
		<param name="PAAG_ANUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="meses">
		<call-query href="getMesesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ESTADOCONCILIACIONLB" query-param="ESTADOCONCILIACIONLB"/>
			<with-param name="ESTADOALMACENLB" query-param="ESTADOALMACENLB"/>
			<with-param name="ESTADOPRESUPUESTOLB" query-param="ESTADOPRESUPUESTOLB"/>
			<with-param name="PAAG_MENSUAL" query-param="PAAG_MENSUAL"/>
			<with-param name="PAAG_ACUMULADO" query-param="PAAG_ACUMULADO"/>
			<with-param name="PAAG_ANUAL" query-param="PAAG_ANUAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMesesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA,ANO,NUMERO,CASE ESTADOCONCILIACION WHEN 'A' THEN 'Activo' WHEN 'C' THEN 'Cerrado' END ESTADOCONCILIACIONLB,ESTADOCONCILIACION,CASE ESTADOALMACEN WHEN 'A' THEN 'Activo' WHEN 'C' THEN 'Cerrado' END ESTADOALMACENLB,ESTADOALMACEN,CASE ESTADOPRESUPUESTO WHEN 'A' THEN 'Activo' WHEN 'C' THEN 'Cerrado' END ESTADOPRESUPUESTOLB,ESTADOPRESUPUESTO,PAAG_MENSUAL,PAAG_ACUMULADO,PAAG_ANUAL  FROM MES WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ESTADOCONCILIACIONLB IS NULL THEN ' ' ELSE UPPER(ESTADOCONCILIACIONLB) END)  LIKE UPPER( '%' || :ESTADOCONCILIACIONLB || '%')  AND (CASE WHEN ESTADOALMACENLB IS NULL THEN ' ' ELSE UPPER(ESTADOALMACENLB) END)  LIKE UPPER( '%' || :ESTADOALMACENLB || '%')  AND (CASE WHEN ESTADOPRESUPUESTOLB IS NULL THEN ' ' ELSE UPPER(ESTADOPRESUPUESTOLB) END)  LIKE UPPER( '%' || :ESTADOPRESUPUESTOLB || '%')  AND (CASE WHEN PAAG_MENSUAL IS NULL THEN ' ' ELSE UPPER(PAAG_MENSUAL) END)  LIKE UPPER( '%' || :PAAG_MENSUAL || '%')  AND (CASE WHEN PAAG_ACUMULADO IS NULL THEN ' ' ELSE UPPER(PAAG_ACUMULADO) END)  LIKE UPPER( '%' || :PAAG_ACUMULADO || '%')  AND (CASE WHEN PAAG_ANUAL IS NULL THEN ' ' ELSE UPPER(PAAG_ANUAL) END)  LIKE UPPER( '%' || :PAAG_ANUAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ESTADOCONCILIACIONLB" sqlType="STRING"/>
		<param name="ESTADOALMACENLB" sqlType="STRING"/>
		<param name="ESTADOPRESUPUESTOLB" sqlType="STRING"/>
		<param name="PAAG_MENSUAL" sqlType="STRING"/>
		<param name="PAAG_ACUMULADO" sqlType="STRING"/>
		<param name="PAAG_ANUAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="meses/numero">
		<call-query href="getMesesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ESTADOCONCILIACIONLB" query-param="ESTADOCONCILIACIONLB"/>
			<with-param name="ESTADOALMACENLB" query-param="ESTADOALMACENLB"/>
			<with-param name="ESTADOPRESUPUESTOLB" query-param="ESTADOPRESUPUESTOLB"/>
			<with-param name="PAAG_MENSUAL" query-param="PAAG_MENSUAL"/>
			<with-param name="PAAG_ACUMULADO" query-param="PAAG_ACUMULADO"/>
			<with-param name="PAAG_ANUAL" query-param="PAAG_ANUAL"/>

		</call-query>
	</resource>
	<query id="updateMeses" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MES SET ESTADOCONCILIACION=:ESTADOCONCILIACION, ESTADOALMACEN=:ESTADOALMACEN, ESTADOPRESUPUESTO=:ESTADOPRESUPUESTO, PAAG_MENSUAL=:PAAG_MENSUAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE MES.COMPANIA= :KEY_COMPANIA AND MES.ANO= :KEY_ANO AND MES.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADOCONCILIACION" sqlType="STRING"/>
		<param name="ESTADOALMACEN" sqlType="STRING"/>
		<param name="ESTADOPRESUPUESTO" sqlType="STRING"/>
		<param name="PAAG_MENSUAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="meses">
		<call-query href="updateMeses">
			<with-param name="ESTADOCONCILIACION" query-param="ESTADOCONCILIACION"/>
			<with-param name="ESTADOALMACEN" query-param="ESTADOALMACEN"/>
			<with-param name="ESTADOPRESUPUESTO" query-param="ESTADOPRESUPUESTO"/>
			<with-param name="PAAG_MENSUAL" query-param="PAAG_MENSUAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
