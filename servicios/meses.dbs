			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESINICIAL" query-param="MESINICIAL"/>

		</call-query>
	</resource>
	<query id="getMesesMessinanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT NUMERO, NOMBRE  FROM MES WHERE COMPANIA = :COMPANIA AND NUMERO NOT IN(0,13) AND NUMERO BETWEEN :TRIMESTRE - 2 AND :TRIMESTRE ORDER BY NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TRIMESTRE" sqlType="STRING"/>

	</query>
