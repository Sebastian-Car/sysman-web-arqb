<data name="dvacaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDvacacionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D.COMPANIA, D.ID_DE_EMPLEADO, D.ANIO, D.CONSECUTIVO, P.NOMBRECOMPLETO,(TO_CHAR(D.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(D.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, D.LICENCIAS_SUSPENSIONES,(TO_CHAR(D.FECHA_INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_DISFRUTE,(TO_CHAR(D.FECHA_ESTIMADA_REGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ESTIMADA_REGRESO, D.DIAS_ESTIMADOS_DISFRUTE, D.ANIOS_ACUMULADOS  FROM D_VACACIONES D INNER JOIN PERSONAL P ON D.COMPANIA = P.COMPANIA AND D.ID_DE_EMPLEADO = P.ID_DE_EMPLEADO WHERE D.COMPANIA = :COMPANIA AND D.ANIO = :ANIO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER( '%' || :ID_DE_EMPLEADO || '%')  AND (CASE WHEN ANIO IS NULL THEN ' ' ELSE UPPER(ANIO) END)  LIKE UPPER( '%' || :ANIO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN LICENCIAS_SUSPENSIONES IS NULL THEN ' ' ELSE UPPER(LICENCIAS_SUSPENSIONES) END)  LIKE UPPER( '%' || :LICENCIAS_SUSPENSIONES || '%')  AND (CASE WHEN FECHA_INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :FECHA_INICIO_DISFRUTE || '%')  AND (CASE WHEN FECHA_ESTIMADA_REGRESO IS NULL THEN ' ' ELSE UPPER(FECHA_ESTIMADA_REGRESO) END)  LIKE UPPER( '%' || :FECHA_ESTIMADA_REGRESO || '%')  AND (CASE WHEN DIAS_ESTIMADOS_DISFRUTE IS NULL THEN ' ' ELSE UPPER(DIAS_ESTIMADOS_DISFRUTE) END)  LIKE UPPER( '%' || :DIAS_ESTIMADOS_DISFRUTE || '%')  AND (CASE WHEN ANIOS_ACUMULADOS IS NULL THEN ' ' ELSE UPPER(ANIOS_ACUMULADOS) END)  LIKE UPPER( '%' || :ANIOS_ACUMULADOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ANIO":"$ANIO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:long)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","LICENCIAS_SUSPENSIONES":"$LICENCIAS_SUSPENSIONES","FECHA_INICIO_DISFRUTE":"$FECHA_INICIO_DISFRUTE","FECHA_ESTIMADA_REGRESO":"$FECHA_ESTIMADA_REGRESO","DIAS_ESTIMADOS_DISFRUTE":"$DIAS_ESTIMADOS_DISFRUTE","ANIOS_ACUMULADOS":"$ANIOS_ACUMULADOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="LICENCIAS_SUSPENSIONES" sqlType="STRING"/>
		<param name="FECHA_INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FECHA_ESTIMADA_REGRESO" sqlType="STRING"/>
		<param name="DIAS_ESTIMADOS_DISFRUTE" sqlType="STRING"/>
		<param name="ANIOS_ACUMULADOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dvacaciones">
		<call-query href="getDvacacionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="LICENCIAS_SUSPENSIONES" query-param="LICENCIAS_SUSPENSIONES"/>
			<with-param name="FECHA_INICIO_DISFRUTE" query-param="FECHA_INICIO_DISFRUTE"/>
			<with-param name="FECHA_ESTIMADA_REGRESO" query-param="FECHA_ESTIMADA_REGRESO"/>
			<with-param name="DIAS_ESTIMADOS_DISFRUTE" query-param="DIAS_ESTIMADOS_DISFRUTE"/>
			<with-param name="ANIOS_ACUMULADOS" query-param="ANIOS_ACUMULADOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDvacacionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D.COMPANIA, D.ID_DE_EMPLEADO, D.ANIO, D.CONSECUTIVO, P.NOMBRECOMPLETO,(TO_CHAR(D.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(D.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, D.LICENCIAS_SUSPENSIONES,(TO_CHAR(D.FECHA_INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_DISFRUTE,(TO_CHAR(D.FECHA_ESTIMADA_REGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ESTIMADA_REGRESO, D.DIAS_ESTIMADOS_DISFRUTE, D.ANIOS_ACUMULADOS  FROM D_VACACIONES D INNER JOIN PERSONAL P ON D.COMPANIA = P.COMPANIA AND D.ID_DE_EMPLEADO = P.ID_DE_EMPLEADO WHERE D.COMPANIA = :COMPANIA AND D.ANIO = :ANIO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER( '%' || :ID_DE_EMPLEADO || '%')  AND (CASE WHEN ANIO IS NULL THEN ' ' ELSE UPPER(ANIO) END)  LIKE UPPER( '%' || :ANIO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN LICENCIAS_SUSPENSIONES IS NULL THEN ' ' ELSE UPPER(LICENCIAS_SUSPENSIONES) END)  LIKE UPPER( '%' || :LICENCIAS_SUSPENSIONES || '%')  AND (CASE WHEN FECHA_INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :FECHA_INICIO_DISFRUTE || '%')  AND (CASE WHEN FECHA_ESTIMADA_REGRESO IS NULL THEN ' ' ELSE UPPER(FECHA_ESTIMADA_REGRESO) END)  LIKE UPPER( '%' || :FECHA_ESTIMADA_REGRESO || '%')  AND (CASE WHEN DIAS_ESTIMADOS_DISFRUTE IS NULL THEN ' ' ELSE UPPER(DIAS_ESTIMADOS_DISFRUTE) END)  LIKE UPPER( '%' || :DIAS_ESTIMADOS_DISFRUTE || '%')  AND (CASE WHEN ANIOS_ACUMULADOS IS NULL THEN ' ' ELSE UPPER(ANIOS_ACUMULADOS) END)  LIKE UPPER( '%' || :ANIOS_ACUMULADOS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="LICENCIAS_SUSPENSIONES" sqlType="STRING"/>
		<param name="FECHA_INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FECHA_ESTIMADA_REGRESO" sqlType="STRING"/>
		<param name="DIAS_ESTIMADOS_DISFRUTE" sqlType="STRING"/>
		<param name="ANIOS_ACUMULADOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dvacaciones/numero">
		<call-query href="getDvacacionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="LICENCIAS_SUSPENSIONES" query-param="LICENCIAS_SUSPENSIONES"/>
			<with-param name="FECHA_INICIO_DISFRUTE" query-param="FECHA_INICIO_DISFRUTE"/>
			<with-param name="FECHA_ESTIMADA_REGRESO" query-param="FECHA_ESTIMADA_REGRESO"/>
			<with-param name="DIAS_ESTIMADOS_DISFRUTE" query-param="DIAS_ESTIMADOS_DISFRUTE"/>
			<with-param name="ANIOS_ACUMULADOS" query-param="ANIOS_ACUMULADOS"/>

		</call-query>
	</resource>
	<query id="updateDvacaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_VACACIONES SET FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), LICENCIAS_SUSPENSIONES=:LICENCIAS_SUSPENSIONES, FECHA_INICIO_DISFRUTE=TO_DATE(:FECHA_INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), FECHA_ESTIMADA_REGRESO=TO_DATE(:FECHA_ESTIMADA_REGRESO,'DD/MM/YYYY HH24:MI:SS'), DIAS_ESTIMADOS_DISFRUTE=:DIAS_ESTIMADOS_DISFRUTE, ANIOS_ACUMULADOS=:ANIOS_ACUMULADOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_VACACIONES.COMPANIA= :KEY_COMPANIA AND D_VACACIONES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND D_VACACIONES.ANIO= :KEY_ANIO AND D_VACACIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="LICENCIAS_SUSPENSIONES" sqlType="STRING"/>
		<param name="FECHA_INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FECHA_ESTIMADA_REGRESO" sqlType="STRING"/>
		<param name="DIAS_ESTIMADOS_DISFRUTE" sqlType="STRING"/>
		<param name="ANIOS_ACUMULADOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ANIO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dvacaciones">
		<call-query href="updateDvacaciones">
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="LICENCIAS_SUSPENSIONES" query-param="LICENCIAS_SUSPENSIONES"/>
			<with-param name="FECHA_INICIO_DISFRUTE" query-param="FECHA_INICIO_DISFRUTE"/>
			<with-param name="FECHA_ESTIMADA_REGRESO" query-param="FECHA_ESTIMADA_REGRESO"/>
			<with-param name="DIAS_ESTIMADOS_DISFRUTE" query-param="DIAS_ESTIMADOS_DISFRUTE"/>
			<with-param name="ANIOS_ACUMULADOS" query-param="ANIOS_ACUMULADOS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ANIO" query-param="KEY_ANIO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>