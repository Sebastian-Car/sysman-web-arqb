<data name="tiposlicencia" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTiposlicenciaIdDeConceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOS_LICENCIA.ID_DE_CONCEPTO  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.LICENCIA = :LICENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/iddeconcepto">
		<call-query href="getTiposlicenciaIdDeConceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaPagPorCompaniaYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.REMUNERACION IN (:REMUNERACION)) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="REMUNERACION" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposlicencia/porcompaniaytipo/pag">
		<call-query href="getTiposlicenciaPagPorCompaniaYTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaNumPorCompaniaYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.REMUNERACION IN (:REMUNERACION)) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="REMUNERACION" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/porcompaniaytipo/num">
		<call-query href="getTiposlicenciaNumPorCompaniaYTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaPagCodigoYNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA ORDER BY TIPOS_LICENCIA.LICENCIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposlicencia/codigoynombreinicial/pag">
		<call-query href="getTiposlicenciaPagCodigoYNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaNumCodigoYNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA ORDER BY TIPOS_LICENCIA.LICENCIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/codigoynombreinicial/num">
		<call-query href="getTiposlicenciaNumCodigoYNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaPagCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.LICENCIA &gt;= :LICENCIAINICIAL ORDER BY TIPOS_LICENCIA.LICENCIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIAINICIAL" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposlicencia/codigoynombrefinal/pag">
		<call-query href="getTiposlicenciaPagCodigoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIAINICIAL" query-param="LICENCIAINICIAL"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaNumCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.LICENCIA &gt;= :LICENCIAINICIAL ORDER BY TIPOS_LICENCIA.LICENCIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIAINICIAL" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/codigoynombrefinal/num">
		<call-query href="getTiposlicenciaNumCodigoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIAINICIAL" query-param="LICENCIAINICIAL"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertTiposlicencia" keyColumns="COMPANIA,LICENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOS_LICENCIA (COMPANIA, LICENCIA, DESCRIPCION, REMUNERACION, ID_DE_CONCEPTO, HABILES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :LICENCIA, :DESCRIPCION, :REMUNERACION, :ID_DE_CONCEPTO, :HABILES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_LICENCIA":"$LICENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="REMUNERACION" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="HABILES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tiposlicencia">
		<call-query href="insertTiposlicencia">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="HABILES" query-param="HABILES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTiposlicencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA= :KEY_COMPANIA AND TIPOS_LICENCIA.LICENCIA= :KEY_LICENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_LICENCIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tiposlicencia">
		<call-query href="deleteTiposlicencia">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_LICENCIA" query-param="KEY_LICENCIA"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  T.COMPANIA, T.LICENCIA, T.DESCRIPCION,(CASE T.REMUNERACION WHEN 0 THEN 'false' ELSE 'true' END) REMUNERACION, T.ID_DE_CONCEPTO , (SELECT NOMBRE_CONCEPTO FROM CONCEPTOS WHERE COMPANIA = T.COMPANIA AND ID_DE_CONCEPTO = T.ID_DE_CONCEPTO ) NOMBRECONCEPTO ,(CASE HABILES WHEN 0 THEN 'false' ELSE 'true' END) HABILES FROM TIPOS_LICENCIA T WHERE T.COMPANIA = :COMPANIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN REMUNERACION IS NULL THEN ' ' ELSE UPPER(REMUNERACION) END)  LIKE UPPER( '%' || :REMUNERACION || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN HABILES IS NULL THEN ' ' ELSE UPPER(HABILES) END)  LIKE UPPER( '%' || :HABILES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION","REMUNERACION":"$REMUNERACION(type:boolean)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRECONCEPTO":"$NOMBRECONCEPTO","HABILES":"$HABILES(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="REMUNERACION" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="HABILES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposlicencia">
		<call-query href="getTiposlicenciaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="HABILES" query-param="HABILES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  T.COMPANIA, T.LICENCIA, T.DESCRIPCION,(CASE T.REMUNERACION WHEN 0 THEN 'false' ELSE 'true' END) REMUNERACION, T.ID_DE_CONCEPTO , (SELECT NOMBRE_CONCEPTO FROM CONCEPTOS WHERE COMPANIA = T.COMPANIA AND ID_DE_CONCEPTO = T.ID_DE_CONCEPTO ) NOMBRECONCEPTO ,(CASE HABILES WHEN 0 THEN 'false' ELSE 'true' END) HABILES FROM TIPOS_LICENCIA T WHERE T.COMPANIA = :COMPANIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN REMUNERACION IS NULL THEN ' ' ELSE UPPER(REMUNERACION) END)  LIKE UPPER( '%' || :REMUNERACION || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN HABILES IS NULL THEN ' ' ELSE UPPER(HABILES) END)  LIKE UPPER( '%' || :HABILES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="REMUNERACION" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="HABILES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/numero">
		<call-query href="getTiposlicenciaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="HABILES" query-param="HABILES"/>

		</call-query>
	</resource>
	<query id="updateTiposlicencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPOS_LICENCIA SET LICENCIA=:LICENCIA, DESCRIPCION=:DESCRIPCION, REMUNERACION=:REMUNERACION, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, HABILES=:HABILES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPOS_LICENCIA.COMPANIA= :KEY_COMPANIA AND TIPOS_LICENCIA.LICENCIA= :KEY_LICENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="REMUNERACION" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="HABILES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_LICENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tiposlicencia">
		<call-query href="updateTiposlicencia">
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="REMUNERACION" query-param="REMUNERACION"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="HABILES" query-param="HABILES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_LICENCIA" query-param="KEY_LICENCIA"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaPagOtraslicenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.LICENCIA IN ('99')) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposlicencia/otraslicencias/pag">
		<call-query href="getTiposlicenciaPagOtraslicenciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaNumOtraslicenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.LICENCIA IN ('99')) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/otraslicencias/num">
		<call-query href="getTiposlicenciaNumOtraslicenciasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaSinremuneracionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOS_LICENCIA.LICENCIA, TIPOS_LICENCIA.DESCRIPCION  FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA AND TIPOS_LICENCIA.REMUNERACION NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/sinremuneracion">
		<call-query href="getTiposlicenciaSinremuneracionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaPagTipoLicDesHabilesPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  LICENCIA, DESCRIPCION,(CASE HABILES WHEN 0 THEN 'false' ELSE 'true' END) HABILES FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN HABILES IS NULL THEN ' ' ELSE UPPER(HABILES) END)  LIKE UPPER(:HABILES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LICENCIA":"$LICENCIA","DESCRIPCION":"$DESCRIPCION","HABILES":"$HABILES(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="HABILES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposlicencia/tipolicdeshabilesporcia/pag">
		<call-query href="getTiposlicenciaPagTipoLicDesHabilesPorCiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="HABILES" query-param="HABILES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposlicenciaNumTipoLicDesHabilesPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  LICENCIA, DESCRIPCION,(CASE HABILES WHEN 0 THEN 'false' ELSE 'true' END) HABILES FROM TIPOS_LICENCIA WHERE TIPOS_LICENCIA.COMPANIA = :COMPANIA) WHERE (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER(:LICENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN HABILES IS NULL THEN ' ' ELSE UPPER(HABILES) END)  LIKE UPPER(:HABILES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="HABILES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposlicencia/tipolicdeshabilesporcia/num">
		<call-query href="getTiposlicenciaNumTipoLicDesHabilesPorCiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LICENCIA" query-param="LICENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="HABILES" query-param="HABILES"/>

		</call-query>
	</resource>

</data>