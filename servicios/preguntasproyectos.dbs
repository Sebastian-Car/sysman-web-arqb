<data name="preguntasproyectos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertPreguntasproyectos" keyColumns="COMPANIA,PROYECTO,PREGUNTA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PREGUNTAS_PROYECTOS (COMPANIA, PROYECTO, PREGUNTA, RESPUESTA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :PROYECTO, :PREGUNTA, :RESPUESTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROYECTO":"$PROYECTO","KEY_PREGUNTA":"$PREGUNTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="PREGUNTA" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="preguntasproyectos">
		<call-query href="insertPreguntasproyectos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="PREGUNTA" query-param="PREGUNTA"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePreguntasproyectos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PREGUNTAS_PROYECTOS WHERE PREGUNTAS_PROYECTOS.COMPANIA= :KEY_COMPANIA AND PREGUNTAS_PROYECTOS.PROYECTO= :KEY_PROYECTO AND PREGUNTAS_PROYECTOS.PREGUNTA= :KEY_PREGUNTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_PREGUNTA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="preguntasproyectos">
		<call-query href="deletePreguntasproyectos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_PREGUNTA" query-param="KEY_PREGUNTA"/>

		</call-query>
	</resource>
	<query id="getPreguntasproyectosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PREGUNTAS_PROYECTOS.COMPANIA, PREGUNTAS_PROYECTOS.PROYECTO, PREGUNTAS_PROYECTOS.PREGUNTA, PREGUNTAS.NOMBRE,(CASE PREGUNTAS_PROYECTOS.RESPUESTA WHEN 0 THEN 'false' ELSE 'true' END) RESPUESTA FROM PREGUNTAS_PROYECTOS INNER JOIN PREGUNTAS ON PREGUNTAS_PROYECTOS.PREGUNTA=PREGUNTAS.CODIGO AND PREGUNTAS_PROYECTOS.PREGUNTA=PREGUNTAS.CODIGO WHERE PREGUNTAS_PROYECTOS.COMPANIA=:COMPANIA AND PREGUNTAS_PROYECTOS.PROYECTO=:CODIGOPROYECTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROYECTO":"$PROYECTO","PREGUNTA":"$PREGUNTA(type:integer)","NOMBRE":"$NOMBRE","RESPUESTA":"$RESPUESTA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="preguntasproyectos">
		<call-query href="getPreguntasproyectosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>

		</call-query>
	</resource>
	<query id="updatePreguntasproyectos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PREGUNTAS_PROYECTOS SET PREGUNTA=:PREGUNTA, RESPUESTA=:RESPUESTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PREGUNTAS_PROYECTOS.COMPANIA= :KEY_COMPANIA AND PREGUNTAS_PROYECTOS.PROYECTO= :KEY_PROYECTO AND PREGUNTAS_PROYECTOS.PREGUNTA= :KEY_PREGUNTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PREGUNTA" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_PREGUNTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="preguntasproyectos">
		<call-query href="updatePreguntasproyectos">
			<with-param name="PREGUNTA" query-param="PREGUNTA"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_PREGUNTA" query-param="KEY_PREGUNTA"/>

		</call-query>
	</resource>

</data>