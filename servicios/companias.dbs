	<query id="getCompaniasPagParametrosEntradaNoNuloQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA.CODIGO, COMPANIA.NITCOMPANIA, COMPANIA.NOMBRE, COMPANIA.TELEFONO, COMPANIA.FAX, COMPANIA.DIRECCION, COMPANIA.PAIS, COMPANIA.DEPARTAMENTO, COMPANIA.CIUDAD  FROM COMPANIA LEFT JOIN PARAMETROS_DE_ENTRADA ON COMPANIA.CODIGO = PARAMETROS_DE_ENTRADA.COMPANIA WHERE PARAMETROS_DE_ENTRADA.COMPANIA IS NOT NULL) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NITCOMPANIA":"$NITCOMPANIA","NOMBRE":"$NOMBRE","TELEFONO":"$TELEFONO","FAX":"$FAX","DIRECCION":"$DIRECCION","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="companias/parametrosentradanonulo/pag">
		<call-query href="getCompaniasPagParametrosEntradaNoNuloQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCompaniasNumParametrosEntradaNoNuloQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA.CODIGO, COMPANIA.NITCOMPANIA, COMPANIA.NOMBRE, COMPANIA.TELEFONO, COMPANIA.FAX, COMPANIA.DIRECCION, COMPANIA.PAIS, COMPANIA.DEPARTAMENTO, COMPANIA.CIUDAD  FROM COMPANIA LEFT JOIN PARAMETROS_DE_ENTRADA ON COMPANIA.CODIGO = PARAMETROS_DE_ENTRADA.COMPANIA WHERE PARAMETROS_DE_ENTRADA.COMPANIA IS NOT NULL) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

