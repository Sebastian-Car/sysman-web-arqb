	<query id="getCompaniasNumListadoGeneralQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO , NOMBRE  FROM COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="companias/listadogeneral/num">
		<call-query href="getCompaniasNumListadoGeneralQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCompaniasPagTipoentidadcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO ,TIPOENTIDAD  FROM COMPANIA WHERE CODIGO = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN TIPOENTIDAD IS NULL THEN ' ' ELSE UPPER(TIPOENTIDAD) END)  LIKE UPPER(:TIPOENTIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","TIPOENTIDAD":"$TIPOENTIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOENTIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="companias/tipoentidadcodigo/pag">
		<call-query href="getCompaniasPagTipoentidadcodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPOENTIDAD" query-param="TIPOENTIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCompaniasNumTipoentidadcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO ,TIPOENTIDAD  FROM COMPANIA WHERE CODIGO = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN TIPOENTIDAD IS NULL THEN ' ' ELSE UPPER(TIPOENTIDAD) END)  LIKE UPPER(:TIPOENTIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOENTIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="companias/tipoentidadcodigo/num">
		<call-query href="getCompaniasNumTipoentidadcodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPOENTIDAD" query-param="TIPOENTIDAD"/>

		</call-query>
	</resource>
	<query id="getCompaniasNombreDepartamentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA.DEPARTAMENTO , DEPARTAMENTO.NOMBRE  FROM COMPANIA INNER JOIN DEPARTAMENTO ON COMPANIA.PAIS = DEPARTAMENTO.PAIS AND COMPANIA.DEPARTAMENTO = DEPARTAMENTO.CODIGO WHERE COMPANIA.CODIGO = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEPARTAMENTO":"$DEPARTAMENTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="companias/nombredepartamento">
		<call-query href="getCompaniasNombreDepartamentoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getCompaniasCodentidadauditoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(CONCAT(CODIGO,'_'),REPLACE(SIGLACOMPANIA,' ','_')) COD_ENTIDAD FROM COMPANIA WHERE CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_ENTIDAD":"$COD_ENTIDAD"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="companias/codentidadauditoria">
		<call-query href="getCompaniasCodentidadauditoriaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getCompaniasRegimenporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT C.REGIMEN, R.NOMBRE FROM COMPANIA C INNER JOIN TIPOREGIMEN R ON C.REGIMEN = R.CODIGO WHERE C.CODIGO LIKE :COMPANIA AND ROWNUM =1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"REGIMEN":"$REGIMEN","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="companias/regimenporcompania">
		<call-query href="getCompaniasRegimenporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
		<query id="getCompaniasCompaniasporusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPANIA.CODIGO, COMPANIA.NOMBRE, COMPANIA.URL_TRATAMIENTO FROM COMPANIA INNER JOIN GRUPO_COMPANIA ON COMPANIA.CODIGO = GRUPO_COMPANIA.COMPANIA INNER JOIN USUARIO_D ON GRUPO_COMPANIA.GRUPO = USUARIO_D.GRUPO WHERE USUARIO_D.USUARIO = :USUARIO ORDER BY COMPANIA.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","URL_TRATAMIENTO":"$URL_TRATAMIENTO"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="companias/companiasporusuario">
		<call-query href="getCompaniasCompaniasporusuarioQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="getCompaniasPagCompaniaconsolidaalmQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA.CODIGO, COMPANIA.NOMBRE FROM CONSOLIDADA INNER JOIN COMPANIA ON COMPANIA.CODIGO = CONSOLIDADA.NITCOMPANIA WHERE CONSOLIDADA.COMPANIACON = :COMPANIA AND CONSOLIDADA.APLICA_ALM = -1) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="companias/companiaconsolidaalm/pag">
		<call-query href="getCompaniasPagCompaniaconsolidaalmQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCompaniasNumCompaniaconsolidaalmQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA.CODIGO, COMPANIA.NOMBRE FROM CONSOLIDADA INNER JOIN COMPANIA ON COMPANIA.CODIGO = CONSOLIDADA.NITCOMPANIA WHERE CONSOLIDADA.COMPANIACON = :COMPANIA AND CONSOLIDADA.APLICA_ALM = -1) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="companias/companiaconsolidaalm/num">
		<call-query href="getCompaniasNumCompaniaconsolidaalmQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

