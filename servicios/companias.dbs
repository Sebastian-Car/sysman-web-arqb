	<query id="getCompaniasNombreporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  UPPER(COMPANIA.NOMBRE) AS NOMBRE  FROM COMPANIA WHERE COMPANIA.CODIGO = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
