	</resource>
	<query id="getCompaniasDataAutenticacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  C.CODIGO,C.NOMBRE,RUTA_IMAGEN,RUTA_VIGILADO_POR,SIGLACOMPANIA, P.NOMBRE NOMBRE_PAIS, D.NOMBRE NOMBRE_DEPARTAMENTO, CU.NOMBRE NOMBRE_CIUDAD,MONEDA,C.PAIS,C.DEPARTAMENTO, C.CIUDAD,C.NITCOMPANIA,C.DIRECCION,C.TELEFONO,(CASE RETENEDOR_FTE WHEN 0 THEN 'false' ELSE 'true' END) RETENEDOR_FTE,(CASE RETENEDOR_IVA WHEN 0 THEN 'false' ELSE 'true' END) RETENEDOR_IVA,(CASE RETENEDOR_ICA WHEN 0 THEN 'false' ELSE 'true' END) RETENEDOR_ICA,(CASE RETENEDOR_TBRE WHEN 0 THEN 'false' ELSE 'true' END) RETENEDOR_TBRE,(CASE CONSOLIDADA WHEN 0 THEN 'false' ELSE 'true' END) CONSOLIDADA, C.FAX, C.CODIGODANE, C.MISION, C.VISION, C.DIRECCIONEMAIL, C.PAGINAWEB, C.TIPOENTIDAD, C.CODIGOSCHIP, C.FIRMAFACTURA, C.CODIGO_WEB, C.CONTACTO, C.RUTA_STICKER, C.NUIR, C.CODIGO_CONTADURIA  FROM COMPANIA C INNER JOIN PAISES P ON(C.PAIS=P.PAIS) INNER JOIN DEPARTAMENTO D ON (C.PAIS=D.PAIS AND C.DEPARTAMENTO=D.CODIGO) INNER JOIN CIUDAD CU ON (C.PAIS=CU.PAIS AND C.DEPARTAMENTO=CU.DEPARTAMENTO AND C.CIUDAD=CU.CODIGO) WHERE C.CODIGO=:CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","RUTA_IMAGEN":"$RUTA_IMAGEN","RUTA_VIGILADO_POR":"$RUTA_VIGILADO_POR","SIGLACOMPANIA":"$SIGLACOMPANIA","NOMBRE_PAIS":"$NOMBRE_PAIS","NOMBRE_DEPARTAMENTO":"$NOMBRE_DEPARTAMENTO","NOMBRE_CIUDAD":"$NOMBRE_CIUDAD","MONEDA":"$MONEDA","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","NITCOMPANIA":"$NITCOMPANIA","DIRECCION":"$DIRECCION","TELEFONO":"$TELEFONO","RETENEDOR_FTE":"$RETENEDOR_FTE(type:boolean)","RETENEDOR_IVA":"$RETENEDOR_IVA(type:boolean)","RETENEDOR_ICA":"$RETENEDOR_ICA(type:boolean)","RETENEDOR_TBRE":"$RETENEDOR_TBRE(type:boolean)","CONSOLIDADA":"$CONSOLIDADA(type:boolean)","FAX":"$FAX","CODIGODANE":"$CODIGODANE","MISION":"$MISION","VISION":"$VISION","DIRECCIONEMAIL":"$DIRECCIONEMAIL","PAGINAWEB":"$PAGINAWEB","TIPOENTIDAD":"$TIPOENTIDAD(type:integer)","CODIGOSCHIP":"$CODIGOSCHIP","FIRMAFACTURA":"$FIRMAFACTURA","CODIGO_WEB":"$CODIGO_WEB","CONTACTO":"$CONTACTO","RUTA_STICKER":"$RUTA_STICKER","NUIR":"$NUIR","CODIGO_CONTADURIA":"$CODIGO_CONTADURIA"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
