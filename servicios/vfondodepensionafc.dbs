<data name="vfondodepensionafc" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVfondodepensionafcTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FONDO_AFC, NOMBRE_FONDO_AFC  FROM V_FONDO_DE_PENSION_AFC WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FONDO_AFC":"$FONDO_AFC","NOMBRE_FONDO_AFC":"$NOMBRE_FONDO_AFC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vfondodepensionafc/todosporcompania">
		<call-query href="getVfondodepensionafcTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>