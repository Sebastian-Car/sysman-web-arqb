<data name="depreciar" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDepreciarCantPorSerieConVlrdepreciacionDiferenteADependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM DEPRECIAR WHERE COMPANIA =:COMPANIA AND SERIE =:SERIE AND DEPENDENCIA NOT IN(:DEPENDENCIA) AND VLRDEPRECIACION NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/cantporserieconvlrdepreciaciondiferenteadependencia">
		<call-query href="getDepreciarCantPorSerieConVlrdepreciacionDiferenteADependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getDepreciarValormesanteriorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ELEMENTO, SERIE, NIIF_COSTOAJUSTADO, NIIF_VLRLIBROS FROM DEPRECIAR WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND SERIE = :SERIE AND PERIODO = :FECHA_CAMBIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","NIIF_COSTOAJUSTADO":"$NIIF_COSTOAJUSTADO","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHA_CAMBIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/valormesanterior">
		<call-query href="getDepreciarValormesanteriorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHA_CAMBIO" query-param="FECHA_CAMBIO"/>

		</call-query>
	</resource>
	<query id="getDepreciarExistedepreciarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) VALOR FROM DEPRECIAR WHERE COMPANIA = :COMPANIA AND SERIE = :SERIE AND ELEMENTO = :ELEMENTO AND MES = :MES AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/existedepreciar">
		<call-query href="getDepreciarExistedepreciarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDepreciarDepreciacionposteriorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) VALOR FROM DEPRECIAR WHERE COMPANIA = :COMPANIA AND SERIE = :SERIE AND ELEMENTO = :ELEMENTO AND MES &gt; :MES AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/depreciacionposterior">
		<call-query href="getDepreciarDepreciacionposteriorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDepreciarDepreciacionxcuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGOCUENTA , NVL(NOMBRECUENTA,'TOTAL') NOMBRECUENTA, SUM(VLRELEMENTO) VALOR_HISTORICO, SUM(VLRDEPRECIACION) DEPRECIACION_DEL_PERIODO, SUM(DEPACUMULADA) DEPRECIACION_ACUMULADA, SUM(DEPRECIACION_ANTERIOR) DEPRECIACION_ANTERIOR, SUM(VLRLIBROS) VALOR_LIBROS FROM ( SELECT SUBSTR(DEPRECIAR.ELEMENTO, 1, :AGRUPACION) ELEMENTO, DEPRECIAR.SERIE, TO_CHAR(DEVOLUTIVO.FECHAADQUISICION , 'DD/MM/YYYY') AS FECHA_ADQUISICION, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN DEPRECIAR.NIIF_VLRELEMENTO ELSE DEPRECIAR.VLRELEMENTO END VLRELEMENTO, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN DEPRECIAR.NIIF_COSTOAJUSTADO ELSE DEPRECIAR.COSTOAJUSTADO END COSTOAJUSTADO, CASE WHEN TO_DATE(:ULTIMODIA,'DD/MM/YYYY')&gt;= REEXPRESARVIDAUTIL.FECHACAMBIO THEN REEXPRESARVIDAUTIL.DETERIORO ELSE DEVOLUTIVO.DETERIORO END DETERIORO, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN DEPRECIAR.NIIF_VLRDEPRECIACION ELSE DEPRECIAR.VLRDEPRECIACION END VLRDEPRECIACION, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN DEPRECIAR.NIIF_DEPACUMULADA ELSE DEPRECIAR.DEPACUMULADA END DEPACUMULADA, (CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN DEPRECIAR.NIIF_DEPACUMULADA ELSE DEPRECIAR.DEPACUMULADA END) - (CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN DEPRECIAR.NIIF_VLRDEPRECIACION ELSE DEPRECIAR.VLRDEPRECIACION END) DEPRECIACION_ANTERIOR, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN DEPRECIAR.NIIF_VLRLIBROS ELSE DEPRECIAR.VLRLIBROS END VLRLIBROS, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN NVL(NIIF_INVENTARIOCONTA.CUENTACREDITO,INVENTARIOCUENTA.CUENTAACTIVO) ELSE INVENTARIOCONTABILIDAD.DEPRECCREDITOS END CODIGOCUENTA, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(DEPRECIAR.COMPANIA,'MANEJA NIIF EN ALMACEN',10,DEPRECIAR.PERIODO)='SI' THEN NVL(PLAN_CONTABLE.NOMBRE,PLAN_CONTABLEI.NOMBRE) ELSE PLANCONTABLE.NOMBRE END NOMBRECUENTA FROM DEPRECIAR INNER JOIN DEVOLUTIVO ON DEPRECIAR.COMPANIA = DEVOLUTIVO.COMPANIA AND DEPRECIAR.ELEMENTO = DEVOLUTIVO.ELEMENTO AND DEPRECIAR.SERIE = DEVOLUTIVO.SERIE LEFT JOIN INVENTARIO ON DEPRECIAR.COMPANIA = INVENTARIO.COMPANIA AND DEPRECIAR.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN INVENTARIO INVENTARIOCUENTA ON DEPRECIAR.COMPANIA = INVENTARIOCUENTA.COMPANIA AND SUBSTR(DEPRECIAR.ELEMENTO, 1, :AGRUPACION) = INVENTARIOCUENTA.CODIGOELEMENTO LEFT JOIN NIIF_INVENTARIOCONTA ON DEPRECIAR.COMPANIA = NIIF_INVENTARIOCONTA.COMPANIA AND SUBSTR(DEPRECIAR.ELEMENTO, 1, :AGRUPACION) = NIIF_INVENTARIOCONTA.CODIGOELEMENTO AND DEPRECIAR.ANO = NIIF_INVENTARIOCONTA.ANO AND DEPRECIAR.BODEGA = NIIF_INVENTARIOCONTA.BODEGA AND DEPRECIAR.NIIF_TIPO_ACTIVO = NIIF_INVENTARIOCONTA.TIPOACTIVO LEFT JOIN PLAN_CONTABLE ON NIIF_INVENTARIOCONTA.COMPANIA = PLAN_CONTABLE.COMPANIA AND NIIF_INVENTARIOCONTA.CUENTACREDITO = PLAN_CONTABLE.CODIGO AND NIIF_INVENTARIOCONTA.ANO = PLAN_CONTABLE.ANO LEFT JOIN PLAN_CONTABLE PLAN_CONTABLEI ON INVENTARIOCUENTA.COMPANIA = PLAN_CONTABLEI.COMPANIA AND INVENTARIOCUENTA.CUENTAACTIVO = PLAN_CONTABLEI.CODIGO AND NIIF_INVENTARIOCONTA.ANO = PLAN_CONTABLEI.ANO LEFT JOIN INVENTARIOCONTABILIDAD ON DEPRECIAR.COMPANIA = INVENTARIOCONTABILIDAD.COMPANIA AND SUBSTR(DEPRECIAR.ELEMENTO, 1, :AGRUPACION) = INVENTARIOCONTABILIDAD.CODIGOELEMENTO AND DEPRECIAR.ANO = INVENTARIOCONTABILIDAD.ANO LEFT JOIN PLAN_CONTABLE PLANCONTABLE ON INVENTARIOCONTABILIDAD.COMPANIA = PLANCONTABLE.COMPANIA AND INVENTARIOCONTABILIDAD.DEPRECCREDITO = PLANCONTABLE.CODIGO AND INVENTARIOCONTABILIDAD.ANO = PLANCONTABLE.ANO INNER JOIN BODEGA ON DEPRECIAR.COMPANIA = BODEGA.COMPANIA AND DEPRECIAR.BODEGA = BODEGA.CODIGO LEFT JOIN ( SELECT RV.COMPANIA, RV.ELEMENTO, RV.SERIE, RV.FECHACAMBIO, REEXVIDA.VIDAUTIL, RV.NIIF_COSTOAJUSTADO, RV.DETERIORO, RV.NIIF_VLRACUMULADO FROM (SELECT REEXPRESARVIDAUTIL.COMPANIA, REEXPRESARVIDAUTIL.ELEMENTO, REEXPRESARVIDAUTIL.SERIE, MAX(REEXPRESARVIDAUTIL.FECHACAMBIO) FECHACAMBIO, DEPRECIAR.NIIF_COSTOAJUSTADO, SUM(REEXPRESARVIDAUTIL.DETERIORO) DETERIORO, DEPRECIAR.NIIF_VLRACUMULADO FROM REEXPRESARVIDAUTIL LEFT JOIN DEPRECIAR ON REEXPRESARVIDAUTIL.COMPANIA = DEPRECIAR.COMPANIA AND REEXPRESARVIDAUTIL.ELEMENTO = DEPRECIAR.ELEMENTO AND REEXPRESARVIDAUTIL.SERIE = DEPRECIAR.SERIE AND TO_DATE(:ULTIMODIA,'DD/MM/YYYY') = DEPRECIAR.PERIODO WHERE REEXPRESARVIDAUTIL.FECHACAMBIO &lt;= TO_DATE(:ULTIMODIA,'DD/MM/YYYY') GROUP BY REEXPRESARVIDAUTIL.COMPANIA, REEXPRESARVIDAUTIL.ELEMENTO, REEXPRESARVIDAUTIL.SERIE, DEPRECIAR.NIIF_COSTOAJUSTADO, DEPRECIAR.NIIF_VLRACUMULADO ) RV INNER JOIN REEXPRESARVIDAUTIL REEXVIDA ON RV.COMPANIA = REEXVIDA.COMPANIA AND RV.ELEMENTO = REEXVIDA.ELEMENTO AND RV.SERIE = REEXVIDA.SERIE AND RV.FECHACAMBIO = REEXVIDA.FECHACAMBIO ) REEXPRESARVIDAUTIL ON DEVOLUTIVO.COMPANIA = REEXPRESARVIDAUTIL.COMPANIA AND DEVOLUTIVO.ELEMENTO = REEXPRESARVIDAUTIL.ELEMENTO AND DEVOLUTIVO.SERIE = REEXPRESARVIDAUTIL.SERIE WHERE DEPRECIAR.COMPANIA=:COMPANIA AND DEPRECIAR.ELEMENTO BETWEEN :ELEMENTOINICIAL AND :ELEMENTOFINAL AND TO_CHAR(DEPRECIAR.PERIODO,'DD/MM/YYYY')= :ULTIMODIA AND TO_DATE(TO_CHAR(NVL(FECHAANULADA,TO_DATE('31/12/3000')), 'DD/MM/YYYY'), 'DD/MM/YYYY')&gt;TO_DATE(:ULTIMODIA, 'DD/MM/YYYY') AND TO_DATE(TO_CHAR(DEVOLUTIVO.FECHAADQUISICION, 'DD/MM/YYYY'), 'DD/MM/YYYY')&lt;=TO_DATE(:ULTIMODIA, 'DD/MM/YYYY') ORDER BY DEPRECIAR.COMPANIA, DEPRECIAR.ELEMENTO, DEPRECIAR.SERIE, DEPRECIAR.PERIODO ) GROUP BY GROUPING SETS ( (CODIGOCUENTA, NOMBRECUENTA), () ) ORDER BY GROUPING(CODIGOCUENTA), CODIGOCUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOCUENTA":"$CODIGOCUENTA","NOMBRECUENTA":"$NOMBRECUENTA","VALOR_HISTORICO":"$VALOR_HISTORICO(type:double)","DEPRECIACION_DEL_PERIODO":"$DEPRECIACION_DEL_PERIODO(type:double)","DEPRECIACION_ACUMULADA":"$DEPRECIACION_ACUMULADA(type:double)","DEPRECIACION_ANTERIOR":"$DEPRECIACION_ANTERIOR(type:double)","VALOR_LIBROS":"$VALOR_LIBROS(type:double)"}]}}		</result>
		<param name="AGRUPACION" sqlType="STRING"/>
		<param name="ULTIMODIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTOINICIAL" sqlType="STRING"/>
		<param name="ELEMENTOFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/depreciacionxcuenta">
		<call-query href="getDepreciarDepreciacionxcuentaQuery">
			<with-param name="AGRUPACION" query-param="AGRUPACION"/>
			<with-param name="ULTIMODIA" query-param="ULTIMODIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTOINICIAL" query-param="ELEMENTOINICIAL"/>
			<with-param name="ELEMENTOFINAL" query-param="ELEMENTOFINAL"/>

		</call-query>
	</resource>
	<query id="getDepreciarDevolutivogenxcuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CUENTA_CONTABLE, SUM(VALOR_HISTORICO) VALOR_HISTORICO, SUM(VALOR_LIBROS) VALOR_LIBROS, SUM(DEPRECIACION_MENSUAL) DEPRECIACION_MENSUAL, SUM(DEPRECIACION_ACUMULADA) DEPRECIACION_ACUMULADA FROM (SELECT CASE WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ( 20 ) AND ULTIMOMOVIMIENTO.MANTENIMIENTO NOT IN ( 0 ) THEN NVL( ICUENTA.CUENTAACTIVOMAN, ICUENTA.CUENTAACTIVO ) WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ( 20 ) AND ULTIMOMOVIMIENTO.NO_EXPLOTADOS NOT IN ( 0 ) THEN NVL( ICUENTA.CUENTAACTIVONEXP, ICUENTA.CUENTAACTIVO ) WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ( '30' ) THEN ICUENTA.CUENTAACTIVOS WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ( '40' ) THEN ICUENTA.CUENTAACTIVOI WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ( '50' ) THEN ICUENTA.CUENTAACTIVOR WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ( '90' ) THEN ICUENTA.CUENTAACTIVOC ELSE ICUENTA.CUENTAACTIVO END CUENTA_CONTABLE, DEVOLUTIVO.SERIE, DEVOLUTIVO.NIIF_VALOR_TOTAL VALOR_HISTORICO, NVL(DEPRECIAR.NIIF_VLRLIBROS, 0) VALOR_LIBROS, NVL(DEPRECIAR.NIIF_VLRDEPRECIACION, 0) DEPRECIACION_MENSUAL, NVL(DEPRECIAR.NIIF_DEPACUMULADA, 0) DEPRECIACION_ACUMULADA FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEPRECIAR ON DEVOLUTIVO.COMPANIA = DEPRECIAR.COMPANIA AND DEVOLUTIVO.ELEMENTO = DEPRECIAR.ELEMENTO AND DEVOLUTIVO.SERIE = DEPRECIAR.SERIE INNER JOIN ( SELECT D_MOVIMIENTO.COMPANIA, D_MOVIMIENTO.TIPOMOVIMIENTO, D_MOVIMIENTO.MOVIMIENTO, D_MOVIMIENTO.ELEMENTO, D_MOVIMIENTO.SERIE, ULTIMO.FECHA_HORA, MOVIMIENTO.CLASE_BODEGA_ORIGEN, MOVIMIENTO.CLASE_BODEGA_DESTINO, MOVIMIENTO.BODEGA_ORIGEN, MOVIMIENTO.BODEGA_DESTINO, TIPOMOVIMIENTO.CLASE, BODEGA.NO_EXPLOTADOS, BODEGA.MANTENIMIENTO, MOVIMIENTO.DEPENDENCIA_DESTINO FROM D_MOVIMIENTO INNER JOIN ( SELECT D_MOVIMIENTO.COMPANIA, D_MOVIMIENTO.ELEMENTO, D_MOVIMIENTO.SERIE, MAX(TO_DATE(CONCAT(TO_CHAR(D_MOVIMIENTO.FECHA, 'DD/MM/YYYY'), TO_CHAR(D_MOVIMIENTO.HORA, 'HH24:MI:SS')),'DD/MM/YYYY HH24:MI:SS')) FECHA_HORA FROM D_MOVIMIENTO WHERE IND_REG NOT IN (0) AND TO_DATE(CONCAT(TO_CHAR(D_MOVIMIENTO.FECHA, 'DD/MM/YYYY'),TO_CHAR(D_MOVIMIENTO.HORA, 'HH24:MI:SS')),'DD/MM/YYYY HH24:MI:SS') &lt;= TO_DATE(:ULTIMODIA, 'DD/MM/YYYY HH24:MI:SS') GROUP BY D_MOVIMIENTO.COMPANIA, D_MOVIMIENTO.ELEMENTO, D_MOVIMIENTO.SERIE ) ULTIMO ON D_MOVIMIENTO.COMPANIA = ULTIMO.COMPANIA AND D_MOVIMIENTO.ELEMENTO = ULTIMO.ELEMENTO AND D_MOVIMIENTO.SERIE = ULTIMO.SERIE AND TO_DATE(CONCAT(TO_CHAR(D_MOVIMIENTO.FECHA, 'DD/MM/YYYY '),TO_CHAR(D_MOVIMIENTO.HORA, 'HH24:MI:SS')),'DD/MM/YYYY HH24:MI:SS') = ULTIMO.FECHA_HORA INNER JOIN MOVIMIENTO ON D_MOVIMIENTO.COMPANIA = MOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO = MOVIMIENTO.NUMERO INNER JOIN TIPOMOVIMIENTO ON MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO INNER JOIN BODEGA ON MOVIMIENTO.COMPANIA = BODEGA.COMPANIA AND MOVIMIENTO.BODEGA_DESTINO = BODEGA.CODIGO WHERE D_MOVIMIENTO.ELEMENTO BETWEEN :ELEMENTOINICIAL AND :ELEMENTOFINAL ) ULTIMOMOVIMIENTO ON ULTIMOMOVIMIENTO.COMPANIA = DEVOLUTIVO.COMPANIA AND ULTIMOMOVIMIENTO.ELEMENTO = DEVOLUTIVO.ELEMENTO AND ULTIMOMOVIMIENTO.SERIE = DEVOLUTIVO.SERIE INNER JOIN MOVIMIENTO ON ULTIMOMOVIMIENTO.COMPANIA = MOVIMIENTO.COMPANIA AND ULTIMOMOVIMIENTO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO AND ULTIMOMOVIMIENTO.MOVIMIENTO = MOVIMIENTO.NUMERO INNER JOIN INVENTARIO ICUENTA ON DEVOLUTIVO.COMPANIA = ICUENTA.COMPANIA AND SUBSTR( DEVOLUTIVO.ELEMENTO, 1, PCK_SYSMAN_UTL.FC_PAR( UN_COMPANIA =&gt; DEVOLUTIVO.COMPANIA, UN_NOMBRE =&gt; 'DIGITOS AGRUPACION INVENTARIO', UN_MODULO =&gt; PCK_DATOS.FC_MODULOALMACEN, UN_FECHA_PAR =&gt; SYSDATE, UN_IND_MAYUS =&gt; - 1 ) ) = ICUENTA.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA = :COMPANIA AND DEVOLUTIVO.ELEMENTO BETWEEN :ELEMENTOINICIAL AND :ELEMENTOFINAL AND ( INVENTARIO.TIPO IN ( 'M' ) OR ( EXTRACT(MONTH FROM DEPRECIAR.PERIODO) = EXTRACT(MONTH FROM TO_DATE( :FECHACORTE, 'DD/MM/YYYY' )) AND EXTRACT(YEAR FROM DEPRECIAR.PERIODO) = EXTRACT(YEAR FROM TO_DATE( :FECHACORTE, 'DD/MM/YYYY' )) ) ) AND ( DEVOLUTIVO.PLACAANULADA IN ( 0 ) OR DEVOLUTIVO.PLACAANULADA NOT IN ( 0 ) AND DEVOLUTIVO.FECHAANULADA &gt; TO_DATE( :FECHACORTE, 'DD/MM/YYYY' ) ) GROUP BY CASE WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN (20) AND ULTIMOMOVIMIENTO.MANTENIMIENTO NOT IN(0) THEN NVL(ICUENTA.CUENTAACTIVOMAN, ICUENTA.CUENTAACTIVO) WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN (20) AND ULTIMOMOVIMIENTO.NO_EXPLOTADOS NOT IN(0) THEN NVL(ICUENTA.CUENTAACTIVONEXP, ICUENTA.CUENTAACTIVO) WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ('30') THEN ICUENTA.CUENTAACTIVOS WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ('40') THEN ICUENTA.CUENTAACTIVOI WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ('50') THEN ICUENTA.CUENTAACTIVOR WHEN ULTIMOMOVIMIENTO.CLASE_BODEGA_DESTINO IN ('90') THEN ICUENTA.CUENTAACTIVOC ELSE ICUENTA.CUENTAACTIVO END, DEVOLUTIVO.SERIE, DEVOLUTIVO.NIIF_VALOR_TOTAL, NVL(DEPRECIAR.NIIF_VLRLIBROS, 0), NVL(DEPRECIAR.NIIF_VLRDEPRECIACION, 0), NVL(DEPRECIAR.NIIF_DEPACUMULADA, 0) ) GROUP BY CUENTA_CONTABLE ORDER BY CUENTA_CONTABLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA_CONTABLE":"$CUENTA_CONTABLE","VALOR_HISTORICO":"$VALOR_HISTORICO(type:double)","VALOR_LIBROS":"$VALOR_LIBROS(type:double)","DEPRECIACION_MENSUAL":"$DEPRECIACION_MENSUAL(type:double)","DEPRECIACION_ACUMULADA":"$DEPRECIACION_ACUMULADA(type:double)"  }]}}		</result>
		<param name="ULTIMODIA" sqlType="STRING"/>
		<param name="ELEMENTOINICIAL" sqlType="STRING"/>
		<param name="ELEMENTOFINAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/devolutivogenxcuenta">
		<call-query href="getDepreciarDevolutivogenxcuentaQuery">
			<with-param name="ULTIMODIA" query-param="ULTIMODIA"/>
			<with-param name="ELEMENTOINICIAL" query-param="ELEMENTOINICIAL"/>
			<with-param name="ELEMENTOFINAL" query-param="ELEMENTOFINAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>

		</call-query>
	</resource>
	<query id="getDepreciarCuentaalmxcuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CUENTA, NOMBRECUENTA, SUM(ANTERIOR) ANTERIOR, SUM(ENTRADAS) ENTRADAS, SUM(SALIDAS) SALIDAS, SUM(AJUSTES_DEBITO) AJUSTES_DEBITO, SUM(AJUSTES_CREDITO) AJUSTES_CREDITO, SUM(ANTERIOR + ENTRADAS - SALIDAS + AJUSTES_DEBITO + AJUSTES_CREDITO) SALDO_FINAL FROM (SELECT V_BASE_CUENTAALMACEN.BODEGA_DESTINO1 , V_BASE_CUENTAALMACEN.CUENTA , V_BASE_CUENTAALMACEN.GRUPO, PLAN_CONTABLE.NOMBRE NOMBRECUENTA, V_BASE_CUENTAALMACEN.NOMBREBODEGA DEPENDENCIA, CASE V_BASE_CUENTAALMACEN.TIPO WHEN 'C' THEN 'Consumo' WHEN 'D' THEN 'Devolutivos' WHEN 'N' THEN 'ActivosFijos' WHEN 'M' THEN 'Consumo Controlado' WHEN 'E' THEN 'Recibidos en Comodato' WHEN 'S' THEN 'Servicios' WHEN 'EC' THEN 'Entregados en Comodato' END TIPO, SUM(CASE WHEN (V_BASE_CUENTAALMACEN.FECHA &lt; TO_DATE(:FECHAINICIAL,'DD/MM/YYYY')) THEN NVL(V_BASE_CUENTAALMACEN.VALOR_ENTRADAS,0) - NVL(V_BASE_CUENTAALMACEN.VALOR_SALIDAS,0) + NVL(V_BASE_CUENTAALMACEN.AJUSTESDEBITO,0) + NVL(V_BASE_CUENTAALMACEN.AJUSTESCREDITO,0) ELSE 0 END ) AS ANTERIOR, SUM(CASE WHEN (V_BASE_CUENTAALMACEN.FECHA &gt;= TO_DATE(:FECHAINICIAL,'DD/MM/YYYY') AND V_BASE_CUENTAALMACEN.FECHA &lt;= TO_DATE(:FECHAFINAL,'DD/MM/YYYY')) THEN NVL(V_BASE_CUENTAALMACEN.VALOR_ENTRADAS,0) ELSE 0 END ) AS ENTRADAS, SUM(CASE WHEN (V_BASE_CUENTAALMACEN.FECHA &gt;= TO_DATE(:FECHAINICIAL,'DD/MM/YYYY') AND V_BASE_CUENTAALMACEN.FECHA &lt;= TO_DATE(:FECHAFINAL,'DD/MM/YYYY')) THEN NVL(V_BASE_CUENTAALMACEN.VALOR_SALIDAS,0) ELSE 0 END ) AS SALIDAS, SUM(CASE WHEN (V_BASE_CUENTAALMACEN.FECHA &gt;= TO_DATE(:FECHAINICIAL,'DD/MM/YYYY') AND V_BASE_CUENTAALMACEN.FECHA &lt;= TO_DATE(:FECHAFINAL,'DD/MM/YYYY')) THEN NVL(V_BASE_CUENTAALMACEN.AJUSTESDEBITO,0) ELSE 0 END ) AS AJUSTES_DEBITO, SUM(CASE WHEN (V_BASE_CUENTAALMACEN.FECHA &gt;= TO_DATE(:FECHAINICIAL,'DD/MM/YYYY') AND V_BASE_CUENTAALMACEN.FECHA &lt;= TO_DATE(:FECHAFINAL,'DD/MM/YYYY')) THEN NVL(V_BASE_CUENTAALMACEN.AJUSTESCREDITO,0) ELSE 0 END ) AS AJUSTES_CREDITO, SUM(NVL(V_BASE_CUENTAALMACEN.VALOR_ENTRADAS,0)-NVL(V_BASE_CUENTAALMACEN.VALOR_SALIDAS,0)+ NVL(V_BASE_CUENTAALMACEN.AJUSTESDEBITO,0) +NVL(V_BASE_CUENTAALMACEN.AJUSTESCREDITO,0)) AS SALDO_FINAL FROM V_BASE_CUENTAALMACEN INNER JOIN BODEGA ON V_BASE_CUENTAALMACEN.COMPANIA = BODEGA.COMPANIA AND V_BASE_CUENTAALMACEN.BODEGA_DESTINO1 = BODEGA.CODIGO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NOMBRE FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = TO_NUMBER(TO_CHAR(TO_DATE(:FECHAFINAL,'DD/MM/YYYY'), 'YYYY'))) PLAN_CONTABLE ON PLAN_CONTABLE.COMPANIA = V_BASE_CUENTAALMACEN.COMPANIA AND PLAN_CONTABLE.CODIGO = V_BASE_CUENTAALMACEN.CUENTA AND PLAN_CONTABLE.ANO = TO_NUMBER(TO_CHAR(TO_DATE(:FECHAFINAL,'DD/MM/YYYY'), 'YYYY')) WHERE V_BASE_CUENTAALMACEN.COMPANIA= :COMPANIA AND V_BASE_CUENTAALMACEN.FECHA BETWEEN TO_DATE(:FECHACORTE,'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL,'DD/MM/YYYY') AND V_BASE_CUENTAALMACEN.IND_REG NOT IN (0) AND BODEGA.MOSTRAR NOT IN(0) AND CASE WHEN :SINCONTROLADO NOT IN (0) THEN (CONCAT(TIPO,BODEGA_DESTINO1)) ELSE ' ' END NOT IN ('M30') GROUP BY V_BASE_CUENTAALMACEN.BODEGA_DESTINO1, V_BASE_CUENTAALMACEN.NOMBREBODEGA, V_BASE_CUENTAALMACEN.TIPO, V_BASE_CUENTAALMACEN.CUENTA, V_BASE_CUENTAALMACEN.GRUPO, PLAN_CONTABLE.NOMBRE) VISTA_CUENTAALMACEN WHERE ABS(ANTERIOR) + ABS(ENTRADAS) +ABS( SALIDAS) + ABS(AJUSTES_DEBITO) + ABS(AJUSTES_CREDITO) &lt;&gt;0 GROUP BY CUENTA, NOMBRECUENTA ORDER BY CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","NOMBRECUENTA":"$NOMBRECUENTA","ANTERIOR":"$ANTERIOR(type:double)","ENTRADAS":"$ENTRADAS(type:double)","SALIDAS":"$SALIDAS(type:double)","AJUSTES_DEBITO":"$AJUSTES_DEBITO(type:double)","AJUSTES_CREDITO":"$AJUSTES_CREDITO(type:double)","SALDO_FINAL":"$SALDO_FINAL(type:double)"}]}}		</result>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="SINCONTROLADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/cuentaalmxcuenta">
		<call-query href="getDepreciarCuentaalmxcuentaQuery">
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>
			<with-param name="SINCONTROLADO" query-param="SINCONTROLADO"/>

		</call-query>
	</resource>
	<query id="getDepreciarExistedepreciacioninicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) VALOR FROM DEPRECIAR WHERE COMPANIA = :COMPANIA AND SERIE = :SERIE AND ELEMENTO = :ELEMENTO AND MES = :MES AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="depreciar/existedepreciacioninicial">
		<call-query href="getDepreciarExistedepreciacioninicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>

</data>