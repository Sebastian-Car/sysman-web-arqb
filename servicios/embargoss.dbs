		</call-query>
	</resource>
	<query id="deleteEmbargoss" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EMBARGOS WHERE EMBARGOS.COMPANIA= :KEY_COMPANIA AND EMBARGOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND EMBARGOS.ANO= :KEY_ANO AND EMBARGOS.MES= :KEY_MES AND EMBARGOS.PERIODO= :KEY_PERIODO AND EMBARGOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND EMBARGOS.ID_EMBARGO= :KEY_ID_EMBARGO AND EMBARGOS.ID_JUZGADO= :KEY_ID_JUZGADO AND EMBARGOS.FECHA_EMBARGO= TO_DATE(:KEY_FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS')  AND EMBARGOS.OFICIO= :KEY_OFICIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ID_EMBARGO" sqlType="STRING"/>
		<param name="KEY_ID_JUZGADO" sqlType="STRING"/>
		<param name="KEY_FECHA_EMBARGO" sqlType="STRING"/>
		<param name="KEY_OFICIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="embargoss">
		<call-query href="deleteEmbargoss">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_EMBARGO" query-param="KEY_ID_EMBARGO"/>
			<with-param name="KEY_ID_JUZGADO" query-param="KEY_ID_JUZGADO"/>
			<with-param name="KEY_FECHA_EMBARGO" query-param="KEY_FECHA_EMBARGO"/>
			<with-param name="KEY_OFICIO" query-param="KEY_OFICIO"/>

		</call-query>
	</resource>
	<query id="getEmbargossPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT EMBARGOS.COMPANIA, EMBARGOS.ID_DE_PROCESO, EMBARGOS.ANO, EMBARGOS.MES, EMBARGOS.PERIODO, EMBARGOS.ID_DE_EMPLEADO, EMBARGOS.ID_EMBARGO, EMBARGOS.ID_JUZGADO, EMBARGOS.OFICIO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, TO_CHAR(EMBARGOS.FECHA_EMBARGO, 'DD/MM/YYYY') FECHA_EMBARGO, JUZGADOS.NOMBRE NOMJUZGADO FROM EMBARGOS INNER JOIN PERSONAL ON PERSONAL.ID_DE_EMPLEADO = EMBARGOS.ID_DE_EMPLEADO AND PERSONAL.COMPANIA = EMBARGOS.COMPANIA INNER JOIN JUZGADOS ON JUZGADOS.COMPANIA = EMBARGOS.COMPANIA AND JUZGADOS.ID_JUZGADO = EMBARGOS.ID_JUZGADO WHERE EMBARGOS.COMPANIA = :COMPANIA AND EMBARGOS.ID_DE_PROCESO = :PROCESO AND EMBARGOS.ANO = :ANIO AND EMBARGOS.MES = :MES AND EMBARGOS.PERIODO = :PERIODO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_DCTO), '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN FECHA_EMBARGO IS NULL THEN ' ' ELSE UPPER(FECHA_EMBARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_EMBARGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_EMBARGO":"$ID_EMBARGO","ID_JUZGADO":"$ID_JUZGADO","OFICIO":"$OFICIO","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","FECHA_EMBARGO":"$FECHA_EMBARGO","NOMJUZGADO":"$NOMJUZGADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FECHA_EMBARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="embargoss">
		<call-query href="getEmbargossPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="FECHA_EMBARGO" query-param="FECHA_EMBARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEmbargossNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT EMBARGOS.COMPANIA, EMBARGOS.ID_DE_PROCESO, EMBARGOS.ANO, EMBARGOS.MES, EMBARGOS.PERIODO, EMBARGOS.ID_DE_EMPLEADO, EMBARGOS.ID_EMBARGO, EMBARGOS.ID_JUZGADO, EMBARGOS.OFICIO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, TO_CHAR(EMBARGOS.FECHA_EMBARGO, 'DD/MM/YYYY') FECHA_EMBARGO, JUZGADOS.NOMBRE NOMJUZGADO FROM EMBARGOS INNER JOIN PERSONAL ON PERSONAL.ID_DE_EMPLEADO = EMBARGOS.ID_DE_EMPLEADO AND PERSONAL.COMPANIA = EMBARGOS.COMPANIA INNER JOIN JUZGADOS ON JUZGADOS.COMPANIA = EMBARGOS.COMPANIA AND JUZGADOS.ID_JUZGADO = EMBARGOS.ID_JUZGADO WHERE EMBARGOS.COMPANIA = :COMPANIA AND EMBARGOS.ID_DE_PROCESO = :PROCESO AND EMBARGOS.ANO = :ANIO AND EMBARGOS.MES = :MES AND EMBARGOS.PERIODO = :PERIODO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_DCTO), '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN FECHA_EMBARGO IS NULL THEN ' ' ELSE UPPER(FECHA_EMBARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_EMBARGO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FECHA_EMBARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="embargoss/numero">
		<call-query href="getEmbargossNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="FECHA_EMBARGO" query-param="FECHA_EMBARGO"/>

		</call-query>
	</resource>
	<query id="getEmbargossRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT JUZGADOS.NOMBRE NOMJUZGADO,(TO_CHAR(EMBARGOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(EMBARGOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, EMBARGOS.MODIFIED_BY, EMBARGOS.CREATED_BY, CONCEPTOS.NOMBRE_CONCEPTO NOMBRECONCEPTO, EMBARGOS.ID_DE_PROCESO, EMBARGOS.ANO, EMBARGOS.MES, EMBARGOS.PERIODO, EMBARGOS.ID_DE_EMPLEADO, EMBARGOS.ID_EMBARGO,(TO_CHAR(EMBARGOS.FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS')) FECHA_EMBARGO, EMBARGOS.OFICIO, EMBARGOS.ID_JUZGADO, EMBARGOS.MONTO_EMBARGO, EMBARGOS.PORCENTAJE, EMBARGOS.VALOR, EMBARGOS.CUOTAS, EMBARGOS.DEMANDANTE, EMBARGOS.TIPO_DEMANDANTE, EMBARGOS.NUM_RADICACION,(TO_CHAR(EMBARGOS.FECHA_RADICACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RADICACION, EMBARGOS.OBSERVACIONES, EMBARGOS.FORMA_PAGO, EMBARGOS.FACTOR1, EMBARGOS.FACTOR2, EMBARGOS.FACTOR3, EMBARGOS.FACTOR4, EMBARGOS.FACTOR5, EMBARGOS.FACTOR6, EMBARGOS.FACTOR7, EMBARGOS.FACTOR8, EMBARGOS.ESTADO, EMBARGOS.SALDO, EMBARGOS.VR_CUOTA, EMBARGOS.COMPANIA, EMBARGOS.CONCEPTO_DEPOSITO, EMBARGOS.CUENTA, EMBARGOS.DCTO_IDENTIDAD, EMBARGOS.CEDULA, EMBARGOS.BANCO, EMBARGOS.DEMANDANTE_NOMBRES, EMBARGOS.PORCENTAJE_CESANTIAS, EMBARGOS.PORCENTAJE_PRIMAS, EMBARGOS.OFICINA_DESTINO, EMBARGOS.ID_DE_CONCEPTO, EMBARGOS.NUMERO_PROCESO, EMBARGOS.COMISION, CLASE_DEMANDANTE.DEMANDANTE NOMBRETIPO FROM EMBARGOS LEFT JOIN JUZGADOS ON EMBARGOS.ID_JUZGADO = JUZGADOS.ID_JUZGADO AND EMBARGOS.COMPANIA = JUZGADOS.COMPANIA LEFT JOIN CONCEPTOS ON EMBARGOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO AND EMBARGOS.COMPANIA = JUZGADOS.COMPANIA LEFT JOIN CLASE_DEMANDANTE ON EMBARGOS.COMPANIA = CLASE_DEMANDANTE.COMPANIA AND EMBARGOS.TIPO_DEMANDANTE = CLASE_DEMANDANTE.ID_DEMANDANTE WHERE EMBARGOS.COMPANIA= :KEY_COMPANIA AND EMBARGOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND EMBARGOS.ANO= :KEY_ANO AND EMBARGOS.MES= :KEY_MES AND EMBARGOS.PERIODO= :KEY_PERIODO AND EMBARGOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND EMBARGOS.ID_EMBARGO= :KEY_ID_EMBARGO AND EMBARGOS.ID_JUZGADO= :KEY_ID_JUZGADO AND EMBARGOS.FECHA_EMBARGO= TO_DATE(:KEY_FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS') AND EMBARGOS.OFICIO= :KEY_OFICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMJUZGADO":"$NOMJUZGADO","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","CREATED_BY":"$CREATED_BY","NOMBRECONCEPTO":"$NOMBRECONCEPTO","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_EMBARGO":"$ID_EMBARGO","FECHA_EMBARGO":"$FECHA_EMBARGO","OFICIO":"$OFICIO","ID_JUZGADO":"$ID_JUZGADO","MONTO_EMBARGO":"$MONTO_EMBARGO","PORCENTAJE":"$PORCENTAJE","VALOR":"$VALOR","CUOTAS":"$CUOTAS(type:integer)","DEMANDANTE":"$DEMANDANTE","TIPO_DEMANDANTE":"$TIPO_DEMANDANTE","NUM_RADICACION":"$NUM_RADICACION","FECHA_RADICACION":"$FECHA_RADICACION","OBSERVACIONES":"$OBSERVACIONES","FORMA_PAGO":"$FORMA_PAGO","FACTOR1":"$FACTOR1(type:integer)","FACTOR2":"$FACTOR2(type:integer)","FACTOR3":"$FACTOR3(type:integer)","FACTOR4":"$FACTOR4(type:integer)","FACTOR5":"$FACTOR5(type:integer)","FACTOR6":"$FACTOR6(type:integer)","FACTOR7":"$FACTOR7(type:integer)","FACTOR8":"$FACTOR8(type:integer)","ESTADO":"$ESTADO","SALDO":"$SALDO","VR_CUOTA":"$VR_CUOTA","COMPANIA":"$COMPANIA","CONCEPTO_DEPOSITO":"$CONCEPTO_DEPOSITO","CUENTA":"$CUENTA","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","CEDULA":"$CEDULA","BANCO":"$BANCO","DEMANDANTE_NOMBRES":"$DEMANDANTE_NOMBRES","PORCENTAJE_CESANTIAS":"$PORCENTAJE_CESANTIAS","PORCENTAJE_PRIMAS":"$PORCENTAJE_PRIMAS","OFICINA_DESTINO":"$OFICINA_DESTINO","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NUMERO_PROCESO":"$NUMERO_PROCESO","COMISION":"$COMISION","NOMBRETIPO":"$NOMBRETIPO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_EMBARGO" sqlType="STRING"/>
