<data name="embargoss" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEmbargoss" keyColumns="COMPANIA,ID_DE_PROCESO,ANO,MES,PERIODO,ID_DE_EMPLEADO,ID_EMBARGO,ID_JUZGADO,OFICIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EMBARGOS (COMPANIA, ID_DE_EMPLEADO, ID_DE_PROCESO, ANO, MES, PERIODO, ID_EMBARGO, ID_JUZGADO, OFICIO, MONTO_EMBARGO, PORCENTAJE, VALOR, SALDO, VR_CUOTA, NUM_RADICACION, OBSERVACIONES, FORMA_PAGO, FACTOR1, FACTOR2, FACTOR3, FACTOR4, FACTOR5, FACTOR6, FACTOR7, FACTOR8, ESTADO, CONCEPTO_DEPOSITO, CUENTA, DCTO_IDENTIDAD, CEDULA, SUCURSAL, BANCO, DEMANDANTE, DEMANDANTE_NOMBRES, PORCENTAJE_CESANTIAS, PORCENTAJE_PRIMAS, OFICINA_DESTINO, ID_DE_CONCEPTO, COMISION, MANEJAIPC, NUMERO_PROCESO, FECHA_EMBARGO, FECHA_RADICACION, TIPO_DEMANDANTE, CUOTAS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_EMPLEADO, :ID_DE_PROCESO, :ANO, :MES, :PERIODO, :ID_EMBARGO, :ID_JUZGADO, :OFICIO, :MONTO_EMBARGO, :PORCENTAJE, :VALOR, :SALDO, :VR_CUOTA, :NUM_RADICACION, :OBSERVACIONES, :FORMA_PAGO, :FACTOR1, :FACTOR2, :FACTOR3, :FACTOR4, :FACTOR5, :FACTOR6, :FACTOR7, :FACTOR8, :ESTADO, :CONCEPTO_DEPOSITO, :CUENTA, :DCTO_IDENTIDAD, :CEDULA, :SUCURSAL, :BANCO, :DEMANDANTE, :DEMANDANTE_NOMBRES, :PORCENTAJE_CESANTIAS, :PORCENTAJE_PRIMAS, :OFICINA_DESTINO, :ID_DE_CONCEPTO, :COMISION, :MANEJAIPC, :NUMERO_PROCESO, TO_DATE(:FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_RADICACION,'DD/MM/YYYY HH24:MI:SS'), :TIPO_DEMANDANTE, :CUOTAS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_PERIODO":"$PERIODO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_EMBARGO":"$ID_EMBARGO","KEY_ID_JUZGADO":"$ID_JUZGADO","KEY_FECHA_EMBARGO":"$FECHA_EMBARGO","KEY_OFICIO":"$OFICIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_EMBARGO" sqlType="STRING"/>
		<param name="ID_JUZGADO" sqlType="STRING"/>
		<param name="OFICIO" sqlType="STRING"/>
		<param defaultValue="0" name="MONTO_EMBARGO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="0" name="SALDO" sqlType="STRING"/>
		<param defaultValue="0" name="VR_CUOTA" sqlType="STRING"/>
		<param defaultValue="" name="NUM_RADICACION" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="00" name="FORMA_PAGO" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR1" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR2" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR3" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR4" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR5" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR6" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR7" sqlType="STRING"/>
		<param defaultValue="" name="FACTOR8" sqlType="STRING"/>
		<param defaultValue="N" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO_DEPOSITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA" sqlType="STRING"/>
		<param defaultValue="" name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="CEDULA" sqlType="STRING"/>
		<param defaultValue="" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="BANCO" sqlType="STRING"/>
		<param defaultValue="" name="DEMANDANTE" sqlType="STRING"/>
		<param defaultValue="" name="DEMANDANTE_NOMBRES" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE_CESANTIAS" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE_PRIMAS" sqlType="STRING"/>
		<param defaultValue="" name="OFICINA_DESTINO" sqlType="STRING"/>
		<param defaultValue="" name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="COMISION" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJAIPC" sqlType="STRING"/>
		<param defaultValue="" name="NUMERO_PROCESO" sqlType="STRING"/>
		<param name="FECHA_EMBARGO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_RADICACION" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_DEMANDANTE" sqlType="STRING"/>
		<param defaultValue="" name="CUOTAS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
