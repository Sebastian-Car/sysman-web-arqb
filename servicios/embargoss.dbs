	<query id="updateEmbargoss" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EMBARGOS SET ID_DE_PROCESO=:ID_DE_PROCESO, TIPO_DEMANDANTE=:TIPO_DEMANDANTE, ID_EMBARGO=:ID_EMBARGO, ID_JUZGADO=:ID_JUZGADO, OFICIO=:OFICIO, MONTO_EMBARGO=:MONTO_EMBARGO, PORCENTAJE=:PORCENTAJE, VALOR=:VALOR, SALDO=:SALDO, VR_CUOTA=:VR_CUOTA, NUM_RADICACION=:NUM_RADICACION, OBSERVACIONES=:OBSERVACIONES, FORMA_PAGO=:FORMA_PAGO, FACTOR1=:FACTOR1, FACTOR2=:FACTOR2, FACTOR3=:FACTOR3, FACTOR4=:FACTOR4, FACTOR5=:FACTOR5, FACTOR6=:FACTOR6, FACTOR7=:FACTOR7, FACTOR8=:FACTOR8, ESTADO=:ESTADO, CONCEPTO_DEPOSITO=:CONCEPTO_DEPOSITO, CUENTA=:CUENTA, DCTO_IDENTIDAD=:DCTO_IDENTIDAD, CEDULA=:CEDULA, BANCO=:BANCO, DEMANDANTE=:DEMANDANTE, DEMANDANTE_NOMBRES=:DEMANDANTE_NOMBRES, PORCENTAJE_CESANTIAS=:PORCENTAJE_CESANTIAS, PORCENTAJE_PRIMAS=:PORCENTAJE_PRIMAS, OFICINA_DESTINO=:OFICINA_DESTINO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, COMISION=:COMISION, NUMERO_PROCESO=:NUMERO_PROCESO, FECHA_EMBARGO=TO_DATE(:FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS'), FECHA_RADICACION=TO_DATE(:FECHA_RADICACION,'DD/MM/YYYY HH24:MI:SS'), CUOTAS=:CUOTAS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EMBARGOS.COMPANIA= :KEY_COMPANIA AND EMBARGOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND EMBARGOS.ANO= :KEY_ANO AND EMBARGOS.MES= :KEY_MES AND EMBARGOS.PERIODO= :KEY_PERIODO AND EMBARGOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND EMBARGOS.ID_EMBARGO= :KEY_ID_EMBARGO AND EMBARGOS.ID_JUZGADO= :KEY_ID_JUZGADO AND EMBARGOS.FECHA_EMBARGO= TO_DATE(:KEY_FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS') AND EMBARGOS.OFICIO= :KEY_OFICIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

