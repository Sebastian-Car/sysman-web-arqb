	<query id="getComprobantescntretencionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, TIPORETENCION.NOMBRE NOMBRERETENCIONES, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, RETENCIONES.NOMBRE, COMPROBANTE_CNTRETENCION.PORCIVA, COMPROBANTE_CNTRETENCION.ACTIVIDAD_ECONOMICA FROM COMPROBANTE_CNTRETENCION LEFT JOIN RETENCIONES ON COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO AND COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO AND COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO LEFT JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO WHERE COMPROBANTE_CNTRETENCION.COMPANIA = :COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = :ANO AND COMPROBANTE_CNTRETENCION.TIPO = :TIPO AND COMPROBANTE_CNTRETENCION.NUMERO = :NUMERO ORDER BY COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION) WHERE (CASE WHEN NOMBRERETENCIONES IS NULL THEN ' ' ELSE UPPER(NOMBRERETENCIONES) END)  LIKE UPPER( '%' || :NOMBRERETENCIONES || '%')  AND (CASE WHEN CODIGORETENCION IS NULL THEN ' ' ELSE UPPER(CODIGORETENCION) END)  LIKE UPPER( '%' || :CODIGORETENCION || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN VALORBASE IS NULL THEN ' ' ELSE UPPER(VALORBASE) END)  LIKE UPPER( '%' || :VALORBASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TIPORETENCION":"$TIPORETENCION","NOMBRERETENCIONES":"$NOMBRERETENCIONES","CODIGORETENCION":"$CODIGORETENCION","VALOR":"$VALOR","VALORBASE":"$VALORBASE","NOMBRE":"$NOMBRE","PORCIVA":"$PORCIVA","ACTIVIDAD_ECONOMICA":"$ACTIVIDAD_ECONOMICA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRERETENCIONES" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>
		<param name="ACTIVIDAD_ECONOMICA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantescntretenciones">
		<call-query href="getComprobantescntretencionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NOMBRERETENCIONES" query-param="NOMBRERETENCIONES"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
