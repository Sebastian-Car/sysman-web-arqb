	<query id="insertComprobantescntretencionesCausacionautoxregimen" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPROBANTE_CNTRETENCION ( COMPANIA, ANO, TIPO, NUMERO, TIPORETENCION, CODIGORETENCION, VALORBASE, CONCEPTO, PROVEEDOR, REFERENCIADO, CENTROCOSTO, CREATED_BY, DATE_CREATED) SELECT COMPANIA, ANO, :TIPO, :NUMERO, TIPORETENCION, CODIGORETENCION, CASE WHEN TIPORETENCION IN ('IVA') THEN :VALORBASEIVA ELSE :VALORBASE END, :CONCEPTO, :PROVEEDOR, :REFERENCIADO, :CENTROCOSTO, :CREATED_BY, TO_DATE(:DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS') FROM TA_DETALLE_CONCEPTOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODIGO AND TIPORETENCION IN ( SELECT DISTINCT TR.CODIGO FROM TIPORETENCION TR LEFT JOIN CONFIGURACION_RETENCION CR ON TR.CODIGO = CR.TIPO_RETENCION LEFT JOIN COMPANIA CP ON CP.REGIMEN = CR.REGIMEN_COMPRADOR LEFT JOIN TERCERO TER ON TER.REGIMEN = CR.REGIMEN_VENDEDOR WHERE CP.CODIGO = :COMPANIA AND TER.NIT = :NIT AND CR.ANO = :ANO)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALORBASEIVA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORBASE" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="REFERENCIADO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>

	</query>
	<resource method="POST" path="comprobantescntretenciones/causacionautoxregimen">
		<call-query href="insertComprobantescntretencionesCausacionautoxregimen">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALORBASEIVA" query-param="VALORBASEIVA"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="REFERENCIADO" query-param="REFERENCIADO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NIT" query-param="NIT"/>

		</call-query>
	</resource>

</data>