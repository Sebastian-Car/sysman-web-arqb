<data name="comprobantescntretenciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getComprobantescntretencionesExistePorAnoTipomovNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'X' X  FROM COMPROBANTE_CNTRETENCION WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPOMOVIMIENTO AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescntretenciones/existeporanotipomovnumero">
		<call-query href="getComprobantescntretencionesExistePorAnoTipomovNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntretencionesExisteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  1 EXISTE  FROM COMPROBANTE_CNTRETENCION WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPO AND NUMERO = :NUMERO AND TIPORETENCION = :TIPORETENCION AND CODIGORETENCION= :CODIGORETENCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPORETENCION" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescntretenciones/existe">
		<call-query href="getComprobantescntretencionesExisteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>

		</call-query>
	</resource>
	<query id="getComprobantescntretencionesTipocodigoretencionQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT DETALLE_COMPROBANTE_CNT.COMPROBANTE,RETENCIONES.CUENTA_CREDITO, COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION FROM COMPROBANTE_CNTRETENCION INNER JOIN RETENCIONES ON COMPROBANTE_CNTRETENCION.COMPANIA= RETENCIONES.COMPANIA AND COMPROBANTE_CNTRETENCION.ANO= RETENCIONES.ANO AND COMPROBANTE_CNTRETENCION.TIPORETENCION= RETENCIONES.TIPO AND COMPROBANTE_CNTRETENCION.CODIGORETENCION= RETENCIONES.CODIGO INNER JOIN DETALLE_COMPROBANTE_CNT ON COMPROBANTE_CNTRETENCION.COMPANIA=DETALLE_COMPROBANTE_CNT.COMPANIA AND COMPROBANTE_CNTRETENCION.ANO=DETALLE_COMPROBANTE_CNT.ANO AND COMPROBANTE_CNTRETENCION.TIPO=DETALLE_COMPROBANTE_CNT.TIPO_CPTE AND COMPROBANTE_CNTRETENCION.NUMERO=DETALLE_COMPROBANTE_CNT.COMPROBANTE WHERE COMPROBANTE_CNTRETENCION.COMPANIA = :COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = :ANO AND COMPROBANTE_CNTRETENCION.TIPO IN (:TIPO) AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = :COMPROBANTE AND RETENCIONES.CUENTA_CREDITO = :CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE(type:long)","CUENTA_CREDITO":"$CUENTA_CREDITO","TIPORETENCION":"$TIPORETENCION","CODIGORETENCION":"$CODIGORETENCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescntretenciones/tipocodigoretencion">
		<call-query href="getComprobantescntretencionesTipocodigoretencionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="getComprobantescntretencionesTodosporcompanianumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, TIPORETENCION.NOMBRE NOMBRERETENCIONES, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, RETENCIONES.NOMBRE, COMPROBANTE_CNTRETENCION.PORCIVA FROM COMPROBANTE_CNTRETENCION LEFT JOIN RETENCIONES ON COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO AND COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO AND COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO LEFT JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO WHERE COMPROBANTE_CNTRETENCION.COMPANIA = :COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = :ANO AND COMPROBANTE_CNTRETENCION.TIPO = :TIPO AND COMPROBANTE_CNTRETENCION.NUMERO = :NUMERO ORDER BY COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TIPORETENCION":"$TIPORETENCION","NOMBRERETENCIONES":"$NOMBRERETENCIONES","CODIGORETENCION":"$CODIGORETENCION","VALOR":"$VALOR","VALORBASE":"$VALORBASE","NOMBRE":"$NOMBRE","PORCIVA":"$PORCIVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescntretenciones/todosporcompanianumero">
		<call-query href="getComprobantescntretencionesTodosporcompanianumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntretencionesCausacionautmQuery" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPROBANTE_CNTRETENCION (COMPANIA, ANO, TIPO, NUMERO, TIPORETENCION, CODIGORETENCION, VALORBASE, CONCEPTO, PROVEEDOR, REFERENCIADO, CENTROCOSTO, CREATED_BY, DATE_CREATED) SELECT COMPANIA, ANO, :TIPO, :NUMERO, TIPORETENCION, CODIGORETENCION, CASE WHEN TIPORETENCION IN ('IVA') THEN :VALORBASEIVA ELSE :VALORBASE END, :CONCEPTO, :PROVEEDOR, :REFERENCIADO, :CENTROCOSTO, :CREATED_BY, TO_DATE(:DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS') FROM TA_DETALLE_CONCEPTOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALORBASEIVA" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="REFERENCIADO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="comprobantescntretenciones/causacionautm">
		<call-query href="getComprobantescntretencionesCausacionautmQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALORBASEIVA" query-param="VALORBASEIVA"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="REFERENCIADO" query-param="REFERENCIADO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntretencionesCausacionautmxterceroQuery" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPROBANTE_CNTRETENCION (COMPANIA, ANO, TIPO, NUMERO, TIPORETENCION, CODIGORETENCION,VALORBASE, CREATED_BY, DATE_CREATED) SELECT COMPANIA, ANO, :TIPO, :NUMERO, TIPO_RETENCION, CODIGO_RETENCION,CASE WHEN TIPORETENCION IN ('IVA') THEN :VALORBASEIVA ELSE :VALORBASE END, :CREATED_BY, TO_DATE(:DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS') FROM TERCERO_RETENCIONES WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TERCERO = :TERCERO AND SUCURSAL = :SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALORBASEIVA" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="POST" path="comprobantescntretenciones/causacionautmxtercero">
		<call-query href="getComprobantescntretencionesCausacionautmxterceroQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALORBASEIVA" query-param="VALORBASEIVA"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="deleteComprobantescntretencionesDeletecausacionautm" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM COMPROBANTE_CNTRETENCION WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPO AND NUMERO = :NUMERO AND CONCEPTO = :CONCEPTO AND PROVEEDOR = :PROVEEDOR AND REFERENCIADO = :REFERENCIADO AND CENTROCOSTO = :CENTROCOSTO AND TIPORETENCION = :TIPORETENCION AND CODIGORETENCION = :CODIGORETENCION</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="REFERENCIADO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>
		<param name="TIPORETENCION" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="comprobantescntretenciones/deletecausacionautm">
		<call-query href="deleteComprobantescntretencionesDeletecausacionautm">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="REFERENCIADO" query-param="REFERENCIADO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>

		</call-query>
	</resource>
	<query id="getComprobantescntretencionesTodosporcausacionautoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, TIPORETENCION.NOMBRE NOMBRERETENCIONES, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, RETENCIONES.NOMBRE, COMPROBANTE_CNTRETENCION.PORCIVA FROM COMPROBANTE_CNTRETENCION LEFT JOIN RETENCIONES ON COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO AND COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO AND COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO LEFT JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO WHERE COMPROBANTE_CNTRETENCION.COMPANIA = :COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = :ANO AND COMPROBANTE_CNTRETENCION.TIPO = :TIPO AND COMPROBANTE_CNTRETENCION.NUMERO = :NUMERO AND COMPROBANTE_CNTRETENCION.CONCEPTO = :CONCEPTO AND COMPROBANTE_CNTRETENCION.PROVEEDOR = :PROVEEDOR AND COMPROBANTE_CNTRETENCION.REFERENCIADO = :REFERENCIADO AND COMPROBANTE_CNTRETENCION.CENTROCOSTO = :CENTROCOSTO ORDER BY COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TIPORETENCION":"$TIPORETENCION","NOMBRERETENCIONES":"$NOMBRERETENCIONES","CODIGORETENCION":"$CODIGORETENCION","VALOR":"$VALOR","VALORBASE":"$VALORBASE","NOMBRE":"$NOMBRE","PORCIVA":"$PORCIVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="REFERENCIADO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescntretenciones/todosporcausacionauto">
		<call-query href="getComprobantescntretencionesTodosporcausacionautoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="REFERENCIADO" query-param="REFERENCIADO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="updateComprobantescntretencionesCausacionautomatica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNTRETENCION SET TIPORETENCION=:TIPORETENCION, CODIGORETENCION=:CODIGORETENCION, VALOR=:VALOR, VALORBASE=:VALORBASE, CONCEPTO=:CONCEPTO, PROVEEDOR=:PROVEEDOR, REFERENCIADO=:REFERENCIADO, CENTROCOSTO=:CENTROCOSTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPROBANTE_CNTRETENCION.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_CNTRETENCION.ANO= :KEY_ANO AND COMPROBANTE_CNTRETENCION.TIPO= :KEY_TIPO AND COMPROBANTE_CNTRETENCION.NUMERO= :KEY_NUMERO AND COMPROBANTE_CNTRETENCION.TIPORETENCION= :KEY_TIPORETENCION AND COMPROBANTE_CNTRETENCION.CODIGORETENCION= :KEY_CODIGORETENCION AND COMPROBANTE_CNTRETENCION.CONCEPTO= :KEY_CONCEPTO AND COMPROBANTE_CNTRETENCION.PROVEEDOR= :KEY_PROVEEDOR AND COMPROBANTE_CNTRETENCION.REFERENCIADO= :KEY_REFERENCIADO AND COMPROBANTE_CNTRETENCION.CENTROCOSTO= :KEY_CENTROCOSTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPORETENCION" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PROVEEDOR" sqlType="STRING"/>
		<param name="REFERENCIADO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPORETENCION" sqlType="STRING"/>
		<param name="KEY_CODIGORETENCION" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_PROVEEDOR" sqlType="STRING"/>
		<param name="KEY_REFERENCIADO" sqlType="STRING"/>
		<param name="KEY_CENTROCOSTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="comprobantescntretenciones/causacionautomatica">
		<call-query href="updateComprobantescntretencionesCausacionautomatica">
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="CODIGORETENCION" query-param="CODIGORETENCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALORBASE" query-param="VALORBASE"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PROVEEDOR" query-param="PROVEEDOR"/>
			<with-param name="REFERENCIADO" query-param="REFERENCIADO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPORETENCION" query-param="KEY_TIPORETENCION"/>
			<with-param name="KEY_CODIGORETENCION" query-param="KEY_CODIGORETENCION"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_PROVEEDOR" query-param="KEY_PROVEEDOR"/>
			<with-param name="KEY_REFERENCIADO" query-param="KEY_REFERENCIADO"/>
			<with-param name="KEY_CENTROCOSTO" query-param="KEY_CENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="insertComprobantescntretenciones" keyColumns="COMPANIA,ANO,TIPO,NUMERO,TIPORETENCION,CODIGORETENCION" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPROBANTE_CNTRETENCION (COMPANIA, ANO, TIPO, NUMERO, TIPORETENCION, CODIGORETENCION, VALOR, VALORBASE, PORCIVA, CONCEPTO, PROVEEDOR, REFERENCIADO, CENTROCOSTO, ACTIVIDAD_ECONOMICA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO, :NUMERO, :TIPORETENCION, :CODIGORETENCION, :VALOR, :VALORBASE, :PORCIVA, :CONCEPTO, :PROVEEDOR, :REFERENCIADO, :CENTROCOSTO, :ACTIVIDAD_ECONOMICA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_TIPORETENCION":"$TIPORETENCION","KEY_CODIGORETENCION":"$CODIGORETENCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPORETENCION" sqlType="STRING"/>
