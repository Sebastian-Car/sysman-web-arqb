			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntretencionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPROBANTE_CNTRETENCION.COMPANIA, COMPROBANTE_CNTRETENCION.ANO, COMPROBANTE_CNTRETENCION.TIPO, COMPROBANTE_CNTRETENCION.NUMERO, COMPROBANTE_CNTRETENCION.TIPORETENCION, TIPORETENCION.NOMBRE NOMBRERETENCIONES, COMPROBANTE_CNTRETENCION.CODIGORETENCION, COMPROBANTE_CNTRETENCION.VALOR, COMPROBANTE_CNTRETENCION.VALORBASE, RETENCIONES.NOMBRE, COMPROBANTE_CNTRETENCION.PORCIVA, COMPROBANTE_CNTRETENCION.ACTIVIDAD_ECONOMICA FROM COMPROBANTE_CNTRETENCION LEFT JOIN RETENCIONES ON COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO AND COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO AND COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO LEFT JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO WHERE COMPROBANTE_CNTRETENCION.COMPANIA = :COMPANIA AND COMPROBANTE_CNTRETENCION.ANO = :ANO AND COMPROBANTE_CNTRETENCION.TIPO = :TIPO AND COMPROBANTE_CNTRETENCION.NUMERO = :NUMERO ORDER BY COMPROBANTE_CNTRETENCION.TIPORETENCION, COMPROBANTE_CNTRETENCION.CODIGORETENCION) WHERE (CASE WHEN NOMBRERETENCIONES IS NULL THEN ' ' ELSE UPPER(NOMBRERETENCIONES) END)  LIKE UPPER( '%' || :NOMBRERETENCIONES || '%')  AND (CASE WHEN CODIGORETENCION IS NULL THEN ' ' ELSE UPPER(CODIGORETENCION) END)  LIKE UPPER( '%' || :CODIGORETENCION || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN VALORBASE IS NULL THEN ' ' ELSE UPPER(VALORBASE) END)  LIKE UPPER( '%' || :VALORBASE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRERETENCIONES" sqlType="STRING"/>
		<param name="CODIGORETENCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALORBASE" sqlType="STRING"/>
		<param name="ACTIVIDAD_ECONOMICA" sqlType="STRING"/>

	</query>
