<data name="estadodevolutivo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEstadodevolutivoTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ESTADO, DESCRIPCION  FROM ESTADODEVOLUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
 
	</query>
	<resource method="GET" path="estadodevolutivo/todos">
		<call-query href="getEstadodevolutivoTodosQuery">
 
		</call-query>
	</resource>
	<query id="getEstadodevolutivoPagEstadoydescrpcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ESTADO, DESCRIPCION  FROM ESTADODEVOLUTIVO) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estadodevolutivo/estadoydescrpcion/pag">
		<call-query href="getEstadodevolutivoPagEstadoydescrpcionQuery">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstadodevolutivoNumEstadoydescrpcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ESTADO, DESCRIPCION  FROM ESTADODEVOLUTIVO) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estadodevolutivo/estadoydescrpcion/num">
		<call-query href="getEstadodevolutivoNumEstadoydescrpcionQuery">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertEstadodevolutivo" keyColumns="ESTADO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ESTADODEVOLUTIVO (ESTADO, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:ESTADO, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ESTADO":"$ESTADO"}]}}		</result>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="estadodevolutivo">
		<call-query href="insertEstadodevolutivo">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEstadodevolutivo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ESTADODEVOLUTIVO WHERE ESTADODEVOLUTIVO.ESTADO= :KEY_ESTADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ESTADO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="estadodevolutivo">
		<call-query href="deleteEstadodevolutivo">
			<with-param name="KEY_ESTADO" query-param="KEY_ESTADO"/>

		</call-query>
	</resource>
	<query id="getEstadodevolutivoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ESTADO, DESCRIPCION  FROM ESTADODEVOLUTIVO ORDER BY ESTADO) WHERE (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estadodevolutivo">
		<call-query href="getEstadodevolutivoPaginaQuery">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstadodevolutivoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ESTADO, DESCRIPCION  FROM ESTADODEVOLUTIVO ORDER BY ESTADO) WHERE (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estadodevolutivo/numero">
		<call-query href="getEstadodevolutivoNumeroQuery">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateEstadodevolutivo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ESTADODEVOLUTIVO SET ESTADO=:ESTADO, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ESTADODEVOLUTIVO.ESTADO= :KEY_ESTADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ESTADO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="estadodevolutivo">
		<call-query href="updateEstadodevolutivo">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_ESTADO" query-param="KEY_ESTADO"/>

		</call-query>
	</resource>

</data>