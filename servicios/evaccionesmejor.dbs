<data name="evaccionesmejor" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEvaccionesmejor" keyColumns="COMPANIA,NUMERO_EVALUACION,CLASE_EVALUACION,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_ACCIONES_MEJORA (COMPANIA, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, ID_COMPETENCIA, CONSECUTIVO, VERSION, COMPONENTE, ASPECTO_A_CORREGIR, ACCION, MOTIVO, OBSERVACIONES, NUMERO_MANUAL, TIPO_COMPETENCIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_EVALUACION, :CLASE_EVALUACION, :TIPO_EVALUACION, :CEDULA_EVALUADO, :SUCURSAL_EVALUADO, :CEDULA_EVALUADOR, :SUCURSAL_EVALUADOR, :ID_COMPETENCIA, :CONSECUTIVO, :VERSION, :COMPONENTE, :ASPECTO_A_CORREGIR, :ACCION, :MOTIVO, :OBSERVACIONES, :NUMERO_MANUAL, :TIPO_COMPETENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="ID_COMPETENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param defaultValue="" name="ASPECTO_A_CORREGIR" sqlType="STRING"/>
		<param defaultValue="" name="ACCION" sqlType="STRING"/>
		<param defaultValue="" name="MOTIVO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evaccionesmejor">
		<call-query href="insertEvaccionesmejor">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_EVALUACION" query-param="NUMERO_EVALUACION"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="SUCURSAL_EVALUADOR" query-param="SUCURSAL_EVALUADOR"/>
			<with-param name="ID_COMPETENCIA" query-param="ID_COMPETENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ASPECTO_A_CORREGIR" query-param="ASPECTO_A_CORREGIR"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="MOTIVO" query-param="MOTIVO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="TIPO_COMPETENCIA" query-param="TIPO_COMPETENCIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEvaccionesmejor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_ACCIONES_MEJORA WHERE EV_ACCIONES_MEJORA.COMPANIA= :KEY_COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_ACCIONES_MEJORA.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_ACCIONES_MEJORA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="evaccionesmejor">
		<call-query href="deleteEvaccionesmejor">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEvaccionesmejorPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT EV_ACCIONES_MEJORA.COMPANIA, EV_ACCIONES_MEJORA.CONSECUTIVO, EV_ACCIONES_MEJORA.NUMERO_MANUAL, EV_ACCIONES_MEJORA.NUMERO_EVALUACION, EV_ACCIONES_MEJORA.CLASE_EVALUACION, EV_CLASE_EVALUACION.NOMBRE NOMBRE_CLASE, EV_TIPO_DE_EVALUACION.NOMBRE NOMBRE_TIPO, EV_ACCIONES_MEJORA.TIPO_EVALUACION, EV_ACCIONES_MEJORA.CEDULA_EVALUADO, EV_ACCIONES_MEJORA.CEDULA_EVALUADOR, EV_ACCIONES_MEJORA.ID_COMPETENCIA, TO_CHAR(CONCAT( SUBSTR(EV_COMPETENCIAS.DESCRIPCION,1,25), '...')) DESCRIPCION, EV_ACCIONES_MEJORA.OBSERVACIONES FROM EV_ACCIONES_MEJORA INNER JOIN EV_TIPO_DE_EVALUACION ON EV_ACCIONES_MEJORA.COMPANIA = EV_TIPO_DE_EVALUACION.COMPANIA AND EV_ACCIONES_MEJORA.TIPO_EVALUACION = EV_TIPO_DE_EVALUACION.CODIGO AND EV_ACCIONES_MEJORA.CLASE_EVALUACION = EV_TIPO_DE_EVALUACION.CLASE_EVALUACION INNER JOIN EV_CLASE_EVALUACION ON EV_ACCIONES_MEJORA.CLASE_EVALUACION = EV_CLASE_EVALUACION.CODIGO INNER JOIN EV_COMPETENCIAS ON EV_ACCIONES_MEJORA.COMPANIA = EV_COMPETENCIAS.COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_MANUAL = EV_COMPETENCIAS.NUMERO_MANUAL AND EV_ACCIONES_MEJORA.VERSION = EV_COMPETENCIAS.VERSION AND EV_ACCIONES_MEJORA.TIPO_COMPETENCIA = EV_COMPETENCIAS.TIPO_COMPETENCIA AND EV_ACCIONES_MEJORA.ID_COMPETENCIA = EV_COMPETENCIAS.CONSECUTIVO WHERE EV_ACCIONES_MEJORA.COMPANIA =:COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_EVALUACION =:NUMEROEVALUACION AND EV_ACCIONES_MEJORA.CLASE_EVALUACION =:CLASEEVALUACION AND EV_ACCIONES_MEJORA.TIPO_EVALUACION =:TIPOEVALUACION AND EV_ACCIONES_MEJORA.CEDULA_EVALUADO =:CEDULAEVALUADO AND EV_ACCIONES_MEJORA.SUCURSAL_EVALUADO =:SUCURSALEVALUADO AND EV_ACCIONES_MEJORA.CEDULA_EVALUADOR =:CEDULAEVALUADOR AND EV_ACCIONES_MEJORA.SUCURSAL_EVALUADOR =:SUCURSALEVALUADOR) INI WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END) LIKE UPPER(CONCAT(:NUMERO_MANUAL, '%')) AND (CASE WHEN NUMERO_EVALUACION IS NULL THEN ' ' ELSE UPPER(NUMERO_EVALUACION) END) LIKE UPPER(CONCAT(:NUMERO_EVALUACION, '%')) AND (CASE WHEN NOMBRE_CLASE IS NULL THEN ' ' ELSE UPPER(NOMBRE_CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CLASE), '%')) AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPO), '%')) AND (CASE WHEN CEDULA_EVALUADO IS NULL THEN ' ' ELSE UPPER(CEDULA_EVALUADO) END) LIKE UPPER(CONCAT(:CEDULA_EVALUADO, '%')) AND (CASE WHEN CEDULA_EVALUADOR IS NULL THEN ' ' ELSE UPPER(CEDULA_EVALUADOR) END) LIKE UPPER(CONCAT(:CEDULA_EVALUADOR, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","NUMERO_MANUAL":"$NUMERO_MANUAL","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","NOMBRE_CLASE":"$NOMBRE_CLASE","NOMBRE_TIPO":"$NOMBRE_TIPO","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","ID_COMPETENCIA":"$ID_COMPETENCIA(type:long)","DESCRIPCION":"$DESCRIPCION","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROEVALUACION" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="TIPOEVALUACION" sqlType="STRING"/>
		<param name="CEDULAEVALUADO" sqlType="STRING"/>
		<param name="SUCURSALEVALUADO" sqlType="STRING"/>
		<param name="CEDULAEVALUADOR" sqlType="STRING"/>
		<param name="SUCURSALEVALUADOR" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="NOMBRE_CLASE" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evaccionesmejor">
		<call-query href="getEvaccionesmejorPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROEVALUACION" query-param="NUMEROEVALUACION"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="TIPOEVALUACION" query-param="TIPOEVALUACION"/>
			<with-param name="CEDULAEVALUADO" query-param="CEDULAEVALUADO"/>
			<with-param name="SUCURSALEVALUADO" query-param="SUCURSALEVALUADO"/>
			<with-param name="CEDULAEVALUADOR" query-param="CEDULAEVALUADOR"/>
			<with-param name="SUCURSALEVALUADOR" query-param="SUCURSALEVALUADOR"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="NUMERO_EVALUACION" query-param="NUMERO_EVALUACION"/>
			<with-param name="NOMBRE_CLASE" query-param="NOMBRE_CLASE"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvaccionesmejorNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT EV_ACCIONES_MEJORA.COMPANIA, EV_ACCIONES_MEJORA.CONSECUTIVO, EV_ACCIONES_MEJORA.NUMERO_MANUAL, EV_ACCIONES_MEJORA.NUMERO_EVALUACION, EV_ACCIONES_MEJORA.CLASE_EVALUACION, EV_CLASE_EVALUACION.NOMBRE NOMBRE_CLASE, EV_TIPO_DE_EVALUACION.NOMBRE NOMBRE_TIPO, EV_ACCIONES_MEJORA.TIPO_EVALUACION, EV_ACCIONES_MEJORA.CEDULA_EVALUADO, EV_ACCIONES_MEJORA.CEDULA_EVALUADOR, EV_ACCIONES_MEJORA.ID_COMPETENCIA, TO_CHAR(CONCAT( SUBSTR(EV_COMPETENCIAS.DESCRIPCION,1,25), '...')) DESCRIPCION, EV_ACCIONES_MEJORA.OBSERVACIONES FROM EV_ACCIONES_MEJORA INNER JOIN EV_TIPO_DE_EVALUACION ON EV_ACCIONES_MEJORA.COMPANIA = EV_TIPO_DE_EVALUACION.COMPANIA AND EV_ACCIONES_MEJORA.TIPO_EVALUACION = EV_TIPO_DE_EVALUACION.CODIGO AND EV_ACCIONES_MEJORA.CLASE_EVALUACION = EV_TIPO_DE_EVALUACION.CLASE_EVALUACION INNER JOIN EV_CLASE_EVALUACION ON EV_ACCIONES_MEJORA.CLASE_EVALUACION = EV_CLASE_EVALUACION.CODIGO INNER JOIN EV_COMPETENCIAS ON EV_ACCIONES_MEJORA.COMPANIA = EV_COMPETENCIAS.COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_MANUAL = EV_COMPETENCIAS.NUMERO_MANUAL AND EV_ACCIONES_MEJORA.VERSION = EV_COMPETENCIAS.VERSION AND EV_ACCIONES_MEJORA.TIPO_COMPETENCIA = EV_COMPETENCIAS.TIPO_COMPETENCIA AND EV_ACCIONES_MEJORA.ID_COMPETENCIA = EV_COMPETENCIAS.CONSECUTIVO WHERE EV_ACCIONES_MEJORA.COMPANIA =:COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_EVALUACION =:NUMEROEVALUACION AND EV_ACCIONES_MEJORA.CLASE_EVALUACION =:CLASEEVALUACION AND EV_ACCIONES_MEJORA.TIPO_EVALUACION =:TIPOEVALUACION AND EV_ACCIONES_MEJORA.CEDULA_EVALUADO =:CEDULAEVALUADO AND EV_ACCIONES_MEJORA.SUCURSAL_EVALUADO =:SUCURSALEVALUADO AND EV_ACCIONES_MEJORA.CEDULA_EVALUADOR =:CEDULAEVALUADOR AND EV_ACCIONES_MEJORA.SUCURSAL_EVALUADOR =:SUCURSALEVALUADOR) INI WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END) LIKE UPPER(CONCAT(:NUMERO_MANUAL, '%')) AND (CASE WHEN NUMERO_EVALUACION IS NULL THEN ' ' ELSE UPPER(NUMERO_EVALUACION) END) LIKE UPPER(CONCAT(:NUMERO_EVALUACION, '%')) AND (CASE WHEN NOMBRE_CLASE IS NULL THEN ' ' ELSE UPPER(NOMBRE_CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CLASE), '%')) AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPO), '%')) AND (CASE WHEN CEDULA_EVALUADO IS NULL THEN ' ' ELSE UPPER(CEDULA_EVALUADO) END) LIKE UPPER(CONCAT(:CEDULA_EVALUADO, '%')) AND (CASE WHEN CEDULA_EVALUADOR IS NULL THEN ' ' ELSE UPPER(CEDULA_EVALUADOR) END) LIKE UPPER(CONCAT(:CEDULA_EVALUADOR, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROEVALUACION" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="TIPOEVALUACION" sqlType="STRING"/>
		<param name="CEDULAEVALUADO" sqlType="STRING"/>
		<param name="SUCURSALEVALUADO" sqlType="STRING"/>
		<param name="CEDULAEVALUADOR" sqlType="STRING"/>
		<param name="SUCURSALEVALUADOR" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="NOMBRE_CLASE" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evaccionesmejor/numero">
		<call-query href="getEvaccionesmejorNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROEVALUACION" query-param="NUMEROEVALUACION"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="TIPOEVALUACION" query-param="TIPOEVALUACION"/>
			<with-param name="CEDULAEVALUADO" query-param="CEDULAEVALUADO"/>
			<with-param name="SUCURSALEVALUADO" query-param="SUCURSALEVALUADO"/>
			<with-param name="CEDULAEVALUADOR" query-param="CEDULAEVALUADOR"/>
