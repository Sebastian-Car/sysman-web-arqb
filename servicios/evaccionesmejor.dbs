	</resource>
	<query id="getEvaccionesmejorRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT EV_ACCIONES_MEJORA.COMPANIA, EV_ACCIONES_MEJORA.NUMERO_EVALUACION, EV_ACCIONES_MEJORA.CLASE_EVALUACION, EV_ACCIONES_MEJORA.TIPO_EVALUACION, EV_ACCIONES_MEJORA.CEDULA_EVALUADO, EV_ACCIONES_MEJORA.SUCURSAL_EVALUADO, EV_ACCIONES_MEJORA.CEDULA_EVALUADOR, EV_ACCIONES_MEJORA.SUCURSAL_EVALUADOR, EV_ACCIONES_MEJORA.ID_COMPETENCIA, EV_ACCIONES_MEJORA.CONSECUTIVO, EV_ACCIONES_MEJORA.VERSION, EV_ACCIONES_MEJORA.COMPONENTE, EV_ACCIONES_MEJORA.ASPECTO_A_CORREGIR, EV_ACCIONES_MEJORA.ACCION, EV_ACCIONES_MEJORA.MOTIVO, EV_ACCIONES_MEJORA.OBSERVACIONES, EV_ACCIONES_MEJORA.NUMERO_MANUAL, EV_ACCIONES_MEJORA.TIPO_COMPETENCIA, EV_ACCIONES_MEJORA.CREATED_BY,(TO_CHAR(EV_ACCIONES_MEJORA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, EV_ACCIONES_MEJORA.MODIFIED_BY,(TO_CHAR(EV_ACCIONES_MEJORA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CONCAT(TO_CHAR(SUBSTR(EV_COMPETENCIAS.DESCRIPCION,0,100) ), '...') DESCRIPCION FROM EV_ACCIONES_MEJORA INNER JOIN EV_COMPETENCIAS ON EV_ACCIONES_MEJORA.COMPANIA = EV_COMPETENCIAS.COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_MANUAL = EV_COMPETENCIAS.NUMERO_MANUAL AND EV_ACCIONES_MEJORA.VERSION = EV_COMPETENCIAS.VERSION AND EV_ACCIONES_MEJORA.TIPO_COMPETENCIA = EV_COMPETENCIAS.TIPO_COMPETENCIA AND EV_ACCIONES_MEJORA.ID_COMPETENCIA = EV_COMPETENCIAS.CONSECUTIVO WHERE EV_ACCIONES_MEJORA.COMPANIA= :KEY_COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_ACCIONES_MEJORA.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_ACCIONES_MEJORA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR","ID_COMPETENCIA":"$ID_COMPETENCIA(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:long)","VERSION":"$VERSION","COMPONENTE":"$COMPONENTE","ASPECTO_A_CORREGIR":"$ASPECTO_A_CORREGIR","ACCION":"$ACCION","MOTIVO":"$MOTIVO","OBSERVACIONES":"$OBSERVACIONES","NUMERO_MANUAL":"$NUMERO_MANUAL","TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evaccionesmejor/data">
		<call-query href="getEvaccionesmejorRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateEvaccionesmejor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_ACCIONES_MEJORA SET TIPO_EVALUACION=:TIPO_EVALUACION, CEDULA_EVALUADO=:CEDULA_EVALUADO, SUCURSAL_EVALUADO=:SUCURSAL_EVALUADO, CEDULA_EVALUADOR=:CEDULA_EVALUADOR, SUCURSAL_EVALUADOR=:SUCURSAL_EVALUADOR, ID_COMPETENCIA=:ID_COMPETENCIA, VERSION=:VERSION, COMPONENTE=:COMPONENTE, ASPECTO_A_CORREGIR=:ASPECTO_A_CORREGIR, ACCION=:ACCION, MOTIVO=:MOTIVO, OBSERVACIONES=:OBSERVACIONES, NUMERO_MANUAL=:NUMERO_MANUAL, TIPO_COMPETENCIA=:TIPO_COMPETENCIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_ACCIONES_MEJORA.COMPANIA= :KEY_COMPANIA AND EV_ACCIONES_MEJORA.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_ACCIONES_MEJORA.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_ACCIONES_MEJORA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="ID_COMPETENCIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ASPECTO_A_CORREGIR" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="MOTIVO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evaccionesmejor">
		<call-query href="updateEvaccionesmejor">
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="SUCURSAL_EVALUADOR" query-param="SUCURSAL_EVALUADOR"/>
			<with-param name="ID_COMPETENCIA" query-param="ID_COMPETENCIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ASPECTO_A_CORREGIR" query-param="ASPECTO_A_CORREGIR"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="MOTIVO" query-param="MOTIVO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="TIPO_COMPETENCIA" query-param="TIPO_COMPETENCIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
