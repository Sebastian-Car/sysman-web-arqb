	</resource>
	<query id="updateParametrosActualizarvalor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PARAMETRO SET VALOR = :VALOR,             MODIFIED_BY=:MODIFIED_BY,                         DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPANIA = :KEY_COMPANIA  AND NOMBRE = :KEY_NOMBRE AND FECHA_INICIAL = :KEY_FECHA_INICIAL AND MODULO = :KEY_MODULO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NOMBRE" sqlType="STRING"/>
		<param name="KEY_FECHA_INICIAL" sqlType="STRING"/>
		<param name="KEY_MODULO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="parametros/actualizarvalor">
		<call-query href="updateParametrosActualizarvalor">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NOMBRE" query-param="KEY_NOMBRE"/>
			<with-param name="KEY_FECHA_INICIAL" query-param="KEY_FECHA_INICIAL"/>
			<with-param name="KEY_MODULO" query-param="KEY_MODULO"/>

		</call-query>
	</resource>
	<query id="getParametrosPagListadoParamNominaCtaPublicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  P.COMPANIA, P.NOMBRE, P.VALOR, P.DESCRIPCION,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL, P.MODULO, AP.NOMBRE NOMAPLICACION, P.TIPOPARAMETRO, TP.NOMBRE NOMPARAMETRO, TO_CHAR(P.DATE_CREATED,'DD/MM/YYYY') DATE_CREATED  FROM PARAMETRO P INNER JOIN TIPOPARAMETRO TP ON P.TIPOPARAMETRO = TP.CODIGO INNER JOIN APLICACIONES AP ON P.MODULO = AP.APLICACION WHERE P.COMPANIA = :COMPANIA AND P.NOMBRE LIKE 'CTA_%' AND P.NOMBRE LIKE '%PUBLICA%' AND P.MODULO = 6 ORDER BY P.COMPANIA, P.NOMBRE) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER( '%' || :FECHA_INICIAL || '%')  AND (CASE WHEN NOMAPLICACION IS NULL THEN ' ' ELSE UPPER(NOMAPLICACION) END)  LIKE UPPER( '%' || :NOMAPLICACION || '%')  AND (CASE WHEN NOMPARAMETRO IS NULL THEN ' ' ELSE UPPER(NOMPARAMETRO) END)  LIKE UPPER( '%' || :NOMPARAMETRO || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NOMBRE":"$NOMBRE","VALOR":"$VALOR","DESCRIPCION":"$DESCRIPCION","FECHA_INICIAL":"$FECHA_INICIAL","MODULO":"$MODULO(type:integer)","NOMAPLICACION":"$NOMAPLICACION","TIPOPARAMETRO":"$TIPOPARAMETRO","NOMPARAMETRO":"$NOMPARAMETRO","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="NOMAPLICACION" sqlType="STRING"/>
		<param name="NOMPARAMETRO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="parametros/listadoparamnominactapublica/pag">
		<call-query href="getParametrosPagListadoParamNominaCtaPublicaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="NOMAPLICACION" query-param="NOMAPLICACION"/>
			<with-param name="NOMPARAMETRO" query-param="NOMPARAMETRO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getParametrosNumListadoParamNominaCtaPublicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  P.COMPANIA, P.NOMBRE, P.VALOR, P.DESCRIPCION,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL, P.MODULO, AP.NOMBRE NOMAPLICACION, P.TIPOPARAMETRO, TP.NOMBRE NOMPARAMETRO, TO_CHAR(P.DATE_CREATED,'DD/MM/YYYY') DATE_CREATED  FROM PARAMETRO P INNER JOIN TIPOPARAMETRO TP ON P.TIPOPARAMETRO = TP.CODIGO INNER JOIN APLICACIONES AP ON P.MODULO = AP.APLICACION WHERE P.COMPANIA = :COMPANIA AND P.NOMBRE LIKE 'CTA_%' AND P.NOMBRE LIKE '%PUBLICA%' AND P.MODULO = 6 ORDER BY P.COMPANIA, P.NOMBRE) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER( '%' || :FECHA_INICIAL || '%')  AND (CASE WHEN NOMAPLICACION IS NULL THEN ' ' ELSE UPPER(NOMAPLICACION) END)  LIKE UPPER( '%' || :NOMAPLICACION || '%')  AND (CASE WHEN NOMPARAMETRO IS NULL THEN ' ' ELSE UPPER(NOMPARAMETRO) END)  LIKE UPPER( '%' || :NOMPARAMETRO || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="NOMAPLICACION" sqlType="STRING"/>
		<param name="NOMPARAMETRO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="GET" path="parametros/listadoparamnominactapublica/num">
		<call-query href="getParametrosNumListadoParamNominaCtaPublicaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="NOMAPLICACION" query-param="NOMAPLICACION"/>
			<with-param name="NOMPARAMETRO" query-param="NOMPARAMETRO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>

</data>