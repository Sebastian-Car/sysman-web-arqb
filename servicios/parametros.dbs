	<query id="updateParametros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PARAMETRO SET VALOR=:VALOR, FECHA_INICIAL=TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), TIPOPARAMETRO=:TIPOPARAMETRO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PARAMETRO.COMPANIA= :KEY_COMPANIA AND PARAMETRO.NOMBRE= :KEY_NOMBRE AND PARAMETRO.FECHA_INICIAL= TO_DATE(:KEY_FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')  AND PARAMETRO.MODULO= :KEY_MODULO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="TIPOPARAMETRO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NOMBRE" sqlType="STRING"/>
		<param name="KEY_FECHA_INICIAL" sqlType="STRING"/>
		<param name="KEY_MODULO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="parametros">
		<call-query href="updateParametros">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="TIPOPARAMETRO" query-param="TIPOPARAMETRO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NOMBRE" query-param="KEY_NOMBRE"/>
			<with-param name="KEY_FECHA_INICIAL" query-param="KEY_FECHA_INICIAL"/>
			<with-param name="KEY_MODULO" query-param="KEY_MODULO"/>

		</call-query>
	</resource>
	<query id="getParametrosNumListcertdianQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  P.NOMBRE NOMBRE, P.VALOR, P.DESCRIPCION, P.MODULO,(TO_CHAR(P.FECHACREACION,'DD/MM/YYYY HH24:MI:SS')) FECHACREACION,(TO_CHAR(P.FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL, P.COMPANIA, P.TIPOPARAMETRO, T.NOMBRE NOMPARAMETRO  FROM PARAMETRO P INNER JOIN TIPOPARAMETRO T ON P.TIPOPARAMETRO = T.CODIGO WHERE COMPANIA = :COMPANIA AND MODULO = :MODULO AND P.NOMBRE IN ('VALOR PORCENTAJE APLICAR PROCESO RETEFUENTE','CEDULA DE QUIEN FIRMA CERTIFICADO DIAN', 'FORMATO CERTIFICADO DIAN', 'FORMATO CERTIFICADO DIAN EMAIL', 'FORMATO CERTIFICADOS DIAN PENSIONADOS', 'NOMBRE DE QUIEN FIRMA CERTIFICADO DIAN', 'VALOR CONSIG BANCARIAS PARA CERTIFICADO UVT', 'VALOR CONSIGNACIONES BANCARIAS PARA CERTIFICADO', 'VALOR CONSUMOS CON TARJETAS PARA CERTIFICADO', 'VALOR CONSUMS CON TARJ PARA CERTIFICADO UVT', 'VALOR CONSUMS CON TARJ PARA CERTIFICADO UVT', 'VALOR INGRESOS PATRIMONIOS PARA CERTIFICADO', 'VALOR INGRESOS SUPERIORES PARA CERTIFICADO', 'VALOR INGRESS SUPERIORES PARA CERTIFICADO UVT', 'VALOR TOTAL COMPRAS Y CON PARA CERTIFICADO UVT', 'VALOR TOTAL COMPRAS Y CONSUMOS PARA CERTIFICADO', 'VALOR UVT ACTUAL', 'VALOR UVT AÑO ANTERIOR') ORDER BY NOMBRE, FECHA_INICIAL) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHACREACION IS NULL THEN ' ' ELSE UPPER(FECHACREACION) END)  LIKE UPPER( '%' || :FECHACREACION || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER( '%' || :FECHA_INICIAL || '%')  AND (CASE WHEN NOMPARAMETRO IS NULL THEN ' ' ELSE UPPER(NOMPARAMETRO) END)  LIKE UPPER( '%' || :NOMPARAMETRO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHACREACION" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="NOMPARAMETRO" sqlType="STRING"/>

	</query>
