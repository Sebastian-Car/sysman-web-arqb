	<query id="getParametrosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  P.COMPANIA, P.NOMBRE, P.VALOR, P.DESCRIPCION,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL, P.MODULO, AP.NOMBRE NOMAPLICACION, P.TIPOPARAMETRO, TP.NOMBRE NOMPARAMETRO, TO_CHAR(P.DATE_CREATED,'DD/MM/YYYY') DATE_CREATED  FROM PARAMETRO P INNER JOIN TIPOPARAMETRO TP ON P.TIPOPARAMETRO = TP.CODIGO INNER JOIN APLICACIONES AP ON P.MODULO = AP.APLICACION WHERE COMPANIA =:COMPANIA ORDER BY COMPANIA, NOMBRE) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER( '%' || :FECHA_INICIAL || '%')  AND (CASE WHEN NOMAPLICACION IS NULL THEN ' ' ELSE UPPER(NOMAPLICACION) END)  LIKE UPPER( '%' || :NOMAPLICACION || '%')  AND (CASE WHEN NOMPARAMETRO IS NULL THEN ' ' ELSE UPPER(NOMPARAMETRO) END)  LIKE UPPER( '%' || :NOMPARAMETRO || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="NOMAPLICACION" sqlType="STRING"/>
		<param name="NOMPARAMETRO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
