	<query id="getParametrosPagParametrosliquidacionviaticosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PARAMETRO.COMPANIA, PARAMETRO.NOMBRE, PARAMETRO.VALOR  FROM PARAMETRO WHERE PARAMETRO.COMPANIA = :COMPANIA AND PARAMETRO.NOMBRE IN ('NUMERO SALARIOS MINIMOS DIARIOS VIGENTES', 'PORCENTAJE ULTIMO DIA PERNOCTANDO', 'PORCENTAJE SIN PERNOCTAR', 'PORCENTAJE SIN PERNOCTAR INTERIOR EXTERIOR')) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NOMBRE":"$NOMBRE","VALOR":"$VALOR"}]}}		</result>
