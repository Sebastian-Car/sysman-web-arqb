	<query id="updateDetallescomprobantepptalAuxiliarPorCompaniaNumeroTipoComprobante" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_PPTAL SET AUXILIAR = :AUXILIAR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :STRTIPOCOMPROBANTE AND COMPROBANTE = :NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallescomprobantepptal/auxiliarporcompanianumerotipocomprobante">
		<call-query href="updateDetallescomprobantepptalAuxiliarPorCompaniaNumeroTipoComprobante">
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="STRTIPOCOMPROBANTE" query-param="STRTIPOCOMPROBANTE"/>
