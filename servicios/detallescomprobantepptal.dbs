	</resource>
	<query id="getDetallescomprobantepptalConcomprobante_pptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.ANO , DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, PLAN_PRESUPUESTAL.NATURALEZA NAT, ROUND( CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA='D' THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO -DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO)-(DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO)+(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO) ELSE (DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO-DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO)-(DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO)+(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO) END ,2) NETO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TERCERO, DETALLE_COMPROBANTE_PPTAL.SUCURSAL, DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, DETALLE_COMPROBANTE_PPTAL.AUXILIAR, DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO, DETALLE_COMPROBANTE_PPTAL.REFERENCIA FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COMPROBANTE_PPTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = COMPROBANTE_PPTAL.TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = COMPROBANTE_PPTAL.NUMERO INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = PLAN_PRESUPUESTAL.CODIGO WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA =:COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE =:TIPO AND (COMPROBANTE_PPTAL.FECHA_VCN_DOC &lt;= TO_DATE(:FECHACORTE, 'DD/MM/YYYY HH24:MI:SS') OR DETALLE_COMPROBANTE_PPTAL.FECHA &lt;= TO_DATE(:FECHACORTE, 'DD/MM/YYYY HH24:MI:SS')) AND EXTRACT (YEAR FROM COMPROBANTE_PPTAL.FECHA) = :ANOFECHACORTE AND ROUND( CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA= 'D' THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO -DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO)-(DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO)+(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO) ELSE (DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO-DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO)-(DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO)+(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO) END ,2)&gt;0 ORDER BY DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","NAT":"$NAT","NETO":"$NETO","CUENTA":"$CUENTA","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","FUENTE_RECURSO":"$FUENTE_RECURSO","REFERENCIA":"$REFERENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="ANOFECHACORTE" sqlType="STRING"/>

	</query>
