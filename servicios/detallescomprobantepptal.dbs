	<query id="getDetallescomprobantepptalPagTodosPorTipocpteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.DESCRIPCION, DETALLE_COMPROBANTE_PPTAL.ANO,(VALOR_DEBITO-VALOR_CREDITO)-(DEBITO_AFECTADO-CREDITO_AFECTADO)+(MODIFICACION_DEBITO-MODIFICACION_CREDITO) VALORPPTO, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO FROM DETALLE_COMPROBANTE_PPTAL WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = :NUMPPTO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = :TIPOCPTE ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN VALORPPTO IS NULL THEN ' ' ELSE UPPER(VALORPPTO) END) LIKE UPPER(CONCAT(:VALORPPTO, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","DESCRIPCION":"$DESCRIPCION","ANO":"$ANO(type:integer)","VALORPPTO":"$VALORPPTO(type:double)","CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMPPTO" sqlType="STRING"/>
		<param name="TIPOCPTE" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="VALORPPTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/todosportipocpte/pag">
		<call-query href="getDetallescomprobantepptalPagTodosPorTipocpteQuery">
