	<query id="getDetallescomprobantepptalNumListacomprobantesafectarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT D.CONSECUTIVO, D.COMPANIA, D.ANO, D.TIPO_CPTE, D.COMPROBANTE,(TO_CHAR(D.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, D.DESCRIPCION, D.CUENTA, D.REFERENCIA, D.CENTRO_COSTO, D.FUENTE_RECURSO, D.AUXILIAR, TO_CHAR(D.VALOR_DEBITO, '999,999,999,999,999,999.99') VALOR_DEBITO, TO_CHAR(( D.VALOR_DEBITO - ( D.DEBITO_AFECTADO - D.CREDITO_AFECTADO ) + ( D.MODIFICACION_DEBITO - D.MODIFICACION_CREDITO ) ),'999,999,999,999,999,999.99') SALDO, TO_CHAR(( D.VALOR_DEBITO - ( D.DEBITO_AFECTADO - D.CREDITO_AFECTADO ) + ( D.MODIFICACION_DEBITO - D.MODIFICACION_CREDITO ) ),'999,999,999,999,999,999.99') VALOR_A_PAGAR FROM DETALLE_COMPROBANTE_PPTAL D LEFT JOIN TIPO_COMPROBPP T ON D.COMPANIA = T.COMPANIA AND D.TIPO_CPTE = T.CODIGO WHERE D.COMPANIA = :COMPANIA AND D.TERCERO = :TERCERO AND D.FECHA &lt;= :FECHAINI AND T.CLASE = 'RES' AND D.ANO = :ANO AND ( D.VALOR_DEBITO - ( D.DEBITO_AFECTADO - D.CREDITO_AFECTADO ) + ( D.MODIFICACION_DEBITO - D.MODIFICACION_CREDITO ) )&gt;0 ORDER BY COMPROBANTE, CONSECUTIVO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(:TIPO_CPTE, '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(:VALOR_DEBITO, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN VALOR_A_PAGAR IS NULL THEN ' ' ELSE UPPER(VALOR_A_PAGAR) END) LIKE UPPER(CONCAT(:VALOR_A_PAGAR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
