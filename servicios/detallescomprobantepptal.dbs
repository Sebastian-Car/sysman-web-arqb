	<query id="getDetallescomprobantepptalPagDetallesportiponumeroconvalordocfechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT D.COMPROBANTE, D.DESCRIPCION, C.VLR_DOCUMENTO VALOR,(TO_CHAR(C.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM DETALLE_COMPROBANTE_PPTAL D INNER JOIN COMPROBANTE_PPTAL C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPO_CPTE = C.TIPO AND D.COMPROBANTE = C.NUMERO WHERE D.COMPANIA = :COMPANIA AND D.TIPO_CPTE = :TIPO) INI WHERE (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
