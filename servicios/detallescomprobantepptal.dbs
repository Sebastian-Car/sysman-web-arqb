	<query id="updateDetallescomprobantepptalActualizarfecha" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_PPTAL SET FECHA = TO_DATE(:FECHA, 'DD/MM/YYYY') ,MODIFIED_BY = :MODIFIED_BY ,DATE_MODIFIED = TO_DATE(:DATE_MODIFIED, 'DD/MM/YYYY') WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPO AND COMPROBANTE = :COMPROBANTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallescomprobantepptal/actualizarfecha">
		<call-query href="updateDetallescomprobantepptalActualizarfecha">
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>

		</call-query>
	</resource>

	<query id="getDetallescomprobantepptalPagPorDescripcionUnicaQuery"  useConfig="sysmandsunist">
			<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT D.COMPROBANTE, MIN(D.DESCRIPCION) OVER(PARTITION BY D.COMPROBANTE ORDER BY D.COMPROBANTE) DESCRIPCION, C.VLR_DOCUMENTO VALOR,(TO_CHAR(C.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM DETALLE_COMPROBANTE_PPTAL D INNER JOIN COMPROBANTE_PPTAL C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPO_CPTE = C.TIPO AND D.COMPROBANTE = C.NUMERO WHERE D.COMPANIA = :COMPANIA AND D.TIPO_CPTE = :TIPO AND D.ANO = :ANO ORDER BY D.COMPROBANTE) INI WHERE (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
			<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE(type:long)","DESCRIPCION":"$DESCRIPCION","VALOR":"$VALOR","FECHA":"$FECHA"}]}}		</result>
			<param name="COMPANIA" sqlType="STRING"/>
			<param name="TIPO" sqlType="STRING"/>
			<param name="ANO" sqlType="STRING"/>
			<param name="COMPROBANTE" sqlType="STRING"/>
			<param name="DESCRIPCION" sqlType="STRING"/>
			<param name="VALOR" sqlType="STRING"/>
			<param name="PAGINICIO" sqlType="INTEGER"/>
			<param name="PAGTAMANIO" sqlType="INTEGER"/>

		</query>
