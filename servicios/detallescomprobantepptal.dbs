	<query id="getDetallescomprobantepptalPagTodosPorTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D.COMPANIA, D.ANO, D.CONSECUTIVO, D.TIPO_CPTE, D.COMPROBANTE, TO_CHAR(D.FECHA, 'DD/MM/YYYY') FECHA, D.VALOR_DEBITO, D.VALOR_CREDITO, D.DESCRIPCION, D.CUENTA, D.TERCERO ID_TERCERO, D.SUCURSAL, T.NOMBRE NOMBRE_TERCERO, D.CENTRO_COSTO, C.NOMBRE NOMBRECENTROCOSTO, D.AUXILIAR, A.NOMBRE NOMBRE_AUXILIAR, D.FUENTE_RECURSO, F.NOMBRE NOMBRE_FTERECURSO, D.REFERENCIA, R.NOMBRE NOMBRE_REFERENCIA FROM DETALLE_COMPROBANTE_PPTAL D INNER JOIN TERCERO T ON D.COMPANIA = T.COMPANIA AND D.TERCERO = T.NIT AND D.SUCURSAL = T.SUCURSAL INNER JOIN AUXILIAR A ON D.COMPANIA = A.COMPANIA AND D.ANO = A.ANO AND D.AUXILIAR = A.CODIGO INNER JOIN FUENTE_RECURSOS F ON D.COMPANIA = F.COMPANIA AND D.ANO = F.ANO AND D.FUENTE_RECURSO = F.CODIGO INNER JOIN REFERENCIA R ON D.COMPANIA = R.COMPANIA AND D.ANO = R.ANO AND D.REFERENCIA = R.CODIGO INNER JOIN CENTRO_COSTO C ON D.COMPANIA = C.COMPANIA AND D.CENTRO_COSTO = C.CODIGO AND D.ANO = C.ANO WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANOQR AND D.MES BETWEEN :MESINICIALQR AND :MESFINALQR AND D.TERCERO = :TERCERO AND D.SUCURSAL = :SUCURSALTERCERO ORDER BY D.FECHA, D.TIPO_CPTE, D.COMPROBANTE) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(:TIPO_CPTE, '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA), '%')) AND (CASE WHEN ID_TERCERO IS NULL THEN ' ' ELSE UPPER(ID_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN NOMBRECENTROCOSTO IS NULL THEN ' ' ELSE UPPER(NOMBRECENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECENTROCOSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN NOMBRE_AUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUXILIAR), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN NOMBRE_FTERECURSO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FTERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FTERECURSO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN NOMBRE_REFERENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_REFERENCIA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","FECHA":"$FECHA","VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","DESCRIPCION":"$DESCRIPCION","CUENTA":"$CUENTA","ID_TERCERO":"$ID_TERCERO","SUCURSAL":"$SUCURSAL","NOMBRE_TERCERO":"$NOMBRE_TERCERO","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRECENTROCOSTO":"$NOMBRECENTROCOSTO","AUXILIAR":"$AUXILIAR","NOMBRE_AUXILIAR":"$NOMBRE_AUXILIAR","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBRE_FTERECURSO":"$NOMBRE_FTERECURSO","REFERENCIA":"$REFERENCIA","NOMBRE_REFERENCIA":"$NOMBRE_REFERENCIA"}]}}		</result>
