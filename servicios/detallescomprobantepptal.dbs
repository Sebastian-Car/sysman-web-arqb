	<query id="updateDetallescomprobantepptal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_PPTAL SET CUENTA=:CUENTA, DESCRIPCION=:DESCRIPCION, VALOR_DEBITO=:VALOR_DEBITO, VALOR_CREDITO=:VALOR_CREDITO, PROGRAMARPAC=:PROGRAMARPAC, TIPO_CPTE_AFECT=:TIPO_CPTE_AFECT, CMPTE_AFECTADO=:CMPTE_AFECTADO, CONSECUTIVOPPTO=:CONSECUTIVOPPTO, TIPO_DOCUMENTO=:TIPO_DOCUMENTO, NRO_DOCUMENTO=:NRO_DOCUMENTO, CENTRO_COSTO=:CENTRO_COSTO, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, FUENTE_RECURSO=:FUENTE_RECURSO, AUXILIAR=:AUXILIAR, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), REFERENCIA=:REFERENCIA, PAPELES=:PAPELES, CONTRACTUAL=:CONTRACTUAL, CONSITUACIONFONDOS=:CONSITUACIONFONDOS, PORCENTAJEDISTRIBUIDO=:PORCENTAJEDISTRIBUIDO, SALDO=:SALDO, CREDITO_AFECTADO=:CREDITO_AFECTADO, DEBITO_AFECTADO=:DEBITO_AFECTADO, MODIFICACION_CREDITO=:MODIFICACION_CREDITO, MODIFICACION_DEBITO=:MODIFICACION_DEBITO, DEBITO_AFECTADOCNT=:DEBITO_AFECTADOCNT, CREDITO_AFECTADOCNT=:CREDITO_AFECTADOCNT, VALORCOMPROMISO=:VALORCOMPROMISO, DISPONIBILIDADNETA=:DISPONIBILIDADNETA, DISACUMULADAS=:DISACUMULADAS, RESACUMULADAS=:RESACUMULADAS, APRDEFINITIVA=:APRDEFINITIVA, TIPOCONTRATO=:TIPOCONTRATO, NUMEROCONTRATO=:NUMEROCONTRATO, PAC_DISPONIBLE=:PAC_DISPONIBLE, NATURALEZA=:NATURALEZA, CUENTA_DEBITO=:CUENTA_DEBITO, CUENTA_CREDITO=:CUENTA_CREDITO, CODIGO_CPC=:CODIGO_CPC, FUENTE_CUIPO=:FUENTE_CUIPO, COD_PROD_CUIPO=:COD_PROD_CUIPO, CODIGO_BPIN=:CODIGO_BPIN, CODIGO_CCPET=:CODIGO_CCPET, SECTOR=:SECTOR, PROGRAMA=:PROGRAMA, SUBPROGRAMA=:SUBPROGRAMA, CODIGOUNIDADEJE=:CODIGOUNIDADEJE, CODIGOCCPETREGA=:CODIGOCCPETREGA, POLITICA_PUBLICA=:POLITICA_PUBLICA, DETALLE_SECTORIAL=:DETALLE_SECTORIAL, RECURSO_SGR=:RECURSO_SGR, IMPUESTO=:IMPUESTO, VALOR_BASE=:VALOR_BASE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA= :KEY_COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO= :KEY_ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE= :KEY_TIPO_CPTE AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE= :KEY_COMPROBANTE AND DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
