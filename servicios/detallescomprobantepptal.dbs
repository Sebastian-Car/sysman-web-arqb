	<query id="getDetallescomprobantepptalExisteconcreditoydebitoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) CONTEO FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPO_CPTE AND COMPROBANTE = :COMPROBANTE AND (DEBITO_AFECTADO NOT IN (0) OR CREDITO_AFECTADO NOT IN (0) OR MODIFICACION_DEBITO NOT IN (0) OR MODIFICACION_CREDITO NOT IN (0))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
