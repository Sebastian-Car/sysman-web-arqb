) AND (CASE WHEN ID_TERCERO IS NULL THEN ' ' ELSE UPPER(ID_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN NOMBRECENTROCOSTO IS NULL THEN ' ' ELSE UPPER(NOMBRECENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECENTROCOSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN NOMBRE_AUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUXILIAR), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN NOMBRE_FTERECURSO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FTERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FTERECURSO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN NOMBRE_REFERENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_REFERENCIA), '%')) ) A) FIN</sql>
