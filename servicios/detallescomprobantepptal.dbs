	</resource>
	<query id="getDetallescomprobantepptalTotalescomprcausacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT D.COMPANIA, D.ANO, D.TERCERO, SUM(D.VALOR_DEBITO) SUMA_DEBITO, SUM(( D.VALOR_DEBITO - ( D.DEBITO_AFECTADO - D.CREDITO_AFECTADO ) + ( D.MODIFICACION_DEBITO - D.MODIFICACION_CREDITO ) )) SUMA_SALDO, SUM(( D.VALOR_DEBITO - ( D.DEBITO_AFECTADO - D.CREDITO_AFECTADO ) + ( D.MODIFICACION_DEBITO - D.MODIFICACION_CREDITO ) )) SUMA_PAGAR FROM DETALLE_COMPROBANTE_PPTAL D LEFT JOIN TIPO_COMPROBPP T ON D.COMPANIA = T.COMPANIA AND D.TIPO_CPTE = T.CODIGO WHERE D.COMPANIA = :COMPANIA AND D.TERCERO = :TERCERO AND D.ANO = :ANO AND D.FECHA &lt;= :FECHAINI AND T.CLASE = 'RES' AND ( D.VALOR_DEBITO - ( D.DEBITO_AFECTADO - D.CREDITO_AFECTADO ) + ( D.MODIFICACION_DEBITO - D.MODIFICACION_CREDITO ) ) &gt; 0 GROUP BY D.COMPANIA, D.ANO, D.TERCERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TERCERO":"$TERCERO","SUMA_DEBITO":"$SUMA_DEBITO","SUMA_SALDO":"$SUMA_SALDO","SUMA_PAGAR":"$SUMA_PAGAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/totalescomprcausacion">
		<call-query href="getDetallescomprobantepptalTotalescomprcausacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>

		</call-query>
	</resource>
		<query id="getDetallescomprobantepptalVerificaafectacionespptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT TIPO_CPTE, COMPROBANTE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND CMPTE_AFECTADO = :COMPROBANTE AND TIPO_CPTE_AFECT = :TIPO_CPTE AND CONSECUTIVOPPTO = :CONSECUTIVO AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/verificaafectacionespptal">
		<call-query href="getDetallescomprobantepptalVerificaafectacionespptalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>

</data>