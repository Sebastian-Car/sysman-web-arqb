	<query id="updateDetallescomprobantepptalUpdatedetallescomprobantepptalconfiguracioncuipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_PPTAL SET SECTOR=:SECTOR, PROGRAMA=:PROGRAMA, SUBPROGRAMA=:SUBPROGRAMA, COD_PROD_CUIPO=:COD_PROD_CUIPO, CODIGO_BPIN=:CODIGO_BPIN, CODIGO_CCPET=:CODIGO_CCPET, CODIGO_CPC=:CODIGO_CPC, CODIGOUNIDADEJE=:CODIGOUNIDADEJE, FUENTE_CUIPO=:FUENTE_CUIPO, CODIGOCCPETREGA=:CODIGOCCPETREGA, POLITICA_PUBLICA=:POLITICA_PUBLICA, DETALLE_SECTORIAL=:DETALLE_SECTORIAL, RECURSO_SGR=:RECURSO_SGR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA= :KEY_COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO= :KEY_ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE= :KEY_TIPO_CPTE AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE= :KEY_COMPROBANTE AND DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SECTOR" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="SUBPROGRAMA" sqlType="STRING"/>
		<param name="COD_PROD_CUIPO" sqlType="STRING"/>
		<param name="CODIGO_BPIN" sqlType="STRING"/>
		<param name="CODIGO_CCPET" sqlType="STRING"/>
		<param name="CODIGO_CPC" sqlType="STRING"/>
		<param name="CODIGOUNIDADEJE" sqlType="STRING"/>
		<param name="FUENTE_CUIPO" sqlType="STRING"/>
		<param name="CODIGOCCPETREGA" sqlType="STRING"/>
		<param name="POLITICA_PUBLICA" sqlType="STRING"/>
		<param name="DETALLE_SECTORIAL" sqlType="STRING"/>
		<param name="RECURSO_SGR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_CPTE" sqlType="STRING"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallescomprobantepptal/updatedetallescomprobantepptalconfiguracioncuipo">
		<call-query href="updateDetallescomprobantepptalUpdatedetallescomprobantepptalconfiguracioncuipo">
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
			<with-param name="SUBPROGRAMA" query-param="SUBPROGRAMA"/>
			<with-param name="COD_PROD_CUIPO" query-param="COD_PROD_CUIPO"/>
			<with-param name="CODIGO_BPIN" query-param="CODIGO_BPIN"/>
			<with-param name="CODIGO_CCPET" query-param="CODIGO_CCPET"/>
			<with-param name="CODIGO_CPC" query-param="CODIGO_CPC"/>
			<with-param name="CODIGOUNIDADEJE" query-param="CODIGOUNIDADEJE"/>
			<with-param name="FUENTE_CUIPO" query-param="FUENTE_CUIPO"/>
			<with-param name="CODIGOCCPETREGA" query-param="CODIGOCCPETREGA"/>
			<with-param name="POLITICA_PUBLICA" query-param="POLITICA_PUBLICA"/>
			<with-param name="DETALLE_SECTORIAL" query-param="DETALLE_SECTORIAL"/>
			<with-param name="RECURSO_SGR" query-param="RECURSO_SGR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_CPTE" query-param="KEY_TIPO_CPTE"/>
			<with-param name="KEY_COMPROBANTE" query-param="KEY_COMPROBANTE"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantepptalGetconfigurarcodigocuipoarchivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO,(TO_CHAR(DETALLE_COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, SUBSTR(COMPROBANTE_PPTAL.DESCRIPCION,0,50) DESCRIPCION, TERCERO.NIT, TERCERO.NOMBRE, DETALLE_COMPROBANTE_PPTAL.CUENTA, SUBSTR(CONCAT( PLAN_PRESUPUESTAL.NOMBRE, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_TER &lt;&gt; 0 THEN CONCAT( '/', TERCERO.NOMBRE ) ELSE NULL END, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_GEN &lt;&gt; 0 THEN CONCAT( '/', AUXILIAR.NOMBRE ) ELSE NULL END, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_CEN_CTO &lt;&gt; 0 THEN CONCAT( '/', CENTRO_COSTO.NOMBRE ) ELSE NULL END, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_REF &lt;&gt; 0 THEN CONCAT( '/', REFERENCIA.NOMBRE ) ELSE NULL END, CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_FUE &lt;&gt; 0 THEN CONCAT( '/', FUENTE_RECURSOS.NOMBRE ) ELSE NULL END ) ) ) ) ) ,0,50) CUENTANOMBRE, DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, DETALLE_COMPROBANTE_PPTAL.REFERENCIA, DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO, DETALLE_COMPROBANTE_PPTAL.AUXILIAR, DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO CREDITO, DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO CONTRACREDITO, DETALLE_COMPROBANTE_PPTAL.SECTOR, DETALLE_COMPROBANTE_PPTAL.PROGRAMA, DETALLE_COMPROBANTE_PPTAL.SUBPROGRAMA, DETALLE_COMPROBANTE_PPTAL.COD_PROD_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET, DETALLE_COMPROBANTE_PPTAL.CODIGO_CPC, DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE, DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGOCCPETREGA, DETALLE_COMPROBANTE_PPTAL.POLITICA_PUBLICA, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, DETALLE_COMPROBANTE_PPTAL.RECURSO_SGR FROM COMPROBANTE_PPTAL INNER JOIN DETALLE_COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COMPROBANTE_PPTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = COMPROBANTE_PPTAL.TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = COMPROBANTE_PPTAL.NUMERO INNER JOIN TIPO_COMPROBPP ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COMPROBANTE_PPTAL.TIPO = TIPO_COMPROBPP.CODIGO LEFT JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = PLAN_PRESUPUESTAL.CODIGO LEFT JOIN AUXILIAR ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = AUXILIAR.ANO AND CASE WHEN MAN_AUX_GEN IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.AUXILIAR END = AUXILIAR.CODIGO LEFT JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = CENTRO_COSTO.ANO AND CASE WHEN MAN_CEN_CTO IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO END = CENTRO_COSTO.CODIGO LEFT JOIN REFERENCIA ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = REFERENCIA.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = REFERENCIA.ANO AND CASE WHEN MAN_AUX_REF IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.REFERENCIA END = REFERENCIA.CODIGO LEFT JOIN FUENTE_RECURSOS ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = FUENTE_RECURSOS.ANO AND CASE WHEN MAN_AUX_FUE IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO END = FUENTE_RECURSOS.CODIGO INNER JOIN TERCERO TERCERO ON COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND EXTRACT(MONTH FROM DETALLE_COMPROBANTE_PPTAL.FECHA) BETWEEN :TRIMESTRE - 2 AND :TRIMESTRE AND CASE WHEN :NATURALEZA = 'C' THEN DETALLE_COMPROBANTE_PPTAL.NATURALEZA WHEN :NATURALEZA = 'D' THEN DETALLE_COMPROBANTE_PPTAL.NATURALEZA ELSE '1' END = CASE WHEN :NATURALEZA = 'C' THEN 'C' WHEN :NATURALEZA = 'D' THEN 'D' ELSE '1' END AND INSTR(:CLASE, CONCAT(CONCAT(',', TIPO_COMPROBPP.CLASE), ',')) &gt; 0 ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPROBANTE DESC, CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","DESCRIPCION":"$DESCRIPCION","NIT":"$NIT","NOMBRE":"$NOMBRE","CUENTA":"$CUENTA","CUENTANOMBRE":"$CUENTANOMBRE","CENTRO_COSTO":"$CENTRO_COSTO","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","AUXILIAR":"$AUXILIAR","CREDITO":"$CREDITO","CONTRACREDITO":"$CONTRACREDITO","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","COD_PROD_CUIPO":"$COD_PROD_CUIPO","CODIGO_BPIN":"$CODIGO_BPIN","CODIGO_CCPET":"$CODIGO_CCPET","CODIGO_CPC":"$CODIGO_CPC","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","FUENTE_CUIPO":"$FUENTE_CUIPO","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITICA_PUBLICA":"$POLITICA_PUBLICA","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","RECURSO_SGR":"$RECURSO_SGR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TRIMESTRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
