	<query id="getDetallescomprobantepptalPagValorPptoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.DESCRIPCION, TRIM(TO_CHAR(VALOR_DEBITO-VALOR_CREDITO-(DEBITO_AFECTADO-CREDITO_AFECTADO)+(MODIFICACION_DEBITO-MODIFICACION_CREDITO),'999,999,999,999.00')) AS VALORPPTO, VALOR_DEBITO-VALOR_CREDITO-(DEBITO_AFECTADO-CREDITO_AFECTADO)+(MODIFICACION_DEBITO-MODIFICACION_CREDITO) VALORPPTON, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALORPPTO IS NULL THEN ' ' ELSE UPPER(VALORPPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORPPTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","DESCRIPCION":"$DESCRIPCION","VALORPPTO":"$VALORPPTO","VALORPPTON":"$VALORPPTON(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORPPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
