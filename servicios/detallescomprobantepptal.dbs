			<with-param name="SUBPROGRAMA" query-param="SUBPROGRAMA"/>
			<with-param name="CODIGOUNIDADEJE" query-param="CODIGOUNIDADEJE"/>
			<with-param name="CODIGOCCPETREGA" query-param="CODIGOCCPETREGA"/>
			<with-param name="POLITICA_PUBLICA" query-param="POLITICA_PUBLICA"/>
			<with-param name="DETALLE_SECTORIAL" query-param="DETALLE_SECTORIAL"/>
			<with-param name="RECURSO_SGR" query-param="RECURSO_SGR"/>
			<with-param name="IMPUESTO" query-param="IMPUESTO"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>												 
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantepptalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.CLASET, DETALLE_COMPROBANTE_PPTAL.TIPOT, DETALLE_COMPROBANTE_PPTAL.CMPTE_SOLICI_AFECTADO, V_PLAN_PRESUPUESTAL.NOMBRE NOMBREPPTAL, DETALLE_COMPROBANTE_PPTAL.DESCRIPCION, DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO, DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO,(CASE DETALLE_COMPROBANTE_PPTAL.PROGRAMARPAC WHEN 0 THEN 'false' ELSE 'true' END) PROGRAMARPAC, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE_AFECT, DETALLE_COMPROBANTE_PPTAL.CMPTE_AFECTADO, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVOPPTO, DETALLE_COMPROBANTE_PPTAL.TIPO_DOCUMENTO, DETALLE_COMPROBANTE_PPTAL.NRO_DOCUMENTO, DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, DETALLE_COMPROBANTE_PPTAL.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, DETALLE_COMPROBANTE_PPTAL.SUCURSAL, DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO, DETALLE_COMPROBANTE_PPTAL.AUXILIAR,(TO_CHAR(DETALLE_COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_PPTAL.REFERENCIA,(CASE DETALLE_COMPROBANTE_PPTAL.PAPELES WHEN 0 THEN 'false' ELSE 'true' END) PAPELES,(CASE DETALLE_COMPROBANTE_PPTAL.CONTRACTUAL WHEN 0 THEN 'false' ELSE 'true' END) CONTRACTUAL,(CASE DETALLE_COMPROBANTE_PPTAL.CONSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) CONSITUACIONFONDOS, DETALLE_COMPROBANTE_PPTAL.PORCENTAJEDISTRIBUIDO, DETALLE_COMPROBANTE_PPTAL.SALDO, DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO, DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO, DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO, DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO, ( CASE WHEN DETALLE_COMPROBANTE_PPTAL.NATURALEZA = 'D' THEN (VALOR_DEBITO - VALOR_CREDITO) - (DEBITO_AFECTADO - CREDITO_AFECTADO ) + (MODIFICACION_DEBITO - MODIFICACION_CREDITO) ELSE (VALOR_CREDITO - VALOR_DEBITO) - (CREDITO_AFECTADO - DEBITO_AFECTADO ) + (MODIFICACION_CREDITO - MODIFICACION_DEBITO) END) AS SALDONETO, V_PLAN_PRESUPUESTAL.DESTINO, DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADOCNT, DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADOCNT, DETALLE_COMPROBANTE_PPTAL.VALORCOMPROMISO, DETALLE_COMPROBANTE_PPTAL.DISPONIBILIDADNETA, DETALLE_COMPROBANTE_PPTAL.DISACUMULADAS, DETALLE_COMPROBANTE_PPTAL.RESACUMULADAS, DETALLE_COMPROBANTE_PPTAL.APRDEFINITIVA, DETALLE_COMPROBANTE_PPTAL.TIPOCONTRATO, DETALLE_COMPROBANTE_PPTAL.NUMEROCONTRATO, DETALLE_COMPROBANTE_PPTAL.PAC_DISPONIBLE, DETALLE_COMPROBANTE_PPTAL.NATURALEZA, DETALLE_COMPROBANTE_PPTAL.CUENTA_DEBITO, DETALLE_COMPROBANTE_PPTAL.CUENTA_CREDITO , DETALLE_COMPROBANTE_PPTAL.CODIGO_CPC, DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.COD_PROD_CUIPO , DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET, DETALLE_COMPROBANTE_PPTAL.SECTOR , DETALLE_COMPROBANTE_PPTAL.PROGRAMA , DETALLE_COMPROBANTE_PPTAL.SUBPROGRAMA , DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE , DETALLE_COMPROBANTE_PPTAL.CODIGOCCPETREGA ,DETALLE_COMPROBANTE_PPTAL.POLITICA_PUBLICA ,DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL ,DETALLE_COMPROBANTE_PPTAL.RECURSO_SGR, DETALLE_COMPROBANTE_PPTAL.IMPUESTO, DETALLE_COMPROBANTE_PPTAL.VALOR_BASE, DETALLE_COMPROBANTE_PPTAL.CREATED_BY, DETALLE_COMPROBANTE_PPTAL.DEPENDENCIA FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN TERCERO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN PLAN_PRESUPUESTAL V_PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = V_PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = V_PLAN_PRESUPUESTAL.CODIGO WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = :TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = :NUMERO ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPROBANTE) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASET), '%')) AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOT), '%')) AND (CASE WHEN CMPTE_SOLICI_AFECTADO IS NULL THEN ' ' ELSE UPPER(CMPTE_SOLICI_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CMPTE_SOLICI_AFECTADO), '%')) AND (CASE WHEN NOMBREPPTAL IS NULL THEN ' ' ELSE UPPER(NOMBREPPTAL) END) LIKE UPPER(CONCAT(:NOMBREPPTAL, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN PROGRAMARPAC IS NULL THEN ' ' ELSE UPPER(PROGRAMARPAC) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMARPAC), '%')) AND (CASE WHEN TIPO_CPTE_AFECT IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE_AFECT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE_AFECT), '%')) AND (CASE WHEN CMPTE_AFECTADO IS NULL THEN ' ' ELSE UPPER(CMPTE_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CMPTE_AFECTADO), '%')) AND (CASE WHEN CONSECUTIVOPPTO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOPPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVOPPTO), '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOCUMENTO), '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NRO_DOCUMENTO), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN CONTRACTUAL IS NULL THEN ' ' ELSE UPPER(CONTRACTUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRACTUAL), '%')) AND (CASE WHEN CONSITUACIONFONDOS IS NULL THEN ' ' ELSE UPPER(CONSITUACIONFONDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSITUACIONFONDOS), '%')) AND (CASE WHEN PORCENTAJEDISTRIBUIDO IS NULL THEN ' ' ELSE UPPER(PORCENTAJEDISTRIBUIDO) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJEDISTRIBUIDO), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN CREDITO_AFECTADO IS NULL THEN ' ' ELSE UPPER(CREDITO_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CREDITO_AFECTADO), '%')) AND (CASE WHEN DEBITO_AFECTADO IS NULL THEN ' ' ELSE UPPER(DEBITO_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:DEBITO_AFECTADO), '%')) AND (CASE WHEN MODIFICACION_CREDITO IS NULL THEN ' ' ELSE UPPER(MODIFICACION_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFICACION_CREDITO), '%')) AND (CASE WHEN MODIFICACION_DEBITO IS NULL THEN ' ' ELSE UPPER(MODIFICACION_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFICACION_DEBITO), '%')) AND (CASE WHEN SALDONETO IS NULL THEN ' ' ELSE UPPER(SALDONETO) END) LIKE UPPER(CONCAT(:SALDONETO, '%')) AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END) LIKE UPPER(CONCAT(:DESTINO, '%')) AND (CASE WHEN CUENTA_DEBITO IS NULL THEN ' ' ELSE UPPER(CUENTA_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA_DEBITO), '%')) AND (CASE WHEN CUENTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CUENTA_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA_CREDITO), '%')) AND (CASE WHEN CODIGO_CPC IS NULL THEN ' ' ELSE UPPER(CODIGO_CPC) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CPC), '%')) AND (CASE WHEN FUENTE_CUIPO IS NULL THEN ' ' ELSE UPPER(FUENTE_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_CUIPO), '%')) AND (CASE WHEN COD_PROD_CUIPO IS NULL THEN ' ' ELSE UPPER(COD_PROD_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_PROD_CUIPO), '%')) AND (CASE WHEN CODIGO_BPIN IS NULL THEN ' ' ELSE UPPER(CODIGO_BPIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_BPIN), '%')) AND (CASE WHEN CODIGO_CCPET IS NULL THEN ' ' ELSE UPPER(CODIGO_CCPET) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CCPET), '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SECTOR), '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMA), '%')) AND (CASE WHEN SUBPROGRAMA IS NULL THEN ' ' ELSE UPPER(SUBPROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:SUBPROGRAMA), '%')) AND (CASE WHEN CODIGOUNIDADEJE IS NULL THEN ' ' ELSE UPPER(CODIGOUNIDADEJE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOUNIDADEJE), '%')) AND (CASE WHEN CODIGOCCPETREGA IS NULL THEN ' ' ELSE UPPER(CODIGOCCPETREGA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPETREGA), '%')) AND (CASE WHEN POLITICA_PUBLICA IS NULL THEN ' ' ELSE UPPER(POLITICA_PUBLICA) END) LIKE UPPER(CONCAT(CONCAT('%',:POLITICA_PUBLICA), '%')) AND (CASE WHEN DETALLE_SECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLE_SECTORIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DETALLE_SECTORIAL), '%')) AND (CASE WHEN RECURSO_SGR IS NULL THEN ' ' ELSE UPPER(RECURSO_SGR) END) LIKE UPPER(CONCAT(CONCAT('%',:RECURSO_SGR), '%')) AND (CASE WHEN IMPUESTO IS NULL THEN ' ' ELSE UPPER(IMPUESTO) END) LIKE UPPER(CONCAT(CONCAT('%',:IMPUESTO), '%')) AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_BASE), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:CREATED_BY), '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DEPENDENCIA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
