	<query id="updateDetallescomprobantepptalActualizarTercero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_COMPROBANTE_PPTAL SET TERCERO =:TERCERO, SUCURSAL =:SUCURSAL WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND TIPO_CPTE =:TIPO AND COMPROBANTE =:COMPROBANTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

