	<query id="insertDetallescomprobantepptal" keyColumns="COMPANIA,ANO,TIPO_CPTE,COMPROBANTE,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLE_COMPROBANTE_PPTAL (COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CUENTA, DESCRIPCION, VALOR_DEBITO, VALOR_CREDITO, PROGRAMARPAC, ANO_AFECT, TIPO_CPTE_AFECT, CMPTE_AFECTADO, CONSECUTIVOPPTO, TIPO_DOCUMENTO, NRO_DOCUMENTO, CENTRO_COSTO, TERCERO, SUCURSAL, FUENTE_RECURSO, AUXILIAR, FECHA, REFERENCIA, PAPELES, CONTRACTUAL, CONSITUACIONFONDOS, PORCENTAJEDISTRIBUIDO, SALDO, CREDITO_AFECTADO, DEBITO_AFECTADO, MODIFICACION_CREDITO, MODIFICACION_DEBITO, DEBITO_AFECTADOCNT, CREDITO_AFECTADOCNT, VALORCOMPROMISO, DISPONIBILIDADNETA, DISACUMULADAS, RESACUMULADAS, APRDEFINITIVA, TIPOCONTRATO, NUMEROCONTRATO, PAC_DISPONIBLE, NATURALEZA, CUENTA_DEBITO, CUENTA_CREDITO, CODIGO_CPC, FUENTE_CUIPO, COD_PROD_CUIPO, CODIGO_BPIN, CODIGO_CCPET, SECTOR, PROGRAMA, SUBPROGRAMA, CODIGOUNIDADEJE, CODIGOCCPETREGA, POLITICA_PUBLICA, DETALLE_SECTORIAL, RECURSO_SGR, IMPUESTO, VALOR_BASE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO_CPTE, :COMPROBANTE, :CONSECUTIVO, :CUENTA, :DESCRIPCION, :VALOR_DEBITO, :VALOR_CREDITO, :PROGRAMARPAC, :ANO_AFECT, :TIPO_CPTE_AFECT, :CMPTE_AFECTADO, :CONSECUTIVOPPTO, :TIPO_DOCUMENTO, :NRO_DOCUMENTO, :CENTRO_COSTO, :TERCERO, :SUCURSAL, :FUENTE_RECURSO, :AUXILIAR, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :REFERENCIA, :PAPELES, :CONTRACTUAL, :CONSITUACIONFONDOS, :PORCENTAJEDISTRIBUIDO, :SALDO, :CREDITO_AFECTADO, :DEBITO_AFECTADO, :MODIFICACION_CREDITO, :MODIFICACION_DEBITO, :DEBITO_AFECTADOCNT, :CREDITO_AFECTADOCNT, :VALORCOMPROMISO, :DISPONIBILIDADNETA, :DISACUMULADAS, :RESACUMULADAS, :APRDEFINITIVA, :TIPOCONTRATO, :NUMEROCONTRATO, :PAC_DISPONIBLE, :NATURALEZA, :CUENTA_DEBITO, :CUENTA_CREDITO, :CODIGO_CPC, :FUENTE_CUIPO, :COD_PROD_CUIPO, :CODIGO_BPIN, :CODIGO_CCPET, :SECTOR, :PROGRAMA, :SUBPROGRAMA, :CODIGOUNIDADEJE, :CODIGOCCPETREGA, :POLITICA_PUBLICA, :DETALLE_SECTORIAL, :RECURSO_SGR, :IMPUESTO, :VALOR_BASE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO_CPTE":"$TIPO_CPTE","KEY_COMPROBANTE":"$COMPROBANTE(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
