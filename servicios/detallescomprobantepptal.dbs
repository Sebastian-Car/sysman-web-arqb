	<query id="getDetallescomprobantepptalListacomprobantetempQuery"  useConfig="sysmandsunist">
		<sql>SELECT D.CONSECUTIVOPPTO CONSECUTIVO, D.COMPANIA, D.ANO, D.TIPO_CPTE_AFECT TIPO_CPTE, D.CMPTE_AFECTADO AS COMPROBANTE,(TO_CHAR(D.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, D.DESCRIPCION, D.CUENTA, D.REFERENCIA, D.CENTRO_COSTO, D.FUENTE_RECURSO, D.AUXILIAR, D.VALOR_DEBITO FROM TEMP_DETALLE_COMPROBANTE_PPTAL D WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANO AND D.COMPROBANTE = :NUMERO AND D.TIPO_CPTE = :TIPO ORDER BY COMPROBANTE, CONSECUTIVO</sql>
