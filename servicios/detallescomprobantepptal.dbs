	<query id="getDetallescomprobantepptalGetvalordisminuidopptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(DETALLE.MODIFICACION_CREDITO) AS VALOR_DISMINUIDO_PPTO FROM DETALLE_COMPROBANTE_PPTAL DETALLE INNER JOIN TIPO_COMPROBPP TIPO ON DETALLE.COMPANIA = TIPO.COMPANIA AND DETALLE.TIPO_CPTE = TIPO.CODIGO WHERE DETALLE.COMPANIA = :COMPANIA AND DETALLE.TIPOT = :TIPOT AND DETALLE.CLASET = :CLASET AND DETALLE.CMPTE_SOLICI_AFECTADO = :CODIGO AND DETALLE.DEPENDENCIA = :DEPENDENCIA AND DETALLE.CONSECUTIVOPPTO = :CONSECUTIVO AND TIPO.CLASE IN ('DIS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_DISMINUIDO_PPTO":"$VALOR_DISMINUIDO_PPTO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
