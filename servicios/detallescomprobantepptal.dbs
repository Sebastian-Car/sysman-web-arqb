	<query id="getDetallescomprobantepptalConteoPorCompaniaAnoCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT('X') CUENTA FROM DETALLE_COMPROBANTE_PPTAL WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = :CODIGO</sql>
