	<query id="getDetallescomprobantepptalNumListaEliminarDetalleLoteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, DETALLE_COMPROBANTE_PPTAL.CUENTA, V_PLAN_PRESUPUESTAL.NOMBRE NOMBREPPTAL, DETALLE_COMPROBANTE_PPTAL.DESCRIPCION, DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO, DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO, DETALLE_COMPROBANTE_PPTAL.CREATED_BY FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN TERCERO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN V_PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = V_PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = V_PLAN_PRESUPUESTAL.ID WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = :TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = :NUMERO ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CUENTA) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN NOMBREPPTAL IS NULL THEN ' ' ELSE UPPER(NOMBREPPTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPPTAL), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_DEBITO), '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_CREDITO), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(:CREATED_BY, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBREPPTAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR_DEBITO" sqlType="STRING"/>
		<param name="VALOR_CREDITO" sqlType="STRING"/>
        <param name="CREATED_BY" sqlType="STRING"/>

	</query>
