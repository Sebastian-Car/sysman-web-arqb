	<query id="getDetallescomprobantepptalNumConsecutivocuentaauxiliarvalordebcreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE.CONSECUTIVO, DETALLE.CUENTA, DETALLE.AUXILIAR, DETALLE.VALOR_DEBITO, DETALLE.VALOR_CREDITO, DETALLE.CENTRO_COSTO,(TO_CHAR(DETALLE.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, AUXILIAR.NOMBRE NOMBREAUX FROM DETALLE_COMPROBANTE_PPTAL DETALLE LEFT JOIN AUXILIAR ON DETALLE.COMPANIA = AUXILIAR.COMPANIA AND DETALLE.ANO = AUXILIAR.ANO AND DETALLE.AUXILIAR = AUXILIAR.CODIGO WHERE DETALLE.COMPANIA = :COMPANIA AND DETALLE.ANO = :ANO AND DETALLE.TIPO_CPTE = :TIPO_CPTE AND DETALLE.COMPROBANTE = :COMPROBANTE) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN VALOR_DEBITO IS NULL THEN ' ' ELSE UPPER(VALOR_DEBITO) END) LIKE UPPER(CONCAT(:VALOR_DEBITO, '%')) AND (CASE WHEN VALOR_CREDITO IS NULL THEN ' ' ELSE UPPER(VALOR_CREDITO) END) LIKE UPPER(CONCAT(:VALOR_CREDITO, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NOMBREAUX IS NULL THEN ' ' ELSE UPPER(NOMBREAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAUX), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
