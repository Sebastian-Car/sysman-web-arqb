	<query id="getDetallescomprobantepptalCalcularTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(NVL(SUM( CASE WHEN :NATURALEZA = 'D' THEN DCP.VALOR_DEBITO -DCP.VALOR_CREDITO ELSE DCP.VALOR_CREDITO-DCP.VALOR_DEBITO END),0), '99,999,999,999,999,990.90') TOTAL FROM DETALLE_COMPROBANTE_PPTAL DCP INNER JOIN CENTRO_COSTO CC ON DCP.COMPANIA = CC.COMPANIA AND DCP.CENTRO_COSTO = CC.CODIGO AND DCP.ANO = CC.ANO INNER JOIN TERCERO TER ON DCP.COMPANIA = TER.COMPANIA AND DCP.TERCERO = TER.NIT AND DCP.SUCURSAL = TER.SUCURSAL INNER JOIN AUXILIAR ON DCP.COMPANIA = AUXILIAR.COMPANIA AND DCP.AUXILIAR = AUXILIAR.CODIGO AND DCP.ANO = AUXILIAR.ANO INNER JOIN COMPROBANTE_PPTAL CP ON DCP.COMPANIA = CP.COMPANIA AND DCP.COMPROBANTE = CP.NUMERO AND DCP.TIPO_CPTE = CP.TIPO AND DCP.ANO = CP.ANO WHERE DCP.COMPANIA = :COMPANIA AND SUBSTR(DCP.ID,0,LENGTH(:CODIGO)) = :CODIGO AND LENGTH(DCP.ID) &gt;= LENGTH(:CODIGO) AND DCP.ANO = :ANO AND DCP.TIPO_CPTE = CASE WHEN :TCOMPONENTE = 'TODOS' THEN DCP.TIPO_CPTE ELSE :TCOMPONENTE END AND EXTRACT (MONTH FROM DCP.FECHA) BETWEEN :MESINICIAL AND :MESFINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TCOMPONENTE" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
