	<query id="getDetallescomprobantepptalTodosPorCompaniaTipoComprobanteNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TERCERO, DETALLE_COMPROBANTE_PPTAL.SUCURSAL, DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, DETALLE_COMPROBANTE_PPTAL.AUXILIAR, DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO, DETALLE_COMPROBANTE_PPTAL.REFERENCIA, V_PLAN_PRESUPUESTAL.NATURALEZA AS NAT, ROUND((CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO-DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) -(DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO) +(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO) ELSE (DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO-DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO) -(DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO) +(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO) END ),2) AS NETO FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COMPROBANTE_PPTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = COMPROBANTE_PPTAL.TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = COMPROBANTE_PPTAL.NUMERO LEFT JOIN V_PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = V_PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = V_PLAN_PRESUPUESTAL.ID WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA =:COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = :STRTIPOCOMPROBANTE AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = :NUMERO AND ROUND((CASE WHEN V_PLAN_PRESUPUESTAL.NATURALEZA='D' THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO-DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) -(DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO) +(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO) ELSE (DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO-DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO) -(DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO-DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO) +(DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO-DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO) END),2) &gt; 0 ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","FUENTE_RECURSO":"$FUENTE_RECURSO","REFERENCIA":"$REFERENCIA","NAT":"$NAT","NETO":"$NETO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
