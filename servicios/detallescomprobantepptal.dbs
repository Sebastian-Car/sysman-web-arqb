	<query id="getDetallescomprobantepptalGetdetallecomprobanteclasificadosporcuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.NATURALEZA, DETALLE_COMPROBANTE_PPTAL.CODIGO_CPC, DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.COD_PROD_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET, DETALLE_COMPROBANTE_PPTAL.SECTOR, DETALLE_COMPROBANTE_PPTAL.PROGRAMA, DETALLE_COMPROBANTE_PPTAL.SUBPROGRAMA, DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE, DETALLE_COMPROBANTE_PPTAL.CODIGOCCPETREGA, DETALLE_COMPROBANTE_PPTAL.POLITICA_PUBLICA, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN TERCERO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN V_PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = V_PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = V_PLAN_PRESUPUESTAL.ID WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = :TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = :NUMERO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = :CUENTA ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NATURALEZA":"$NATURALEZA","CODIGO_CPC":"$CODIGO_CPC","FUENTE_CUIPO":"$FUENTE_CUIPO","COD_PROD_CUIPO":"$COD_PROD_CUIPO","CODIGO_BPIN":"$CODIGO_BPIN","CODIGO_CCPET":"$CODIGO_CCPET","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITICA_PUBLICA":"$POLITICA_PUBLICA","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
