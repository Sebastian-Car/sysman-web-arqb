	<query id="getDetallescomprobantepptalTotalesResDisPorClaseFechasQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO)-SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) AS TOTALMOV FROM DETALLE_COMPROBANTE_PPTAL LEFT JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = TIPO_COMPROBPP.CODIGO WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CLASES), TIPO_COMPROBPP.CLASE, 1) &gt; 0 AND FECHA BETWEEN TO_DATE(:FECHAINICIAL, 'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL, 'DD/MM/YYYY')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTALMOV":"$TOTALMOV"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASES" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/totalesresdisporclasefechas">
		<call-query href="getDetallescomprobantepptalTotalesResDisPorClaseFechasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASES" query-param="CLASES"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantepptalPagCuentaydescripcionconcomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CUENTA, DESCRIPCION, COMPANIA, ANO, CENTRO_COSTO, AUXILIAR, REFERENCIA, FUENTE_RECURSO FROM DETALLE_COMPROBANTE_PPTAl WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPOPPTAL AND COMPROBANTE = :COMPROBANTEDISPONIBILIDAD) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","DESCRIPCION":"$DESCRIPCION","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOPPTAL" sqlType="STRING"/>
		<param name="COMPROBANTEDISPONIBILIDAD" sqlType="STRING"/>
