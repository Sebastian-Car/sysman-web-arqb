	<query id="getDetallescomprobantepptalNumTodosMovPptalesPorCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DCP.COMPANIA, DCP.ANO, DCP.ID, CASE WHEN DCP.TIPOCONTRATO IS NULL THEN CP.TIPOCONTRATO ELSE DCP.TIPOCONTRATO END AS TIPOCONTRATO, CASE WHEN NVL(DCP.NUMEROCONTRATO,0) &gt;= 1 THEN DCP.NUMEROCONTRATO ELSE CP.NUMEROCONTRATO END AS NUMEROCONTRATO, CP.NRO_DOCUMENTO, DCP.TIPO_CPTE, DCP.COMPROBANTE, DCP.CONSECUTIVO,(TO_CHAR(DCP.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DCP.TERCERO, TER.NOMBRE TERCERONOMBRE, DCP.DESCRIPCION, DCP.TIPO_CPTE_AFECT, DCP.CMPTE_AFECTADO, DCP.CENTRO_COSTO, CC.NOMBRE CENTRONOMBRE, DCP.AUXILIAR, AUXILIAR.NOMBRE AUXILIARNOMBRE, DCP.FUENTE_RECURSO, FUENTE_RECURSOS.NOMBRE NOMBREFTEREC, DCP.REFERENCIA, REFERENCIA.NOMBRE NOMBRE_REF, CASE WHEN :NATURALEZA = 'D' THEN DCP.VALOR_DEBITO -DCP.VALOR_CREDITO ELSE DCP.VALOR_CREDITO-DCP.VALOR_DEBITO END VALOR, :NOMBRE NOMBRERUBRO,(TO_CHAR(CP.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CREACION_CMPTE FROM DETALLE_COMPROBANTE_PPTAL DCP INNER JOIN COMPROBANTE_PPTAL CP ON DCP.COMPANIA = CP.COMPANIA AND DCP.ANO = CP.ANO AND DCP.TIPO_CPTE = CP.TIPO AND DCP.COMPROBANTE = CP.NUMERO LEFT JOIN CENTRO_COSTO CC ON DCP.COMPANIA = CC.COMPANIA AND DCP.ANO = CC.ANO AND DCP.CENTRO_COSTO = CC.CODIGO LEFT JOIN TERCERO TER ON DCP.COMPANIA = TER.COMPANIA AND DCP.TERCERO = TER.NIT AND DCP.SUCURSAL = TER.SUCURSAL LEFT JOIN AUXILIAR ON DCP.COMPANIA = AUXILIAR.COMPANIA AND DCP.ANO = AUXILIAR.ANO AND DCP.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN FUENTE_RECURSOS ON DCP.COMPANIA = FUENTE_RECURSOS.COMPANIA AND DCP.ANO = FUENTE_RECURSOS.ANO AND DCP.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO LEFT JOIN REFERENCIA ON DCP.COMPANIA = REFERENCIA.COMPANIA AND DCP.ANO = REFERENCIA.ANO AND DCP.FUENTE_RECURSO = REFERENCIA.CODIGO WHERE DCP.COMPANIA = :COMPANIA AND SUBSTR(DCP.ID,0,LENGTH(:CODIGO)) = :CODIGO AND LENGTH(DCP.ID) &gt;= LENGTH(:CODIGO) AND DCP.ANO = :ANO AND DCP.TIPO_CPTE = CASE WHEN :TCOMPONENTE = 'TODOS' THEN DCP.TIPO_CPTE ELSE :TCOMPONENTE END AND EXTRACT (MONTH FROM DCP.FECHA) BETWEEN :MESINICIAL AND :MESFINAL ORDER BY DCP.TIPO_CPTE, DCP.COMPROBANTE, DCP.FECHA, CP.FECHA) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(CONCAT('%',:ID), '%')) AND (CASE WHEN TIPOCONTRATO IS NULL THEN ' ' ELSE UPPER(TIPOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCONTRATO), '%')) AND (CASE WHEN NUMEROCONTRATO IS NULL THEN ' ' ELSE UPPER(NUMEROCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMEROCONTRATO), '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NRO_DOCUMENTO), '%')) AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN TERCERONOMBRE IS NULL THEN ' ' ELSE UPPER(TERCERONOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERONOMBRE), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN TIPO_CPTE_AFECT IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE_AFECT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE_AFECT), '%')) AND (CASE WHEN CMPTE_AFECTADO IS NULL THEN ' ' ELSE UPPER(CMPTE_AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CMPTE_AFECTADO), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN CENTRONOMBRE IS NULL THEN ' ' ELSE UPPER(CENTRONOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRONOMBRE), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN AUXILIARNOMBRE IS NULL THEN ' ' ELSE UPPER(AUXILIARNOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIARNOMBRE), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN NOMBREFTEREC IS NULL THEN ' ' ELSE UPPER(NOMBREFTEREC) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFTEREC), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN NOMBRE_REF IS NULL THEN ' ' ELSE UPPER(NOMBRE_REF) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_REF), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN FECHA_CREACION_CMPTE IS NULL THEN ' ' ELSE UPPER(FECHA_CREACION_CMPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_CREACION_CMPTE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TCOMPONENTE" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>
		<param name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="TERCERONOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO_CPTE_AFECT" sqlType="STRING"/>
		<param name="CMPTE_AFECTADO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="CENTRONOMBRE" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="AUXILIARNOMBRE" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBREFTEREC" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="NOMBRE_REF" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA_CREACION_CMPTE" sqlType="STRING"/>

	</query>
