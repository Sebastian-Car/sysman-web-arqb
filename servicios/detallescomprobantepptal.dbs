	<query id="insertDetallescomprobantepptalValidarValoresEnCero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLE_COMPROBANTE_PPTAL ( COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CUENTA, FECHA, NATURALEZA, DESCRIPCION, VALOR_DEBITO, VALOR_CREDITO, TIPO_DOCUMENTO, NRO_DOCUMENTO, CENTRO_COSTO, TERCERO, SUCURSAL, AUXILIAR, CONSECUTIVOPPTO, CONTRACTUAL, PAPELES, PAC_DISPONIBLE, REFERENCIA, FUENTE_RECURSO ) VALUES ( :COMPANIA, :ANO, :TIPO_CPTE, :COMPROBANTE, :CONSECUTIVO, :CUENTA, :FECHA, :NATURALEZA, :DESCRIPCION, :VALOR_DEBITO, :VALOR_CREDITO, :TIPO_DOCUMENTO, :NUMERO_DCTO, :CENTRO_COSTO, :TERCERO, :SUCURSAL, :AUXILIAR, :CONSECUTIVOPPTO, :CONTRACTUAL, :PAPELES, :PAC_DISPONIBLE, :REFERENCIA, :FUENTE_RECURSO )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_DEBITO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_CREDITO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="" name="CONSECUTIVOPPTO" sqlType="STRING"/>
		<param defaultValue="0" name="CONTRACTUAL" sqlType="STRING"/>
		<param defaultValue="0" name="PAPELES" sqlType="STRING"/>
		<param defaultValue="0" name="PAC_DISPONIBLE" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_RECURSO" sqlType="STRING"/>

	</query>
