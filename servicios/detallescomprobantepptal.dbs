	<query id="getDetallescomprobantepptalPagNumeroYDescripcionPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT COMPROBANTE, DESCRIPCION ,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CASE WHEN NATURALEZA = 'D' THEN (VALOR_DEBITO -VALOR_CREDITO) ELSE (VALOR_CREDITO-VALOR_DEBITO) END VALOR FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND TIPO_CPTE = :TIPO) INI WHERE (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE(type:long)","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","VALOR":"$VALOR(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/numeroydescripcionportipo/pag">
