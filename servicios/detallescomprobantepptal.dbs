	<query id="getDetallescomprobantepptalGetiaddcodigos23cuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CUENTA, CONSECUTIVO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, VALOR_CREDITO, VALOR_DEBITO CONTRACREDITO, NVL(SECTOR, '0') SECTOR, NVL(PROGRAMA, '0') PROGRAMA, NVL(COD_PROD_CUIPO, '0') CODIGOPRODUCTO, NVL(CODIGO_BPIN, '0') CODIGOBPIN, NVL(DETALLE_SECTORIAL, '0') DETALLESECTORIAL FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTA LIKE '2.3%' AND ( ( SECTOR IS NULL OR SECTOR IN ( '' ) OR SECTOR IN ( '0' ) ) OR ( PROGRAMA IS NULL OR PROGRAMA IN ( '' ) OR PROGRAMA IN ( '0' ) ) OR ( COD_PROD_CUIPO IS NULL OR COD_PROD_CUIPO IN ( '' ) OR COD_PROD_CUIPO IN ( '0' ) ) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CUENTA":"$CUENTA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","VALOR_CREDITO":"$VALOR_CREDITO","CONTRACREDITO":"$CONTRACREDITO","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","DETALLESECTORIAL":"$DETALLESECTORIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
