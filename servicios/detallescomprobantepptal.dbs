	<query id="getDetallescomprobantepptalGetcodigoccpetcpccuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT DPPT.COMPANIA, DPPT.ANO, DPPT.TIPO_CPTE, DPPT.COMPROBANTE, DPPT.CUENTA,(TO_CHAR(DPPT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DPPT.CONSECUTIVO, DPPT.VALOR_CREDITO, DPPT.VALOR_DEBITO CONTRACREDITO, NVL(DPPT.CODIGO_CCPET, '0') CODIGOCCPET, NVL(DPPT.CODIGO_CPC, '0') CODIGOCPCDANE FROM DETALLE_COMPROBANTE_PPTAL DPPT WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND ( ( ( DPPT.CODIGO_CPC IS NOT NULL OR DPPT.CODIGO_CPC NOT IN ( '0' ) OR DPPT.CODIGO_CPC NOT IN ( '' ) ) AND ( CODIGO_CCPET LIKE '2.1.2.01%' OR CODIGO_CCPET LIKE '2.1.3.01%' OR CODIGO_CCPET LIKE '2.1.5.01%' OR CODIGO_CCPET LIKE '2.1.7.01%' OR CODIGO_CCPET LIKE '2.1.7.01%' OR CODIGO_CCPET LIKE '2.1.8.01%' OR CODIGO_CCPET LIKE '2.3.2.01%' OR CODIGO_CCPET LIKE '2.3.3.01%' OR CODIGO_CCPET LIKE '2.3.5.01%' OR CODIGO_CCPET LIKE '2.3.7.01%' OR CODIGO_CCPET LIKE '2.3.8.01%' ) ) OR ( ( DPPT.CODIGO_CPC IS NULL OR DPPT.CODIGO_CPC IN ( '0' ) OR DPPT.CODIGO_CPC IN ( '' ) ) AND ( CODIGO_CCPET LIKE '2.1.2.02%' OR CODIGO_CCPET LIKE '2.1.3.02%' OR CODIGO_CCPET LIKE '2.1.5.02%' OR CODIGO_CCPET LIKE '2.3.2.02%' OR CODIGO_CCPET LIKE '2.3.5.02%' ) ) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CUENTA":"$CUENTA","FECHA":"$FECHA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","VALOR_CREDITO":"$VALOR_CREDITO","CONTRACREDITO":"$CONTRACREDITO","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/getcodigoccpetcpccuipo">
		<call-query href="getDetallescomprobantepptalGetcodigoccpetcpccuipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantepptalGetinformemovimientospptalingresoscuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPANIA, ANO, TIPO_CPTE, COMPROBANTE, CUENTA, CONSECUTIVO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, VALOR_CREDITO, VALOR_DEBITO CONTRACREDITO, NVL(SECTOR, '0') SECTOR, NVL(PROGRAMA, '0') PROGRAMA, NVL(SUBPROGRAMA, '0') SUBPROGRAMA, NVL(COD_PROD_CUIPO, '0') CODIGOPRODUCTO, NVL(CODIGO_BPIN, '0') CODIGOBPIN, NVL(CODIGO_CCPET, '0') CODIGOCCPET, NVL(CODIGO_CPC, '0') CODIGOCPCDANE, NVL(CODIGOUNIDADEJE, '0') CODIGOUNIDADEJE, NVL(FUENTE_CUIPO, '0') CODIGOFUENTE, NVL(CODIGOCCPETREGA, '0') CODIGOCCPETREGA, NVL(POLITICA_PUBLICA, '0') POLITICAPUBLICA, NVL(DETALLE_SECTORIAL, '0') DETALLESECTORIAL FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE IN (SELECT CODIGO FROM TIPO_COMPROBANTE WHERE CLASE_CONTABLE = 'I') AND ( ( SECTOR IS NULL OR SECTOR IN ( '' ) ) OR ( PROGRAMA IS NULL OR PROGRAMA IN ( '' ) ) OR ( SUBPROGRAMA IS NULL OR SUBPROGRAMA IN ( '' ) ) OR ( COD_PROD_CUIPO IS NULL OR COD_PROD_CUIPO IN ( '' ) ) OR ( CODIGO_BPIN IS NULL OR CODIGO_BPIN IN ( '' ) ) OR ( CODIGO_CCPET IS NULL OR CODIGO_CCPET IN ( '' ) ) OR ( CODIGO_CPC IS NULL OR CODIGO_CPC IN ( '' ) ) OR ( CODIGOUNIDADEJE IS NULL OR CODIGOUNIDADEJE IN ( '' ) ) OR ( FUENTE_CUIPO IS NULL OR FUENTE_CUIPO IN ( '' ) ) OR ( CODIGOCCPETREGA IS NULL OR CODIGOCCPETREGA IN ( '' ) ) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CUENTA":"$CUENTA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","VALOR_CREDITO":"$VALOR_CREDITO","CONTRACREDITO":"$CONTRACREDITO","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITICAPUBLICA":"$POLITICAPUBLICA","DETALLESECTORIAL":"$DETALLESECTORIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/getinformemovimientospptalingresoscuipo">
		<call-query href="getDetallescomprobantepptalGetinformemovimientospptalingresoscuipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

