	<query id="getDetallescomprobantepptalNumConfiguracionCuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO,(TO_CHAR(DETALLE_COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, SUBSTR(COMPROBANTE_PPTAL.DESCRIPCION,0,50) DESCRIPCION, TERCERO.NIT, TERCERO.NOMBRE, DETALLE_COMPROBANTE_PPTAL.CUENTA, SUBSTR(CONCAT( PLAN_PRESUPUESTAL.NOMBRE, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_TER &lt;&gt; 0 THEN CONCAT( '/', TERCERO.NOMBRE ) ELSE NULL END, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_GEN &lt;&gt; 0 THEN CONCAT( '/', AUXILIAR.NOMBRE ) ELSE NULL END, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_CEN_CTO &lt;&gt; 0 THEN CONCAT( '/', CENTRO_COSTO.NOMBRE ) ELSE NULL END, CONCAT( CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_REF &lt;&gt; 0 THEN CONCAT( '/', REFERENCIA.NOMBRE ) ELSE NULL END, CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_FUE &lt;&gt; 0 THEN CONCAT( '/', FUENTE_RECURSOS.NOMBRE ) ELSE NULL END ) ) ) ) ) ,0,50) CUENTANOMBRE, DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, DETALLE_COMPROBANTE_PPTAL.REFERENCIA, DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO, DETALLE_COMPROBANTE_PPTAL.AUXILIAR, DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO CREDITO, DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO CONTRACREDITO, DETALLE_COMPROBANTE_PPTAL.SECTOR, DETALLE_COMPROBANTE_PPTAL.PROGRAMA, DETALLE_COMPROBANTE_PPTAL.SUBPROGRAMA, DETALLE_COMPROBANTE_PPTAL.COD_PROD_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET, DETALLE_COMPROBANTE_PPTAL.CODIGO_CPC, DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE, DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGOCCPETREGA, DETALLE_COMPROBANTE_PPTAL.POLITICA_PUBLICA, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, DETALLE_COMPROBANTE_PPTAL.RECURSO_SGR FROM COMPROBANTE_PPTAL INNER JOIN DETALLE_COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COMPROBANTE_PPTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = COMPROBANTE_PPTAL.TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = COMPROBANTE_PPTAL.NUMERO INNER JOIN TIPO_COMPROBPP ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COMPROBANTE_PPTAL.TIPO = TIPO_COMPROBPP.CODIGO LEFT JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = PLAN_PRESUPUESTAL.CODIGO LEFT JOIN AUXILIAR ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = AUXILIAR.ANO AND CASE WHEN MAN_AUX_GEN IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.AUXILIAR END = AUXILIAR.CODIGO LEFT JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = CENTRO_COSTO.ANO AND CASE WHEN MAN_CEN_CTO IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO END = CENTRO_COSTO.CODIGO LEFT JOIN REFERENCIA ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = REFERENCIA.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = REFERENCIA.ANO AND CASE WHEN MAN_AUX_REF IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.REFERENCIA END = REFERENCIA.CODIGO LEFT JOIN FUENTE_RECURSOS ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = FUENTE_RECURSOS.ANO AND CASE WHEN MAN_AUX_FUE IN ( 0 ) THEN '99999999999999999999' ELSE DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO END = FUENTE_RECURSOS.CODIGO INNER JOIN TERCERO TERCERO ON COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANO AND EXTRACT(MONTH FROM DETALLE_COMPROBANTE_PPTAL.FECHA) BETWEEN :TRIMESTRE - 2 AND :TRIMESTRE AND CASE WHEN :NATURALEZA = 'C' THEN DETALLE_COMPROBANTE_PPTAL.NATURALEZA WHEN :NATURALEZA = 'D' THEN DETALLE_COMPROBANTE_PPTAL.NATURALEZA ELSE '1' END = CASE WHEN :NATURALEZA = 'C' THEN 'C' WHEN :NATURALEZA = 'D' THEN 'D' ELSE '1' END AND INSTR(:CLASE, CONCAT( CONCAT(',', TIPO_COMPROBPP.CLASE), ',')) &gt; 0 ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPROBANTE DESC, CONSECUTIVO) INI WHERE (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN CUENTANOMBRE IS NULL THEN ' ' ELSE UPPER(CUENTANOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTANOMBRE), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN CREDITO IS NULL THEN ' ' ELSE UPPER(CREDITO) END) LIKE UPPER(CONCAT(:CREDITO, '%')) AND (CASE WHEN CONTRACREDITO IS NULL THEN ' ' ELSE UPPER(CONTRACREDITO) END) LIKE UPPER(CONCAT(:CONTRACREDITO, '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(:SECTOR, '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMA), '%')) AND (CASE WHEN SUBPROGRAMA IS NULL THEN ' ' ELSE UPPER(SUBPROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:SUBPROGRAMA), '%')) AND (CASE WHEN COD_PROD_CUIPO IS NULL THEN ' ' ELSE UPPER(COD_PROD_CUIPO) END) LIKE UPPER(CONCAT(:COD_PROD_CUIPO, '%')) AND (CASE WHEN CODIGO_BPIN IS NULL THEN ' ' ELSE UPPER(CODIGO_BPIN) END) LIKE UPPER(CONCAT(:CODIGO_BPIN, '%')) AND (CASE WHEN CODIGO_CCPET IS NULL THEN ' ' ELSE UPPER(CODIGO_CCPET) END) LIKE UPPER(CONCAT(:CODIGO_CCPET, '%')) AND (CASE WHEN CODIGO_CPC IS NULL THEN ' ' ELSE UPPER(CODIGO_CPC) END) LIKE UPPER(CONCAT(:CODIGO_CPC, '%')) AND (CASE WHEN CODIGOUNIDADEJE IS NULL THEN ' ' ELSE UPPER(CODIGOUNIDADEJE) END) LIKE UPPER(CONCAT(:CODIGOUNIDADEJE, '%')) AND (CASE WHEN FUENTE_CUIPO IS NULL THEN ' ' ELSE UPPER(FUENTE_CUIPO) END) LIKE UPPER(CONCAT(:FUENTE_CUIPO, '%')) AND (CASE WHEN CODIGOCCPETREGA IS NULL THEN ' ' ELSE UPPER(CODIGOCCPETREGA) END) LIKE UPPER(CONCAT(:CODIGOCCPETREGA, '%')) AND (CASE WHEN POLITICA_PUBLICA IS NULL THEN ' ' ELSE UPPER(POLITICA_PUBLICA) END) LIKE UPPER(CONCAT(:POLITICA_PUBLICA, '%')) AND (CASE WHEN DETALLE_SECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLE_SECTORIAL) END) LIKE UPPER(CONCAT(:DETALLE_SECTORIAL, '%')) AND (CASE WHEN RECURSO_SGR IS NULL THEN ' ' ELSE UPPER(RECURSO_SGR) END) LIKE UPPER(CONCAT(:RECURSO_SGR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TRIMESTRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
