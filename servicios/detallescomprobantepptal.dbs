	</resource>
	<query id="getDetallescomprobantepptalGetclasificanoconfigcuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT DPPT.COMPANIA, DPPT.ANO, DPPT.TIPO_CPTE, DPPT.COMPROBANTE, DPPT.CUENTA, dppt.consecutivo, dppt.fecha, dppt.valor_credito, dppt.valor_debito contracredito, NVL( CASE WHEN TC1.COMPANIA IS NULL AND DPPT.SECTOR IS NOT NULL THEN DPPT.SECTOR ELSE '0' END, '0' ) SECTOR, NVL( CASE WHEN TC2.COMPANIA IS NULL AND DPPT.PROGRAMA IS NOT NULL THEN DPPT.PROGRAMA ELSE '0' END, '0' ) PROGRAMA, NVL( CASE WHEN TC3.COMPANIA IS NULL AND DPPT.SUBPROGRAMA IS NOT NULL THEN DPPT.SUBPROGRAMA ELSE '0' END, '0' ) SUBPROGRAMA, NVL( CASE WHEN TC4.COMPANIA IS NULL AND DPPT.COD_PROD_CUIPO IS NOT NULL THEN DPPT.COD_PROD_CUIPO ELSE '0' END, '0' ) CODIGOPRODUCTO, NVL( CASE WHEN TC5.COMPANIA IS NULL AND DPPT.CODIGO_BPIN IS NOT NULL THEN DPPT.CODIGO_BPIN ELSE '0' END, '0' ) CODIGOBPIN, NVL( CASE WHEN TC6.COMPANIA IS NULL AND DPPT.CODIGO_CCPET IS NOT NULL THEN DPPT.CODIGO_CCPET ELSE '0' END, '0' ) CODIGOCCPET, NVL( CASE WHEN TC7.COMPANIA IS NULL AND DPPT.CODIGO_CPC IS NOT NULL THEN DPPT.CODIGO_CPC ELSE '0' END, '0' ) CODIGOCPCDANE, NVL( CASE WHEN TC8.COMPANIA IS NULL AND DPPT.CODIGOUNIDADEJE IS NOT NULL THEN DPPT.CODIGOUNIDADEJE ELSE '0' END, '0' ) CODIGOUNIDADEJE, NVL( CASE WHEN TC9.COMPANIA IS NULL AND DPPT.FUENTE_CUIPO IS NOT NULL THEN DPPT.FUENTE_CUIPO ELSE '0' END, '0' ) CODIGOFUENTE, NVL( CASE WHEN TC10.COMPANIA IS NULL AND DPPT.CODIGOCCPETREGA IS NOT NULL THEN DPPT.CODIGOCCPETREGA ELSE '0' END, '0' ) CODIGOCCPETREGA, nvl( CASE WHEN tc11.compania IS NULL AND dppt.POLITICA_PUBLICA is not null then dppt.POLITICA_PUBLICA else '0' end, '0') politicapublica, nvl( CASE WHEN tc12.compania is null AND dppt.detalle_sectorial is not null then dppt.DETALLE_SECTORIAL else '0' end, '0') detallesectorial FROM DETALLE_COMPROBANTE_PPTAL DPPT LEFT JOIN TIPOCLASIFICADOR TC1 ON DPPT.COMPANIA = TC1.COMPANIA AND DPPT.ANO = TC1.ANO AND DPPT.SECTOR = TC1.CODIGO AND '001' = TC1.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC2 ON DPPT.COMPANIA = TC2.COMPANIA AND DPPT.ANO = TC2.ANO AND DPPT.PROGRAMA = TC2.CODIGO AND '002' = TC2.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC3 ON DPPT.COMPANIA = TC3.COMPANIA AND DPPT.ANO = TC3.ANO AND DPPT.SUBPROGRAMA = TC3.CODIGO AND '003' = TC3.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC4 ON DPPT.COMPANIA = TC4.COMPANIA AND DPPT.ANO = TC4.ANO AND DPPT.COD_PROD_CUIPO = TC4.CODIGO AND '004' = TC4.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC5 ON DPPT.COMPANIA = TC5.COMPANIA AND DPPT.ANO = TC5.ANO AND DPPT.CODIGO_BPIN = TC5.CODIGO AND '005' = TC5.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC6 ON DPPT.COMPANIA = TC6.COMPANIA AND DPPT.ANO = TC6.ANO AND DPPT.CODIGO_CCPET = TC6.CODIGO AND '006' = TC6.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC7 ON DPPT.COMPANIA = TC7.COMPANIA AND DPPT.ANO = TC7.ANO AND DPPT.CODIGO_CPC = TC7.CODIGO AND '007' = TC7.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC8 ON DPPT.COMPANIA = TC8.COMPANIA AND DPPT.ANO = TC8.ANO AND DPPT.CODIGOUNIDADEJE = TC8.CODIGO AND '008' = TC8.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC9 ON DPPT.COMPANIA = TC9.COMPANIA AND DPPT.ANO = TC9.ANO AND DPPT.FUENTE_CUIPO = TC9.CODIGO AND '009' = TC9.CLASECLASIFICADOR LEFT JOIN TIPOCLASIFICADOR TC10 ON DPPT.COMPANIA = TC10.COMPANIA AND DPPT.ANO = TC10.ANO AND DPPT.CODIGOCCPETREGA = TC10.CODIGO AND '010' = TC10.CLASECLASIFICADOR LEFT JOIN tipoclasificador tc11 ON dppt.compania = tc11.compania AND dppt.ano = tc11.ano AND dppt.codigoccpetrega = tc11.codigo AND '011' = tc11.claseclasificador LEFT JOIN tipoclasificador tc12 ON dppt.compania = tc12.compania AND dppt.ano = tc12.ano AND dppt.codigoccpetrega = tc12.codigo AND '012' = tc12.claseclasificador WHERE DPPT.COMPANIA = :COMPANIA AND DPPT.ANO = :ANO AND ( ( TC1.COMPANIA IS NULL AND DPPT.SECTOR IS NOT NULL ) OR ( TC2.COMPANIA IS NULL AND DPPT.PROGRAMA IS NOT NULL ) OR ( TC3.COMPANIA IS NULL AND DPPT.SUBPROGRAMA IS NOT NULL ) OR ( TC4.COMPANIA IS NULL AND DPPT.COD_PROD_CUIPO IS NOT NULL ) OR ( TC5.COMPANIA IS NULL AND DPPT.CODIGO_BPIN IS NOT NULL ) OR ( TC6.COMPANIA IS NULL AND DPPT.CODIGO_CCPET IS NOT NULL ) OR ( TC7.COMPANIA IS NULL AND DPPT.CODIGO_CPC IS NOT NULL ) OR ( TC8.COMPANIA IS NULL AND DPPT.CODIGOUNIDADEJE IS NOT NULL ) OR ( TC9.COMPANIA IS NULL AND DPPT.FUENTE_CUIPO IS NOT NULL ) OR ( TC10.COMPANIA IS NULL AND DPPT.CODIGOCCPETREGA IS NOT NULL ) OR ( tc11.compania IS NULL AND dppt.politica_publica is not null) OR ( tc12.compania IS NULL AND dppt.detalle_sectorial is not null))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CUENTA":"$CUENTA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","VALOR_CREDITO":"$VALOR_CREDITO","CONTRACREDITO":"$CONTRACREDITO","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOBPIN":"$CODIGOBPIN","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITICAPUBLICA":"$POLITICAPUBLICA","DETALLESECTORIAL":"$DETALLESECTORIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/getclasificanoconfigcuipo">
		<call-query href="getDetallescomprobantepptalGetclasificanoconfigcuipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
