	<query id="getDetallescomprobantepptalPagCptesAfectadosPorAnioTipoCuentaYFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(COMPROBANTE,CONSECUTIVO) ID, COMPROBANTE, (CASE NATURALEZA WHEN 'D' THEN VALOR_DEBITO - VALOR_CREDITO - (DEBITO_AFECTADO - CREDITO_AFECTADO) + (MODIFICACION_DEBITO - MODIFICACION_CREDITO) ELSE VALOR_CREDITO - VALOR_DEBITO - (CREDITO_AFECTADO - DEBITO_AFECTADO) + (MODIFICACION_CREDITO - MODIFICACION_DEBITO) END) AS VALOR, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, DESCRIPCION, CONSECUTIVO, NATURALEZA FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPO AND CUENTA = :CUENTA AND FECHA &lt;= :FECHA_DET AND (CASE WHEN :AFECTACION &lt;&gt; 'A' THEN VALOR_CREDITO - VALOR_DEBITO - (CREDITO_AFECTADO - DEBITO_AFECTADO) + (MODIFICACION_CREDITO - MODIFICACION_DEBITO) ELSE 1 END) &lt;&gt; 0 AND (CASE WHEN (:AFECTACION &lt;&gt; 'A' AND :CLASECOMPROBANTE NOT IN('DIN','DIC')) THEN CENTRO_COSTO ELSE :CENTRO_COSTO END) = :CENTRO_COSTO AND (CASE WHEN (:AFECTACION &lt;&gt; 'A' AND :CLASECOMPROBANTE NOT IN('DIN','DIC')) THEN AUXILIAR ELSE :AUXILIAR END) = :AUXILIAR AND (CASE WHEN (:AFECTACION &lt;&gt; 'A' AND :CLASECOMPROBANTE NOT IN('DIN','DIC')) THEN REFERENCIA ELSE :REFERENCIA END) = :REFERENCIA AND (CASE WHEN (:AFECTACION &lt;&gt; 'A' AND :CLASECOMPROBANTE NOT IN('DIN','DIC')) THEN FUENTE_RECURSO ELSE :FUENTE_RECURSO END) = :FUENTE_RECURSO AND (CASE WHEN :FILTRA_TERCERO = 'SI' THEN TERCERO ELSE :TERCERO END) = :TERCERO AND (CASE WHEN :FILTRA_TERCERO = 'SI' THEN SUCURSAL ELSE :SUCURSAL END) = :SUCURSAL ORDER BY COMPROBANTE, CONSECUTIVO) INI WHERE (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPROBANTE":"$COMPROBANTE(type:long)","VALOR":"$VALOR(type:double)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","CONSECUTIVO":"$CONSECUTIVO(type:integer)","NATURALEZA":"$NATURALEZA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="FECHA_DET" sqlType="STRING"/>
		<param name="AFECTACION" sqlType="STRING"/>
		<param name="CLASECOMPROBANTE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="FILTRA_TERCERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
