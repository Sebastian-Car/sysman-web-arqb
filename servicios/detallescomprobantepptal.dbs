	<query id="getDetallescomprobantepptalTodosPorCuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT LISTAGG(PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE,', ') WITHIN GROUP( ORDER BY DC.COMPANIA, DC.ANO, DC.TIPO_CPTE, DC.COMPROBANTE) LISTADO FROM DETALLE_COMPROBANTE_PPTAL DC INNER JOIN DETALLE_COMPROBANTE_PPTAL DC1 ON DC.COMPANIA = DC1.COMPANIA AND DC.ANO = DC1.ANO AND DC.TIPO_CPTE_AFECT = DC1.TIPO_CPTE AND DC.CMPTE_AFECTADO = DC1.COMPROBANTE AND DC.CONSECUTIVOPPTO = DC1.CONSECUTIVO INNER JOIN DETALLE_COMPROBANTE_PPTAL DC2 ON DC1.COMPANIA = DC2.COMPANIA AND DC1.ANO = DC2.ANO AND DC1.TIPO_CPTE_AFECT = DC2.TIPO_CPTE AND DC1.CMPTE_AFECTADO = DC2.COMPROBANTE AND DC1.CONSECUTIVOPPTO = DC2.CONSECUTIVO INNER JOIN PLAN_PPTAL_CUENTACNT ON DC.COMPANIA = PLAN_PPTAL_CUENTACNT.COMPANIA AND DC.ANO = PLAN_PPTAL_CUENTACNT.ANO AND DC.CUENTA = PLAN_PPTAL_CUENTACNT.CUENTA_CONTABLE INNER JOIN PLAN_PRESUPUESTAL ON PLAN_PPTAL_CUENTACNT.RUBRO = PLAN_PRESUPUESTAL.CODIGO AND PLAN_PPTAL_CUENTACNT.ANO = PLAN_PRESUPUESTAL.ANO AND PLAN_PPTAL_CUENTACNT.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND DC.ANO = :ANO AND DC.TIPO_CPTE = :TIPOCOMPROBANTE AND DC.COMPROBANTE = :COMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LISTADO":"$LISTADO"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallescomprobantepptal/todosporcuentas">
		<call-query href="getDetallescomprobantepptalTodosPorCuentasQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="getDetallescomprobantepptalExistecomprobantepptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT (1) CANTIDAD FROM DETALLE_COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_CPTE = :TIPOCOMPROBANTE AND COMPROBANTE = :NUMEROCOMPROBANTE</sql>
