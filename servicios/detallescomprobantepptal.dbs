	<query id="getDetallescomprobantepptalTodosPorCompaniaAnoTipoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, DETALLE_COMPROBANTE_PPTAL.CUENTA,(TO_CHAR(DETALLE_COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_PPTAL.NATURALEZA, DETALLE_COMPROBANTE_PPTAL.TERCERO, DETALLE_COMPROBANTE_PPTAL.SUCURSAL, DETALLE_COMPROBANTE_PPTAL.DESCRIPCION, DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO, DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO, DETALLE_COMPROBANTE_PPTAL.TIPO_DOCUMENTO, DETALLE_COMPROBANTE_PPTAL.NRO_DOCUMENTO, DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, DETALLE_COMPROBANTE_PPTAL.AUXILIAR,(CASE DETALLE_COMPROBANTE_PPTAL.CONTRACTUAL WHEN 0 THEN 'false' ELSE 'true' END) CONTRACTUAL,(CASE DETALLE_COMPROBANTE_PPTAL.PAPELES WHEN 0 THEN 'false' ELSE 'true' END) PAPELES, DETALLE_COMPROBANTE_PPTAL.REFERENCIA, COMPROBANTE_PPTAL.TERCERO AS TERCEROH, COMPROBANTE_PPTAL.SUCURSAL AS SUCURSALH FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COMPROBANTE_PPTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = COMPROBANTE_PPTAL.TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = COMPROBANTE_PPTAL.NUMERO WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA =:COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO =:ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE =:TIPO AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE =:NUMERO ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","FECHA":"$FECHA","NATURALEZA":"$NATURALEZA","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","DESCRIPCION":"$DESCRIPCION","VALOR_DEBITO":"$VALOR_DEBITO","VALOR_CREDITO":"$VALOR_CREDITO","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","CONTRACTUAL":"$CONTRACTUAL(type:boolean)","PAPELES":"$PAPELES(type:boolean)","REFERENCIA":"$REFERENCIA","TERCEROH":"$TERCEROH","SUCURSALH":"$SUCURSALH"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
