	<query id="updateEvcompromisoslaborales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_COMPROMISOS_LABORALES SET CEDULA_EVALUADO=:CEDULA_EVALUADO, SUCURSAL_EVALUADO=:SUCURSAL_EVALUADO, CEDULA_EVALUADOR=:CEDULA_EVALUADOR, SUCURSAL_EVALUADOR=:SUCURSAL_EVALUADOR, ID_COMPETENCIA=:ID_COMPETENCIA, VERSION=:VERSION, DEPENDENCIA=:DEPENDENCIA, CODIGO_META=:CODIGO_META, COMPROMISO=:COMPROMISO, PLANTILLA=:PLANTILLA, PESO_PORCENTUAL=:PESO_PORCENTUAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), TIPO_COMPETENCIA=:TIPO_COMPETENCIA, NUMERO_MANUAL=:NUMERO_MANUAL WHERE EV_COMPROMISOS_LABORALES.COMPANIA= :KEY_COMPANIA AND EV_COMPROMISOS_LABORALES.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_COMPROMISOS_LABORALES.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_COMPROMISOS_LABORALES.ANO= :KEY_ANO AND EV_COMPROMISOS_LABORALES.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_COMPROMISOS_LABORALES.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND EV_COMPROMISOS_LABORALES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
