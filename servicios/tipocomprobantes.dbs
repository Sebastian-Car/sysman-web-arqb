	<query id="getTipocomprobantesPagTodosCodigoNombreNiiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE,(CASE EXCLUIR_NIIF WHEN 0 THEN 'false' ELSE 'true' END) EXCLUIR_NIIF,(CASE APLICA_NIIF WHEN 0 THEN 'false' ELSE 'true' END) APLICA_NIIF FROM TIPO_COMPROBANTE WHERE COMPANIA=:COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN EXCLUIR_NIIF IS NULL THEN ' ' ELSE UPPER(EXCLUIR_NIIF) END)  LIKE UPPER( '%' || :EXCLUIR_NIIF || '%')  AND (CASE WHEN APLICA_NIIF IS NULL THEN ' ' ELSE UPPER(APLICA_NIIF) END)  LIKE UPPER( '%' || :APLICA_NIIF || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","EXCLUIR_NIIF":"$EXCLUIR_NIIF(type:boolean)","APLICA_NIIF":"$APLICA_NIIF(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="EXCLUIR_NIIF" sqlType="STRING"/>
		<param name="APLICA_NIIF" sqlType="STRING"/>
