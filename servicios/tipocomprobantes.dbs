<data name="tipocomprobantes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipocomprobantesPagPorCompaniaTipoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE  FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CODIGO &gt;= :TIPOINICIAL ORDER BY TIPO_COMPROBANTE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantes/porcompaniatipofinal/pag">
		<call-query href="getTipocomprobantesPagPorCompaniaTipoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesNumPorCompaniaTipoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE  FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CODIGO &gt;= :TIPOINICIAL ORDER BY TIPO_COMPROBANTE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/porcompaniatipofinal/num">
		<call-query href="getTipocomprobantesNumPorCompaniaTipoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesPagPorCompaniaTipoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA ORDER BY TIPO_COMPROBANTE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantes/porcompaniatipoinicial/pag">
		<call-query href="getTipocomprobantesPagPorCompaniaTipoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesNumPorCompaniaTipoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA ORDER BY TIPO_COMPROBANTE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/porcompaniatipoinicial/num">
		<call-query href="getTipocomprobantesNumPorCompaniaTipoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesPagTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, FORMATO, CLASE_CONTABLE  FROM TIPO_COMPROBANTE WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FORMATO":"$FORMATO","CLASE_CONTABLE":"$CLASE_CONTABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantes/todos/pag">
		<call-query href="getTipocomprobantesPagTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesNumTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, FORMATO, CLASE_CONTABLE  FROM TIPO_COMPROBANTE WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/todos/num">
		<call-query href="getTipocomprobantesNumTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesPagPorClasecontableQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CLASE_CONTABLE = :CLASECONTABLE ORDER BY TIPO_COMPROBANTE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASECONTABLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantes/porclasecontable/pag">
		<call-query href="getTipocomprobantesPagPorClasecontableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASECONTABLE" query-param="CLASECONTABLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertTipocomprobantes" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPO_COMPROBANTE (COMPANIA, CODIGO, NOMBRE, TIPO_DOCUMENTO, CLASE_CONTABLE, FORMATO, COMPRELACIONADO, PIDE_RETENCION, OBLIGA_AFECT_PPTAL, TIPO_CRUCECUENTAS, IND_REPORTAR_1001, TIPO_RECAUDO, ARCHIVO_CENTRAL, ARCHIVO_GESTION, DISPOSICION_FINAL, NUMERO_DOCUMENTO, DOCSOPORTE, NOTAAJUSTE_CUDS, ESTAMPILLA_SIGEC, LEGALIZACION, FORMATO_5247, REINTEGRO, ANTICIPO, TIPO_ANTICIPO, CRUCE_ANTICIPO, GENERA_CTE_PPTAL_MASIVO, EXCLUIR_CER_DIAN, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :TIPO_DOCUMENTO, :CLASE_CONTABLE, :FORMATO, :COMPRELACIONADO, :PIDE_RETENCION, :OBLIGA_AFECT_PPTAL, :TIPO_CRUCECUENTAS, :IND_REPORTAR_1001, :TIPO_RECAUDO, :ARCHIVO_CENTRAL, :ARCHIVO_GESTION, :DISPOSICION_FINAL, :NUMERO_DOCUMENTO, :DOCSOPORTE, :NOTAAJUSTE_CUDS, :ESTAMPILLA_SIGEC, :LEGALIZACION, :FORMATO_5247, :REINTEGRO, :ANTICIPO, :TIPO_ANTICIPO, :CRUCE_ANTICIPO, :GENERA_CTE_PPTAL_MASIVO, :EXCLUIR_CER_DIAN, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="CLASE_CONTABLE" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO" sqlType="STRING"/>
		<param defaultValue="" name="COMPRELACIONADO" sqlType="STRING"/>
		<param defaultValue="0" name="PIDE_RETENCION" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGA_AFECT_PPTAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CRUCECUENTAS" sqlType="STRING"/>
		<param defaultValue="0" name="IND_REPORTAR_1001" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_RECAUDO" sqlType="STRING"/>
		<param defaultValue="" name="ARCHIVO_CENTRAL" sqlType="STRING"/>
		<param defaultValue="" name="ARCHIVO_GESTION" sqlType="STRING"/>
		<param defaultValue="" name="DISPOSICION_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="NUMERO_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="DOCSOPORTE" sqlType="STRING"/>
		<param defaultValue="0" name="NOTAAJUSTE_CUDS" sqlType="STRING"/>
		<param defaultValue="0" name="ESTAMPILLA_SIGEC" sqlType="STRING"/>
		<param defaultValue="0" name="LEGALIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="FORMATO_5247" sqlType="STRING"/>
		<param defaultValue="0" name="REINTEGRO" sqlType="STRING"/>
		<param defaultValue="0" name="ANTICIPO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_ANTICIPO" sqlType="STRING"/>
		<param defaultValue="0" name="CRUCE_ANTICIPO" sqlType="STRING"/>
		<param defaultValue="0" name="GENERA_CTE_PPTAL_MASIVO" sqlType="STRING"/>
		<param defaultValue="0" name="EXCLUIR_CER_DIAN" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tipocomprobantes">
		<call-query href="insertTipocomprobantes">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_DOCUMENTO" query-param="TIPO_DOCUMENTO"/>
			<with-param name="CLASE_CONTABLE" query-param="CLASE_CONTABLE"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="COMPRELACIONADO" query-param="COMPRELACIONADO"/>
			<with-param name="PIDE_RETENCION" query-param="PIDE_RETENCION"/>
			<with-param name="OBLIGA_AFECT_PPTAL" query-param="OBLIGA_AFECT_PPTAL"/>
			<with-param name="TIPO_CRUCECUENTAS" query-param="TIPO_CRUCECUENTAS"/>
			<with-param name="IND_REPORTAR_1001" query-param="IND_REPORTAR_1001"/>
			<with-param name="TIPO_RECAUDO" query-param="TIPO_RECAUDO"/>
			<with-param name="ARCHIVO_CENTRAL" query-param="ARCHIVO_CENTRAL"/>
			<with-param name="ARCHIVO_GESTION" query-param="ARCHIVO_GESTION"/>
			<with-param name="DISPOSICION_FINAL" query-param="DISPOSICION_FINAL"/>
			<with-param name="NUMERO_DOCUMENTO" query-param="NUMERO_DOCUMENTO"/>
			<with-param name="DOCSOPORTE" query-param="DOCSOPORTE"/>
			<with-param name="NOTAAJUSTE_CUDS" query-param="NOTAAJUSTE_CUDS"/>
			<with-param name="ESTAMPILLA_SIGEC" query-param="ESTAMPILLA_SIGEC"/>
			<with-param name="LEGALIZACION" query-param="LEGALIZACION"/>
			<with-param name="FORMATO_5247" query-param="FORMATO_5247"/>
			<with-param name="REINTEGRO" query-param="REINTEGRO"/>
			<with-param name="ANTICIPO" query-param="ANTICIPO"/>
			<with-param name="TIPO_ANTICIPO" query-param="TIPO_ANTICIPO"/>
			<with-param name="CRUCE_ANTICIPO" query-param="CRUCE_ANTICIPO"/>
			<with-param name="GENERA_CTE_PPTAL_MASIVO" query-param="GENERA_CTE_PPTAL_MASIVO"/>
			<with-param name="EXCLUIR_CER_DIAN" query-param="EXCLUIR_CER_DIAN"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTipocomprobantes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA= :KEY_COMPANIA AND TIPO_COMPROBANTE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tipocomprobantes">
		<call-query href="deleteTipocomprobantes">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPO_COMPROBANTE.COMPANIA, TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE, TIPO_COMPROBANTE.TIPO_DOCUMENTO ,CLASECNT.DESCRIPCION CLASE_CONTABLE,(CASE TIPO_COMPROBANTE.DOCSOPORTE WHEN 0 THEN 'false' ELSE 'true' END) DOCSOPORTE FROM TIPO_COMPROBANTE INNER JOIN CLASECNT ON (TIPO_COMPROBANTE.CLASE_CONTABLE=CLASECNT.CODIGO) WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASE_CONTABLE IS NULL THEN ' ' ELSE UPPER(CLASE_CONTABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CONTABLE), '%')) AND (CASE WHEN DOCSOPORTE IS NULL THEN ' ' ELSE UPPER(DOCSOPORTE) END) LIKE UPPER(CONCAT(:DOCSOPORTE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","CLASE_CONTABLE":"$CLASE_CONTABLE","DOCSOPORTE":"$DOCSOPORTE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_CONTABLE" sqlType="STRING"/>
		<param name="DOCSOPORTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipocomprobantes">
		<call-query href="getTipocomprobantesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_CONTABLE" query-param="CLASE_CONTABLE"/>
			<with-param name="DOCSOPORTE" query-param="DOCSOPORTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TIPO_COMPROBANTE.COMPANIA, TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE, TIPO_COMPROBANTE.TIPO_DOCUMENTO ,CLASECNT.DESCRIPCION CLASE_CONTABLE,(CASE TIPO_COMPROBANTE.DOCSOPORTE WHEN 0 THEN 'false' ELSE 'true' END) DOCSOPORTE FROM TIPO_COMPROBANTE INNER JOIN CLASECNT ON (TIPO_COMPROBANTE.CLASE_CONTABLE=CLASECNT.CODIGO) WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASE_CONTABLE IS NULL THEN ' ' ELSE UPPER(CLASE_CONTABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CONTABLE), '%')) AND (CASE WHEN DOCSOPORTE IS NULL THEN ' ' ELSE UPPER(DOCSOPORTE) END) LIKE UPPER(CONCAT(:DOCSOPORTE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_CONTABLE" sqlType="STRING"/>
		<param name="DOCSOPORTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/numero">
		<call-query href="getTipocomprobantesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_CONTABLE" query-param="CLASE_CONTABLE"/>
			<with-param name="DOCSOPORTE" query-param="DOCSOPORTE"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO, NOMBRE, TIPO_DOCUMENTO, CLASE_CONTABLE, FORMATO, COMPRELACIONADO,(CASE PIDE_RETENCION WHEN 0 THEN 'false' ELSE 'true' END) PIDE_RETENCION,(CASE OBLIGA_AFECT_PPTAL WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_AFECT_PPTAL, TIPO_CRUCECUENTAS,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CREATED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, MODIFIED_BY,(CASE IND_REPORTAR_1001 WHEN 0 THEN 'false' ELSE 'true' END) IND_REPORTAR_1001,TIPO_RECAUDO,ARCHIVO_CENTRAL, ARCHIVO_GESTION, DISPOSICION_FINAL,NUMERO_DOCUMENTO,(CASE TIPO_COMPROBANTE.DOCSOPORTE WHEN 0 THEN 'false' ELSE 'true' END) DOCSOPORTE,(CASE NOTAAJUSTE_CUDS WHEN 0 THEN 'false' ELSE 'true' END) NOTAAJUSTE_CUDS,(CASE ESTAMPILLA_SIGEC WHEN 0 THEN 'false' ELSE 'true' END) ESTAMPILLA_SIGEC,(CASE LEGALIZACION WHEN 0 THEN 'false' ELSE 'true' END) LEGALIZACION,(CASE FORMATO_5247 WHEN 0 THEN 'false' ELSE 'true' END) FORMATO_5247,(CASE REINTEGRO WHEN 0 THEN 'false' ELSE 'true' END) REINTEGRO,(CASE ANTICIPO WHEN 0 THEN 'false' ELSE 'true' END) ANTICIPO, TIPO_ANTICIPO,(CASE CRUCE_ANTICIPO WHEN 0 THEN 'false' ELSE 'true' END) CRUCE_ANTICIPO,(CASE GENERA_CTE_PPTAL_MASIVO WHEN 0 THEN 'false' ELSE 'true' END) GENERA_CTE_PPTAL_MASIVO,(CASE EXCLUIR_CER_DIAN WHEN 0 THEN 'false' ELSE 'true' END) EXCLUIR_CER_DIAN  FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA= :KEY_COMPANIA AND TIPO_COMPROBANTE.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","CLASE_CONTABLE":"$CLASE_CONTABLE","FORMATO":"$FORMATO","COMPRELACIONADO":"$COMPRELACIONADO","PIDE_RETENCION":"$PIDE_RETENCION(type:boolean)","OBLIGA_AFECT_PPTAL":"$OBLIGA_AFECT_PPTAL(type:boolean)","TIPO_CRUCECUENTAS":"$TIPO_CRUCECUENTAS","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","IND_REPORTAR_1001":"$IND_REPORTAR_1001(type:boolean)","TIPO_RECAUDO":"$TIPO_RECAUDO(type:integer)","ARCHIVO_CENTRAL":"$ARCHIVO_CENTRAL(type:double)","ARCHIVO_GESTION":"$ARCHIVO_GESTION(type:double)","DISPOSICION_FINAL":"$DISPOSICION_FINAL","NUMERO_DOCUMENTO":"$NUMERO_DOCUMENTO","DOCSOPORTE":"$DOCSOPORTE(type:boolean)","NOTAAJUSTE_CUDS":"$NOTAAJUSTE_CUDS(type:boolean)","ESTAMPILLA_SIGEC":"$ESTAMPILLA_SIGEC(type:boolean)","LEGALIZACION":"$LEGALIZACION(type:boolean)","FORMATO_5247":"$FORMATO_5247(type:boolean)","REINTEGRO":"$REINTEGRO(type:boolean)","ANTICIPO":"$ANTICIPO(type:boolean)","TIPO_ANTICIPO":"$TIPO_ANTICIPO","CRUCE_ANTICIPO":"$CRUCE_ANTICIPO(type:boolean)","GENERA_CTE_PPTAL_MASIVO":"$GENERA_CTE_PPTAL_MASIVO(type:boolean)","EXCLUIR_CER_DIAN":"$EXCLUIR_CER_DIAN(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/data">
		<call-query href="getTipocomprobantesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
<query id="updateTipocomprobantes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPO_COMPROBANTE SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, TIPO_DOCUMENTO=:TIPO_DOCUMENTO, CLASE_CONTABLE=:CLASE_CONTABLE, FORMATO=:FORMATO, COMPRELACIONADO=:COMPRELACIONADO, PIDE_RETENCION=:PIDE_RETENCION, OBLIGA_AFECT_PPTAL=:OBLIGA_AFECT_PPTAL, TIPO_CRUCECUENTAS=:TIPO_CRUCECUENTAS, IND_REPORTAR_1001=:IND_REPORTAR_1001, TIPO_RECAUDO=:TIPO_RECAUDO, ARCHIVO_CENTRAL=:ARCHIVO_CENTRAL, ARCHIVO_GESTION=:ARCHIVO_GESTION, DISPOSICION_FINAL=:DISPOSICION_FINAL, NUMERO_DOCUMENTO=:NUMERO_DOCUMENTO, DOCSOPORTE=:DOCSOPORTE, NOTAAJUSTE_CUDS=:NOTAAJUSTE_CUDS, ESTAMPILLA_SIGEC=:ESTAMPILLA_SIGEC, LEGALIZACION=:LEGALIZACION, FORMATO_5247=:FORMATO_5247, REINTEGRO=:REINTEGRO, ANTICIPO=:ANTICIPO, TIPO_ANTICIPO=:TIPO_ANTICIPO, CRUCE_ANTICIPO=:CRUCE_ANTICIPO, GENERA_CTE_PPTAL_MASIVO=:GENERA_CTE_PPTAL_MASIVO, EXCLUIR_CER_DIAN=:EXCLUIR_CER_DIAN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPO_COMPROBANTE.COMPANIA= :KEY_COMPANIA AND TIPO_COMPROBANTE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="CLASE_CONTABLE" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="COMPRELACIONADO" sqlType="STRING"/>
		<param name="PIDE_RETENCION" sqlType="STRING"/>
		<param name="OBLIGA_AFECT_PPTAL" sqlType="STRING"/>
		<param name="TIPO_CRUCECUENTAS" sqlType="STRING"/>
		<param name="IND_REPORTAR_1001" sqlType="STRING"/>
		<param name="TIPO_RECAUDO" sqlType="STRING"/>
		<param name="ARCHIVO_CENTRAL" sqlType="STRING"/>
		<param name="ARCHIVO_GESTION" sqlType="STRING"/>
		<param name="DISPOSICION_FINAL" sqlType="STRING"/>
		<param name="NUMERO_DOCUMENTO" sqlType="STRING"/>
		<param name="DOCSOPORTE" sqlType="STRING"/>
		<param name="NOTAAJUSTE_CUDS" sqlType="STRING"/>
		<param name="ESTAMPILLA_SIGEC" sqlType="STRING"/>
		<param name="LEGALIZACION" sqlType="STRING"/>
		<param name="FORMATO_5247" sqlType="STRING"/>
		<param name="REINTEGRO" sqlType="STRING"/>
		<param name="ANTICIPO" sqlType="STRING"/>
		<param name="TIPO_ANTICIPO" sqlType="STRING"/>
		<param name="CRUCE_ANTICIPO" sqlType="STRING"/>
		<param name="GENERA_CTE_PPTAL_MASIVO" sqlType="STRING"/>
		<param name="EXCLUIR_CER_DIAN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipocomprobantes">
