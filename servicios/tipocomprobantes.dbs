	<query id="updateTipocomprobantesExcluirYAplicaNiifPorCodigo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPO_COMPROBANTE SET EXCLUIR_NIIF=:EXCLUIR_NIIF, APLICA_NIIF=:APLICA_NIIF, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPO_COMPROBANTE.COMPANIA= :KEY_COMPANIA AND TIPO_COMPROBANTE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="EXCLUIR_NIIF" sqlType="STRING"/>
		<param name="APLICA_NIIF" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipocomprobantes/excluiryaplicaniifporcodigo">
		<call-query href="updateTipocomprobantesExcluirYAplicaNiifPorCodigo">
			<with-param name="EXCLUIR_NIIF" query-param="EXCLUIR_NIIF"/>
			<with-param name="APLICA_NIIF" query-param="APLICA_NIIF"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesTodosPorTipomovQuery"  useConfig="sysmandsunist">
		<sql>SELECT TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE, TIPO_COMPROBANTE.CLASE_CONTABLE, TIPO_COMPROBANTE.FORMATO, TIPO_COMPROBANTE.COMPRELACIONADO,(CASE TIPO_COMPROBANTE.PIDE_RETENCION WHEN 0 THEN 'false' ELSE 'true' END) PIDE_RETENCION, TIPO_COMPROBANTE.TIPO_CRUCECUENTAS,(CASE TIPO_COMPROBANTE.ANTICIPO WHEN 0 THEN 'false' ELSE 'true' END) ANTICIPO FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CODIGO = :TIPOMOVIMIENTO ORDER BY TIPO_COMPROBANTE.COMPANIA, TIPO_COMPROBANTE.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE_CONTABLE":"$CLASE_CONTABLE","FORMATO":"$FORMATO","COMPRELACIONADO":"$COMPRELACIONADO","PIDE_RETENCION":"$PIDE_RETENCION(type:boolean)","TIPO_CRUCECUENTAS":"$TIPO_CRUCECUENTAS","ANTICIPO":"$ANTICIPO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/todosportipomov">
		<call-query href="getTipocomprobantesTodosPorTipomovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesExistePorTipomovQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' X  FROM TIPO_COMPROBANTE INNER JOIN CLASECNT ON TIPO_COMPROBANTE.CLASE_CONTABLE = CLASECNT.CODIGO WHERE TIPO_COMPROBANTE.COMPANIA =:COMPANIA AND TIPO_COMPROBANTE.CODIGO =:TIPOMOVIMIENTO AND CLASECNT.CLASETIPOPPTAL IS NOT NULL ORDER BY TIPO_COMPROBANTE.COMPANIA, TIPO_COMPROBANTE.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/existeportipomov">
		<call-query href="getTipocomprobantesExistePorTipomovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesValordocumentoPorAnoTipomovNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ABS(SUM(NVL(VALOR_DEBITO,0)) - SUM(NVL(VALOR_CREDITO,0))) AS VALORDOCUMENTO  FROM TIPO_COMPROBANTE INNER JOIN DETALLE_COMPROBANTE_PPTAL ON (TIPO_COMPROBANTE.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND TIPO_COMPROBANTE.CODIGO = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND TIPO_COMPROBANTE.OBLIGA_AFECT_PPTAL NOT IN 0) WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO =:ANO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = :TIPOMOVIMIENTO AND COMPROBANTE =:NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORDOCUMENTO":"$VALORDOCUMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/valordocumentoporanotipomovnumero">
