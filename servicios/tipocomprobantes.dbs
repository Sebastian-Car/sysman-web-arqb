	<query id="getTipocomprobantesGetclasedocsoporteelectronicoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CASE WHEN (TIPO_COMPROBANTE.DOCSOPORTE NOT IN (0) AND TIPO_COMPROBANTE.NOTAAJUSTE_CUDS IN (0)) THEN '05' ELSE '06' END CLASE FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CODIGO = :TIPOMOVIMIENTO</sql>
