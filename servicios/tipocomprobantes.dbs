	<query id="getTipocomprobantesPagPoranioytipofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.TIPO, TO_CHAR(COMPROBANTE_CNT.FECHA ,'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.DESCRIPCION  FROM TIPO_COMPROBANTE INNER JOIN COMPROBANTE_CNT ON TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNT.COMPANIA AND TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNT.TIPO WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND COMPROBANTE_CNT.ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TRUNC(COMPROBANTE_CNT.NUMERO) &gt;= :NUMEROINICIAL ORDER BY COMPROBANTE_CNT.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","TIPO":"$TIPO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
