	<query id="getTipocomprobantesNumPorClasecontableQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CLASE_CONTABLE = :CLASECONTABLE ORDER BY TIPO_COMPROBANTE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASECONTABLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipocomprobantes/porclasecontable/num">
		<call-query href="getTipocomprobantesNumPorClasecontableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASECONTABLE" query-param="CLASECONTABLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesTodosPorClasecontablevQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE  FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CLASE_CONTABLE = 'V'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
