			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_CONTABLE" query-param="CLASE_CONTABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipocomprobantesNumPorClaseEgresoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE, TIPO_COMPROBANTE.CLASE_CONTABLE  FROM TIPO_COMPROBANTE WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CLASE_CONTABLE = 'E') WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE_CONTABLE IS NULL THEN ' ' ELSE UPPER(CLASE_CONTABLE) END)  LIKE UPPER( '%' || :CLASE_CONTABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
