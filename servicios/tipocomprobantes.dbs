	<query id="getTipocomprobantesNumTodosConDescripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPO_COMPROBANTE.COMPANIA, TIPO_COMPROBANTE.CODIGO, TIPO_COMPROBANTE.NOMBRE, TIPO_COMPROBANTE.CLASE_CONTABLE, CLASECNT.DESCRIPCION  FROM TIPO_COMPROBANTE INNER JOIN CLASECNT ON TIPO_COMPROBANTE.CLASE_CONTABLE = CLASECNT.CODIGO WHERE TIPO_COMPROBANTE.COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE_CONTABLE IS NULL THEN ' ' ELSE UPPER(CLASE_CONTABLE) END)  LIKE UPPER( '%' || :CLASE_CONTABLE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
