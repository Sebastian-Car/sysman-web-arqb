<data name="tipoacto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoactoPagTodosLosTipoactoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOACTO.TIPOACTO, TIPOACTO.NOMBREACTO  FROM TIPOACTO ORDER BY TO_NUMBER(TIPOACTO.TIPOACTO)) WHERE (CASE WHEN TIPOACTO IS NULL THEN ' ' ELSE UPPER(TIPOACTO) END)  LIKE UPPER(:TIPOACTO || '%')  AND (CASE WHEN NOMBREACTO IS NULL THEN ' ' ELSE UPPER(NOMBREACTO) END)  LIKE UPPER( '%' || :NOMBREACTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOACTO":"$TIPOACTO","NOMBREACTO":"$NOMBREACTO"}]}}		</result>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="NOMBREACTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoacto/todoslostipoacto/pag">
		<call-query href="getTipoactoPagTodosLosTipoactoQuery">
			<with-param name="TIPOACTO" query-param="TIPOACTO"/>
			<with-param name="NOMBREACTO" query-param="NOMBREACTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoactoNumTodosLosTipoactoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOACTO.TIPOACTO, TIPOACTO.NOMBREACTO  FROM TIPOACTO ORDER BY TO_NUMBER(TIPOACTO.TIPOACTO)) WHERE (CASE WHEN TIPOACTO IS NULL THEN ' ' ELSE UPPER(TIPOACTO) END)  LIKE UPPER(:TIPOACTO || '%')  AND (CASE WHEN NOMBREACTO IS NULL THEN ' ' ELSE UPPER(NOMBREACTO) END)  LIKE UPPER( '%' || :NOMBREACTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="NOMBREACTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoacto/todoslostipoacto/num">
		<call-query href="getTipoactoNumTodosLosTipoactoQuery">
			<with-param name="TIPOACTO" query-param="TIPOACTO"/>
			<with-param name="NOMBREACTO" query-param="NOMBREACTO"/>

		</call-query>
	</resource>

</data>