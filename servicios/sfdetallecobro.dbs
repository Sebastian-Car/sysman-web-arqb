<data name="sfdetallecobro" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="deleteSfdetallecobroEliminardetalles" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_DETALLE_COBRO WHERE COMPANIA   = :COMPANIA AND ANO          = :ANO AND TIPOCOBRO    = :TIPOCOBRO AND CODIGO_COBRO = :CODIGO_COBRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO_COBRO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfdetallecobro/eliminardetalles">
		<call-query href="deleteSfdetallecobroEliminardetalles">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO_COBRO" query-param="CODIGO_COBRO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecobroTodosLosTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(VALOR_UNITARIO),0) VALOR_UNITARIO, NVL(SUM(VALOR_BASE),0) VALOR, NVL(SUM(VALOR_IVA),0) IVA, NVL(SUM(VALOR_RETEFUENTE),0) RETEFUENTE, NVL(SUM(VALOR_DESCUENTO),0) DESCUENTO, NVL(SUM(VALOR_ICA),0) ICA, NVL(SUM(VALOR_NETO),0) VALORNETO , NVL(SUM(VALOR_IMPOCONSUMO),0) VALORIMPOCONSUMO , NVL(SUM(DEUDA_ANTERIOR),0) DEUDA_ANTERIOR, NVL(SUM(VALOR_TOTAL_DOLARES),0) VALOR_TOTAL_DOLARES FROM SF_DETALLE_COBRO WHERE COMPANIA = :COMPANIA AND CODIGO_COBRO = :CODIGOCOBRO AND TIPOCOBRO = :TIPOCOBRO AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_UNITARIO":"$VALOR_UNITARIO","VALOR":"$VALOR","IVA":"$IVA","RETEFUENTE":"$RETEFUENTE","DESCUENTO":"$DESCUENTO","ICA":"$ICA","VALORNETO":"$VALORNETO","VALORIMPOCONSUMO":"$VALORIMPOCONSUMO","DEUDA_ANTERIOR":"$DEUDA_ANTERIOR","VALOR_TOTAL_DOLARES":"$VALOR_TOTAL_DOLARES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOCOBRO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecobro/todoslostotales">
		<call-query href="getSfdetallecobroTodosLosTotalesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOCOBRO" query-param="CODIGOCOBRO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateSfdetallecobroActualizarvalorcree" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_COBRO   SET VALOR_CREE    = :CREE,       MODIFIED_BY   = :MODIFIED_BY,       DATE_MODIFIED = SYSDATE WHERE COMPANIA     = :COMPANIA   AND ANO          = :ANO   AND TIPOCOBRO    = :TIPOCOBRO   AND CODIGO_COBRO = :CODIGO   AND CONCEPTO     = :CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CREE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfdetallecobro/actualizarvalorcree">
		<call-query href="updateSfdetallecobroActualizarvalorcree">
			<with-param name="CREE" query-param="CREE"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecobroExisteConceptosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM SF_DETALLE_COBRO WHERE COMPANIA = :COMPANIA AND TIPOCOBRO = :TIPOCOBRO AND CODIGO_COBRO = :CODIGO_COBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO_COBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecobro/existeconceptos">
		<call-query href="getSfdetallecobroExisteConceptosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO_COBRO" query-param="CODIGO_COBRO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecobroGetmaximoconsecutivoporobjetocobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(MAX(CONSECUTIVO), 0) CONSECUTIVO FROM SF_DETALLE_COBRO WHERE CODIGO_COBRO =:CODIGO AND COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecobro/getmaximoconsecutivoporobjetocobro">
		<call-query href="getSfdetallecobroGetmaximoconsecutivoporobjetocobroQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
					</call-query>
	</resource>
	<query id="updateSfdetallecobroActualizartercero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_COBRO SET TERCERO = :TERCERO, SUCURSAL = :SUCURSAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO AND CODIGO_COBRO = :CODIGO_COBRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO_COBRO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfdetallecobro/actualizartercero">
		<call-query href="updateSfdetallecobroActualizartercero">
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO_COBRO" query-param="CODIGO_COBRO"/>

		</call-query>
	</resource>
    <query id="insertSfdetallecobro" keyColumns="COMPANIA,ANO,CODIGO_COBRO,TIPOCOBRO,CONCEPTO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_DETALLE_COBRO (COMPANIA, ANO, TIPOCOBRO, CODIGO_COBRO, CONCEPTO, TARIFA, CANTIDAD, VALOR_BASE, VALOR_IVA, VALOR_RETEFUENTE, VALOR_DESCUENTO, VALOR_ICA, VALOR_NETO, VALOR_COMPRA, VALOR_UTILIDAD, FECHA_INICIO_COBRO, FECHA_FIN_COBRO, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, VALOR_UNITARIO, ESTRATO, ACOMETIDA_SERVICIO, AIU, ADMON_IMPREVISTOS, UTILIDAD_AIU, IVA_UTILIDAD, VALOR_CREE, BASE_GRAVABLE, CANTIDADX, DESCUENTO, BASE_FIJA, CREATED_BY, DATE_CREATED, FUENTE_RECURSO, REFERENCIA, CUENTA_BANCO, VALOR_IMPOCONSUMO, DEUDA_ANTERIOR, VALOR_UNITARIO_DOLARES, VALOR_TOTAL_DOLARES, CENTRO_UTILIDAD, NUMEROLISTA, VALOR_RETEIVA, CONSECUTIVO, NROCONTRATOSIGEC, TIPOCONTRATOSIGEC, AJUSTE_DECIMAL) VALUES (:COMPANIA, :ANO, :TIPOCOBRO, :CODIGO_COBRO, :CONCEPTO, :TARIFA, :CANTIDAD, :VALOR_BASE, :VALOR_IVA, :VALOR_RETEFUENTE, :VALOR_DESCUENTO, :VALOR_ICA, :VALOR_NETO, :VALOR_COMPRA, :VALOR_UTILIDAD, TO_DATE(:FECHA_INICIO_COBRO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FIN_COBRO,'DD/MM/YYYY HH24:MI:SS'), :TERCERO, :SUCURSAL, :CENTRO_COSTO, :AUXILIAR, :VALOR_UNITARIO, :ESTRATO, :ACOMETIDA_SERVICIO, :AIU, :ADMON_IMPREVISTOS, :UTILIDAD_AIU, :IVA_UTILIDAD, :VALOR_CREE, :BASE_GRAVABLE, :CANTIDADX, :DESCUENTO, :BASE_FIJA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :FUENTE_RECURSO, :REFERENCIA, :CUENTA_BANCO, :VALOR_IMPOCONSUMO, :DEUDA_ANTERIOR, :VALOR_UNITARIO_DOLARES, :VALOR_TOTAL_DOLARES, :CENTRO_UTILIDAD, :NUMEROLISTA, :VALOR_RETEIVA, :CONSECUTIVO, :NROCONTRATOSIGEC, :TIPOCONTRATOSIGEC, :AJUSTE_DECIMAL)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO_COBRO":"$CODIGO_COBRO(type:long)","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_CONCEPTO":"$CONCEPTO","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}			</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO_COBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="TARIFA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_BASE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_IVA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_RETEFUENTE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_ICA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_NETO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_COMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UTILIDAD" sqlType="STRING"/>
		<param name="FECHA_INICIO_COBRO" sqlType="STRING"/>
		<param name="FECHA_FIN_COBRO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UNITARIO" sqlType="STRING"/>
		<param defaultValue="" name="ESTRATO" sqlType="STRING"/>
		<param defaultValue="0" name="ACOMETIDA_SERVICIO" sqlType="STRING"/>
		<param defaultValue="0" name="AIU" sqlType="STRING"/>
		<param defaultValue="0" name="ADMON_IMPREVISTOS" sqlType="STRING"/>
		<param defaultValue="0" name="UTILIDAD_AIU" sqlType="STRING"/>
		<param defaultValue="0" name="IVA_UTILIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_CREE" sqlType="STRING"/>
		<param defaultValue="0" name="BASE_GRAVABLE" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDADX" sqlType="STRING"/>
		<param defaultValue="0" name="DESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="BASE_FIJA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_RECURSO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_BANCO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_IMPOCONSUMO" sqlType="STRING"/>
		<param defaultValue="0" name="DEUDA_ANTERIOR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UNITARIO_DOLARES" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_TOTAL_DOLARES" sqlType="STRING"/>
		<param defaultValue="" name="CENTRO_UTILIDAD" sqlType="STRING"/>
		<param defaultValue="" name="NUMEROLISTA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_RETEIVA" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
        <param defaultValue="0" name="VALOR_RETEIVA" sqlType="STRING"/>
		<param defaultValue="" name="NROCONTRATOSIGEC" sqlType="STRING"/>
		<param defaultValue="" name="TIPOCONTRATOSIGEC" sqlType="STRING"/>
		<param defaultValue="0" name="AJUSTE_DECIMAL" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfdetallecobro">
		<call-query href="insertSfdetallecobro">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO_COBRO" query-param="CODIGO_COBRO"/>
