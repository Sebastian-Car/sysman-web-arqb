	<query id="updateSfdetallecobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_COBRO SET COMPANIA=:COMPANIA, ANO=:ANO, TIPOCOBRO=:TIPOCOBRO, CODIGO_COBRO=:CODIGO_COBRO, CONCEPTO=:CONCEPTO, TARIFA=:TARIFA, CANTIDAD=:CANTIDAD, VALOR_BASE=:VALOR_BASE, VALOR_IVA=:VALOR_IVA, VALOR_RETEFUENTE=:VALOR_RETEFUENTE, VALOR_DESCUENTO=:VALOR_DESCUENTO, VALOR_ICA=:VALOR_ICA, VALOR_NETO=:VALOR_NETO, VALOR_COMPRA=:VALOR_COMPRA, VALOR_UTILIDAD=:VALOR_UTILIDAD, FECHA_INICIO_COBRO=TO_DATE(:FECHA_INICIO_COBRO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FIN_COBRO=TO_DATE(:FECHA_FIN_COBRO,'DD/MM/YYYY HH24:MI:SS'), TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, VALOR_UNITARIO=:VALOR_UNITARIO, ESTRATO=:ESTRATO, ACOMETIDA_SERVICIO=:ACOMETIDA_SERVICIO, AIU=:AIU, ADMON_IMPREVISTOS=:ADMON_IMPREVISTOS, UTILIDAD_AIU=:UTILIDAD_AIU, IVA_UTILIDAD=:IVA_UTILIDAD, VALOR_CREE=:VALOR_CREE, BASE_GRAVABLE=:BASE_GRAVABLE, CANTIDADX=:CANTIDADX, DESCUENTO=:DESCUENTO, BASE_FIJA=:BASE_FIJA, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FUENTE_RECURSO=:FUENTE_RECURSO, REFERENCIA=:REFERENCIA, CUENTA_BANCO=:CUENTA_BANCO, VALOR_IMPOCONSUMO=:VALOR_IMPOCONSUMO, DEUDA_ANTERIOR=:DEUDA_ANTERIOR, VALOR_UNITARIO_DOLARES=:VALOR_UNITARIO_DOLARES, VALOR_TOTAL_DOLARES=:VALOR_TOTAL_DOLARES, NUMEROLISTA=:NUMEROLISTA, VALOR_RETEIVA=:VALOR_RETEIVA,CENTRO_UTILIDAD=:CENTRO_UTILIDAD,NROCONTRATOSIGEC=:NROCONTRATOSIGEC, TIPOCONTRATOSIGEC=:TIPOCONTRATOSIGEC, AJUSTE_DECIMAL=:AJUSTE_DECIMAL WHERE SF_DETALLE_COBRO.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_COBRO.ANO= :KEY_ANO AND SF_DETALLE_COBRO.CODIGO_COBRO= :KEY_CODIGO_COBRO AND SF_DETALLE_COBRO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_DETALLE_COBRO.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_COBRO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

