		</call-query>
	</resource>
	<query id="deleteSfdetallecobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_DETALLE_COBRO WHERE SF_DETALLE_COBRO.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_COBRO.ANO= :KEY_ANO AND SF_DETALLE_COBRO.CODIGO_COBRO= :KEY_CODIGO_COBRO AND SF_DETALLE_COBRO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_DETALLE_COBRO.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_COBRO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_COBRO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="sfdetallecobro">
		<call-query href="deleteSfdetallecobro">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO_COBRO" query-param="KEY_CODIGO_COBRO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecobroPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_DETALLE_COBRO.CONSECUTIVO, SF_DETALLE_COBRO.COMPANIA, SF_DETALLE_COBRO.ANO, SF_DETALLE_COBRO.TIPOCOBRO, SF_DETALLE_COBRO.CODIGO_COBRO, SF_DETALLE_COBRO.CONCEPTO, SF_DETALLE_COBRO.TARIFA, SF_DETALLE_COBRO.CANTIDAD, SF_DETALLE_COBRO.VALOR_BASE, SF_DETALLE_COBRO.VALOR_IVA, SF_DETALLE_COBRO.VALOR_RETEFUENTE, SF_DETALLE_COBRO.VALOR_DESCUENTO, SF_DETALLE_COBRO.VALOR_ICA, SF_DETALLE_COBRO.VALOR_NETO, SF_DETALLE_COBRO.VALOR_COMPRA, SF_DETALLE_COBRO.VALOR_UTILIDAD,(TO_CHAR(SF_DETALLE_COBRO.FECHA_INICIO_COBRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_COBRO,(TO_CHAR(SF_DETALLE_COBRO.FECHA_FIN_COBRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_FIN_COBRO, SF_DETALLE_COBRO.TERCERO, SF_DETALLE_COBRO.SUCURSAL, SF_DETALLE_COBRO.CENTRO_COSTO, SF_DETALLE_COBRO.AUXILIAR, SF_DETALLE_COBRO.VALOR_UNITARIO, SF_DETALLE_COBRO.ESTRATO, SF_DETALLE_COBRO.ACOMETIDA_SERVICIO, SF_DETALLE_COBRO.AIU, SF_DETALLE_COBRO.ADMON_IMPREVISTOS, SF_DETALLE_COBRO.UTILIDAD_AIU, SF_DETALLE_COBRO.IVA_UTILIDAD, SF_DETALLE_COBRO.VALOR_CREE, SF_DETALLE_COBRO.BASE_GRAVABLE, SF_DETALLE_COBRO.CANTIDADX,(CASE SF_DETALLE_COBRO.DESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) DESCUENTO, SF_DETALLE_COBRO.BASE_FIJA, SF_DETALLE_COBRO.CREATED_BY,(TO_CHAR(SF_DETALLE_COBRO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_DETALLE_COBRO.MODIFIED_BY,(TO_CHAR(SF_DETALLE_COBRO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SF_DETALLE_COBRO.FUENTE_RECURSO, SF_DETALLE_COBRO.REFERENCIA, SF_DETALLE_COBRO.CUENTA_BANCO, SF_CONCEPTOS.NOMBRE NOMBRECONCEPTO, SF_DETALLE_COBRO.VALOR_IMPOCONSUMO, SF_DETALLE_COBRO.DEUDA_ANTERIOR, SF_DETALLE_COBRO.VALOR_UNITARIO_DOLARES, SF_DETALLE_COBRO.VALOR_TOTAL_DOLARES, SF_DETALLE_COBRO.CENTRO_UTILIDAD, CENTRO_UTILIDAD.DESCRIPCION NOMBRECENTROUTILIDAD, NUMEROLISTA,SF_DETALLE_COBRO.VALOR_RETEIVA, SF_DETALLE_COBRO.NROCONTRATOSIGEC, SF_DETALLE_COBRO.TIPOCONTRATOSIGEC, SF_DETALLE_COBRO.AJUSTE_DECIMAL FROM SF_DETALLE_COBRO LEFT JOIN SF_CONCEPTOS ON SF_DETALLE_COBRO.COMPANIA = SF_CONCEPTOS.COMPANIA AND SF_DETALLE_COBRO.ANO = SF_CONCEPTOS.ANO AND SF_DETALLE_COBRO.TIPOCOBRO = SF_CONCEPTOS.TIPOCOBRO AND SF_DETALLE_COBRO.CONCEPTO = SF_CONCEPTOS.CODIGO LEFT JOIN CENTRO_UTILIDAD ON SF_DETALLE_COBRO.COMPANIA = CENTRO_UTILIDAD.COMPANIA AND SF_DETALLE_COBRO.ANO = CENTRO_UTILIDAD.ANO AND SF_DETALLE_COBRO.CENTRO_UTILIDAD = CENTRO_UTILIDAD.CODIGO WHERE SF_DETALLE_COBRO.COMPANIA = :COMPANIA AND SF_DETALLE_COBRO.TIPOCOBRO = :TIPOCOBRO AND SF_DETALLE_COBRO.CODIGO_COBRO = :CODIGOCOBRO AND SF_DETALLE_COBRO.ANO = :ANO ORDER BY SF_DETALLE_COBRO.CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","CONCEPTO":"$CONCEPTO","TARIFA":"$TARIFA","CANTIDAD":"$CANTIDAD","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETEFUENTE":"$VALOR_RETEFUENTE","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_ICA":"$VALOR_ICA","VALOR_NETO":"$VALOR_NETO","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_UTILIDAD":"$VALOR_UTILIDAD","FECHA_INICIO_COBRO":"$FECHA_INICIO_COBRO","FECHA_FIN_COBRO":"$FECHA_FIN_COBRO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VALOR_UNITARIO":"$VALOR_UNITARIO","ESTRATO":"$ESTRATO","ACOMETIDA_SERVICIO":"$ACOMETIDA_SERVICIO","AIU":"$AIU","ADMON_IMPREVISTOS":"$ADMON_IMPREVISTOS","UTILIDAD_AIU":"$UTILIDAD_AIU","IVA_UTILIDAD":"$IVA_UTILIDAD","VALOR_CREE":"$VALOR_CREE","BASE_GRAVABLE":"$BASE_GRAVABLE","CANTIDADX":"$CANTIDADX(type:long)","DESCUENTO":"$DESCUENTO(type:boolean)","BASE_FIJA":"$BASE_FIJA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","FUENTE_RECURSO":"$FUENTE_RECURSO","REFERENCIA":"$REFERENCIA","CUENTA_BANCO":"$CUENTA_BANCO","NOMBRECONCEPTO":"$NOMBRECONCEPTO","VALOR_IMPOCONSUMO":"$VALOR_IMPOCONSUMO","DEUDA_ANTERIOR":"$DEUDA_ANTERIOR","VALOR_UNITARIO_DOLARES":"$VALOR_UNITARIO_DOLARES","VALOR_TOTAL_DOLARES":"$VALOR_TOTAL_DOLARES","CENTRO_UTILIDAD":"$CENTRO_UTILIDAD","NOMBRECENTROUTILIDAD":"$NOMBRECENTROUTILIDAD","NUMEROLISTA":"$NUMEROLISTA","VALOR_RETEIVA":"$VALOR_RETEIVA","NROCONTRATOSIGEC":"$NROCONTRATOSIGEC", "TIPOCONTRATOSIGEC":"$TIPOCONTRATOSIGEC","AJUSTE_DECIMAL":"$AJUSTE_DECIMAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecobro">
