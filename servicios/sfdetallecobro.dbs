			<with-param name="VALOR_NETO" query-param="VALOR_NETO"/>
			<with-param name="VALOR_COMPRA" query-param="VALOR_COMPRA"/>
			<with-param name="VALOR_UTILIDAD" query-param="VALOR_UTILIDAD"/>
			<with-param name="FECHA_INICIO_COBRO" query-param="FECHA_INICIO_COBRO"/>
			<with-param name="FECHA_FIN_COBRO" query-param="FECHA_FIN_COBRO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="VALOR_UNITARIO" query-param="VALOR_UNITARIO"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="ACOMETIDA_SERVICIO" query-param="ACOMETIDA_SERVICIO"/>
			<with-param name="AIU" query-param="AIU"/>
			<with-param name="ADMON_IMPREVISTOS" query-param="ADMON_IMPREVISTOS"/>
			<with-param name="UTILIDAD_AIU" query-param="UTILIDAD_AIU"/>
			<with-param name="IVA_UTILIDAD" query-param="IVA_UTILIDAD"/>
			<with-param name="VALOR_CREE" query-param="VALOR_CREE"/>
			<with-param name="BASE_GRAVABLE" query-param="BASE_GRAVABLE"/>
			<with-param name="CANTIDADX" query-param="CANTIDADX"/>
			<with-param name="DESCUENTO" query-param="DESCUENTO"/>
			<with-param name="BASE_FIJA" query-param="BASE_FIJA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CUENTA_BANCO" query-param="CUENTA_BANCO"/>
