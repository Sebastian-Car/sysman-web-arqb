			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
            <with-param name="VALOR_RETEIVA" query-param="VALOR_RETEIVA"/>
			<with-param name="NROCONTRATOSIGEC" query-param="NROCONTRATOSIGEC"/>
			<with-param name="TIPOCONTRATOSIGEC" query-param="TIPOCONTRATOSIGEC"/>
