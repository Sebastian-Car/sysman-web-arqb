<data name="natquinquenio" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatquinquenio" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,QU_TIPODOCUACTO,QU_NUME,QQ_CODIGOPERSONA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_QUINQUENIO (COMPANIA, DP_NUMEDOCU, SUCURSAL, ID_DE_EMPLEADO, QU_FECHDESDE, QU_FECHHASTA, QU_VALOR, QU_TIPODOCUACTO, QU_NUME, QU_FECHRESO, QQ_CODIGOPERSONA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :ID_DE_EMPLEADO, TO_DATE(:QU_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:QU_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), :QU_VALOR, :QU_TIPODOCUACTO, :QU_NUME, TO_DATE(:QU_FECHRESO,'DD/MM/YYYY HH24:MI:SS'), :QQ_CODIGOPERSONA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_QU_TIPODOCUACTO":"$QU_TIPODOCUACTO","KEY_QU_NUME":"$QU_NUME","KEY_QU_FECHRESO":"$QU_FECHRESO","KEY_QQ_CODIGOPERSONA":"$QQ_CODIGOPERSONA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="" name="QU_FECHDESDE" sqlType="STRING"/>
		<param defaultValue="" name="QU_FECHHASTA" sqlType="STRING"/>
		<param defaultValue="0" name="QU_VALOR" sqlType="STRING"/>
		<param name="QU_TIPODOCUACTO" sqlType="STRING"/>
		<param name="QU_NUME" sqlType="STRING"/>
		<param name="QU_FECHRESO" sqlType="STRING"/>
		<param name="QQ_CODIGOPERSONA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natquinquenio">
		<call-query href="insertNatquinquenio">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="QU_FECHDESDE" query-param="QU_FECHDESDE"/>
			<with-param name="QU_FECHHASTA" query-param="QU_FECHHASTA"/>
			<with-param name="QU_VALOR" query-param="QU_VALOR"/>
			<with-param name="QU_TIPODOCUACTO" query-param="QU_TIPODOCUACTO"/>
			<with-param name="QU_NUME" query-param="QU_NUME"/>
			<with-param name="QU_FECHRESO" query-param="QU_FECHRESO"/>
			<with-param name="QQ_CODIGOPERSONA" query-param="QQ_CODIGOPERSONA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatquinquenio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_QUINQUENIO WHERE NAT_QUINQUENIO.COMPANIA= :KEY_COMPANIA AND NAT_QUINQUENIO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_QUINQUENIO.SUCURSAL= :KEY_SUCURSAL AND NAT_QUINQUENIO.QU_TIPODOCUACTO= :KEY_QU_TIPODOCUACTO AND NAT_QUINQUENIO.QU_NUME= :KEY_QU_NUME AND NAT_QUINQUENIO.QU_FECHRESO= TO_DATE(:KEY_QU_FECHRESO,'DD/MM/YYYY HH24:MI:SS')  AND NAT_QUINQUENIO.QQ_CODIGOPERSONA= :KEY_QQ_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_QU_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_QU_NUME" sqlType="STRING"/>
		<param name="KEY_QU_FECHRESO" sqlType="STRING"/>
		<param name="KEY_QQ_CODIGOPERSONA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natquinquenio">
		<call-query href="deleteNatquinquenio">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_QU_TIPODOCUACTO" query-param="KEY_QU_TIPODOCUACTO"/>
			<with-param name="KEY_QU_NUME" query-param="KEY_QU_NUME"/>
			<with-param name="KEY_QU_FECHRESO" query-param="KEY_QU_FECHRESO"/>
			<with-param name="KEY_QQ_CODIGOPERSONA" query-param="KEY_QQ_CODIGOPERSONA"/>

		</call-query>
	</resource>
	<query id="getNatquinquenioPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  QUI.COMPANIA, QUI.DP_NUMEDOCU, QUI.SUCURSAL, QUI.ID_DE_EMPLEADO,(TO_CHAR(QUI.QU_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) QU_FECHDESDE,(TO_CHAR(QUI.QU_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) QU_FECHHASTA, QUI.QU_VALOR, QUI.QU_TIPODOCUACTO, QUI.QU_NUME,(TO_CHAR(QUI.QU_FECHRESO,'DD/MM/YYYY HH24:MI:SS')) QU_FECHRESO,QUI.QQ_CODIGOPERSONA  FROM NAT_QUINQUENIO QUI WHERE QUI.COMPANIA= :COMPANIA AND QUI.DP_NUMEDOCU= :DP_NUMEDOCU AND QUI.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN QU_FECHDESDE IS NULL THEN ' ' ELSE UPPER(QU_FECHDESDE) END)  LIKE UPPER( '%' || :QU_FECHDESDE || '%')  AND (CASE WHEN QU_FECHHASTA IS NULL THEN ' ' ELSE UPPER(QU_FECHHASTA) END)  LIKE UPPER( '%' || :QU_FECHHASTA || '%')  AND (CASE WHEN QU_VALOR IS NULL THEN ' ' ELSE UPPER(QU_VALOR) END)  LIKE UPPER(:QU_VALOR || '%')  AND (CASE WHEN QU_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(QU_TIPODOCUACTO) END)  LIKE UPPER( '%' || :QU_TIPODOCUACTO || '%')  AND (CASE WHEN QU_NUME IS NULL THEN ' ' ELSE UPPER(QU_NUME) END)  LIKE UPPER( '%' || :QU_NUME || '%')  AND (CASE WHEN QU_FECHRESO IS NULL THEN ' ' ELSE UPPER(QU_FECHRESO) END)  LIKE UPPER( '%' || :QU_FECHRESO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","QU_FECHDESDE":"$QU_FECHDESDE","QU_FECHHASTA":"$QU_FECHHASTA","QU_VALOR":"$QU_VALOR","QU_TIPODOCUACTO":"$QU_TIPODOCUACTO","QU_NUME":"$QU_NUME","QU_FECHRESO":"$QU_FECHRESO","QQ_CODIGOPERSONA":"$QQ_CODIGOPERSONA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="QU_FECHDESDE" sqlType="STRING"/>
		<param name="QU_FECHHASTA" sqlType="STRING"/>
		<param name="QU_VALOR" sqlType="STRING"/>
		<param name="QU_TIPODOCUACTO" sqlType="STRING"/>
		<param name="QU_NUME" sqlType="STRING"/>
		<param name="QU_FECHRESO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natquinquenio">
		<call-query href="getNatquinquenioPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="QU_FECHDESDE" query-param="QU_FECHDESDE"/>
			<with-param name="QU_FECHHASTA" query-param="QU_FECHHASTA"/>
			<with-param name="QU_VALOR" query-param="QU_VALOR"/>
			<with-param name="QU_TIPODOCUACTO" query-param="QU_TIPODOCUACTO"/>
			<with-param name="QU_NUME" query-param="QU_NUME"/>
			<with-param name="QU_FECHRESO" query-param="QU_FECHRESO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatquinquenioNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  QUI.COMPANIA, QUI.DP_NUMEDOCU, QUI.SUCURSAL, QUI.ID_DE_EMPLEADO,(TO_CHAR(QUI.QU_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) QU_FECHDESDE,(TO_CHAR(QUI.QU_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) QU_FECHHASTA, QUI.QU_VALOR, QUI.QU_TIPODOCUACTO, QUI.QU_NUME,(TO_CHAR(QUI.QU_FECHRESO,'DD/MM/YYYY HH24:MI:SS')) QU_FECHRESO,QUI.QQ_CODIGOPERSONA  FROM NAT_QUINQUENIO QUI WHERE QUI.COMPANIA= :COMPANIA AND QUI.DP_NUMEDOCU= :DP_NUMEDOCU AND QUI.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN QU_FECHDESDE IS NULL THEN ' ' ELSE UPPER(QU_FECHDESDE) END)  LIKE UPPER( '%' || :QU_FECHDESDE || '%')  AND (CASE WHEN QU_FECHHASTA IS NULL THEN ' ' ELSE UPPER(QU_FECHHASTA) END)  LIKE UPPER( '%' || :QU_FECHHASTA || '%')  AND (CASE WHEN QU_VALOR IS NULL THEN ' ' ELSE UPPER(QU_VALOR) END)  LIKE UPPER(:QU_VALOR || '%')  AND (CASE WHEN QU_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(QU_TIPODOCUACTO) END)  LIKE UPPER( '%' || :QU_TIPODOCUACTO || '%')  AND (CASE WHEN QU_NUME IS NULL THEN ' ' ELSE UPPER(QU_NUME) END)  LIKE UPPER( '%' || :QU_NUME || '%')  AND (CASE WHEN QU_FECHRESO IS NULL THEN ' ' ELSE UPPER(QU_FECHRESO) END)  LIKE UPPER( '%' || :QU_FECHRESO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="QU_FECHDESDE" sqlType="STRING"/>
		<param name="QU_FECHHASTA" sqlType="STRING"/>
		<param name="QU_VALOR" sqlType="STRING"/>
		<param name="QU_TIPODOCUACTO" sqlType="STRING"/>
		<param name="QU_NUME" sqlType="STRING"/>
		<param name="QU_FECHRESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natquinquenio/numero">
		<call-query href="getNatquinquenioNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="QU_FECHDESDE" query-param="QU_FECHDESDE"/>
			<with-param name="QU_FECHHASTA" query-param="QU_FECHHASTA"/>
			<with-param name="QU_VALOR" query-param="QU_VALOR"/>
			<with-param name="QU_TIPODOCUACTO" query-param="QU_TIPODOCUACTO"/>
			<with-param name="QU_NUME" query-param="QU_NUME"/>
			<with-param name="QU_FECHRESO" query-param="QU_FECHRESO"/>

		</call-query>
	</resource>
	<query id="updateNatquinquenio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_QUINQUENIO SET QU_FECHDESDE=TO_DATE(:QU_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), QU_FECHHASTA=TO_DATE(:QU_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), QU_VALOR=:QU_VALOR, QU_TIPODOCUACTO=:QU_TIPODOCUACTO, QU_NUME=:QU_NUME, QU_FECHRESO=TO_DATE(:QU_FECHRESO,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_QUINQUENIO.COMPANIA= :KEY_COMPANIA AND NAT_QUINQUENIO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_QUINQUENIO.SUCURSAL= :KEY_SUCURSAL AND NAT_QUINQUENIO.QU_TIPODOCUACTO= :KEY_QU_TIPODOCUACTO AND NAT_QUINQUENIO.QU_NUME= :KEY_QU_NUME AND NAT_QUINQUENIO.QU_FECHRESO= TO_DATE(:KEY_QU_FECHRESO,'DD/MM/YYYY HH24:MI:SS')  AND NAT_QUINQUENIO.QQ_CODIGOPERSONA= :KEY_QQ_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="QU_FECHDESDE" sqlType="STRING"/>
		<param name="QU_FECHHASTA" sqlType="STRING"/>
		<param name="QU_VALOR" sqlType="STRING"/>
		<param name="QU_TIPODOCUACTO" sqlType="STRING"/>
		<param name="QU_NUME" sqlType="STRING"/>
		<param name="QU_FECHRESO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_QU_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_QU_NUME" sqlType="STRING"/>
		<param name="KEY_QU_FECHRESO" sqlType="STRING"/>
		<param name="KEY_QQ_CODIGOPERSONA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natquinquenio">
		<call-query href="updateNatquinquenio">
			<with-param name="QU_FECHDESDE" query-param="QU_FECHDESDE"/>
			<with-param name="QU_FECHHASTA" query-param="QU_FECHHASTA"/>
			<with-param name="QU_VALOR" query-param="QU_VALOR"/>
			<with-param name="QU_TIPODOCUACTO" query-param="QU_TIPODOCUACTO"/>
			<with-param name="QU_NUME" query-param="QU_NUME"/>
			<with-param name="QU_FECHRESO" query-param="QU_FECHRESO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_QU_TIPODOCUACTO" query-param="KEY_QU_TIPODOCUACTO"/>
			<with-param name="KEY_QU_NUME" query-param="KEY_QU_NUME"/>
			<with-param name="KEY_QU_FECHRESO" query-param="KEY_QU_FECHRESO"/>
			<with-param name="KEY_QQ_CODIGOPERSONA" query-param="KEY_QQ_CODIGOPERSONA"/>

		</call-query>
	</resource>

</data>