	<query id="updatePiplanindicativofuentes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_PLAN_INDICATIVO_FUENTES SET VIGENCIA_META=:VIGENCIA_META, VALOR_PRESUPUESTO_FIN=:VALOR_PRESUPUESTO_FIN, VALOR_COMPROMETIDO_FIN=:VALOR_COMPROMETIDO_FIN, VALOR_PAGADO_FIN=:VALOR_PAGADO_FIN, FUENTE=:FUENTE, VALOR_OBLIGACIONES_FIN=:VALOR_OBLIGACIONES_FIN, VALOR_DISPONIBLE_FIN=:VALOR_DISPONIBLE_FIN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_PLAN_INDICATIVO_FUENTES.COMPANIA= :KEY_COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.TIPO= :KEY_TIPO AND PI_PLAN_INDICATIVO_FUENTES.NUMERO= :KEY_NUMERO AND PI_PLAN_INDICATIVO_FUENTES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
