	<query id="getPiplanindicativofuentesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PI_PLAN_INDICATIVO_FUENTES.COMPANIA, PI_PLAN_INDICATIVO_FUENTES.ID_PLAN, PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN, PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_META, PI_PLAN_INDICATIVO_FUENTES.FUENTE, FUENTE_RECURSOS.NOMBRE NOMBREFUENTE, PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN, PI_PLAN_INDICATIVO_FUENTES.VALOR_COMPROMETIDO_FIN, PI_PLAN_INDICATIVO_FUENTES.VALOR_PAGADO_FIN, PI_PLAN_INDICATIVO_FUENTES.TIPO, PI_PLAN_INDICATIVO_FUENTES.NUMERO, PI_PLAN_INDICATIVO_FUENTES.CONSECUTIVO,(CASE PI_PLAN_INDICATIVO_FUENTES.ESNUEVO WHEN 0 THEN 'false' ELSE 'true' END) ESNUEVO, PI_PLAN_INDICATIVO_FUENTES.VALOR_DISPONIBLE_FIN, PI_PLAN_INDICATIVO_FUENTES.VALOR_OBLIGACIONES_FIN, PCK_SYSMAN_UTL.FC_ROUND( CASE WHEN PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN = 0 THEN 0 ELSE (PI_PLAN_INDICATIVO_FUENTES.VALOR_PAGADO_FIN / PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN)*100 END,2) PORCENTAJEPAGADO , PCK_SYSMAN_UTL.FC_ROUND( CASE WHEN PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN = 0 THEN 0 ELSE (PI_PLAN_INDICATIVO_FUENTES.VALOR_OBLIGACIONES_FIN / PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN)*100 END,2) PORCENTAJEOBLIGACIONES, PCK_SYSMAN_UTL.FC_ROUND( CASE WHEN PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN = 0 THEN 0 ELSE (PI_PLAN_INDICATIVO_FUENTES.VALOR_COMPROMETIDO_FIN / PI_PLAN_INDICATIVO_FUENTES.VALOR_PRESUPUESTO_FIN) * 100 END,2) PORCENTAJECOMPROMETIDO  FROM PI_PLAN_INDICATIVO_FUENTES INNER JOIN FUENTE_RECURSOS ON PI_PLAN_INDICATIVO_FUENTES.COMPANIA = FUENTE_RECURSOS.COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_META = FUENTE_RECURSOS.ANO AND PI_PLAN_INDICATIVO_FUENTES.FUENTE = FUENTE_RECURSOS.CODIGO WHERE PI_PLAN_INDICATIVO_FUENTES.COMPANIA = :COMPANIA AND PI_PLAN_INDICATIVO_FUENTES.TIPO = :TIPO AND PI_PLAN_INDICATIVO_FUENTES.NUMERO = :NUMERO AND PI_PLAN_INDICATIVO_FUENTES.ID_PLAN = :PLAN AND PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN = :VIGENCIA ORDER BY PI_PLAN_INDICATIVO_FUENTES.VIGENCIA_META) WHERE (CASE WHEN VIGENCIA_META IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META) END)  LIKE UPPER(:VIGENCIA_META || '%')  AND (CASE WHEN NOMBREFUENTE IS NULL THEN ' ' ELSE UPPER(NOMBREFUENTE) END)  LIKE UPPER( '%' || :NOMBREFUENTE || '%')  AND (CASE WHEN VALOR_PRESUPUESTO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_PRESUPUESTO_FIN) END)  LIKE UPPER(:VALOR_PRESUPUESTO_FIN || '%')  AND (CASE WHEN VALOR_COMPROMETIDO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_COMPROMETIDO_FIN) END)  LIKE UPPER(:VALOR_COMPROMETIDO_FIN || '%')  AND (CASE WHEN VALOR_PAGADO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_PAGADO_FIN) END)  LIKE UPPER(:VALOR_PAGADO_FIN || '%')  AND (CASE WHEN VALOR_DISPONIBLE_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_DISPONIBLE_FIN) END)  LIKE UPPER( '%' || :VALOR_DISPONIBLE_FIN || '%')  AND (CASE WHEN VALOR_OBLIGACIONES_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_OBLIGACIONES_FIN) END)  LIKE UPPER( '%' || :VALOR_OBLIGACIONES_FIN || '%')  AND (CASE WHEN PORCENTAJEPAGADO IS NULL THEN ' ' ELSE UPPER(PORCENTAJEPAGADO) END)  LIKE UPPER( '%' || :PORCENTAJEPAGADO || '%')  AND (CASE WHEN PORCENTAJEOBLIGACIONES IS NULL THEN ' ' ELSE UPPER(PORCENTAJEOBLIGACIONES) END)  LIKE UPPER( '%' || :PORCENTAJEOBLIGACIONES || '%')  AND (CASE WHEN PORCENTAJECOMPROMETIDO IS NULL THEN ' ' ELSE UPPER(PORCENTAJECOMPROMETIDO) END)  LIKE UPPER( '%' || :PORCENTAJECOMPROMETIDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_PLAN":"$ID_PLAN","VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","VIGENCIA_META":"$VIGENCIA_META(type:integer)","FUENTE":"$FUENTE","NOMBREFUENTE":"$NOMBREFUENTE","VALOR_PRESUPUESTO_FIN":"$VALOR_PRESUPUESTO_FIN","VALOR_COMPROMETIDO_FIN":"$VALOR_COMPROMETIDO_FIN","VALOR_PAGADO_FIN":"$VALOR_PAGADO_FIN","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","ESNUEVO":"$ESNUEVO(type:boolean)","VALOR_DISPONIBLE_FIN":"$VALOR_DISPONIBLE_FIN","VALOR_OBLIGACIONES_FIN":"$VALOR_OBLIGACIONES_FIN","PORCENTAJEPAGADO":"$PORCENTAJEPAGADO(type:double)","PORCENTAJEOBLIGACIONES":"$PORCENTAJEOBLIGACIONES(type:double)","PORCENTAJECOMPROMETIDO":"$PORCENTAJECOMPROMETIDO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PLAN" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="NOMBREFUENTE" sqlType="STRING"/>
		<param name="VALOR_PRESUPUESTO_FIN" sqlType="STRING"/>
