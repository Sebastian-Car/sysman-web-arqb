<data name="alertas" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getAlertasJerarquiacodigoQuery"  useConfig="sysmanirisst">
		<sql>SELECT  COUNT (1) PADRE  FROM ALERTAS WHERE CODIGO NOT IN(:CODIGO) AND ((CODIGO BETWEEN SUBSTR(:CODIGO, 1,1) AND :CODIGO AND CODIGO = SUBSTR(:CODIGO,1,LENGTH(CODIGO)) ) OR ( CODIGO BETWEEN SUBSTR(:CODIGO, 1,1) AND :CODIGO AND :CODIGO = SUBSTR(CODIGO,1,LENGTH(:CODIGO)) )) AND MOVIMIENTO NOT IN 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PADRE":"$PADRE(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="alertas/jerarquiacodigo">
		<call-query href="getAlertasJerarquiacodigoQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertAlertas" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO ALERTAS (COMPANIA, CODIGO, TEXTO, MENSAJE, MODULO, MOVIMIENTO, DEPENDENCIA, CARGO, MINUTOS, HORAS, DIAS, ULTIMA_FECHA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :TEXTO, :MENSAJE, :MODULO, :MOVIMIENTO, :DEPENDENCIA, :CARGO, :MINUTOS, :HORAS, :DIAS, TO_DATE(:ULTIMA_FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param defaultValue="EMPTY_CLOB()" name="MENSAJE" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="CARGO" sqlType="STRING"/>
		<param defaultValue="0" name="MINUTOS" sqlType="STRING"/>
		<param defaultValue="0" name="HORAS" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="" name="ULTIMA_FECHA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="alertas">
		<call-query href="insertAlertas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="ULTIMA_FECHA" query-param="ULTIMA_FECHA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteAlertas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM ALERTAS WHERE ALERTAS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="alertas">
		<call-query href="deleteAlertas">
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getAlertasPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ALERTAS.COMPANIA, ALERTAS.CODIGO, ALERTAS.TEXTO, TO_CHAR(ALERTAS.MENSAJE)MENSAJE, ALERTAS.MODULO,(CASE ALERTAS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, CASE ALERTAS.MODULO WHEN 10 THEN 'Almacen' WHEN 52 THEN 'Banco de Proyectos' WHEN 66 THEN 'Carpeta Comercial' WHEN 86 THEN 'Circulación y Tránsito' WHEN 70 THEN 'Comercio' WHEN 11 THEN 'Consolidador' WHEN 1 THEN 'Contabilidad' WHEN 96 THEN 'Contabilizar' WHEN 20 THEN 'Contratacion' WHEN 9 THEN 'ControlContratos' WHEN 4 THEN 'Distribucion' WHEN 76 THEN 'Energia' WHEN 99 THEN 'Entes de Control' WHEN 47 THEN 'EXOGENAS' WHEN 5 THEN 'Facturacion' WHEN 74 THEN 'FacturacionServiciosPúblicos' WHEN -1 THEN 'General' WHEN 21 THEN 'Hojas de Vida' WHEN 78 THEN 'ImpuestosD' WHEN 12 THEN 'IngresosVarios' WHEN 50 THEN 'Mantenimiento' WHEN 6 THEN 'Nomina' WHEN 67 THEN 'Plan de desarrollo' WHEN 40 THEN 'Planeacion' WHEN 19 THEN 'Precontractual' WHEN 60 THEN 'Predial' WHEN 3 THEN 'Presupuesto' WHEN 15 THEN 'Procesos Judiciales' WHEN 65 THEN 'Programacion Visitas' WHEN 998 THEN 'Prueba' WHEN 30 THEN 'Radicacion' WHEN 14 THEN 'RecaudoComercio' WHEN 13 THEN 'RecaudoPredial' WHEN 85 THEN 'Rips' WHEN 999 THEN 'Sysman' WHEN 43 THEN 'SysmanALHC' WHEN 42 THEN 'SysmanPH' WHEN 45 THEN 'SysmanRes5993_CGR' WHEN 69 THEN 'SYSMANSF' WHEN 48 THEN 'SysmanSia' WHEN 80 THEN 'SysmanWebL' WHEN 90 THEN 'SysmanWebR' WHEN 35 THEN 'WORKFLOW' ELSE '' END NOMBRE, ALERTAS.DEPENDENCIA, ALERTAS.CARGO, ALERTAS.MINUTOS, ALERTAS.HORAS, ALERTAS.DIAS,(TO_CHAR(ALERTAS.ULTIMA_FECHA,'DD/MM/YYYY HH24:MI:SS')) ULTIMA_FECHA FROM ALERTAS ORDER BY ALERTAS.CODIGO ASC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END)  LIKE UPPER(:TEXTO || '%')  AND (CASE WHEN MENSAJE IS NULL THEN ' ' ELSE UPPER(MENSAJE) END)  LIKE UPPER(:MENSAJE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER(:CARGO || '%')  AND (CASE WHEN MINUTOS IS NULL THEN ' ' ELSE UPPER(MINUTOS) END)  LIKE UPPER(:MINUTOS || '%')  AND (CASE WHEN HORAS IS NULL THEN ' ' ELSE UPPER(HORAS) END)  LIKE UPPER(:HORAS || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN ULTIMA_FECHA IS NULL THEN ' ' ELSE UPPER(ULTIMA_FECHA) END)  LIKE UPPER(:ULTIMA_FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","TEXTO":"$TEXTO","MENSAJE":"$MENSAJE","MODULO":"$MODULO(type:integer)","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","NOMBRE":"$NOMBRE","DEPENDENCIA":"$DEPENDENCIA","CARGO":"$CARGO","MINUTOS":"$MINUTOS(type:integer)","HORAS":"$HORAS(type:integer)","DIAS":"$DIAS(type:integer)","ULTIMA_FECHA":"$ULTIMA_FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="MENSAJE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="MINUTOS" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ULTIMA_FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="alertas">
		<call-query href="getAlertasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="ULTIMA_FECHA" query-param="ULTIMA_FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAlertasNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ALERTAS.COMPANIA, ALERTAS.CODIGO, ALERTAS.TEXTO, TO_CHAR(ALERTAS.MENSAJE)MENSAJE, ALERTAS.MODULO,(CASE ALERTAS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, CASE ALERTAS.MODULO WHEN 10 THEN 'Almacen' WHEN 52 THEN 'Banco de Proyectos' WHEN 66 THEN 'Carpeta Comercial' WHEN 86 THEN 'Circulación y Tránsito' WHEN 70 THEN 'Comercio' WHEN 11 THEN 'Consolidador' WHEN 1 THEN 'Contabilidad' WHEN 96 THEN 'Contabilizar' WHEN 20 THEN 'Contratacion' WHEN 9 THEN 'ControlContratos' WHEN 4 THEN 'Distribucion' WHEN 76 THEN 'Energia' WHEN 99 THEN 'Entes de Control' WHEN 47 THEN 'EXOGENAS' WHEN 5 THEN 'Facturacion' WHEN 74 THEN 'FacturacionServiciosPúblicos' WHEN -1 THEN 'General' WHEN 21 THEN 'Hojas de Vida' WHEN 78 THEN 'ImpuestosD' WHEN 12 THEN 'IngresosVarios' WHEN 50 THEN 'Mantenimiento' WHEN 6 THEN 'Nomina' WHEN 67 THEN 'Plan de desarrollo' WHEN 40 THEN 'Planeacion' WHEN 19 THEN 'Precontractual' WHEN 60 THEN 'Predial' WHEN 3 THEN 'Presupuesto' WHEN 15 THEN 'Procesos Judiciales' WHEN 65 THEN 'Programacion Visitas' WHEN 998 THEN 'Prueba' WHEN 30 THEN 'Radicacion' WHEN 14 THEN 'RecaudoComercio' WHEN 13 THEN 'RecaudoPredial' WHEN 85 THEN 'Rips' WHEN 999 THEN 'Sysman' WHEN 43 THEN 'SysmanALHC' WHEN 42 THEN 'SysmanPH' WHEN 45 THEN 'SysmanRes5993_CGR' WHEN 69 THEN 'SYSMANSF' WHEN 48 THEN 'SysmanSia' WHEN 80 THEN 'SysmanWebL' WHEN 90 THEN 'SysmanWebR' WHEN 35 THEN 'WORKFLOW' ELSE '' END NOMBRE, ALERTAS.DEPENDENCIA, ALERTAS.CARGO, ALERTAS.MINUTOS, ALERTAS.HORAS, ALERTAS.DIAS,(TO_CHAR(ALERTAS.ULTIMA_FECHA,'DD/MM/YYYY HH24:MI:SS')) ULTIMA_FECHA FROM ALERTAS ORDER BY ALERTAS.CODIGO ASC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END)  LIKE UPPER(:TEXTO || '%')  AND (CASE WHEN MENSAJE IS NULL THEN ' ' ELSE UPPER(MENSAJE) END)  LIKE UPPER(:MENSAJE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER(:CARGO || '%')  AND (CASE WHEN MINUTOS IS NULL THEN ' ' ELSE UPPER(MINUTOS) END)  LIKE UPPER(:MINUTOS || '%')  AND (CASE WHEN HORAS IS NULL THEN ' ' ELSE UPPER(HORAS) END)  LIKE UPPER(:HORAS || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN ULTIMA_FECHA IS NULL THEN ' ' ELSE UPPER(ULTIMA_FECHA) END)  LIKE UPPER(:ULTIMA_FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="MENSAJE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="MINUTOS" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ULTIMA_FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="alertas/numero">
		<call-query href="getAlertasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="ULTIMA_FECHA" query-param="ULTIMA_FECHA"/>

		</call-query>
	</resource>
	<query id="getAlertasRegistroQuery"  useConfig="sysmanirisst">
		<sql>SELECT  ALERTAS.COMPANIA, ALERTAS.CODIGO, ALERTAS.TEXTO, ALERTAS.MENSAJE, ALERTAS.MODULO,(CASE ALERTAS.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, ALERTAS.DEPENDENCIA, ALERTAS.CARGO, ALERTAS.HORAS, ALERTAS.MINUTOS, ALERTAS.DIAS,(TO_CHAR(ALERTAS.ULTIMA_FECHA,'DD/MM/YYYY HH24:MI:SS')) ULTIMA_FECHA FROM ALERTAS WHERE ALERTAS.COMPANIA= :KEY_COMPANIA AND ALERTAS.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","TEXTO":"$TEXTO","MENSAJE":"$MENSAJE","MODULO":"$MODULO(type:integer)","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","DEPENDENCIA":"$DEPENDENCIA","CARGO":"$CARGO","HORAS":"$HORAS(type:integer)","MINUTOS":"$MINUTOS(type:integer)","DIAS":"$DIAS(type:integer)","ULTIMA_FECHA":"$ULTIMA_FECHA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="alertas/data">
		<call-query href="getAlertasRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateAlertas" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE ALERTAS SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, TEXTO=:TEXTO, MENSAJE=:MENSAJE, MODULO=:MODULO, MOVIMIENTO=:MOVIMIENTO, DEPENDENCIA=:DEPENDENCIA, CARGO=:CARGO, MINUTOS=:MINUTOS, HORAS=:HORAS, DIAS=:DIAS, ULTIMA_FECHA=TO_DATE(:ULTIMA_FECHA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ALERTAS.COMPANIA= :KEY_COMPANIA AND ALERTAS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="MENSAJE" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="MINUTOS" sqlType="STRING"/>
		<param name="HORAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ULTIMA_FECHA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="alertas">
		<call-query href="updateAlertas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="MINUTOS" query-param="MINUTOS"/>
			<with-param name="HORAS" query-param="HORAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="ULTIMA_FECHA" query-param="ULTIMA_FECHA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>