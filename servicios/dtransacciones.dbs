<data name="dtransacciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDtransacciones" keyColumns="COMPANIA,ANO,TIPO,NUMERO_MODELO,NUMERO,ORDEN" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_TRANSACCIONES (ANO, ANO_AFECTAR_CNT, ANO_AFECTAR_PPTO, AUXILIAR, CENTRO_COSTO, COMPANIA, CUENTA_CONTABLE, CUENTA_PPTAL, DESCRIPCION, FECHA, FUENTE_RECURSO, NUMERO, NUMERO_MODELO, NUMEROAAFECTAR, NUMEROAFECTARPPTO, ORDEN, REFERENCIA, SUCURSAL, TERCERO, TIPO, TIPOAAFECTAR, TIPOAAFECTARPPTO, VALOR, VALOR_BASEGRAVABLE, DATE_CREATED, CREATED_BY) VALUES (:ANO, :ANO_AFECTAR_CNT, :ANO_AFECTAR_PPTO, :AUXILIAR, :CENTRO_COSTO, :COMPANIA, :CUENTA_CONTABLE, :CUENTA_PPTAL, :DESCRIPCION, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :FUENTE_RECURSO, :NUMERO, :NUMERO_MODELO, :NUMEROAAFECTAR, :NUMEROAFECTARPPTO, :ORDEN, :REFERENCIA, :SUCURSAL, :TERCERO, :TIPO, :TIPOAAFECTAR, :TIPOAAFECTARPPTO, :VALOR, :VALOR_BASEGRAVABLE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO_MODELO":"$NUMERO_MODELO","KEY_NUMERO":"$NUMERO(type:long)","KEY_ORDEN":"$ORDEN"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="ANO_AFECTAR_CNT" sqlType="STRING"/>
		<param defaultValue="" name="ANO_AFECTAR_PPTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_PPTAL" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NUMERO_MODELO" sqlType="STRING"/>
		<param defaultValue="" name="NUMEROAAFECTAR" sqlType="STRING"/>
		<param defaultValue="" name="NUMEROAFECTARPPTO" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="TIPOAAFECTAR" sqlType="STRING"/>
		<param defaultValue="" name="TIPOAAFECTARPPTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_BASEGRAVABLE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dtransacciones">
		<call-query href="insertDtransacciones">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ANO_AFECTAR_CNT" query-param="ANO_AFECTAR_CNT"/>
			<with-param name="ANO_AFECTAR_PPTO" query-param="ANO_AFECTAR_PPTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="CUENTA_PPTAL" query-param="CUENTA_PPTAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NUMERO_MODELO" query-param="NUMERO_MODELO"/>
			<with-param name="NUMEROAAFECTAR" query-param="NUMEROAAFECTAR"/>
			<with-param name="NUMEROAFECTARPPTO" query-param="NUMEROAFECTARPPTO"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TIPOAAFECTAR" query-param="TIPOAAFECTAR"/>
			<with-param name="TIPOAAFECTARPPTO" query-param="TIPOAAFECTARPPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_BASEGRAVABLE" query-param="VALOR_BASEGRAVABLE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDtransacciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_TRANSACCIONES WHERE D_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND D_TRANSACCIONES.ANO= :KEY_ANO AND D_TRANSACCIONES.TIPO= :KEY_TIPO AND D_TRANSACCIONES.NUMERO_MODELO= :KEY_NUMERO_MODELO AND D_TRANSACCIONES.NUMERO= :KEY_NUMERO AND D_TRANSACCIONES.ORDEN= :KEY_ORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO_MODELO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dtransacciones">
		<call-query href="deleteDtransacciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO_MODELO" query-param="KEY_NUMERO_MODELO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ORDEN" query-param="KEY_ORDEN"/>

		</call-query>
	</resource>
	<query id="getDtransaccionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_TRANSACCIONES.COMPANIA, D_TRANSACCIONES.ANO, D_TRANSACCIONES.TIPO, D_TRANSACCIONES.NUMERO, D_TRANSACCIONES.NUMERO_MODELO, D_TRANSACCIONES.VALOR, D_TRANSACCIONES.VALOR_BASEGRAVABLE, D_TRANSACCIONES.CUENTA_CONTABLE, D_TRANSACCIONES.ORDEN, D_TRANSACCIONES.DESCRIPCION , D_TRANSACCIONMODELO.PEDIRMOSTRAR, CASE WHEN D_TRANSACCIONMODELO.PEDIRMOSTRAR IN ('P') THEN 'Digitar' ELSE 'Calcular' END MOSTRARPEDIRNOMBRE  FROM D_TRANSACCIONES INNER JOIN TRANSACCIONES ON D_TRANSACCIONES.COMPANIA = TRANSACCIONES.COMPANIA AND D_TRANSACCIONES.ANO = TRANSACCIONES.ANO AND D_TRANSACCIONES.TIPO = TRANSACCIONES.TIPO AND D_TRANSACCIONES.NUMERO_MODELO = TRANSACCIONES.NUMERO_MODELO AND D_TRANSACCIONES.NUMERO = TRANSACCIONES.NUMERO INNER JOIN TRANSACCIONMODELO ON TRANSACCIONES.COMPANIA = TRANSACCIONMODELO.COMPANIA AND TRANSACCIONES.ANO = TRANSACCIONMODELO.ANO AND TRANSACCIONES.TIPO = TRANSACCIONMODELO.TIPO AND TRANSACCIONES.NUMERO_MODELO = TRANSACCIONMODELO.NUMERO INNER JOIN D_TRANSACCIONMODELO ON TRANSACCIONMODELO.COMPANIA = D_TRANSACCIONMODELO.COMPANIA AND TRANSACCIONMODELO.ANO = D_TRANSACCIONMODELO.ANO AND TRANSACCIONMODELO.TIPO = D_TRANSACCIONMODELO.TIPO AND TRANSACCIONMODELO.NUMERO = D_TRANSACCIONMODELO.NUMERO AND D_TRANSACCIONES.ORDEN = D_TRANSACCIONMODELO.ORDEN WHERE D_TRANSACCIONES.COMPANIA = :COMPANIA AND D_TRANSACCIONES.ANO = :ANO AND D_TRANSACCIONES.TIPO = :TIPO AND D_TRANSACCIONES.NUMERO_MODELO = :NUMEROMODELO AND D_TRANSACCIONES.NUMERO = :NUMERO) WHERE (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN VALOR_BASEGRAVABLE IS NULL THEN ' ' ELSE UPPER(VALOR_BASEGRAVABLE) END)  LIKE UPPER( '%' || :VALOR_BASEGRAVABLE || '%')  AND (CASE WHEN CUENTA_CONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTA_CONTABLE) END)  LIKE UPPER(:CUENTA_CONTABLE || '%')  AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END)  LIKE UPPER(:ORDEN || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN MOSTRARPEDIRNOMBRE IS NULL THEN ' ' ELSE UPPER(MOSTRARPEDIRNOMBRE) END)  LIKE UPPER( '%' || :MOSTRARPEDIRNOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","NUMERO_MODELO":"$NUMERO_MODELO","VALOR":"$VALOR","VALOR_BASEGRAVABLE":"$VALOR_BASEGRAVABLE","CUENTA_CONTABLE":"$CUENTA_CONTABLE","ORDEN":"$ORDEN","DESCRIPCION":"$DESCRIPCION","PEDIRMOSTRAR":"$PEDIRMOSTRAR","MOSTRARPEDIRNOMBRE":"$MOSTRARPEDIRNOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMEROMODELO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_BASEGRAVABLE" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MOSTRARPEDIRNOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dtransacciones">
		<call-query href="getDtransaccionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMEROMODELO" query-param="NUMEROMODELO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_BASEGRAVABLE" query-param="VALOR_BASEGRAVABLE"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MOSTRARPEDIRNOMBRE" query-param="MOSTRARPEDIRNOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDtransaccionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_TRANSACCIONES.COMPANIA, D_TRANSACCIONES.ANO, D_TRANSACCIONES.TIPO, D_TRANSACCIONES.NUMERO, D_TRANSACCIONES.NUMERO_MODELO, D_TRANSACCIONES.VALOR, D_TRANSACCIONES.VALOR_BASEGRAVABLE, D_TRANSACCIONES.CUENTA_CONTABLE, D_TRANSACCIONES.ORDEN, D_TRANSACCIONES.DESCRIPCION , D_TRANSACCIONMODELO.PEDIRMOSTRAR, CASE WHEN D_TRANSACCIONMODELO.PEDIRMOSTRAR IN ('P') THEN 'Digitar' ELSE 'Calcular' END MOSTRARPEDIRNOMBRE  FROM D_TRANSACCIONES INNER JOIN TRANSACCIONES ON D_TRANSACCIONES.COMPANIA = TRANSACCIONES.COMPANIA AND D_TRANSACCIONES.ANO = TRANSACCIONES.ANO AND D_TRANSACCIONES.TIPO = TRANSACCIONES.TIPO AND D_TRANSACCIONES.NUMERO_MODELO = TRANSACCIONES.NUMERO_MODELO AND D_TRANSACCIONES.NUMERO = TRANSACCIONES.NUMERO INNER JOIN TRANSACCIONMODELO ON TRANSACCIONES.COMPANIA = TRANSACCIONMODELO.COMPANIA AND TRANSACCIONES.ANO = TRANSACCIONMODELO.ANO AND TRANSACCIONES.TIPO = TRANSACCIONMODELO.TIPO AND TRANSACCIONES.NUMERO_MODELO = TRANSACCIONMODELO.NUMERO INNER JOIN D_TRANSACCIONMODELO ON TRANSACCIONMODELO.COMPANIA = D_TRANSACCIONMODELO.COMPANIA AND TRANSACCIONMODELO.ANO = D_TRANSACCIONMODELO.ANO AND TRANSACCIONMODELO.TIPO = D_TRANSACCIONMODELO.TIPO AND TRANSACCIONMODELO.NUMERO = D_TRANSACCIONMODELO.NUMERO AND D_TRANSACCIONES.ORDEN = D_TRANSACCIONMODELO.ORDEN WHERE D_TRANSACCIONES.COMPANIA = :COMPANIA AND D_TRANSACCIONES.ANO = :ANO AND D_TRANSACCIONES.TIPO = :TIPO AND D_TRANSACCIONES.NUMERO_MODELO = :NUMEROMODELO AND D_TRANSACCIONES.NUMERO = :NUMERO) WHERE (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN VALOR_BASEGRAVABLE IS NULL THEN ' ' ELSE UPPER(VALOR_BASEGRAVABLE) END)  LIKE UPPER( '%' || :VALOR_BASEGRAVABLE || '%')  AND (CASE WHEN CUENTA_CONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTA_CONTABLE) END)  LIKE UPPER(:CUENTA_CONTABLE || '%')  AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END)  LIKE UPPER(:ORDEN || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN MOSTRARPEDIRNOMBRE IS NULL THEN ' ' ELSE UPPER(MOSTRARPEDIRNOMBRE) END)  LIKE UPPER( '%' || :MOSTRARPEDIRNOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMEROMODELO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_BASEGRAVABLE" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MOSTRARPEDIRNOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtransacciones/numero">
		<call-query href="getDtransaccionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMEROMODELO" query-param="NUMEROMODELO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_BASEGRAVABLE" query-param="VALOR_BASEGRAVABLE"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MOSTRARPEDIRNOMBRE" query-param="MOSTRARPEDIRNOMBRE"/>

		</call-query>
	</resource>
	<query id="getDtransaccionesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  D_TRANSACCIONES.ANO , D_TRANSACCIONES.ANO_AFECTAR_CNT , D_TRANSACCIONES.ANO_AFECTAR_PPTO , D_TRANSACCIONES.AUXILIAR , D_TRANSACCIONES.CENTRO_COSTO , D_TRANSACCIONES.COMPANIA , D_TRANSACCIONES.CUENTA_CONTABLE , D_TRANSACCIONES.CUENTA_PPTAL , D_TRANSACCIONES.DESCRIPCION ,(TO_CHAR(D_TRANSACCIONES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, D_TRANSACCIONES.FUENTE_RECURSO , D_TRANSACCIONES.NUMERO , D_TRANSACCIONES.NUMERO_MODELO , D_TRANSACCIONES.NUMEROAAFECTAR , D_TRANSACCIONES.NUMEROAFECTARPPTO , D_TRANSACCIONES.ORDEN , D_TRANSACCIONES.REFERENCIA , D_TRANSACCIONES.SUCURSAL , D_TRANSACCIONES.TERCERO , D_TRANSACCIONES.TIPO , D_TRANSACCIONES.TIPOAAFECTAR , D_TRANSACCIONES.TIPOAAFECTARPPTO , D_TRANSACCIONES.VALOR , D_TRANSACCIONES.VALOR_BASEGRAVABLE , TERCERO.NOMBRE TERCERONOMBRE , REFERENCIA.NOMBRE REFERENCIANOMBRE , FUENTE_RECURSOS.NOMBRE FUENTERECURSONOMBRE , CENTRO_COSTO.NOMBRE CENTROCOSTONOMBRE , AUXILIAR.NOMBRE AUXILIARNOMBRE, TIPOTRANSACCION.NOMBRE TIPONOMBRE, TRANSACCIONMODELO.DESCRIPCION CODIGONOMBRE  FROM D_TRANSACCIONES INNER JOIN TRANSACCIONES ON TRANSACCIONES.COMPANIA = D_TRANSACCIONES.COMPANIA AND TRANSACCIONES.ANO = D_TRANSACCIONES.ANO AND TRANSACCIONES.TIPO = D_TRANSACCIONES.TIPO AND TRANSACCIONES.NUMERO_MODELO = D_TRANSACCIONES.NUMERO_MODELO AND TRANSACCIONES.NUMERO = D_TRANSACCIONES.NUMERO INNER JOIN TERCERO ON D_TRANSACCIONES.COMPANIA = TERCERO.COMPANIA AND D_TRANSACCIONES.TERCERO = TERCERO.NIT AND D_TRANSACCIONES.SUCURSAL = TERCERO.SUCURSAL INNER JOIN REFERENCIA ON D_TRANSACCIONES.COMPANIA = REFERENCIA.COMPANIA AND D_TRANSACCIONES.ANO = REFERENCIA.ANO AND D_TRANSACCIONES.REFERENCIA = REFERENCIA.CODIGO INNER JOIN FUENTE_RECURSOS ON D_TRANSACCIONES.COMPANIA = FUENTE_RECURSOS.COMPANIA AND D_TRANSACCIONES.ANO = FUENTE_RECURSOS.ANO AND D_TRANSACCIONES.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO INNER JOIN CENTRO_COSTO ON D_TRANSACCIONES.COMPANIA = CENTRO_COSTO.COMPANIA AND D_TRANSACCIONES.ANO = CENTRO_COSTO.ANO AND D_TRANSACCIONES.CENTRO_COSTO = CENTRO_COSTO.CODIGO INNER JOIN AUXILIAR ON D_TRANSACCIONES.COMPANIA = AUXILIAR.COMPANIA AND D_TRANSACCIONES.ANO = AUXILIAR.ANO AND D_TRANSACCIONES.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN TIPOTRANSACCION ON D_TRANSACCIONES.COMPANIA = TIPOTRANSACCION.COMPANIA AND D_TRANSACCIONES.TIPO = TIPOTRANSACCION.CODIGO LEFT JOIN TRANSACCIONMODELO ON D_TRANSACCIONES.COMPANIA = TRANSACCIONMODELO.COMPANIA AND D_TRANSACCIONES.TIPO = TRANSACCIONMODELO.TIPO WHERE D_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND D_TRANSACCIONES.ANO= :KEY_ANO AND D_TRANSACCIONES.TIPO= :KEY_TIPO AND D_TRANSACCIONES.NUMERO_MODELO= :KEY_NUMERO_MODELO AND D_TRANSACCIONES.NUMERO= :KEY_NUMERO AND D_TRANSACCIONES.ORDEN= :KEY_ORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","ANO_AFECTAR_CNT":"$ANO_AFECTAR_CNT(type:integer)","ANO_AFECTAR_PPTO":"$ANO_AFECTAR_PPTO(type:integer)","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","COMPANIA":"$COMPANIA","CUENTA_CONTABLE":"$CUENTA_CONTABLE","CUENTA_PPTAL":"$CUENTA_PPTAL","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","FUENTE_RECURSO":"$FUENTE_RECURSO","NUMERO":"$NUMERO(type:long)","NUMERO_MODELO":"$NUMERO_MODELO","NUMEROAAFECTAR":"$NUMEROAAFECTAR(type:long)","NUMEROAFECTARPPTO":"$NUMEROAFECTARPPTO(type:long)","ORDEN":"$ORDEN","REFERENCIA":"$REFERENCIA","SUCURSAL":"$SUCURSAL","TERCERO":"$TERCERO","TIPO":"$TIPO","TIPOAAFECTAR":"$TIPOAAFECTAR","TIPOAAFECTARPPTO":"$TIPOAAFECTARPPTO","VALOR":"$VALOR","VALOR_BASEGRAVABLE":"$VALOR_BASEGRAVABLE","TERCERONOMBRE":"$TERCERONOMBRE","REFERENCIANOMBRE":"$REFERENCIANOMBRE","FUENTERECURSONOMBRE":"$FUENTERECURSONOMBRE","CENTROCOSTONOMBRE":"$CENTROCOSTONOMBRE","AUXILIARNOMBRE":"$AUXILIARNOMBRE","TIPONOMBRE":"$TIPONOMBRE","CODIGONOMBRE":"$CODIGONOMBRE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO_MODELO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtransacciones/data">
		<call-query href="getDtransaccionesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO_MODELO" query-param="KEY_NUMERO_MODELO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ORDEN" query-param="KEY_ORDEN"/>

		</call-query>
	</resource>
	<query id="updateDtransacciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_TRANSACCIONES SET ANO=:ANO, CUENTA_CONTABLE=:CUENTA_CONTABLE, DESCRIPCION=:DESCRIPCION, NUMERO=:NUMERO, NUMERO_MODELO=:NUMERO_MODELO, ORDEN=:ORDEN, TIPO=:TIPO, VALOR=:VALOR, VALOR_BASEGRAVABLE=:VALOR_BASEGRAVABLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND D_TRANSACCIONES.ANO= :KEY_ANO AND D_TRANSACCIONES.TIPO= :KEY_TIPO AND D_TRANSACCIONES.NUMERO_MODELO= :KEY_NUMERO_MODELO AND D_TRANSACCIONES.NUMERO= :KEY_NUMERO AND D_TRANSACCIONES.ORDEN= :KEY_ORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
