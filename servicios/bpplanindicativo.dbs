	<query id="getBpplanindicativoPagCargarvigenciainicialfinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CONCAT( VIGENCIA_INICIAL , VIGENCIA_FINAL) LLAVE, VIGENCIA_INICIAL, VIGENCIA_FINAL FROM BP_PLAN_INDICATIVO WHERE COMPANIA =:COMPANIA ORDER BY VIGENCIA_INICIAL) INI WHERE (CASE WHEN LLAVE IS NULL THEN ' ' ELSE UPPER(LLAVE) END) LIKE UPPER(CONCAT(:LLAVE, '%')) AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END) LIKE UPPER(CONCAT(:VIGENCIA_INICIAL, '%')) AND (CASE WHEN VIGENCIA_FINAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_FINAL) END) LIKE UPPER(CONCAT(:VIGENCIA_FINAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LLAVE":"$LLAVE","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","VIGENCIA_FINAL":"$VIGENCIA_FINAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LLAVE" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo/cargarvigenciainicialfinal/pag">
		<call-query href="getBpplanindicativoPagCargarvigenciainicialfinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="LLAVE" query-param="LLAVE"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA_FINAL" query-param="VIGENCIA_FINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumCargarvigenciainicialfinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT CONCAT( VIGENCIA_INICIAL , VIGENCIA_FINAL) LLAVE, VIGENCIA_INICIAL, VIGENCIA_FINAL FROM BP_PLAN_INDICATIVO WHERE COMPANIA =:COMPANIA ORDER BY VIGENCIA_INICIAL) INI WHERE (CASE WHEN LLAVE IS NULL THEN ' ' ELSE UPPER(LLAVE) END) LIKE UPPER(CONCAT(:LLAVE, '%')) AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END) LIKE UPPER(CONCAT(:VIGENCIA_INICIAL, '%')) AND (CASE WHEN VIGENCIA_FINAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_FINAL) END) LIKE UPPER(CONCAT(:VIGENCIA_FINAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="LLAVE" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>

	</query>
