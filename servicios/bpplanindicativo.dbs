	<query id="getBpplanindicativoTotalPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(PONDERACION) AS TOTAL  FROM BP_PLAN_INDICATIVO WHERE LENGTH(ID) IN (SELECT DIGITOS FROM BP_NIVEL_PLAN_IND WHERE VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND META_PRODUC &lt;&gt; 0 ) AND VIGENCIA_INICIAL = :VIGENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL"}]}}		</result>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/totalporvigencia">
		<call-query href="getBpplanindicativoTotalPorVigenciaQuery">
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoDescrplanindQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DESCRIPCION_TEXTO_BP  FROM BP_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA AND ID = :ID_PLAN AND VIGENCIA_INICIAL = :VIGENCIA_PLAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION_TEXTO_BP":"$DESCRIPCION_TEXTO_BP"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/descrplanind">
		<call-query href="getBpplanindicativoDescrplanindQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_PLAN" query-param="VIGENCIA_PLAN"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoEstructuraDelPlanQuery"  useConfig="sysmandsunist">
		<sql>SELECT  A.ID, N.DESCRIPCION NIVEL,(CASE N.META_RESUL WHEN 0 THEN 'false' ELSE 'true' END) ES_PROGRAMA, A.DESCRIPCION, A.DESCRIPCION_TEXTO_BP OBJETIVO  FROM BP_PLAN_INDICATIVO A INNER JOIN BP_PLAN_INDICATIVO B ON A.COMPANIA = B.COMPANIA AND A.VIGENCIA_INICIAL = B.VIGENCIA_INICIAL AND A.ID &lt; B.PREDECESOR INNER JOIN BP_NIVEL_PLAN_IND N ON A.COMPANIA = N.COMPANIA AND A.VIGENCIA_INICIAL = N.VIGENCIA AND LENGTH(A.ID) = N.DIGITOS WHERE B.COMPANIA = :COMPANIA AND B.VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND B.ID = :ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NIVEL":"$NIVEL","ES_PROGRAMA":"$ES_PROGRAMA(type:boolean)","DESCRIPCION":"$DESCRIPCION","OBJETIVO":"$OBJETIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/estructuradelplan">
		<call-query href="getBpplanindicativoEstructuraDelPlanQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID" query-param="ID"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPorAccionYCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.DESCRIPCION  FROM BP_PLAN_INDICATIVO INNER JOIN BP_NIVEL_PLAN_IND ON BP_PLAN_INDICATIVO.COMPANIA = BP_NIVEL_PLAN_IND.COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_NIVEL_PLAN_IND.VIGENCIA WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND LENGTH(BP_PLAN_INDICATIVO.ID) = BP_NIVEL_PLAN_IND.DIGITOS AND NVL(BP_PLAN_INDICATIVO.CODIGOBPIM,'N') ='N' AND BP_NIVEL_PLAN_IND.ACCION NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/poraccionycompania">
		<call-query href="getBpplanindicativoPorAccionYCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPagTodosPorCompaniaVigenciaProgramaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  *  FROM (SELECT '99999999999' AS ID, 'TODAS' AS DESCRIPCION FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL UNION SELECT DISTINCT BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL WHERE BP_NIVEL_PLAN_IND.COMPANIA= :COMPANIA AND LENGTH(BP_PLAN_INDICATIVO.ID) =:NIVEL AND BP_NIVEL_PLAN_IND.VIGENCIA = :VIGENCIAPLANP ) ORDER BY ID ASC) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="VIGENCIAPLANP" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo/todosporcompaniavigenciaprograma/pag">
		<call-query href="getBpplanindicativoPagTodosPorCompaniaVigenciaProgramaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="VIGENCIAPLANP" query-param="VIGENCIAPLANP"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumTodosPorCompaniaVigenciaProgramaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  *  FROM (SELECT '99999999999' AS ID, 'TODAS' AS DESCRIPCION FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL UNION SELECT DISTINCT BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL WHERE BP_NIVEL_PLAN_IND.COMPANIA= :COMPANIA AND LENGTH(BP_PLAN_INDICATIVO.ID) =:NIVEL AND BP_NIVEL_PLAN_IND.VIGENCIA = :VIGENCIAPLANP ) ORDER BY ID ASC) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="VIGENCIAPLANP" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/todosporcompaniavigenciaprograma/num">
		<call-query href="getBpplanindicativoNumTodosPorCompaniaVigenciaProgramaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="VIGENCIAPLANP" query-param="VIGENCIAPLANP"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPagMetadeproductoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION, DESCRIPCION_TEXTO_BP, DECODE (TIPO_META_INDICADOR, 'MI', 'Meta Incremento', 'MM', 'Meta Mantenimiento', 'MR', 'Meta Reduccion', 'MG', 'Meta Gestion') TIPO_META, LB, META, CASE WHEN TIPO_META_INDICADOR = 'MR' THEN (LB - META) ELSE CASE WHEN TIPO_META_INDICADOR = 'MI' THEN (META - LB) ELSE META END END CANT_PROG, DEPENDENCIA, DESCRIPCION_INDICADOR, VIGENCIA_FINAL  FROM BP_PLAN_INDICATIVO LEFT JOIN BP_NIVEL_PLAN_IND ON BP_PLAN_INDICATIVO.COMPANIA = BP_NIVEL_PLAN_IND.COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_NIVEL_PLAN_IND.VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) = BP_NIVEL_PLAN_IND.DIGITOS WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND BP_NIVEL_PLAN_IND.META_PRODUC NOT IN (0) ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","DESCRIPCION":"$DESCRIPCION","DESCRIPCION_TEXTO_BP":"$DESCRIPCION_TEXTO_BP","TIPO_META":"$TIPO_META","LB":"$LB","META":"$META","CANT_PROG":"$CANT_PROG","DEPENDENCIA":"$DEPENDENCIA","DESCRIPCION_INDICADOR":"$DESCRIPCION_INDICADOR","VIGENCIA_FINAL":"$VIGENCIA_FINAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo/metadeproducto/pag">
		<call-query href="getBpplanindicativoPagMetadeproductoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumMetadeproductoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION, DESCRIPCION_TEXTO_BP, DECODE (TIPO_META_INDICADOR, 'MI', 'Meta Incremento', 'MM', 'Meta Mantenimiento', 'MR', 'Meta Reduccion', 'MG', 'Meta Gestion') TIPO_META, LB, META, CASE WHEN TIPO_META_INDICADOR = 'MR' THEN (LB - META) ELSE CASE WHEN TIPO_META_INDICADOR = 'MI' THEN (META - LB) ELSE META END END CANT_PROG, DEPENDENCIA, DESCRIPCION_INDICADOR, VIGENCIA_FINAL  FROM BP_PLAN_INDICATIVO LEFT JOIN BP_NIVEL_PLAN_IND ON BP_PLAN_INDICATIVO.COMPANIA = BP_NIVEL_PLAN_IND.COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_NIVEL_PLAN_IND.VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) = BP_NIVEL_PLAN_IND.DIGITOS WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND BP_NIVEL_PLAN_IND.META_PRODUC NOT IN (0) ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/metadeproducto/num">
		<call-query href="getBpplanindicativoNumMetadeproductoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPagTodosPorCompaniaNivelVigenciaPlanQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  *  FROM (SELECT '99999999999' AS ID, 'TODAS' AS DESCRIPCION, TO_NUMBER(TO_CHAR(sysdate, 'YYYY')) VIGENCIA FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL UNION SELECT DISTINCT BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION, BP_NIVEL_PLAN_IND.VIGENCIA FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL WHERE BP_NIVEL_PLAN_IND.COMPANIA = :COMPANIA AND LENGTH(BP_PLAN_INDICATIVO.ID)= :NIVEL AND BP_NIVEL_PLAN_IND.VIGENCIA = :VIGENCIAPLANP ) ORDER BY ID DESC) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","DESCRIPCION":"$DESCRIPCION","VIGENCIA":"$VIGENCIA(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="VIGENCIAPLANP" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo/todosporcompanianivelvigenciaplan/pag">
		<call-query href="getBpplanindicativoPagTodosPorCompaniaNivelVigenciaPlanQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="VIGENCIAPLANP" query-param="VIGENCIAPLANP"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumTodosPorCompaniaNivelVigenciaPlanQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  *  FROM (SELECT '99999999999' AS ID, 'TODAS' AS DESCRIPCION, TO_NUMBER(TO_CHAR(sysdate, 'YYYY')) VIGENCIA FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL UNION SELECT DISTINCT BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION, BP_NIVEL_PLAN_IND.VIGENCIA FROM BP_NIVEL_PLAN_IND INNER JOIN BP_PLAN_INDICATIVO ON BP_NIVEL_PLAN_IND.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_NIVEL_PLAN_IND.VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL WHERE BP_NIVEL_PLAN_IND.COMPANIA = :COMPANIA AND LENGTH(BP_PLAN_INDICATIVO.ID)= :NIVEL AND BP_NIVEL_PLAN_IND.VIGENCIA = :VIGENCIAPLANP ) ORDER BY ID DESC) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="VIGENCIAPLANP" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/todosporcompanianivelvigenciaplan/num">
		<call-query href="getBpplanindicativoNumTodosPorCompaniaNivelVigenciaPlanQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="VIGENCIAPLANP" query-param="VIGENCIAPLANP"/>
			<with-param name="ID" query-param="ID"/>
