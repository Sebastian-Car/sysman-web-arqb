	<query id="getBpplanindicativoPagMetasProyectoPorVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ID, DESCRIPCION FROM BP_PLAN_INDICATIVO WHERE LENGTH(ID) = ( SELECT DIGITOS FROM BP_NIVEL_PLAN_IND WHERE VIGENCIA = :VIGENCIA AND META_PRODUC &lt;&gt; 0 )) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
