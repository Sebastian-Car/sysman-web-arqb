	<query id="getBpplanindicativoValoresPorFuentesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(BP_PLAN_INDICATIVO_FUENTES.VALOR_POR_FUENTES) VALOR_FUENTE, FUENTE_RECURSOS.TIPO_RECURSO  FROM BP_PLAN_INDICATIVO INNER JOIN BP_PLAN_INDICATIVO_FUENTES ON BP_PLAN_INDICATIVO.COMPANIA = BP_PLAN_INDICATIVO_FUENTES.COMPANIA AND BP_PLAN_INDICATIVO.ID = BP_PLAN_INDICATIVO_FUENTES.ID_PLAN AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_PLAN INNER JOIN FUENTE_RECURSOS ON BP_PLAN_INDICATIVO_FUENTES.COMPANIA = FUENTE_RECURSOS.COMPANIA AND BP_PLAN_INDICATIVO_FUENTES.VIGENCIA_META = FUENTE_RECURSOS.ANO AND BP_PLAN_INDICATIVO_FUENTES.FUENTE = FUENTE_RECURSOS.CODIGO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.ID = :ID AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND FUENTE_RECURSOS.TIPO_RECURSO IS NOT NULL GROUP BY FUENTE_RECURSOS.TIPO_RECURSO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_FUENTE":"$VALOR_FUENTE(type:integer)","TIPO_RECURSO":"$TIPO_RECURSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/valoresporfuentes">
