	</resource>
	<query id="getBpplanindicativoPagPlandesarrollotrazQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.DESCRIPCION, ( CASE WHEN ( SELECT META_RESUL FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH( NVL( BP_PLAN_INDICATIVO.ID, 0 ) ) ) NOT IN ( 0 ) THEN 'Meta de resultado' ELSE CASE WHEN ( SELECT META_PRODUC FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH( NVL( BP_PLAN_INDICATIVO.ID, 0 ) ) ) NOT IN ( 0 ) THEN 'Meta de producto' ELSE 'Sin tipo meta' END END ) TIPO_META, BP_PLAN_INDICATIVO.TIPO_META_PLAN FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) &lt;&gt; :ACCION ORDER BY BP_PLAN_INDICATIVO.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN TIPO_META IS NULL THEN ' ' ELSE UPPER(TIPO_META) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_META), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","DESCRIPCION":"$DESCRIPCION","TIPO_META":"$TIPO_META","TIPO_META_PLAN":"$TIPO_META_PLAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO_META" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo/plandesarrollotraz/pag">
		<call-query href="getBpplanindicativoPagPlandesarrollotrazQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPO_META" query-param="TIPO_META"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumPlandesarrollotrazQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.DESCRIPCION, ( CASE WHEN ( SELECT META_RESUL FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH( NVL( BP_PLAN_INDICATIVO.ID, 0 ) ) ) NOT IN ( 0 ) THEN 'Meta de resultado' ELSE CASE WHEN ( SELECT META_PRODUC FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH( NVL( BP_PLAN_INDICATIVO.ID, 0 ) ) ) NOT IN ( 0 ) THEN 'Meta de producto' ELSE 'Sin tipo meta' END END ) TIPO_META, BP_PLAN_INDICATIVO.TIPO_META_PLAN FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) &lt;&gt; :ACCION ORDER BY BP_PLAN_INDICATIVO.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN TIPO_META IS NULL THEN ' ' ELSE UPPER(TIPO_META) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_META), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO_META" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/plandesarrollotraz/num">
		<call-query href="getBpplanindicativoNumPlandesarrollotrazQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPO_META" query-param="TIPO_META"/>

		</call-query>
	</resource>
