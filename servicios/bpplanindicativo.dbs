			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoCalcularmetabrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM( CASE WHEN P.TIPO_META_INDICADOR = 'MR' THEN NVL(P.LB,0) - NVL(M.CANTIDAD_PROGRAMADA,0) ELSE CASE WHEN P.TIPO_META_INDICADOR='MI' THEN NVL(P.LB,0) + NVL(M.CANTIDAD_PROGRAMADA,0) END END) ACUM_BRUTA, P.TIPO_META_INDICADOR, P.META  FROM BP_PLAN_INDICATIVO P LEFT JOIN BP_PLAN_INDICATIVO_METAS M ON P.COMPANIA = M.COMPANIA AND P.ID = M.ID_PLAN AND P.VIGENCIA_INICIAL = M.VIGENCIA_PLAN WHERE P.COMPANIA = :COMPANIA AND P.ID = :CODIGO GROUP BY P.TIPO_META_INDICADOR, P.META</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ACUM_BRUTA":"$ACUM_BRUTA(type:double)","TIPO_META_INDICADOR":"$TIPO_META_INDICADOR","META":"$META"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/calcularmetabruta">
		<call-query href="getBpplanindicativoCalcularmetabrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoValoresreprogramarQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CASE WHEN P.TIPO_META_INDICADOR = 'MR' THEN NVL(P.LB,0) - NVL(P.META,0) ELSE CASE WHEN P.TIPO_META_INDICADOR = 'MI' THEN NVL(P.META,0) - NVL(P.LB,0) ELSE NVL(P.META,0) END END AS A_PROGRAMAR, SUM(M.PONDERACION_META) AS PONDERACION_META, SUM(M.CANTIDAD_PROGRAMADA) AS CANTIDAD_PROGRAMADA  FROM BP_PLAN_INDICATIVO P LEFT JOIN BP_PLAN_INDICATIVO_METAS M ON P.COMPANIA = M.COMPANIA AND P.ID = M.ID_PLAN AND P.VIGENCIA_INICIAL = M.VIGENCIA_PLAN WHERE P.COMPANIA = :COMPANIA AND P.ID = :CODIGO AND P.VIGENCIA_INICIAL = :VIGENCIA GROUP BY P.ID, P.LB, P.META, P.TIPO_META_INDICADOR, P.VIGENCIA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"A_PROGRAMAR":"$A_PROGRAMAR(type:integer)","PONDERACION_META":"$PONDERACION_META(type:double)","CANTIDAD_PROGRAMADA":"$CANTIDAD_PROGRAMADA(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/valoresreprogramar">
		<call-query href="getBpplanindicativoValoresreprogramarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoSectorPorIdentificadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_PLAN_INDICATIVO.SECTOR  FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA= :COMPANIA AND BP_PLAN_INDICATIVO.ID = :INDICADOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SECTOR":"$SECTOR"}]}}		</result>
