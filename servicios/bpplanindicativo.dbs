			<with-param name="DESCRIPCION_INDICADOR_MEDIDA" query-param="DESCRIPCION_INDICADOR_MEDIDA"/>
			<with-param name="NOMBRE_INDICADOR" query-param="NOMBRE_INDICADOR"/>
			<with-param name="META" query-param="META"/>
			<with-param name="LB" query-param="LB"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="DESCRIPCION_INDICADOR" query-param="DESCRIPCION_INDICADOR"/>
			<with-param name="DESCRIPCION_TEXTO_BP" query-param="DESCRIPCION_TEXTO_BP"/>
