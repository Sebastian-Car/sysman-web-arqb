	<query id="getBpplanindicativoPagSubProgramaEquiQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.ID, BP_PLAN_ADQUISICIONES.CODIGO , BP_PLAN_INDICATIVO.DESCRIPCION  FROM BP_PLAN_INDICATIVO INNER JOIN BP_PLAN_INDICATIVO_METAS ON BP_PLAN_INDICATIVO.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA AND BP_PLAN_INDICATIVO.ID = BP_PLAN_INDICATIVO_METAS.ID_PLAN AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN INNER JOIN BP_PLAN_ADQUISICIONES ON BP_PLAN_INDICATIVO.COMPANIA = BP_PLAN_ADQUISICIONES.COMPANIA AND BP_PLAN_INDICATIVO.ID = BP_PLAN_ADQUISICIONES.ID_PLAN AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_META = :VIGENCIA) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
