<data name="bpplanindicativo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpplanindicativoExistePlanQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM BP_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA AND VIGENCIA_INICIAL = :VIGENCIA AND ID = :ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/existeplan">
		<call-query href="getBpplanindicativoExistePlanQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPorCompaniaYIdQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID ID_PLAN, DESCRIPCION  FROM BP_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA AND VIGENCIA_INICIAL = :VIGENCIA AND ID = :ID_PLAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN":"$ID_PLAN","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/porcompaniayid">
		<call-query href="getBpplanindicativoPorCompaniaYIdQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoIdPorCompaniaYpredecesorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID ID_PLAN, DESCRIPCION  FROM BP_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA AND VIGENCIA_INICIAL = :VIGENCIA AND PREDECESOR = :PREDECESOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN":"$ID_PLAN","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/idporcompaniaypredecesor">
		<call-query href="getBpplanindicativoIdPorCompaniaYpredecesorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPorCompaniaYCodigobpimQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID, VIGENCIA_INICIAL  FROM BP_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA AND CODIGOBPIM = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/porcompaniaycodigobpim">
		<call-query href="getBpplanindicativoPorCompaniaYCodigobpimQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoDescripcionPorNivelYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_PLAN_INDICATIVO.DESCRIPCION  FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.ID = :NIVEL AND VIGENCIA_INICIAL &lt;= :VIGENCIA_INICIAL AND VIGENCIA_FINAL &gt;= :VIGENCIA_FINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/descripcionpornivelyvigencia">
		<call-query href="getBpplanindicativoDescripcionPorNivelYVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA_FINAL" query-param="VIGENCIA_FINAL"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoDescripcionPorNivelQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_PLAN_INDICATIVO.DESCRIPCION  FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.ID = :NIVEL AND VIGENCIA_INICIAL &lt;= :VIGENCIAINICIAL AND VIGENCIA_FINAL &gt;= :VIGENCIAFINAL AND ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="VIGENCIAINICIAL" sqlType="STRING"/>
		<param name="VIGENCIAFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/descripcionpornivel">
		<call-query href="getBpplanindicativoDescripcionPorNivelQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="VIGENCIAINICIAL" query-param="VIGENCIAINICIAL"/>
			<with-param name="VIGENCIAFINAL" query-param="VIGENCIAFINAL"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPagPondPorCiaVigQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.PONDERACION,(CASE BP_NIVEL_PLAN_IND.META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC FROM BP_PLAN_INDICATIVO INNER JOIN BP_NIVEL_PLAN_IND ON BP_PLAN_INDICATIVO.COMPANIA = BP_NIVEL_PLAN_IND.COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_NIVEL_PLAN_IND.VIGENCIA WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND BP_NIVEL_PLAN_IND.DIGITOS = LENGTH(BP_PLAN_INDICATIVO.ID) ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER( '%' || :ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END)  LIKE UPPER( '%' || :VIGENCIA_INICIAL || '%')  AND (CASE WHEN PONDERACION IS NULL THEN ' ' ELSE UPPER(PONDERACION) END)  LIKE UPPER( '%' || :PONDERACION || '%')  AND (CASE WHEN META_PRODUC IS NULL THEN ' ' ELSE UPPER(META_PRODUC) END)  LIKE UPPER( '%' || :META_PRODUC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","DESCRIPCION":"$DESCRIPCION","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","PONDERACION":"$PONDERACION","META_PRODUC":"$META_PRODUC(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="PONDERACION" sqlType="STRING"/>
		<param name="META_PRODUC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo/pondporciavig/pag">
		<call-query href="getBpplanindicativoPagPondPorCiaVigQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="PONDERACION" query-param="PONDERACION"/>
			<with-param name="META_PRODUC" query-param="META_PRODUC"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumPondPorCiaVigQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.PONDERACION,(CASE BP_NIVEL_PLAN_IND.META_PRODUC WHEN 0 THEN 'false' ELSE 'true' END) META_PRODUC FROM BP_PLAN_INDICATIVO INNER JOIN BP_NIVEL_PLAN_IND ON BP_PLAN_INDICATIVO.COMPANIA = BP_NIVEL_PLAN_IND.COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_NIVEL_PLAN_IND.VIGENCIA WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND BP_NIVEL_PLAN_IND.DIGITOS = LENGTH(BP_PLAN_INDICATIVO.ID) ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER( '%' || :ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END)  LIKE UPPER( '%' || :VIGENCIA_INICIAL || '%')  AND (CASE WHEN PONDERACION IS NULL THEN ' ' ELSE UPPER(PONDERACION) END)  LIKE UPPER( '%' || :PONDERACION || '%')  AND (CASE WHEN META_PRODUC IS NULL THEN ' ' ELSE UPPER(META_PRODUC) END)  LIKE UPPER( '%' || :META_PRODUC || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="PONDERACION" sqlType="STRING"/>
		<param name="META_PRODUC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/pondporciavig/num">
		<call-query href="getBpplanindicativoNumPondPorCiaVigQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="PONDERACION" query-param="PONDERACION"/>
			<with-param name="META_PRODUC" query-param="META_PRODUC"/>

		</call-query>
	</resource>
	<query id="updateBpplanindicativoPondPorCiaVig" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PLAN_INDICATIVO SET PONDERACION=:PONDERACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO.ID= :KEY_ID AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PONDERACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpplanindicativo/pondporciavig">
		<call-query href="updateBpplanindicativoPondPorCiaVig">
			<with-param name="PONDERACION" query-param="PONDERACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="insertBpplanindicativo" keyColumns="COMPANIA,ID,VIGENCIA_INICIAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_PLAN_INDICATIVO (COMPANIA, ID, VIGENCIA_INICIAL, VIGENCIA_FINAL, DESCRIPCION, PONDERACION, TIPO_META_PLAN, TIPO_META_INDICADOR, UNIDAD_MEDIDA, AVANCE, AVANCE_FINANCIERO, DESCRIPCION_INDICADOR_MEDIDA, NOMBRE_INDICADOR, META, LB, DEPENDENCIA, DESCRIPCION_INDICADOR, DESCRIPCION_TEXTO_BP, SECTOR, ES_INDICADOR, PREDECESOR, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ID, :VIGENCIA_INICIAL, :VIGENCIA_FINAL, :DESCRIPCION, :PONDERACION, :TIPO_META_PLAN, :TIPO_META_INDICADOR, :UNIDAD_MEDIDA, :AVANCE, :AVANCE_FINANCIERO, :DESCRIPCION_INDICADOR_MEDIDA, :NOMBRE_INDICADOR, :META, :LB, :DEPENDENCIA, :DESCRIPCION_INDICADOR, :DESCRIPCION_TEXTO_BP, :SECTOR, :ES_INDICADOR, :PREDECESOR, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID":"$ID","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="PONDERACION" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_META_PLAN" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_META_INDICADOR" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD_MEDIDA" sqlType="STRING"/>
		<param defaultValue="0" name="AVANCE" sqlType="STRING"/>
		<param defaultValue="0" name="AVANCE_FINANCIERO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_INDICADOR_MEDIDA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_INDICADOR" sqlType="STRING"/>
		<param defaultValue="0" name="META" sqlType="STRING"/>
		<param defaultValue="0" name="LB" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_INDICADOR" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_TEXTO_BP" sqlType="STRING"/>
		<param defaultValue="" name="SECTOR" sqlType="STRING"/>
		<param defaultValue="0" name="ES_INDICADOR" sqlType="STRING"/>
		<param defaultValue="" name="PREDECESOR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpplanindicativo">
		<call-query href="insertBpplanindicativo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA_FINAL" query-param="VIGENCIA_FINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PONDERACION" query-param="PONDERACION"/>
			<with-param name="TIPO_META_PLAN" query-param="TIPO_META_PLAN"/>
			<with-param name="TIPO_META_INDICADOR" query-param="TIPO_META_INDICADOR"/>
			<with-param name="UNIDAD_MEDIDA" query-param="UNIDAD_MEDIDA"/>
			<with-param name="AVANCE" query-param="AVANCE"/>
			<with-param name="AVANCE_FINANCIERO" query-param="AVANCE_FINANCIERO"/>
			<with-param name="DESCRIPCION_INDICADOR_MEDIDA" query-param="DESCRIPCION_INDICADOR_MEDIDA"/>
			<with-param name="NOMBRE_INDICADOR" query-param="NOMBRE_INDICADOR"/>
			<with-param name="META" query-param="META"/>
			<with-param name="LB" query-param="LB"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="DESCRIPCION_INDICADOR" query-param="DESCRIPCION_INDICADOR"/>
			<with-param name="DESCRIPCION_TEXTO_BP" query-param="DESCRIPCION_TEXTO_BP"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="ES_INDICADOR" query-param="ES_INDICADOR"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteBpplanindicativo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO.ID= :KEY_ID AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="bpplanindicativo">
		<call-query href="deleteBpplanindicativo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.DESCRIPCION, ( CASE WHEN (SELECT META_RESUL FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH(NVL( BP_PLAN_INDICATIVO.ID ,0))) NOT IN(0) THEN 'Meta de resultado' ELSE CASE WHEN (SELECT META_PRODUC FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH(NVL( BP_PLAN_INDICATIVO.ID ,0))) NOT IN(0) THEN 'Meta de producto' ELSE 'Sin tipo meta' END END) TIPO_META, BP_PLAN_INDICATIVO.TIPO_META_PLAN  FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN TIPO_META IS NULL THEN ' ' ELSE UPPER(TIPO_META) END)  LIKE UPPER( '%' || :TIPO_META || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","DESCRIPCION":"$DESCRIPCION","TIPO_META":"$TIPO_META","TIPO_META_PLAN":"$TIPO_META_PLAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO_META" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo">
		<call-query href="getBpplanindicativoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPO_META" query-param="TIPO_META"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.DESCRIPCION, ( CASE WHEN (SELECT META_RESUL FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH(NVL( BP_PLAN_INDICATIVO.ID ,0))) NOT IN(0) THEN 'Meta de resultado' ELSE CASE WHEN (SELECT META_PRODUC FROM BP_NIVEL_PLAN_IND WHERE COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND VIGENCIA = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL AND DIGITOS = LENGTH(NVL( BP_PLAN_INDICATIVO.ID ,0))) NOT IN(0) THEN 'Meta de producto' ELSE 'Sin tipo meta' END END) TIPO_META, BP_PLAN_INDICATIVO.TIPO_META_PLAN  FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN TIPO_META IS NULL THEN ' ' ELSE UPPER(TIPO_META) END)  LIKE UPPER( '%' || :TIPO_META || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO_META" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/numero">
		<call-query href="getBpplanindicativoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPO_META" query-param="TIPO_META"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID, VIGENCIA_INICIAL, VIGENCIA_FINAL, DESCRIPCION, PONDERACION, TIPO_META_PLAN, TIPO_META_INDICADOR, UNIDAD_MEDIDA, AVANCE, AVANCE_FINANCIERO, DESCRIPCION_INDICADOR_MEDIDA, NOMBRE_INDICADOR, META, LB, DEPENDENCIA, DESCRIPCION_INDICADOR, DESCRIPCION_TEXTO_BP, SECTOR,(CASE ES_INDICADOR WHEN 0 THEN 'false' ELSE 'true' END) ES_INDICADOR, PREDECESOR, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO.ID= :KEY_ID AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","VIGENCIA_FINAL":"$VIGENCIA_FINAL(type:integer)","DESCRIPCION":"$DESCRIPCION","PONDERACION":"$PONDERACION","TIPO_META_PLAN":"$TIPO_META_PLAN","TIPO_META_INDICADOR":"$TIPO_META_INDICADOR","UNIDAD_MEDIDA":"$UNIDAD_MEDIDA","AVANCE":"$AVANCE","AVANCE_FINANCIERO":"$AVANCE_FINANCIERO","DESCRIPCION_INDICADOR_MEDIDA":"$DESCRIPCION_INDICADOR_MEDIDA","NOMBRE_INDICADOR":"$NOMBRE_INDICADOR","META":"$META","LB":"$LB","DEPENDENCIA":"$DEPENDENCIA","DESCRIPCION_INDICADOR":"$DESCRIPCION_INDICADOR","DESCRIPCION_TEXTO_BP":"$DESCRIPCION_TEXTO_BP","SECTOR":"$SECTOR","ES_INDICADOR":"$ES_INDICADOR(type:boolean)","PREDECESOR":"$PREDECESOR","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/data">
		<call-query href="getBpplanindicativoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="updateBpplanindicativo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PLAN_INDICATIVO SET COMPANIA=:COMPANIA, ID=:ID, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, VIGENCIA_FINAL=:VIGENCIA_FINAL, DESCRIPCION=:DESCRIPCION, PONDERACION=:PONDERACION, TIPO_META_PLAN=:TIPO_META_PLAN, TIPO_META_INDICADOR=:TIPO_META_INDICADOR, UNIDAD_MEDIDA=:UNIDAD_MEDIDA, AVANCE=:AVANCE, AVANCE_FINANCIERO=:AVANCE_FINANCIERO, DESCRIPCION_INDICADOR_MEDIDA=:DESCRIPCION_INDICADOR_MEDIDA, NOMBRE_INDICADOR=:NOMBRE_INDICADOR, META=:META, LB=:LB, DEPENDENCIA=:DEPENDENCIA, DESCRIPCION_INDICADOR=:DESCRIPCION_INDICADOR, DESCRIPCION_TEXTO_BP=:DESCRIPCION_TEXTO_BP, SECTOR=:SECTOR, ES_INDICADOR=:ES_INDICADOR, PREDECESOR=:PREDECESOR, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE BP_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO.ID= :KEY_ID AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PONDERACION" sqlType="STRING"/>
		<param name="TIPO_META_PLAN" sqlType="STRING"/>
		<param name="TIPO_META_INDICADOR" sqlType="STRING"/>
		<param name="UNIDAD_MEDIDA" sqlType="STRING"/>
		<param name="AVANCE" sqlType="STRING"/>
		<param name="AVANCE_FINANCIERO" sqlType="STRING"/>
		<param name="DESCRIPCION_INDICADOR_MEDIDA" sqlType="STRING"/>
		<param name="NOMBRE_INDICADOR" sqlType="STRING"/>
		<param name="META" sqlType="STRING"/>
		<param name="LB" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION_INDICADOR" sqlType="STRING"/>
		<param name="DESCRIPCION_TEXTO_BP" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="ES_INDICADOR" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpplanindicativo">
		<call-query href="updateBpplanindicativo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
