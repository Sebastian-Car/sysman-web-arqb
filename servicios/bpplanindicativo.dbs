	<query id="insertBpplanindicativoPlanDeAccion" keyColumns="COMPANIA,ID,VIGENCIA_INICIAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_PLAN_INDICATIVO (COMPANIA, ID, VIGENCIA_INICIAL, VIGENCIA_FINAL, DESCRIPCION, DEPENDENCIA, SECTOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID, :VIGENCIA_INICIAL, :VIGENCIA_FINAL, :DESCRIPCION, :DEPENDENCIA, :SECTOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID":"$ID","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="SECTOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpplanindicativo/plandeaccion">
		<call-query href="insertBpplanindicativoPlanDeAccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA_FINAL" query-param="VIGENCIA_FINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateBpplanindicativoPlanDeAccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PLAN_INDICATIVO SET COMPANIA=:COMPANIA, ID=:ID, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, VIGENCIA_FINAL=:VIGENCIA_FINAL, DESCRIPCION=:DESCRIPCION, DEPENDENCIA=:DEPENDENCIA, SECTOR=:SECTOR, ES_INDICADOR=:ES_INDICADOR, TIPO_META_PLAN=:TIPO_META_PLAN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND BP_PLAN_INDICATIVO.ID= :KEY_ID AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="ES_INDICADOR" sqlType="STRING"/>
		<param name="TIPO_META_PLAN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpplanindicativo/plandeaccion">
		<call-query href="updateBpplanindicativoPlanDeAccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA_FINAL" query-param="VIGENCIA_FINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="ES_INDICADOR" query-param="ES_INDICADOR"/>
			<with-param name="TIPO_META_PLAN" query-param="TIPO_META_PLAN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoPagPlanDeAccionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.DESCRIPCION, BP_PLAN_INDICATIVO.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, BP_PLAN_INDICATIVO.SECTOR, SECTORES.DESCRIPCION NOMBRE_SECTOR, BP_PLAN_INDICATIVO.VIGENCIA_FINAL,(CASE BP_PLAN_INDICATIVO.ES_INDICADOR WHEN 0 THEN 'false' ELSE 'true' END) ES_INDICADOR, BP_PLAN_INDICATIVO.TIPO_META_PLAN  FROM BP_PLAN_INDICATIVO INNER JOIN DEPENDENCIA ON BP_PLAN_INDICATIVO.COMPANIA = DEPENDENCIA.COMPANIA AND BP_PLAN_INDICATIVO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN SECTORES ON BP_PLAN_INDICATIVO.COMPANIA = SECTORES.COMPANIA AND BP_PLAN_INDICATIVO.SECTOR = SECTORES.CODIGO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL= :VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) &lt;&gt; :ACCION ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBRE_DEPENDENCIA || '%')  AND (CASE WHEN NOMBRE_SECTOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_SECTOR) END)  LIKE UPPER( '%' || :NOMBRE_SECTOR || '%')  AND (CASE WHEN VIGENCIA_FINAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_FINAL) END)  LIKE UPPER( '%' || :VIGENCIA_FINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","DESCRIPCION":"$DESCRIPCION","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","SECTOR":"$SECTOR","NOMBRE_SECTOR":"$NOMBRE_SECTOR","VIGENCIA_FINAL":"$VIGENCIA_FINAL(type:integer)","ES_INDICADOR":"$ES_INDICADOR(type:boolean)","TIPO_META_PLAN":"$TIPO_META_PLAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_SECTOR" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpplanindicativo/plandeaccion/pag">
		<call-query href="getBpplanindicativoPagPlanDeAccionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>
			<with-param name="NOMBRE_SECTOR" query-param="NOMBRE_SECTOR"/>
			<with-param name="VIGENCIA_FINAL" query-param="VIGENCIA_FINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoNumPlanDeAccionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.COMPANIA, BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.DESCRIPCION, BP_PLAN_INDICATIVO.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, BP_PLAN_INDICATIVO.SECTOR, SECTORES.DESCRIPCION NOMBRE_SECTOR, BP_PLAN_INDICATIVO.VIGENCIA_FINAL,(CASE BP_PLAN_INDICATIVO.ES_INDICADOR WHEN 0 THEN 'false' ELSE 'true' END) ES_INDICADOR, BP_PLAN_INDICATIVO.TIPO_META_PLAN  FROM BP_PLAN_INDICATIVO INNER JOIN DEPENDENCIA ON BP_PLAN_INDICATIVO.COMPANIA = DEPENDENCIA.COMPANIA AND BP_PLAN_INDICATIVO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN SECTORES ON BP_PLAN_INDICATIVO.COMPANIA = SECTORES.COMPANIA AND BP_PLAN_INDICATIVO.SECTOR = SECTORES.CODIGO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL= :VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) &lt;&gt; :ACCION ORDER BY BP_PLAN_INDICATIVO.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBRE_DEPENDENCIA || '%')  AND (CASE WHEN NOMBRE_SECTOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_SECTOR) END)  LIKE UPPER( '%' || :NOMBRE_SECTOR || '%')  AND (CASE WHEN VIGENCIA_FINAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_FINAL) END)  LIKE UPPER( '%' || :VIGENCIA_FINAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_SECTOR" sqlType="STRING"/>
		<param name="VIGENCIA_FINAL" sqlType="STRING"/>

	</query>
