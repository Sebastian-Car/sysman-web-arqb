	<query id="getBpplanindicativoRegistroPlanSegunArbolQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_PLAN_INDICATIVO.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA, BP_PLAN_INDICATIVO.VIGENCIA_INICIAL, BP_PLAN_INDICATIVO.VIGENCIA_FINAL  FROM BP_PLAN_INDICATIVO INNER JOIN DEPENDENCIA ON BP_PLAN_INDICATIVO.COMPANIA = DEPENDENCIA.COMPANIA AND BP_PLAN_INDICATIVO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.ID = :ID AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEPENDENCIA":"$DEPENDENCIA","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","VIGENCIA_FINAL":"$VIGENCIA_FINAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
