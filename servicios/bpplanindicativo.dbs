		</call-query>
	</resource>
	<query id="getBpplanindicativoDatosinicialesmetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DESCRIPCION_TEXTO_BP, DECODE (TIPO_META_INDICADOR, 'MI', 'Meta Incremento', 'MM', 'Meta Mantenimiento', 'MR', 'Meta Reduccion', 'MG', 'Meta Gestion') TIPO_META, LB, META, CASE WHEN TIPO_META_INDICADOR = 'MR' THEN (LB - META) ELSE CASE WHEN TIPO_META_INDICADOR = 'MI' THEN (META - LB) ELSE META END END CANT_PROG, DEPENDENCIA, DESCRIPCION_INDICADOR, VIGENCIA_FINAL  FROM BP_PLAN_INDICATIVO LEFT JOIN BP_NIVEL_PLAN_IND ON BP_PLAN_INDICATIVO.COMPANIA = BP_NIVEL_PLAN_IND.COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_NIVEL_PLAN_IND.VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) = BP_NIVEL_PLAN_IND.DIGITOS WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND BP_PLAN_INDICATIVO.ID = :CODIGO AND BP_NIVEL_PLAN_IND.META_PRODUC NOT IN (0) ORDER BY BP_PLAN_INDICATIVO.ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION_TEXTO_BP":"$DESCRIPCION_TEXTO_BP","TIPO_META":"$TIPO_META","LB":"$LB","META":"$META","CANT_PROG":"$CANT_PROG","DEPENDENCIA":"$DEPENDENCIA","DESCRIPCION_INDICADOR":"$DESCRIPCION_INDICADOR","VIGENCIA_FINAL":"$VIGENCIA_FINAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpplanindicativo/datosinicialesmeta">
		<call-query href="getBpplanindicativoDatosinicialesmetaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpplanindicativoIdPorCodigopminQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID, VIGENCIA_INICIAL  FROM BP_PLAN_INDICATIVO WHERE COMPANIA = :COMPANIA AND CODIGOBPIM = :CODIGOBPIM</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)"}]}}		</result>
