	<query id="getBpplanindicativoPagTodosporcompaniayvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PLAN_INDICATIVO.ID, BP_PLAN_INDICATIVO.DESCRIPCION, BP_PLAN_INDICATIVO.TIPO_META_PLAN  FROM BP_PLAN_INDICATIVO WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = :VIGENCIA AND LENGTH(BP_PLAN_INDICATIVO.ID) IN(:GETM_PRO,:GETM_RES)) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN TIPO_META_PLAN IS NULL THEN ' ' ELSE UPPER(TIPO_META_PLAN) END)  LIKE UPPER( '%' || :TIPO_META_PLAN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","DESCRIPCION":"$DESCRIPCION","TIPO_META_PLAN":"$TIPO_META_PLAN"}]}}		</result>
