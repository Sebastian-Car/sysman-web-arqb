	</resource>
	<query id="insertNatevaluacionesPeriodoPrueba" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,EV_FORMATO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_EVALUACION (COMPANIA, DP_NUMEDOCU, SUCURSAL, EV_FORMATO, EV_CLASEVAL, EV_FECHDESDEEVAL, EV_FECHHASTAEVAL, DIASNOEVALUADOS, EV_TIPODOCUEVAL, EV_NUMEDOCUEVAL, EV_NOMBEVAL, CARGOEVALUADOR, EV_P_PLAN, EV_P_UTILRECU, EV_P_CALI, EV_P_COMPTECN, EV_P_RESP, EV_MOTICONC, EV_PUNTOBJEDESE, EV_TOT_EV_LOG_OBJ, EV_TOT_EV_FAC_DES, EV_FECHDILI, EV_FECHANOTI, EV_PUNTOSFUERTES, EV_PUNTOSDEBILES, EV_RECOM_MEJO, EV_REC_REPOS, EV_REC_APEL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :EV_FORMATO, :EV_CLASEVAL, TO_DATE(:EV_FECHDESDEEVAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:EV_FECHHASTAEVAL,'DD/MM/YYYY HH24:MI:SS'), :DIASNOEVALUADOS, :EV_TIPODOCUEVAL, :EV_NUMEDOCUEVAL, :EV_NOMBEVAL, :CARGOEVALUADOR, :EV_P_PLAN, :EV_P_UTILRECU, :EV_P_CALI, :EV_P_COMPTECN, :EV_P_RESP, :EV_MOTICONC, :EV_PUNTOBJEDESE, :EV_TOT_EV_LOG_OBJ, :EV_TOT_EV_FAC_DES, TO_DATE(:EV_FECHDILI,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:EV_FECHANOTI,'DD/MM/YYYY HH24:MI:SS'), :EV_PUNTOSFUERTES, :EV_PUNTOSDEBILES, :EV_RECOM_MEJO, :EV_REC_REPOS, :EV_REC_APEL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_EV_FORMATO":"$EV_FORMATO","KEY_EV_FECHDESDEEVAL":"$EV_FECHDESDEEVAL","KEY_EV_FECHHASTAEVAL":"$EV_FECHHASTAEVAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="EV_FORMATO" sqlType="STRING"/>
		<param defaultValue="99" name="EV_CLASEVAL" sqlType="STRING"/>
		<param name="EV_FECHDESDEEVAL" sqlType="STRING"/>
		<param name="EV_FECHHASTAEVAL" sqlType="STRING"/>
		<param defaultValue="0" name="DIASNOEVALUADOS" sqlType="STRING"/>
		<param name="EV_TIPODOCUEVAL" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="EV_NUMEDOCUEVAL" sqlType="STRING"/>
		<param defaultValue="" name="EV_NOMBEVAL" sqlType="STRING"/>
		<param defaultValue="" name="CARGOEVALUADOR" sqlType="STRING"/>
		<param defaultValue="0" name="EV_P_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="EV_P_UTILRECU" sqlType="STRING"/>
		<param defaultValue="0" name="EV_P_CALI" sqlType="STRING"/>
		<param defaultValue="0" name="EV_P_COMPTECN" sqlType="STRING"/>
		<param defaultValue="0" name="EV_P_RESP" sqlType="STRING"/>
		<param defaultValue="" name="EV_MOTICONC" sqlType="STRING"/>
		<param defaultValue="0" name="EV_PUNTOBJEDESE" sqlType="STRING"/>
		<param defaultValue="0" name="EV_TOT_EV_LOG_OBJ" sqlType="STRING"/>
		<param defaultValue="0" name="EV_TOT_EV_FAC_DES" sqlType="STRING"/>
		<param defaultValue="" name="EV_FECHDILI" sqlType="STRING"/>
		<param defaultValue="" name="EV_FECHANOTI" sqlType="STRING"/>
		<param defaultValue="" name="EV_PUNTOSFUERTES" sqlType="STRING"/>
		<param defaultValue="" name="EV_PUNTOSDEBILES" sqlType="STRING"/>
		<param defaultValue="" name="EV_RECOM_MEJO" sqlType="STRING"/>
		<param defaultValue="0" name="EV_REC_REPOS" sqlType="STRING"/>
		<param defaultValue="0" name="EV_REC_APEL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
