	</resource>
	<query id="getNatevaluacionesRegistroPeriodoPruebaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, DP_NUMEDOCU, SUCURSAL, EV_FORMATO, EV_CLASEVAL,(TO_CHAR(EV_FECHDESDEEVAL,'DD/MM/YYYY HH24:MI:SS')) EV_FECHDESDEEVAL,(TO_CHAR(EV_FECHHASTAEVAL,'DD/MM/YYYY HH24:MI:SS')) EV_FECHHASTAEVAL, DIASNOEVALUADOS, EV_TIPODOCUEVAL, EV_NUMEDOCUEVAL, EV_NOMBEVAL, CARGOEVALUADOR, EV_P_PLAN, EV_P_UTILRECU, EV_P_CALI, EV_P_COMPTECN, EV_P_RESP, EV_MOTICONC, EV_PUNTOBJEDESE, EV_TOT_EV_LOG_OBJ, EV_TOT_EV_FAC_DES,(TO_CHAR(EV_FECHDILI,'DD/MM/YYYY HH24:MI:SS')) EV_FECHDILI,(TO_CHAR(EV_FECHANOTI,'DD/MM/YYYY HH24:MI:SS')) EV_FECHANOTI, EV_PUNTOSFUERTES, EV_PUNTOSDEBILES, EV_RECOM_MEJO,(CASE EV_REC_REPOS WHEN 0 THEN 'false' ELSE 'true' END) EV_REC_REPOS,(CASE EV_REC_APEL WHEN 0 THEN 'false' ELSE 'true' END) EV_REC_APEL FROM NAT_EVALUACION WHERE NAT_EVALUACION.COMPANIA = :KEY_COMPANIA AND NAT_EVALUACION.DP_NUMEDOCU = :KEY_DP_NUMEDOCU AND NAT_EVALUACION.SUCURSAL = :KEY_SUCURSAL AND NAT_EVALUACION.EV_FORMATO = :KEY_EV_FORMATO AND NAT_EVALUACION.EV_FECHDESDEEVAL= TO_DATE(:KEY_EV_FECHDESDEEVAL,'DD/MM/YYYY HH24:MI:SS') AND NAT_EVALUACION.EV_FECHHASTAEVAL= TO_DATE(:KEY_EV_FECHHASTAEVAL,'DD/MM/YYYY HH24:MI:SS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","EV_FORMATO":"$EV_FORMATO","EV_CLASEVAL":"$EV_CLASEVAL(type:integer)","EV_FECHDESDEEVAL":"$EV_FECHDESDEEVAL","EV_FECHHASTAEVAL":"$EV_FECHHASTAEVAL","DIASNOEVALUADOS":"$DIASNOEVALUADOS","EV_TIPODOCUEVAL":"$EV_TIPODOCUEVAL","EV_NUMEDOCUEVAL":"$EV_NUMEDOCUEVAL","EV_NOMBEVAL":"$EV_NOMBEVAL","CARGOEVALUADOR":"$CARGOEVALUADOR","EV_P_PLAN":"$EV_P_PLAN","EV_P_UTILRECU":"$EV_P_UTILRECU","EV_P_CALI":"$EV_P_CALI","EV_P_COMPTECN":"$EV_P_COMPTECN","EV_P_RESP":"$EV_P_RESP","EV_MOTICONC":"$EV_MOTICONC","EV_PUNTOBJEDESE":"$EV_PUNTOBJEDESE","EV_TOT_EV_LOG_OBJ":"$EV_TOT_EV_LOG_OBJ","EV_TOT_EV_FAC_DES":"$EV_TOT_EV_FAC_DES","EV_FECHDILI":"$EV_FECHDILI","EV_FECHANOTI":"$EV_FECHANOTI","EV_PUNTOSFUERTES":"$EV_PUNTOSFUERTES","EV_PUNTOSDEBILES":"$EV_PUNTOSDEBILES","EV_RECOM_MEJO":"$EV_RECOM_MEJO","EV_REC_REPOS":"$EV_REC_REPOS(type:boolean)","EV_REC_APEL":"$EV_REC_APEL(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_EV_FORMATO" sqlType="STRING"/>
		<param name="KEY_EV_FECHDESDEEVAL" sqlType="STRING"/>
		<param name="KEY_EV_FECHHASTAEVAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natevaluaciones/registroperiodoprueba">
		<call-query href="getNatevaluacionesRegistroPeriodoPruebaQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_EV_FORMATO" query-param="KEY_EV_FORMATO"/>
			<with-param name="KEY_EV_FECHDESDEEVAL" query-param="KEY_EV_FECHDESDEEVAL"/>
			<with-param name="KEY_EV_FECHHASTAEVAL" query-param="KEY_EV_FECHHASTAEVAL"/>

		</call-query>
	</resource>
	<query id="deleteNatevaluaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_EVALUACION WHERE NAT_EVALUACION.COMPANIA= :KEY_COMPANIA AND NAT_EVALUACION.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_EVALUACION.SUCURSAL= :KEY_SUCURSAL AND NAT_EVALUACION.EV_FORMATO= :KEY_EV_FORMATO AND NAT_EVALUACION.EV_FECHDESDEEVAL= TO_DATE(:KEY_EV_FECHDESDEEVAL,'DD/MM/YYYY HH24:MI:SS')  AND NAT_EVALUACION.EV_FECHHASTAEVAL= TO_DATE(:KEY_EV_FECHHASTAEVAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_EV_FORMATO" sqlType="STRING"/>
		<param name="KEY_EV_FECHDESDEEVAL" sqlType="STRING"/>
		<param name="KEY_EV_FECHHASTAEVAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natevaluaciones">
		<call-query href="deleteNatevaluaciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_EV_FORMATO" query-param="KEY_EV_FORMATO"/>
			<with-param name="KEY_EV_FECHDESDEEVAL" query-param="KEY_EV_FECHDESDEEVAL"/>
			<with-param name="KEY_EV_FECHHASTAEVAL" query-param="KEY_EV_FECHHASTAEVAL"/>

		</call-query>
	</resource>

</data>