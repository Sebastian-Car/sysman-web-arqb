		</call-query>
	</resource>
	<query id="getNatincentivosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT NAT_INCENTIVOS.COMPANIA, NAT_INCENTIVOS.DP_NUMEDOCU, NAT_INCENTIVOS.DP_NUMEDOCU NUMERO_DCTO, NAT_INCENTIVOS.SUCURSAL, NAT_INCENTIVOS.ID_DE_EMPLEADO, NAT_INCENTIVOS.IN_TIPODOCUACTO, NAT_INCENTIVOS.IN_NUME,(TO_CHAR(NAT_INCENTIVOS.IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) IN_FECHRESODECR, NAT_INCENTIVOS.IN_TIPOINCENT, NAT_INCENTIVOS.IN_CICLO, NAT_INCENTIVOS.IN_COMPLEMENTO, NAT_INCENTIVOS.CREATED_BY,(TO_CHAR(NAT_INCENTIVOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, NAT_INCENTIVOS.MODIFIED_BY,(TO_CHAR(NAT_INCENTIVOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO2,CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRECOMPLETO FROM NAT_INCENTIVOS INNER JOIN NAT_DATOS_PERSONALES ON NAT_INCENTIVOS.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_INCENTIVOS.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE NAT_INCENTIVOS.COMPANIA= :KEY_COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_INCENTIVOS.SUCURSAL= :KEY_SUCURSAL AND NAT_INCENTIVOS.IN_TIPODOCUACTO= :KEY_IN_TIPODOCUACTO AND NAT_INCENTIVOS.IN_NUME= :KEY_IN_NUME AND NAT_INCENTIVOS.IN_FECHRESODECR= TO_DATE(:KEY_IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","IN_TIPODOCUACTO":"$IN_TIPODOCUACTO","IN_NUME":"$IN_NUME","IN_FECHRESODECR":"$IN_FECHRESODECR","IN_TIPOINCENT":"$IN_TIPOINCENT","IN_CICLO":"$IN_CICLO","IN_COMPLEMENTO":"$IN_COMPLEMENTO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_IN_NUME" sqlType="STRING"/>
		<param name="KEY_IN_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natincentivos/data">
		<call-query href="getNatincentivosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_IN_TIPODOCUACTO" query-param="KEY_IN_TIPODOCUACTO"/>
			<with-param name="KEY_IN_NUME" query-param="KEY_IN_NUME"/>
			<with-param name="KEY_IN_FECHRESODECR" query-param="KEY_IN_FECHRESODECR"/>

		</call-query>
	</resource>
	<query id="updateNatincentivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_INCENTIVOS SET COMPANIA=:COMPANIA, DP_NUMEDOCU=:DP_NUMEDOCU, SUCURSAL=:SUCURSAL, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, IN_TIPODOCUACTO=:IN_TIPODOCUACTO, IN_NUME=:IN_NUME, IN_FECHRESODECR=TO_DATE(:IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), IN_TIPOINCENT=:IN_TIPOINCENT, IN_CICLO=:IN_CICLO, IN_VALOR=:IN_VALOR, IN_COMPLEMENTO=:IN_COMPLEMENTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_INCENTIVOS.COMPANIA= :KEY_COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_INCENTIVOS.SUCURSAL= :KEY_SUCURSAL AND NAT_INCENTIVOS.IN_TIPODOCUACTO= :KEY_IN_TIPODOCUACTO AND NAT_INCENTIVOS.IN_NUME= :KEY_IN_NUME AND NAT_INCENTIVOS.IN_FECHRESODECR= TO_DATE(:KEY_IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="IN_NUME" sqlType="STRING"/>
		<param name="IN_FECHRESODECR" sqlType="STRING"/>
		<param name="IN_TIPOINCENT" sqlType="STRING"/>
		<param name="IN_CICLO" sqlType="STRING"/>
		<param name="IN_VALOR" sqlType="STRING"/>
		<param name="IN_COMPLEMENTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_IN_NUME" sqlType="STRING"/>
		<param name="KEY_IN_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natincentivos">
		<call-query href="updateNatincentivos">
