	<query id="updateNatincentivosSinvalor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_INCENTIVOS SET IN_TIPOINCENT=:IN_TIPOINCENT, IN_CICLO=:IN_CICLO, IN_COMPLEMENTO=:IN_COMPLEMENTO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_INCENTIVOS.COMPANIA= :KEY_COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_INCENTIVOS.SUCURSAL= :KEY_SUCURSAL AND NAT_INCENTIVOS.IN_TIPODOCUACTO= :KEY_IN_TIPODOCUACTO AND NAT_INCENTIVOS.IN_NUME= :KEY_IN_NUME AND NAT_INCENTIVOS.IN_FECHRESODECR= TO_DATE(:KEY_IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
