<data name="natincentivos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatincentivosPagGrillatodosporsucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NAT_INCENTIVOS.ID_DE_EMPLEADO, NAT_INCENTIVOS.DP_NUMEDOCU, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO2,CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRECOMPLETO, NAT_INCENTIVOS.IN_TIPODOCUACTO, NAT_INCENTIVOS.IN_NUME,(TO_CHAR(NAT_INCENTIVOS.IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) IN_FECHRESODECR, NAT_INCENTIVOS.COMPANIA, NAT_INCENTIVOS.SUCURSAL, NAT_INCENTIVOS.IN_TIPOINCENT, NAT_INCENTIVOS.IN_CICLO, NAT_INCENTIVOS.IN_COMPLEMENTO FROM NAT_INCENTIVOS INNER JOIN NAT_DATOS_PERSONALES ON NAT_INCENTIVOS.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_INCENTIVOS.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE NAT_INCENTIVOS.COMPANIA =:COMPANIA AND NAT_INCENTIVOS.SUCURSAL NOT IN ( '999' )) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END) LIKE UPPER(CONCAT(:DP_NUMEDOCU, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN IN_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(IN_TIPODOCUACTO) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_TIPODOCUACTO), '%')) AND (CASE WHEN IN_NUME IS NULL THEN ' ' ELSE UPPER(IN_NUME) END) LIKE UPPER(CONCAT(:IN_NUME, '%')) AND (CASE WHEN IN_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(IN_FECHRESODECR) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_FECHRESODECR), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN IN_TIPOINCENT IS NULL THEN ' ' ELSE UPPER(IN_TIPOINCENT) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_TIPOINCENT), '%')) AND (CASE WHEN IN_CICLO IS NULL THEN ' ' ELSE UPPER(IN_CICLO) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_CICLO), '%')) AND (CASE WHEN IN_COMPLEMENTO IS NULL THEN ' ' ELSE UPPER(IN_COMPLEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_COMPLEMENTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","DP_NUMEDOCU":"$DP_NUMEDOCU","NOMBRECOMPLETO":"$NOMBRECOMPLETO","IN_TIPODOCUACTO":"$IN_TIPODOCUACTO","IN_NUME":"$IN_NUME","IN_FECHRESODECR":"$IN_FECHRESODECR","COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","IN_TIPOINCENT":"$IN_TIPOINCENT","IN_CICLO":"$IN_CICLO","IN_COMPLEMENTO":"$IN_COMPLEMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="IN_NUME" sqlType="STRING"/>
		<param name="IN_FECHRESODECR" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="IN_TIPOINCENT" sqlType="STRING"/>
		<param name="IN_CICLO" sqlType="STRING"/>
		<param name="IN_COMPLEMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natincentivos/grillatodosporsucursal/pag">
		<call-query href="getNatincentivosPagGrillatodosporsucursalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="IN_TIPODOCUACTO" query-param="IN_TIPODOCUACTO"/>
			<with-param name="IN_NUME" query-param="IN_NUME"/>
			<with-param name="IN_FECHRESODECR" query-param="IN_FECHRESODECR"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="IN_TIPOINCENT" query-param="IN_TIPOINCENT"/>
			<with-param name="IN_CICLO" query-param="IN_CICLO"/>
			<with-param name="IN_COMPLEMENTO" query-param="IN_COMPLEMENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatincentivosNumGrillatodosporsucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NAT_INCENTIVOS.ID_DE_EMPLEADO, NAT_INCENTIVOS.DP_NUMEDOCU, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO2,CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRECOMPLETO, NAT_INCENTIVOS.IN_TIPODOCUACTO, NAT_INCENTIVOS.IN_NUME,(TO_CHAR(NAT_INCENTIVOS.IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) IN_FECHRESODECR, NAT_INCENTIVOS.COMPANIA, NAT_INCENTIVOS.SUCURSAL, NAT_INCENTIVOS.IN_TIPOINCENT, NAT_INCENTIVOS.IN_CICLO, NAT_INCENTIVOS.IN_COMPLEMENTO FROM NAT_INCENTIVOS INNER JOIN NAT_DATOS_PERSONALES ON NAT_INCENTIVOS.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_INCENTIVOS.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE NAT_INCENTIVOS.COMPANIA =:COMPANIA AND NAT_INCENTIVOS.SUCURSAL NOT IN ( '999' )) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END) LIKE UPPER(CONCAT(:DP_NUMEDOCU, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN IN_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(IN_TIPODOCUACTO) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_TIPODOCUACTO), '%')) AND (CASE WHEN IN_NUME IS NULL THEN ' ' ELSE UPPER(IN_NUME) END) LIKE UPPER(CONCAT(:IN_NUME, '%')) AND (CASE WHEN IN_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(IN_FECHRESODECR) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_FECHRESODECR), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN IN_TIPOINCENT IS NULL THEN ' ' ELSE UPPER(IN_TIPOINCENT) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_TIPOINCENT), '%')) AND (CASE WHEN IN_CICLO IS NULL THEN ' ' ELSE UPPER(IN_CICLO) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_CICLO), '%')) AND (CASE WHEN IN_COMPLEMENTO IS NULL THEN ' ' ELSE UPPER(IN_COMPLEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:IN_COMPLEMENTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="IN_NUME" sqlType="STRING"/>
		<param name="IN_FECHRESODECR" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="IN_TIPOINCENT" sqlType="STRING"/>
		<param name="IN_CICLO" sqlType="STRING"/>
		<param name="IN_COMPLEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natincentivos/grillatodosporsucursal/num">
		<call-query href="getNatincentivosNumGrillatodosporsucursalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="IN_TIPODOCUACTO" query-param="IN_TIPODOCUACTO"/>
