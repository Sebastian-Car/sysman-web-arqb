	</resource>
	<query id="insertNatincentivos" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,IN_TIPODOCUACTO,IN_NUME" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_INCENTIVOS (COMPANIA, DP_NUMEDOCU, SUCURSAL, ID_DE_EMPLEADO, IN_FECHRESODECR, IN_TIPOINCENT, IN_VALOR, IN_CICLO, IN_COMPLEMENTO, IN_NUME, IN_TIPODOCUACTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :ID_DE_EMPLEADO, TO_DATE(:IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), :IN_TIPOINCENT, :IN_VALOR, :IN_CICLO, :IN_COMPLEMENTO, :IN_NUME, :IN_TIPODOCUACTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_IN_TIPODOCUACTO":"$IN_TIPODOCUACTO","KEY_IN_NUME":"$IN_NUME","KEY_IN_FECHRESODECR":"$IN_FECHRESODECR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="IN_FECHRESODECR" sqlType="STRING"/>
		<param defaultValue="" name="IN_TIPOINCENT" sqlType="STRING"/>
		<param defaultValue="0" name="IN_VALOR" sqlType="STRING"/>
		<param defaultValue="" name="IN_CICLO" sqlType="STRING"/>
		<param defaultValue="" name="IN_COMPLEMENTO" sqlType="STRING"/>
		<param name="IN_NUME" sqlType="STRING"/>
		<param name="IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natincentivos">
		<call-query href="insertNatincentivos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="IN_FECHRESODECR" query-param="IN_FECHRESODECR"/>
			<with-param name="IN_TIPOINCENT" query-param="IN_TIPOINCENT"/>
			<with-param name="IN_VALOR" query-param="IN_VALOR"/>
			<with-param name="IN_CICLO" query-param="IN_CICLO"/>
			<with-param name="IN_COMPLEMENTO" query-param="IN_COMPLEMENTO"/>
			<with-param name="IN_NUME" query-param="IN_NUME"/>
			<with-param name="IN_TIPODOCUACTO" query-param="IN_TIPODOCUACTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatincentivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_INCENTIVOS WHERE NAT_INCENTIVOS.COMPANIA= :KEY_COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_INCENTIVOS.SUCURSAL= :KEY_SUCURSAL AND NAT_INCENTIVOS.IN_TIPODOCUACTO= :KEY_IN_TIPODOCUACTO AND NAT_INCENTIVOS.IN_NUME= :KEY_IN_NUME AND NAT_INCENTIVOS.IN_FECHRESODECR= TO_DATE(:KEY_IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_IN_NUME" sqlType="STRING"/>
		<param name="KEY_IN_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natincentivos">
