	<query id="updateNatincentivosEditarincentivosaempleados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_INCENTIVOS SET IN_TIPOINCENT=:IN_TIPOINCENT, IN_CICLO=:IN_CICLO, IN_VALOR=:IN_VALOR, IN_COMPLEMENTO=:IN_COMPLEMENTO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_INCENTIVOS.COMPANIA= :KEY_COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_INCENTIVOS.SUCURSAL= :KEY_SUCURSAL AND NAT_INCENTIVOS.IN_TIPODOCUACTO= :KEY_IN_TIPODOCUACTO AND NAT_INCENTIVOS.IN_NUME= :KEY_IN_NUME AND NAT_INCENTIVOS.IN_FECHRESODECR= TO_DATE(:KEY_IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IN_TIPOINCENT" sqlType="STRING"/>
		<param name="IN_CICLO" sqlType="STRING"/>
		<param name="IN_VALOR" sqlType="STRING"/>
		<param name="IN_COMPLEMENTO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="KEY_IN_NUME" sqlType="STRING"/>
		<param name="KEY_IN_FECHRESODECR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natincentivos/editarincentivosaempleados">
		<call-query href="updateNatincentivosEditarincentivosaempleados">
			<with-param name="IN_TIPOINCENT" query-param="IN_TIPOINCENT"/>
			<with-param name="IN_CICLO" query-param="IN_CICLO"/>
			<with-param name="IN_VALOR" query-param="IN_VALOR"/>
			<with-param name="IN_COMPLEMENTO" query-param="IN_COMPLEMENTO"/>
