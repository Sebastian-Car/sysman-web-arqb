	</resource>
	<query id="getNatincentivosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_INCENTIVOS.COMPANIA, NAT_INCENTIVOS.DP_NUMEDOCU, NAT_INCENTIVOS.SUCURSAL, NAT_DATOS_PERSONALES.CODIGO AS ID_DE_EMPLEADO, NAT_INCENTIVOS.IN_TIPODOCUACTO, NAT_INCENTIVOS.IN_NUME,(TO_CHAR(NAT_INCENTIVOS.IN_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) IN_FECHRESODECR, NAT_INCENTIVOS.IN_TIPOINCENT, NAT_INCENTIVOS.IN_CICLO, NAT_INCENTIVOS.IN_VALOR, NAT_INCENTIVOS.IN_COMPLEMENTO  FROM NAT_INCENTIVOS INNER JOIN NAT_DATOS_PERSONALES ON NAT_INCENTIVOS.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_INCENTIVOS.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE NAT_INCENTIVOS.COMPANIA = :COMPANIA AND NAT_INCENTIVOS.DP_NUMEDOCU = :NUMERO_DCTO AND NAT_INCENTIVOS.ID_DE_EMPLEADO = :ID_DE_EMPLEADO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN IN_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(IN_TIPODOCUACTO) END)  LIKE UPPER(:IN_TIPODOCUACTO || '%')  AND (CASE WHEN IN_NUME IS NULL THEN ' ' ELSE UPPER(IN_NUME) END)  LIKE UPPER(:IN_NUME || '%')  AND (CASE WHEN IN_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(IN_FECHRESODECR) END)  LIKE UPPER(:IN_FECHRESODECR || '%')  AND (CASE WHEN IN_TIPOINCENT IS NULL THEN ' ' ELSE UPPER(IN_TIPOINCENT) END)  LIKE UPPER(:IN_TIPOINCENT || '%')  AND (CASE WHEN IN_CICLO IS NULL THEN ' ' ELSE UPPER(IN_CICLO) END)  LIKE UPPER(:IN_CICLO || '%')  AND (CASE WHEN IN_VALOR IS NULL THEN ' ' ELSE UPPER(IN_VALOR) END)  LIKE UPPER(:IN_VALOR || '%')  AND (CASE WHEN IN_COMPLEMENTO IS NULL THEN ' ' ELSE UPPER(IN_COMPLEMENTO) END)  LIKE UPPER( '%' || :IN_COMPLEMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO","IN_TIPODOCUACTO":"$IN_TIPODOCUACTO","IN_NUME":"$IN_NUME","IN_FECHRESODECR":"$IN_FECHRESODECR","IN_TIPOINCENT":"$IN_TIPOINCENT","IN_CICLO":"$IN_CICLO","IN_VALOR":"$IN_VALOR","IN_COMPLEMENTO":"$IN_COMPLEMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="IN_TIPODOCUACTO" sqlType="STRING"/>
		<param name="IN_NUME" sqlType="STRING"/>
		<param name="IN_FECHRESODECR" sqlType="STRING"/>
		<param name="IN_TIPOINCENT" sqlType="STRING"/>
		<param name="IN_CICLO" sqlType="STRING"/>
		<param name="IN_VALOR" sqlType="STRING"/>
		<param name="IN_COMPLEMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natincentivos">
		<call-query href="getNatincentivosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
