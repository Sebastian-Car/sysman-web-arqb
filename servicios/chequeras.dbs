<data name="chequeras" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getChequerasPagTodosPorNumeroChequeraQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUMCHEQUERA,NUMINICIAL,NUMFINAL  FROM CHEQUERA WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTA = :CUENTA) WHERE (CASE WHEN NUMCHEQUERA IS NULL THEN ' ' ELSE UPPER(NUMCHEQUERA) END)  LIKE UPPER(:NUMCHEQUERA || '%')  AND (CASE WHEN NUMINICIAL IS NULL THEN ' ' ELSE UPPER(NUMINICIAL) END)  LIKE UPPER(:NUMINICIAL || '%')  AND (CASE WHEN NUMFINAL IS NULL THEN ' ' ELSE UPPER(NUMFINAL) END)  LIKE UPPER(:NUMFINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMCHEQUERA":"$NUMCHEQUERA","NUMINICIAL":"$NUMINICIAL(type:integer)","NUMFINAL":"$NUMFINAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NUMCHEQUERA" sqlType="STRING"/>
		<param name="NUMINICIAL" sqlType="STRING"/>
		<param name="NUMFINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="chequeras/todospornumerochequera/pag">
		<call-query href="getChequerasPagTodosPorNumeroChequeraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NUMCHEQUERA" query-param="NUMCHEQUERA"/>
			<with-param name="NUMINICIAL" query-param="NUMINICIAL"/>
			<with-param name="NUMFINAL" query-param="NUMFINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getChequerasNumTodosPorNumeroChequeraQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NUMCHEQUERA,NUMINICIAL,NUMFINAL  FROM CHEQUERA WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTA = :CUENTA) WHERE (CASE WHEN NUMCHEQUERA IS NULL THEN ' ' ELSE UPPER(NUMCHEQUERA) END)  LIKE UPPER(:NUMCHEQUERA || '%')  AND (CASE WHEN NUMINICIAL IS NULL THEN ' ' ELSE UPPER(NUMINICIAL) END)  LIKE UPPER( '%' || :NUMINICIAL || '%')  AND (CASE WHEN NUMFINAL IS NULL THEN ' ' ELSE UPPER(NUMFINAL) END)  LIKE UPPER( '%' || :NUMFINAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NUMCHEQUERA" sqlType="STRING"/>
		<param name="NUMINICIAL" sqlType="STRING"/>
		<param name="NUMFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="chequeras/todospornumerochequera/num">
		<call-query href="getChequerasNumTodosPorNumeroChequeraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NUMCHEQUERA" query-param="NUMCHEQUERA"/>
			<with-param name="NUMINICIAL" query-param="NUMINICIAL"/>
			<with-param name="NUMFINAL" query-param="NUMFINAL"/>

		</call-query>
	</resource>
	<query id="getChequerasTodosPorCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT CUENTA  FROM CHEQUERA WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="chequeras/todosporcuenta">
		<call-query href="getChequerasTodosPorCuentaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getChequerasNochequeraChequeactualQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ANO, CUENTA, NUMCHEQUERA, NVL(NUMACTUAL,NUMINICIAL-1) AS CHEQUE, NUMFINAL -NVL(NUMACTUAL,NUMINICIAL) AS DISPONIBLES  FROM CHEQUERA WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND CUENTA =:CUENTA AND NUMFINAL-NVL(NUMACTUAL,NUMINICIAL)&gt;0 AND ROWNUM = 1 ORDER BY COMPANIA, ANO, CUENTA, NUMCHEQUERA DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","NUMCHEQUERA":"$NUMCHEQUERA","CHEQUE":"$CHEQUE(type:integer)","DISPONIBLES":"$DISPONIBLES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="chequeras/nochequerachequeactual">
		<call-query href="getChequerasNochequeraChequeactualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="getChequerasConsecutivoChequeQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(NUMACTUAL) NUMACTUAL, MAX(NUMINICIAL) NUMINICIAL, MAX(NUMCHEQUERA) NUMCHEQUERA, NUMFINAL-NVL(NUMACTUAL,NUMINICIAL) DISPONIBLES  FROM CHEQUERA WHERE COMPANIA = :COMPANIA AND ANO = :ANOEGRESO AND CUENTA = :CUENTA GROUP BY NUMFINAL, NUMACTUAL, NUMINICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMACTUAL":"$NUMACTUAL(type:integer)","NUMINICIAL":"$NUMINICIAL(type:integer)","NUMCHEQUERA":"$NUMCHEQUERA(type:integer)","DISPONIBLES":"$DISPONIBLES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOEGRESO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="chequeras/consecutivocheque">
		<call-query href="getChequerasConsecutivoChequeQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOEGRESO" query-param="ANOEGRESO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="getChequerasValidacionChequeraActivaQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE ANULADA WHEN 0 THEN 'false' ELSE 'true' END) ANULADA FROM CHEQUERA WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTA = :CUENTA AND ANULADA IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANULADA":"$ANULADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="chequeras/validacionchequeraactiva">
		<call-query href="getChequerasValidacionChequeraActivaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="insertChequeras" keyColumns="COMPANIA,ANO,CUENTA,NUMCHEQUERA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CHEQUERA (COMPANIA, ANO, CUENTA, NUMCHEQUERA, NUMINICIAL, NUMFINAL, NUMACTUAL, DISPONIBLES, ANULADA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CUENTA, :NUMCHEQUERA, :NUMINICIAL, :NUMFINAL, :NUMACTUAL, :DISPONIBLES, :ANULADA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CUENTA":"$CUENTA","KEY_NUMCHEQUERA":"$NUMCHEQUERA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NUMCHEQUERA" sqlType="STRING"/>
		<param name="NUMINICIAL" sqlType="STRING"/>
		<param name="NUMFINAL" sqlType="STRING"/>
		<param name="NUMACTUAL" sqlType="STRING"/>
		<param defaultValue="0" name="DISPONIBLES" sqlType="STRING"/>
		<param defaultValue="0" name="ANULADA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="chequeras">
		<call-query href="insertChequeras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NUMCHEQUERA" query-param="NUMCHEQUERA"/>
			<with-param name="NUMINICIAL" query-param="NUMINICIAL"/>
			<with-param name="NUMFINAL" query-param="NUMFINAL"/>
			<with-param name="NUMACTUAL" query-param="NUMACTUAL"/>
			<with-param name="DISPONIBLES" query-param="DISPONIBLES"/>
			<with-param name="ANULADA" query-param="ANULADA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteChequeras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CHEQUERA WHERE CHEQUERA.COMPANIA= :KEY_COMPANIA AND CHEQUERA.ANO= :KEY_ANO AND CHEQUERA.CUENTA= :KEY_CUENTA AND CHEQUERA.NUMCHEQUERA= :KEY_NUMCHEQUERA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>
		<param name="KEY_NUMCHEQUERA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="chequeras">
		<call-query href="deleteChequeras">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>
			<with-param name="KEY_NUMCHEQUERA" query-param="KEY_NUMCHEQUERA"/>

		</call-query>
	</resource>
	<query id="getChequerasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CHEQUERA.COMPANIA,CHEQUERA.ANO,CHEQUERA.CUENTA,CHEQUERA.NUMCHEQUERA,CHEQUERA.NUMINICIAL,CHEQUERA.NUMFINAL,CHEQUERA.NUMACTUAL,CHEQUERA.DISPONIBLES,(CASE CHEQUERA.ANULADA WHEN 0 THEN 'false' ELSE 'true' END) ANULADA FROM CHEQUERA WHERE CHEQUERA.COMPANIA = :COMPANIA AND CHEQUERA.ANO = :ANO AND CHEQUERA.CUENTA = :CUENTA) WHERE (CASE WHEN NUMCHEQUERA IS NULL THEN ' ' ELSE UPPER(NUMCHEQUERA) END)  LIKE UPPER(:NUMCHEQUERA || '%')  AND (CASE WHEN NUMINICIAL IS NULL THEN ' ' ELSE UPPER(NUMINICIAL) END)  LIKE UPPER( '%' || :NUMINICIAL || '%')  AND (CASE WHEN NUMFINAL IS NULL THEN ' ' ELSE UPPER(NUMFINAL) END)  LIKE UPPER( '%' || :NUMFINAL || '%')  AND (CASE WHEN NUMACTUAL IS NULL THEN ' ' ELSE UPPER(NUMACTUAL) END)  LIKE UPPER( '%' || :NUMACTUAL || '%')  AND (CASE WHEN DISPONIBLES IS NULL THEN ' ' ELSE UPPER(DISPONIBLES) END)  LIKE UPPER( '%' || :DISPONIBLES || '%')  AND (CASE WHEN ANULADA IS NULL THEN ' ' ELSE UPPER(ANULADA) END)  LIKE UPPER(:ANULADA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","NUMCHEQUERA":"$NUMCHEQUERA","NUMINICIAL":"$NUMINICIAL(type:integer)","NUMFINAL":"$NUMFINAL(type:integer)","NUMACTUAL":"$NUMACTUAL(type:integer)","DISPONIBLES":"$DISPONIBLES(type:integer)","ANULADA":"$ANULADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NUMCHEQUERA" sqlType="STRING"/>
		<param name="NUMINICIAL" sqlType="STRING"/>
		<param name="NUMFINAL" sqlType="STRING"/>
		<param name="NUMACTUAL" sqlType="STRING"/>
		<param name="DISPONIBLES" sqlType="STRING"/>
		<param name="ANULADA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="chequeras">
		<call-query href="getChequerasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NUMCHEQUERA" query-param="NUMCHEQUERA"/>
			<with-param name="NUMINICIAL" query-param="NUMINICIAL"/>
			<with-param name="NUMFINAL" query-param="NUMFINAL"/>
			<with-param name="NUMACTUAL" query-param="NUMACTUAL"/>
			<with-param name="DISPONIBLES" query-param="DISPONIBLES"/>
			<with-param name="ANULADA" query-param="ANULADA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getChequerasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CHEQUERA.COMPANIA,CHEQUERA.ANO,CHEQUERA.CUENTA,CHEQUERA.NUMCHEQUERA,CHEQUERA.NUMINICIAL,CHEQUERA.NUMFINAL,CHEQUERA.NUMACTUAL,CHEQUERA.DISPONIBLES,(CASE CHEQUERA.ANULADA WHEN 0 THEN 'false' ELSE 'true' END) ANULADA FROM CHEQUERA WHERE CHEQUERA.COMPANIA = :COMPANIA AND CHEQUERA.ANO = :ANO AND CHEQUERA.CUENTA = :CUENTA) WHERE (CASE WHEN NUMCHEQUERA IS NULL THEN ' ' ELSE UPPER(NUMCHEQUERA) END)  LIKE UPPER(:NUMCHEQUERA || '%')  AND (CASE WHEN NUMINICIAL IS NULL THEN ' ' ELSE UPPER(NUMINICIAL) END)  LIKE UPPER( '%' || :NUMINICIAL || '%')  AND (CASE WHEN NUMFINAL IS NULL THEN ' ' ELSE UPPER(NUMFINAL) END)  LIKE UPPER( '%' || :NUMFINAL || '%')  AND (CASE WHEN NUMACTUAL IS NULL THEN ' ' ELSE UPPER(NUMACTUAL) END)  LIKE UPPER( '%' || :NUMACTUAL || '%')  AND (CASE WHEN DISPONIBLES IS NULL THEN ' ' ELSE UPPER(DISPONIBLES) END)  LIKE UPPER( '%' || :DISPONIBLES || '%')  AND (CASE WHEN ANULADA IS NULL THEN ' ' ELSE UPPER(ANULADA) END)  LIKE UPPER( '%' || :ANULADA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NUMCHEQUERA" sqlType="STRING"/>
		<param name="NUMINICIAL" sqlType="STRING"/>
		<param name="NUMFINAL" sqlType="STRING"/>
		<param name="NUMACTUAL" sqlType="STRING"/>
		<param name="DISPONIBLES" sqlType="STRING"/>
		<param name="ANULADA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="chequeras/numero">
		<call-query href="getChequerasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NUMCHEQUERA" query-param="NUMCHEQUERA"/>
			<with-param name="NUMINICIAL" query-param="NUMINICIAL"/>
			<with-param name="NUMFINAL" query-param="NUMFINAL"/>
			<with-param name="NUMACTUAL" query-param="NUMACTUAL"/>
			<with-param name="DISPONIBLES" query-param="DISPONIBLES"/>
			<with-param name="ANULADA" query-param="ANULADA"/>

		</call-query>
	</resource>
	<query id="updateChequeras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CHEQUERA SET COMPANIA=:COMPANIA, ANO=:ANO, CUENTA=:CUENTA, NUMCHEQUERA=:NUMCHEQUERA, NUMINICIAL=:NUMINICIAL, NUMFINAL=:NUMFINAL, NUMACTUAL=:NUMACTUAL, DISPONIBLES=:DISPONIBLES, ANULADA=:ANULADA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CHEQUERA.COMPANIA= :KEY_COMPANIA AND CHEQUERA.ANO= :KEY_ANO AND CHEQUERA.CUENTA= :KEY_CUENTA AND CHEQUERA.NUMCHEQUERA= :KEY_NUMCHEQUERA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NUMCHEQUERA" sqlType="STRING"/>
		<param name="NUMINICIAL" sqlType="STRING"/>
		<param name="NUMFINAL" sqlType="STRING"/>
		<param name="NUMACTUAL" sqlType="STRING"/>
		<param name="DISPONIBLES" sqlType="STRING"/>
		<param name="ANULADA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>
		<param name="KEY_NUMCHEQUERA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="chequeras">
		<call-query href="updateChequeras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NUMCHEQUERA" query-param="NUMCHEQUERA"/>
			<with-param name="NUMINICIAL" query-param="NUMINICIAL"/>
			<with-param name="NUMFINAL" query-param="NUMFINAL"/>
			<with-param name="NUMACTUAL" query-param="NUMACTUAL"/>
			<with-param name="DISPONIBLES" query-param="DISPONIBLES"/>
			<with-param name="ANULADA" query-param="ANULADA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>
			<with-param name="KEY_NUMCHEQUERA" query-param="KEY_NUMCHEQUERA"/>

		</call-query>
	</resource>

</data>