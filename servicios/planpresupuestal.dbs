<data name="planpresupuestal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getResumenPptal"  useConfig="sysmandsunist">
		<sql>SELECT  V_RESUMENPPTO_BASE.ID,V_RESUMENPPTO_BASE.CODIGO CUENTA,REPLACE(V_RESUMENPPTO_BASE.NOMBRE,CHR(32)||CHR(32),'') NOMBRE,V_RESUMENPPTO_BASE.NATURALEZA,PRED.PREDECESOR,CASE WHEN V_RESUMENPPTO_BASE.MOVIMIENTO NOT IN (0) THEN 1 ELSE 0 END MOVIMIENTO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) APRDEFINITIVA,SUM(V_RESUMENPPTO_BASE.APLAZAMIENTO) APLAZAMIENTO, SUM(V_RESUMENPPTO_BASE.EJECUCIONPPT) TOTALRECAUDO,SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.EJECUCIONPPT) SALDOEJECUTAR,SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD)DISPONIBILIDADF,SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD) SALDODISPONIBLE,SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD - V_RESUMENPPTO_BASE.COMPROMISOSACUM) ABIERTO,SUM(V_RESUMENPPTO_BASE.OBLIGACIONESACUM) REOF,SUM(V_RESUMENPPTO_BASE.OBLIGACIONESACUM - V_RESUMENPPTO_BASE.EJECUCIONPPT) PORPAGAR,SUM(V_RESUMENPPTO_BASE.EJECUCIONPPT) PAGOSF,SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.EJECUCIONPPT) PROG_RECAUDAR,PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) NOT IN(0) THEN SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) / SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) * 100 ELSE 0 END,2) PORCENTAJEUTILIZACION, SUM(V_RESUMENPPTO_BASE.COMPROMISOSACUM) TOTALCOMPROMISOS,SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.COMPROMISOSACUM) SALDOCOMPROMETER, SUM(V_RESUMENPPTO_BASE.COMPROMISOSACUM - V_RESUMENPPTO_BASE.OBLIGACIONESACUM) COMPROMISOSABIERTOS, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) NOT IN(0) THEN SUM(V_RESUMENPPTO_BASE.COMPROMISOSACUM) / SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) * 100 ELSE 0 END,2)PORCCOMPROMISOS  FROM V_RESUMENPPTO_BASE INNER JOIN (SELECT PLAN.COMPANIA,PLAN.ANO,PLAN.ID, MAX(PRE.ID) PREDECESOR FROM V_PLAN_PRESUPUESTAL PLAN LEFT JOIN V_PLAN_PRESUPUESTAL PRE ON PRE.COMPANIA = PLAN.COMPANIA AND PRE.ANO = PLAN.ANO AND PRE.ID = SUBSTR(PLAN.ID,1, LENGTH(PRE.ID)) AND PRE.ID NOT IN(PLAN.ID)WHERE PLAN.COMPANIA =:compania AND PLAN.ANO =:anio GROUP BY PLAN.COMPANIA,PLAN.ANO,PLAN.ID) PRED ON V_RESUMENPPTO_BASE.COMPANIA = PRED.COMPANIA AND V_RESUMENPPTO_BASE.ANO = PRED.ANO AND V_RESUMENPPTO_BASE.ID = PRED.ID GROUP BY V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.CODIGO , V_RESUMENPPTO_BASE.NOMBRE, V_RESUMENPPTO_BASE.NATURALEZA, PRED.PREDECESOR, CASE WHEN V_RESUMENPPTO_BASE.MOVIMIENTO NOT IN (0) THEN 1 ELSE 0 END ORDER BY V_RESUMENPPTO_BASE.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"id":"$ID","cuenta":"$CUENTA","nombre":"$NOMBRE","naturaleza":"$NATURALEZA","predecesor":"$PREDECESOR","movimiento":"$MOVIMIENTO","apropiacionDefinitiva":"$APRDEFINITIVA","aplazamiento":"$APLAZAMIENTO","totalRecaudo":"$TOTALRECAUDO","saldoAEjecutar":"$SALDOEJECUTAR","totalDisponibilidad":"$DISPONIBILIDADF","saldoDisponible":"$SALDODISPONIBLE","abierto":"$ABIERTO","totalObligaciones":"$REOF","porPagar":"$PORPAGAR","totalPagos":"$PAGOSF","programadoPorRecaudar":"$PROG_RECAUDAR","porcentajeUtilizacion":"$PORCENTAJEUTILIZACION","totalCompromisos":"$TOTALCOMPROMISOS","saldoPorComprometer":"$SALDOCOMPROMETER","compromisosAbiertos":"$COMPROMISOSABIERTOS","porcentajeCompromiso":"$PORCCOMPROMISOS"}]}}		</result>
		<param name="compania" sqlType="STRING"/>
		<param name="anio" sqlType="STRING"/>

	</query>
	<resource method="GET" path="resumen">
		<call-query href="getResumenPptal">
			<with-param name="compania" query-param="compania"/>
			<with-param name="anio" query-param="anio"/>

		</call-query>
	</resource>
	<query id="getPlanpresupuestalResumenpptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.CODIGO CUENTA, REPLACE( V_RESUMENPPTO_BASE.NOMBRE,CONCAT( CHR(32), CHR(32)),'') NOMBRE, V_RESUMENPPTO_BASE.NATURALEZA, PRED.PREDECESOR, CASE WHEN V_RESUMENPPTO_BASE.MOVIMIENTO NOT IN (0) THEN 1 ELSE 0 END MOVIMIENTO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) APRDEFINITIVA, SUM(V_RESUMENPPTO_BASE.APLAZAMIENTO) APLAZAMIENTO, SUM(V_RESUMENPPTO_BASE.EJECUCIONPPT) TOTALRECAUDO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.EJECUCIONPPT) SALDOEJECUTAR, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) DISPONIBILIDADF, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD) SALDODISPONIBLE, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD - V_RESUMENPPTO_BASE.COMPROMISOSACUM) ABIERTO, SUM(V_RESUMENPPTO_BASE.OBLIGACIONESACUM) REOF, SUM(V_RESUMENPPTO_BASE.OBLIGACIONESACUM - V_RESUMENPPTO_BASE.EJECUCIONPPT) PORPAGAR, SUM(V_RESUMENPPTO_BASE.EJECUCIONPPT) PAGOSF, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.EJECUCIONPPT) PROG_RECAUDAR, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) NOT IN( 0 ) THEN SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) / SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) * 100 ELSE 0 END,2) PORCENTAJEUTILIZACION, SUM(V_RESUMENPPTO_BASE.COMPROMISOSACUM) TOTALCOMPROMISOS, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.COMPROMISOSACUM) SALDOCOMPROMETER, SUM(V_RESUMENPPTO_BASE.COMPROMISOSACUM - V_RESUMENPPTO_BASE.OBLIGACIONESACUM) COMPROMISOSABIERTOS, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) NOT IN( 0 ) THEN SUM(V_RESUMENPPTO_BASE.COMPROMISOSACUM) / SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE) * 100 ELSE 0 END,2) PORCCOMPROMISOS FROM V_RESUMENPPTO_BASE INNER JOIN ( SELECT PLAN.COMPANIA, PLAN.ANO, PLAN.ID, MAX(PRE.ID) PREDECESOR FROM V_PLAN_PRESUPUESTAL PLAN LEFT JOIN V_PLAN_PRESUPUESTAL PRE ON PRE.COMPANIA = PLAN.COMPANIA AND PRE.ANO = PLAN.ANO AND PRE.ID = SUBSTR(PLAN.ID,1,LENGTH(PRE.ID) ) AND PRE.ID NOT IN ( PLAN.ID ) WHERE PLAN.COMPANIA =:COMPANIA AND PLAN.ANO =:ANIO GROUP BY PLAN.COMPANIA, PLAN.ANO, PLAN.ID ) PRED ON V_RESUMENPPTO_BASE.COMPANIA = PRED.COMPANIA AND V_RESUMENPPTO_BASE.ANO = PRED.ANO AND V_RESUMENPPTO_BASE.ID = PRED.ID GROUP BY V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.CODIGO, V_RESUMENPPTO_BASE.NOMBRE, V_RESUMENPPTO_BASE.NATURALEZA, PRED.PREDECESOR, CASE WHEN V_RESUMENPPTO_BASE.MOVIMIENTO NOT IN ( 0 ) THEN 1 ELSE 0 END ORDER BY V_RESUMENPPTO_BASE.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CUENTA":"$CUENTA","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","PREDECESOR":"$PREDECESOR","MOVIMIENTO":"$MOVIMIENTO(type:integer)","APRDEFINITIVA":"$APRDEFINITIVA(type:integer)","APLAZAMIENTO":"$APLAZAMIENTO(type:integer)","TOTALRECAUDO":"$TOTALRECAUDO(type:integer)","SALDOEJECUTAR":"$SALDOEJECUTAR(type:integer)","DISPONIBILIDADF":"$DISPONIBILIDADF(type:integer)","SALDODISPONIBLE":"$SALDODISPONIBLE(type:integer)","ABIERTO":"$ABIERTO(type:integer)","REOF":"$REOF(type:integer)","PORPAGAR":"$PORPAGAR(type:integer)","PAGOSF":"$PAGOSF(type:integer)","PROG_RECAUDAR":"$PROG_RECAUDAR(type:integer)","PORCENTAJEUTILIZACION":"$PORCENTAJEUTILIZACION(type:integer)","TOTALCOMPROMISOS":"$TOTALCOMPROMISOS(type:integer)","SALDOCOMPROMETER":"$SALDOCOMPROMETER(type:integer)","COMPROMISOSABIERTOS":"$COMPROMISOSABIERTOS(type:integer)","PORCCOMPROMISOS":"$PORCCOMPROMISOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planpresupuestal/resumenpptal">
		<call-query href="getPlanpresupuestalResumenpptalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>

</data>