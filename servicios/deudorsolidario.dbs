<data name="deudorsolidario" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDeudorsolidario" keyColumns="COMPANIA,NIT_DEUDOR,SUCURSAL_DEUDOR,NIT_DEUDORPRINCIPAL,SUCURSAL_DEUDORPRINCIPAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DEUDOR_SOLIDARIO (COMPANIA, NIT_DEUDOR, SUCURSAL_DEUDOR, NIT_DEUDORPRINCIPAL, SUCURSAL_DEUDORPRINCIPAL, TIPOID, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NIT_DEUDOR, :SUCURSAL_DEUDOR, :NIT_DEUDORPRINCIPAL, :SUCURSAL_DEUDORPRINCIPAL, :TIPOID, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT_DEUDOR":"$NIT_DEUDOR","KEY_SUCURSAL_DEUDOR":"$SUCURSAL_DEUDOR","KEY_NIT_DEUDORPRINCIPAL":"$NIT_DEUDORPRINCIPAL","KEY_SUCURSAL_DEUDORPRINCIPAL":"$SUCURSAL_DEUDORPRINCIPAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT_DEUDOR" sqlType="STRING"/>
		<param name="SUCURSAL_DEUDOR" sqlType="STRING"/>
		<param name="NIT_DEUDORPRINCIPAL" sqlType="STRING"/>
		<param name="SUCURSAL_DEUDORPRINCIPAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPOID" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="deudorsolidario">
		<call-query href="insertDeudorsolidario">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT_DEUDOR" query-param="NIT_DEUDOR"/>
			<with-param name="SUCURSAL_DEUDOR" query-param="SUCURSAL_DEUDOR"/>
			<with-param name="NIT_DEUDORPRINCIPAL" query-param="NIT_DEUDORPRINCIPAL"/>
			<with-param name="SUCURSAL_DEUDORPRINCIPAL" query-param="SUCURSAL_DEUDORPRINCIPAL"/>
			<with-param name="TIPOID" query-param="TIPOID"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDeudorsolidario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DEUDOR_SOLIDARIO WHERE DEUDOR_SOLIDARIO.COMPANIA= :KEY_COMPANIA AND DEUDOR_SOLIDARIO.NIT_DEUDOR= :KEY_NIT_DEUDOR AND DEUDOR_SOLIDARIO.SUCURSAL_DEUDOR= :KEY_SUCURSAL_DEUDOR AND DEUDOR_SOLIDARIO.NIT_DEUDORPRINCIPAL= :KEY_NIT_DEUDORPRINCIPAL AND DEUDOR_SOLIDARIO.SUCURSAL_DEUDORPRINCIPAL= :KEY_SUCURSAL_DEUDORPRINCIPAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT_DEUDOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_DEUDOR" sqlType="STRING"/>
		<param name="KEY_NIT_DEUDORPRINCIPAL" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_DEUDORPRINCIPAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="deudorsolidario">
		<call-query href="deleteDeudorsolidario">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT_DEUDOR" query-param="KEY_NIT_DEUDOR"/>
			<with-param name="KEY_SUCURSAL_DEUDOR" query-param="KEY_SUCURSAL_DEUDOR"/>
			<with-param name="KEY_NIT_DEUDORPRINCIPAL" query-param="KEY_NIT_DEUDORPRINCIPAL"/>
			<with-param name="KEY_SUCURSAL_DEUDORPRINCIPAL" query-param="KEY_SUCURSAL_DEUDORPRINCIPAL"/>

		</call-query>
	</resource>
	<query id="getDeudorsolidarioPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DEUDOR_SOLIDARIO.COMPANIA, DEUDOR_SOLIDARIO.NIT_DEUDOR, DEUDOR_SOLIDARIO.SUCURSAL_DEUDOR, DEUDOR_SOLIDARIO.TIPOID, TERCERO.NOMBRE,DEUDOR_SOLIDARIO.NIT_DEUDORPRINCIPAL ,DEUDOR_SOLIDARIO.SUCURSAL_DEUDORPRINCIPAL FROM DEUDOR_SOLIDARIO INNER JOIN TERCERO ON DEUDOR_SOLIDARIO.COMPANIA = TERCERO.COMPANIA AND DEUDOR_SOLIDARIO.NIT_DEUDOR = TERCERO.NIT AND DEUDOR_SOLIDARIO.SUCURSAL_DEUDOR = TERCERO.SUCURSAL WHERE DEUDOR_SOLIDARIO.COMPANIA = :COMPANIA AND DEUDOR_SOLIDARIO.NIT_DEUDORPRINCIPAL = :NIT AND DEUDOR_SOLIDARIO.SUCURSAL_DEUDORPRINCIPAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT_DEUDOR":"$NIT_DEUDOR","SUCURSAL_DEUDOR":"$SUCURSAL_DEUDOR","TIPOID":"$TIPOID","NOMBRE":"$NOMBRE","NIT_DEUDORPRINCIPAL":"$NIT_DEUDORPRINCIPAL","SUCURSAL_DEUDORPRINCIPAL":"$SUCURSAL_DEUDORPRINCIPAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="deudorsolidario">
		<call-query href="getDeudorsolidarioPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateDeudorsolidario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEUDOR_SOLIDARIO SET NIT_DEUDOR=:NIT_DEUDOR, SUCURSAL_DEUDOR=:SUCURSAL_DEUDOR, NIT_DEUDORPRINCIPAL=:NIT_DEUDORPRINCIPAL, SUCURSAL_DEUDORPRINCIPAL=:SUCURSAL_DEUDORPRINCIPAL, TIPOID=:TIPOID, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DEUDOR_SOLIDARIO.COMPANIA= :KEY_COMPANIA AND DEUDOR_SOLIDARIO.NIT_DEUDOR= :KEY_NIT_DEUDOR AND DEUDOR_SOLIDARIO.SUCURSAL_DEUDOR= :KEY_SUCURSAL_DEUDOR AND DEUDOR_SOLIDARIO.NIT_DEUDORPRINCIPAL= :KEY_NIT_DEUDORPRINCIPAL AND DEUDOR_SOLIDARIO.SUCURSAL_DEUDORPRINCIPAL= :KEY_SUCURSAL_DEUDORPRINCIPAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NIT_DEUDOR" sqlType="STRING"/>
		<param name="SUCURSAL_DEUDOR" sqlType="STRING"/>
		<param name="NIT_DEUDORPRINCIPAL" sqlType="STRING"/>
		<param name="SUCURSAL_DEUDORPRINCIPAL" sqlType="STRING"/>
		<param name="TIPOID" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT_DEUDOR" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_DEUDOR" sqlType="STRING"/>
		<param name="KEY_NIT_DEUDORPRINCIPAL" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_DEUDORPRINCIPAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="deudorsolidario">
		<call-query href="updateDeudorsolidario">
			<with-param name="NIT_DEUDOR" query-param="NIT_DEUDOR"/>
			<with-param name="SUCURSAL_DEUDOR" query-param="SUCURSAL_DEUDOR"/>
			<with-param name="NIT_DEUDORPRINCIPAL" query-param="NIT_DEUDORPRINCIPAL"/>
			<with-param name="SUCURSAL_DEUDORPRINCIPAL" query-param="SUCURSAL_DEUDORPRINCIPAL"/>
			<with-param name="TIPOID" query-param="TIPOID"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT_DEUDOR" query-param="KEY_NIT_DEUDOR"/>
			<with-param name="KEY_SUCURSAL_DEUDOR" query-param="KEY_SUCURSAL_DEUDOR"/>
			<with-param name="KEY_NIT_DEUDORPRINCIPAL" query-param="KEY_NIT_DEUDORPRINCIPAL"/>
			<with-param name="KEY_SUCURSAL_DEUDORPRINCIPAL" query-param="KEY_SUCURSAL_DEUDORPRINCIPAL"/>

		</call-query>
	</resource>

</data>