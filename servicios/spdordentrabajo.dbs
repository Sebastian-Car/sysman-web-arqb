<data name="spdordentrabajo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpdordentrabajoCantidadPorClaseYProblemaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) AS CANTIDAD  FROM SP_D_ORDENTRABAJO WHERE COMPANIA = :COMPANIA AND CLASEPROBLEMA = :CLASEPROBLEMA AND PROBLEMA = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEPROBLEMA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdordentrabajo/cantidadporclaseyproblema">
		<call-query href="getSpdordentrabajoCantidadPorClaseYProblemaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEPROBLEMA" query-param="CLASEPROBLEMA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpdordentrabajoConsultaporordentrabajoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_ORDENTRABAJO.NUMORDEN, CASE SP_ORDENTRABAJO.TIPOREQUERIMIENTO WHEN 'C' THEN 'Consulta' WHEN 'Q' THEN 'Queja' WHEN 'R' THEN 'Reclamo' WHEN 'RE' THEN 'Recurso' WHEN 'P' THEN 'Petición' END TIPOREQUERIMIENTO, SP_ORDENTRABAJO.CODIGORUTA, CASE SP_ORDENTRABAJO.PRESENTACION WHEN 'V' THEN 'Verbal' WHEN 'E' THEN 'Escrita' WHEN 'T' THEN 'Teléfono' END PRESENTACION,(CASE SP_ORDENTRABAJO.ENVIOOFICINA WHEN 0 THEN 'false' ELSE 'true' END) ENVIOOFICINA,(CASE SP_ORDENTRABAJO.NECESITAVISITA WHEN 0 THEN 'false' ELSE 'true' END) NECESITAVISITA,(TO_CHAR(SP_ORDENTRABAJO.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD, SP_D_ORDENTRABAJO.PROBLEMA, SP_D_ORDENTRABAJO.SOLUCION, SP_D_ORDENTRABAJO.OBSERVACIONES,(TO_CHAR(SP_D_ORDENTRABAJO.FECHASOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHASOLUCION,(CASE SP_D_ORDENTRABAJO.INDFAVOREMPRESA WHEN 0 THEN 'false' ELSE 'true' END) INDFAVOREMPRESA, SP_ORDENTRABAJO.CLASEDOC, SP_D_ORDENTRABAJO.CLASEPROBLEMA, SP_PROBLEMA.NOMBRE  FROM (SP_D_ORDENTRABAJO LEFT JOIN SP_ORDENTRABAJO ON SP_D_ORDENTRABAJO.COMPANIA = SP_ORDENTRABAJO.COMPANIA AND SP_D_ORDENTRABAJO.ORDENTRABAJO = SP_ORDENTRABAJO.NUMORDEN AND SP_D_ORDENTRABAJO.CLASEDOC = SP_ORDENTRABAJO.CLASEDOC) INNER JOIN SP_PROBLEMA ON SP_D_ORDENTRABAJO.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_D_ORDENTRABAJO.PROBLEMA = SP_PROBLEMA.CODIGO AND SP_D_ORDENTRABAJO.CLASEPROBLEMA = SP_PROBLEMA.CLASEPROBLEMA WHERE SP_ORDENTRABAJO.COMPANIA = :COMPANIA AND SP_ORDENTRABAJO.CODIGORUTA = :CODIGORUTA AND SP_ORDENTRABAJO.CICLO = :CICLO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMORDEN":"$NUMORDEN(type:long)","TIPOREQUERIMIENTO":"$TIPOREQUERIMIENTO","CODIGORUTA":"$CODIGORUTA","PRESENTACION":"$PRESENTACION","ENVIOOFICINA":"$ENVIOOFICINA(type:boolean)","NECESITAVISITA":"$NECESITAVISITA(type:boolean)","FECHASOLICITUD":"$FECHASOLICITUD","PROBLEMA":"$PROBLEMA","SOLUCION":"$SOLUCION","OBSERVACIONES":"$OBSERVACIONES","FECHASOLUCION":"$FECHASOLUCION","INDFAVOREMPRESA":"$INDFAVOREMPRESA(type:boolean)","CLASEDOC":"$CLASEDOC","CLASEPROBLEMA":"$CLASEPROBLEMA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdordentrabajo/consultaporordentrabajo">
		<call-query href="getSpdordentrabajoConsultaporordentrabajoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CICLO" query-param="CICLO"/>

		</call-query>
	</resource>
	<query id="getSpdordentrabajoSeguimientoDeOrdenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_ORDENTRABAJO.CODIGORUTA, SP_ORDENTRABAJO.TIPOREQUERIMIENTO, SP_ORDENTRABAJO.PRESENTACION,(CASE SP_ORDENTRABAJO.ENVIOOFICINA WHEN 0 THEN 'false' ELSE 'true' END) ENVIOOFICINA,(CASE SP_ORDENTRABAJO.NECESITAVISITA WHEN 0 THEN 'false' ELSE 'true' END) NECESITAVISITA,(TO_CHAR(SP_ORDENTRABAJO.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD, SP_D_ORDENTRABAJO.PROBLEMA, SP_D_ORDENTRABAJO.SOLUCION, SP_D_ORDENTRABAJO.OBSERVACIONES,(TO_CHAR(SP_D_ORDENTRABAJO.FECHASOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHASOLUCION,(CASE SP_D_ORDENTRABAJO.INDFAVOREMPRESA WHEN 0 THEN 'false' ELSE 'true' END) INDFAVOREMPRESA, SP_D_ORDENTRABAJO.CLASEPROBLEMA, SP_D_ORDENTRABAJO.CREATED_BY,(TO_CHAR(SP_D_ORDENTRABAJO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_D_ORDENTRABAJO.MODIFIED_BY,(TO_CHAR(SP_D_ORDENTRABAJO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SP_PROBLEMA.NOMBRE NOMBREPROBLEMA, CASE SP_ORDENTRABAJO.PRESENTACION WHEN 'V' THEN 'Verbal' WHEN 'E' THEN 'Escrita' WHEN 'T' THEN 'Teléfono' ELSE '' END NOMBREPRESENTACION  FROM SP_D_ORDENTRABAJO INNER JOIN SP_ORDENTRABAJO ON SP_D_ORDENTRABAJO.COMPANIA = SP_ORDENTRABAJO.COMPANIA AND SP_D_ORDENTRABAJO.CLASEDOC = SP_ORDENTRABAJO.CLASEDOC AND SP_D_ORDENTRABAJO.ORDENTRABAJO = SP_ORDENTRABAJO.NUMORDEN INNER JOIN SP_PROBLEMA ON SP_D_ORDENTRABAJO.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_D_ORDENTRABAJO.CLASEPROBLEMA = SP_PROBLEMA.CLASEPROBLEMA AND SP_D_ORDENTRABAJO.PROBLEMA = SP_PROBLEMA.CODIGO WHERE SP_D_ORDENTRABAJO.COMPANIA =:COMPANIA AND SP_D_ORDENTRABAJO.CLASEDOC =:CLASEDOC AND SP_D_ORDENTRABAJO.ORDENTRABAJO =:ORDENTRABAJO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","TIPOREQUERIMIENTO":"$TIPOREQUERIMIENTO","PRESENTACION":"$PRESENTACION","ENVIOOFICINA":"$ENVIOOFICINA(type:boolean)","NECESITAVISITA":"$NECESITAVISITA(type:boolean)","FECHASOLICITUD":"$FECHASOLICITUD","PROBLEMA":"$PROBLEMA","SOLUCION":"$SOLUCION","OBSERVACIONES":"$OBSERVACIONES","FECHASOLUCION":"$FECHASOLUCION","INDFAVOREMPRESA":"$INDFAVOREMPRESA(type:boolean)","CLASEPROBLEMA":"$CLASEPROBLEMA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBREPROBLEMA":"$NOMBREPROBLEMA","NOMBREPRESENTACION":"$NOMBREPRESENTACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="ORDENTRABAJO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdordentrabajo/seguimientodeorden">
		<call-query href="getSpdordentrabajoSeguimientoDeOrdenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="ORDENTRABAJO" query-param="ORDENTRABAJO"/>

		</call-query>
	</resource>
	<query id="getSpdordentrabajoCantidadDeDetallesDeOrdenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM SP_D_ORDENTRABAJO WHERE COMPANIA = :COMPANIA AND CLASEDOC = :CLASEDOC AND ORDENTRABAJO = :ORDENTRABAJO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="ORDENTRABAJO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdordentrabajo/cantidaddedetallesdeorden">
		<call-query href="getSpdordentrabajoCantidadDeDetallesDeOrdenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="ORDENTRABAJO" query-param="ORDENTRABAJO"/>

		</call-query>
	</resource>
	<query id="getSpdordentrabajoListaordenestrabajoporcodigorutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.OBSERVACION, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.SOLUCION, SP_PROBLEMA.CODIGO  FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA LEFT JOIN SP_CLASEPROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_CLASEPROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_CLASEPROBLEMA.CLASEPROBLEMA WHERE SP_USUARIO_PROBLEMA.COMPANIA = :COMPANIA AND SP_USUARIO_PROBLEMA.CICLO = :CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = :CODIGORUTA ORDER BY SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO DESC, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.PROBLEMA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","OBSERVACION":"$OBSERVACION","NOMBRE":"$NOMBRE","SOLUCION":"$SOLUCION","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdordentrabajo/listaordenestrabajoporcodigoruta">
		<call-query href="getSpdordentrabajoListaordenestrabajoporcodigorutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpdordentrabajoListaordenestrabajoporcicloyperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.OBSERVACION, SP_PROBLEMA.NOMBRE, SP_PROBLEMA.SOLUCION, SP_PROBLEMA.CODIGO  FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA LEFT JOIN SP_CLASEPROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_CLASEPROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_CLASEPROBLEMA.CLASEPROBLEMA WHERE SP_USUARIO_PROBLEMA.COMPANIA = :COMPANIA AND SP_USUARIO_PROBLEMA.CICLO = :CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = :CODIGORUTA AND SP_USUARIO_PROBLEMA.ANO = :ANO AND SP_USUARIO_PROBLEMA.PERIODO = :PERIODO ORDER BY SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO DESC, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO_PROBLEMA.PROBLEMA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROBLEMA":"$PROBLEMA","CLASE":"$CLASE","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","OBSERVACION":"$OBSERVACION","NOMBRE":"$NOMBRE","SOLUCION":"$SOLUCION","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdordentrabajo/listaordenestrabajoporcicloyperiodo">
		<call-query href="getSpdordentrabajoListaordenestrabajoporcicloyperiodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="updateSpdordentrabajoPqr" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>MERGE INTO SP_D_ORDENTRABAJO TABLA USING ( SELECT PQR.COMPANIA, PQR.CLASEDOC, PQR.NUMORDEN, ORD.CLASEDOC CLASEDOCORD, ORD.NUMORDEN NUMORDENORD, D_ORD.NUMERO, D_ORD.OBSERVACIONES, :USUARIO, SYSDATE FROM SP_ORDENTRABAJO ORD INNER JOIN SP_ORDENTRABAJO PQR ON ORD.COMPANIA = PQR.COMPANIA AND ORD.NUMORDEN = PQR.NUMORDENT INNER JOIN SP_D_ORDENTRABAJO D_ORD ON ORD.COMPANIA = D_ORD.COMPANIA AND ORD.CLASEDOC = D_ORD.CLASEDOC AND ORD.NUMORDEN = D_ORD.ORDENTRABAJO WHERE ORD.COMPANIA =:COMPANIA AND ORD.CLASEDOC = 'ORD' AND ORD.NUMORDEN =:NUMORDEN ) VISTA ON ( TABLA.COMPANIA = VISTA.COMPANIA AND TABLA.CLASEDOC = VISTA.CLASEDOC AND TABLA.ORDENTRABAJO = VISTA.NUMORDEN AND TABLA.NUMERO = VISTA.NUMERO ) WHEN MATCHED THEN UPDATE SET TABLA.OBSERVACIONES = CONCAT( TABLA.OBSERVACIONES, CONCAT(' ', VISTA.OBSERVACIONES)) WHERE TABLA.COMPANIA =:COMPANIA AND VISTA.CLASEDOC = 'ORD' AND VISTA.NUMORDENORD =:NUMORDEN AND VISTA.CLASEDOC = 'PQR'</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spdordentrabajo/pqr">
		<call-query href="updateSpdordentrabajoPqr">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>

		</call-query>
	</resource>
	<query id="insertSpdordentrabajo" keyColumns="COMPANIA,CLASEDOC,ORDENTRABAJO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_D_ORDENTRABAJO (COMPANIA, CLASEDOC, ORDENTRABAJO, NUMERO, CLASEPROBLEMA, PROBLEMA, OBSERVACIONES, INDFAVOREMPRESA, VRFACTURADOANT, NUEVOVALOR, TOTALFACTURAANT, TOTFACTURADO, CONCEPTO, TIPO, TIPORESPUESTA, TIPONOTIFICACION, SOLUCION, CREATED_BY, DATE_CREATED, FECHASOLUCIONSITIO, FECHATRASLADO_SSPD, FECHASOLUCION, FECHANOTIFICACION) VALUES (:COMPANIA, :CLASEDOC, :ORDENTRABAJO, :NUMERO, :CLASEPROBLEMA, :PROBLEMA, :OBSERVACIONES, :INDFAVOREMPRESA, :VRFACTURADOANT, :NUEVOVALOR, :TOTALFACTURAANT, :TOTFACTURADO, :CONCEPTO, :TIPO, :TIPORESPUESTA, :TIPONOTIFICACION, :SOLUCION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHASOLUCIONSITIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHATRASLADO_SSPD,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHASOLUCION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHANOTIFICACION,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEDOC":"$CLASEDOC","KEY_ORDENTRABAJO":"$ORDENTRABAJO(type:long)","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="ORDENTRABAJO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CLASEPROBLEMA" sqlType="STRING"/>
		<param name="PROBLEMA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="INDFAVOREMPRESA" sqlType="STRING"/>
		<param defaultValue="0" name="VRFACTURADOANT" sqlType="STRING"/>
		<param defaultValue="0" name="NUEVOVALOR" sqlType="STRING"/>
		<param defaultValue="0" name="TOTALFACTURAANT" sqlType="STRING"/>
		<param defaultValue="0" name="TOTFACTURADO" sqlType="STRING"/>
		<param defaultValue="0" name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="TIPORESPUESTA" sqlType="STRING"/>
		<param defaultValue="" name="TIPONOTIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="SOLUCION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="FECHASOLUCIONSITIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHATRASLADO_SSPD" sqlType="STRING"/>
		<param defaultValue="" name="FECHASOLUCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHANOTIFICACION" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spdordentrabajo">
		<call-query href="insertSpdordentrabajo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="ORDENTRABAJO" query-param="ORDENTRABAJO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CLASEPROBLEMA" query-param="CLASEPROBLEMA"/>
			<with-param name="PROBLEMA" query-param="PROBLEMA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="INDFAVOREMPRESA" query-param="INDFAVOREMPRESA"/>
			<with-param name="VRFACTURADOANT" query-param="VRFACTURADOANT"/>
			<with-param name="NUEVOVALOR" query-param="NUEVOVALOR"/>
			<with-param name="TOTALFACTURAANT" query-param="TOTALFACTURAANT"/>
			<with-param name="TOTFACTURADO" query-param="TOTFACTURADO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TIPORESPUESTA" query-param="TIPORESPUESTA"/>
			<with-param name="TIPONOTIFICACION" query-param="TIPONOTIFICACION"/>
			<with-param name="SOLUCION" query-param="SOLUCION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="FECHASOLUCIONSITIO" query-param="FECHASOLUCIONSITIO"/>
			<with-param name="FECHATRASLADO_SSPD" query-param="FECHATRASLADO_SSPD"/>
			<with-param name="FECHASOLUCION" query-param="FECHASOLUCION"/>
			<with-param name="FECHANOTIFICACION" query-param="FECHANOTIFICACION"/>

		</call-query>
	</resource>
	<query id="deleteSpdordentrabajo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_D_ORDENTRABAJO WHERE SP_D_ORDENTRABAJO.COMPANIA= :KEY_COMPANIA AND SP_D_ORDENTRABAJO.CLASEDOC= :KEY_CLASEDOC AND SP_D_ORDENTRABAJO.ORDENTRABAJO= :KEY_ORDENTRABAJO AND SP_D_ORDENTRABAJO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEDOC" sqlType="STRING"/>
		<param name="KEY_ORDENTRABAJO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spdordentrabajo">
		<call-query href="deleteSpdordentrabajo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEDOC" query-param="KEY_CLASEDOC"/>
			<with-param name="KEY_ORDENTRABAJO" query-param="KEY_ORDENTRABAJO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getSpdordentrabajoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_D_ORDENTRABAJO.COMPANIA, SP_D_ORDENTRABAJO.CLASEDOC, SP_D_ORDENTRABAJO.ORDENTRABAJO, SP_D_ORDENTRABAJO.NUMERO, SP_D_ORDENTRABAJO.CLASEPROBLEMA, SP_D_ORDENTRABAJO.PROBLEMA, SP_D_ORDENTRABAJO.OBSERVACIONES,(CASE SP_D_ORDENTRABAJO.INDFAVOREMPRESA WHEN 0 THEN 'false' ELSE 'true' END) INDFAVOREMPRESA, SP_D_ORDENTRABAJO.VRFACTURADOANT, SP_D_ORDENTRABAJO.NUEVOVALOR, SP_D_ORDENTRABAJO.TOTALFACTURAANT, SP_D_ORDENTRABAJO.TOTFACTURADO, SP_D_ORDENTRABAJO.CONCEPTO, SP_D_ORDENTRABAJO.TIPO, SP_D_ORDENTRABAJO.TIPORESPUESTA, SP_D_ORDENTRABAJO.TIPONOTIFICACION, SP_D_ORDENTRABAJO.SOLUCION,(TO_CHAR(SP_D_ORDENTRABAJO.FECHASOLUCIONSITIO,'DD/MM/YYYY HH24:MI:SS')) FECHASOLUCIONSITIO,(TO_CHAR(SP_D_ORDENTRABAJO.FECHATRASLADO_SSPD,'DD/MM/YYYY HH24:MI:SS')) FECHATRASLADO_SSPD,(TO_CHAR(SP_D_ORDENTRABAJO.FECHASOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHASOLUCION,(TO_CHAR(SP_D_ORDENTRABAJO.FECHANOTIFICACION,'DD/MM/YYYY HH24:MI:SS')) FECHANOTIFICACION, SP_PROBLEMA.NOMBRE PROBLEMANOMBRE, SP_CLASEPROBLEMA.NOMBRE CLASENOMBRE  FROM SP_D_ORDENTRABAJO INNER JOIN SP_PROBLEMA ON SP_D_ORDENTRABAJO.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_D_ORDENTRABAJO.CLASEPROBLEMA = SP_PROBLEMA.CLASEPROBLEMA AND SP_D_ORDENTRABAJO.PROBLEMA = SP_PROBLEMA.CODIGO INNER JOIN SP_CLASEPROBLEMA ON SP_PROBLEMA.COMPANIA = SP_CLASEPROBLEMA.COMPANIA AND SP_PROBLEMA.CLASEPROBLEMA = SP_CLASEPROBLEMA.CLASEPROBLEMA WHERE SP_D_ORDENTRABAJO.COMPANIA = :COMPANIA AND SP_D_ORDENTRABAJO.CLASEDOC = :CLASEDOC AND SP_D_ORDENTRABAJO.ORDENTRABAJO = :ORDENTRABAJO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEDOC":"$CLASEDOC","ORDENTRABAJO":"$ORDENTRABAJO(type:long)","NUMERO":"$NUMERO(type:long)","CLASEPROBLEMA":"$CLASEPROBLEMA","PROBLEMA":"$PROBLEMA","OBSERVACIONES":"$OBSERVACIONES","INDFAVOREMPRESA":"$INDFAVOREMPRESA(type:boolean)","VRFACTURADOANT":"$VRFACTURADOANT","NUEVOVALOR":"$NUEVOVALOR","TOTALFACTURAANT":"$TOTALFACTURAANT","TOTFACTURADO":"$TOTFACTURADO","CONCEPTO":"$CONCEPTO(type:integer)","TIPO":"$TIPO","TIPORESPUESTA":"$TIPORESPUESTA","TIPONOTIFICACION":"$TIPONOTIFICACION","SOLUCION":"$SOLUCION","FECHASOLUCIONSITIO":"$FECHASOLUCIONSITIO","FECHATRASLADO_SSPD":"$FECHATRASLADO_SSPD","FECHASOLUCION":"$FECHASOLUCION","FECHANOTIFICACION":"$FECHANOTIFICACION","PROBLEMANOMBRE":"$PROBLEMANOMBRE","CLASENOMBRE":"$CLASENOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="ORDENTRABAJO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spdordentrabajo">
		<call-query href="getSpdordentrabajoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="ORDENTRABAJO" query-param="ORDENTRABAJO"/>

		</call-query>
	</resource>
	<query id="updateSpdordentrabajo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_D_ORDENTRABAJO SET CLASEPROBLEMA=:CLASEPROBLEMA, PROBLEMA=:PROBLEMA, OBSERVACIONES=:OBSERVACIONES, INDFAVOREMPRESA=:INDFAVOREMPRESA, VRFACTURADOANT=:VRFACTURADOANT, NUEVOVALOR=:NUEVOVALOR, TOTALFACTURAANT=:TOTALFACTURAANT, TOTFACTURADO=:TOTFACTURADO, CONCEPTO=:CONCEPTO, TIPO=:TIPO, TIPORESPUESTA=:TIPORESPUESTA, TIPONOTIFICACION=:TIPONOTIFICACION, SOLUCION=:SOLUCION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHATRASLADO_SSPD=TO_DATE(:FECHATRASLADO_SSPD,'DD/MM/YYYY HH24:MI:SS'), FECHASOLUCION=TO_DATE(:FECHASOLUCION,'DD/MM/YYYY HH24:MI:SS'), FECHANOTIFICACION=TO_DATE(:FECHANOTIFICACION,'DD/MM/YYYY HH24:MI:SS') WHERE SP_D_ORDENTRABAJO.COMPANIA= :KEY_COMPANIA AND SP_D_ORDENTRABAJO.CLASEDOC= :KEY_CLASEDOC AND SP_D_ORDENTRABAJO.ORDENTRABAJO= :KEY_ORDENTRABAJO AND SP_D_ORDENTRABAJO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CLASEPROBLEMA" sqlType="STRING"/>
		<param name="PROBLEMA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="INDFAVOREMPRESA" sqlType="STRING"/>
		<param name="VRFACTURADOANT" sqlType="STRING"/>
		<param name="NUEVOVALOR" sqlType="STRING"/>
		<param name="TOTALFACTURAANT" sqlType="STRING"/>
		<param name="TOTFACTURADO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TIPORESPUESTA" sqlType="STRING"/>
		<param name="TIPONOTIFICACION" sqlType="STRING"/>
		<param name="SOLUCION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="FECHATRASLADO_SSPD" sqlType="STRING"/>
		<param name="FECHASOLUCION" sqlType="STRING"/>
		<param name="FECHANOTIFICACION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEDOC" sqlType="STRING"/>
		<param name="KEY_ORDENTRABAJO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spdordentrabajo">
		<call-query href="updateSpdordentrabajo">
			<with-param name="CLASEPROBLEMA" query-param="CLASEPROBLEMA"/>
			<with-param name="PROBLEMA" query-param="PROBLEMA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="INDFAVOREMPRESA" query-param="INDFAVOREMPRESA"/>
			<with-param name="VRFACTURADOANT" query-param="VRFACTURADOANT"/>
			<with-param name="NUEVOVALOR" query-param="NUEVOVALOR"/>
			<with-param name="TOTALFACTURAANT" query-param="TOTALFACTURAANT"/>
			<with-param name="TOTFACTURADO" query-param="TOTFACTURADO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TIPORESPUESTA" query-param="TIPORESPUESTA"/>
			<with-param name="TIPONOTIFICACION" query-param="TIPONOTIFICACION"/>
			<with-param name="SOLUCION" query-param="SOLUCION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="FECHATRASLADO_SSPD" query-param="FECHATRASLADO_SSPD"/>
			<with-param name="FECHASOLUCION" query-param="FECHASOLUCION"/>
			<with-param name="FECHANOTIFICACION" query-param="FECHANOTIFICACION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEDOC" query-param="KEY_CLASEDOC"/>
			<with-param name="KEY_ORDENTRABAJO" query-param="KEY_ORDENTRABAJO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>

</data>