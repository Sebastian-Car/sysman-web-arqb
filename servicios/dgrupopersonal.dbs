<data name="dgrupopersonal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDgrupopersonalGetdgrupopersonalporgrupoQuery"  useConfig="sysmandsunist">
		<sql>SELECT NOM_CATEGORIA FROM D_GRUPO_PERSONAL WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND ANO =:ANO ORDER BY NOM_CATEGORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOM_CATEGORIA":"$NOM_CATEGORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dgrupopersonal/getdgrupopersonalporgrupo">
		<call-query href="getDgrupopersonalGetdgrupopersonalporgrupoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertDgrupopersonal" keyColumns="COMPANIA,CODIGO,ANO,COD_CATEGORIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_GRUPO_PERSONAL (COMPANIA, CODIGO, ANO, COD_CATEGORIA, NOM_CATEGORIA, SALARIO_BASE, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO, :ANO, :COD_CATEGORIA, :NOM_CATEGORIA, :SALARIO_BASE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_ANO":"$ANO(type:integer)","KEY_COD_CATEGORIA":"$COD_CATEGORIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_CATEGORIA" sqlType="STRING"/>
		<param defaultValue="" name="NOM_CATEGORIA" sqlType="STRING"/>
		<param defaultValue="" name="SALARIO_BASE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dgrupopersonal">
		<call-query href="insertDgrupopersonal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_CATEGORIA" query-param="COD_CATEGORIA"/>
			<with-param name="NOM_CATEGORIA" query-param="NOM_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteDgrupopersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_GRUPO_PERSONAL WHERE D_GRUPO_PERSONAL.COMPANIA= :KEY_COMPANIA AND D_GRUPO_PERSONAL.CODIGO= :KEY_CODIGO AND D_GRUPO_PERSONAL.ANO= :KEY_ANO AND D_GRUPO_PERSONAL.COD_CATEGORIA= :KEY_COD_CATEGORIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_COD_CATEGORIA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="dgrupopersonal">
		<call-query href="deleteDgrupopersonal">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_COD_CATEGORIA" query-param="KEY_COD_CATEGORIA"/>

		</call-query>
	</resource>
	<query id="getDgrupopersonalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO, ANO, COD_CATEGORIA, NOM_CATEGORIA, SALARIO_BASE FROM D_GRUPO_PERSONAL WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO ORDER BY ANO DESC, COD_CATEGORIA) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN COD_CATEGORIA IS NULL THEN ' ' ELSE UPPER(COD_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_CATEGORIA), '%')) AND (CASE WHEN NOM_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOM_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_CATEGORIA), '%')) AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END) LIKE UPPER(CONCAT(:SALARIO_BASE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","COD_CATEGORIA":"$COD_CATEGORIA(type:integer)","NOM_CATEGORIA":"$NOM_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_CATEGORIA" sqlType="STRING"/>
		<param name="NOM_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dgrupopersonal">
		<call-query href="getDgrupopersonalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_CATEGORIA" query-param="COD_CATEGORIA"/>
			<with-param name="NOM_CATEGORIA" query-param="NOM_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDgrupopersonalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO, ANO, COD_CATEGORIA, NOM_CATEGORIA, SALARIO_BASE FROM D_GRUPO_PERSONAL WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO ORDER BY ANO DESC, COD_CATEGORIA) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN COD_CATEGORIA IS NULL THEN ' ' ELSE UPPER(COD_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_CATEGORIA), '%')) AND (CASE WHEN NOM_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOM_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_CATEGORIA), '%')) AND (CASE WHEN SALARIO_BASE IS NULL THEN ' ' ELSE UPPER(SALARIO_BASE) END) LIKE UPPER(CONCAT(:SALARIO_BASE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_CATEGORIA" sqlType="STRING"/>
		<param name="NOM_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dgrupopersonal/numero">
		<call-query href="getDgrupopersonalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_CATEGORIA" query-param="COD_CATEGORIA"/>
			<with-param name="NOM_CATEGORIA" query-param="NOM_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>

		</call-query>
	</resource>
	<query id="getDgrupopersonalRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO, ANO, COD_CATEGORIA, NOM_CATEGORIA, SALARIO_BASE FROM D_GRUPO_PERSONAL WHERE D_GRUPO_PERSONAL.COMPANIA= :KEY_COMPANIA AND D_GRUPO_PERSONAL.CODIGO= :KEY_CODIGO AND D_GRUPO_PERSONAL.ANO= :KEY_ANO AND D_GRUPO_PERSONAL.COD_CATEGORIA= :KEY_COD_CATEGORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","COD_CATEGORIA":"$COD_CATEGORIA(type:integer)","NOM_CATEGORIA":"$NOM_CATEGORIA","SALARIO_BASE":"$SALARIO_BASE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_COD_CATEGORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dgrupopersonal/data">
		<call-query href="getDgrupopersonalRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_COD_CATEGORIA" query-param="KEY_COD_CATEGORIA"/>

		</call-query>
	</resource>
	<query id="updateDgrupopersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_GRUPO_PERSONAL SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, ANO=:ANO, COD_CATEGORIA=:COD_CATEGORIA, NOM_CATEGORIA=:NOM_CATEGORIA, SALARIO_BASE=:SALARIO_BASE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE D_GRUPO_PERSONAL.COMPANIA= :KEY_COMPANIA AND D_GRUPO_PERSONAL.CODIGO= :KEY_CODIGO AND D_GRUPO_PERSONAL.ANO= :KEY_ANO AND D_GRUPO_PERSONAL.COD_CATEGORIA= :KEY_COD_CATEGORIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_CATEGORIA" sqlType="STRING"/>
		<param name="NOM_CATEGORIA" sqlType="STRING"/>
		<param name="SALARIO_BASE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_COD_CATEGORIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dgrupopersonal">
		<call-query href="updateDgrupopersonal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_CATEGORIA" query-param="COD_CATEGORIA"/>
			<with-param name="NOM_CATEGORIA" query-param="NOM_CATEGORIA"/>
			<with-param name="SALARIO_BASE" query-param="SALARIO_BASE"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_COD_CATEGORIA" query-param="KEY_COD_CATEGORIA"/>

		</call-query>
	</resource>

</data>