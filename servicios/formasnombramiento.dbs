<data name="formasnombramiento" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFormasnombramientoTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA  FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDFORMA":"$IDFORMA","NOMBREFORMA":"$NOMBREFORMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formasnombramiento/todosporcompania">
		<call-query href="getFormasnombramientoTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoPagCodigoYNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA  FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.COMPANIA = :COMPANIA ORDER BY FORMANOMBRAMIENTO.IDFORMA) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDFORMA":"$IDFORMA","NOMBREFORMA":"$NOMBREFORMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="formasnombramiento/codigoynombreinicial/pag">
		<call-query href="getFormasnombramientoPagCodigoYNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoNumCodigoYNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA  FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.COMPANIA = :COMPANIA ORDER BY FORMANOMBRAMIENTO.IDFORMA) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formasnombramiento/codigoynombreinicial/num">
		<call-query href="getFormasnombramientoNumCodigoYNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoPagCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA  FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.COMPANIA = :COMPANIA AND FORMANOMBRAMIENTO.IDFORMA &gt;= :TIPOCONTRATOINICIAL ORDER BY FORMANOMBRAMIENTO.IDFORMA) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDFORMA":"$IDFORMA","NOMBREFORMA":"$NOMBREFORMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATOINICIAL" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="formasnombramiento/codigoynombrefinal/pag">
		<call-query href="getFormasnombramientoPagCodigoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATOINICIAL" query-param="TIPOCONTRATOINICIAL"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoNumCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA  FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.COMPANIA = :COMPANIA AND FORMANOMBRAMIENTO.IDFORMA &gt;= :TIPOCONTRATOINICIAL ORDER BY FORMANOMBRAMIENTO.IDFORMA) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATOINICIAL" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formasnombramiento/codigoynombrefinal/num">
		<call-query href="getFormasnombramientoNumCodigoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATOINICIAL" query-param="TIPOCONTRATOINICIAL"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoPagNombramientoEscarreraQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA, FORMANOMBRAMIENTO.TIPO,(CASE FORMANOMBRAMIENTO.ESCARRERA WHEN 0 THEN 'false' ELSE 'true' END) ESCARRERA FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.TIPO IN (:TIPO) AND FORMANOMBRAMIENTO.ESCARRERA NOT IN(0)) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDFORMA":"$IDFORMA","NOMBREFORMA":"$NOMBREFORMA","TIPO":"$TIPO","ESCARRERA":"$ESCARRERA(type:boolean)"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="formasnombramiento/nombramientoescarrera/pag">
		<call-query href="getFormasnombramientoPagNombramientoEscarreraQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoNumNombramientoEscarreraQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA, FORMANOMBRAMIENTO.TIPO,(CASE FORMANOMBRAMIENTO.ESCARRERA WHEN 0 THEN 'false' ELSE 'true' END) ESCARRERA FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.TIPO IN (:TIPO) AND FORMANOMBRAMIENTO.ESCARRERA NOT IN(0)) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formasnombramiento/nombramientoescarrera/num">
		<call-query href="getFormasnombramientoNumNombramientoEscarreraQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>

		</call-query>
	</resource>
	<query id="insertFormasnombramiento" keyColumns="COMPANIA,IDFORMA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FORMANOMBRAMIENTO (COMPANIA, IDFORMA, NOMBREFORMA, DESCRIPCION, COD_SIRECI, ESCARRERA, TIPO, CGR_TIPO_VINCULACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :IDFORMA, :NOMBREFORMA, :DESCRIPCION, :COD_SIRECI, :ESCARRERA, :TIPO, :CGR_TIPO_VINCULACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDFORMA":"$IDFORMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="COD_SIRECI" sqlType="STRING"/>
		<param defaultValue="0" name="ESCARRERA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="CGR_TIPO_VINCULACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="formasnombramiento">
		<call-query href="insertFormasnombramiento">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_SIRECI" query-param="COD_SIRECI"/>
			<with-param name="ESCARRERA" query-param="ESCARRERA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CGR_TIPO_VINCULACION" query-param="CGR_TIPO_VINCULACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteFormasnombramiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FORMANOMBRAMIENTO WHERE FORMANOMBRAMIENTO.COMPANIA= :KEY_COMPANIA AND FORMANOMBRAMIENTO.IDFORMA= :KEY_IDFORMA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDFORMA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="formasnombramiento">
		<call-query href="deleteFormasnombramiento">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDFORMA" query-param="KEY_IDFORMA"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FORMANOMBRAMIENTO.COMPANIA, FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA, FORMANOMBRAMIENTO.DESCRIPCION, FORMANOMBRAMIENTO.COD_SIRECI,(CASE FORMANOMBRAMIENTO.ESCARRERA WHEN 0 THEN 'false' ELSE 'true' END) ESCARRERA, CASE WHEN FORMANOMBRAMIENTO.TIPO IN ('A') THEN 'Activo' ELSE 'Inactivo' END TIPONOMBRE, FORMANOMBRAMIENTO.TIPO, FORMANOMBRAMIENTO.CGR_TIPO_VINCULACION, CGR_TIPO_VINCULACION.NOMBRE NOMBRE_VINCULACION  FROM FORMANOMBRAMIENTO LEFT JOIN CGR_TIPO_VINCULACION ON FORMANOMBRAMIENTO.CGR_TIPO_VINCULACION = CGR_TIPO_VINCULACION.CODIGO WHERE FORMANOMBRAMIENTO.COMPANIA = :COMPANIA) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN COD_SIRECI IS NULL THEN ' ' ELSE UPPER(COD_SIRECI) END)  LIKE UPPER(:COD_SIRECI || '%')  AND (CASE WHEN ESCARRERA IS NULL THEN ' ' ELSE UPPER(ESCARRERA) END)  LIKE UPPER( '%' || :ESCARRERA || '%')  AND (CASE WHEN TIPONOMBRE IS NULL THEN ' ' ELSE UPPER(TIPONOMBRE) END)  LIKE UPPER( '%' || :TIPONOMBRE || '%')  AND (CASE WHEN NOMBRE_VINCULACION IS NULL THEN ' ' ELSE UPPER(NOMBRE_VINCULACION) END)  LIKE UPPER( '%' || :NOMBRE_VINCULACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDFORMA":"$IDFORMA","NOMBREFORMA":"$NOMBREFORMA","DESCRIPCION":"$DESCRIPCION","COD_SIRECI":"$COD_SIRECI","ESCARRERA":"$ESCARRERA(type:boolean)","TIPONOMBRE":"$TIPONOMBRE","TIPO":"$TIPO","CGR_TIPO_VINCULACION":"$CGR_TIPO_VINCULACION","NOMBRE_VINCULACION":"$NOMBRE_VINCULACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COD_SIRECI" sqlType="STRING"/>
		<param name="ESCARRERA" sqlType="STRING"/>
		<param name="TIPONOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_VINCULACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="formasnombramiento">
		<call-query href="getFormasnombramientoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_SIRECI" query-param="COD_SIRECI"/>
			<with-param name="ESCARRERA" query-param="ESCARRERA"/>
			<with-param name="TIPONOMBRE" query-param="TIPONOMBRE"/>
			<with-param name="NOMBRE_VINCULACION" query-param="NOMBRE_VINCULACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFormasnombramientoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FORMANOMBRAMIENTO.COMPANIA, FORMANOMBRAMIENTO.IDFORMA, FORMANOMBRAMIENTO.NOMBREFORMA, FORMANOMBRAMIENTO.DESCRIPCION, FORMANOMBRAMIENTO.COD_SIRECI,(CASE FORMANOMBRAMIENTO.ESCARRERA WHEN 0 THEN 'false' ELSE 'true' END) ESCARRERA, CASE WHEN FORMANOMBRAMIENTO.TIPO IN ('A') THEN 'Activo' ELSE 'Inactivo' END TIPONOMBRE, FORMANOMBRAMIENTO.TIPO, FORMANOMBRAMIENTO.CGR_TIPO_VINCULACION, CGR_TIPO_VINCULACION.NOMBRE NOMBRE_VINCULACION  FROM FORMANOMBRAMIENTO LEFT JOIN CGR_TIPO_VINCULACION ON FORMANOMBRAMIENTO.CGR_TIPO_VINCULACION = CGR_TIPO_VINCULACION.CODIGO WHERE FORMANOMBRAMIENTO.COMPANIA = :COMPANIA) WHERE (CASE WHEN IDFORMA IS NULL THEN ' ' ELSE UPPER(IDFORMA) END)  LIKE UPPER(:IDFORMA || '%')  AND (CASE WHEN NOMBREFORMA IS NULL THEN ' ' ELSE UPPER(NOMBREFORMA) END)  LIKE UPPER( '%' || :NOMBREFORMA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN COD_SIRECI IS NULL THEN ' ' ELSE UPPER(COD_SIRECI) END)  LIKE UPPER(:COD_SIRECI || '%')  AND (CASE WHEN ESCARRERA IS NULL THEN ' ' ELSE UPPER(ESCARRERA) END)  LIKE UPPER( '%' || :ESCARRERA || '%')  AND (CASE WHEN TIPONOMBRE IS NULL THEN ' ' ELSE UPPER(TIPONOMBRE) END)  LIKE UPPER( '%' || :TIPONOMBRE || '%')  AND (CASE WHEN NOMBRE_VINCULACION IS NULL THEN ' ' ELSE UPPER(NOMBRE_VINCULACION) END)  LIKE UPPER( '%' || :NOMBRE_VINCULACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COD_SIRECI" sqlType="STRING"/>
		<param name="ESCARRERA" sqlType="STRING"/>
		<param name="TIPONOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_VINCULACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formasnombramiento/numero">
		<call-query href="getFormasnombramientoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_SIRECI" query-param="COD_SIRECI"/>
			<with-param name="ESCARRERA" query-param="ESCARRERA"/>
			<with-param name="TIPONOMBRE" query-param="TIPONOMBRE"/>
			<with-param name="NOMBRE_VINCULACION" query-param="NOMBRE_VINCULACION"/>

		</call-query>
	</resource>
	<query id="updateFormasnombramiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FORMANOMBRAMIENTO SET IDFORMA=:IDFORMA, NOMBREFORMA=:NOMBREFORMA, DESCRIPCION=:DESCRIPCION, COD_SIRECI=:COD_SIRECI, ESCARRERA=:ESCARRERA, TIPO=:TIPO, CGR_TIPO_VINCULACION=:CGR_TIPO_VINCULACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FORMANOMBRAMIENTO.COMPANIA= :KEY_COMPANIA AND FORMANOMBRAMIENTO.IDFORMA= :KEY_IDFORMA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IDFORMA" sqlType="STRING"/>
		<param name="NOMBREFORMA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COD_SIRECI" sqlType="STRING"/>
		<param name="ESCARRERA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CGR_TIPO_VINCULACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDFORMA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="formasnombramiento">
		<call-query href="updateFormasnombramiento">
			<with-param name="IDFORMA" query-param="IDFORMA"/>
			<with-param name="NOMBREFORMA" query-param="NOMBREFORMA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_SIRECI" query-param="COD_SIRECI"/>
			<with-param name="ESCARRERA" query-param="ESCARRERA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CGR_TIPO_VINCULACION" query-param="CGR_TIPO_VINCULACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDFORMA" query-param="KEY_IDFORMA"/>

		</call-query>
	</resource>

</data>