	<query id="insertFuenterecursosFuentesPptales" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FUENTE_RECURSOS (COMPANIA, ANO, CODIGO, NOMBRE, TIPO, CODIGO_DNP, CODIGO_SIA, TIPO_FUENTE_POAI, IND_SINSITUACIONFONDOS, EQUIVALENTECUIPO, EQUIVALENTEAPROPIACION, EQUIVALENTECAJA, CODIGO_CLEOPATRA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :TIPO, :CODIGO_DNP, :CODIGO_SIA, :TIPO_FUENTE_POAI, :IND_SINSITUACIONFONDOS, :EQUIVALENTECUIPO, :EQUIVALENTEAPROPIACION, :EQUIVALENTECAJA, :CODIGO_CLEOPATRA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_DNP" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_SIA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_FUENTE_POAI" sqlType="STRING"/>
		<param defaultValue="0" name="IND_SINSITUACIONFONDOS" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVALENTECUIPO" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVALENTEAPROPIACION" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVALENTECAJA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_CLEOPATRA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="fuenterecursos/fuentespptales">
		<call-query href="insertFuenterecursosFuentesPptales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO_DNP" query-param="CODIGO_DNP"/>
			<with-param name="CODIGO_SIA" query-param="CODIGO_SIA"/>
			<with-param name="TIPO_FUENTE_POAI" query-param="TIPO_FUENTE_POAI"/>
			<with-param name="IND_SINSITUACIONFONDOS" query-param="IND_SINSITUACIONFONDOS"/>
			<with-param name="EQUIVALENTECUIPO" query-param="EQUIVALENTECUIPO"/>
			<with-param name="EQUIVALENTEAPROPIACION" query-param="EQUIVALENTEAPROPIACION"/>
			<with-param name="EQUIVALENTECAJA" query-param="EQUIVALENTECAJA"/>
			<with-param name="CODIGO_CLEOPATRA" query-param="CODIGO_CLEOPATRA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateFuenterecursosFuentesPptales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FUENTE_RECURSOS SET NOMBRE=:NOMBRE, TIPO=:TIPO, CODIGO_DNP=:CODIGO_DNP, CODIGO_SIA=:CODIGO_SIA, TIPO_FUENTE_POAI=:TIPO_FUENTE_POAI, IND_SINSITUACIONFONDOS=:IND_SINSITUACIONFONDOS, EQUIVALENTECUIPO=:EQUIVALENTECUIPO, EQUIVALENTEAPROPIACION=:EQUIVALENTEAPROPIACION, EQUIVALENTECAJA=:EQUIVALENTECAJA, CODIGO_CLEOPATRA=:CODIGO_CLEOPATRA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FUENTE_RECURSOS.COMPANIA= :KEY_COMPANIA AND FUENTE_RECURSOS.ANO= :KEY_ANO AND FUENTE_RECURSOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO_DNP" sqlType="STRING"/>
		<param name="CODIGO_SIA" sqlType="STRING"/>
		<param name="TIPO_FUENTE_POAI" sqlType="STRING"/>
		<param name="IND_SINSITUACIONFONDOS" sqlType="STRING"/>
		<param name="EQUIVALENTECUIPO" sqlType="STRING"/>
		<param name="EQUIVALENTEAPROPIACION" sqlType="STRING"/>
		<param name="EQUIVALENTECAJA" sqlType="STRING"/>
		<param name="CODIGO_CLEOPATRA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="fuenterecursos/fuentespptales">
		<call-query href="updateFuenterecursosFuentesPptales">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO_DNP" query-param="CODIGO_DNP"/>
