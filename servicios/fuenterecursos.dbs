	<query id="getFuenterecursosNumFuentesDePlanIndQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO CODIGO_FUENTE, NOMBRE FROM FUENTE_RECURSOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO NOT IN ( SELECT FUENTE FROM PI_PLAN_INDICATIVO_FUENTES WHERE COMPANIA =:COMPANIA AND TIPO =:TIPO AND NUMERO =:NUMERO AND ID_PLAN =:ID_PLAN AND VIGENCIA_META = :ANO ) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO_FUENTE IS NULL THEN ' ' ELSE UPPER(CODIGO_FUENTE) END) LIKE UPPER(CONCAT(:CODIGO_FUENTE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO_FUENTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
