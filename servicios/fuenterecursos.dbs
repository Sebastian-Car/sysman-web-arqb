	<query id="getFuenterecursosFuenterecursosequivalentesiganoQuery"  useConfig="sysmandsunist">
		<sql>SELECT FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND FUENTE_RECURSOS.ANO = :ANO ORDER BY CODIGO ASC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
