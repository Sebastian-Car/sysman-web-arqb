	</resource>
	<query id="getFuenterecursosTodosPorAnoactualQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE  FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND FUENTE_RECURSOS.ANO = TO_CHAR(SYSDATE, 'YYYY') ORDER BY FUENTE_RECURSOS.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuenterecursos/todosporanoactual">
		<call-query href="getFuenterecursosTodosPorAnoactualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosPagAnoynombreporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ANO, CODIGO, NOMBRE  FROM FUENTE_RECURSOS WHERE COMPANIA = :COMPANIA ORDER BY CODIGO , ANO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
