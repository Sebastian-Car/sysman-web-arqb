	<query id="getFuenterecursosTodosporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT FUENTE_RECURSOS.ANO  FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA =:COMPANIA ORDER BY FUENTE_RECURSOS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

