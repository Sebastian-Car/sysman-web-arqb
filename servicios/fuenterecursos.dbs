	<query id="updateFuenterecursosGetfuenterecursocuipo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FUENTE_RECURSOS SET CODIGOEQUIVALENTE=:CODIGOEQUIVALENTE, IND_SINSITUACIONFONDOS=:IND_SINSITUACIONFONDOS, EQUIVALENTEAPROPIACION=:EQUIVALENTEAPROPIACION, EQUIVALENTECAJA=:EQUIVALENTECAJA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FUENTE_RECURSOS.COMPANIA= :KEY_COMPANIA AND FUENTE_RECURSOS.ANO= :KEY_ANO AND FUENTE_RECURSOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOEQUIVALENTE" sqlType="STRING"/>
		<param name="IND_SINSITUACIONFONDOS" sqlType="STRING"/>
		<param name="EQUIVALENTEAPROPIACION" sqlType="STRING"/>
		<param name="EQUIVALENTECAJA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="fuenterecursos/getfuenterecursocuipo">
		<call-query href="updateFuenterecursosGetfuenterecursocuipo">
			<with-param name="CODIGOEQUIVALENTE" query-param="CODIGOEQUIVALENTE"/>
			<with-param name="IND_SINSITUACIONFONDOS" query-param="IND_SINSITUACIONFONDOS"/>
			<with-param name="EQUIVALENTEAPROPIACION" query-param="EQUIVALENTEAPROPIACION"/>
