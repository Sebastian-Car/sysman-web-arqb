	<query id="getFuenterecursosPagConfiguracionFuentesFutQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.CODIGO_FUT, FUENTE_RECURSOS.CODIGO_FUTCF  FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA =:COMPANIA AND FUENTE_RECURSOS.ANO = :ANO ORDER BY FUENTE_RECURSOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER( '%' || :CODIGO_FUT || '%')  AND (CASE WHEN CODIGO_FUTCF IS NULL THEN ' ' ELSE UPPER(CODIGO_FUTCF) END)  LIKE UPPER( '%' || :CODIGO_FUTCF || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGO_FUT":"$CODIGO_FUT","CODIGO_FUTCF":"$CODIGO_FUTCF"}]}}		</result>
