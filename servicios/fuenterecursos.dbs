	<query id="getFuenterecursosNumConfiguracionFutQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.CODIGO_FUT_F3,(CASE FUENTE_RECURSOS.REPORTAENREGISTROS WHEN 0 THEN 'false' ELSE 'true' END) REPORTAENREGISTROS FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND FUENTE_RECURSOS.ANO = :ANO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO_FUT_F3 IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT_F3) END)  LIKE UPPER(:CODIGO_FUT_F3 || '%')  AND (CASE WHEN REPORTAENREGISTROS IS NULL THEN ' ' ELSE UPPER(REPORTAENREGISTROS) END)  LIKE UPPER(:REPORTAENREGISTROS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_FUT_F3" sqlType="STRING"/>
		<param name="REPORTAENREGISTROS" sqlType="STRING"/>

	</query>
