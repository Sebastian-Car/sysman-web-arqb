	<query id="getFuenterecursosPagOrigentipofuenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, CODIGO, NOMBRE, TIPO_RECURSO, CASE TIPO_RECURSO WHEN 'RP' THEN 'Recursos Propios' WHEN 'SGP' THEN 'SGP' WHEN 'CN' THEN 'Cofinanciacion Nacion' WHEN 'CD' THEN 'Cofinanciacion Departamento' WHEN 'SGR' THEN 'SGR' WHEN 'CR' THEN 'Creditos' WHEN 'REL' THEN 'Regalias' WHEN 'COMP' THEN 'Compensaciones' WHEN 'OT' THEN 'Otros' END TIPO_RECURSOLB, ANO NUMERO  FROM FUENTE_RECURSOS WHERE COMPANIA = :COMPANIA ORDER BY ANO, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_RECURSOLB IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSOLB) END)  LIKE UPPER( '%' || :TIPO_RECURSOLB || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO_RECURSO":"$TIPO_RECURSO","TIPO_RECURSOLB":"$TIPO_RECURSOLB","NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_RECURSOLB" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuenterecursos/origentipofuente/pag">
		<call-query href="getFuenterecursosPagOrigentipofuenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_RECURSOLB" query-param="TIPO_RECURSOLB"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosNumOrigentipofuenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO, CODIGO, NOMBRE, TIPO_RECURSO, CASE TIPO_RECURSO WHEN 'RP' THEN 'Recursos Propios' WHEN 'SGP' THEN 'SGP' WHEN 'CN' THEN 'Cofinanciacion Nacion' WHEN 'CD' THEN 'Cofinanciacion Departamento' WHEN 'SGR' THEN 'SGR' WHEN 'CR' THEN 'Creditos' WHEN 'REL' THEN 'Regalias' WHEN 'COMP' THEN 'Compensaciones' WHEN 'OT' THEN 'Otros' END TIPO_RECURSOLB, ANO NUMERO  FROM FUENTE_RECURSOS WHERE COMPANIA = :COMPANIA ORDER BY ANO, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_RECURSOLB IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSOLB) END)  LIKE UPPER( '%' || :TIPO_RECURSOLB || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_RECURSOLB" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuenterecursos/origentipofuente/num">
		<call-query href="getFuenterecursosNumOrigentipofuenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_RECURSOLB" query-param="TIPO_RECURSOLB"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="insertFuenterecursosInserttipofuente" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FUENTE_RECURSOS (COMPANIA, ANO, CODIGO, NOMBRE, TIPO_RECURSO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :TIPO_RECURSO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_RECURSO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="fuenterecursos/inserttipofuente">
		<call-query href="insertFuenterecursosInserttipofuente">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_RECURSO" query-param="TIPO_RECURSO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateFuenterecursosUpdatetipofuente" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FUENTE_RECURSOS SET COMPANIA=:COMPANIA, ANO=:ANO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, TIPO_RECURSO=:TIPO_RECURSO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FUENTE_RECURSOS.COMPANIA= :KEY_COMPANIA AND FUENTE_RECURSOS.ANO= :KEY_ANO AND FUENTE_RECURSOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_RECURSO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="fuenterecursos/updatetipofuente">
		<call-query href="updateFuenterecursosUpdatetipofuente">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_RECURSO" query-param="TIPO_RECURSO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="deleteFuenterecursosDeletetipofuente" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA= :KEY_COMPANIA AND FUENTE_RECURSOS.ANO       = :KEY_ANO AND FUENTE_RECURSOS.CODIGO    = :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
