	<query id="getFuenterecursosPagGetlistacodigoequivalenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CUIPO_FUENTES.CODIGO, CUIPO_FUENTES.NOMBRE, CUIPO_FUENTES.CODIGO_EQUIVALENTE FROM ANO LEFT JOIN CUIPO_FUENTES ON ANO.COMPANIA = CUIPO_FUENTES.COMPANIA AND ANO.NUMERO = CUIPO_FUENTES.ANO WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO = :ANO AND ANO.MODELO = 2 UNION ALL SELECT TC.CODIGO,TC.NOMBRE, EQUIVALENTE FROM ANO LEFT JOIN TIPOCLASIFICADOR TC ON ANO.COMPANIA = TC.COMPANIA AND ANO.NUMERO = TC.ANO WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO = :ANO AND TC.CLASECLASIFICADOR = '009' ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGO_EQUIVALENTE IS NULL THEN ' ' ELSE UPPER(CODIGO_EQUIVALENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_EQUIVALENTE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGO_EQUIVALENTE":"$CODIGO_EQUIVALENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_EQUIVALENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
