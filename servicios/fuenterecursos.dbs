	<query id="getFuenterecursosPagConplanpptalporcuentaanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.TIPO  FROM FUENTE_RECURSOS INNER JOIN V_PLAN_PRESUPUESTAL ON FUENTE_RECURSOS.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND FUENTE_RECURSOS.CODIGO = V_PLAN_PRESUPUESTAL.FUENTE_RECURSO AND FUENTE_RECURSOS.ANO = V_PLAN_PRESUPUESTAL.ANO WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.CODIGO = :CODCUENTA AND V_PLAN_PRESUPUESTAL.ANO = :ANIO GROUP BY FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.TIPO ORDER BY FUENTE_RECURSOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
