	<query id="getFuenterecursosNumFuentePptalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.TIPO, TIPO_FUENTERECURSOS.NOMBRE NOMBRETIPO, FUENTE_RECURSOS.CODIGO_DNP , FUENTE_RECURSOS.CODIGO_SIA , FUENTE_RECURSOS.TIPO_FUENTE_POAI, TIPO_FUENTE_POAI.NOMBRE NOMBREPOAI,(CASE FUENTE_RECURSOS.IND_SINSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) IND_SINSITUACIONFONDOS, FUENTE_RECURSOS.EQUIVALENTECUIPO, FUENTE_RECURSOS.EQUIVALENTEAPROPIACION, FUENTE_RECURSOS.EQUIVALENTECAJA, FUENTE_RECURSOS.CODIGO_CLEOPATRA FROM FUENTE_RECURSOS LEFT JOIN TIPO_FUENTERECURSOS ON FUENTE_RECURSOS.TIPO = TIPO_FUENTERECURSOS.CODIGO LEFT JOIN TIPO_FUENTE_POAI ON FUENTE_RECURSOS.TIPO_FUENTE_POAI = TIPO_FUENTE_POAI.CODIGO WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND FUENTE_RECURSOS.ANO = :ANOFUENTE ORDER BY FUENTE_RECURSOS.CODIGO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END) LIKE UPPER(CONCAT(:NOMBRETIPO, '%')) AND (CASE WHEN CODIGO_DNP IS NULL THEN ' ' ELSE UPPER(CODIGO_DNP) END) LIKE UPPER(CONCAT(:CODIGO_DNP, '%')) AND (CASE WHEN CODIGO_SIA IS NULL THEN ' ' ELSE UPPER(CODIGO_SIA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_SIA), '%')) AND (CASE WHEN NOMBREPOAI IS NULL THEN ' ' ELSE UPPER(NOMBREPOAI) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPOAI), '%')) AND (CASE WHEN IND_SINSITUACIONFONDOS IS NULL THEN ' ' ELSE UPPER(IND_SINSITUACIONFONDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:IND_SINSITUACIONFONDOS), '%')) AND (CASE WHEN EQUIVALENTECUIPO IS NULL THEN ' ' ELSE UPPER(EQUIVALENTECUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTECUIPO), '%')) AND (CASE WHEN EQUIVALENTEAPROPIACION IS NULL THEN ' ' ELSE UPPER(EQUIVALENTEAPROPIACION) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTEAPROPIACION), '%')) AND (CASE WHEN EQUIVALENTECAJA IS NULL THEN ' ' ELSE UPPER(EQUIVALENTECAJA) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTECAJA), '%')) AND (CASE WHEN CODIGO_CLEOPATRA IS NULL THEN ' ' ELSE UPPER(CODIGO_CLEOPATRA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CLEOPATRA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOFUENTE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="CODIGO_DNP" sqlType="STRING"/>
		<param name="CODIGO_SIA" sqlType="STRING"/>
		<param name="NOMBREPOAI" sqlType="STRING"/>
		<param name="IND_SINSITUACIONFONDOS" sqlType="STRING"/>
		<param name="EQUIVALENTECUIPO" sqlType="STRING"/>
		<param name="EQUIVALENTEAPROPIACION" sqlType="STRING"/>
		<param name="EQUIVALENTECAJA" sqlType="STRING"/>
		<param name="CODIGO_CLEOPATRA" sqlType="STRING"/>

	</query>
