			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD_RUBRO" query-param="COD_RUBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosPagGetfuenterecursocuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA,ANO,CODIGO,NOMBRE,CODIGOEQUIVALENTE,(CASE IND_SINSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) IND_SINSITUACIONFONDOS, EQUIVALENTEAPROPIACION, EQUIVALENTECAJA FROM FUENTE_RECURSOS WHERE COMPANIA = :KEY_COMPANIA AND ANO = :ANIO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGOEQUIVALENTE IS NULL THEN ' ' ELSE UPPER(CODIGOEQUIVALENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOEQUIVALENTE), '%')) AND (CASE WHEN IND_SINSITUACIONFONDOS IS NULL THEN ' ' ELSE UPPER(IND_SINSITUACIONFONDOS) END) LIKE UPPER(CONCAT(:IND_SINSITUACIONFONDOS, '%')) AND (CASE WHEN EQUIVALENTEAPROPIACION IS NULL THEN ' ' ELSE UPPER(EQUIVALENTEAPROPIACION) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTEAPROPIACION), '%')) AND (CASE WHEN EQUIVALENTECAJA IS NULL THEN ' ' ELSE UPPER(EQUIVALENTECAJA) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTECAJA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGOEQUIVALENTE":"$CODIGOEQUIVALENTE","IND_SINSITUACIONFONDOS":"$IND_SINSITUACIONFONDOS(type:boolean)","EQUIVALENTEAPROPIACION":"$EQUIVALENTEAPROPIACION","EQUIVALENTECAJA":"$EQUIVALENTECAJA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOEQUIVALENTE" sqlType="STRING"/>
		<param name="IND_SINSITUACIONFONDOS" sqlType="STRING"/>
		<param name="EQUIVALENTEAPROPIACION" sqlType="STRING"/>
		<param name="EQUIVALENTECAJA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
