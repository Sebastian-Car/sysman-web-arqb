	</resource>
	<query id="getFuenterecursosNumGetfuenteplanpptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT FUENTE_RECURSOS.CODIGO CODIGO, CONCAT(CONCAT(FUENTE_RECURSOS.CODIGO , '-') , FUENTE_RECURSOS.NOMBRE) NOMBRE FROM V_PLAN_PRESUPUESTAL LEFT JOIN FUENTE_RECURSOS ON V_PLAN_PRESUPUESTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = FUENTE_RECURSOS.ANO AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO = :COD_RUBRO ORDER BY FUENTE_RECURSOS.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuenterecursos/getfuenteplanpptal/num">
		<call-query href="getFuenterecursosNumGetfuenteplanpptalQuery">
