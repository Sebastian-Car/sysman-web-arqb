	<query id="getFuenterecursosPagFuentesDePlanIndQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO CODIGO_FUENTE, NOMBRE FROM FUENTE_RECURSOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO NOT IN ( SELECT FUENTE FROM PI_PLAN_INDICATIVO_FUENTES WHERE COMPANIA =:COMPANIA AND TIPO =:TIPO AND NUMERO =:NUMERO AND ID_PLAN =:ID_PLAN AND VIGENCIA_META = :ANO ) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO_FUENTE IS NULL THEN ' ' ELSE UPPER(CODIGO_FUENTE) END) LIKE UPPER(CONCAT(:CODIGO_FUENTE, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_FUENTE":"$CODIGO_FUENTE","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO_FUENTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuenterecursos/fuentesdeplanind/pag">
