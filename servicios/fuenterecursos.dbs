	<query id="getFuenterecursosPagGetfuenteplanpptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT FUENTE_RECURSOS.CODIGO CODIGO, CONCAT(CONCAT(FUENTE_RECURSOS.CODIGO , '-') , FUENTE_RECURSOS.NOMBRE) NOMBRE FROM V_PLAN_PRESUPUESTAL LEFT JOIN FUENTE_RECURSOS ON V_PLAN_PRESUPUESTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = FUENTE_RECURSOS.ANO AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO = :COD_RUBRO ORDER BY FUENTE_RECURSOS.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD_RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
