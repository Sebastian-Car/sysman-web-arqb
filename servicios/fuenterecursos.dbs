	</resource>
	<query id="updateFuenterecursosUpdatetiporecursoano" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FUENTE_RECURSOS SET TIPO_RECURSO = (   CASE     WHEN TIPO = 'P'     THEN 'RP'     WHEN TIPO = 'RC'     THEN 'CR'     WHEN TIPO IN('RN','ICN')     THEN 'CN'     WHEN TIPO = 'RD'     THEN 'CD'     WHEN TIPO = 'SG'     THEN 'SGP'     WHEN TIPO = 'R'     THEN 'SGR'     WHEN TIPO IS NULL     THEN NULL     ELSE 'OT'   END),   DATE_MODIFIED = SYSDATE,   MODIFIED_BY = :USUARIO WHERE COMPANIA = :COMPANIA AND ANO        =:ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="fuenterecursos/updatetiporecursoano">
		<call-query href="updateFuenterecursosUpdatetiporecursoano">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosPagTipoFuenteRecursoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.TIPO_RECURSO, BP_TIPORECURSOS.NOMBRE TIPO_RECURSOLB, ANO NUMERO  FROM FUENTE_RECURSOS LEFT JOIN BP_TIPORECURSOS ON FUENTE_RECURSOS.COMPANIA = BP_TIPORECURSOS.COMPANIA AND FUENTE_RECURSOS.TIPO_RECURSO= BP_TIPORECURSOS.CODIGO WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA ORDER BY FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_RECURSOLB IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSOLB) END)  LIKE UPPER( '%' || :TIPO_RECURSOLB || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO_RECURSO":"$TIPO_RECURSO","TIPO_RECURSOLB":"$TIPO_RECURSOLB","NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_RECURSOLB" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuenterecursos/tipofuenterecurso/pag">
		<call-query href="getFuenterecursosPagTipoFuenteRecursoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO_RECURSOLB" query-param="TIPO_RECURSOLB"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosNumTipoFuenteRecursoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.TIPO_RECURSO, BP_TIPORECURSOS.NOMBRE TIPO_RECURSOLB, ANO NUMERO  FROM FUENTE_RECURSOS LEFT JOIN BP_TIPORECURSOS ON FUENTE_RECURSOS.COMPANIA = BP_TIPORECURSOS.COMPANIA AND FUENTE_RECURSOS.TIPO_RECURSO= BP_TIPORECURSOS.CODIGO WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA ORDER BY FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPO_RECURSOLB IS NULL THEN ' ' ELSE UPPER(TIPO_RECURSOLB) END)  LIKE UPPER( '%' || :TIPO_RECURSOLB || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO_RECURSOLB" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuenterecursos/tipofuenterecurso/num">
