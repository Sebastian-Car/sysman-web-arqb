	<query id="insertFuenterecursosAnioDestino" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FUENTE_RECURSOS   (     COMPANIA,     CODIGO,     ANO,     NOMBRE,     TIPO,     CODIGO_FUT,     CODIGO_FUTCF,     CREATED_BY,     DATE_CREATED   ) SELECT COMPANIA,   CODIGO,   TO_NUMBER(:ANODESTINO) ANO,   NOMBRE,   TIPO,   CODIGO_FUT,   CODIGO_FUTCF,   CREATED_BY,   DATE_CREATED FROM FUENTE_RECURSOS WHERE COMPANIA  =:COMPANIA AND ANO         = :ANO AND CODIGO NOT IN   (SELECT CODIGO   FROM FUENTE_RECURSOS   WHERE COMPANIA = :COMPANIA   AND ANO        = :ANODESTINO   )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANODESTINO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="fuenterecursos/aniodestino">
		<call-query href="insertFuenterecursosAnioDestino">
			<with-param name="ANODESTINO" query-param="ANODESTINO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updateFuenterecursosAnioRecursosFuentesFut" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FUENTE_RECURSOS SET ANO        = :ANO - 1 WHERE COMPANIA = :COMPANIA AND ANO        = 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="fuenterecursos/aniorecursosfuentesfut">
		<call-query href="updateFuenterecursosAnioRecursosFuentesFut">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosPagConfiguracionFutQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.CODIGO_FUT_F3,(CASE FUENTE_RECURSOS.REPORTAENREGISTROS WHEN 0 THEN 'false' ELSE 'true' END) REPORTAENREGISTROS FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND FUENTE_RECURSOS.ANO = :ANO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO_FUT_F3 IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT_F3) END)  LIKE UPPER(:CODIGO_FUT_F3 || '%')  AND (CASE WHEN REPORTAENREGISTROS IS NULL THEN ' ' ELSE UPPER(REPORTAENREGISTROS) END)  LIKE UPPER(:REPORTAENREGISTROS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGO_FUT_F3":"$CODIGO_FUT_F3","REPORTAENREGISTROS":"$REPORTAENREGISTROS(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_FUT_F3" sqlType="STRING"/>
		<param name="REPORTAENREGISTROS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
