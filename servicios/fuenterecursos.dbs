	<query id="getFuenterecursosPagGetfuenteporcompaniarubroanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO CODIGO, FUENTE_RECURSOS.NOMBRE NOMBRE FROM DETALLE_COMPROBANTE_PPTAL LEFT JOIN FUENTE_RECURSOS ON FUENTE_RECURSOS .COMPANIA = DETALLE_COMPROBANTE_PPTAL.compania AND FUENTE_RECURSOS .ANO = DETALLE_COMPROBANTE_PPTAL.ano AND FUENTE_RECURSOS .CODIGO = DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO WHERE DETALLE_COMPROBANTE_PPTAL.compania = :COMPANIA and DETALLE_COMPROBANTE_PPTAL.ano = :ANO and DETALLE_COMPROBANTE_PPTAL.cuenta = :RUBRO group by FUENTE_RECURSOS .NOMBRE, DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
