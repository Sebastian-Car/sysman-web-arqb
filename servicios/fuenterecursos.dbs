			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertFuenterecursos" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FUENTE_RECURSOS (COMPANIA, ANO, CODIGO, NOMBRE, TIPO, PAIS, CODIGO_SIA, EQUIVALENTECUIPO, EQUIVALENTE_SIG_VIG, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :TIPO, :PAIS, :CODIGO_SIA, :EQUIVALENTECUIPO, :EQUIVALENTE_SIG_VIG, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="PAIS" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_SIA" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVALENTECUIPO" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVALENTE_SIG_VIG" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="fuenterecursos">
		<call-query href="insertFuenterecursos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO_SIA" query-param="CODIGO_SIA"/>
			<with-param name="EQUIVALENTECUIPO" query-param="EQUIVALENTECUIPO"/>
			<with-param name="EQUIVALENTE_SIG_VIG" query-param="EQUIVALENTE_SIG_VIG"/>			
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteFuenterecursos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FUENTE_RECURSOS WHERE FUENTE_RECURSOS.COMPANIA= :KEY_COMPANIA AND FUENTE_RECURSOS.ANO= :KEY_ANO AND FUENTE_RECURSOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="fuenterecursos">
		<call-query href="deleteFuenterecursos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.TIPO, CASE FUENTE_RECURSOS.TIPO WHEN 'P' THEN 'Propios' WHEN 'N' THEN 'Nación' WHEN 'D' THEN 'Departamental' WHEN 'O' THEN 'Otros' END TIPOD, FUENTE_RECURSOS.PAIS, PAISES.NOMBRE NOMBREPAIS, FUENTE_RECURSOS.CODIGO_SIA, FUENTE_RECURSOS.EQUIVALENTECUIPO,FUENTE_RECURSOS.EQUIVALENTE_SIG_VIG FROM FUENTE_RECURSOS LEFT JOIN PAISES ON FUENTE_RECURSOS.PAIS = PAISES.PAIS WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND FUENTE_RECURSOS.ANO NOT IN (0) ORDER BY FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPOD IS NULL THEN ' ' ELSE UPPER(TIPOD) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOD), '%')) AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPAIS), '%')) AND (CASE WHEN CODIGO_SIA IS NULL THEN ' ' ELSE UPPER(CODIGO_SIA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_SIA), '%')) AND (CASE WHEN EQUIVALENTECUIPO IS NULL THEN ' ' ELSE UPPER(EQUIVALENTECUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTECUIPO), '%')) AND (CASE WHEN EQUIVALENTE_SIG_VIG IS NULL THEN ' ' ELSE UPPER(EQUIVALENTE_SIG_VIG) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTE_SIG_VIG), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO":"$TIPO","TIPOD":"$TIPOD","PAIS":"$PAIS","NOMBREPAIS":"$NOMBREPAIS","CODIGO_SIA":"$CODIGO_SIA","EQUIVALENTECUIPO":"$EQUIVALENTECUIPO","EQUIVALENTE_SIG_VIG":"$EQUIVALENTE_SIG_VIG"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPOD" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="CODIGO_SIA" sqlType="STRING"/>
		<param name="EQUIVALENTECUIPO" sqlType="STRING"/>
		<param name="EQUIVALENTE_SIG_VIG" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuenterecursos">
		<call-query href="getFuenterecursosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPOD" query-param="TIPOD"/>
			<with-param name="NOMBREPAIS" query-param="NOMBREPAIS"/>
			<with-param name="CODIGO_SIA" query-param="CODIGO_SIA"/>
			<with-param name="EQUIVALENTECUIPO" query-param="EQUIVALENTECUIPO"/>
			<with-param name="EQUIVALENTE_SIG_VIG" query-param="EQUIVALENTE_SIG_VIG"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuenterecursosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT FUENTE_RECURSOS.COMPANIA, FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO, FUENTE_RECURSOS.NOMBRE, FUENTE_RECURSOS.TIPO, CASE FUENTE_RECURSOS.TIPO WHEN 'P' THEN 'Propios' WHEN 'N' THEN 'Nación' WHEN 'D' THEN 'Departamental' WHEN 'O' THEN 'Otros' END TIPOD, FUENTE_RECURSOS.PAIS, PAISES.NOMBRE NOMBREPAIS, FUENTE_RECURSOS.CODIGO_SIA, FUENTE_RECURSOS.EQUIVALENTECUIPO,FUENTE_RECURSOS.EQUIVALENTE_SIG_VIG FROM FUENTE_RECURSOS LEFT JOIN PAISES ON FUENTE_RECURSOS.PAIS = PAISES.PAIS WHERE FUENTE_RECURSOS.COMPANIA = :COMPANIA AND FUENTE_RECURSOS.ANO NOT IN (0) ORDER BY FUENTE_RECURSOS.ANO, FUENTE_RECURSOS.CODIGO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPOD IS NULL THEN ' ' ELSE UPPER(TIPOD) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOD), '%')) AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPAIS), '%')) AND (CASE WHEN CODIGO_SIA IS NULL THEN ' ' ELSE UPPER(CODIGO_SIA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_SIA), '%')) AND (CASE WHEN EQUIVALENTECUIPO IS NULL THEN ' ' ELSE UPPER(EQUIVALENTECUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTECUIPO), '%')) AND (CASE WHEN EQUIVALENTE_SIG_VIG IS NULL THEN ' ' ELSE UPPER(EQUIVALENTE_SIG_VIG) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTE_SIG_VIG), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPOD" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="CODIGO_SIA" sqlType="STRING"/>
		<param name="EQUIVALENTECUIPO" sqlType="STRING"/>
		<param name="EQUIVALENTE_SIG_VIG" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuenterecursos/numero">
		<call-query href="getFuenterecursosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
