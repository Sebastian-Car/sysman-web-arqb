<data name="sftasasinteres" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSftasasinteres" keyColumns="COMPANIA,ANO,TIPOCOBRO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_TASAS_INTERES (COMPANIA, ANO, TIPOCOBRO, FECHA_INICIAL, FECHA_FINAL, TASAINTERES, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ANO, :TIPOCOBRO, TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), :TASAINTERES, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_FECHA_INICIAL":"$FECHA_INICIAL","KEY_FECHA_FINAL":"$FECHA_FINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="TASAINTERES" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sftasasinteres">
		<call-query href="insertSftasasinteres">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASAINTERES" query-param="TASAINTERES"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteSftasasinteres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_TASAS_INTERES WHERE SF_TASAS_INTERES.COMPANIA= :KEY_COMPANIA AND SF_TASAS_INTERES.ANO= :KEY_ANO AND SF_TASAS_INTERES.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_TASAS_INTERES.FECHA_INICIAL= TO_DATE(:KEY_FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS') AND SF_TASAS_INTERES.FECHA_FINAL= TO_DATE(:KEY_FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_FECHA_INICIAL" sqlType="STRING"/>
		<param name="KEY_FECHA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sftasasinteres">
		<call-query href="deleteSftasasinteres">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_FECHA_INICIAL" query-param="KEY_FECHA_INICIAL"/>
			<with-param name="KEY_FECHA_FINAL" query-param="KEY_FECHA_FINAL"/>

		</call-query>
	</resource>
	<query id="getSftasasinteresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, TIPOCOBRO,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, TASAINTERES FROM SF_TASAS_INTERES WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPOCOBRO = :TIPOCOBRO) INI WHERE (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIAL), '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINAL), '%')) AND (CASE WHEN TASAINTERES IS NULL THEN ' ' ELSE UPPER(TASAINTERES) END) LIKE UPPER(CONCAT(:TASAINTERES, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","TASAINTERES":"$TASAINTERES(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="TASAINTERES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftasasinteres">
		<call-query href="getSftasasinteresPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASAINTERES" query-param="TASAINTERES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftasasinteresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, TIPOCOBRO,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, TASAINTERES FROM SF_TASAS_INTERES WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPOCOBRO = :TIPOCOBRO) INI WHERE (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIAL), '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINAL), '%')) AND (CASE WHEN TASAINTERES IS NULL THEN ' ' ELSE UPPER(TASAINTERES) END) LIKE UPPER(CONCAT(:TASAINTERES, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="TASAINTERES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftasasinteres/numero">
		<call-query href="getSftasasinteresNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASAINTERES" query-param="TASAINTERES"/>

		</call-query>
	</resource>
	<query id="updateSftasasinteres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_TASAS_INTERES SET ANO=:ANO, TIPOCOBRO=:TIPOCOBRO, FECHA_INICIAL=TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TASAINTERES=:TASAINTERES, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SF_TASAS_INTERES.COMPANIA= :KEY_COMPANIA AND SF_TASAS_INTERES.ANO= :KEY_ANO AND SF_TASAS_INTERES.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_TASAS_INTERES.FECHA_INICIAL= TO_DATE(:KEY_FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS') AND SF_TASAS_INTERES.FECHA_FINAL= TO_DATE(:KEY_FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="TASAINTERES" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_FECHA_INICIAL" sqlType="STRING"/>
		<param name="KEY_FECHA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sftasasinteres">
		<call-query href="updateSftasasinteres">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASAINTERES" query-param="TASAINTERES"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_FECHA_INICIAL" query-param="KEY_FECHA_INICIAL"/>
			<with-param name="KEY_FECHA_FINAL" query-param="KEY_FECHA_FINAL"/>

		</call-query>
	</resource>

</data>