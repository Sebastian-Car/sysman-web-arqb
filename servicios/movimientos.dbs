	<query id="updateMovimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE MOVIMIENTO SET NUMERO=:NUMERO, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, PORCIVAGLOBAL=:PORCIVAGLOBAL, TIPOMOVASOCIADO=:TIPOMOVASOCIADO, MOVASOCIADO=:MOVASOCIADO, FECHAMOVASOCIADO=TO_DATE(:FECHAMOVASOCIADO,'DD/MM/YYYY HH24:MI:SS'), VALORIVA=:VALORIVA, VALORDESCUENTO=:VALORDESCUENTO, VALORTOTAL=:VALORTOTAL, VACIA=:VACIA, CENTRODECOSTO=:CENTRODECOSTO, REMISIONNO=:REMISIONNO, FACTURANO=:FACTURANO, VALORDOCASOCIADO=:VALORDOCASOCIADO, AJUSTECENTAVOS=:AJUSTECENTAVOS, AJUSTECENTAVOS1=:AJUSTECENTAVOS1, REGISTRADO=:REGISTRADO, IMPRESO=:IMPRESO, GENERADO=:GENERADO, AUXILIAR=:AUXILIAR, PROVEEDORCA=:PROVEEDORCA, SUCURSALCA=:SUCURSALCA, VALORTOTALCONIVA=:VALORTOTALCONIVA, TOTALCONAJUSTE=:TOTALCONAJUSTE, FINICIO_CONTRATO=TO_DATE(:FINICIO_CONTRATO,'DD/MM/YYYY HH24:MI:SS'), FFINAL_CONTRATO=TO_DATE(:FFINAL_CONTRATO,'DD/MM/YYYY HH24:MI:SS'), AJUSTE_DEC_MANUAL=:AJUSTE_DEC_MANUAL, RESPONSABLE_ORIGEN=:RESPONSABLE_ORIGEN, RESPONSABLE_DESTINO=:RESPONSABLE_DESTINO, SUCURSAL_RESDESTINO=:SUCURSAL_RESDESTINO, SUCURSAL_RESORIGEN=:SUCURSAL_RESORIGEN, BODEGA_DESTINO=:BODEGA_DESTINO, BODEGA_ORIGEN=:BODEGA_ORIGEN, CLASE_BODEGA_DESTINO=:CLASE_BODEGA_DESTINO, CLASE_BODEGA_ORIGEN=:CLASE_BODEGA_ORIGEN, DEPENDENCIA_ORIGEN=:DEPENDENCIA_ORIGEN, DEPENDENCIA_DESTINO=:DEPENDENCIA_DESTINO, SUCURSAL_RECIBIDO=:SUCURSAL_RECIBIDO, NIT_RECIBIDO=:NIT_RECIBIDO, VLRUNITARIO_SINIVA=:VLRUNITARIO_SINIVA, FUENTEDERECURSO=:FUENTEDERECURSO, REFERENCIA=:REFERENCIA, ACTA_INSTALACION=:ACTA_INSTALACION, FECHA_INSTALACION=TO_DATE(:FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS'), ORFEO=:ORFEO, CODIGOPROYECTO=:CODIGOPROYECTO, RUEDA=:RUEDA, OPERACION=:OPERACION, AUX_ALMACEN=:AUX_ALMACEN, UBICACION=:UBICACION, UBICACION_ORIGEN=:UBICACION_ORIGEN, UBICACION_DESTINO=:UBICACION_DESTINO, VALORIMPOCONSUMO=:VALORIMPOCONSUMO, AIU=:AIU, ADMINISTRACION=:ADMINISTRACION, IMPREVISTOS=:IMPREVISTOS, UTILIDADES=:UTILIDADES, VALORTOTALAIU=:VALORTOTALAIU, NOMBRE_CONTRATO=:NOMBRE_CONTRATO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE MOVIMIENTO.COMPANIA= :KEY_COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND MOVIMIENTO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

