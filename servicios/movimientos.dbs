	<query id="getMovimientosPagPorConceptoNQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT MOVIMIENTO.TIPOMOVIMIENTO, MOVIMIENTO.NUMERO, TO_CHAR(MOVIMIENTO.FECHA,'DD/MM/YYYY') FECHA, MOVIMIENTO.DESCRIPCION FROM MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE MOVIMIENTO.COMPANIA =:COMPANIA AND MOVIMIENTO.BODEGA_ORIGEN = 20 AND MOVIMIENTO.BODEGA_DESTINO = 30 AND TIPOMOVIMIENTO.CONCEPTO IN ( 'N' ) AND TIPOMOVIMIENTO.TIPOELEMENTO IN ( 'C', 'D' ) AND (CONCAT( MOVIMIENTO.COMPANIA ,CONCAT( MOVIMIENTO.TIPOMOVIMIENTO , MOVIMIENTO.NUMERO)) ) NOT IN ( SELECT (CONCAT( COMPANIA ,CONCAT(TIPOMOVIMIENTO ,NUM_MOVIMIENTO) )) CODIGO FROM MANTENIMIENTO_MOV_ASOCIADO )) INI WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="movimientos/porconcepton/pag">
		<call-query href="getMovimientosPagPorConceptoNQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMovimientosNumPorConceptoNQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT MOVIMIENTO.TIPOMOVIMIENTO, MOVIMIENTO.NUMERO, TO_CHAR(MOVIMIENTO.FECHA,'DD/MM/YYYY') FECHA, MOVIMIENTO.DESCRIPCION FROM MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE MOVIMIENTO.COMPANIA =:COMPANIA AND MOVIMIENTO.BODEGA_ORIGEN = 20 AND MOVIMIENTO.BODEGA_DESTINO = 30 AND TIPOMOVIMIENTO.CONCEPTO IN ( 'N' ) AND TIPOMOVIMIENTO.TIPOELEMENTO IN ( 'C', 'D' ) AND (CONCAT( MOVIMIENTO.COMPANIA ,CONCAT( MOVIMIENTO.TIPOMOVIMIENTO , MOVIMIENTO.NUMERO)) ) NOT IN ( SELECT (CONCAT( COMPANIA ,CONCAT(TIPOMOVIMIENTO ,NUM_MOVIMIENTO) )) CODIGO FROM MANTENIMIENTO_MOV_ASOCIADO )) INI WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
