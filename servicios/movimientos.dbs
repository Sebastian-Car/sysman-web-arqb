	<query id="getMovimientosPagDescynumeroportipomovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  M.TIPOMOVIMIENTO CLASEDOC, M.NUMERO, TO_CHAR(M.FECHA, 'DD/MM/YYYY') FECHA, SUBSTR(M.DESCRIPCION,1,200) DESCRIPCION, SUM(I.EXISTENCIA) CANTIDAD  FROM MOVIMIENTO M INNER JOIN D_MOVIMIENTO DM ON M.COMPANIA = DM.COMPANIA AND M.TIPOMOVIMIENTO = DM.TIPOMOVIMIENTO AND M.NUMERO = DM.MOVIMIENTO INNER JOIN TIPOMOVIMIENTO T ON M.COMPANIA = T.COMPANIA AND M.TIPOMOVIMIENTO = T.CODIGO INNER JOIN INVENTARIO I ON DM.COMPANIA = I.COMPANIA AND DM.ELEMENTO = I.CODIGOELEMENTO WHERE M.COMPANIA = :COMPANIA AND T.CLASE IN (:CLASE) AND T.TIPOELEMENTO = :TIPOELEMENTO GROUP BY M.TIPOMOVIMIENTO , M.NUMERO, TO_CHAR(M.FECHA, 'DD/MM/YYYY'), M.DESCRIPCION HAVING SUM(I.EXISTENCIA) &gt; 0 ORDER BY NUMERO DESC) WHERE (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END)  LIKE UPPER( '%' || :CLASEDOC || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEDOC":"$CLASEDOC","NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","CANTIDAD":"$CANTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPOELEMENTO" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
