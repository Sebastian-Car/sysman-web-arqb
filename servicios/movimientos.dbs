	<query id="getMovimientosCamposauditarmovQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPOMOVIMIENTO, NUMERO, TERCERO, RESPONSABLE_ORIGEN, RESPONSABLE_DESTINO, TIPOMOVASOCIADO, MOVASOCIADO, CREATED_BY, MODIFIED_BY, DEPENDENCIA_ORIGEN, DEPENDENCIA_DESTINO,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TO_CHAR(FECHAMOVASOCIADO, 'DD/MM/YYYY') FECHAMOVASOCIADO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, TO_CHAR(FFINAL_CONTRATO, 'DD/MM/YYYY') FFINAL_CONTRATO,(TO_CHAR(HORA,'DD/MM/YYYY HH24:MI:SS')) HORA FROM MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND NUMERO = :NUMERO</sql>
