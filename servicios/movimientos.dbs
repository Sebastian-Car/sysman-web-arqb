	<query id="deleteMovimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM MOVIMIENTO WHERE MOVIMIENTO.COMPANIA= :KEY_COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND MOVIMIENTO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="movimientos">
		<call-query href="deleteMovimientos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getMovimientosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, TIPOMOVIMIENTO, NUMERO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHAMOV, DESCRIPCION,(CASE REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO FROM MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPO AND FECHA BETWEEN :FECHA_INICIAL AND :FECHA_FINAL ORDER BY NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN FECHAMOV IS NULL THEN ' ' ELSE UPPER(FECHAMOV) END) LIKE UPPER(CONCAT(:FECHAMOV, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","NUMERO":"$NUMERO","FECHAMOV":"$FECHAMOV","DESCRIPCION":"$DESCRIPCION","REGISTRADO":"$REGISTRADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHAMOV" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="movimientos">
		<call-query href="getMovimientosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHAMOV" query-param="FECHAMOV"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMovimientosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, TIPOMOVIMIENTO, NUMERO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHAMOV, DESCRIPCION,(CASE REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO FROM MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPO AND FECHA BETWEEN :FECHA_INICIAL AND :FECHA_FINAL ORDER BY NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN FECHAMOV IS NULL THEN ' ' ELSE UPPER(FECHAMOV) END) LIKE UPPER(CONCAT(:FECHAMOV, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHAMOV" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
