			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHAMOV" query-param="FECHAMOV"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getMovimientosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT MOVIMIENTO.COMPANIA, TIPOMOVIMIENTO, NUMERO, TERCERO, MOVIMIENTO.SUCURSAL,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DESCRIPCION, PORCIVAGLOBAL, TIPOMOVASOCIADO, MOVASOCIADO,(TO_CHAR(FECHAMOVASOCIADO,'DD/MM/YYYY HH24:MI:SS')) FECHAMOVASOCIADO, VALORIVA, VALORDESCUENTO, MOVIMIENTO.VALORTOTAL,(CASE VACIA WHEN 0 THEN 'false' ELSE 'true' END) VACIA, CENTRODECOSTO, REMISIONNO, FACTURANO, VALORDOCASOCIADO, AJUSTECENTAVOS, AJUSTECENTAVOS1,(CASE REGISTRADO WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADO,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE GENERADO WHEN 0 THEN 'false' ELSE 'true' END) GENERADO, AUXILIAR, PROVEEDORCA, SUCURSALCA, VALORTOTALCONIVA, TOTALCONAJUSTE,(TO_CHAR(FINICIO_CONTRATO,'DD/MM/YYYY HH24:MI:SS')) FINICIO_CONTRATO,(TO_CHAR(FFINAL_CONTRATO,'DD/MM/YYYY HH24:MI:SS')) FFINAL_CONTRATO, AJUSTE_DEC_MANUAL, RESPONSABLE_ORIGEN, RESPONSABLE_DESTINO, SUCURSAL_RESDESTINO, SUCURSAL_RESORIGEN, BODEGA_DESTINO, BODEGA_ORIGEN, CLASE_BODEGA_DESTINO, CLASE_BODEGA_ORIGEN, DEPENDENCIA_ORIGEN, DEPENDENCIA_DESTINO, SUCURSAL_RECIBIDO, NIT_RECIBIDO,(CASE VLRUNITARIO_SINIVA WHEN 0 THEN 'false' ELSE 'true' END) VLRUNITARIO_SINIVA, FUENTEDERECURSO, REFERENCIA, ACTA_INSTALACION,(TO_CHAR(FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_INSTALACION, ORFEO, MOVIMIENTO.CREATED_BY, MOVIMIENTO.MODIFIED_BY,(TO_CHAR(MOVIMIENTO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(MOVIMIENTO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CODIGOPROYECTO, RUEDA, OPERACION, AUX_ALMACEN, PROYECTOS.NOMBREPROYECTO, UBICACION, U.NOMBRE NOMBRE_UBICACION, MOVIMIENTO.UBICACION_ORIGEN, MOVIMIENTO.UBICACION_DESTINO, UO.NOMBRE NOMBRE_UBICACIONORIGEN, UD.NOMBRE NOMBRE_UBICACIONDESTINO, VALORIMPOCONSUMO,(CASE AIU WHEN 0 THEN 'false' ELSE 'true' END) AIU,ADMINISTRACION,IMPREVISTOS,UTILIDADES,VALORTOTALAIU,NOMBRE_CONTRATO FROM MOVIMIENTO LEFT JOIN PROYECTOS ON MOVIMIENTO.COMPANIA = PROYECTOS.COMPANIA AND MOVIMIENTO.CODIGOPROYECTO = PROYECTOS.CODIGO LEFT JOIN UBICACIONES U ON MOVIMIENTO.COMPANIA = U.COMPANIA AND MOVIMIENTO.UBICACION = U.CODIGO LEFT JOIN UBICACIONES UO ON MOVIMIENTO.COMPANIA = UO.COMPANIA AND MOVIMIENTO.UBICACION_ORIGEN = UO.CODIGO LEFT JOIN UBICACIONES UD ON MOVIMIENTO.COMPANIA = UO.COMPANIA AND MOVIMIENTO.UBICACION_DESTINO = UD.CODIGO WHERE MOVIMIENTO.COMPANIA= :KEY_COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND MOVIMIENTO.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","NUMERO":"$NUMERO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","PORCIVAGLOBAL":"$PORCIVAGLOBAL","TIPOMOVASOCIADO":"$TIPOMOVASOCIADO","MOVASOCIADO":"$MOVASOCIADO","FECHAMOVASOCIADO":"$FECHAMOVASOCIADO","VALORIVA":"$VALORIVA","VALORDESCUENTO":"$VALORDESCUENTO","VALORTOTAL":"$VALORTOTAL","VACIA":"$VACIA(type:boolean)","CENTRODECOSTO":"$CENTRODECOSTO","REMISIONNO":"$REMISIONNO","FACTURANO":"$FACTURANO","VALORDOCASOCIADO":"$VALORDOCASOCIADO","AJUSTECENTAVOS":"$AJUSTECENTAVOS","AJUSTECENTAVOS1":"$AJUSTECENTAVOS1","REGISTRADO":"$REGISTRADO(type:boolean)","IMPRESO":"$IMPRESO(type:boolean)","GENERADO":"$GENERADO(type:boolean)","AUXILIAR":"$AUXILIAR","PROVEEDORCA":"$PROVEEDORCA","SUCURSALCA":"$SUCURSALCA","VALORTOTALCONIVA":"$VALORTOTALCONIVA","TOTALCONAJUSTE":"$TOTALCONAJUSTE","FINICIO_CONTRATO":"$FINICIO_CONTRATO","FFINAL_CONTRATO":"$FFINAL_CONTRATO","AJUSTE_DEC_MANUAL":"$AJUSTE_DEC_MANUAL","RESPONSABLE_ORIGEN":"$RESPONSABLE_ORIGEN","RESPONSABLE_DESTINO":"$RESPONSABLE_DESTINO","SUCURSAL_RESDESTINO":"$SUCURSAL_RESDESTINO","SUCURSAL_RESORIGEN":"$SUCURSAL_RESORIGEN","BODEGA_DESTINO":"$BODEGA_DESTINO","BODEGA_ORIGEN":"$BODEGA_ORIGEN","CLASE_BODEGA_DESTINO":"$CLASE_BODEGA_DESTINO","CLASE_BODEGA_ORIGEN":"$CLASE_BODEGA_ORIGEN","DEPENDENCIA_ORIGEN":"$DEPENDENCIA_ORIGEN","DEPENDENCIA_DESTINO":"$DEPENDENCIA_DESTINO","SUCURSAL_RECIBIDO":"$SUCURSAL_RECIBIDO","NIT_RECIBIDO":"$NIT_RECIBIDO","VLRUNITARIO_SINIVA":"$VLRUNITARIO_SINIVA(type:boolean)","FUENTEDERECURSO":"$FUENTEDERECURSO","REFERENCIA":"$REFERENCIA","ACTA_INSTALACION":"$ACTA_INSTALACION","FECHA_INSTALACION":"$FECHA_INSTALACION","ORFEO":"$ORFEO","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","CODIGOPROYECTO":"$CODIGOPROYECTO","RUEDA":"$RUEDA","OPERACION":"$OPERACION","AUX_ALMACEN":"$AUX_ALMACEN","NOMBREPROYECTO":"$NOMBREPROYECTO","UBICACION":"$UBICACION","NOMBRE_UBICACION":"$NOMBRE_UBICACION","UBICACION_ORIGEN":"$UBICACION_ORIGEN","UBICACION_DESTINO":"$UBICACION_DESTINO","NOMBRE_UBICACIONORIGEN":"$NOMBRE_UBICACIONORIGEN","NOMBRE_UBICACIONDESTINO":"$NOMBRE_UBICACIONDESTINO","VALORIMPOCONSUMO":"$VALORIMPOCONSUMO","AIU":"$AIU(type:boolean)","ADMINISTRACION":"$ADMINISTRACION","IMPREVISTOS":"$IMPREVISTOS","UTILIDADES":"$UTILIDADES","VALORTOTALAIU":"$VALORTOTALAIU","NOMBRE_CONTRATO":"$NOMBRE_CONTRATO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/data">
		<call-query href="getMovimientosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
