	<query id="getMovimientosExisteRequisicionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' Existe  FROM MOVIMIENTO INNER JOIN ORDENDECOMPRA ON MOVIMIENTO.COMPANIA = ORDENDECOMPRA.COMPANIA AND MOVIMIENTO.MOVASOCIADO = ORDENDECOMPRA.NUMERO INNER JOIN ORDENDESUMINISTRO ON ORDENDESUMINISTRO.COMPANIA = ORDENDECOMPRA.COMPANIA AND NVL(ORDENDECOMPRA.COD_REQUISICION,0) = ORDENDESUMINISTRO.NUMERO WHERE MOVIMIENTO.REGISTRADO=-1 AND ORDENDESUMINISTRO.NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
