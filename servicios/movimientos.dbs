<data name="movimientos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getMovimientosTodosPorTipoMovQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MOVIMIENTO.NUMERO, MOVIMIENTO.TIPOMOVIMIENTO  FROM MOVIMIENTO WHERE MOVIMIENTO.COMPANIA = :COMPANIA AND MOVIMIENTO.TIPOMOVASOCIADO = :CLASEORDEN AND MOVIMIENTO.MOVASOCIADO = :NUMEROORDEN AND MOVIMIENTO.TERCERO = :TERCERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/todosportipomov">
		<call-query href="getMovimientosTodosPorTipoMovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>
			<with-param name="TERCERO" query-param="TERCERO"/>

		</call-query>
	</resource>
	<query id="getMovimientosPagTodosPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUMERO, DESCRIPCION,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPO ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="movimientos/todosportipo/pag">
		<call-query href="getMovimientosPagTodosPorTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMovimientosNumTodosPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NUMERO, DESCRIPCION,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPO ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/todosportipo/num">
		<call-query href="getMovimientosNumTodosPorTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getMovimientosPagTodosPorTipoDistinctQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT NUMERO, DESCRIPCION, TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS') FECHA FROM MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPO ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="movimientos/todosportipodistinct/pag">
		<call-query href="getMovimientosPagTodosPorTipoDistinctQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMovimientosNumTodosPorTipoDistinctQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT NUMERO, DESCRIPCION, TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS') FECHA FROM MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPO ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/todosportipodistinct/num">
		<call-query href="getMovimientosNumTodosPorTipoDistinctQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getMovimientosPagPorDocAsociadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  :DOCASOCIADO CLASEDOC, T.NUMERO, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, T.DESCRIPCION  FROM MOVIMIENTO T INNER JOIN TIPOMOVIMIENTO C ON T.COMPANIA = C.COMPANIA AND T.TIPOMOVIMIENTO = C.CODIGO WHERE T.COMPANIA = :COMPANIA AND C.CLASE IN (:CLASE) ORDER BY NUMERO DESC) WHERE (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END)  LIKE UPPER(:CLASEDOC || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEDOC":"$CLASEDOC","NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="DOCASOCIADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="movimientos/pordocasociado/pag">
		<call-query href="getMovimientosPagPorDocAsociadoQuery">
			<with-param name="DOCASOCIADO" query-param="DOCASOCIADO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getMovimientosNumPorDocAsociadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  :DOCASOCIADO CLASEDOC, T.NUMERO, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, T.DESCRIPCION  FROM MOVIMIENTO T INNER JOIN TIPOMOVIMIENTO C ON T.COMPANIA = C.COMPANIA AND T.TIPOMOVIMIENTO = C.CODIGO WHERE T.COMPANIA = :COMPANIA AND C.CLASE IN (:CLASE) ORDER BY NUMERO DESC) WHERE (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END)  LIKE UPPER(:CLASEDOC || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="DOCASOCIADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/pordocasociado/num">
		<call-query href="getMovimientosNumPorDocAsociadoQuery">
			<with-param name="DOCASOCIADO" query-param="DOCASOCIADO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getMovimientosTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MOVIMIENTO.TIPOMOVIMIENTO  FROM MOVIMIENTO WHERE MOVIMIENTO.COMPANIA = :COMPANIA GROUP BY MOVIMIENTO.TIPOMOVIMIENTO ORDER BY MOVIMIENTO.TIPOMOVIMIENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOMOVIMIENTO":"$TIPOMOVIMIENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/todosporcompania">
		<call-query href="getMovimientosTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getMovimientosTodosPorTipomovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MOVIMIENTO.NUMERO  FROM MOVIMIENTO WHERE MOVIMIENTO.COMPANIA = :COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO = :MOVIMIENTO ORDER BY MOVIMIENTO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/todosportipomovimiento">
		<call-query href="getMovimientosTodosPorTipomovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="insertMovimientos" keyColumns="COMPANIA,TIPOMOVIMIENTO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO MOVIMIENTO (COMPANIA, TIPOMOVIMIENTO, NUMERO, TERCERO, SUCURSAL, FECHA, DESCRIPCION, PORCIVAGLOBAL, TIPOMOVASOCIADO, MOVASOCIADO, FECHAMOVASOCIADO, VALORIVA, VALORDESCUENTO, VALORTOTAL, VACIA, CENTRODECOSTO, REMISIONNO, FACTURANO, VALORDOCASOCIADO, AJUSTECENTAVOS, AJUSTECENTAVOS1, REGISTRADO, IMPRESO, GENERADO, AUXILIAR, PROVEEDORCA, SUCURSALCA, VALORTOTALCONIVA, TOTALCONAJUSTE, FINICIO_CONTRATO, FFINAL_CONTRATO, AJUSTE_DEC_MANUAL, RESPONSABLE_ORIGEN, RESPONSABLE_DESTINO, SUCURSAL_RESDESTINO, SUCURSAL_RESORIGEN, BODEGA_DESTINO, BODEGA_ORIGEN, CLASE_BODEGA_DESTINO, CLASE_BODEGA_ORIGEN, DEPENDENCIA_ORIGEN, DEPENDENCIA_DESTINO, SUCURSAL_RECIBIDO, NIT_RECIBIDO, VLRUNITARIO_SINIVA, FUENTEDERECURSO, REFERENCIA, ACTA_INSTALACION, FECHA_INSTALACION, ORFEO, CODIGOPROYECTO, RUEDA, OPERACION, AUX_ALMACEN, UBICACION, UBICACION_ORIGEN, UBICACION_DESTINO, AIU, ADMINISTRACION, IMPREVISTOS, UTILIDADES, NOMBRE_CONTRATO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOMOVIMIENTO, :NUMERO, :TERCERO, :SUCURSAL, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, :PORCIVAGLOBAL, :TIPOMOVASOCIADO, :MOVASOCIADO, TO_DATE(:FECHAMOVASOCIADO,'DD/MM/YYYY HH24:MI:SS'), :VALORIVA, :VALORDESCUENTO, :VALORTOTAL, :VACIA, :CENTRODECOSTO, :REMISIONNO, :FACTURANO, :VALORDOCASOCIADO, :AJUSTECENTAVOS, :AJUSTECENTAVOS1, :REGISTRADO, :IMPRESO, :GENERADO, :AUXILIAR, :PROVEEDORCA, :SUCURSALCA, :VALORTOTALCONIVA, :TOTALCONAJUSTE, TO_DATE(:FINICIO_CONTRATO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FFINAL_CONTRATO,'DD/MM/YYYY HH24:MI:SS'), :AJUSTE_DEC_MANUAL, :RESPONSABLE_ORIGEN, :RESPONSABLE_DESTINO, :SUCURSAL_RESDESTINO, :SUCURSAL_RESORIGEN, :BODEGA_DESTINO, :BODEGA_ORIGEN, :CLASE_BODEGA_DESTINO, :CLASE_BODEGA_ORIGEN, :DEPENDENCIA_ORIGEN, :DEPENDENCIA_DESTINO, :SUCURSAL_RECIBIDO, :NIT_RECIBIDO, :VLRUNITARIO_SINIVA, :FUENTEDERECURSO, :REFERENCIA, :ACTA_INSTALACION, TO_DATE(:FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS'), :ORFEO, :CODIGOPROYECTO, :RUEDA, :OPERACION, :AUX_ALMACEN, :UBICACION, :UBICACION_ORIGEN, :UBICACION_DESTINO, :AIU, :ADMINISTRACION, :IMPREVISTOS, :UTILIDADES, :NOMBRE_CONTRATO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","KEY_NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVAGLOBAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPOMOVASOCIADO" sqlType="STRING"/>
		<param defaultValue="0" name="MOVASOCIADO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAMOVASOCIADO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORIVA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORDESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VACIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRODECOSTO" sqlType="STRING"/>
		<param defaultValue="" name="REMISIONNO" sqlType="STRING"/>
		<param defaultValue="" name="FACTURANO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORDOCASOCIADO" sqlType="STRING"/>
		<param defaultValue="0" name="AJUSTECENTAVOS" sqlType="STRING"/>
		<param defaultValue="0" name="AJUSTECENTAVOS1" sqlType="STRING"/>
		<param defaultValue="0" name="REGISTRADO" sqlType="STRING"/>
		<param defaultValue="0" name="IMPRESO" sqlType="STRING"/>
		<param defaultValue="0" name="GENERADO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="PROVEEDORCA" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSALCA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTALCONIVA" sqlType="STRING"/>
		<param defaultValue="0" name="TOTALCONAJUSTE" sqlType="STRING"/>
		<param defaultValue="" name="FINICIO_CONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="FFINAL_CONTRATO" sqlType="STRING"/>
		<param defaultValue="0" name="AJUSTE_DEC_MANUAL" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE_ORIGEN" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE_DESTINO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_RESDESTINO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_RESORIGEN" sqlType="STRING"/>
		<param name="BODEGA_DESTINO" sqlType="STRING"/>
		<param name="BODEGA_ORIGEN" sqlType="STRING"/>
		<param name="CLASE_BODEGA_DESTINO" sqlType="STRING"/>
		<param name="CLASE_BODEGA_ORIGEN" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA_ORIGEN" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA_DESTINO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_RECIBIDO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT_RECIBIDO" sqlType="STRING"/>
		<param defaultValue="0" name="VLRUNITARIO_SINIVA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTEDERECURSO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="ACTA_INSTALACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INSTALACION" sqlType="STRING"/>
		<param defaultValue="" name="ORFEO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOPROYECTO" sqlType="STRING"/>
		<param defaultValue="" name="RUEDA" sqlType="STRING"/>
		<param defaultValue="" name="OPERACION" sqlType="STRING"/>
		<param defaultValue="" name="AUX_ALMACEN" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION_ORIGEN" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION_DESTINO" sqlType="STRING"/>
		<param defaultValue="0" name="AIU" sqlType="STRING"/>
		<param defaultValue="0" name="ADMINISTRACION" sqlType="STRING"/>
		<param defaultValue="0" name="IMPREVISTOS" sqlType="STRING"/>
		<param defaultValue="0" name="UTILIDADES" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_CONTRATO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="movimientos">
		<call-query href="insertMovimientos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PORCIVAGLOBAL" query-param="PORCIVAGLOBAL"/>
			<with-param name="TIPOMOVASOCIADO" query-param="TIPOMOVASOCIADO"/>
			<with-param name="MOVASOCIADO" query-param="MOVASOCIADO"/>
			<with-param name="FECHAMOVASOCIADO" query-param="FECHAMOVASOCIADO"/>
			<with-param name="VALORIVA" query-param="VALORIVA"/>
