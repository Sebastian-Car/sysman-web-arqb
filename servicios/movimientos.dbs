	</resource>
	<query id="getMovimientosNumEntradasauxQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT M.TIPOMOVIMIENTO CLASEDOC, M.NUMERO, TO_CHAR(M.FECHA, 'DD/MM/YYYY') FECHA, SUBSTR(M.DESCRIPCION, 1, 200) DESCRIPCION, SUM(I.EXISTENCIA) CANTIDAD FROM MOVIMIENTO M INNER JOIN D_MOVIMIENTO DM ON M.COMPANIA = DM.COMPANIA AND M.TIPOMOVIMIENTO = DM.TIPOMOVIMIENTO AND M.NUMERO = DM.MOVIMIENTO INNER JOIN TIPOMOVIMIENTO T ON M.COMPANIA = T.COMPANIA AND M.TIPOMOVIMIENTO = T.CODIGO INNER JOIN INVENTARIO I ON DM.COMPANIA = I.COMPANIA AND DM.ELEMENTO = I.CODIGOELEMENTO WHERE M.COMPANIA = :COMPANIA AND T.CLASE IN (:CLASE) AND T.TIPOELEMENTO = :TIPOELEMENTO AND DM.FUENTEDERECURSO = :FUENTER AND DM.REFERENCIA_CNT = :REFERENCIA AND DM.AUXILIAR = :AUXILIAR AND DM.CENTRODECOSTO = :CENTRODECOSTO AND DM.CODIGOPROYECTO = :PROYECTO AND M.BODEGA_DESTINO = :BODEGA GROUP BY M.TIPOMOVIMIENTO, M.NUMERO, TO_CHAR(M.FECHA, 'DD/MM/YYYY'), M.DESCRIPCION HAVING SUM(I.EXISTENCIA) &gt; 0 ORDER BY NUMERO DESC) INI WHERE (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASEDOC), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPOELEMENTO" sqlType="STRING"/>
		<param name="FUENTER" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRODECOSTO" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="movimientos/entradasaux/num">
		<call-query href="getMovimientosNumEntradasauxQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPOELEMENTO" query-param="TIPOELEMENTO"/>
			<with-param name="FUENTER" query-param="FUENTER"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="CENTRODECOSTO" query-param="CENTRODECOSTO"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="BODEGA" query-param="BODEGA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
</data>