	<query id="getMovimientosPagEntradasauxQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT M.TIPOMOVIMIENTO CLASEDOC, M.NUMERO, TO_CHAR(M.FECHA, 'DD/MM/YYYY') FECHA, SUBSTR(M.DESCRIPCION, 1, 200) DESCRIPCION, SUM(I.EXISTENCIA) CANTIDAD FROM MOVIMIENTO M INNER JOIN D_MOVIMIENTO DM ON M.COMPANIA = DM.COMPANIA AND M.TIPOMOVIMIENTO = DM.TIPOMOVIMIENTO AND M.NUMERO = DM.MOVIMIENTO INNER JOIN TIPOMOVIMIENTO T ON M.COMPANIA = T.COMPANIA AND M.TIPOMOVIMIENTO = T.CODIGO INNER JOIN INVENTARIO I ON DM.COMPANIA = I.COMPANIA AND DM.ELEMENTO = I.CODIGOELEMENTO WHERE M.COMPANIA = :COMPANIA AND T.CLASE IN (:CLASE) AND T.TIPOELEMENTO = :TIPOELEMENTO AND DM.FUENTEDERECURSO = :FUENTER AND DM.REFERENCIA_CNT = :REFERENCIA AND DM.AUXILIAR = :AUXILIAR AND DM.CENTRODECOSTO = :CENTRODECOSTO AND DM.CODIGOPROYECTO = :PROYECTO AND M.BODEGA_DESTINO = :BODEGA GROUP BY M.TIPOMOVIMIENTO, M.NUMERO, TO_CHAR(M.FECHA, 'DD/MM/YYYY'), M.DESCRIPCION HAVING SUM(I.EXISTENCIA) &gt; 0 ORDER BY NUMERO DESC) INI WHERE (CASE WHEN CLASEDOC IS NULL THEN ' ' ELSE UPPER(CLASEDOC) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASEDOC), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEDOC":"$CLASEDOC","NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
