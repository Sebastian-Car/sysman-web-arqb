<data name="esestprevioexperiencia" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEsestprevioexperiencia" keyColumns="COMPANIA,COD_ESTUDIO,COD_UNSPSC,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_ESTPREVIO_EXPERIENCIA (COMPANIA, COD_ESTUDIO, COD_UNSPSC, CONSECUTIVO, CONTRATOS, CUANTIA, EXPERIENCIAS_ADIC, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_ESTUDIO, :COD_UNSPSC, :CONSECUTIVO, :CONTRATOS, :CUANTIA, :EXPERIENCIAS_ADIC, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO","KEY_COD_UNSPSC":"$COD_UNSPSC","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="CONTRATOS" sqlType="STRING"/>
		<param defaultValue="0" name="CUANTIA" sqlType="STRING"/>
		<param defaultValue="" name="EXPERIENCIAS_ADIC" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esestprevioexperiencia">
		<call-query href="insertEsestprevioexperiencia">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONTRATOS" query-param="CONTRATOS"/>
			<with-param name="CUANTIA" query-param="CUANTIA"/>
			<with-param name="EXPERIENCIAS_ADIC" query-param="EXPERIENCIAS_ADIC"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsestprevioexperiencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_ESTPREVIO_EXPERIENCIA WHERE ES_ESTPREVIO_EXPERIENCIA.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO_EXPERIENCIA.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC= :KEY_COD_UNSPSC AND ES_ESTPREVIO_EXPERIENCIA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_UNSPSC" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="esestprevioexperiencia">
		<call-query href="deleteEsestprevioexperiencia">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_COD_UNSPSC" query-param="KEY_COD_UNSPSC"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEsestprevioexperienciaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_ESTPREVIO_EXPERIENCIA.COMPANIA, ES_ESTPREVIO_EXPERIENCIA.COD_ESTUDIO, ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC, ES_ESTPREVIO_EXPERIENCIA.CONSECUTIVO, ES_ESTPREVIO_EXPERIENCIA.CONTRATOS, ES_ESTPREVIO_EXPERIENCIA.CUANTIA, ES_ESTPREVIO_EXPERIENCIA.EXPERIENCIAS_ADIC, CODIGOS_UNSPSC.NOMBRE  FROM ES_ESTPREVIO_EXPERIENCIA INNER JOIN CODIGOS_UNSPSC ON ES_ESTPREVIO_EXPERIENCIA.COMPANIA = CODIGOS_UNSPSC.COMPANIA AND ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC = CODIGOS_UNSPSC.CODIGO WHERE ES_ESTPREVIO_EXPERIENCIA.COMPANIA = :COMPANIA AND ES_ESTPREVIO_EXPERIENCIA.COD_ESTUDIO = :CODIGO ORDER BY ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC, ES_ESTPREVIO_EXPERIENCIA.CONSECUTIVO) WHERE (CASE WHEN COD_UNSPSC IS NULL THEN ' ' ELSE UPPER(COD_UNSPSC) END)  LIKE UPPER(:COD_UNSPSC || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CONTRATOS IS NULL THEN ' ' ELSE UPPER(CONTRATOS) END)  LIKE UPPER( '%' || :CONTRATOS || '%')  AND (CASE WHEN CUANTIA IS NULL THEN ' ' ELSE UPPER(CUANTIA) END)  LIKE UPPER(:CUANTIA || '%')  AND (CASE WHEN EXPERIENCIAS_ADIC IS NULL THEN ' ' ELSE UPPER(EXPERIENCIAS_ADIC) END)  LIKE UPPER( '%' || :EXPERIENCIAS_ADIC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO","COD_UNSPSC":"$COD_UNSPSC","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CONTRATOS":"$CONTRATOS","CUANTIA":"$CUANTIA","EXPERIENCIAS_ADIC":"$EXPERIENCIAS_ADIC","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONTRATOS" sqlType="STRING"/>
		<param name="CUANTIA" sqlType="STRING"/>
		<param name="EXPERIENCIAS_ADIC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esestprevioexperiencia">
		<call-query href="getEsestprevioexperienciaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONTRATOS" query-param="CONTRATOS"/>
			<with-param name="CUANTIA" query-param="CUANTIA"/>
			<with-param name="EXPERIENCIAS_ADIC" query-param="EXPERIENCIAS_ADIC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsestprevioexperienciaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_ESTPREVIO_EXPERIENCIA.COMPANIA, ES_ESTPREVIO_EXPERIENCIA.COD_ESTUDIO, ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC, ES_ESTPREVIO_EXPERIENCIA.CONSECUTIVO, ES_ESTPREVIO_EXPERIENCIA.CONTRATOS, ES_ESTPREVIO_EXPERIENCIA.CUANTIA, ES_ESTPREVIO_EXPERIENCIA.EXPERIENCIAS_ADIC, CODIGOS_UNSPSC.NOMBRE  FROM ES_ESTPREVIO_EXPERIENCIA INNER JOIN CODIGOS_UNSPSC ON ES_ESTPREVIO_EXPERIENCIA.COMPANIA = CODIGOS_UNSPSC.COMPANIA AND ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC = CODIGOS_UNSPSC.CODIGO WHERE ES_ESTPREVIO_EXPERIENCIA.COMPANIA = :COMPANIA AND ES_ESTPREVIO_EXPERIENCIA.COD_ESTUDIO = :CODIGO ORDER BY ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC, ES_ESTPREVIO_EXPERIENCIA.CONSECUTIVO) WHERE (CASE WHEN COD_UNSPSC IS NULL THEN ' ' ELSE UPPER(COD_UNSPSC) END)  LIKE UPPER(:COD_UNSPSC || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CONTRATOS IS NULL THEN ' ' ELSE UPPER(CONTRATOS) END)  LIKE UPPER( '%' || :CONTRATOS || '%')  AND (CASE WHEN CUANTIA IS NULL THEN ' ' ELSE UPPER(CUANTIA) END)  LIKE UPPER(:CUANTIA || '%')  AND (CASE WHEN EXPERIENCIAS_ADIC IS NULL THEN ' ' ELSE UPPER(EXPERIENCIAS_ADIC) END)  LIKE UPPER( '%' || :EXPERIENCIAS_ADIC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONTRATOS" sqlType="STRING"/>
		<param name="CUANTIA" sqlType="STRING"/>
		<param name="EXPERIENCIAS_ADIC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestprevioexperiencia/numero">
		<call-query href="getEsestprevioexperienciaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONTRATOS" query-param="CONTRATOS"/>
			<with-param name="CUANTIA" query-param="CUANTIA"/>
			<with-param name="EXPERIENCIAS_ADIC" query-param="EXPERIENCIAS_ADIC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateEsestprevioexperiencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ESTPREVIO_EXPERIENCIA SET COD_UNSPSC=:COD_UNSPSC, CONTRATOS=:CONTRATOS, CUANTIA=:CUANTIA, EXPERIENCIAS_ADIC=:EXPERIENCIAS_ADIC, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_ESTPREVIO_EXPERIENCIA.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO_EXPERIENCIA.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_ESTPREVIO_EXPERIENCIA.COD_UNSPSC= :KEY_COD_UNSPSC AND ES_ESTPREVIO_EXPERIENCIA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="CONTRATOS" sqlType="STRING"/>
		<param name="CUANTIA" sqlType="STRING"/>
		<param name="EXPERIENCIAS_ADIC" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_UNSPSC" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esestprevioexperiencia">
		<call-query href="updateEsestprevioexperiencia">
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="CONTRATOS" query-param="CONTRATOS"/>
			<with-param name="CUANTIA" query-param="CUANTIA"/>
			<with-param name="EXPERIENCIAS_ADIC" query-param="EXPERIENCIAS_ADIC"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_COD_UNSPSC" query-param="KEY_COD_UNSPSC"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>