<data name="intermediarias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIntermediariasPorRentaFijaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  INTERMEDIARIAS.CODIGO,INTERMEDIARIAS.NOMBRE  FROM INTERMEDIARIAS ORDER BY INTERMEDIARIAS.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="intermediarias/porrentafija">
		<call-query href="getIntermediariasPorRentaFijaQuery">
 
		</call-query>
	</resource>

</data>