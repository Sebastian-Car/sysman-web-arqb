<data name="bpactividades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpactividadesPagTodosSinIndicadorDesactivarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA AND NVL(DES_ACTIVAR_A, 0) IN(0) ORDER BY NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpactividades/todossinindicadordesactivar/pag">
		<call-query href="getBpactividadesPagTodosSinIndicadorDesactivarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpactividadesNumTodosSinIndicadorDesactivarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA AND NVL(DES_ACTIVAR_A, 0) IN(0) ORDER BY NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpactividades/todossinindicadordesactivar/num">
		<call-query href="getBpactividadesNumTodosSinIndicadorDesactivarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBpactividadesTodosPorTipoFicticioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA AND TIPOCOMPONENTEFICTICIO = :TIPOCOMPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpactividades/todosportipoficticio">
		<call-query href="getBpactividadesTodosPorTipoFicticioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>

		</call-query>
	</resource>
	<query id="getBpactividadesNombrePorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOMBRE  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpactividades/nombreporcodigo">
		<call-query href="getBpactividadesNombrePorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpactividadesPagTodoslosdatosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA ORDER BY NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpactividades/todoslosdatos/pag">
		<call-query href="getBpactividadesPagTodoslosdatosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpactividadesNumTodoslosdatosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA ORDER BY NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpactividades/todoslosdatos/num">
		<call-query href="getBpactividadesNumTodoslosdatosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBpactividadesPagListadocodigofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :CODIGO_INICIAL ORDER BY CODIGO, NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_INICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpactividades/listadocodigofinal/pag">
		<call-query href="getBpactividadesPagListadocodigofinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_INICIAL" query-param="CODIGO_INICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpactividadesNumListadocodigofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :CODIGO_INICIAL ORDER BY CODIGO, NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_INICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpactividades/listadocodigofinal/num">
		<call-query href="getBpactividadesNumListadocodigofinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_INICIAL" query-param="CODIGO_INICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBpactividadesPagActividadesporvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BP_ACTIVIDADES.CODIGO, BP_ACTIVIDADES.NOMBRE  FROM BP_ACTIVIDADES INNER JOIN BP_D_NOVEDADPROYECTO ON BP_ACTIVIDADES.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BP_ACTIVIDADES.CODIGO = BP_D_NOVEDADPROYECTO.ACTIVIDAD INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = BPNOVEDADPROYECTO.DEPENDENCIA WHERE BP_ACTIVIDADES.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.VIGENCIA = :VIGENCIA ORDER BY BP_ACTIVIDADES.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpactividades/actividadesporvigencia/pag">
		<call-query href="getBpactividadesPagActividadesporvigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertBpactividades" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_ACTIVIDADES (COMPANIA, CODIGO, NOMBRE, UNIDAD, PRODUCTO, DES_ACTIVAR_A, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :UNIDAD, :PRODUCTO, :DES_ACTIVAR_A, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD" sqlType="STRING"/>
		<param defaultValue="" name="PRODUCTO" sqlType="STRING"/>
		<param defaultValue="0" name="DES_ACTIVAR_A" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpactividades">
		<call-query href="insertBpactividades">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PRODUCTO" query-param="PRODUCTO"/>
			<with-param name="DES_ACTIVAR_A" query-param="DES_ACTIVAR_A"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpactividades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_ACTIVIDADES WHERE BP_ACTIVIDADES.COMPANIA= :KEY_COMPANIA AND BP_ACTIVIDADES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpactividades">
		<call-query href="deleteBpactividades">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpactividadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, UNIDAD, PRODUCTO,(CASE DES_ACTIVAR_A WHEN 0 THEN 'false' ELSE 'true' END) DES_ACTIVAR_A FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN PRODUCTO IS NULL THEN ' ' ELSE UPPER(PRODUCTO) END)  LIKE UPPER( '%' || :PRODUCTO || '%')  AND (CASE WHEN DES_ACTIVAR_A IS NULL THEN ' ' ELSE UPPER(DES_ACTIVAR_A) END)  LIKE UPPER(:DES_ACTIVAR_A || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","UNIDAD":"$UNIDAD","PRODUCTO":"$PRODUCTO","DES_ACTIVAR_A":"$DES_ACTIVAR_A(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PRODUCTO" sqlType="STRING"/>
		<param name="DES_ACTIVAR_A" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpactividades">
		<call-query href="getBpactividadesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PRODUCTO" query-param="PRODUCTO"/>
			<with-param name="DES_ACTIVAR_A" query-param="DES_ACTIVAR_A"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpactividadesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, UNIDAD, PRODUCTO,(CASE DES_ACTIVAR_A WHEN 0 THEN 'false' ELSE 'true' END) DES_ACTIVAR_A FROM BP_ACTIVIDADES WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN PRODUCTO IS NULL THEN ' ' ELSE UPPER(PRODUCTO) END)  LIKE UPPER( '%' || :PRODUCTO || '%')  AND (CASE WHEN DES_ACTIVAR_A IS NULL THEN ' ' ELSE UPPER(DES_ACTIVAR_A) END)  LIKE UPPER(:DES_ACTIVAR_A || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PRODUCTO" sqlType="STRING"/>
		<param name="DES_ACTIVAR_A" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpactividades/numero">
		<call-query href="getBpactividadesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PRODUCTO" query-param="PRODUCTO"/>
			<with-param name="DES_ACTIVAR_A" query-param="DES_ACTIVAR_A"/>

		</call-query>
	</resource>
	<query id="updateBpactividades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_ACTIVIDADES SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, UNIDAD=:UNIDAD, PRODUCTO=:PRODUCTO, DES_ACTIVAR_A=:DES_ACTIVAR_A, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_ACTIVIDADES.COMPANIA= :KEY_COMPANIA AND BP_ACTIVIDADES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PRODUCTO" sqlType="STRING"/>
		<param name="DES_ACTIVAR_A" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpactividades">
		<call-query href="updateBpactividades">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PRODUCTO" query-param="PRODUCTO"/>
			<with-param name="DES_ACTIVAR_A" query-param="DES_ACTIVAR_A"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpactividadesNumActividadesporvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BP_ACTIVIDADES.CODIGO, BP_ACTIVIDADES.NOMBRE  FROM BP_ACTIVIDADES INNER JOIN BP_D_NOVEDADPROYECTO ON BP_ACTIVIDADES.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BP_ACTIVIDADES.CODIGO = BP_D_NOVEDADPROYECTO.ACTIVIDAD INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = BPNOVEDADPROYECTO.DEPENDENCIA WHERE BP_ACTIVIDADES.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.VIGENCIA = :VIGENCIA ORDER BY BP_ACTIVIDADES.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpactividades/actividadesporvigencia/num">
		<call-query href="getBpactividadesNumActividadesporvigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBpactividadesPagActividadesporvigenciafinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BP_ACTIVIDADES.CODIGO, BP_ACTIVIDADES.NOMBRE  FROM BP_ACTIVIDADES INNER JOIN BP_D_NOVEDADPROYECTO ON BP_ACTIVIDADES.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BP_ACTIVIDADES.CODIGO = BP_D_NOVEDADPROYECTO.ACTIVIDAD INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = BPNOVEDADPROYECTO.DEPENDENCIA WHERE BP_ACTIVIDADES.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.VIGENCIA = :VIGENCIA AND BP_ACTIVIDADES.CODIGO &gt;= :CODIGO_INICIAL ORDER BY BP_ACTIVIDADES.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO_INICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpactividades/actividadesporvigenciafinal/pag">
