<data name="logauditoria" transports="http https local">
	<config enableOData="false" id="sysmanauditoria">
		<property name="carbon_datasource_name">SYSMANAUDITORIA</property>
	</config>
	<query id="getLogauditoriaPaginaQuery"  useConfig="sysmanauditoria">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID, CUK, COMPANIA, USUARIO, NIT, SUCURSAL, NOMBRE_BD,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ACCION, NOMBRE_TABLA, TO_CHAR(DESCRIPCION_NUEVA) DESCRIPCION_NUEVA  FROM LOG_AUDITORIA) WHERE (CASE WHEN CUK IS NULL THEN ' ' ELSE UPPER(CUK) END)  LIKE UPPER( '%' || :CUK || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE_BD IS NULL THEN ' ' ELSE UPPER(NOMBRE_BD) END)  LIKE UPPER( '%' || :NOMBRE_BD || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ACCION IS NULL THEN ' ' ELSE UPPER(ACCION) END)  LIKE UPPER( '%' || :ACCION || '%')  AND (CASE WHEN NOMBRE_TABLA IS NULL THEN ' ' ELSE UPPER(NOMBRE_TABLA) END)  LIKE UPPER( '%' || :NOMBRE_TABLA || '%')  AND (CASE WHEN DESCRIPCION_NUEVA IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_NUEVA) END)  LIKE UPPER( '%' || :DESCRIPCION_NUEVA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID(type:long)","CUK":"$CUK","COMPANIA":"$COMPANIA","USUARIO":"$USUARIO","NIT":"$NIT","SUCURSAL":"$SUCURSAL","NOMBRE_BD":"$NOMBRE_BD","FECHA":"$FECHA","ACCION":"$ACCION","NOMBRE_TABLA":"$NOMBRE_TABLA","DESCRIPCION_NUEVA":"$DESCRIPCION_NUEVA"}]}}		</result>
		<param name="CUK" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE_BD" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="NOMBRE_TABLA" sqlType="STRING"/>
		<param name="DESCRIPCION_NUEVA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="logauditoria">
		<call-query href="getLogauditoriaPaginaQuery">
			<with-param name="CUK" query-param="CUK"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE_BD" query-param="NOMBRE_BD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="NOMBRE_TABLA" query-param="NOMBRE_TABLA"/>
			<with-param name="DESCRIPCION_NUEVA" query-param="DESCRIPCION_NUEVA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getLogauditoriaNumeroQuery"  useConfig="sysmanauditoria">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID, CUK, COMPANIA, USUARIO, NIT, SUCURSAL, NOMBRE_BD,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ACCION, NOMBRE_TABLA, TO_CHAR(DESCRIPCION_NUEVA) DESCRIPCION_NUEVA  FROM LOG_AUDITORIA) WHERE (CASE WHEN CUK IS NULL THEN ' ' ELSE UPPER(CUK) END)  LIKE UPPER( '%' || :CUK || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE_BD IS NULL THEN ' ' ELSE UPPER(NOMBRE_BD) END)  LIKE UPPER( '%' || :NOMBRE_BD || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ACCION IS NULL THEN ' ' ELSE UPPER(ACCION) END)  LIKE UPPER( '%' || :ACCION || '%')  AND (CASE WHEN NOMBRE_TABLA IS NULL THEN ' ' ELSE UPPER(NOMBRE_TABLA) END)  LIKE UPPER( '%' || :NOMBRE_TABLA || '%')  AND (CASE WHEN DESCRIPCION_NUEVA IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_NUEVA) END)  LIKE UPPER( '%' || :DESCRIPCION_NUEVA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CUK" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE_BD" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ACCION" sqlType="STRING"/>
		<param name="NOMBRE_TABLA" sqlType="STRING"/>
		<param name="DESCRIPCION_NUEVA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="logauditoria/numero">
		<call-query href="getLogauditoriaNumeroQuery">
			<with-param name="CUK" query-param="CUK"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE_BD" query-param="NOMBRE_BD"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="ACCION" query-param="ACCION"/>
			<with-param name="NOMBRE_TABLA" query-param="NOMBRE_TABLA"/>
			<with-param name="DESCRIPCION_NUEVA" query-param="DESCRIPCION_NUEVA"/>

		</call-query>
	</resource>

</data>