			<with-param name="KEY_ID_CENTRO_DE_COSTO" query-param="KEY_ID_CENTRO_DE_COSTO"/>
			<with-param name="KEY_ID_AUXILIAR" query-param="KEY_ID_AUXILIAR"/>

		</call-query>
	</resource>
	<query id="updateDistpersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DISTPERSONAL SET COMPANIA=:COMPANIA, ID_DE_PROCESO=:ID_DE_PROCESO, ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_CENTRO_DE_COSTO=:ID_CENTRO_DE_COSTO, HORAST=:HORAST, MINUTOST=:MINUTOST, TIEMPOTRABAJADO=:TIEMPOTRABAJADO, TOTALTIEMPOTRABAJADO=:TOTALTIEMPOTRABAJADO, PORCENTAJE=:PORCENTAJE, ID_AUXILIAR=:ID_AUXILIAR, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE DISTPERSONAL.COMPANIA= :KEY_COMPANIA AND DISTPERSONAL.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND DISTPERSONAL.ANO= :KEY_ANO AND DISTPERSONAL.MES= :KEY_MES AND DISTPERSONAL.PERIODO= :KEY_PERIODO AND DISTPERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND DISTPERSONAL.ID_CENTRO_DE_COSTO= :KEY_ID_CENTRO_DE_COSTO AND DISTPERSONAL.ID_AUXILIAR= :KEY_ID_AUXILIAR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="HORAST" sqlType="STRING"/>
		<param name="MINUTOST" sqlType="STRING"/>
		<param name="TIEMPOTRABAJADO" sqlType="STRING"/>
		<param name="TOTALTIEMPOTRABAJADO" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="ID_AUXILIAR" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
