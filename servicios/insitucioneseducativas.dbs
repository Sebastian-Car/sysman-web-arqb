<data name="insitucioneseducativas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getInsitucioneseducativasListaEstablecimientosEducativosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NIT, NOMBRE  FROM INSTITUCIONES_EDUCATIVAS ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="insitucioneseducativas/listaestablecimientoseducativos">
		<call-query href="getInsitucioneseducativasListaEstablecimientosEducativosQuery">
 
		</call-query>
	</resource>
	<query id="getInsitucioneseducativasEstablecbasicoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NIT, NOMBRE NOMBREINSTITUCION  FROM INSTITUCIONES_EDUCATIVAS ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBREINSTITUCION":"$NOMBREINSTITUCION"}]}}		</result>
 
	</query>
	<resource method="GET" path="insitucioneseducativas/establecbasico">
		<call-query href="getInsitucioneseducativasEstablecbasicoQuery">
 
		</call-query>
	</resource>
	<query id="insertInsitucioneseducativas" keyColumns="NIT" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INSTITUCIONES_EDUCATIVAS (NIT, NOMBRE, DIRECCION, CREATED_BY, DATE_CREATED) VALUES (:NIT, :NOMBRE, :DIRECCION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_NIT":"$NIT"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="insitucioneseducativas">
		<call-query href="insertInsitucioneseducativas">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteInsitucioneseducativas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM INSTITUCIONES_EDUCATIVAS WHERE INSTITUCIONES_EDUCATIVAS.NIT= :KEY_NIT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_NIT" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="insitucioneseducativas">
		<call-query href="deleteInsitucioneseducativas">
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>

		</call-query>
	</resource>
	<query id="getInsitucioneseducativasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIT, NOMBRE, DIRECCION  FROM INSTITUCIONES_EDUCATIVAS) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="insitucioneseducativas">
		<call-query href="getInsitucioneseducativasPaginaQuery">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInsitucioneseducativasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NIT, NOMBRE, DIRECCION  FROM INSTITUCIONES_EDUCATIVAS) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="insitucioneseducativas/numero">
		<call-query href="getInsitucioneseducativasNumeroQuery">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>

		</call-query>
	</resource>
	<query id="updateInsitucioneseducativas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INSTITUCIONES_EDUCATIVAS SET NIT=:NIT, NOMBRE=:NOMBRE, DIRECCION=:DIRECCION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE INSTITUCIONES_EDUCATIVAS.NIT= :KEY_NIT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="insitucioneseducativas">
		<call-query href="updateInsitucioneseducativas">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>

		</call-query>
	</resource>

</data>