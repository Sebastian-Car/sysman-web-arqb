<data name="consultasrp" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getConsultasrpPagTodosPorCompaniaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO_CONSULTA CODIGO, NOMBRE_CONSULTA NOMBRE  FROM CONSULTAS_RP WHERE COMPANIA = :COMPANIA AND MODULO = :MODULO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="consultasrp/todosporcompania/pag">
		<call-query href="getConsultasrpPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConsultasrpNumTodosPorCompaniaQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO_CONSULTA CODIGO, NOMBRE_CONSULTA NOMBRE  FROM CONSULTAS_RP WHERE COMPANIA = :COMPANIA AND MODULO = :MODULO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="consultasrp/todosporcompania/num">
		<call-query href="getConsultasrpNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getConsultasrpSqlPorCompaniaYCodigoQuery"  useConfig="sysmanirisst">
		<sql>SELECT  SQL  FROM CONSULTAS_RP WHERE COMPANIA = :COMPANIA AND CODIGO_CONSULTA = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SQL":"$SQL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="consultasrp/sqlporcompaniaycodigo">
		<call-query href="getConsultasrpSqlPorCompaniaYCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertConsultasrp" keyColumns="COMPANIA,CODIGO_CONSULTA" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO CONSULTAS_RP (COMPANIA, CODIGO_CONSULTA, NOMBRE_CONSULTA, SQL, ESTADO, MODULO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO_CONSULTA, :NOMBRE_CONSULTA, :SQL, :ESTADO, :MODULO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_CONSULTA":"$CODIGO_CONSULTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>
		<param name="SQL" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="consultasrp">
		<call-query href="insertConsultasrp">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>
			<with-param name="SQL" query-param="SQL"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteConsultasrp" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM CONSULTAS_RP WHERE CONSULTAS_RP.COMPANIA= :KEY_COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA= :KEY_CODIGO_CONSULTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONSULTA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="consultasrp">
		<call-query href="deleteConsultasrp">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONSULTA" query-param="KEY_CODIGO_CONSULTA"/>

		</call-query>
	</resource>
	<query id="getConsultasrpPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , CODIGO_CONSULTA , NOMBRE_CONSULTA , CASE WHEN ESTADO NOT IN ('I') THEN 'ACTIVO' ELSE 'INACTIVO' END ESTADO  FROM CONSULTAS_RP WHERE COMPANIA = :COMPANIA AND MODULO = :MODULO) WHERE (CASE WHEN CODIGO_CONSULTA IS NULL THEN ' ' ELSE UPPER(CODIGO_CONSULTA) END)  LIKE UPPER(:CODIGO_CONSULTA || '%')  AND (CASE WHEN NOMBRE_CONSULTA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONSULTA) END)  LIKE UPPER( '%' || :NOMBRE_CONSULTA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_CONSULTA":"$CODIGO_CONSULTA","NOMBRE_CONSULTA":"$NOMBRE_CONSULTA","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="consultasrp">
		<call-query href="getConsultasrpPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConsultasrpNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , CODIGO_CONSULTA , NOMBRE_CONSULTA , CASE WHEN ESTADO NOT IN ('I') THEN 'ACTIVO' ELSE 'INACTIVO' END ESTADO  FROM CONSULTAS_RP WHERE COMPANIA = :COMPANIA AND MODULO = :MODULO) WHERE (CASE WHEN CODIGO_CONSULTA IS NULL THEN ' ' ELSE UPPER(CODIGO_CONSULTA) END)  LIKE UPPER(:CODIGO_CONSULTA || '%')  AND (CASE WHEN NOMBRE_CONSULTA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONSULTA) END)  LIKE UPPER( '%' || :NOMBRE_CONSULTA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="consultasrp/numero">
		<call-query href="getConsultasrpNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getConsultasrpRegistroQuery"  useConfig="sysmanirisst">
		<sql>SELECT  COMPANIA , CODIGO_CONSULTA , NOMBRE_CONSULTA , SQL , ESTADO , MODULO , CREATED_BY ,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY ,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM CONSULTAS_RP WHERE CONSULTAS_RP.COMPANIA= :KEY_COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA= :KEY_CODIGO_CONSULTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_CONSULTA":"$CODIGO_CONSULTA","NOMBRE_CONSULTA":"$NOMBRE_CONSULTA","SQL":"$SQL","ESTADO":"$ESTADO","MODULO":"$MODULO(type:integer)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONSULTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="consultasrp/data">
		<call-query href="getConsultasrpRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONSULTA" query-param="KEY_CODIGO_CONSULTA"/>

		</call-query>
	</resource>
	<query id="updateConsultasrp" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE CONSULTAS_RP SET CODIGO_CONSULTA=:CODIGO_CONSULTA, NOMBRE_CONSULTA=:NOMBRE_CONSULTA, SQL=:SQL, ESTADO=:ESTADO, MODULO=:MODULO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE CONSULTAS_RP.COMPANIA= :KEY_COMPANIA AND CONSULTAS_RP.CODIGO_CONSULTA= :KEY_CODIGO_CONSULTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO_CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_CONSULTA" sqlType="STRING"/>
		<param name="SQL" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONSULTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="consultasrp">
		<call-query href="updateConsultasrp">
			<with-param name="CODIGO_CONSULTA" query-param="CODIGO_CONSULTA"/>
			<with-param name="NOMBRE_CONSULTA" query-param="NOMBRE_CONSULTA"/>
			<with-param name="SQL" query-param="SQL"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_CONSULTA" query-param="KEY_CODIGO_CONSULTA"/>

		</call-query>
	</resource>

</data>