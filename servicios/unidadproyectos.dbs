<data name="unidadproyectos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getUnidadproyectosTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  UNIDADPROYECTOS.UNIDAD, UNIDADPROYECTOS.NOMBRE  FROM UNIDADPROYECTOS WHERE UNIDADPROYECTOS.COMPANIA = :COMPANIA ORDER BY UNIDADPROYECTOS.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidadproyectos/todosporcompania">
		<call-query href="getUnidadproyectosTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getUnidadproyectosPagUnidadnombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  UNIDAD, NOMBRE  FROM UNIDADPROYECTOS WHERE COMPANIA = :COMPANIA ORDER BY UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="unidadproyectos/unidadnombre/pag">
		<call-query href="getUnidadproyectosPagUnidadnombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getUnidadproyectosNumUnidadnombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  UNIDAD, NOMBRE  FROM UNIDADPROYECTOS WHERE COMPANIA = :COMPANIA ORDER BY UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidadproyectos/unidadnombre/num">
		<call-query href="getUnidadproyectosNumUnidadnombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getUnidadproyectosUnidadYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  UNIDADPROYECTOS.UNIDAD, UNIDADPROYECTOS.NOMBRE NOMBRE  FROM UNIDADPROYECTOS WHERE UNIDADPROYECTOS.COMPANIA = :COMPANIA ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidadproyectos/unidadynombre">
		<call-query href="getUnidadproyectosUnidadYNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getUnidadproyectosTodoisPorProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(PROYECTOS.CODIGOBPIM, ' ') CODIGOBPIM, PROYECTOS.NOMBREPROYECTO, PROYECTOS.VIGENCIAINICIO, PROYECTOS.VIGENCIAFIN  FROM PROYECTOS WHERE PROYECTOS.COMPANIA= :COMPANIA AND PROYECTOS.CODIGO = :PROYECTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBPIM":"$CODIGOBPIM","NOMBREPROYECTO":"$NOMBREPROYECTO","VIGENCIAINICIO":"$VIGENCIAINICIO(type:integer)","VIGENCIAFIN":"$VIGENCIAFIN(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidadproyectos/todoisporproyecto">
		<call-query href="getUnidadproyectosTodoisPorProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>

		</call-query>
	</resource>
	<query id="getUnidadproyectosXunidadnombredescQuery"  useConfig="sysmandsunist">
		<sql>SELECT UNIDAD, NOMBRE, DESCRIPCION FROM UNIDADPROYECTOS WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidadproyectos/xunidadnombredesc">
		<call-query href="getUnidadproyectosXunidadnombredescQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertUnidadproyectos" keyColumns="COMPANIA,UNIDAD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO UNIDADPROYECTOS (COMPANIA, UNIDAD, NOMBRE, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :UNIDAD, :NOMBRE, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_UNIDAD":"$UNIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="unidadproyectos">
		<call-query href="insertUnidadproyectos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteUnidadproyectos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM UNIDADPROYECTOS WHERE UNIDADPROYECTOS.COMPANIA= :KEY_COMPANIA AND UNIDADPROYECTOS.UNIDAD= :KEY_UNIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_UNIDAD" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="unidadproyectos">
		<call-query href="deleteUnidadproyectos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_UNIDAD" query-param="KEY_UNIDAD"/>

		</call-query>
	</resource>
	<query id="getUnidadproyectosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, UNIDAD, NOMBRE, DESCRIPCION  FROM UNIDADPROYECTOS WHERE COMPANIA= :COMPANIA ORDER BY UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="unidadproyectos">
		<call-query href="getUnidadproyectosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getUnidadproyectosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, UNIDAD, NOMBRE, DESCRIPCION  FROM UNIDADPROYECTOS WHERE COMPANIA= :COMPANIA ORDER BY UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidadproyectos/numero">
		<call-query href="getUnidadproyectosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateUnidadproyectos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE UNIDADPROYECTOS SET UNIDAD=:UNIDAD, NOMBRE=:NOMBRE, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE UNIDADPROYECTOS.COMPANIA= :KEY_COMPANIA AND UNIDADPROYECTOS.UNIDAD= :KEY_UNIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_UNIDAD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="unidadproyectos">
		<call-query href="updateUnidadproyectos">
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_UNIDAD" query-param="KEY_UNIDAD"/>

		</call-query>
	</resource>

</data>