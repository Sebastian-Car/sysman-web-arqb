		</call-query>
	</resource>
	<query id="getRequisicionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  REQUISICION.COMPANIA, REQUISICION.COD_REQUISICION , REQUISICION.DEPENDENCIA , DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, REQUISICION.RESPONSABLE , TERCERO.NOMBRE NOMBER_TERCERO, REQUISICION.SUCURSAL , REQUISICION.COD_ACTIVIDAD  FROM REQUISICION LEFT JOIN DEPENDENCIA ON REQUISICION.COMPANIA = DEPENDENCIA.COMPANIA AND REQUISICION.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE ON REQUISICION.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND REQUISICION.DEPENDENCIA = DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND REQUISICION.RESPONSABLE = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND REQUISICION.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON TERCERO.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND TERCERO.NIT = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND TERCERO.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL WHERE REQUISICION.COMPANIA = :COMPANIA ORDER BY REQUISICION.COMPANIA, REQUISICION.COD_REQUISICION) WHERE (CASE WHEN COD_REQUISICION IS NULL THEN ' ' ELSE UPPER(COD_REQUISICION) END)  LIKE UPPER(:COD_REQUISICION || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER( '%' || :RESPONSABLE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN COD_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(COD_ACTIVIDAD) END)  LIKE UPPER(:COD_ACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_REQUISICION":"$COD_REQUISICION(type:long)","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","NOMBER_TERCERO":"$NOMBER_TERCERO","SUCURSAL":"$SUCURSAL","COD_ACTIVIDAD":"$COD_ACTIVIDAD(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COD_ACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="requisiciones">
		<call-query href="getRequisicionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COD_ACTIVIDAD" query-param="COD_ACTIVIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRequisicionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  REQUISICION.COMPANIA, REQUISICION.COD_REQUISICION , REQUISICION.DEPENDENCIA , DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, REQUISICION.RESPONSABLE , TERCERO.NOMBRE NOMBER_TERCERO, REQUISICION.SUCURSAL , REQUISICION.COD_ACTIVIDAD  FROM REQUISICION LEFT JOIN DEPENDENCIA ON REQUISICION.COMPANIA = DEPENDENCIA.COMPANIA AND REQUISICION.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE ON REQUISICION.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND REQUISICION.DEPENDENCIA = DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND REQUISICION.RESPONSABLE = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND REQUISICION.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON TERCERO.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND TERCERO.NIT = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND TERCERO.SUCURSAL = DEPENDENCIA_RESPONSABLE.SUCURSAL WHERE REQUISICION.COMPANIA = :COMPANIA ORDER BY REQUISICION.COMPANIA, REQUISICION.COD_REQUISICION) WHERE (CASE WHEN COD_REQUISICION IS NULL THEN ' ' ELSE UPPER(COD_REQUISICION) END)  LIKE UPPER(:COD_REQUISICION || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER( '%' || :RESPONSABLE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN COD_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(COD_ACTIVIDAD) END)  LIKE UPPER(:COD_ACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COD_ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="requisiciones/numero">
		<call-query href="getRequisicionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COD_ACTIVIDAD" query-param="COD_ACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="getRequisicionesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASEGASTO ,COD_ACTIVIDAD ,COD_CLACONTRATO ,COD_CONTRATO ,COD_REQUISICION ,COMPANIA ,CREATED_BY ,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE DEFINIRCONTRATACION WHEN 0 THEN 'false' ELSE 'true' END) DEFINIRCONTRATACION,DEPENDENCIA ,DESCRIPCION ,DISPONIBILIDAD ,(TO_CHAR(FECHAREQUISICION,'DD/MM/YYYY HH24:MI:SS')) FECHAREQUISICION,MODIFIED_BY ,NUMOFICIO ,ORDENDESUMINISTRO ,REQUISICIONES ,REQUISIONES ,RESPONSABLE ,RUBRO ,RUBROCOMPRAS ,SUCURSAL ,(CASE VACIA WHEN 0 THEN 'false' ELSE 'true' END) VACIA,VALORDISPONIBILIDAD ,VALORESTIMADO ,VALORREAL ,VIABILIDAD  FROM REQUISICION WHERE REQUISICION.COD_REQUISICION= :KEY_COD_REQUISICION AND REQUISICION.COMPANIA= :KEY_COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEGASTO":"$CLASEGASTO","COD_ACTIVIDAD":"$COD_ACTIVIDAD(type:long)","COD_CLACONTRATO":"$COD_CLACONTRATO(type:long)","COD_CONTRATO":"$COD_CONTRATO(type:long)","COD_REQUISICION":"$COD_REQUISICION(type:long)","COMPANIA":"$COMPANIA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","DEFINIRCONTRATACION":"$DEFINIRCONTRATACION(type:boolean)","DEPENDENCIA":"$DEPENDENCIA","DESCRIPCION":"$DESCRIPCION","DISPONIBILIDAD":"$DISPONIBILIDAD(type:long)","FECHAREQUISICION":"$FECHAREQUISICION","MODIFIED_BY":"$MODIFIED_BY","NUMOFICIO":"$NUMOFICIO","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO(type:long)","REQUISICIONES":"$REQUISICIONES","REQUISIONES":"$REQUISIONES","RESPONSABLE":"$RESPONSABLE","RUBRO":"$RUBRO","RUBROCOMPRAS":"$RUBROCOMPRAS","SUCURSAL":"$SUCURSAL","VACIA":"$VACIA(type:boolean)","VALORDISPONIBILIDAD":"$VALORDISPONIBILIDAD","VALORESTIMADO":"$VALORESTIMADO","VALORREAL":"$VALORREAL","VIABILIDAD":"$VIABILIDAD"}]}}		</result>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="requisiciones/data">
		<call-query href="getRequisicionesRegistroQuery">
			<with-param name="KEY_COD_REQUISICION" query-param="KEY_COD_REQUISICION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateRequisiciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE REQUISICION SET CLASEGASTO=:CLASEGASTO, COD_ACTIVIDAD=:COD_ACTIVIDAD, COD_CLACONTRATO=:COD_CLACONTRATO, COD_CONTRATO=:COD_CONTRATO, COD_REQUISICION=:COD_REQUISICION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), DEFINIRCONTRATACION=:DEFINIRCONTRATACION, DEPENDENCIA=:DEPENDENCIA, DESCRIPCION=:DESCRIPCION, DISPONIBILIDAD=:DISPONIBILIDAD, FECHAREQUISICION=TO_DATE(:FECHAREQUISICION,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, NUMOFICIO=:NUMOFICIO, ORDENDESUMINISTRO=:ORDENDESUMINISTRO, REQUISICIONES=:REQUISICIONES, REQUISIONES=:REQUISIONES, RESPONSABLE=:RESPONSABLE, RUBRO=:RUBRO, RUBROCOMPRAS=:RUBROCOMPRAS, SUCURSAL=:SUCURSAL, VACIA=:VACIA, VALORDISPONIBILIDAD=:VALORDISPONIBILIDAD, VALORESTIMADO=:VALORESTIMADO, VALORREAL=:VALORREAL, VIABILIDAD=:VIABILIDAD WHERE REQUISICION.COD_REQUISICION= :KEY_COD_REQUISICION AND REQUISICION.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CLASEGASTO" sqlType="STRING"/>
		<param name="COD_ACTIVIDAD" sqlType="STRING"/>
		<param name="COD_CLACONTRATO" sqlType="STRING"/>
		<param name="COD_CONTRATO" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="DEFINIRCONTRATACION" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DISPONIBILIDAD" sqlType="STRING"/>
		<param name="FECHAREQUISICION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="NUMOFICIO" sqlType="STRING"/>
		<param name="ORDENDESUMINISTRO" sqlType="STRING"/>
		<param name="REQUISICIONES" sqlType="STRING"/>
		<param name="REQUISIONES" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="RUBROCOMPRAS" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="VACIA" sqlType="STRING"/>
		<param name="VALORDISPONIBILIDAD" sqlType="STRING"/>
		<param name="VALORESTIMADO" sqlType="STRING"/>
		<param name="VALORREAL" sqlType="STRING"/>
		<param name="VIABILIDAD" sqlType="STRING"/>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="requisiciones">
		<call-query href="updateRequisiciones">
			<with-param name="CLASEGASTO" query-param="CLASEGASTO"/>
			<with-param name="COD_ACTIVIDAD" query-param="COD_ACTIVIDAD"/>
			<with-param name="COD_CLACONTRATO" query-param="COD_CLACONTRATO"/>
			<with-param name="COD_CONTRATO" query-param="COD_CONTRATO"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="DEFINIRCONTRATACION" query-param="DEFINIRCONTRATACION"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DISPONIBILIDAD" query-param="DISPONIBILIDAD"/>
			<with-param name="FECHAREQUISICION" query-param="FECHAREQUISICION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="NUMOFICIO" query-param="NUMOFICIO"/>
			<with-param name="ORDENDESUMINISTRO" query-param="ORDENDESUMINISTRO"/>
			<with-param name="REQUISICIONES" query-param="REQUISICIONES"/>
			<with-param name="REQUISIONES" query-param="REQUISIONES"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="RUBROCOMPRAS" query-param="RUBROCOMPRAS"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="VACIA" query-param="VACIA"/>
			<with-param name="VALORDISPONIBILIDAD" query-param="VALORDISPONIBILIDAD"/>
			<with-param name="VALORESTIMADO" query-param="VALORESTIMADO"/>
			<with-param name="VALORREAL" query-param="VALORREAL"/>
			<with-param name="VIABILIDAD" query-param="VIABILIDAD"/>
			<with-param name="KEY_COD_REQUISICION" query-param="KEY_COD_REQUISICION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>

</data>