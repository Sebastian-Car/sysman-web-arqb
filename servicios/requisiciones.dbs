<data name="requisiciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getRequisicionesPagListaDePropuestasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  REQUISICION.COMPANIA , REQUISICION.COD_REQUISICION , REQUISICION.ORDENDESUMINISTRO , REQUISICION.COD_ACTIVIDAD , REQUISICION.DEPENDENCIA , REQUISICION.RESPONSABLE , REQUISICION.SUCURSAL , REQUISICION.COD_CLACONTRATO , REQUISICION.COD_CONTRATO , REQUISICION.NUMOFICIO , REQUISICION.DESCRIPCION , REQUISICION.VALORESTIMADO , REQUISICION.VALORREAL ,(TO_CHAR(REQUISICION.FECHAREQUISICION,'DD/MM/YYYY HH24:MI:SS')) FECHAREQUISICION, REQUISICION.VIABILIDAD , REQUISICION.RUBRO , REQUISICION.DISPONIBILIDAD , REQUISICION.VALORDISPONIBILIDAD , REQUISICION.CLASEGASTO ,(CASE REQUISICION.VACIA WHEN 0 THEN 'false' ELSE 'true' END) VACIA,(CASE REQUISICION.DEFINIRCONTRATACION WHEN 0 THEN 'false' ELSE 'true' END) DEFINIRCONTRATACION, REQUISICION.RUBROCOMPRAS , REQUISICION.REQUISICIONES , REQUISICION.REQUISIONES , REQUISICION.CREATED_BY ,(TO_CHAR(REQUISICION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, REQUISICION.MODIFIED_BY ,(TO_CHAR(REQUISICION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ACTIVIDAD.NOMBRE NOMACTIVIDAD, TERCERO.NOMBRE NOMRESPONSABLE  FROM REQUISICION LEFT JOIN ACTIVIDAD ON REQUISICION.COD_ACTIVIDAD=ACTIVIDAD.COD_ACTIVIDAD LEFT JOIN TERCERO ON TERCERO.COMPANIA =REQUISICION.COMPANIA AND TERCERO.NIT =REQUISICION.RESPONSABLE AND TERCERO.SUCURSAL=REQUISICION.SUCURSAL WHERE REQUISICION.COMPANIA=:COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN COD_REQUISICION IS NULL THEN ' ' ELSE UPPER(COD_REQUISICION) END)  LIKE UPPER(:COD_REQUISICION || '%')  AND (CASE WHEN ORDENDESUMINISTRO IS NULL THEN ' ' ELSE UPPER(ORDENDESUMINISTRO) END)  LIKE UPPER(:ORDENDESUMINISTRO || '%')  AND (CASE WHEN COD_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(COD_ACTIVIDAD) END)  LIKE UPPER(:COD_ACTIVIDAD || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN COD_CLACONTRATO IS NULL THEN ' ' ELSE UPPER(COD_CLACONTRATO) END)  LIKE UPPER(:COD_CLACONTRATO || '%')  AND (CASE WHEN COD_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_CONTRATO) END)  LIKE UPPER(:COD_CONTRATO || '%')  AND (CASE WHEN NUMOFICIO IS NULL THEN ' ' ELSE UPPER(NUMOFICIO) END)  LIKE UPPER(:NUMOFICIO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALORESTIMADO IS NULL THEN ' ' ELSE UPPER(VALORESTIMADO) END)  LIKE UPPER(:VALORESTIMADO || '%')  AND (CASE WHEN VALORREAL IS NULL THEN ' ' ELSE UPPER(VALORREAL) END)  LIKE UPPER(:VALORREAL || '%')  AND (CASE WHEN FECHAREQUISICION IS NULL THEN ' ' ELSE UPPER(FECHAREQUISICION) END)  LIKE UPPER(:FECHAREQUISICION || '%')  AND (CASE WHEN VIABILIDAD IS NULL THEN ' ' ELSE UPPER(VIABILIDAD) END)  LIKE UPPER(:VIABILIDAD || '%')  AND (CASE WHEN RUBRO IS NULL THEN ' ' ELSE UPPER(RUBRO) END)  LIKE UPPER(:RUBRO || '%')  AND (CASE WHEN DISPONIBILIDAD IS NULL THEN ' ' ELSE UPPER(DISPONIBILIDAD) END)  LIKE UPPER(:DISPONIBILIDAD || '%')  AND (CASE WHEN VALORDISPONIBILIDAD IS NULL THEN ' ' ELSE UPPER(VALORDISPONIBILIDAD) END)  LIKE UPPER(:VALORDISPONIBILIDAD || '%')  AND (CASE WHEN CLASEGASTO IS NULL THEN ' ' ELSE UPPER(CLASEGASTO) END)  LIKE UPPER(:CLASEGASTO || '%')  AND (CASE WHEN VACIA IS NULL THEN ' ' ELSE UPPER(VACIA) END)  LIKE UPPER(:VACIA || '%')  AND (CASE WHEN DEFINIRCONTRATACION IS NULL THEN ' ' ELSE UPPER(DEFINIRCONTRATACION) END)  LIKE UPPER(:DEFINIRCONTRATACION || '%')  AND (CASE WHEN RUBROCOMPRAS IS NULL THEN ' ' ELSE UPPER(RUBROCOMPRAS) END)  LIKE UPPER(:RUBROCOMPRAS || '%')  AND (CASE WHEN REQUISICIONES IS NULL THEN ' ' ELSE UPPER(REQUISICIONES) END)  LIKE UPPER(:REQUISICIONES || '%')  AND (CASE WHEN REQUISIONES IS NULL THEN ' ' ELSE UPPER(REQUISIONES) END)  LIKE UPPER(:REQUISIONES || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER(:CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER(:DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER(:MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER(:DATE_MODIFIED || '%')  AND (CASE WHEN NOMACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMACTIVIDAD) END)  LIKE UPPER(:NOMACTIVIDAD || '%')  AND (CASE WHEN NOMRESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMRESPONSABLE) END)  LIKE UPPER( '%' || :NOMRESPONSABLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_REQUISICION":"$COD_REQUISICION(type:long)","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO(type:long)","COD_ACTIVIDAD":"$COD_ACTIVIDAD(type:long)","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","COD_CLACONTRATO":"$COD_CLACONTRATO(type:long)","COD_CONTRATO":"$COD_CONTRATO(type:long)","NUMOFICIO":"$NUMOFICIO","DESCRIPCION":"$DESCRIPCION","VALORESTIMADO":"$VALORESTIMADO","VALORREAL":"$VALORREAL","FECHAREQUISICION":"$FECHAREQUISICION","VIABILIDAD":"$VIABILIDAD","RUBRO":"$RUBRO","DISPONIBILIDAD":"$DISPONIBILIDAD(type:long)","VALORDISPONIBILIDAD":"$VALORDISPONIBILIDAD","CLASEGASTO":"$CLASEGASTO","VACIA":"$VACIA(type:boolean)","DEFINIRCONTRATACION":"$DEFINIRCONTRATACION(type:boolean)","RUBROCOMPRAS":"$RUBROCOMPRAS","REQUISICIONES":"$REQUISICIONES","REQUISIONES":"$REQUISIONES","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMACTIVIDAD":"$NOMACTIVIDAD","NOMRESPONSABLE":"$NOMRESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="ORDENDESUMINISTRO" sqlType="STRING"/>
		<param name="COD_ACTIVIDAD" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COD_CLACONTRATO" sqlType="STRING"/>
		<param name="COD_CONTRATO" sqlType="STRING"/>
		<param name="NUMOFICIO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORESTIMADO" sqlType="STRING"/>
		<param name="VALORREAL" sqlType="STRING"/>
		<param name="FECHAREQUISICION" sqlType="STRING"/>
		<param name="VIABILIDAD" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="DISPONIBILIDAD" sqlType="STRING"/>
		<param name="VALORDISPONIBILIDAD" sqlType="STRING"/>
		<param name="CLASEGASTO" sqlType="STRING"/>
		<param name="VACIA" sqlType="STRING"/>
		<param name="DEFINIRCONTRATACION" sqlType="STRING"/>
		<param name="RUBROCOMPRAS" sqlType="STRING"/>
		<param name="REQUISICIONES" sqlType="STRING"/>
		<param name="REQUISIONES" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="NOMACTIVIDAD" sqlType="STRING"/>
		<param name="NOMRESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="requisiciones/listadepropuestas/pag">
		<call-query href="getRequisicionesPagListaDePropuestasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="ORDENDESUMINISTRO" query-param="ORDENDESUMINISTRO"/>
			<with-param name="COD_ACTIVIDAD" query-param="COD_ACTIVIDAD"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
