		<sql>INSERT INTO REQUISICION (CLASEGASTO, COD_ACTIVIDAD, COD_CLACONTRATO, COD_CONTRATO, COD_REQUISICION, COMPANIA, CREATED_BY, DATE_CREATED, DEFINIRCONTRATACION, DEPENDENCIA, DESCRIPCION, DISPONIBILIDAD, FECHAREQUISICION, NUMOFICIO, ORDENDESUMINISTRO, REQUISICIONES, REQUISIONES, RESPONSABLE, RUBRO, RUBROCOMPRAS, SUCURSAL, VACIA, VALORDISPONIBILIDAD, VALORESTIMADO, VALORREAL, VIABILIDAD) VALUES (:CLASEGASTO, :COD_ACTIVIDAD, :COD_CLACONTRATO, :COD_CONTRATO, :COD_REQUISICION, :COMPANIA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :DEFINIRCONTRATACION, :DEPENDENCIA, :DESCRIPCION, :DISPONIBILIDAD, TO_DATE(:FECHAREQUISICION,'DD/MM/YYYY HH24:MI:SS'), :NUMOFICIO, :ORDENDESUMINISTRO, :REQUISICIONES, :REQUISIONES, :RESPONSABLE, :RUBRO, :RUBROCOMPRAS, :SUCURSAL, :VACIA, :VALORDISPONIBILIDAD, :VALORESTIMADO, :VALORREAL, :VIABILIDAD)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COD_REQUISICION":"$COD_REQUISICION(type:long)","KEY_COMPANIA":"$COMPANIA"}]}}		</result>
