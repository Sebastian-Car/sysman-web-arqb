	<query id="updateRequisicionesSolicitudDeCotizaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE REQUISICION SET COMPANIA=:COMPANIA, COD_REQUISICION=:COD_REQUISICION, FECHAREQUISICION=TO_DATE(:FECHAREQUISICION,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, VALORESTIMADO=:VALORESTIMADO, DEPENDENCIA=:DEPENDENCIA, RESPONSABLE=:RESPONSABLE, REQUISICIONES=:REQUISICIONES, COD_ACTIVIDAD=:COD_ACTIVIDAD, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE REQUISICION.COD_REQUISICION= :KEY_COD_REQUISICION AND REQUISICION.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

