	<query id="getRequisicionesLecturaDePropuestasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  REQUISICION.COMPANIA,REQUISICION.COD_REQUISICION,(TO_CHAR(REQUISICION.FECHAREQUISICION,'DD/MM/YYYY HH24:MI:SS')) FECHAREQUISICION, REQUISICION.DESCRIPCION, REQUISICION.VALORESTIMADO, REQUISICION.DEPENDENCIA , REQUISICION.RESPONSABLE, REQUISICION.REQUISICIONES, REQUISICION.COD_ACTIVIDAD,(TO_CHAR(REQUISICION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, REQUISICION.CREATED_BY, REQUISICION.MODIFIED_BY,(TO_CHAR(REQUISICION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TERCERO.NOMBRE NOMRESPONSABLE, ACTIVIDAD.NOMBRE NOMACTIVIDAD  FROM REQUISICION LEFT JOIN ACTIVIDAD ON REQUISICION.COD_ACTIVIDAD=ACTIVIDAD.COD_ACTIVIDAD LEFT JOIN TERCERO ON TERCERO.COMPANIA =REQUISICION.COMPANIA AND TERCERO.NIT =REQUISICION.RESPONSABLE AND TERCERO.SUCURSAL =REQUISICION.SUCURSAL WHERE REQUISICION.COMPANIA =:KEY_COMPANIA AND REQUISICION.COD_REQUISICION =:KEY_COD_REQUISICION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_REQUISICION":"$COD_REQUISICION(type:long)","FECHAREQUISICION":"$FECHAREQUISICION","DESCRIPCION":"$DESCRIPCION","VALORESTIMADO":"$VALORESTIMADO","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","REQUISICIONES":"$REQUISICIONES","COD_ACTIVIDAD":"$COD_ACTIVIDAD(type:long)","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMRESPONSABLE":"$NOMRESPONSABLE","NOMACTIVIDAD":"$NOMACTIVIDAD"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>

	</query>
