	<query id="insertRequisicionesSolicitudDeCotizaciones" keyColumns="COD_REQUISICION,COMPANIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO REQUISICION (VALORESTIMADO, SUCURSAL, COD_ACTIVIDAD, RESPONSABLE, COMPANIA, DEPENDENCIA, DESCRIPCION, COD_REQUISICION, FECHAREQUISICION, DATE_CREATED, CREATED_BY) VALUES (:VALORESTIMADO, :SUCURSAL, :COD_ACTIVIDAD, :RESPONSABLE, :COMPANIA, :DEPENDENCIA, :DESCRIPCION, :COD_REQUISICION, TO_DATE(:FECHAREQUISICION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
