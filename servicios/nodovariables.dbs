<data name="nodovariables" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNodovariablesCodNodProcEtiquetaPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, CODIGO_NODO, CODIGO_PROCESO, ETIQUETA  FROM NODO_VARIABLES WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND CODIGO_PROCESO = :CODIGO_PROCESO AND ESTADO = :ESTADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CODIGO_NODO":"$CODIGO_NODO","CODIGO_PROCESO":"$CODIGO_PROCESO","ETIQUETA":"$ETIQUETA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGO_PROCESO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodovariables/codnodprocetiquetaporcia">
		<call-query href="getNodovariablesCodNodProcEtiquetaPorCiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_PROCESO" query-param="CODIGO_PROCESO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getNodovariablesCodetiquetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO ,ETIQUETA  FROM NODO_VARIABLES WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO_NODO = :NODO AND ESTADO IN(:ESTADO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","ETIQUETA":"$ETIQUETA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodovariables/codetiqueta">
		<call-query href="getNodovariablesCodetiquetaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getNodovariablesTipodatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_DATO  FROM NODO_VARIABLES WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO_NODO = :NODO AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_DATO":"$TIPO_DATO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodovariables/tipodato">
		<call-query href="getNodovariablesTipodatoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getNodovariablesAdjuntoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ADJUNTO  FROM NODO_VARIABLES WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO_NODO = :NODO AND CODIGO = :VARIABLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ADJUNTO":"$ADJUNTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="VARIABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodovariables/adjunto">
		<call-query href="getNodovariablesAdjuntoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="VARIABLE" query-param="VARIABLE"/>

		</call-query>
	</resource>
	<query id="insertNodovariablesVardocmenu" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NODO_VARIABLES   (     COMPANIA ,     CODIGO_PROCESO ,     CODIGO_NODO ,     CODIGO ,     TIPO_DATO ,     ETIQUETA ,     OBLIGATORIO ,     MANEJA_ADJUNTO ,     ESTADO ,     MANEJA_RADICADO ,     ADJUNTO ,     CREATED_BY ,     DATE_CREATED   ) SELECT COMPANIA ,   CODIGO_PROCESO ,   CODIGO ,   (:ETIQUETA) ,   8 ,   :ETIQUETA ,   -1 ,   -1 ,   CASE     WHEN MENU IS NULL     THEN 5     ELSE 4   END ,   0 ,   RUTA ,   CREATED_BY ,   SYSDATE FROM NODOS WHERE COMPANIA     = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO         = :NODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="nodovariables/vardocmenu">
		<call-query href="insertNodovariablesVardocmenu">
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>

		</call-query>
	</resource>
	<query id="deleteNodovariablesVariablesnodo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NODO_VARIABLES WHERE COMPANIA       = :COMPANIA   AND CODIGO_PROCESO = :PROCESO   AND CODIGO_NODO    = :NODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="nodovariables/variablesnodo">
		<call-query href="deleteNodovariablesVariablesnodo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>

		</call-query>
	</resource>
	<query id="insertNodovariables" keyColumns="COMPANIA,CODIGO,CODIGO_NODO,CODIGO_PROCESO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NODO_VARIABLES (COMPANIA, CODIGO, CODIGO_PROCESO, CODIGO_NODO, TIPO_DATO, ETIQUETA, OBLIGATORIO, MANEJA_ADJUNTO, ADJUNTO_OBLIGATORIO, ESTADO, MANEJA_RADICADO, ADJUNTO, TABLA, COD_REG_TABLA, SUC_REG_TABLA, ANO_REG_TABLA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :CODIGO_PROCESO, :CODIGO_NODO, :TIPO_DATO, :ETIQUETA, :OBLIGATORIO, :MANEJA_ADJUNTO, :ADJUNTO_OBLIGATORIO, :ESTADO, :MANEJA_RADICADO, :ADJUNTO, :TABLA, :COD_REG_TABLA, :SUC_REG_TABLA, :ANO_REG_TABLA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO","KEY_CODIGO_NODO":"$CODIGO_NODO","KEY_CODIGO_PROCESO":"$CODIGO_PROCESO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGO_PROCESO" sqlType="STRING"/>
		<param name="CODIGO_NODO" sqlType="STRING"/>
		<param name="TIPO_DATO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGATORIO" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_ADJUNTO" sqlType="STRING"/>
		<param defaultValue="0" name="ADJUNTO_OBLIGATORIO" sqlType="STRING"/>
		<param defaultValue="4" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="0" name="MANEJA_RADICADO" sqlType="STRING"/>
		<param defaultValue="" name="ADJUNTO" sqlType="STRING"/>
		<param defaultValue="" name="TABLA" sqlType="STRING"/>
		<param defaultValue="" name="COD_REG_TABLA" sqlType="STRING"/>
		<param defaultValue="" name="SUC_REG_TABLA" sqlType="STRING"/>
		<param defaultValue="" name="ANO_REG_TABLA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="nodovariables">
		<call-query href="insertNodovariables">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_PROCESO" query-param="CODIGO_PROCESO"/>
			<with-param name="CODIGO_NODO" query-param="CODIGO_NODO"/>
			<with-param name="TIPO_DATO" query-param="TIPO_DATO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="MANEJA_ADJUNTO" query-param="MANEJA_ADJUNTO"/>
			<with-param name="ADJUNTO_OBLIGATORIO" query-param="ADJUNTO_OBLIGATORIO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="MANEJA_RADICADO" query-param="MANEJA_RADICADO"/>
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>
			<with-param name="TABLA" query-param="TABLA"/>
			<with-param name="COD_REG_TABLA" query-param="COD_REG_TABLA"/>
			<with-param name="SUC_REG_TABLA" query-param="SUC_REG_TABLA"/>
			<with-param name="ANO_REG_TABLA" query-param="ANO_REG_TABLA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNodovariables" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NODO_VARIABLES WHERE NODO_VARIABLES.COMPANIA= :KEY_COMPANIA AND NODO_VARIABLES.CODIGO= :KEY_CODIGO AND NODO_VARIABLES.CODIGO_NODO= :KEY_CODIGO_NODO AND NODO_VARIABLES.CODIGO_PROCESO= :KEY_CODIGO_PROCESO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CODIGO_NODO" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="nodovariables">
		<call-query href="deleteNodovariables">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CODIGO_NODO" query-param="KEY_CODIGO_NODO"/>
			<with-param name="KEY_CODIGO_PROCESO" query-param="KEY_CODIGO_PROCESO"/>

		</call-query>
	</resource>
	<query id="getNodovariablesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NV.COMPANIA , NV.CODIGO , NV.CODIGO_NODO , NV.CODIGO_PROCESO , NV.ETIQUETA , T2.NOMBRE TIPO_DATO_NOM, T.NOMBRE ESTADO_NOM, ('&lt;#'||NV.CODIGO||'#&gt;') CODIGO_VAR  FROM NODO_VARIABLES NV INNER JOIN TIPOS T ON NV.ESTADO = T.ID INNER JOIN TIPOS T2 ON NV.TIPO_DATO = T2.ID WHERE NV.COMPANIA = :COMPANIA AND NV.CODIGO_PROCESO = :PROCESO AND NV.CODIGO_NODO = :NODO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN TIPO_DATO_NOM IS NULL THEN ' ' ELSE UPPER(TIPO_DATO_NOM) END)  LIKE UPPER( '%' || :TIPO_DATO_NOM || '%')  AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END)  LIKE UPPER( '%' || :ESTADO_NOM || '%')  AND (CASE WHEN CODIGO_VAR IS NULL THEN ' ' ELSE UPPER(CODIGO_VAR) END)  LIKE UPPER( '%' || :CODIGO_VAR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CODIGO_NODO":"$CODIGO_NODO","CODIGO_PROCESO":"$CODIGO_PROCESO","ETIQUETA":"$ETIQUETA","TIPO_DATO_NOM":"$TIPO_DATO_NOM","ESTADO_NOM":"$ESTADO_NOM","CODIGO_VAR":"$CODIGO_VAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="TIPO_DATO_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="CODIGO_VAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nodovariables">
		<call-query href="getNodovariablesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="TIPO_DATO_NOM" query-param="TIPO_DATO_NOM"/>
			<with-param name="ESTADO_NOM" query-param="ESTADO_NOM"/>
			<with-param name="CODIGO_VAR" query-param="CODIGO_VAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNodovariablesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NV.COMPANIA , NV.CODIGO , NV.CODIGO_NODO , NV.CODIGO_PROCESO , NV.ETIQUETA , T2.NOMBRE TIPO_DATO_NOM, T.NOMBRE ESTADO_NOM, ('&lt;#'||NV.CODIGO||'#&gt;') CODIGO_VAR  FROM NODO_VARIABLES NV INNER JOIN TIPOS T ON NV.ESTADO = T.ID INNER JOIN TIPOS T2 ON NV.TIPO_DATO = T2.ID WHERE NV.COMPANIA = :COMPANIA AND NV.CODIGO_PROCESO = :PROCESO AND NV.CODIGO_NODO = :NODO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN TIPO_DATO_NOM IS NULL THEN ' ' ELSE UPPER(TIPO_DATO_NOM) END)  LIKE UPPER( '%' || :TIPO_DATO_NOM || '%')  AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END)  LIKE UPPER( '%' || :ESTADO_NOM || '%')  AND (CASE WHEN CODIGO_VAR IS NULL THEN ' ' ELSE UPPER(CODIGO_VAR) END)  LIKE UPPER( '%' || :CODIGO_VAR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="TIPO_DATO_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="CODIGO_VAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodovariables/numero">
		<call-query href="getNodovariablesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="TIPO_DATO_NOM" query-param="TIPO_DATO_NOM"/>
			<with-param name="ESTADO_NOM" query-param="ESTADO_NOM"/>
			<with-param name="CODIGO_VAR" query-param="CODIGO_VAR"/>

		</call-query>
	</resource>
	<query id="getNodovariablesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NODO_VARIABLES.COMPANIA , NODO_VARIABLES.CODIGO , ('&lt;#' ||NODO_VARIABLES.CODIGO ||'#&gt;') CODIGO_VAR, NODO_VARIABLES.CODIGO_NODO , NODO_VARIABLES.CODIGO_PROCESO , NODOS.NOMBRE NODO_NOM, PROCESOS.NOMBRE PROCESO_NOM, NODO_VARIABLES.TIPO_DATO , NODO_VARIABLES.ETIQUETA ,(CASE NODO_VARIABLES.OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGATORIO,(CASE NODO_VARIABLES.MANEJA_ADJUNTO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_ADJUNTO,(CASE NODO_VARIABLES.ADJUNTO_OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) ADJUNTO_OBLIGATORIO, NODO_VARIABLES.ESTADO , NODO_VARIABLES.ADJUNTO, NODO_VARIABLES.TABLA, NODO_VARIABLES.COD_REG_TABLA, NODO_VARIABLES.SUC_REG_TABLA, NODO_VARIABLES.ANO_REG_TABLA,(CASE NODO_VARIABLES.MANEJA_RADICADO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RADICADO, NODO_VARIABLES.CREATED_BY , NODO_VARIABLES.MODIFIED_BY ,(TO_CHAR(NODO_VARIABLES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NODO_VARIABLES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM NODO_VARIABLES INNER JOIN NODOS ON NODO_VARIABLES.COMPANIA = NODOS.COMPANIA AND NODO_VARIABLES.CODIGO_PROCESO = NODOS.CODIGO_PROCESO AND NODO_VARIABLES.CODIGO_NODO = NODOS.CODIGO INNER JOIN PROCESOS ON NODO_VARIABLES.COMPANIA = PROCESOS.COMPANIA AND NODO_VARIABLES.CODIGO_PROCESO = PROCESOS.CODIGO WHERE NODO_VARIABLES.COMPANIA= :KEY_COMPANIA AND NODO_VARIABLES.CODIGO= :KEY_CODIGO AND NODO_VARIABLES.CODIGO_NODO= :KEY_CODIGO_NODO AND NODO_VARIABLES.CODIGO_PROCESO= :KEY_CODIGO_PROCESO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","CODIGO_VAR":"$CODIGO_VAR","CODIGO_NODO":"$CODIGO_NODO","CODIGO_PROCESO":"$CODIGO_PROCESO","NODO_NOM":"$NODO_NOM","PROCESO_NOM":"$PROCESO_NOM","TIPO_DATO":"$TIPO_DATO(type:integer)","ETIQUETA":"$ETIQUETA","OBLIGATORIO":"$OBLIGATORIO(type:boolean)","MANEJA_ADJUNTO":"$MANEJA_ADJUNTO(type:boolean)","ADJUNTO_OBLIGATORIO":"$ADJUNTO_OBLIGATORIO(type:boolean)","ESTADO":"$ESTADO(type:integer)","ADJUNTO":"$ADJUNTO","TABLA":"$TABLA(type:integer)","COD_REG_TABLA":"$COD_REG_TABLA","SUC_REG_TABLA":"$SUC_REG_TABLA","ANO_REG_TABLA":"$ANO_REG_TABLA(type:integer)","MANEJA_RADICADO":"$MANEJA_RADICADO(type:boolean)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CODIGO_NODO" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nodovariables/data">
		<call-query href="getNodovariablesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CODIGO_NODO" query-param="KEY_CODIGO_NODO"/>
			<with-param name="KEY_CODIGO_PROCESO" query-param="KEY_CODIGO_PROCESO"/>

		</call-query>
	</resource>
	<query id="updateNodovariables" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NODO_VARIABLES SET CODIGO=:CODIGO, TIPO_DATO=:TIPO_DATO, ETIQUETA=:ETIQUETA, OBLIGATORIO=:OBLIGATORIO, MANEJA_ADJUNTO=:MANEJA_ADJUNTO, ADJUNTO_OBLIGATORIO=:ADJUNTO_OBLIGATORIO, ESTADO=:ESTADO, MANEJA_RADICADO=:MANEJA_RADICADO, ADJUNTO=:ADJUNTO, TABLA=:TABLA, COD_REG_TABLA=:COD_REG_TABLA, SUC_REG_TABLA=:SUC_REG_TABLA, ANO_REG_TABLA=:ANO_REG_TABLA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NODO_VARIABLES.COMPANIA= :KEY_COMPANIA AND NODO_VARIABLES.CODIGO= :KEY_CODIGO AND NODO_VARIABLES.CODIGO_NODO= :KEY_CODIGO_NODO AND NODO_VARIABLES.CODIGO_PROCESO= :KEY_CODIGO_PROCESO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO_DATO" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="OBLIGATORIO" sqlType="STRING"/>
		<param name="MANEJA_ADJUNTO" sqlType="STRING"/>
		<param name="ADJUNTO_OBLIGATORIO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="MANEJA_RADICADO" sqlType="STRING"/>
		<param name="ADJUNTO" sqlType="STRING"/>
		<param name="TABLA" sqlType="STRING"/>
		<param name="COD_REG_TABLA" sqlType="STRING"/>
		<param name="SUC_REG_TABLA" sqlType="STRING"/>
		<param name="ANO_REG_TABLA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CODIGO_NODO" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="nodovariables">
