<data name="departamentos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDepartamentosPorPaisQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT CODIGO, NOMBRE, PAIS  FROM DEPARTAMENTO WHERE PAIS = :PAIS ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PAIS":"$PAIS"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/porpais">
		<call-query href="getDepartamentosPorPaisQuery">
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="getDepartamentosPagCiudadesPorPaisQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CIUDAD.NOMBRE NOMBRECIUDAD, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO  FROM DEPARTAMENTO INNER JOIN CIUDAD ON DEPARTAMENTO.CODIGO = CIUDAD.DEPARTAMENTO AND DEPARTAMENTO.PAIS = CIUDAD.PAIS WHERE DEPARTAMENTO.PAIS = :PAIS ORDER BY CIUDAD.NOMBRE) WHERE (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END)  LIKE UPPER( '%' || :NOMBRECIUDAD || '%')  AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END)  LIKE UPPER( '%' || :NOMBREDEPARTAMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRECIUDAD":"$NOMBRECIUDAD","NOMBREDEPARTAMENTO":"$NOMBREDEPARTAMENTO"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="departamentos/ciudadesporpais/pag">
		<call-query href="getDepartamentosPagCiudadesPorPaisQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDepartamentosNumCiudadesPorPaisQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CIUDAD.NOMBRE NOMBRECIUDAD, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO  FROM DEPARTAMENTO INNER JOIN CIUDAD ON DEPARTAMENTO.CODIGO = CIUDAD.DEPARTAMENTO AND DEPARTAMENTO.PAIS = CIUDAD.PAIS WHERE DEPARTAMENTO.PAIS = :PAIS ORDER BY CIUDAD.NOMBRE) WHERE (CASE WHEN NOMBRECIUDAD IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDAD) END)  LIKE UPPER( '%' || :NOMBRECIUDAD || '%')  AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END)  LIKE UPPER( '%' || :NOMBREDEPARTAMENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="NOMBRECIUDAD" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/ciudadesporpais/num">
		<call-query href="getDepartamentosNumCiudadesPorPaisQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="NOMBRECIUDAD" query-param="NOMBRECIUDAD"/>
			<with-param name="NOMBREDEPARTAMENTO" query-param="NOMBREDEPARTAMENTO"/>

		</call-query>
	</resource>
	<query id="getDepartamentosPorPaisYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE  FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS = :PAIS AND DEPARTAMENTO.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/porpaisycodigo">
		<call-query href="getDepartamentosPorPaisYCodigoQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getDepartamentosTodosPorPaisQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO ,NOMBRE  FROM DEPARTAMENTO WHERE PAIS =:PAIS ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/todosporpais">
		<call-query href="getDepartamentosTodosPorPaisQuery">
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="getDepartamentosDepartporpaisQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE  FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS = :PAIS ORDER BY DEPARTAMENTO.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/departporpais">
		<call-query href="getDepartamentosDepartporpaisQuery">
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="getDepartamentosPagTodosPorPaisiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE  FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS = :PAIS ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="departamentos/todosporpaisini/pag">
		<call-query href="getDepartamentosPagTodosPorPaisiniQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDepartamentosNumTodosPorPaisiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE  FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS = :PAIS ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/todosporpaisini/num">
		<call-query href="getDepartamentosNumTodosPorPaisiniQuery">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getDepartamentosNombreDptoorigenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE DEPTOORIGENNOMBRE  FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS = :PAIS ORDER BY DEPARTAMENTO.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DEPTOORIGENNOMBRE":"$DEPTOORIGENNOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/nombredptoorigen">
		<call-query href="getDepartamentosNombreDptoorigenQuery">
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="insertDepartamentos" keyColumns="PAIS,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DEPARTAMENTO (PAIS, CODIGO, NOMBRE, SIGLA, CODIGODANE, REGION, CREATED_BY, DATE_CREATED) VALUES (:PAIS, :CODIGO, :NOMBRE, :SIGLA, :CODIGODANE, :REGION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_PAIS":"$PAIS","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="SIGLA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGODANE" sqlType="STRING"/>
		<param defaultValue="" name="REGION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="departamentos">
		<call-query href="insertDepartamentos">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="CODIGODANE" query-param="CODIGODANE"/>
			<with-param name="REGION" query-param="REGION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteDepartamentos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS= :KEY_PAIS AND DEPARTAMENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="departamentos">
		<call-query href="deleteDepartamentos">
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getDepartamentosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEPARTAMENTO.PAIS PAIS, PAISES.NOMBRE NOMBRE_PAIS, DEPARTAMENTO.CODIGO CODIGO, DEPARTAMENTO.NOMBRE, DEPARTAMENTO.SIGLA, DEPARTAMENTO.CODIGODANE CODIGO_DANE, DEPARTAMENTO.REGION  FROM DEPARTAMENTO LEFT JOIN PAISES ON DEPARTAMENTO.PAIS=PAISES.PAIS ORDER BY PAISES.NOMBRE, DEPARTAMENTO.NOMBRE) WHERE (CASE WHEN NOMBRE_PAIS IS NULL THEN ' ' ELSE UPPER(NOMBRE_PAIS) END)  LIKE UPPER( '%' || :NOMBRE_PAIS || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SIGLA IS NULL THEN ' ' ELSE UPPER(SIGLA) END)  LIKE UPPER( '%' || :SIGLA || '%')  AND (CASE WHEN CODIGO_DANE IS NULL THEN ' ' ELSE UPPER(CODIGO_DANE) END)  LIKE UPPER( '%' || :CODIGO_DANE || '%')  AND (CASE WHEN REGION IS NULL THEN ' ' ELSE UPPER(REGION) END)  LIKE UPPER(:REGION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","NOMBRE_PAIS":"$NOMBRE_PAIS","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SIGLA":"$SIGLA","CODIGO_DANE":"$CODIGO_DANE","REGION":"$REGION"}]}}		</result>
		<param name="NOMBRE_PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="CODIGO_DANE" sqlType="STRING"/>
		<param name="REGION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="departamentos">
		<call-query href="getDepartamentosPaginaQuery">
			<with-param name="NOMBRE_PAIS" query-param="NOMBRE_PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="CODIGO_DANE" query-param="CODIGO_DANE"/>
			<with-param name="REGION" query-param="REGION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDepartamentosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DEPARTAMENTO.PAIS PAIS, PAISES.NOMBRE NOMBRE_PAIS, DEPARTAMENTO.CODIGO CODIGO, DEPARTAMENTO.NOMBRE, DEPARTAMENTO.SIGLA, DEPARTAMENTO.CODIGODANE CODIGO_DANE, DEPARTAMENTO.REGION  FROM DEPARTAMENTO LEFT JOIN PAISES ON DEPARTAMENTO.PAIS=PAISES.PAIS ORDER BY PAISES.NOMBRE, DEPARTAMENTO.NOMBRE) WHERE (CASE WHEN NOMBRE_PAIS IS NULL THEN ' ' ELSE UPPER(NOMBRE_PAIS) END)  LIKE UPPER( '%' || :NOMBRE_PAIS || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SIGLA IS NULL THEN ' ' ELSE UPPER(SIGLA) END)  LIKE UPPER( '%' || :SIGLA || '%')  AND (CASE WHEN CODIGO_DANE IS NULL THEN ' ' ELSE UPPER(CODIGO_DANE) END)  LIKE UPPER( '%' || :CODIGO_DANE || '%')  AND (CASE WHEN REGION IS NULL THEN ' ' ELSE UPPER(REGION) END)  LIKE UPPER( '%' || :REGION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NOMBRE_PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="CODIGO_DANE" sqlType="STRING"/>
		<param name="REGION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/numero">
		<call-query href="getDepartamentosNumeroQuery">
			<with-param name="NOMBRE_PAIS" query-param="NOMBRE_PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="CODIGO_DANE" query-param="CODIGO_DANE"/>
			<with-param name="REGION" query-param="REGION"/>

		</call-query>
	</resource>
	<query id="getDepartamentosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPARTAMENTO.PAIS, DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE, DEPARTAMENTO.SIGLA, DEPARTAMENTO.CODIGODANE, DEPARTAMENTO.REGION, DEPARTAMENTO.CREATED_BY, DEPARTAMENTO.MODIFIED_BY,(TO_CHAR(DEPARTAMENTO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DEPARTAMENTO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS= :KEY_PAIS AND DEPARTAMENTO.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAIS":"$PAIS","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SIGLA":"$SIGLA","CODIGODANE":"$CODIGODANE","REGION":"$REGION","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/data">
		<call-query href="getDepartamentosRegistroQuery">
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateDepartamentos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DEPARTAMENTO SET PAIS=:PAIS, CODIGO=:CODIGO, NOMBRE=:NOMBRE, SIGLA=:SIGLA, CODIGODANE=:CODIGODANE, REGION=:REGION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE DEPARTAMENTO.PAIS= :KEY_PAIS AND DEPARTAMENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="CODIGODANE" sqlType="STRING"/>
		<param name="REGION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_PAIS" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="departamentos">
		<call-query href="updateDepartamentos">
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="CODIGODANE" query-param="CODIGODANE"/>
			<with-param name="REGION" query-param="REGION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_PAIS" query-param="KEY_PAIS"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getDepartamentosNombreDptodestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEPARTAMENTO.CODIGO, DEPARTAMENTO.NOMBRE DEPTODESTINONOMBRE  FROM DEPARTAMENTO WHERE DEPARTAMENTO.PAIS = :PAIS ORDER BY DEPARTAMENTO.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DEPTODESTINONOMBRE":"$DEPTODESTINONOMBRE"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/nombredptodestino">
		<call-query href="getDepartamentosNombreDptodestinoQuery">
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="getDepartamentosDeparteducbasicQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT CODIGO, NOMBRE NOMBREDEPARTAMENTO, PAIS  FROM DEPARTAMENTO WHERE PAIS = :PAIS ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREDEPARTAMENTO":"$NOMBREDEPARTAMENTO","PAIS":"$PAIS"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="departamentos/departeducbasic">
		<call-query href="getDepartamentosDeparteducbasicQuery">
			<with-param name="PAIS" query-param="PAIS"/>

		</call-query>
	</resource>
	<query id="getDepartamentosTodoslosdepartamentosQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(CONCAT(CODIGO, ' '), NOMBRE) AS CODIGO, NOMBRE FROM DEPARTAMENTO ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="departamentos/todoslosdepartamentos">
		<call-query href="getDepartamentosTodoslosdepartamentosQuery">
 
		</call-query>
	</resource>

</data>