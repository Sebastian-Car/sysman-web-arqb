	<query id="updatePolizasIndicadorImpreso" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE POLIZAS SET INDIMPRESION         =:INDIMPRESION,   DATE_MODIFIED          =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY            =:MODIFIED_BY WHERE POLIZAS.COMPANIA   = :COMPANIA AND POLIZAS.CLASEORDEN   = :CLASEORDEN AND POLIZAS.ORDENDECOMPRA= :ORDENDECOMPRA AND POLIZAS.CODIGO       = :CODIGO AND POLIZAS.CONSECUTIVO  = :CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="INDIMPRESION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
