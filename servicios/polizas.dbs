			<with-param name="FECHAAPROBACIONCUMPLIMIENTO" query-param="FECHAAPROBACIONCUMPLIMIENTO"/>
			<with-param name="FECHAAPROBACIONRESPONSABILIDAD" query-param="FECHAAPROBACIONRESPONSABILIDAD"/>
			<with-param name="VALORASEGURADO" query-param="VALORASEGURADO"/>
			<with-param name="NOMBREASEGURADORA" query-param="NOMBREASEGURADORA"/>
			<with-param name="TIPODESC" query-param="TIPODESC"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPolizasNumListasubpolizasmodificacionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  POLIZAS.COMPANIA, POLIZAS.CLASEORDEN, POLIZAS.ORDENDECOMPRA, POLIZAS.CODIGO, POLIZAS.CONSECUTIVO, POLIZAS.VLRANTERIOR, POLIZAS.VLRACTUAL, POLIZAS.OBSERVACIONES,(TO_CHAR(POLIZAS.FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAEXPEDICION,(TO_CHAR(POLIZAS.VIGENCIADESDE,'DD/MM/YYYY HH24:MI:SS')) VIGENCIADESDE,(TO_CHAR(POLIZAS.VIGENCIAHASTA,'DD/MM/YYYY HH24:MI:SS')) VIGENCIAHASTA, POLIZAS.VALOR, POLIZAS.ESTADO, POLIZAS.TIPO,(TO_CHAR(POLIZAS.FECHAAPROBACIONCUMPLIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONCUMPLIMIENTO,(TO_CHAR(POLIZAS.FECHAAPROBACIONRESPONSABILIDAD,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONRESPONSABILIDAD, POLIZAS.ASEGURADORA, POLIZAS.VALORASEGURADO, ASEGURADORA.NOMBRE NOMBREASEGURADORA, TIPOPOLIZA.DESCRIPCION TIPODESC  FROM POLIZAS INNER JOIN ASEGURADORA ON POLIZAS.COMPANIA = ASEGURADORA.COMPANIA AND POLIZAS.ASEGURADORA = ASEGURADORA.NITASEGURADORA AND POLIZAS.SUCURSAL = ASEGURADORA.SUCURSAL INNER JOIN TIPOPOLIZA ON POLIZAS.TIPO = TIPOPOLIZA.CODIGO WHERE POLIZAS.COMPANIA = :COMPANIA AND POLIZAS.CLASEORDEN = :TIPOCONTRATO AND POLIZAS.ORDENDECOMPRA = :ORDEN ORDER BY POLIZAS.CONSECUTIVO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN VLRANTERIOR IS NULL THEN ' ' ELSE UPPER(VLRANTERIOR) END)  LIKE UPPER(:VLRANTERIOR || '%')  AND (CASE WHEN VLRACTUAL IS NULL THEN ' ' ELSE UPPER(VLRACTUAL) END)  LIKE UPPER(:VLRACTUAL || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER(:OBSERVACIONES || '%')  AND (CASE WHEN FECHAEXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHAEXPEDICION) END)  LIKE UPPER(:FECHAEXPEDICION || '%')  AND (CASE WHEN VIGENCIADESDE IS NULL THEN ' ' ELSE UPPER(VIGENCIADESDE) END)  LIKE UPPER( '%' || :VIGENCIADESDE || '%')  AND (CASE WHEN VIGENCIAHASTA IS NULL THEN ' ' ELSE UPPER(VIGENCIAHASTA) END)  LIKE UPPER( '%' || :VIGENCIAHASTA || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%')  AND (CASE WHEN FECHAAPROBACIONCUMPLIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAAPROBACIONCUMPLIMIENTO) END)  LIKE UPPER( '%' || :FECHAAPROBACIONCUMPLIMIENTO || '%')  AND (CASE WHEN FECHAAPROBACIONRESPONSABILIDAD IS NULL THEN ' ' ELSE UPPER(FECHAAPROBACIONRESPONSABILIDAD) END)  LIKE UPPER(:FECHAAPROBACIONRESPONSABILIDAD || '%')  AND (CASE WHEN VALORASEGURADO IS NULL THEN ' ' ELSE UPPER(VALORASEGURADO) END)  LIKE UPPER( '%' || :VALORASEGURADO || '%')  AND (CASE WHEN NOMBREASEGURADORA IS NULL THEN ' ' ELSE UPPER(NOMBREASEGURADORA) END)  LIKE UPPER( '%' || :NOMBREASEGURADORA || '%')  AND (CASE WHEN TIPODESC IS NULL THEN ' ' ELSE UPPER(TIPODESC) END)  LIKE UPPER( '%' || :TIPODESC || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="VLRANTERIOR" sqlType="STRING"/>
		<param name="VLRACTUAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="FECHAEXPEDICION" sqlType="STRING"/>
		<param name="VIGENCIADESDE" sqlType="STRING"/>
		<param name="VIGENCIAHASTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHAAPROBACIONCUMPLIMIENTO" sqlType="STRING"/>
		<param name="FECHAAPROBACIONRESPONSABILIDAD" sqlType="STRING"/>
		<param name="VALORASEGURADO" sqlType="STRING"/>
		<param name="NOMBREASEGURADORA" sqlType="STRING"/>
		<param name="TIPODESC" sqlType="STRING"/>

	</query>
