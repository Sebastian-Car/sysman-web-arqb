<data name="polizas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPolizasTotalRegistrosPorClaseYOrdenDeCompraQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) REGISTROS  FROM POLIZAS WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"REGISTROS":"$REGISTROS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="polizas/totalregistrosporclaseyordendecompra">
		<call-query href="getPolizasTotalRegistrosPorClaseYOrdenDeCompraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getPolizasPagCodconsecobsporcomnumtipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  POLIZAS.CODIGO, POLIZAS.CONSECUTIVO, TRIM(POLIZAS.OBSERVACIONES) AS OBSERVACIONES  FROM POLIZAS INNER JOIN ORDENDECOMPRA ON POLIZAS.COMPANIA = ORDENDECOMPRA.COMPANIA AND POLIZAS.CLASEORDEN = ORDENDECOMPRA.CLASEORDEN AND POLIZAS.ORDENDECOMPRA = ORDENDECOMPRA.NUMERO WHERE POLIZAS.COMPANIA = :COMPANIA AND NVL(ORDENDECOMPRA.NUMEROAFECTADO,0) = 0 AND ORDENDECOMPRA.NUMERO = :NUMERO AND POLIZAS.TIPO = :TIPO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CONSECUTIVO":"$CONSECUTIVO","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="polizas/codconsecobsporcomnumtipo/pag">
		<call-query href="getPolizasPagCodconsecobsporcomnumtipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPolizasNumCodconsecobsporcomnumtipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  POLIZAS.CODIGO, POLIZAS.CONSECUTIVO, TRIM(POLIZAS.OBSERVACIONES) AS OBSERVACIONES  FROM POLIZAS INNER JOIN ORDENDECOMPRA ON POLIZAS.COMPANIA = ORDENDECOMPRA.COMPANIA AND POLIZAS.CLASEORDEN = ORDENDECOMPRA.CLASEORDEN AND POLIZAS.ORDENDECOMPRA = ORDENDECOMPRA.NUMERO WHERE POLIZAS.COMPANIA = :COMPANIA AND NVL(ORDENDECOMPRA.NUMEROAFECTADO,0) = 0 AND ORDENDECOMPRA.NUMERO = :NUMERO AND POLIZAS.TIPO = :TIPO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="polizas/codconsecobsporcomnumtipo/num">
		<call-query href="getPolizasNumCodconsecobsporcomnumtipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="getPolizasObtenervaloraseguradoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(POLIZAS.VALORASEGURADO,0) VALORASEGURADO  FROM POLIZAS INNER JOIN ORDENDECOMPRA ON POLIZAS.COMPANIA = ORDENDECOMPRA.COMPANIA AND POLIZAS.CLASEORDEN = ORDENDECOMPRA.CLASEORDEN AND POLIZAS.ORDENDECOMPRA = ORDENDECOMPRA.NUMERO WHERE POLIZAS.COMPANIA = :COMPANIA AND NVL(ORDENDECOMPRA.NUMEROAFECTADO,0) = 0 AND POLIZAS.CODIGO = :CODIGO AND ORDENDECOMPRA.NUMERO = :NUMERO AND POLIZAS.TIPO = :TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORASEGURADO":"$VALORASEGURADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="polizas/obtenervalorasegurado">
		<call-query href="getPolizasObtenervaloraseguradoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getPolizasValoraseguradoconnroafectadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(POLIZAS.VALORASEGURADO) VALORASEGURADO  FROM POLIZAS INNER JOIN ORDENDECOMPRA ON POLIZAS.COMPANIA = ORDENDECOMPRA.COMPANIA AND POLIZAS.CLASEORDEN = ORDENDECOMPRA.CLASEORDEN AND POLIZAS.ORDENDECOMPRA = ORDENDECOMPRA.NUMERO WHERE POLIZAS.COMPANIA = :COMPANIA AND ORDENDECOMPRA.NUMEROAFECTADO = :NUMERO AND POLIZAS.CODIGO = :CODIGO AND POLIZAS.TIPO = :TIPO ORDER BY POLIZAS.ORDENDECOMPRA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORASEGURADO":"$VALORASEGURADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="polizas/valoraseguradoconnroafectado">
		<call-query href="getPolizasValoraseguradoconnroafectadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getPolizasPagListasubpolizasmodificacionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  POLIZAS.COMPANIA, POLIZAS.CLASEORDEN, POLIZAS.ORDENDECOMPRA, POLIZAS.CODIGO, POLIZAS.CONSECUTIVO, POLIZAS.VLRANTERIOR, POLIZAS.VLRACTUAL, POLIZAS.OBSERVACIONES,(TO_CHAR(POLIZAS.FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAEXPEDICION,(TO_CHAR(POLIZAS.VIGENCIADESDE,'DD/MM/YYYY HH24:MI:SS')) VIGENCIADESDE,(TO_CHAR(POLIZAS.VIGENCIAHASTA,'DD/MM/YYYY HH24:MI:SS')) VIGENCIAHASTA, POLIZAS.VALOR, POLIZAS.ESTADO, POLIZAS.TIPO,(TO_CHAR(POLIZAS.FECHAAPROBACIONCUMPLIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONCUMPLIMIENTO,(TO_CHAR(POLIZAS.FECHAAPROBACIONRESPONSABILIDAD,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONRESPONSABILIDAD, POLIZAS.ASEGURADORA, POLIZAS.VALORASEGURADO, ASEGURADORA.NOMBRE NOMBREASEGURADORA, TIPOPOLIZA.DESCRIPCION TIPODESC  FROM POLIZAS INNER JOIN ASEGURADORA ON POLIZAS.COMPANIA = ASEGURADORA.COMPANIA AND POLIZAS.ASEGURADORA = ASEGURADORA.NITASEGURADORA AND POLIZAS.SUCURSAL = ASEGURADORA.SUCURSAL INNER JOIN TIPOPOLIZA ON POLIZAS.TIPO = TIPOPOLIZA.CODIGO WHERE POLIZAS.COMPANIA = :COMPANIA AND POLIZAS.CLASEORDEN = :TIPOCONTRATO AND POLIZAS.ORDENDECOMPRA = :ORDEN ORDER BY POLIZAS.CONSECUTIVO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN VLRANTERIOR IS NULL THEN ' ' ELSE UPPER(VLRANTERIOR) END)  LIKE UPPER(:VLRANTERIOR || '%')  AND (CASE WHEN VLRACTUAL IS NULL THEN ' ' ELSE UPPER(VLRACTUAL) END)  LIKE UPPER(:VLRACTUAL || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER(:OBSERVACIONES || '%')  AND (CASE WHEN FECHAEXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHAEXPEDICION) END)  LIKE UPPER(:FECHAEXPEDICION || '%')  AND (CASE WHEN VIGENCIADESDE IS NULL THEN ' ' ELSE UPPER(VIGENCIADESDE) END)  LIKE UPPER( '%' || :VIGENCIADESDE || '%')  AND (CASE WHEN VIGENCIAHASTA IS NULL THEN ' ' ELSE UPPER(VIGENCIAHASTA) END)  LIKE UPPER( '%' || :VIGENCIAHASTA || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%')  AND (CASE WHEN FECHAAPROBACIONCUMPLIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAAPROBACIONCUMPLIMIENTO) END)  LIKE UPPER( '%' || :FECHAAPROBACIONCUMPLIMIENTO || '%')  AND (CASE WHEN FECHAAPROBACIONRESPONSABILIDAD IS NULL THEN ' ' ELSE UPPER(FECHAAPROBACIONRESPONSABILIDAD) END)  LIKE UPPER(:FECHAAPROBACIONRESPONSABILIDAD || '%')  AND (CASE WHEN VALORASEGURADO IS NULL THEN ' ' ELSE UPPER(VALORASEGURADO) END)  LIKE UPPER( '%' || :VALORASEGURADO || '%')  AND (CASE WHEN NOMBREASEGURADORA IS NULL THEN ' ' ELSE UPPER(NOMBREASEGURADORA) END)  LIKE UPPER( '%' || :NOMBREASEGURADORA || '%')  AND (CASE WHEN TIPODESC IS NULL THEN ' ' ELSE UPPER(TIPODESC) END)  LIKE UPPER( '%' || :TIPODESC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","CODIGO":"$CODIGO","CONSECUTIVO":"$CONSECUTIVO","VLRANTERIOR":"$VLRANTERIOR","VLRACTUAL":"$VLRACTUAL","OBSERVACIONES":"$OBSERVACIONES","FECHAEXPEDICION":"$FECHAEXPEDICION","VIGENCIADESDE":"$VIGENCIADESDE","VIGENCIAHASTA":"$VIGENCIAHASTA","VALOR":"$VALOR","ESTADO":"$ESTADO","TIPO":"$TIPO","FECHAAPROBACIONCUMPLIMIENTO":"$FECHAAPROBACIONCUMPLIMIENTO","FECHAAPROBACIONRESPONSABILIDAD":"$FECHAAPROBACIONRESPONSABILIDAD","ASEGURADORA":"$ASEGURADORA","VALORASEGURADO":"$VALORASEGURADO","NOMBREASEGURADORA":"$NOMBREASEGURADORA","TIPODESC":"$TIPODESC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="VLRANTERIOR" sqlType="STRING"/>
		<param name="VLRACTUAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="FECHAEXPEDICION" sqlType="STRING"/>
		<param name="VIGENCIADESDE" sqlType="STRING"/>
		<param name="VIGENCIAHASTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHAAPROBACIONCUMPLIMIENTO" sqlType="STRING"/>
		<param name="FECHAAPROBACIONRESPONSABILIDAD" sqlType="STRING"/>
		<param name="VALORASEGURADO" sqlType="STRING"/>
		<param name="NOMBREASEGURADORA" sqlType="STRING"/>
		<param name="TIPODESC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="polizas/listasubpolizasmodificaciones/pag">
		<call-query href="getPolizasPagListasubpolizasmodificacionesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
