	<query id="getPolizasPagDatosBasicosValoresActualesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  POLIZAS.CODIGO, POLIZAS.CONSECUTIVO, POLIZAS.TIPO, POLIZAS.VALORASEGURADO VLRANTERIOR, POLIZAS.VLRACTUAL, POLIZAS.ASEGURADORA, TRIM(POLIZAS.OBSERVACIONES) AS OBSERVACIONES,(TO_CHAR(POLIZAS.FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAEXPEDICION,(TO_CHAR(POLIZAS.VIGENCIADESDE,'DD/MM/YYYY HH24:MI:SS')) VIGENCIADESDE,(TO_CHAR(POLIZAS.VIGENCIAHASTA,'DD/MM/YYYY HH24:MI:SS')) VIGENCIAHASTA, POLIZAS.VALOR, POLIZAS.ESTADO  FROM POLIZAS INNER JOIN ORDENDECOMPRA ON POLIZAS.COMPANIA = ORDENDECOMPRA.COMPANIA AND POLIZAS.CLASEORDEN = ORDENDECOMPRA.CLASEORDEN AND POLIZAS.ORDENDECOMPRA = ORDENDECOMPRA.NUMERO WHERE POLIZAS.COMPANIA = :COMPANIA AND POLIZAS.CLASEORDEN = :CLASEORDEN AND POLIZAS.ORDENDECOMPRA = :NUMERO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN VLRANTERIOR IS NULL THEN ' ' ELSE UPPER(VLRANTERIOR) END)  LIKE UPPER(:VLRANTERIOR || '%')  AND (CASE WHEN VLRACTUAL IS NULL THEN ' ' ELSE UPPER(VLRACTUAL) END)  LIKE UPPER(:VLRACTUAL || '%')  AND (CASE WHEN ASEGURADORA IS NULL THEN ' ' ELSE UPPER(ASEGURADORA) END)  LIKE UPPER( '%' || :ASEGURADORA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN FECHAEXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHAEXPEDICION) END)  LIKE UPPER( '%' || :FECHAEXPEDICION || '%')  AND (CASE WHEN VIGENCIADESDE IS NULL THEN ' ' ELSE UPPER(VIGENCIADESDE) END)  LIKE UPPER( '%' || :VIGENCIADESDE || '%')  AND (CASE WHEN VIGENCIAHASTA IS NULL THEN ' ' ELSE UPPER(VIGENCIAHASTA) END)  LIKE UPPER( '%' || :VIGENCIAHASTA || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CONSECUTIVO":"$CONSECUTIVO","TIPO":"$TIPO","VLRANTERIOR":"$VLRANTERIOR","VLRACTUAL":"$VLRACTUAL","ASEGURADORA":"$ASEGURADORA","OBSERVACIONES":"$OBSERVACIONES","FECHAEXPEDICION":"$FECHAEXPEDICION","VIGENCIADESDE":"$VIGENCIADESDE","VIGENCIAHASTA":"$VIGENCIAHASTA","VALOR":"$VALOR","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="VLRANTERIOR" sqlType="STRING"/>
		<param name="VLRACTUAL" sqlType="STRING"/>
		<param name="ASEGURADORA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="FECHAEXPEDICION" sqlType="STRING"/>
		<param name="VIGENCIADESDE" sqlType="STRING"/>
		<param name="VIGENCIAHASTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
