			<with-param name="VIGENCIAHASTA" query-param="VIGENCIAHASTA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TIPODESC" query-param="TIPODESC"/>
			<with-param name="NOMBREASEGURADORA" query-param="NOMBREASEGURADORA"/>
			<with-param name="VALORASEGURADO" query-param="VALORASEGURADO"/>
			<with-param name="INDIMPRESION" query-param="INDIMPRESION"/>
			<with-param name="PORC_POLIZA" query-param="PORC_POLIZA"/>
			<with-param name="FECHACOBERTURA" query-param="FECHACOBERTURA"/>
			<with-param name="N_SALARIOS" query-param="N_SALARIOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPolizasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  POLIZAS.COMPANIA, POLIZAS.CLASEORDEN, POLIZAS.ORDENDECOMPRA, POLIZAS.CODIGO, POLIZAS.CONSECUTIVO, POLIZAS.OBSERVACIONES,(TO_CHAR(POLIZAS.FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAEXPEDICION,(TO_CHAR(POLIZAS.VIGENCIADESDE,'DD/MM/YYYY HH24:MI:SS')) VIGENCIADESDE,(TO_CHAR(POLIZAS.VIGENCIAHASTA,'DD/MM/YYYY HH24:MI:SS')) VIGENCIAHASTA, POLIZAS.VALOR, POLIZAS.ESTADO, POLIZAS.TIPO, TIPOPOLIZA.DESCRIPCION TIPODESC,(TO_CHAR(POLIZAS.FECHAAPROBACIONCUMPLIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONCUMPLIMIENTO,(TO_CHAR(POLIZAS.FECHAAPROBACIONRESPONSABILIDAD,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONRESPONSABILIDAD, POLIZAS.ASEGURADORA, ASEGURADORA.NOMBRE NOMBREASEGURADORA, POLIZAS.VALORASEGURADO,(CASE POLIZAS.INDIMPRESION WHEN 0 THEN 'false' ELSE 'true' END) INDIMPRESION, POLIZAS.PORC_POLIZA,(TO_CHAR(POLIZAS.FECHACOBERTURA,'DD/MM/YYYY HH24:MI:SS')) FECHACOBERTURA,POLIZAS.N_SALARIOS  FROM POLIZAS INNER JOIN ASEGURADORA ON POLIZAS.COMPANIA = ASEGURADORA.COMPANIA AND POLIZAS.ASEGURADORA = ASEGURADORA.NITASEGURADORA AND POLIZAS.SUCURSAL = ASEGURADORA.SUCURSAL INNER JOIN TIPOPOLIZA ON POLIZAS.TIPO = TIPOPOLIZA.CODIGO WHERE POLIZAS.COMPANIA = :COMPANIA AND POLIZAS.CLASEORDEN = :CLASEORDEN AND POLIZAS.ORDENDECOMPRA = :ORDENDECOMPRA ORDER BY POLIZAS.CONSECUTIVO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN FECHAEXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHAEXPEDICION) END)  LIKE UPPER( '%' || :FECHAEXPEDICION || '%')  AND (CASE WHEN VIGENCIADESDE IS NULL THEN ' ' ELSE UPPER(VIGENCIADESDE) END)  LIKE UPPER( '%' || :VIGENCIADESDE || '%')  AND (CASE WHEN VIGENCIAHASTA IS NULL THEN ' ' ELSE UPPER(VIGENCIAHASTA) END)  LIKE UPPER( '%' || :VIGENCIAHASTA || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN TIPODESC IS NULL THEN ' ' ELSE UPPER(TIPODESC) END)  LIKE UPPER( '%' || :TIPODESC || '%')  AND (CASE WHEN NOMBREASEGURADORA IS NULL THEN ' ' ELSE UPPER(NOMBREASEGURADORA) END)  LIKE UPPER( '%' || :NOMBREASEGURADORA || '%')  AND (CASE WHEN VALORASEGURADO IS NULL THEN ' ' ELSE UPPER(VALORASEGURADO) END)  LIKE UPPER( '%' || :VALORASEGURADO || '%')  AND (CASE WHEN INDIMPRESION IS NULL THEN ' ' ELSE UPPER(INDIMPRESION) END)  LIKE UPPER( '%' || :INDIMPRESION || '%')  AND (CASE WHEN PORC_POLIZA IS NULL THEN ' ' ELSE UPPER(PORC_POLIZA) END)  LIKE UPPER( '%' || :PORC_POLIZA || '%')  AND (CASE WHEN FECHACOBERTURA IS NULL THEN ' ' ELSE UPPER(FECHACOBERTURA) END)  LIKE UPPER( '%' || :FECHACOBERTURA || '%')  AND (CASE WHEN N_SALARIOS IS NULL THEN ' ' ELSE UPPER(N_SALARIOS) END)  LIKE UPPER( '%' || :N_SALARIOS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="FECHAEXPEDICION" sqlType="STRING"/>
		<param name="VIGENCIADESDE" sqlType="STRING"/>
		<param name="VIGENCIAHASTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TIPODESC" sqlType="STRING"/>
		<param name="NOMBREASEGURADORA" sqlType="STRING"/>
		<param name="VALORASEGURADO" sqlType="STRING"/>
		<param name="INDIMPRESION" sqlType="STRING"/>
		<param name="PORC_POLIZA" sqlType="STRING"/>
		<param name="FECHACOBERTURA" sqlType="STRING"/>
		<param name="N_SALARIOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="polizas/numero">
