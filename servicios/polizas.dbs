	<query id="updatePolizas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE POLIZAS SET COMPANIA=:COMPANIA, CLASEORDEN=:CLASEORDEN, ORDENDECOMPRA=:ORDENDECOMPRA, CODIGO=:CODIGO, CONSECUTIVO=:CONSECUTIVO, OBSERVACIONES=:OBSERVACIONES, FECHAEXPEDICION=TO_DATE(:FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS'), VIGENCIADESDE=TO_DATE(:VIGENCIADESDE,'DD/MM/YYYY HH24:MI:SS'), VIGENCIAHASTA=TO_DATE(:VIGENCIAHASTA,'DD/MM/YYYY HH24:MI:SS'), VALOR=:VALOR, ESTADO=:ESTADO, TIPO=:TIPO, FECHAAPROBACIONCUMPLIMIENTO=TO_DATE(:FECHAAPROBACIONCUMPLIMIENTO,'DD/MM/YYYY HH24:MI:SS'), FECHAAPROBACIONRESPONSABILIDAD=TO_DATE(:FECHAAPROBACIONRESPONSABILIDAD,'DD/MM/YYYY HH24:MI:SS'), ASEGURADORA=:ASEGURADORA, VALORASEGURADO=:VALORASEGURADO, INDIMPRESION=:INDIMPRESION, PORC_POLIZA=:PORC_POLIZA, FECHACOBERTURA=TO_DATE(:FECHACOBERTURA,'DD/MM/YYYY HH24:MI:SS'), N_SALARIOS=:N_SALARIOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE POLIZAS.COMPANIA= :KEY_COMPANIA AND POLIZAS.CLASEORDEN= :KEY_CLASEORDEN AND POLIZAS.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND POLIZAS.CODIGO= :KEY_CODIGO AND POLIZAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="FECHAEXPEDICION" sqlType="STRING"/>
		<param name="VIGENCIADESDE" sqlType="STRING"/>
		<param name="VIGENCIAHASTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FECHAAPROBACIONCUMPLIMIENTO" sqlType="STRING"/>
		<param name="FECHAAPROBACIONRESPONSABILIDAD" sqlType="STRING"/>
		<param name="ASEGURADORA" sqlType="STRING"/>
		<param name="VALORASEGURADO" sqlType="STRING"/>
		<param name="INDIMPRESION" sqlType="STRING"/>
		<param name="PORC_POLIZA" sqlType="STRING"/>
		<param name="FECHACOBERTURA" sqlType="STRING"/>
		<param name="N_SALARIOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
