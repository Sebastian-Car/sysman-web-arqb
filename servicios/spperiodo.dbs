			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPagAnoMesPorCompaniaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CONCAT(ANO,CASE WHEN LENGTH(MES) = 1 THEN CONCAT('0',MES) ELSE TO_CHAR(MES) END) PERCOMPLETO, TRIM(PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(COMPANIA,ANO,MES,NULL) ) NOMBREDEPERIODO FROM SP_PERIODO WHERE COMPANIA =:COMPANIA AND CONCAT(ANO,CASE WHEN LENGTH(MES) = 1 THEN CONCAT('0',MES) ELSE TO_CHAR(MES) END) &gt;=:PERIODO ORDER BY CONCAT(ANO,CASE WHEN LENGTH(MES) = 1 THEN CONCAT('0',MES) ELSE TO_CHAR(MES) END)) INI WHERE (CASE WHEN PERCOMPLETO IS NULL THEN ' ' ELSE UPPER(PERCOMPLETO) END) LIKE UPPER(CONCAT(:PERCOMPLETO, '%')) AND (CASE WHEN NOMBREDEPERIODO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREDEPERIODO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERCOMPLETO":"$PERCOMPLETO","NOMBREDEPERIODO":"$NOMBREDEPERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="PERCOMPLETO" sqlType="STRING"/>
		<param name="NOMBREDEPERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
