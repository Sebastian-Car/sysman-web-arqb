	<query id="getSpperiodoPagPorEstadoUnionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT ANO FROM SP_PERIODO WHERE ESTADO NOT IN (0) AND CONCAT( ANO , CONCAT(' ' , LPAD(MES,2,'0'))) &gt; CONCAT( TO_CHAR(SYSDATE,'YYYY'),CONCAT( ' ', TO_CHAR(SYSDATE,'MM'))) UNION SELECT TO_NUMBER(:ANOINI) FROM DUAL ORDER BY ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
