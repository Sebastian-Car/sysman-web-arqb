			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FILTRO" query-param="FILTRO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoMesPerunicoPorAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MES, TRIM(PCK_SERVICIOS_PUBLICOS_COM2.FC_NOMBREPERIODOM(:COMPANIA,MES)) AS PERUNICO  FROM SP_PERIODO WHERE COMPANIA=:COMPANIA AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES","PERUNICO":"$PERUNICO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/mesperunicoporano">
