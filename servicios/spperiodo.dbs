	<query id="getSpperiodoPagPeriodoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (CONCAT(SP_PERIODO.ANO, SP_PERIODO.MES) ) FILTRO, TRIM(PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(COMPANIA,ANO,MES,NULL) ) PER FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA =:COMPANIA ORDER BY (CONCAT( SP_PERIODO.ANO, SP_PERIODO.MES ))) INI WHERE (CASE WHEN PER IS NULL THEN ' ' ELSE UPPER(PER) END) LIKE UPPER(CONCAT(CONCAT('%',:PER), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FILTRO":"$FILTRO","PER":"$PER"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PER" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo/periodoinicial/pag">
		<call-query href="getSpperiodoPagPeriodoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PER" query-param="PER"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumPeriodoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (CONCAT(SP_PERIODO.ANO, SP_PERIODO.MES) ) FILTRO, TRIM(PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(COMPANIA,ANO,MES,NULL) ) PER FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA =:COMPANIA ORDER BY (CONCAT( SP_PERIODO.ANO, SP_PERIODO.MES ))) INI WHERE (CASE WHEN PER IS NULL THEN ' ' ELSE UPPER(PER) END) LIKE UPPER(CONCAT(CONCAT('%',:PER), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PER" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/periodoinicial/num">
		<call-query href="getSpperiodoNumPeriodoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PER" query-param="PER"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPagPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CONCAT(ANO,CASE WHEN LENGTH(MES) = 1 THEN CONCAT('0',MES) ELSE TO_CHAR(MES) END) PERCOMPLETO, TRIM(PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(COMPANIA,ANO,MES,NULL) ) NOMBREDEPERIODO FROM SP_PERIODO WHERE COMPANIA =:COMPANIA ORDER BY CONCAT(ANO,CASE WHEN LENGTH(MES) = 1 THEN CONCAT('0',MES) ELSE TO_CHAR(MES) END)) INI WHERE (CASE WHEN PERCOMPLETO IS NULL THEN ' ' ELSE UPPER(PERCOMPLETO) END) LIKE UPPER(CONCAT(:PERCOMPLETO, '%')) AND (CASE WHEN NOMBREDEPERIODO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREDEPERIODO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERCOMPLETO":"$PERCOMPLETO","NOMBREDEPERIODO":"$NOMBREDEPERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERCOMPLETO" sqlType="STRING"/>
		<param name="NOMBREDEPERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo/porcompania/pag">
		<call-query href="getSpperiodoPagPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PERCOMPLETO" query-param="PERCOMPLETO"/>
			<with-param name="NOMBREDEPERIODO" query-param="NOMBREDEPERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT CONCAT(ANO,CASE WHEN LENGTH(MES) = 1 THEN CONCAT('0',MES) ELSE TO_CHAR(MES) END) PERCOMPLETO, TRIM(PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(COMPANIA,ANO,MES,NULL) ) NOMBREDEPERIODO FROM SP_PERIODO WHERE COMPANIA =:COMPANIA ORDER BY CONCAT(ANO,CASE WHEN LENGTH(MES) = 1 THEN CONCAT('0',MES) ELSE TO_CHAR(MES) END)) INI WHERE (CASE WHEN PERCOMPLETO IS NULL THEN ' ' ELSE UPPER(PERCOMPLETO) END) LIKE UPPER(CONCAT(:PERCOMPLETO, '%')) AND (CASE WHEN NOMBREDEPERIODO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREDEPERIODO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERCOMPLETO" sqlType="STRING"/>
		<param name="NOMBREDEPERIODO" sqlType="STRING"/>

	</query>
