	<query id="getSpperiodoPagAnoperiodonombreperiodoporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, NULL) NOPERIODO  FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA = :COMPANIA AND SP_PERIODO.ANO = :ANIO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN NOPERIODO IS NULL THEN ' ' ELSE UPPER(NOPERIODO) END)  LIKE UPPER( '%' || :NOPERIODO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","MES":"$MES","NOPERIODO":"$NOPERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOPERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo/anoperiodonombreperiodoporanio/pag">
		<call-query href="getSpperiodoPagAnoperiodonombreperiodoporanioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NOPERIODO" query-param="NOPERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumAnoperiodonombreperiodoporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, NULL) NOPERIODO  FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA = :COMPANIA AND SP_PERIODO.ANO = :ANIO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN NOPERIODO IS NULL THEN ' ' ELSE UPPER(NOPERIODO) END)  LIKE UPPER( '%' || :NOPERIODO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOPERIODO" sqlType="STRING"/>

	</query>
