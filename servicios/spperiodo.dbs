<data name="spperiodo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpperiodoTodosPorAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosporano">
		<call-query href="getSpperiodoTodosPorAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpperiodoTodosPorPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MES  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosporperiodo">
		<call-query href="getSpperiodoTodosPorPeriodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoTodosPorAnoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND ANO&gt;= :ANO ORDER BY ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosporanoinicial">
		<call-query href="getSpperiodoTodosPorAnoinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoTodosPorAnofinalYMesinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT MES  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND ANO= :ANOFINAL AND MES &gt;= :MES ORDER BY MES DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosporanofinalymesinicial">
		<call-query href="getSpperiodoTodosPorAnofinalYMesinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getSpperiodoTodosPorHojaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT SP_PERIODO.ANO AS NOMBREHOJA  FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA = :COMPANIA AND 1 = 0 ORDER BY SP_PERIODO.ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBREHOJA":"$NOMBREHOJA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosporhoja">
		<call-query href="getSpperiodoTodosPorHojaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPorMesYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO, MES  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND MES = :MES AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/pormesyanio">
		<call-query href="getSpperiodoPorMesYAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoTodosMesesPorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PERIODO.MES  FROM SP_PERIODO PERIODO WHERE PERIODO.COMPANIA = :COMPANIA AND PERIODO.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosmesesporanio">
		<call-query href="getSpperiodoTodosMesesPorAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoTodosAniocreadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO AS ANIOCREADO  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANIOCREADO":"$ANIOCREADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosaniocreado">
		<call-query href="getSpperiodoTodosAniocreadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPagTodosNombreperiodoPorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MES, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(COMPANIA,ANO,MES,NULL) AS NOPERIODO, ANO  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND ANO = :ANO) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN NOPERIODO IS NULL THEN ' ' ELSE UPPER(NOPERIODO) END)  LIKE UPPER( '%' || :NOPERIODO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES","NOPERIODO":"$NOPERIODO","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOPERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo/todosnombreperiodoporanio/pag">
		<call-query href="getSpperiodoPagTodosNombreperiodoPorAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NOPERIODO" query-param="NOPERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertSpperiodo" keyColumns="COMPANIA,ANO,MES" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_PERIODO (COMPANIA, ANO, MES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :MES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spperiodo">
		<call-query href="insertSpperiodo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSpperiodo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA= :KEY_COMPANIA AND SP_PERIODO.ANO= :KEY_ANO AND SP_PERIODO.MES= :KEY_MES</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spperiodo">
		<call-query href="deleteSpperiodo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, MES FROM SP_PERIODO WHERE COMPANIA = :COMPANIA ORDER BY CONCAT(ANO,MES) DESC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo">
		<call-query href="getSpperiodoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, MES FROM SP_PERIODO WHERE COMPANIA = :COMPANIA ORDER BY CONCAT(ANO,MES) DESC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/numero">
		<call-query href="getSpperiodoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="updateSpperiodo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_PERIODO SET ANO=:ANO, MES=:MES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_PERIODO.COMPANIA= :KEY_COMPANIA AND SP_PERIODO.ANO= :KEY_ANO AND SP_PERIODO.MES= :KEY_MES</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spperiodo">
		<call-query href="updateSpperiodo">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumTodosNombreperiodoPorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MES, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(COMPANIA,ANO,MES,NULL) AS NOPERIODO, ANO  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND ANO = :ANO) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN NOPERIODO IS NULL THEN ' ' ELSE UPPER(NOPERIODO) END)  LIKE UPPER( '%' || :NOPERIODO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOPERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/todosnombreperiodoporanio/num">
		<call-query href="getSpperiodoNumTodosNombreperiodoPorAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NOPERIODO" query-param="NOPERIODO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPorAnioYMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MES, PCK_SERVICIOS_PUBLICOS_COM2.FC_NOMBREPERIODOM(COMPANIA,MES) PERUNICO  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND MES &gt;= CASE WHEN (:ANO)=(:BLOQUEAHASTAANO) THEN (:PERIODO) ELSE '01' END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES","PERUNICO":"$PERUNICO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="BLOQUEAHASTAANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/poranioymes">
		<call-query href="getSpperiodoPorAnioYMesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="BLOQUEAHASTAANO" query-param="BLOQUEAHASTAANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoExistePeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM SP_PERIODO WHERE COMPANIA= :COMPANIA AND ANO = :ANO AND MES = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/existeperiodo">
		<call-query href="getSpperiodoExistePeriodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumeroPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(MES) PERIODO  FROM SP_PERIODO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND MES = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/numeroperiodo">
		<call-query href="getSpperiodoNumeroPeriodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPagPorAnosYPeriodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, NULL) NOPERIODO  FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA = :COMPANIA AND SP_PERIODO.ANO = :ANO AND SP_PERIODO.MES &gt;= CASE WHEN :ANO = :ANOBLOQUEADO THEN :PERIODO ELSE '01' END) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN NOPERIODO IS NULL THEN ' ' ELSE UPPER(NOPERIODO) END)  LIKE UPPER( '%' || :NOPERIODO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","MES":"$MES","NOPERIODO":"$NOPERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ANOBLOQUEADO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOPERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo/poranosyperiodos/pag">
		<call-query href="getSpperiodoPagPorAnosYPeriodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ANOBLOQUEADO" query-param="ANOBLOQUEADO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NOPERIODO" query-param="NOPERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumPorAnosYPeriodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_PERIODO.COMPANIA, SP_PERIODO.ANO, SP_PERIODO.MES, NULL) NOPERIODO  FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA = :COMPANIA AND SP_PERIODO.ANO = :ANO AND SP_PERIODO.MES &gt;= CASE WHEN :ANO = :ANOBLOQUEADO THEN :PERIODO ELSE '01' END) WHERE (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN NOPERIODO IS NULL THEN ' ' ELSE UPPER(NOPERIODO) END)  LIKE UPPER( '%' || :NOPERIODO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ANOBLOQUEADO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NOPERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/poranosyperiodos/num">
		<call-query href="getSpperiodoNumPorAnosYPeriodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ANOBLOQUEADO" query-param="ANOBLOQUEADO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NOPERIODO" query-param="NOPERIODO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoAniosPorAnioActualQuery"  useConfig="sysmandsunist">
