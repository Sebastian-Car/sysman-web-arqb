		<call-query href="getSpperiodoPagPorEstadoQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumPorEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT ANO FROM SP_PERIODO WHERE ESTADO NOT IN (0) AND CONCAT(ANO , CONCAT(' ' , LPAD(MES,2,'0'))) &gt; CONCAT( TO_CHAR(SYSDATE,'YYYY'), CONCAT(' ', TO_CHAR(SYSDATE,'MM')))) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>

	</query>
