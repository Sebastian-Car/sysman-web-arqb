	<query id="getSpperiodoMesynombreinnermesporanomayoramesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_PERIODO.MES, MES.NOMBRE  FROM SP_PERIODO INNER JOIN MES ON SP_PERIODO.COMPANIA = MES.COMPANIA AND SP_PERIODO.ANO = MES.ANO AND SP_PERIODO.MES = MES.NUMERO WHERE SP_PERIODO.COMPANIA = :COMPANIA AND SP_PERIODO.ANO = :ANO AND MES.NUMERO NOT IN(0,13) AND SP_PERIODO.MES &gt;= :MES GROUP BY SP_PERIODO.ANO, SP_PERIODO.MES, MES.NUMERO, MES.NOMBRE ORDER BY MES.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES","NOMBRE":"$NOMBRE"}]}}		</result>
