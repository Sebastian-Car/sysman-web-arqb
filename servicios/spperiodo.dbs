	<query id="getSpperiodoConsultarAnoInicialYFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MIN (ANO) AS ANOINICIAL, MAX(ANO) AS ANOFINAL  FROM SP_PERIODO WHERE COMPANIA= :COMPANIA AND ANO &gt;= :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANOINICIAL":"$ANOINICIAL(type:integer)","ANOFINAL":"$ANOFINAL(type:integer)"}]}}		</result>
