	<query id="getSpperiodoConsultarPrimerMesPorPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MIN (MES) AS MES  FROM SP_PERIODO WHERE COMPANIA= :COMPANIA AND ANO = :ANO AND MES &gt;= CASE WHEN ANO = :ANO THEN :PERIODO ELSE TO_CHAR(01) END</sql>
