	<query id="getSpperiodoPagAnioperiodoporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(SP_PERIODO.ANO,SP_PERIODO.MES) FILTRO, CONCAT(ANO,CONCAT('-',MES) ) PER, SP_PERIODO.ANO, SP_PERIODO.MES, CASE SP_PERIODO.MES WHEN '01' THEN 'Enero' WHEN '02' THEN 'Febrero' WHEN '03' THEN 'Marzo' WHEN '04' THEN 'Abril' WHEN '05' THEN 'Mayo' WHEN '06' THEN 'Junio' WHEN '07' THEN 'Julio' WHEN '08' THEN 'Agosto' WHEN '09' THEN 'Septiembre' WHEN '10' THEN 'Octubre' WHEN '11' THEN 'Noviembre' WHEN '12' THEN 'Diciembre' END MESNOMBRE FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN FILTRO IS NULL THEN ' ' ELSE UPPER(FILTRO) END) LIKE UPPER(CONCAT(:FILTRO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FILTRO":"$FILTRO","PER":"$PER","ANO":"$ANO(type:integer)","MES":"$MES","MESNOMBRE":"$MESNOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FILTRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo/anioperiodoporcompania/pag">
		<call-query href="getSpperiodoPagAnioperiodoporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FILTRO" query-param="FILTRO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumAnioperiodoporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCAT(SP_PERIODO.ANO,SP_PERIODO.MES) FILTRO, CONCAT(ANO,CONCAT('-',MES) ) PER, SP_PERIODO.ANO, SP_PERIODO.MES, CASE SP_PERIODO.MES WHEN '01' THEN 'Enero' WHEN '02' THEN 'Febrero' WHEN '03' THEN 'Marzo' WHEN '04' THEN 'Abril' WHEN '05' THEN 'Mayo' WHEN '06' THEN 'Junio' WHEN '07' THEN 'Julio' WHEN '08' THEN 'Agosto' WHEN '09' THEN 'Septiembre' WHEN '10' THEN 'Octubre' WHEN '11' THEN 'Noviembre' WHEN '12' THEN 'Diciembre' END MESNOMBRE FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN FILTRO IS NULL THEN ' ' ELSE UPPER(FILTRO) END) LIKE UPPER(CONCAT(:FILTRO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FILTRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spperiodo/anioperiodoporcompania/num">
		<call-query href="getSpperiodoNumAnioperiodoporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FILTRO" query-param="FILTRO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoPagAnioperiodoporcompaniafinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(SP_PERIODO.ANO,SP_PERIODO.MES) FILTRO, CONCAT(ANO,CONCAT('-',MES) ) PER, SP_PERIODO.ANO, SP_PERIODO.MES, CASE SP_PERIODO.MES WHEN '01' THEN 'Enero' WHEN '02' THEN 'Febrero' WHEN '03' THEN 'Marzo' WHEN '04' THEN 'Abril' WHEN '05' THEN 'Mayo' WHEN '06' THEN 'Junio' WHEN '07' THEN 'Julio' WHEN '08' THEN 'Agosto' WHEN '09' THEN 'Septiembre' WHEN '10' THEN 'Octubre' WHEN '11' THEN 'Noviembre' WHEN '12' THEN 'Diciembre' END MESNOMBRE FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA =:COMPANIA AND CONCAT(SP_PERIODO.ANO,SP_PERIODO.MES) &gt;=:PERIODO) INI WHERE (CASE WHEN FILTRO IS NULL THEN ' ' ELSE UPPER(FILTRO) END) LIKE UPPER(CONCAT(:FILTRO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FILTRO":"$FILTRO","PER":"$PER","ANO":"$ANO(type:integer)","MES":"$MES","MESNOMBRE":"$MESNOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FILTRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spperiodo/anioperiodoporcompaniafinal/pag">
		<call-query href="getSpperiodoPagAnioperiodoporcompaniafinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FILTRO" query-param="FILTRO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpperiodoNumAnioperiodoporcompaniafinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCAT(SP_PERIODO.ANO,SP_PERIODO.MES) FILTRO, CONCAT(ANO,CONCAT('-',MES) ) PER, SP_PERIODO.ANO, SP_PERIODO.MES, CASE SP_PERIODO.MES WHEN '01' THEN 'Enero' WHEN '02' THEN 'Febrero' WHEN '03' THEN 'Marzo' WHEN '04' THEN 'Abril' WHEN '05' THEN 'Mayo' WHEN '06' THEN 'Junio' WHEN '07' THEN 'Julio' WHEN '08' THEN 'Agosto' WHEN '09' THEN 'Septiembre' WHEN '10' THEN 'Octubre' WHEN '11' THEN 'Noviembre' WHEN '12' THEN 'Diciembre' END MESNOMBRE FROM SP_PERIODO WHERE SP_PERIODO.COMPANIA =:COMPANIA AND CONCAT(SP_PERIODO.ANO,SP_PERIODO.MES) &gt;=:PERIODO) INI WHERE (CASE WHEN FILTRO IS NULL THEN ' ' ELSE UPPER(FILTRO) END) LIKE UPPER(CONCAT(:FILTRO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FILTRO" sqlType="STRING"/>

	</query>
