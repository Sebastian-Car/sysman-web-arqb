	<query id="insertComponentes" keyColumns="COMPANIA,CODIGOPROYECTO,CODIGO,TIPOCOMPONENTE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPONENTES (COMPANIA, CODIGOPROYECTO, CODIGO, TIPOCOMPONENTE, NOMBRECOMPONENTE, SALDOCOMPONENTE, VALORGASTOSREP, VALORPROGRAMADOFINANCIADO, VALORPROGRAMADOPORFINANCIAR, VALOREJECUTADO, CANTIDADPERIODOS, DURACIONUNIDAD, ETAPA, PESOPORCENTAJE, METAFINANCIERA, METAFISICA, UNIDAD, CANTIDAD, VALORACTUAL, VALORTOTAL, VALORFINANCIADO, VALORPORFINANCIAR, PRIORIDAD, VALORPROGRAMADO, TEMPORAL, SINFINANCIACION, VIGENCIACOM, VALORUNITARIO, ESTADOFINANCIACION, VIGENCIA, OBJETO, VALORTOTALSOLICITADO, VALORRECURSOSPROPIOS, VALORSGP, VALORREGALIAS, VALORRECURSOSESPECIALES, VALOR_OTROS, CONPROGRAMACION, CREATED_BY, DATE_CREATED, VALOR_DISMINUIDO) VALUES (:COMPANIA, :CODIGOPROYECTO, :CODIGO, :TIPOCOMPONENTE, :NOMBRECOMPONENTE, :SALDOCOMPONENTE, :VALORGASTOSREP, :VALORPROGRAMADOFINANCIADO, :VALORPROGRAMADOPORFINANCIAR, :VALOREJECUTADO, :CANTIDADPERIODOS, :DURACIONUNIDAD, :ETAPA, :PESOPORCENTAJE, :METAFINANCIERA, :METAFISICA, :UNIDAD, :CANTIDAD, :VALORACTUAL, :VALORTOTAL, :VALORFINANCIADO, :VALORPORFINANCIAR, :PRIORIDAD, :VALORPROGRAMADO, :TEMPORAL, :SINFINANCIACION, :VIGENCIACOM, :VALORUNITARIO, :ESTADOFINANCIACION, :VIGENCIA, :OBJETO, :VALORTOTALSOLICITADO, :VALORRECURSOSPROPIOS, :VALORSGP, :VALORREGALIAS, :VALORRECURSOSESPECIALES, :VALOR_OTROS, :CONPROGRAMACION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :VALOR_DISMINUIDO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOPROYECTO":"$CODIGOPROYECTO","KEY_CODIGO":"$CODIGO","KEY_TIPOCOMPONENTE":"$TIPOCOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param defaultValue="0" name="SALDOCOMPONENTE" sqlType="STRING"/>
		<param defaultValue="0" name="VALORGASTOSREP" sqlType="STRING"/>
		<param defaultValue="0" name="VALORPROGRAMADOFINANCIADO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORPROGRAMADOPORFINANCIAR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOREJECUTADO" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDADPERIODOS" sqlType="STRING"/>
		<param defaultValue="" name="DURACIONUNIDAD" sqlType="STRING"/>
		<param defaultValue="" name="ETAPA" sqlType="STRING"/>
		<param defaultValue="0" name="PESOPORCENTAJE" sqlType="STRING"/>
		<param defaultValue="0" name="METAFINANCIERA" sqlType="STRING"/>
		<param defaultValue="0" name="METAFISICA" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALORACTUAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORFINANCIADO" sqlType="STRING"/>
