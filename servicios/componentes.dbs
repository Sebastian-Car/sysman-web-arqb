		<param name="VALORACTUAL" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="VALORFINANCIADO" sqlType="STRING"/>
		<param name="VALORPORFINANCIAR" sqlType="STRING"/>
		<param name="PRIORIDAD" sqlType="STRING"/>
