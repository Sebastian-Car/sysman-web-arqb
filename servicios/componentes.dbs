			<with-param name="VALORPROGRAMADO" query-param="VALORPROGRAMADO"/>
			<with-param name="VALOREJECUTADO" query-param="VALOREJECUTADO"/>
			<with-param name="SALDOCOMPONENTE" query-param="SALDOCOMPONENTE"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComponentesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPONENTES.VIGENCIA, NVL(BP_TIPOSCOMPONENTES.DESCRIPCION,COMPONENTES.TIPOCOMPONENTE) NOMBRETIPO, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.CODIGO, COMPONENTES.VALORTOTALSOLICITADO, COMPONENTES.VALORPROGRAMADO, COMPONENTES.VALOREJECUTADO, COMPONENTES.SALDOCOMPONENTE, COMPONENTES.VALORUNITARIO, COMPONENTES.VALORTOTAL, COMPONENTES.COMPANIA, COMPONENTES.CODIGOPROYECTO, COMPONENTES.TIPOCOMPONENTE  FROM COMPONENTES LEFT JOIN BP_TIPOSCOMPONENTES ON COMPONENTES.COMPANIA = BP_TIPOSCOMPONENTES.COMPANIA AND COMPONENTES.TIPOCOMPONENTE = BP_TIPOSCOMPONENTES.CODIGO WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :CODIGOPROYECTO ORDER BY COMPONENTES.VIGENCIA, COMPONENTES.CODIGO) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END)  LIKE UPPER(:NOMBRETIPO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN VALORTOTALSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORTOTALSOLICITADO) END)  LIKE UPPER(:VALORTOTALSOLICITADO || '%')  AND (CASE WHEN VALORPROGRAMADO IS NULL THEN ' ' ELSE UPPER(VALORPROGRAMADO) END)  LIKE UPPER(:VALORPROGRAMADO || '%')  AND (CASE WHEN VALOREJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOREJECUTADO) END)  LIKE UPPER(:VALOREJECUTADO || '%')  AND (CASE WHEN SALDOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(SALDOCOMPONENTE) END)  LIKE UPPER(:SALDOCOMPONENTE || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VALORTOTALSOLICITADO" sqlType="STRING"/>
		<param name="VALORPROGRAMADO" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="SALDOCOMPONENTE" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/numero">
		<call-query href="getComponentesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
