			<with-param name="VALORPROGRAMADO" query-param="VALORPROGRAMADO"/>
			<with-param name="VALOREJECUTADO" query-param="VALOREJECUTADO"/>
			<with-param name="SALDOCOMPONENTE" query-param="SALDOCOMPONENTE"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>

		</call-query>
	</resource>
	<query id="getComponentesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPONENTES.COMPANIA, COMPONENTES.CODIGOPROYECTO, COMPONENTES.CODIGO, COMPONENTES.TIPOCOMPONENTE, BP_TIPOSCOMPONENTES.DESCRIPCION NOMBRETIPO, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.SALDOCOMPONENTE, COMPONENTES.VALORGASTOSREP, COMPONENTES.VALORPROGRAMADOFINANCIADO, COMPONENTES.VALORPROGRAMADOPORFINANCIAR, COMPONENTES.VALOREJECUTADO, COMPONENTES.CANTIDADPERIODOS, COMPONENTES.DURACIONUNIDAD, COMPONENTES.ETAPA, COMPONENTES.PESOPORCENTAJE, COMPONENTES.METAFINANCIERA, COMPONENTES.METAFISICA, COMPONENTES.UNIDAD, COMPONENTES.CANTIDAD, COMPONENTES.VALORACTUAL, COMPONENTES.VALORTOTAL, COMPONENTES.VALORFINANCIADO, COMPONENTES.VALORPORFINANCIAR, COMPONENTES.PRIORIDAD, COMPONENTES.VALORPROGRAMADO, COMPONENTES.TEMPORAL,(CASE COMPONENTES.SINFINANCIACION WHEN 0 THEN 'false' ELSE 'true' END) SINFINANCIACION, COMPONENTES.VIGENCIACOM, COMPONENTES.VALORUNITARIO, COMPONENTES.ESTADOFINANCIACION, COMPONENTES.VIGENCIA, COMPONENTES.OBJETO, COMPONENTES.VALORTOTALSOLICITADO, COMPONENTES.VALORRECURSOSPROPIOS, COMPONENTES.VALORSGP, COMPONENTES.VALORREGALIAS, COMPONENTES.VALORRECURSOSESPECIALES, COMPONENTES.VALOR_OTROS,(CASE COMPONENTES.CONPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) CONPROGRAMACION, COMPONENTES.CREATED_BY,(TO_CHAR(COMPONENTES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, COMPONENTES.MODIFIED_BY,(TO_CHAR(COMPONENTES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, COMPONENTES.VALOR_DISMINUIDO  FROM COMPONENTES LEFT JOIN BP_TIPOSCOMPONENTES ON COMPONENTES.TIPOCOMPONENTE = BP_TIPOSCOMPONENTES.CODIGO WHERE COMPONENTES.COMPANIA= :KEY_COMPANIA AND COMPONENTES.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND COMPONENTES.CODIGO= :KEY_CODIGO AND COMPONENTES.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOPROYECTO":"$CODIGOPROYECTO","CODIGO":"$CODIGO","TIPOCOMPONENTE":"$TIPOCOMPONENTE","NOMBRETIPO":"$NOMBRETIPO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","SALDOCOMPONENTE":"$SALDOCOMPONENTE","VALORGASTOSREP":"$VALORGASTOSREP","VALORPROGRAMADOFINANCIADO":"$VALORPROGRAMADOFINANCIADO","VALORPROGRAMADOPORFINANCIAR":"$VALORPROGRAMADOPORFINANCIAR","VALOREJECUTADO":"$VALOREJECUTADO","CANTIDADPERIODOS":"$CANTIDADPERIODOS(type:integer)","DURACIONUNIDAD":"$DURACIONUNIDAD","ETAPA":"$ETAPA","PESOPORCENTAJE":"$PESOPORCENTAJE","METAFINANCIERA":"$METAFINANCIERA","METAFISICA":"$METAFISICA","UNIDAD":"$UNIDAD","CANTIDAD":"$CANTIDAD","VALORACTUAL":"$VALORACTUAL","VALORTOTAL":"$VALORTOTAL","VALORFINANCIADO":"$VALORFINANCIADO","VALORPORFINANCIAR":"$VALORPORFINANCIAR","PRIORIDAD":"$PRIORIDAD(type:integer)","VALORPROGRAMADO":"$VALORPROGRAMADO","TEMPORAL":"$TEMPORAL","SINFINANCIACION":"$SINFINANCIACION(type:boolean)","VIGENCIACOM":"$VIGENCIACOM","VALORUNITARIO":"$VALORUNITARIO","ESTADOFINANCIACION":"$ESTADOFINANCIACION","VIGENCIA":"$VIGENCIA(type:integer)","OBJETO":"$OBJETO","VALORTOTALSOLICITADO":"$VALORTOTALSOLICITADO","VALORRECURSOSPROPIOS":"$VALORRECURSOSPROPIOS","VALORSGP":"$VALORSGP","VALORREGALIAS":"$VALORREGALIAS","VALORRECURSOSESPECIALES":"$VALORRECURSOSESPECIALES","VALOR_OTROS":"$VALOR_OTROS","CONPROGRAMACION":"$CONPROGRAMACION(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","VALOR_DISMINUIDO":"$VALOR_DISMINUIDO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPROYECTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/data">
		<call-query href="getComponentesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPROYECTO" query-param="KEY_CODIGOPROYECTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPOCOMPONENTE" query-param="KEY_TIPOCOMPONENTE"/>

		</call-query>
	</resource>
	<query id="updateComponentes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPONENTES SET CODIGOPROYECTO=:CODIGOPROYECTO, CODIGO=:CODIGO, TIPOCOMPONENTE=:TIPOCOMPONENTE, NOMBRECOMPONENTE=:NOMBRECOMPONENTE, SALDOCOMPONENTE=:SALDOCOMPONENTE, VALORGASTOSREP=:VALORGASTOSREP, VALORPROGRAMADOFINANCIADO=:VALORPROGRAMADOFINANCIADO, VALORPROGRAMADOPORFINANCIAR=:VALORPROGRAMADOPORFINANCIAR, VALOREJECUTADO=:VALOREJECUTADO, CANTIDADPERIODOS=:CANTIDADPERIODOS, DURACIONUNIDAD=:DURACIONUNIDAD, ETAPA=:ETAPA, PESOPORCENTAJE=:PESOPORCENTAJE, METAFINANCIERA=:METAFINANCIERA, METAFISICA=:METAFISICA, UNIDAD=:UNIDAD, CANTIDAD=:CANTIDAD, VALORACTUAL=:VALORACTUAL, VALORTOTAL=:VALORTOTAL, VALORFINANCIADO=:VALORFINANCIADO, VALORPORFINANCIAR=:VALORPORFINANCIAR, PRIORIDAD=:PRIORIDAD, VALORPROGRAMADO=:VALORPROGRAMADO, TEMPORAL=:TEMPORAL, SINFINANCIACION=:SINFINANCIACION, VIGENCIACOM=:VIGENCIACOM, VALORUNITARIO=:VALORUNITARIO, ESTADOFINANCIACION=:ESTADOFINANCIACION, VIGENCIA=:VIGENCIA, OBJETO=:OBJETO, VALORTOTALSOLICITADO=:VALORTOTALSOLICITADO, VALORRECURSOSPROPIOS=:VALORRECURSOSPROPIOS, VALORSGP=:VALORSGP, VALORREGALIAS=:VALORREGALIAS, VALORRECURSOSESPECIALES=:VALORRECURSOSESPECIALES, VALOR_OTROS=:VALOR_OTROS, CONPROGRAMACION=:CONPROGRAMACION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), VALOR_DISMINUIDO=:VALOR_DISMINUIDO WHERE COMPONENTES.COMPANIA= :KEY_COMPANIA AND COMPONENTES.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND COMPONENTES.CODIGO= :KEY_CODIGO AND COMPONENTES.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="SALDOCOMPONENTE" sqlType="STRING"/>
		<param name="VALORGASTOSREP" sqlType="STRING"/>
		<param name="VALORPROGRAMADOFINANCIADO" sqlType="STRING"/>
		<param name="VALORPROGRAMADOPORFINANCIAR" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="CANTIDADPERIODOS" sqlType="STRING"/>
