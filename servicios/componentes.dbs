		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="ESTADOFINANCIACION" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALORTOTALSOLICITADO" sqlType="STRING"/>
		<param name="VALORRECURSOSPROPIOS" sqlType="STRING"/>
		<param name="VALORSGP" sqlType="STRING"/>
		<param name="VALORREGALIAS" sqlType="STRING"/>
		<param name="VALORRECURSOSESPECIALES" sqlType="STRING"/>
		<param name="VALOR_OTROS" sqlType="STRING"/>
		<param name="CONPROGRAMACION" sqlType="STRING"/>
