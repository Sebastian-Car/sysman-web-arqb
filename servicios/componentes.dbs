	<query id="getComponentesPorTiposDeComponenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'X' X  FROM COMPONENTES WHERE COMPANIA = :COMPANIA AND CODIGOPROYECTO = :CODIGOPROYECTO AND TIPOCOMPONENTE IN('100','99')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/portiposdecomponente">
		<call-query href="getComponentesPorTiposDeComponenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>

		</call-query>
	</resource>
	<query id="getComponentesCantidadPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(CODIGO) CONTEO  FROM COMPONENTES WHERE COMPANIA = :COMPANIA AND CODIGOPROYECTO = :CODIGOPROYECTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/cantidadporcodigo">
		<call-query href="getComponentesCantidadPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>

		</call-query>
	</resource>
	<query id="getComponentesPagTodosPorVigenciaCompaniaCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPONENTES.CODIGO, COMPONENTES.NOMBRECOMPONENTE  FROM COMPONENTES WHERE COMPONENTES.TIPOCOMPONENTE = :TIPOCOMPONENTE AND COMPONENTES.VIGENCIA = :VIGENCIAMETAP AND COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :CODIGOPROYECTO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE"}]}}		</result>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="VIGENCIAMETAP" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="componentes/todosporvigenciacompaniacodigo/pag">
		<call-query href="getComponentesPagTodosPorVigenciaCompaniaCodigoQuery">
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>
			<with-param name="VIGENCIAMETAP" query-param="VIGENCIAMETAP"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComponentesNumTodosPorVigenciaCompaniaCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPONENTES.CODIGO, COMPONENTES.NOMBRECOMPONENTE  FROM COMPONENTES WHERE COMPONENTES.TIPOCOMPONENTE = :TIPOCOMPONENTE AND COMPONENTES.VIGENCIA = :VIGENCIAMETAP AND COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :CODIGOPROYECTO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="VIGENCIAMETAP" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/todosporvigenciacompaniacodigo/num">
		<call-query href="getComponentesNumTodosPorVigenciaCompaniaCodigoQuery">
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>
			<with-param name="VIGENCIAMETAP" query-param="VIGENCIAMETAP"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>

		</call-query>
	</resource>
	<query id="getComponentesPagTipoyvigenciaporproyQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT COMPONENTES.CODIGO COMPONENTE, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.TIPOCOMPONENTE, COMPONENTES.VALORPROGRAMADO PROGRAMADO, COMPONENTES.VALORTOTAL TOTAL, (NVL(COMPONENTES.VALORTOTAL, 0) - NVL(COMPONENTES.VALOREJECUTADO, 0) ) SALDO, COMPONENTES.OBJETO, COMPONENTES_ACTIVIDADES.VIGENCIA, COMPONENTES.VALOREJECUTADO, COMPONENTES.CODIGO COD, COMPONENTES.VALORTOTALSOLICITADO SOLICITADO FROM COMPONENTES LEFT JOIN COMPONENTES_ACTIVIDADES ON COMPONENTES.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND COMPONENTES.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND COMPONENTES.CODIGO = COMPONENTES_ACTIVIDADES.COMPONENTE AND COMPONENTES.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE INNER JOIN BP_PROYECTO_PLAN_INDICATIVO ON COMPONENTES_ACTIVIDADES.COMPANIA = BP_PROYECTO_PLAN_INDICATIVO.COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = BP_PROYECTO_PLAN_INDICATIVO.PROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE AND COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE AND COMPONENTES_ACTIVIDADES.ACTIVIDAD = BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :PROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P = :METAPRODUCTO ORDER BY COMPONENTES.NOMBRECOMPONENTE, COMPONENTES_ACTIVIDADES.VIGENCIA) INI WHERE (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(:COMPONENTE, '%')) AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPONENTE), '%')) AND (CASE WHEN PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PROGRAMADO) END) LIKE UPPER(CONCAT(:PROGRAMADO, '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(:TOTAL, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(:VIGENCIA, '%')) AND (CASE WHEN VALOREJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOREJECUTADO) END) LIKE UPPER(CONCAT(:VALOREJECUTADO, '%')) AND (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END) LIKE UPPER(CONCAT(:COD, '%')) AND (CASE WHEN SOLICITADO IS NULL THEN ' ' ELSE UPPER(SOLICITADO) END) LIKE UPPER(CONCAT(:SOLICITADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPONENTE":"$COMPONENTE","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","PROGRAMADO":"$PROGRAMADO","TOTAL":"$TOTAL","SALDO":"$SALDO","OBJETO":"$OBJETO","VIGENCIA":"$VIGENCIA(type:integer)","VALOREJECUTADO":"$VALOREJECUTADO","COD":"$COD","SOLICITADO":"$SOLICITADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="METAPRODUCTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="PROGRAMADO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="SOLICITADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="componentes/tipoyvigenciaporproy/pag">
		<call-query href="getComponentesPagTipoyvigenciaporproyQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="METAPRODUCTO" query-param="METAPRODUCTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="PROGRAMADO" query-param="PROGRAMADO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALOREJECUTADO" query-param="VALOREJECUTADO"/>
			<with-param name="COD" query-param="COD"/>
			<with-param name="SOLICITADO" query-param="SOLICITADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComponentesNumTipoyvigenciaporproyQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT COMPONENTES.CODIGO COMPONENTE, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.TIPOCOMPONENTE, COMPONENTES.VALORPROGRAMADO PROGRAMADO, COMPONENTES.VALORTOTAL TOTAL, (NVL(COMPONENTES.VALORTOTAL, 0) - NVL(COMPONENTES.VALOREJECUTADO, 0) ) SALDO, COMPONENTES.OBJETO, COMPONENTES_ACTIVIDADES.VIGENCIA, COMPONENTES.VALOREJECUTADO, COMPONENTES.CODIGO COD, COMPONENTES.VALORTOTALSOLICITADO SOLICITADO FROM COMPONENTES LEFT JOIN COMPONENTES_ACTIVIDADES ON COMPONENTES.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND COMPONENTES.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND COMPONENTES.CODIGO = COMPONENTES_ACTIVIDADES.COMPONENTE AND COMPONENTES.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE INNER JOIN BP_PROYECTO_PLAN_INDICATIVO ON COMPONENTES_ACTIVIDADES.COMPANIA = BP_PROYECTO_PLAN_INDICATIVO.COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = BP_PROYECTO_PLAN_INDICATIVO.PROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE AND COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE AND COMPONENTES_ACTIVIDADES.ACTIVIDAD = BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :PROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P = :METAPRODUCTO ORDER BY COMPONENTES.NOMBRECOMPONENTE, COMPONENTES_ACTIVIDADES.VIGENCIA) INI WHERE (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(:COMPONENTE, '%')) AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPONENTE), '%')) AND (CASE WHEN PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PROGRAMADO) END) LIKE UPPER(CONCAT(:PROGRAMADO, '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(:TOTAL, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(:VIGENCIA, '%')) AND (CASE WHEN VALOREJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOREJECUTADO) END) LIKE UPPER(CONCAT(:VALOREJECUTADO, '%')) AND (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END) LIKE UPPER(CONCAT(:COD, '%')) AND (CASE WHEN SOLICITADO IS NULL THEN ' ' ELSE UPPER(SOLICITADO) END) LIKE UPPER(CONCAT(:SOLICITADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="METAPRODUCTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="PROGRAMADO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="SOLICITADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/tipoyvigenciaporproy/num">
		<call-query href="getComponentesNumTipoyvigenciaporproyQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="METAPRODUCTO" query-param="METAPRODUCTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="PROGRAMADO" query-param="PROGRAMADO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALOREJECUTADO" query-param="VALOREJECUTADO"/>
			<with-param name="COD" query-param="COD"/>
			<with-param name="SOLICITADO" query-param="SOLICITADO"/>

		</call-query>
	</resource>
	<query id="getComponentesGetvalorescomponenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT COMPONENTES.CODIGO COMPONENTE, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.TIPOCOMPONENTE, COMPONENTES.VALORPROGRAMADO PROGRAMADO, COMPONENTES.VALORTOTAL TOTAL, (NVL(COMPONENTES.VALORTOTAL, 0) - NVL(COMPONENTES.VALOREJECUTADO, 0) ) SALDO, COMPONENTES_ACTIVIDADES.VIGENCIA, COMPONENTES.VALOREJECUTADO, COMPONENTES.VALORTOTALSOLICITADO SOLICITADO  FROM COMPONENTES LEFT JOIN COMPONENTES_ACTIVIDADES ON COMPONENTES.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND COMPONENTES.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND COMPONENTES.CODIGO = COMPONENTES_ACTIVIDADES.COMPONENTE AND COMPONENTES.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE INNER JOIN BP_PROYECTO_PLAN_INDICATIVO ON COMPONENTES_ACTIVIDADES.COMPANIA = BP_PROYECTO_PLAN_INDICATIVO.COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = BP_PROYECTO_PLAN_INDICATIVO.PROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE AND COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE AND COMPONENTES_ACTIVIDADES.ACTIVIDAD = BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :PROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P = :METAPRODUCTO ORDER BY COMPONENTES.NOMBRECOMPONENTE, COMPONENTES_ACTIVIDADES.VIGENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPONENTE":"$COMPONENTE","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","PROGRAMADO":"$PROGRAMADO","TOTAL":"$TOTAL","SALDO":"$SALDO(type:integer)","VIGENCIA":"$VIGENCIA(type:integer)","VALOREJECUTADO":"$VALOREJECUTADO","SOLICITADO":"$SOLICITADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="METAPRODUCTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/getvalorescomponente">
		<call-query href="getComponentesGetvalorescomponenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="METAPRODUCTO" query-param="METAPRODUCTO"/>

		</call-query>
	</resource>
	<query id="updateComponentesUpdatevalorprogramado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPONENTES  SET VALORPROGRAMADO = :VALORPROGRAMADO,     MODIFIED_BY = :USUARIO,     DATE_MODIFIED   = SYSDATE  WHERE COMPANIA = :COMPANIA  AND CODIGOPROYECTO = :CODIGO  AND CODIGO = :COMPONENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORPROGRAMADO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="componentes/updatevalorprogramado">
		<call-query href="updateComponentesUpdatevalorprogramado">
			<with-param name="VALORPROGRAMADO" query-param="VALORPROGRAMADO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>

		</call-query>
	</resource>

</data>