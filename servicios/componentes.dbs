	<query id="deleteComponentes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM COMPONENTES WHERE COMPONENTES.COMPANIA= :KEY_COMPANIA AND COMPONENTES.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND COMPONENTES.CODIGO= :KEY_CODIGO AND COMPONENTES.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPROYECTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="componentes">
		<call-query href="deleteComponentes">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPROYECTO" query-param="KEY_CODIGOPROYECTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPOCOMPONENTE" query-param="KEY_TIPOCOMPONENTE"/>

		</call-query>
	</resource>
	<query id="getComponentesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPONENTES.VIGENCIA, NVL(BP_TIPOSCOMPONENTES.DESCRIPCION,COMPONENTES.TIPOCOMPONENTE) NOMBRETIPO, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.CODIGO, COMPONENTES.VALORTOTALSOLICITADO, COMPONENTES.VALORPROGRAMADO, COMPONENTES.VALOREJECUTADO, COMPONENTES.SALDOCOMPONENTE, COMPONENTES.VALORUNITARIO, COMPONENTES.VALORTOTAL, COMPONENTES.COMPANIA, COMPONENTES.CODIGOPROYECTO, COMPONENTES.TIPOCOMPONENTE  FROM COMPONENTES LEFT JOIN BP_TIPOSCOMPONENTES ON COMPONENTES.COMPANIA = BP_TIPOSCOMPONENTES.COMPANIA AND COMPONENTES.TIPOCOMPONENTE = BP_TIPOSCOMPONENTES.CODIGO WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :CODIGOPROYECTO ORDER BY COMPONENTES.VIGENCIA, COMPONENTES.CODIGO) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END)  LIKE UPPER(:NOMBRETIPO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN VALORTOTALSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORTOTALSOLICITADO) END)  LIKE UPPER(:VALORTOTALSOLICITADO || '%')  AND (CASE WHEN VALORPROGRAMADO IS NULL THEN ' ' ELSE UPPER(VALORPROGRAMADO) END)  LIKE UPPER(:VALORPROGRAMADO || '%')  AND (CASE WHEN VALOREJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOREJECUTADO) END)  LIKE UPPER(:VALOREJECUTADO || '%')  AND (CASE WHEN SALDOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(SALDOCOMPONENTE) END)  LIKE UPPER(:SALDOCOMPONENTE || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA":"$VIGENCIA(type:integer)","NOMBRETIPO":"$NOMBRETIPO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","CODIGO":"$CODIGO","VALORTOTALSOLICITADO":"$VALORTOTALSOLICITADO","VALORPROGRAMADO":"$VALORPROGRAMADO","VALOREJECUTADO":"$VALOREJECUTADO","SALDOCOMPONENTE":"$SALDOCOMPONENTE","VALORUNITARIO":"$VALORUNITARIO","VALORTOTAL":"$VALORTOTAL","COMPANIA":"$COMPANIA","CODIGOPROYECTO":"$CODIGOPROYECTO","TIPOCOMPONENTE":"$TIPOCOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VALORTOTALSOLICITADO" sqlType="STRING"/>
		<param name="VALORPROGRAMADO" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="SALDOCOMPONENTE" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="componentes">
		<call-query href="getComponentesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
