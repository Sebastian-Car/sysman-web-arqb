<data name="componentes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getComponentesTodosProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPONENTES.CODIGO, COMPONENTES.NOMBRECOMPONENTE  FROM COMPONENTES WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/todosproyecto">
		<call-query href="getComponentesTodosProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getComponentesPagTodosPorCompaniaYCodproQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPONENTES.CODIGO, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.VIGENCIA, COMPONENTES.VALORTOTAL  FROM COMPONENTES WHERE COMPONENTES.VIGENCIA = :ANO AND COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :CODIGOPROYECTO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","VIGENCIA":"$VIGENCIA(type:integer)","VALORTOTAL":"$VALORTOTAL"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="componentes/todosporcompaniaycodpro/pag">
		<call-query href="getComponentesPagTodosPorCompaniaYCodproQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComponentesDetallesNovedadesProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  C.NOMBRECOMPONENTE, C.TIPOCOMPONENTE, C.VALORPROGRAMADO PROGRAMADO, C.VALORTOTAL TOTAL, CA.VIGENCIA, C.VALOREJECUTADO, C.VALORTOTALSOLICITADO SOLICITADO, CA.CANTIDAD, CA.CANTIDAD_EJE, CA.NOMBREACTIVIDAD, (C.VALORTOTAL-C.VALORTOTALSOLICITADO) SALDO, (CA.CANTIDAD -CA.CANTIDAD_EJE) SALDOCANTIDAD  FROM COMPONENTES C LEFT JOIN COMPONENTES_ACTIVIDADES CA ON C.COMPANIA = CA.COMPANIA AND C.CODIGO = CA.COMPONENTE AND C.CODIGOPROYECTO = CA.CODIGOPROYECTO AND C.TIPOCOMPONENTE = CA.TIPOCOMPONENTE LEFT JOIN BP_ACTIVIDADES BPA ON CA.COMPANIA = BPA.COMPANIA AND CA.ACTIVIDAD = BPA.CODIGO WHERE C.Compania = :COMPANIA AND C.CodigoProyecto = :PROYECTO AND C.CODIGO = :COMPONENTE AND BPA.CODIGO = :ACTIVIDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","PROGRAMADO":"$PROGRAMADO","TOTAL":"$TOTAL","VIGENCIA":"$VIGENCIA(type:integer)","VALOREJECUTADO":"$VALOREJECUTADO","SOLICITADO":"$SOLICITADO","CANTIDAD":"$CANTIDAD","CANTIDAD_EJE":"$CANTIDAD_EJE","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","SALDO":"$SALDO","SALDOCANTIDAD":"$SALDOCANTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/detallesnovedadesproyecto">
		<call-query href="getComponentesDetallesNovedadesProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="getComponentesNumTodosPorCompaniaYCodproQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPONENTES.CODIGO, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.VIGENCIA, COMPONENTES.VALORTOTAL  FROM COMPONENTES WHERE COMPONENTES.VIGENCIA = :ANO AND COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :CODIGOPROYECTO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/todosporcompaniaycodpro/num">
		<call-query href="getComponentesNumTodosPorCompaniaYCodproQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>

		</call-query>
	</resource>
	<query id="getComponentesTotalesPorProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(NVL(VALORPROGRAMADO,0)) VALORPROGRAMADO, SUM(NVL(VALORTOTAL,0))VALORTOTAL, SUM(NVL(VALORUNITARIO,0))VALORUNITARIO, SUM(NVL(SALDOCOMPONENTE,0))SALDOCOMPONENTE, SUM(NVL(VALOREJECUTADO,0))VALOREJECUTADO, SUM(NVL(VALORTOTALSOLICITADO,0)) VALORTOTALSOLICITADO  FROM COMPONENTES WHERE COMPANIA = :COMPANIA AND CODIGOPROYECTO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORPROGRAMADO":"$VALORPROGRAMADO","VALORTOTAL":"$VALORTOTAL","VALORUNITARIO":"$VALORUNITARIO","SALDOCOMPONENTE":"$SALDOCOMPONENTE","VALOREJECUTADO":"$VALOREJECUTADO","VALORTOTALSOLICITADO":"$VALORTOTALSOLICITADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/totalesporproyecto">
		<call-query href="getComponentesTotalesPorProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getComponentesInformacionBasicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRECOMPONENTE, TIPOCOMPONENTE, VALOREJECUTADO, VALORTOTAL, VIGENCIA, UNIDAD, OBJETO, VALORUNITARIO, CANTIDAD  FROM COMPONENTES WHERE COMPANIA = :COMPANIA AND CODIGOPROYECTO = :CODIGOPROYECTO AND CODIGO = :CODIGO AND TIPOCOMPONENTE = :TIPOCOMPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","VALOREJECUTADO":"$VALOREJECUTADO","VALORTOTAL":"$VALORTOTAL","VIGENCIA":"$VIGENCIA(type:integer)","UNIDAD":"$UNIDAD","OBJETO":"$OBJETO","VALORUNITARIO":"$VALORUNITARIO","CANTIDAD":"$CANTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/informacionbasica">
		<call-query href="getComponentesInformacionBasicaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>

		</call-query>
	</resource>
	<query id="getComponentesPagValoresYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRECOMPONENTE, TIPOCOMPONENTE, CODIGOPROYECTO, VALORTOTAL, VALOREJECUTADO, VALORPROGRAMADO, VIGENCIA  FROM COMPONENTES WHERE COMPANIA = :COMPANIA AND CODIGOPROYECTO = :CODIGOPROYECTO AND VIGENCIA = :VIGENCIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","CODIGOPROYECTO":"$CODIGOPROYECTO","VALORTOTAL":"$VALORTOTAL","VALOREJECUTADO":"$VALOREJECUTADO","VALORPROGRAMADO":"$VALORPROGRAMADO","VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="componentes/valoresyvigencia/pag">
		<call-query href="getComponentesPagValoresYVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComponentesNumValoresYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRECOMPONENTE, TIPOCOMPONENTE, CODIGOPROYECTO, VALORTOTAL, VALOREJECUTADO, VALORPROGRAMADO, VIGENCIA  FROM COMPONENTES WHERE COMPANIA = :COMPANIA AND CODIGOPROYECTO = :CODIGOPROYECTO AND VIGENCIA = :VIGENCIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentes/valoresyvigencia/num">
		<call-query href="getComponentesNumValoresYVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>

		</call-query>
	</resource>
		<query id="getComponentesPagTipoYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT COMPONENTES.CODIGO COMPONENTE, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.TIPOCOMPONENTE, COMPONENTES.VALORPROGRAMADO PROGRAMADO, COMPONENTES.VALORTOTAL TOTAL, ( NVL(COMPONENTES.VALORTOTAL, 0) - NVL(COMPONENTES.VALOREJECUTADO, 0) ) SALDO, SUBSTR(COMPONENTES.OBJETO, 1, 100) OBJETO, COMPONENTES_ACTIVIDADES.VIGENCIA, COMPONENTES.VALOREJECUTADO, COMPONENTES.CODIGO COD, COMPONENTES.VALORTOTALSOLICITADO SOLICITADO FROM COMPONENTES LEFT JOIN COMPONENTES_ACTIVIDADES ON COMPONENTES.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND COMPONENTES.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND COMPONENTES.CODIGO = COMPONENTES_ACTIVIDADES.COMPONENTE AND COMPONENTES.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :PROYECTO AND (:VIGENCIA IS NULL OR COMPONENTES_ACTIVIDADES.VIGENCIA = :VIGENCIA) ORDER BY COMPONENTES.NOMBRECOMPONENTE, COMPONENTES_ACTIVIDADES.VIGENCIA) INI WHERE (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(:COMPONENTE, '%')) AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPONENTE), '%')) AND (CASE WHEN PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PROGRAMADO) END) LIKE UPPER(CONCAT(:PROGRAMADO, '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(:TOTAL, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(:VIGENCIA, '%')) AND (CASE WHEN VALOREJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOREJECUTADO) END) LIKE UPPER(CONCAT(:VALOREJECUTADO, '%')) AND (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END) LIKE UPPER(CONCAT(:COD, '%')) AND (CASE WHEN SOLICITADO IS NULL THEN ' ' ELSE UPPER(SOLICITADO) END) LIKE UPPER(CONCAT(:SOLICITADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPONENTE":"$COMPONENTE","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","PROGRAMADO":"$PROGRAMADO","TOTAL":"$TOTAL","SALDO":"$SALDO","OBJETO":"$OBJETO","VIGENCIA":"$VIGENCIA(type:integer)","VALOREJECUTADO":"$VALOREJECUTADO","COD":"$COD","SOLICITADO":"$SOLICITADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="PROGRAMADO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="SOLICITADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="componentes/tipoyvigencia/pag">
		<call-query href="getComponentesPagTipoYVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="PROGRAMADO" query-param="PROGRAMADO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VALOREJECUTADO" query-param="VALOREJECUTADO"/>
			<with-param name="COD" query-param="COD"/>
			<with-param name="SOLICITADO" query-param="SOLICITADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComponentesNumTipoYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT COMPONENTES.CODIGO COMPONENTE, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES.TIPOCOMPONENTE, COMPONENTES.VALORPROGRAMADO PROGRAMADO, COMPONENTES.VALORTOTAL TOTAL, (NVL(COMPONENTES.VALORTOTAL, 0) - NVL(COMPONENTES.VALOREJECUTADO, 0) ) SALDO, SUBSTR(COMPONENTES.OBJETO,1,100) OBJETO, COMPONENTES_ACTIVIDADES.VIGENCIA, COMPONENTES.VALOREJECUTADO, COMPONENTES.CODIGO COD, COMPONENTES.VALORTOTALSOLICITADO SOLICITADO FROM COMPONENTES LEFT JOIN COMPONENTES_ACTIVIDADES ON COMPONENTES.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND COMPONENTES.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND COMPONENTES.CODIGO = COMPONENTES_ACTIVIDADES.COMPONENTE AND COMPONENTES.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE WHERE COMPONENTES.COMPANIA = :COMPANIA AND COMPONENTES.CODIGOPROYECTO = :PROYECTO ORDER BY COMPONENTES.NOMBRECOMPONENTE, COMPONENTES_ACTIVIDADES.VIGENCIA) INI WHERE (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(:COMPONENTE, '%')) AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPONENTE), '%')) AND (CASE WHEN PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PROGRAMADO) END) LIKE UPPER(CONCAT(:PROGRAMADO, '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(:TOTAL, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(:VIGENCIA, '%')) AND (CASE WHEN VALOREJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOREJECUTADO) END) LIKE UPPER(CONCAT(:VALOREJECUTADO, '%')) AND (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END) LIKE UPPER(CONCAT(:COD, '%')) AND (CASE WHEN SOLICITADO IS NULL THEN ' ' ELSE UPPER(SOLICITADO) END) LIKE UPPER(CONCAT(:SOLICITADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="PROGRAMADO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
