<data name="evevidencias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEvevidencias" keyColumns="COMPANIA,NUMERO_EVALUACION,CLASE_EVALUACION,TIPO_EVALUACION,TIPO,CEDULA_EVALUADO,CEDULA_EVALUADOR,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_EVIDENCIAS (COMPANIA, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, CONSECUTIVO, COMPONENTE, DESCRIPCION, UBICACION, FECHA, OBSERVACIONES, APORTADO_POR, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NUMERO_EVALUACION, :CLASE_EVALUACION, :TIPO_EVALUACION, :CEDULA_EVALUADO, :SUCURSAL_EVALUADO, :CEDULA_EVALUADOR, :SUCURSAL_EVALUADOR, :CONSECUTIVO, :COMPONENTE, :DESCRIPCION, :UBICACION, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACIONES, :APORTADO_POR, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","KEY_TIPO_EVALUACION":"$TIPO_EVALUACION","KEY_TIPO":"$TIPO","KEY_CEDULA_EVALUADO":"$CEDULA_EVALUADO","KEY_CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="" name="APORTADO_POR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evevidencias">
		<call-query href="insertEvevidencias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_EVALUACION" query-param="NUMERO_EVALUACION"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="SUCURSAL_EVALUADOR" query-param="SUCURSAL_EVALUADOR"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="APORTADO_POR" query-param="APORTADO_POR"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteEvevidencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_EVIDENCIAS WHERE EV_EVIDENCIAS.COMPANIA= :KEY_COMPANIA AND EV_EVIDENCIAS.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_EVIDENCIAS.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_EVIDENCIAS.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_EVIDENCIAS.TIPO= :KEY_TIPO AND EV_EVIDENCIAS.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_EVIDENCIAS.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND EV_EVIDENCIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="INTEGER"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="evevidencias">
		<call-query href="deleteEvevidencias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_CEDULA_EVALUADOR" query-param="KEY_CEDULA_EVALUADOR"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEvevidenciasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_EVIDENCIAS.COMPANIA, EV_EVIDENCIAS.CONSECUTIVO, EV_EVIDENCIAS.NUMERO_EVALUACION, EV_EVIDENCIAS.TIPO_EVALUACION, EV_EVIDENCIAS.CLASE_EVALUACION, EV_EVIDENCIAS.COMPONENTE, EV_EVIDENCIAS.DESCRIPCION,(TO_CHAR(EV_EVIDENCIAS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, EV_EVIDENCIAS.CEDULA_EVALUADO, EV_EVIDENCIAS.CEDULA_EVALUADOR, EV_EVIDENCIAS.TIPO  FROM EV_EVIDENCIAS INNER JOIN EV_TIPO_DE_EVALUACION ON EV_EVIDENCIAS.COMPANIA = EV_TIPO_DE_EVALUACION.COMPANIA AND EV_EVIDENCIAS.TIPO_EVALUACION = EV_TIPO_DE_EVALUACION.CODIGO AND EV_EVIDENCIAS.CLASE_EVALUACION = EV_TIPO_DE_EVALUACION.CLASE_EVALUACION WHERE EV_EVIDENCIAS.COMPANIA = :COMPANIA AND EV_EVIDENCIAS.NUMERO_EVALUACION = :NUMEROEVALUACION AND EV_EVIDENCIAS.CLASE_EVALUACION = :CLASEEVALUACION AND EV_EVIDENCIAS.TIPO_EVALUACION = :TIPOEVALUACION AND EV_EVIDENCIAS.CEDULA_EVALUADO = :CEDULAEVALUADO AND EV_EVIDENCIAS.CEDULA_EVALUADOR = :CEDULAEVALUADOR) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER( '%' || :COMPONENTE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","TIPO_EVALUACION":"$TIPO_EVALUACION","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","COMPONENTE":"$COMPONENTE","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","CEDULA_EVALUADO":"$CEDULA_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROEVALUACION" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="TIPOEVALUACION" sqlType="STRING"/>
		<param name="CEDULAEVALUADO" sqlType="STRING"/>
		<param name="CEDULAEVALUADOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evevidencias">
		<call-query href="getEvevidenciasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROEVALUACION" query-param="NUMEROEVALUACION"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="TIPOEVALUACION" query-param="TIPOEVALUACION"/>
			<with-param name="CEDULAEVALUADO" query-param="CEDULAEVALUADO"/>
			<with-param name="CEDULAEVALUADOR" query-param="CEDULAEVALUADOR"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvevidenciasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_EVIDENCIAS.COMPANIA, EV_EVIDENCIAS.CONSECUTIVO, EV_EVIDENCIAS.NUMERO_EVALUACION, EV_EVIDENCIAS.TIPO_EVALUACION, EV_EVIDENCIAS.CLASE_EVALUACION, EV_EVIDENCIAS.COMPONENTE, EV_EVIDENCIAS.DESCRIPCION,(TO_CHAR(EV_EVIDENCIAS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, EV_EVIDENCIAS.CEDULA_EVALUADO, EV_EVIDENCIAS.CEDULA_EVALUADOR, EV_EVIDENCIAS.TIPO  FROM EV_EVIDENCIAS INNER JOIN EV_TIPO_DE_EVALUACION ON EV_EVIDENCIAS.COMPANIA = EV_TIPO_DE_EVALUACION.COMPANIA AND EV_EVIDENCIAS.TIPO_EVALUACION = EV_TIPO_DE_EVALUACION.CODIGO AND EV_EVIDENCIAS.CLASE_EVALUACION = EV_TIPO_DE_EVALUACION.CLASE_EVALUACION WHERE EV_EVIDENCIAS.COMPANIA = :COMPANIA AND EV_EVIDENCIAS.NUMERO_EVALUACION = :NUMEROEVALUACION AND EV_EVIDENCIAS.CLASE_EVALUACION = :CLASEEVALUACION AND EV_EVIDENCIAS.TIPO_EVALUACION = :TIPOEVALUACION AND EV_EVIDENCIAS.CEDULA_EVALUADO = :CEDULAEVALUADO AND EV_EVIDENCIAS.CEDULA_EVALUADOR = :CEDULAEVALUADOR) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER( '%' || :COMPONENTE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROEVALUACION" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="TIPOEVALUACION" sqlType="STRING"/>
		<param name="CEDULAEVALUADO" sqlType="STRING"/>
		<param name="CEDULAEVALUADOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evevidencias/numero">
		<call-query href="getEvevidenciasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROEVALUACION" query-param="NUMEROEVALUACION"/>
			<with-param name="CLASEEVALUACION" query-param="CLASEEVALUACION"/>
			<with-param name="TIPOEVALUACION" query-param="TIPOEVALUACION"/>
			<with-param name="CEDULAEVALUADO" query-param="CEDULAEVALUADO"/>
			<with-param name="CEDULAEVALUADOR" query-param="CEDULAEVALUADOR"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getEvevidenciasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  EV_EVIDENCIAS.COMPANIA, EV_EVIDENCIAS.NUMERO_EVALUACION, EV_EVIDENCIAS.CLASE_EVALUACION, EV_EVIDENCIAS.TIPO_EVALUACION, EV_EVIDENCIAS.CEDULA_EVALUADO, EV_EVIDENCIAS.SUCURSAL_EVALUADO, EV_EVIDENCIAS.CEDULA_EVALUADOR, EV_EVIDENCIAS.SUCURSAL_EVALUADOR, EV_EVIDENCIAS.CONSECUTIVO, EV_EVIDENCIAS.COMPONENTE, EV_EVIDENCIAS.DESCRIPCION, EV_EVIDENCIAS.UBICACION,(TO_CHAR(EV_EVIDENCIAS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, EV_EVIDENCIAS.OBSERVACIONES, EV_EVIDENCIAS.APORTADO_POR, EV_EVIDENCIAS.CREATED_BY,(TO_CHAR(EV_EVIDENCIAS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, EV_EVIDENCIAS.MODIFIED_BY,(TO_CHAR(EV_EVIDENCIAS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, EV_APORTADO_POR.NOMBRE  FROM EV_EVIDENCIAS LEFT JOIN EV_APORTADO_POR ON EV_EVIDENCIAS.COMPANIA = EV_APORTADO_POR.COMPANIA AND EV_EVIDENCIAS.APORTADO_POR = EV_APORTADO_POR.CODIGO WHERE EV_EVIDENCIAS.COMPANIA= :KEY_COMPANIA AND EV_EVIDENCIAS.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_EVIDENCIAS.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_EVIDENCIAS.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_EVIDENCIAS.TIPO= :KEY_TIPO AND EV_EVIDENCIAS.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_EVIDENCIAS.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND EV_EVIDENCIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR","CONSECUTIVO":"$CONSECUTIVO(type:long)","COMPONENTE":"$COMPONENTE","DESCRIPCION":"$DESCRIPCION","UBICACION":"$UBICACION","FECHA":"$FECHA","OBSERVACIONES":"$OBSERVACIONES","APORTADO_POR":"$APORTADO_POR(type:integer)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evevidencias/data">
		<call-query href="getEvevidenciasRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_CEDULA_EVALUADOR" query-param="KEY_CEDULA_EVALUADOR"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateEvevidencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_EVIDENCIAS SET COMPANIA=:COMPANIA, NUMERO_EVALUACION=:NUMERO_EVALUACION, CLASE_EVALUACION=:CLASE_EVALUACION, TIPO_EVALUACION=:TIPO_EVALUACION, CEDULA_EVALUADO=:CEDULA_EVALUADO, SUCURSAL_EVALUADO=:SUCURSAL_EVALUADO, CEDULA_EVALUADOR=:CEDULA_EVALUADOR, SUCURSAL_EVALUADOR=:SUCURSAL_EVALUADOR, CONSECUTIVO=:CONSECUTIVO, COMPONENTE=:COMPONENTE, DESCRIPCION=:DESCRIPCION, UBICACION=:UBICACION, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), OBSERVACIONES=:OBSERVACIONES, APORTADO_POR=:APORTADO_POR, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE EV_EVIDENCIAS.COMPANIA= :KEY_COMPANIA AND EV_EVIDENCIAS.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_EVIDENCIAS.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_EVIDENCIAS.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_EVIDENCIAS.TIPO= :KEY_TIPO AND EV_EVIDENCIAS.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_EVIDENCIAS.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND EV_EVIDENCIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="APORTADO_POR" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evevidencias">
		<call-query href="updateEvevidencias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_EVALUACION" query-param="NUMERO_EVALUACION"/>
