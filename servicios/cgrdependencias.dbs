<data name="cgrdependencias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCgrdependenciasTodosPorDependenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, DEPENDENCIA  FROM CGR_DEPENDENCIAS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
 
	</query>
	<resource method="GET" path="cgrdependencias/todospordependencias">
		<call-query href="getCgrdependenciasTodosPorDependenciasQuery">
 
		</call-query>
	</resource>

</data>