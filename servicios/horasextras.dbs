<data name="horasextras" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertHorasextras" keyColumns="CODIGO,ANO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO HORAS_EXTRAS (CODIGO, ANO, CONCEPTO, PORCENTAJE, CONCEPTO_RELACIONADO, FORMULA, DATE_CREATED, CREATED_BY) VALUES (:CODIGO, :ANO, :CONCEPTO, :PORCENTAJE, :CONCEPTO_RELACIONADO, :FORMULA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGO":"$CODIGO(type:long)","KEY_ANO":"$ANO(type:integer)","KEY_CONCEPTO":"$CONCEPTO(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="PORCENTAJE" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO_RELACIONADO" sqlType="STRING"/>
		<param defaultValue="" name="FORMULA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="horasextras">
		<call-query href="insertHorasextras">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="CONCEPTO_RELACIONADO" query-param="CONCEPTO_RELACIONADO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteHorasextras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM HORAS_EXTRAS WHERE HORAS_EXTRAS.CODIGO= :KEY_CODIGO AND HORAS_EXTRAS.ANO= :KEY_ANO AND HORAS_EXTRAS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CONCEPTO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="horasextras">
		<call-query href="deleteHorasextras">
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getHorasextrasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, ANO, CONCEPTO, C.NOMBRE_CONCEPTO, PORCENTAJE, CONCEPTO_RELACIONADO, CR.NOMBRE_CONCEPTO NOMBRE_RELACIONADO, FORMULA FROM HORAS_EXTRAS INNER JOIN CONCEPTOS C ON :COMPANIA = COMPANIA AND CONCEPTO = ID_DE_CONCEPTO LEFT JOIN CONCEPTOS CR ON :COMPANIA = CR.COMPANIA AND CONCEPTO_RELACIONADO = CR.ID_DE_CONCEPTO WHERE ANO = :ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(:PORCENTAJE, '%')) AND (CASE WHEN CONCEPTO_RELACIONADO IS NULL THEN ' ' ELSE UPPER(CONCEPTO_RELACIONADO) END) LIKE UPPER(CONCAT(:CONCEPTO_RELACIONADO, '%')) AND (CASE WHEN NOMBRE_RELACIONADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RELACIONADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RELACIONADO), '%')) AND (CASE WHEN FORMULA IS NULL THEN ' ' ELSE UPPER(FORMULA) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMULA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:long)","ANO":"$ANO(type:integer)","CONCEPTO":"$CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","PORCENTAJE":"$PORCENTAJE(type:double)","CONCEPTO_RELACIONADO":"$CONCEPTO_RELACIONADO(type:integer)","NOMBRE_RELACIONADO":"$NOMBRE_RELACIONADO","FORMULA":"$FORMULA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="CONCEPTO_RELACIONADO" sqlType="STRING"/>
		<param name="NOMBRE_RELACIONADO" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="horasextras">
		<call-query href="getHorasextrasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="CONCEPTO_RELACIONADO" query-param="CONCEPTO_RELACIONADO"/>
			<with-param name="NOMBRE_RELACIONADO" query-param="NOMBRE_RELACIONADO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getHorasextrasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, ANO, CONCEPTO, C.NOMBRE_CONCEPTO, PORCENTAJE, CONCEPTO_RELACIONADO, CR.NOMBRE_CONCEPTO NOMBRE_RELACIONADO, FORMULA FROM HORAS_EXTRAS INNER JOIN CONCEPTOS C ON :COMPANIA = COMPANIA AND CONCEPTO = ID_DE_CONCEPTO LEFT JOIN CONCEPTOS CR ON :COMPANIA = CR.COMPANIA AND CONCEPTO_RELACIONADO = CR.ID_DE_CONCEPTO WHERE ANO = :ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(:PORCENTAJE, '%')) AND (CASE WHEN CONCEPTO_RELACIONADO IS NULL THEN ' ' ELSE UPPER(CONCEPTO_RELACIONADO) END) LIKE UPPER(CONCAT(:CONCEPTO_RELACIONADO, '%')) AND (CASE WHEN NOMBRE_RELACIONADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_RELACIONADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_RELACIONADO), '%')) AND (CASE WHEN FORMULA IS NULL THEN ' ' ELSE UPPER(FORMULA) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMULA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="CONCEPTO_RELACIONADO" sqlType="STRING"/>
		<param name="NOMBRE_RELACIONADO" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="horasextras/numero">
		<call-query href="getHorasextrasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="CONCEPTO_RELACIONADO" query-param="CONCEPTO_RELACIONADO"/>
			<with-param name="NOMBRE_RELACIONADO" query-param="NOMBRE_RELACIONADO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>

		</call-query>
	</resource>
	<query id="updateHorasextras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE HORAS_EXTRAS SET CODIGO=:CODIGO, ANO=:ANO, CONCEPTO=:CONCEPTO, PORCENTAJE=:PORCENTAJE, CONCEPTO_RELACIONADO=:CONCEPTO_RELACIONADO, FORMULA=:FORMULA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE HORAS_EXTRAS.CODIGO= :KEY_CODIGO AND HORAS_EXTRAS.ANO= :KEY_ANO AND HORAS_EXTRAS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="CONCEPTO_RELACIONADO" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="horasextras">
		<call-query href="updateHorasextras">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="CONCEPTO_RELACIONADO" query-param="CONCEPTO_RELACIONADO"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>

</data>