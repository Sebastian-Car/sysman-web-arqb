		<param name="PERIODOANT6" sqlType="STRING"/>
		<param name="FECHACORTEC1" sqlType="STRING"/>
		<param name="FECHACORTEC2" sqlType="STRING"/>
		<param name="FECHACORTEC3" sqlType="STRING"/>
		<param name="FECHACORTEL1" sqlType="STRING"/>
		<param name="FECHACORTEL2" sqlType="STRING"/>
