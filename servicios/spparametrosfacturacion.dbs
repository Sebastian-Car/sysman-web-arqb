		<param name="FECHALIMITE3" sqlType="STRING"/>
		<param name="FECHAINICIOPERIODO" sqlType="STRING"/>
		<param name="FECHAFINPERIODO" sqlType="STRING"/>
		<param name="FECHASUSPENSION" sqlType="STRING"/>
		<param name="FECHAEXPEDICION" sqlType="STRING"/>
		<param name="FECHALIMITE2" sqlType="STRING"/>
		<param name="FECHALIMITE1" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>

	</query>
