	</resource>
	<query id="updateSpparametrosfacturacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_PARAMETROFACTURACION SET PAGO1=:PAGO1, PAGO2=:PAGO2, OBSERVACION2=:OBSERVACION2, OBSERVACION3=:OBSERVACION3, FACTURAINICIAL=:FACTURAINICIAL, NORECIBOINICIAL=:NORECIBOINICIAL, CODIGOINICIAL=:CODIGOINICIAL, CODIGOFINAL=:CODIGOFINAL, PERIODOCORTO=:PERIODOCORTO, PERIODOLARGO=:PERIODOLARGO, PERIODOANT1=:PERIODOANT1, PERIODOANT2=:PERIODOANT2, PERIODOANT3=:PERIODOANT3, PERIODOANT4=:PERIODOANT4, PERIODOANT5=:PERIODOANT5, PERIODOANT6=:PERIODOANT6, FECHACORTEC1=:FECHACORTEC1, FECHACORTEC2=:FECHACORTEC2, FECHACORTEC3=:FECHACORTEC3, FECHACORTEL1=:FECHACORTEL1, FECHACORTEL2=:FECHACORTEL2, FECHACORTEL3=:FECHACORTEL3, OBSERVACION1=:OBSERVACION1, PUBLICIDAD=:PUBLICIDAD, MODIFIED_BY=:MODIFIED_BY, FECHALIMITE3=TO_DATE(:FECHALIMITE3,'DD/MM/YYYY HH24:MI:SS'), FECHAINICIOPERIODO=TO_DATE(:FECHAINICIOPERIODO,'DD/MM/YYYY HH24:MI:SS'), FECHAFINPERIODO=TO_DATE(:FECHAFINPERIODO,'DD/MM/YYYY HH24:MI:SS'), FECHASUSPENSION=TO_DATE(:FECHASUSPENSION,'DD/MM/YYYY HH24:MI:SS'), FECHAEXPEDICION=TO_DATE(:FECHAEXPEDICION,'DD/MM/YYYY HH24:MI:SS'), FECHALIMITE2=TO_DATE(:FECHALIMITE2,'DD/MM/YYYY HH24:MI:SS'), FECHALIMITE1=TO_DATE(:FECHALIMITE1,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_PARAMETROFACTURACION.COMPANIA= :KEY_COMPANIA AND SP_PARAMETROFACTURACION.CICLO= :KEY_CICLO AND SP_PARAMETROFACTURACION.ANO= :KEY_ANO AND SP_PARAMETROFACTURACION.PERIODO= :KEY_PERIODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAGO1" sqlType="STRING"/>
		<param name="PAGO2" sqlType="STRING"/>
		<param name="OBSERVACION2" sqlType="STRING"/>
		<param name="OBSERVACION3" sqlType="STRING"/>
		<param name="FACTURAINICIAL" sqlType="STRING"/>
		<param name="NORECIBOINICIAL" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="PERIODOCORTO" sqlType="STRING"/>
		<param name="PERIODOLARGO" sqlType="STRING"/>
		<param name="PERIODOANT1" sqlType="STRING"/>
		<param name="PERIODOANT2" sqlType="STRING"/>
		<param name="PERIODOANT3" sqlType="STRING"/>
		<param name="PERIODOANT4" sqlType="STRING"/>
