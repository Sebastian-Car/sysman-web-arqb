<data name="sflocales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSflocalesPagLocalesLibresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_LOCALES.CODIGO, SF_LOCALES.ANCHO, SF_LOCALES.LARGO, SF_LOCALES.AREA, CASE WHEN SF_LOCALES.ESTADO = 'A' THEN 'Adjudicado' WHEN SF_LOCALES.ESTADO = 'L' THEN 'Libre' WHEN SF_LOCALES.ESTADO = 'D' THEN 'Proceso Desadjudicación' END NOMBRE_ESTADO, SF_LOCALES.DESCRIPCION, SF_LUGAR.NOMBRE NOMBRE_LUGAR, SF_UBICACION.NOMBRE NOMBRE_UBICACION, SF_LOCALES.CODIGO_ANTERIOR FROM SF_LOCALES LEFT JOIN SF_LUGAR ON SF_LOCALES.COMPANIA = SF_LUGAR.COMPANIA AND SF_LOCALES.UBICACION = SF_LUGAR.CODIGO LEFT JOIN SF_UBICACION ON SF_LOCALES.COMPANIA = SF_UBICACION.COMPANIA AND SF_LOCALES.UBICACION = SF_UBICACION.CODIGO WHERE SF_LOCALES.COMPANIA =:COMPANIA AND SF_LOCALES.ESTADO IN ('L') ORDER BY SF_LOCALES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ANCHO IS NULL THEN ' ' ELSE UPPER(ANCHO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANCHO), '%')) AND (CASE WHEN LARGO IS NULL THEN ' ' ELSE UPPER(LARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:LARGO), '%')) AND (CASE WHEN AREA IS NULL THEN ' ' ELSE UPPER(AREA) END) LIKE UPPER(CONCAT(CONCAT('%',:AREA), '%')) AND (CASE WHEN NOMBRE_ESTADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ESTADO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRE_LUGAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_LUGAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_LUGAR), '%')) AND (CASE WHEN NOMBRE_UBICACION IS NULL THEN ' ' ELSE UPPER(NOMBRE_UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_UBICACION), '%')) AND (CASE WHEN CODIGO_ANTERIOR IS NULL THEN ' ' ELSE UPPER(CODIGO_ANTERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_ANTERIOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","ANCHO":"$ANCHO","LARGO":"$LARGO","AREA":"$AREA","NOMBRE_ESTADO":"$NOMBRE_ESTADO","DESCRIPCION":"$DESCRIPCION","NOMBRE_LUGAR":"$NOMBRE_LUGAR","NOMBRE_UBICACION":"$NOMBRE_UBICACION","CODIGO_ANTERIOR":"$CODIGO_ANTERIOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANCHO" sqlType="STRING"/>
		<param name="LARGO" sqlType="STRING"/>
		<param name="AREA" sqlType="STRING"/>
		<param name="NOMBRE_ESTADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE_LUGAR" sqlType="STRING"/>
		<param name="NOMBRE_UBICACION" sqlType="STRING"/>
		<param name="CODIGO_ANTERIOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sflocales/localeslibres/pag">
		<call-query href="getSflocalesPagLocalesLibresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANCHO" query-param="ANCHO"/>
			<with-param name="LARGO" query-param="LARGO"/>
			<with-param name="AREA" query-param="AREA"/>
			<with-param name="NOMBRE_ESTADO" query-param="NOMBRE_ESTADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRE_LUGAR" query-param="NOMBRE_LUGAR"/>
			<with-param name="NOMBRE_UBICACION" query-param="NOMBRE_UBICACION"/>
			<with-param name="CODIGO_ANTERIOR" query-param="CODIGO_ANTERIOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSflocalesNumLocalesLibresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_LOCALES.CODIGO, SF_LOCALES.ANCHO, SF_LOCALES.LARGO, SF_LOCALES.AREA, CASE WHEN SF_LOCALES.ESTADO = 'A' THEN 'Adjudicado' WHEN SF_LOCALES.ESTADO = 'L' THEN 'Libre' WHEN SF_LOCALES.ESTADO = 'D' THEN 'Proceso Desadjudicación' END NOMBRE_ESTADO, SF_LOCALES.DESCRIPCION, SF_LUGAR.NOMBRE NOMBRE_LUGAR, SF_UBICACION.NOMBRE NOMBRE_UBICACION, SF_LOCALES.CODIGO_ANTERIOR FROM SF_LOCALES LEFT JOIN SF_LUGAR ON SF_LOCALES.COMPANIA = SF_LUGAR.COMPANIA AND SF_LOCALES.UBICACION = SF_LUGAR.CODIGO LEFT JOIN SF_UBICACION ON SF_LOCALES.COMPANIA = SF_UBICACION.COMPANIA AND SF_LOCALES.UBICACION = SF_UBICACION.CODIGO WHERE SF_LOCALES.COMPANIA =:COMPANIA AND SF_LOCALES.ESTADO IN ('L') ORDER BY SF_LOCALES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ANCHO IS NULL THEN ' ' ELSE UPPER(ANCHO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANCHO), '%')) AND (CASE WHEN LARGO IS NULL THEN ' ' ELSE UPPER(LARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:LARGO), '%')) AND (CASE WHEN AREA IS NULL THEN ' ' ELSE UPPER(AREA) END) LIKE UPPER(CONCAT(CONCAT('%',:AREA), '%')) AND (CASE WHEN NOMBRE_ESTADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ESTADO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRE_LUGAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_LUGAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_LUGAR), '%')) AND (CASE WHEN NOMBRE_UBICACION IS NULL THEN ' ' ELSE UPPER(NOMBRE_UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_UBICACION), '%')) AND (CASE WHEN CODIGO_ANTERIOR IS NULL THEN ' ' ELSE UPPER(CODIGO_ANTERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_ANTERIOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANCHO" sqlType="STRING"/>
		<param name="LARGO" sqlType="STRING"/>
		<param name="AREA" sqlType="STRING"/>
		<param name="NOMBRE_ESTADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE_LUGAR" sqlType="STRING"/>
		<param name="NOMBRE_UBICACION" sqlType="STRING"/>
		<param name="CODIGO_ANTERIOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sflocales/localeslibres/num">
		<call-query href="getSflocalesNumLocalesLibresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANCHO" query-param="ANCHO"/>
			<with-param name="LARGO" query-param="LARGO"/>
			<with-param name="AREA" query-param="AREA"/>
			<with-param name="NOMBRE_ESTADO" query-param="NOMBRE_ESTADO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRE_LUGAR" query-param="NOMBRE_LUGAR"/>
			<with-param name="NOMBRE_UBICACION" query-param="NOMBRE_UBICACION"/>
			<with-param name="CODIGO_ANTERIOR" query-param="CODIGO_ANTERIOR"/>

		</call-query>
	</resource>
	<query id="updateSflocalesActualizarEstado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_LOCALES SET ESTADO=:ESTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_LOCALES.COMPANIA= :KEY_COMPANIA AND SF_LOCALES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sflocales/actualizarestado">
		<call-query href="updateSflocalesActualizarEstado">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="insertSflocales" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_LOCALES (COMPANIA, CODIGO, ANCHO, LARGO, AREA, DESCRIPCION, ESTADO, LUGAR, UBICACION, CODIGO_ANTERIOR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :ANCHO, :LARGO, :AREA, :DESCRIPCION, :ESTADO, :LUGAR, :UBICACION, :CODIGO_ANTERIOR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="ANCHO" sqlType="STRING"/>
		<param defaultValue="" name="LARGO" sqlType="STRING"/>
		<param defaultValue="" name="AREA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="LUGAR" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_ANTERIOR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sflocales">
		<call-query href="insertSflocales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANCHO" query-param="ANCHO"/>
			<with-param name="LARGO" query-param="LARGO"/>
			<with-param name="AREA" query-param="AREA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="LUGAR" query-param="LUGAR"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="CODIGO_ANTERIOR" query-param="CODIGO_ANTERIOR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSflocales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_LOCALES WHERE SF_LOCALES.COMPANIA= :KEY_COMPANIA AND SF_LOCALES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sflocales">
		<call-query href="deleteSflocales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSflocalesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_LOCALES.COMPANIA, SF_LOCALES.CODIGO, SF_LOCALES.ANCHO, SF_LOCALES.LARGO, SF_LOCALES.AREA, SF_LOCALES.DESCRIPCION, CASE WHEN SF_LOCALES.ESTADO = 'A' THEN 'Adjudicado' WHEN SF_LOCALES.ESTADO = 'L' THEN 'Libre' WHEN SF_LOCALES.ESTADO = 'D' THEN 'Proceso Desadjudicación' END NOMBRE_ESTADO, SF_LOCALES.ESTADO, SF_LOCALES.LUGAR, SF_LUGAR.NOMBRE NOMBRE_LUGAR, SF_LOCALES.UBICACION, SF_UBICACION.NOMBRE NOMBRE_UBICACION, SF_LOCALES.CODIGO_ANTERIOR FROM SF_LOCALES LEFT JOIN SF_LUGAR ON SF_LOCALES.COMPANIA = SF_LUGAR.COMPANIA AND SF_LOCALES.LUGAR = SF_LUGAR.CODIGO LEFT JOIN SF_UBICACION ON SF_LOCALES.COMPANIA = SF_UBICACION.COMPANIA AND SF_LOCALES.UBICACION = SF_UBICACION.CODIGO WHERE SF_LOCALES.COMPANIA =:COMPANIA ORDER BY SF_LOCALES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ANCHO IS NULL THEN ' ' ELSE UPPER(ANCHO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANCHO), '%')) AND (CASE WHEN LARGO IS NULL THEN ' ' ELSE UPPER(LARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:LARGO), '%')) AND (CASE WHEN AREA IS NULL THEN ' ' ELSE UPPER(AREA) END) LIKE UPPER(CONCAT(CONCAT('%',:AREA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRE_ESTADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ESTADO), '%')) AND (CASE WHEN NOMBRE_LUGAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_LUGAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_LUGAR), '%')) AND (CASE WHEN NOMBRE_UBICACION IS NULL THEN ' ' ELSE UPPER(NOMBRE_UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_UBICACION), '%')) AND (CASE WHEN CODIGO_ANTERIOR IS NULL THEN ' ' ELSE UPPER(CODIGO_ANTERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_ANTERIOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","ANCHO":"$ANCHO","LARGO":"$LARGO","AREA":"$AREA","DESCRIPCION":"$DESCRIPCION","NOMBRE_ESTADO":"$NOMBRE_ESTADO","ESTADO":"$ESTADO","LUGAR":"$LUGAR","NOMBRE_LUGAR":"$NOMBRE_LUGAR","UBICACION":"$UBICACION","NOMBRE_UBICACION":"$NOMBRE_UBICACION","CODIGO_ANTERIOR":"$CODIGO_ANTERIOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANCHO" sqlType="STRING"/>
		<param name="LARGO" sqlType="STRING"/>
		<param name="AREA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE_ESTADO" sqlType="STRING"/>
		<param name="NOMBRE_LUGAR" sqlType="STRING"/>
		<param name="NOMBRE_UBICACION" sqlType="STRING"/>
		<param name="CODIGO_ANTERIOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sflocales">
		<call-query href="getSflocalesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANCHO" query-param="ANCHO"/>
			<with-param name="LARGO" query-param="LARGO"/>
			<with-param name="AREA" query-param="AREA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRE_ESTADO" query-param="NOMBRE_ESTADO"/>
			<with-param name="NOMBRE_LUGAR" query-param="NOMBRE_LUGAR"/>
			<with-param name="NOMBRE_UBICACION" query-param="NOMBRE_UBICACION"/>
			<with-param name="CODIGO_ANTERIOR" query-param="CODIGO_ANTERIOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSflocalesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_LOCALES.COMPANIA, SF_LOCALES.CODIGO, SF_LOCALES.ANCHO, SF_LOCALES.LARGO, SF_LOCALES.AREA, SF_LOCALES.DESCRIPCION, CASE WHEN SF_LOCALES.ESTADO = 'A' THEN 'Adjudicado' WHEN SF_LOCALES.ESTADO = 'L' THEN 'Libre' WHEN SF_LOCALES.ESTADO = 'D' THEN 'Proceso Desadjudicación' END NOMBRE_ESTADO, SF_LOCALES.ESTADO, SF_LOCALES.LUGAR, SF_LUGAR.NOMBRE NOMBRE_LUGAR, SF_LOCALES.UBICACION, SF_UBICACION.NOMBRE NOMBRE_UBICACION, SF_LOCALES.CODIGO_ANTERIOR FROM SF_LOCALES LEFT JOIN SF_LUGAR ON SF_LOCALES.COMPANIA = SF_LUGAR.COMPANIA AND SF_LOCALES.LUGAR = SF_LUGAR.CODIGO LEFT JOIN SF_UBICACION ON SF_LOCALES.COMPANIA = SF_UBICACION.COMPANIA AND SF_LOCALES.UBICACION = SF_UBICACION.CODIGO WHERE SF_LOCALES.COMPANIA =:COMPANIA ORDER BY SF_LOCALES.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ANCHO IS NULL THEN ' ' ELSE UPPER(ANCHO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANCHO), '%')) AND (CASE WHEN LARGO IS NULL THEN ' ' ELSE UPPER(LARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:LARGO), '%')) AND (CASE WHEN AREA IS NULL THEN ' ' ELSE UPPER(AREA) END) LIKE UPPER(CONCAT(CONCAT('%',:AREA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRE_ESTADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ESTADO), '%')) AND (CASE WHEN NOMBRE_LUGAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_LUGAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_LUGAR), '%')) AND (CASE WHEN NOMBRE_UBICACION IS NULL THEN ' ' ELSE UPPER(NOMBRE_UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_UBICACION), '%')) AND (CASE WHEN CODIGO_ANTERIOR IS NULL THEN ' ' ELSE UPPER(CODIGO_ANTERIOR) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_ANTERIOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANCHO" sqlType="STRING"/>
		<param name="LARGO" sqlType="STRING"/>
		<param name="AREA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE_ESTADO" sqlType="STRING"/>
		<param name="NOMBRE_LUGAR" sqlType="STRING"/>
		<param name="NOMBRE_UBICACION" sqlType="STRING"/>
		<param name="CODIGO_ANTERIOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sflocales/numero">
		<call-query href="getSflocalesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANCHO" query-param="ANCHO"/>
			<with-param name="LARGO" query-param="LARGO"/>
			<with-param name="AREA" query-param="AREA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRE_ESTADO" query-param="NOMBRE_ESTADO"/>
			<with-param name="NOMBRE_LUGAR" query-param="NOMBRE_LUGAR"/>
			<with-param name="NOMBRE_UBICACION" query-param="NOMBRE_UBICACION"/>
			<with-param name="CODIGO_ANTERIOR" query-param="CODIGO_ANTERIOR"/>

		</call-query>
	</resource>
	<query id="updateSflocales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_LOCALES SET CODIGO=:CODIGO, ANCHO=:ANCHO, LARGO=:LARGO, AREA=:AREA, DESCRIPCION=:DESCRIPCION, ESTADO=:ESTADO, LUGAR=:LUGAR, UBICACION=:UBICACION, CODIGO_ANTERIOR=:CODIGO_ANTERIOR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_LOCALES.COMPANIA= :KEY_COMPANIA AND SF_LOCALES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANCHO" sqlType="STRING"/>
		<param name="LARGO" sqlType="STRING"/>
		<param name="AREA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="LUGAR" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="CODIGO_ANTERIOR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sflocales">
		<call-query href="updateSflocales">
			<with-param name="CODIGO" query-param="CODIGO"/>
