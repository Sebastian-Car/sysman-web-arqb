		<sql>SELECT  CENTRO_COSTO.COMPANIA, CENTRO_COSTO.ANO, CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO ORDER BY CENTRO_COSTO.ANO DESC, CENTRO_COSTO.CODIGO ASC</sql>
