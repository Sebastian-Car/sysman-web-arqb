	<query id="getCentrocostosPagConCentroActivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE,(CASE CENTRO_COSTO.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA= :COMPANIA AND CENTRO_COSTO.ANO= :ANO AND CENTRO_COSTO.ACTIVOCENTRO NOT IN (0) AND CENTRO_COSTO.MOVIMIENTO NOT IN (0) ORDER BY CENTRO_COSTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
