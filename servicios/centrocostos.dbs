<data name="centrocostos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCentrocostosPagPorAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE ,(CASE CENTRO_COSTO.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="centrocostos/porano/pag">
		<call-query href="getCentrocostosPagPorAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosNumPorAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE ,(CASE CENTRO_COSTO.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/porano/num">
		<call-query href="getCentrocostosNumPorAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosPagTodosPorCodigoAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO AND CENTRO_COSTO.MOVIMIENTO NOT IN(0) ORDER BY CENTRO_COSTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="centrocostos/todosporcodigoano/pag">
		<call-query href="getCentrocostosPagTodosPorCodigoAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosNumTodosPorCodigoAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANO AND CENTRO_COSTO.MOVIMIENTO NOT IN(0) ORDER BY CENTRO_COSTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/todosporcodigoano/num">
		<call-query href="getCentrocostosNumTodosPorCodigoAnoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCentrocostosPagTodosPorCodigoNombreIgualQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA =:COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="centrocostos/todosporcodigonombreigual/pag">
		<call-query href="getCentrocostosPagTodosPorCodigoNombreIgualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosNumTodosPorCodigoNombreIgualQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA =:COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/todosporcodigonombreigual/num">
		<call-query href="getCentrocostosNumTodosPorCodigoNombreIgualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCentrocostosPagTodosPorCodigoNombreMayorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA =:COMPANIA AND CENTRO_COSTO.CODIGO &gt;= :COSTOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COSTOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="centrocostos/todosporcodigonombremayor/pag">
		<call-query href="getCentrocostosPagTodosPorCodigoNombreMayorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COSTOINICIAL" query-param="COSTOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosNumTodosPorCodigoNombreMayorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA =:COMPANIA AND CENTRO_COSTO.CODIGO &gt;= :COSTOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COSTOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/todosporcodigonombremayor/num">
		<call-query href="getCentrocostosNumTodosPorCodigoNombreMayorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COSTOINICIAL" query-param="COSTOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCentrocostosPagTodosPorAnioInicialMayorizarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM CENTRO_COSTO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND LENGTH(CODIGO) = CASE WHEN TO_CHAR(:NIVEL) = 0 THEN LENGTH(CODIGO) ELSE TO_NUMBER(:NIVEL) END ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="centrocostos/todosporanioinicialmayorizar/pag">
		<call-query href="getCentrocostosPagTodosPorAnioInicialMayorizarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertCentrocostos" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CENTRO_COSTO (ANO, CODIGO, NOMBRE, TIPO, MOVIMIENTO, CATEGORIAGASTO, APLICADISTRIBUCION, ACTIVOCENTRO, COMPANIA, CREATED_BY, DATE_CREATED, DISTRIBUIR, EQUIVALENTE_SIG_VIG) VALUES (:ANO, :CODIGO, :NOMBRE, :TIPO, :MOVIMIENTO, :CATEGORIAGASTO, :APLICADISTRIBUCION, :ACTIVOCENTRO, :COMPANIA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :DISTRIBUIR, :EQUIVALENTE_SIG_VIG)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="D" name="TIPO" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="CATEGORIAGASTO" sqlType="STRING"/>
		<param defaultValue="0" name="APLICADISTRIBUCION" sqlType="STRING"/>
		<param defaultValue="-1" name="ACTIVOCENTRO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="DISTRIBUIR" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVALENTE_SIG_VIG" sqlType="STRING"/>

	</query>
	<resource method="POST" path="centrocostos">
		<call-query href="insertCentrocostos">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="CATEGORIAGASTO" query-param="CATEGORIAGASTO"/>
			<with-param name="APLICADISTRIBUCION" query-param="APLICADISTRIBUCION"/>
			<with-param name="ACTIVOCENTRO" query-param="ACTIVOCENTRO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="DISTRIBUIR" query-param="DISTRIBUIR"/>
			<with-param name="EQUIVALENTE_SIG_VIG" query-param="EQUIVALENTE_SIG_VIG"/>

		</call-query>
	</resource>
	<query id="deleteCentrocostos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA= :KEY_COMPANIA AND CENTRO_COSTO.ANO= :KEY_ANO AND CENTRO_COSTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="centrocostos">
		<call-query href="deleteCentrocostos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CENTRO_COSTO.COMPANIA, CENTRO_COSTO.ANO, CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA ORDER BY CENTRO_COSTO.ANO DESC, CENTRO_COSTO.CODIGO ASC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="centrocostos">
		<call-query href="getCentrocostosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CENTRO_COSTO.COMPANIA, CENTRO_COSTO.ANO, CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA ORDER BY CENTRO_COSTO.ANO DESC, CENTRO_COSTO.CODIGO ASC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/numero">
		<call-query href="getCentrocostosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCentrocostosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT CENTRO_COSTO.ANO, CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE, CENTRO_COSTO.TIPO,(CASE CENTRO_COSTO.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, CENTRO_COSTO.CATEGORIAGASTO,(CASE CENTRO_COSTO.APLICADISTRIBUCION WHEN 0 THEN 'false' ELSE 'true' END) APLICADISTRIBUCION,(CASE CENTRO_COSTO.ACTIVOCENTRO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVOCENTRO, CENTRO_COSTO.COMPANIA, CENTRO_COSTO.CREATED_BY,(TO_CHAR(CENTRO_COSTO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CENTRO_COSTO.MODIFIED_BY,(TO_CHAR(CENTRO_COSTO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE DISTRIBUIR WHEN 0 THEN 'false' ELSE 'true' END) DISTRIBUIR, CENTRO_COSTO.EQUIVALENTE_SIG_VIG FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA= :KEY_COMPANIA AND CENTRO_COSTO.ANO= :KEY_ANO AND CENTRO_COSTO.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPO":"$TIPO","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","CATEGORIAGASTO":"$CATEGORIAGASTO","APLICADISTRIBUCION":"$APLICADISTRIBUCION(type:boolean)","ACTIVOCENTRO":"$ACTIVOCENTRO(type:boolean)","COMPANIA":"$COMPANIA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DISTRIBUIR":"$DISTRIBUIR(type:boolean)","EQUIVALENTE_SIG_VIG":"$EQUIVALENTE_SIG_VIG"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/data">
		<call-query href="getCentrocostosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateCentrocostos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CENTRO_COSTO SET NOMBRE=:NOMBRE, TIPO=:TIPO, MOVIMIENTO=:MOVIMIENTO, CATEGORIAGASTO=:CATEGORIAGASTO, APLICADISTRIBUCION=:APLICADISTRIBUCION, ACTIVOCENTRO=:ACTIVOCENTRO, DISTRIBUIR=:DISTRIBUIR, EQUIVALENTE_SIG_VIG=:EQUIVALENTE_SIG_VIG, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CENTRO_COSTO.COMPANIA= :KEY_COMPANIA AND CENTRO_COSTO.ANO= :KEY_ANO AND CENTRO_COSTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CATEGORIAGASTO" sqlType="STRING"/>
		<param name="APLICADISTRIBUCION" sqlType="STRING"/>
		<param name="ACTIVOCENTRO" sqlType="STRING"/>
		<param name="DISTRIBUIR" sqlType="STRING"/>
		<param name="EQUIVALENTE_SIG_VIG" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="centrocostos">
		<call-query href="updateCentrocostos">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="CATEGORIAGASTO" query-param="CATEGORIAGASTO"/>
			<with-param name="APLICADISTRIBUCION" query-param="APLICADISTRIBUCION"/>
			<with-param name="ACTIVOCENTRO" query-param="ACTIVOCENTRO"/>
			<with-param name="DISTRIBUIR" query-param="DISTRIBUIR"/>
			<with-param name="EQUIVALENTE_SIG_VIG" query-param="EQUIVALENTE_SIG_VIG"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getCentrocostosNumTodosPorAnioInicialMayorizarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM CENTRO_COSTO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND LENGTH(CODIGO) = CASE WHEN TO_CHAR(:NIVEL) = 0 THEN LENGTH(CODIGO) ELSE TO_NUMBER(:NIVEL) END ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/todosporanioinicialmayorizar/num">
		<call-query href="getCentrocostosNumTodosPorAnioInicialMayorizarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCentrocostosPagTodosDistinctPorAnioFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM CENTRO_COSTO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO &gt;= :CENTROINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CENTROINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="centrocostos/todosdistinctporaniofinal/pag">
		<call-query href="getCentrocostosPagTodosDistinctPorAnioFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CENTROINICIAL" query-param="CENTROINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
