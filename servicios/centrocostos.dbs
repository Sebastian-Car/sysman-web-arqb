	<query id="getCentrocostosCentrocostoxpaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT T.*, ROWNUM RN FROM ( SELECT COMPANIA, ANO, CODIGO, NOMBRE FROM CENTRO_COSTO WHERE COMPANIA = :COMPANIA AND ANO = :ANIO ORDER BY CODIGO ) T WHERE ROWNUM &lt;= :PAGINICIO + :PAGTAMANIO ) WHERE RN &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","RN":"$RN(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
