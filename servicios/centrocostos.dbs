	<query id="getCentrocostosPagCentrodecosto/inicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE ULTIMODENOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA =:COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ULTIMODENOMBRE IS NULL THEN ' ' ELSE UPPER(ULTIMODENOMBRE) END)  LIKE UPPER( '%' || :ULTIMODENOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","ULTIMODENOMBRE":"$ULTIMODENOMBRE"}]}}		</result>
