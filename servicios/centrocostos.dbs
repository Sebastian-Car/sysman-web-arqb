	<query id="getCentrocostosPagConplanpptalporcuentaanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO INNER JOIN V_PLAN_PRESUPUESTAL ON CENTRO_COSTO.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND CENTRO_COSTO.CODIGO = V_PLAN_PRESUPUESTAL.CENTRO_COSTO AND CENTRO_COSTO.ANO = V_PLAN_PRESUPUESTAL.ANO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.CODIGO = :CODCUENTA AND V_PLAN_PRESUPUESTAL.ANO = :ANIO AND CENTRO_COSTO.CODIGO &lt;&gt; :CODIGOEXCLUIDO AND CENTRO_COSTO.ACTIVOCENTRO NOT IN ( 0 ) GROUP BY CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE, CENTRO_COSTO.TIPO ORDER BY CENTRO_COSTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGOEXCLUIDO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
