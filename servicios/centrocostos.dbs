		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE  FROM CENTRO_COSTO WHERE CENTRO_COSTO.COMPANIA = :COMPANIA AND CENTRO_COSTO.ANO = :ANIO AND CENTRO_COSTO.CODIGO &lt;&gt; :CODIGOEXCLUIDO AND CENTRO_COSTO.ACTIVOCENTRO NOT IN (0) ORDER BY CENTRO_COSTO.CODIGO, CENTRO_COSTO.NOMBRE) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGOEXCLUIDO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="centrocostos/codigonombresinactivocentroconcodigoexcluido/num">
		<call-query href="getCentrocostosNumCodigonombresinactivocentroconcodigoexcluidoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGOEXCLUIDO" query-param="CODIGOEXCLUIDO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getCentrocostosConindicadoresdistribuiractivocentroporanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ANO, CODIGO, NOMBRE, PORCENTAJEDIS  FROM CENTRO_COSTO WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND DISTRIBUIR NOT IN (0) AND ACTIVOCENTRO NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PORCENTAJEDIS":"$PORCENTAJEDIS"}]}}		</result>
