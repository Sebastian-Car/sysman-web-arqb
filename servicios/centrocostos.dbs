	<query id="getCentrocostosPagGetccostoporaniorubrofuenterecQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CENTRO_COSTO.CODIGO CODIGO, CENTRO_COSTO.NOMBRE NOMBRE FROM V_PLAN_PRESUPUESTAL LEFT JOIN CENTRO_COSTO ON V_PLAN_PRESUPUESTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = CENTRO_COSTO.ANO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO = :COD_RUBRO AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = :FUENTE_RECURSO AND V_PLAN_PRESUPUESTAL.REFERENCIA = :REFERENCIA ORDER BY CENTRO_COSTO.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
