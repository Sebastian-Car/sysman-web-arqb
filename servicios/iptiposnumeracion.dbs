<data name="iptiposnumeracion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIptiposnumeracionTodosCodigoNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM IP_TIPOSNUMERACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="iptiposnumeracion/todoscodigonombre">
		<call-query href="getIptiposnumeracionTodosCodigoNombreQuery">
 
		</call-query>
	</resource>
	<query id="getIptiposnumeracionNumeroDeDigitosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DIGITOS  FROM IP_TIPOSNUMERACION WHERE CODIGO IN(:CODIGO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIGITOS":"$DIGITOS(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="iptiposnumeracion/numerodedigitosporcodigo">
		<call-query href="getIptiposnumeracionNumeroDeDigitosPorCodigoQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>

</data>