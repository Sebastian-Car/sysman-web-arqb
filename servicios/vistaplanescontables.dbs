<query id="getVistaplanescontablesPagPorconciliacionbancariamovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE, COD_EQUIV, MOVIMIENTO + MAN_AUX_TER + MAN_CEN_CTO + MAN_AUX_GEN + MAN_AUX_REF SECONCILIA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CLASECUENTA = 'B' AND MOVIMIENTO + MAN_AUX_TER + MAN_CEN_CTO + MAN_AUX_GEN + MAN_AUX_REF = - 1 ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","COD_EQUIV":"$COD_EQUIV","SECONCILIA":"$SECONCILIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistaplanescontables/porconciliacionbancariamovimiento/pag">
		<call-query href="getVistaplanescontablesPagPorconciliacionbancariamovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanescontablesNumPorconciliacionbancariamovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE, COD_EQUIV, MOVIMIENTO + MAN_AUX_TER + MAN_CEN_CTO + MAN_AUX_GEN + MAN_AUX_REF SECONCILIA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CLASECUENTA = 'B' AND MOVIMIENTO + MAN_AUX_TER + MAN_CEN_CTO + MAN_AUX_GEN + MAN_AUX_REF = - 1 ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanescontables/porconciliacionbancariamovimiento/num">
		<call-query href="getVistaplanescontablesNumPorconciliacionbancariamovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

