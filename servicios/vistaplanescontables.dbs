			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getVistaplanescontablesPagTodasLasCuentasBancosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE  FROM V_PLAN_CONTABLE PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND (PLAN_CONTABLE.CLASECUENTA = 'B' OR PLAN_CONTABLE.CLASECUENTA = 'J') AND PLAN_CONTABLE.MOVIMIENTO NOT IN (0) AND PLAN_CONTABLE.ANO = :ANO ORDER BY PLAN_CONTABLE.ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
