	<query id="getVistaplanescontablesPorcretencioncuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASECUENTA, PORCRETENCION FROM PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND CODIGO =:CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASECUENTA":"$CLASECUENTA","PORCRETENCION":"$PORCRETENCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
