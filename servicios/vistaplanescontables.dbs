	<query id="getVistaplanescontablesValorCxpQuery"  useConfig="sysmandsunist">
		<sql>SELECT  D1.VALOR_DEBITO-D1.DEBITO_AFECTADO+D1.VALOR_CREDITO-D1.CREDITO_AFECTADO-:VALORD VALOR_CXP  FROM V_PLAN_CONTABLE INNER JOIN DETALLE_COMPROBANTE_CNT D1 ON V_PLAN_CONTABLE.COMPANIA = D1.COMPANIA AND V_PLAN_CONTABLE.ANO = D1.ANO AND V_PLAN_CONTABLE.ID = D1.ID INNER JOIN DETALLE_COMPROBANTE_CNT CXP ON D1.COMPANIA = CXP.COMPANIA AND D1.ANO = CXP.ANO AND D1.TIPO_CPTE = CXP.TIPO_CPTE_AFECT AND D1.COMPROBANTE = CXP.CMPTE_AFECTADO WHERE CXP.COMPANIA=:COMPANIA AND CXP.ANO=:ANO AND CXP.TIPO_CPTE=:TIPOCOMP AND CXP.COMPROBANTE=:NUMEROCOMP AND CXP.ID=:CUENTA AND V_PLAN_CONTABLE.CLASECUENTA IN('P','E')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_CXP":"$VALOR_CXP(type:integer)"}]}}		</result>
		<param name="VALORD" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanescontables/valorcxp">
		<call-query href="getVistaplanescontablesValorCxpQuery">
			<with-param name="VALORD" query-param="VALORD"/>
