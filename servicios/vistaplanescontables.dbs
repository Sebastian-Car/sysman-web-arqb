	<query id="getVistaplanescontablesPagTodosPorAniotienenmovYTienenauxQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT V_PLAN_CONTABLE.ID, V_PLAN_CONTABLE.NOMBRE, V_PLAN_CONTABLE.CLASECUENTA, V_PLAN_CONTABLE.COMPANIA, V_PLAN_CONTABLE.ANO, V_PLAN_CONTABLE.MOVIMIENTO + V_PLAN_CONTABLE.MAN_CEN_CTO + V_PLAN_CONTABLE.MAN_AUX_TER + V_PLAN_CONTABLE.MAN_AUX_GEN TIENENMOV ,CONCAT(V_PLAN_CONTABLE.TERCERO ,CONCAT(V_PLAN_CONTABLE.CENTRO_COSTO, V_PLAN_CONTABLE.AUXILIAR)) TIENEAUX FROM V_PLAN_CONTABLE WHERE V_PLAN_CONTABLE.COMPANIA =:COMPANIA AND V_PLAN_CONTABLE.ANO =:ANO AND V_PLAN_CONTABLE.MOVIMIENTO + V_PLAN_CONTABLE.MAN_CEN_CTO + V_PLAN_CONTABLE.MAN_AUX_TER + V_PLAN_CONTABLE.MAN_AUX_GEN &lt;&gt; 0 AND V_PLAN_CONTABLE.CENTRO_COSTO IS NULL AND V_PLAN_CONTABLE.TERCERO IS NULL AND V_PLAN_CONTABLE.SUCURSAL IS NULL AND V_PLAN_CONTABLE.AUXILIAR IS NULL ORDER BY V_PLAN_CONTABLE.COMPANIA, V_PLAN_CONTABLE.ANO, V_PLAN_CONTABLE.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASECUENTA), '%')) AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN TIENENMOV IS NULL THEN ' ' ELSE UPPER(TIENENMOV) END) LIKE UPPER(CONCAT(CONCAT('%',:TIENENMOV), '%')) AND (CASE WHEN TIENEAUX IS NULL THEN ' ' ELSE UPPER(TIENEAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:TIENEAUX), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","CLASECUENTA":"$CLASECUENTA","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIENENMOV":"$TIENENMOV(type:integer)","TIENEAUX":"$TIENEAUX"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="TIENENMOV" sqlType="STRING"/>
		<param name="TIENEAUX" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
