	<query id="getVistaplanescontablesCuentaPptalPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT('''' ,CONCAT( REPLACE(V_PLAN_CONTABLE.CUENTA_PPTAL,',',''',''') , '''')) CUENTA_PPTAL FROM V_PLAN_CONTABLE WHERE V_PLAN_CONTABLE.COMPANIA =:COMPANIA AND V_PLAN_CONTABLE.ANO =:ANO AND V_PLAN_CONTABLE.CODIGO =:CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA_PPTAL":"$CUENTA_PPTAL"}]}}		</result>
