	<query id="getVistaplanescontablesAuxiliarGeneralQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT NOMBRE, MAN_AUX_GEN  FROM V_PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND V_PLAN_CONTABLE.ANO = :ANO AND V_PLAN_CONTABLE.ID = :CODIGO</sql>
