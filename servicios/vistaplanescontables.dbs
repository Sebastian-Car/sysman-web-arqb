	<query id="getVistaplanescontablesNumCuentasDeExogenasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT V_PLAN_CONTABLE.CODIGO CUENTA, V_PLAN_CONTABLE.NOMBRE, CLASECUENTA.DESCRIPCION CLASECUENTA, CASE WHEN CONFIGURACION_EXOGENA.FORMATO = :FORMATO THEN CONFIGURACION_EXOGENA.CONCEPTO ELSE NULL END CONCEPTO, CASE WHEN V_PLAN_CONTABLE.MOVIMIENTO IN(0) THEN 'false' ELSE 'true' END MOVIMIENTO,(CASE V_PLAN_CONTABLE.EXDISTRITAL WHEN 0 THEN 'false' ELSE 'true' END) EXDISTRITAL, CASE WHEN V_PLAN_CONTABLE.RETEPRACTICADA IN(0) THEN 'false' ELSE 'true' END RETEPRACTICADA , CASE WHEN V_PLAN_CONTABLE.RETEASUMIDA IN (0) THEN 'false' ELSE 'true' END RETEASUMIDA , CASE WHEN V_PLAN_CONTABLE.IVACOMUN IN(0) THEN 'false' ELSE 'true' END IVACOMUN , CASE WHEN V_PLAN_CONTABLE.IVASIMPLIFICADO IN(0) THEN 'false' ELSE 'true' END IVASIMPLIFICADO , CASE WHEN V_PLAN_CONTABLE.RETEICA IN(0) THEN 'false' ELSE 'true' END RETEICA ,(CASE V_PLAN_CONTABLE.MOSTRARF1001 WHEN 0 THEN 'false' ELSE 'true' END) MOSTRARF1001,(CASE V_PLAN_CONTABLE.IND_AGENTE_RETENCION WHEN 0 THEN 'false' ELSE 'true' END) IND_AGENTE_RETENCION,(CASE V_PLAN_CONTABLE.IND_SUJETO_RETENCION WHEN 0 THEN 'false' ELSE 'true' END) IND_SUJETO_RETENCION FROM V_PLAN_CONTABLE INNER JOIN CLASECUENTA ON V_PLAN_CONTABLE.CLASECUENTA = CLASECUENTA.CODIGO LEFT JOIN CONFIGURACION_EXOGENA ON V_PLAN_CONTABLE.COMPANIA = CONFIGURACION_EXOGENA.COMPANIA AND V_PLAN_CONTABLE.ANO = CONFIGURACION_EXOGENA.ANO AND V_PLAN_CONTABLE.CODIGO = CONFIGURACION_EXOGENA.CUENTA AND :FORMATO = CONFIGURACION_EXOGENA.FORMATO WHERE V_PLAN_CONTABLE.COMPANIA = :COMPANIA AND V_PLAN_CONTABLE.ANO = :ANO ORDER BY V_PLAN_CONTABLE.CODIGO) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASECUENTA), '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MOVIMIENTO), '%')) AND (CASE WHEN EXDISTRITAL IS NULL THEN ' ' ELSE UPPER(EXDISTRITAL) END) LIKE UPPER(CONCAT(CONCAT('%',:EXDISTRITAL), '%')) AND (CASE WHEN RETEPRACTICADA IS NULL THEN ' ' ELSE UPPER(RETEPRACTICADA) END) LIKE UPPER(CONCAT(CONCAT('%',:RETEPRACTICADA), '%')) AND (CASE WHEN RETEASUMIDA IS NULL THEN ' ' ELSE UPPER(RETEASUMIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:RETEASUMIDA), '%')) AND (CASE WHEN IVACOMUN IS NULL THEN ' ' ELSE UPPER(IVACOMUN) END) LIKE UPPER(CONCAT(CONCAT('%',:IVACOMUN), '%')) AND (CASE WHEN IVASIMPLIFICADO IS NULL THEN ' ' ELSE UPPER(IVASIMPLIFICADO) END) LIKE UPPER(CONCAT(CONCAT('%',:IVASIMPLIFICADO), '%')) AND (CASE WHEN RETEICA IS NULL THEN ' ' ELSE UPPER(RETEICA) END) LIKE UPPER(CONCAT(CONCAT('%',:RETEICA), '%')) AND (CASE WHEN MOSTRARF1001 IS NULL THEN ' ' ELSE UPPER(MOSTRARF1001) END) LIKE UPPER(CONCAT(CONCAT('%',:MOSTRARF1001), '%')) AND (CASE WHEN IND_AGENTE_RETENCION IS NULL THEN ' ' ELSE UPPER(IND_AGENTE_RETENCION) END) LIKE UPPER(CONCAT(CONCAT('%',:IND_AGENTE_RETENCION), '%')) AND (CASE WHEN IND_SUJETO_RETENCION IS NULL THEN ' ' ELSE UPPER(IND_SUJETO_RETENCION) END) LIKE UPPER(CONCAT(CONCAT('%',:IND_SUJETO_RETENCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="EXDISTRITAL" sqlType="STRING"/>
		<param name="RETEPRACTICADA" sqlType="STRING"/>
		<param name="RETEASUMIDA" sqlType="STRING"/>
		<param name="IVACOMUN" sqlType="STRING"/>
		<param name="IVASIMPLIFICADO" sqlType="STRING"/>
		<param name="RETEICA" sqlType="STRING"/>
		<param name="MOSTRARF1001" sqlType="STRING"/>
		<param name="IND_AGENTE_RETENCION" sqlType="STRING"/>
		<param name="IND_SUJETO_RETENCION" sqlType="STRING"/>

	</query>
