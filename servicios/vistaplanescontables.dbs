	<query id="getVistaplanescontablesPagReservaApropiacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.AUXILIAR  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.NATURALEZA = 'D' AND V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.TIPOVIGENCIA = 'RA' ORDER BY V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ANO, V_PLAN_PRESUPUESTAL.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","AUXILIAR":"$AUXILIAR"}]}}		</result>
