	<query id="getVistaplanescontablesNumNombreauxliarcentrofuenteporcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT V_PLAN_CONTABLE.ID, V_PLAN_CONTABLE.NOMBRE, AUXILIAR.NOMBRE AUXILIARNOM, CENTRO_COSTO.NOMBRE CENTRONOM, TRIM(TERCERO.NOMBRE) TERCERONOM, FUENTE_RECURSOS.NOMBRE FUENTENOM, REFERENCIA.NOMBRE REFERENCIANOM, TRIM(TERCERO.NIT) TERCERONIT FROM V_PLAN_CONTABLE LEFT JOIN CENTRO_COSTO ON V_PLAN_CONTABLE.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_CONTABLE.ANO = CENTRO_COSTO.ANO AND V_PLAN_CONTABLE.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON V_PLAN_CONTABLE.COMPANIA = AUXILIAR.COMPANIA AND V_PLAN_CONTABLE.ANO = AUXILIAR.ANO AND V_PLAN_CONTABLE.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN FUENTE_RECURSOS ON V_PLAN_CONTABLE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_PLAN_CONTABLE.ANO = FUENTE_RECURSOS.ANO AND V_PLAN_CONTABLE.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO LEFT JOIN TERCERO ON V_PLAN_CONTABLE.COMPANIA = TERCERO.COMPANIA AND V_PLAN_CONTABLE.TERCERO = TERCERO.NIT AND V_PLAN_CONTABLE.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN REFERENCIA ON V_PLAN_CONTABLE.COMPANIA = REFERENCIA.COMPANIA AND V_PLAN_CONTABLE.ANO = REFERENCIA.ANO AND V_PLAN_CONTABLE.REFERENCIA = REFERENCIA.CODIGO WHERE V_PLAN_CONTABLE.COMPANIA = :COMPANIA AND V_PLAN_CONTABLE.ANO = :ANIO AND V_PLAN_CONTABLE.CODIGO = :CODIGOF ORDER BY V_PLAN_CONTABLE.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN AUXILIARNOM IS NULL THEN ' ' ELSE UPPER(AUXILIARNOM) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIARNOM), '%')) AND (CASE WHEN CENTRONOM IS NULL THEN ' ' ELSE UPPER(CENTRONOM) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRONOM), '%')) AND (CASE WHEN TERCERONOM IS NULL THEN ' ' ELSE UPPER(TERCERONOM) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERONOM), '%')) AND (CASE WHEN FUENTENOM IS NULL THEN ' ' ELSE UPPER(FUENTENOM) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTENOM), '%')) AND (CASE WHEN REFERENCIANOM IS NULL THEN ' ' ELSE UPPER(REFERENCIANOM) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIANOM), '%')) AND (CASE WHEN TERCERONIT IS NULL THEN ' ' ELSE UPPER(TERCERONIT) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERONIT), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
