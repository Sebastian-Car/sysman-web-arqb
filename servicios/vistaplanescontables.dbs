			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="NUMEROCOMP" query-param="NUMEROCOMP"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
