	<query id="getVistaplanescontablesPagCuentasRecaudoPorClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.MAN_CEN_CTO + PLAN_CONTABLE.MAN_AUX_TER + PLAN_CONTABLE.MAN_AUX_GEN CTAPADRE FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA =:COMPANIA AND PLAN_CONTABLE.ANO =:ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASECUENTA,' ','') ),CONCAT('',CONCAT(PLAN_CONTABLE.CLASECUENTA, '')),1) &gt; 0 AND ( PLAN_CONTABLE.MOVIMIENTO + MAN_AUX_FUE + MAN_AUX_GEN + MAN_AUX_REF + MAN_AUX_TER + MAN_CEN_CTO + MAN_DISTRI_CCOSTO + MAN_FACT_ARRENDAMIENTO ) NOT IN ( 0 ) ORDER BY PLAN_CONTABLE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CTAPADRE":"$CTAPADRE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
