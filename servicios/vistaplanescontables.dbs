	<query id="getVistaplanescontablesOblymancentroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_NUMBER( MAN_CEN_CTO, '0' ) MAN_CEN_CTO,(CASE OBLIGA_CENTRO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_CENTRO FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MAN_CEN_CTO":"$MAN_CEN_CTO(type:integer)","OBLIGA_CENTRO":"$OBLIGA_CENTRO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
