	<query id="getVistaplanescontablesPagCodigosPorClaseCuentaBjeQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT V_PLAN_CONTABLE.ID, V_PLAN_CONTABLE.CODIGO, V_PLAN_CONTABLE.NOMBRE, V_PLAN_CONTABLE.MAN_CEN_CTO + V_PLAN_CONTABLE.MAN_AUX_TER + V_PLAN_CONTABLE.MAN_AUX_GEN CTAPADRE FROM V_PLAN_CONTABLE WHERE V_PLAN_CONTABLE.COMPANIA =:COMPANIA AND V_PLAN_CONTABLE.ANO =:ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASECUENTA,' ','') ),CONCAT('',CONCAT(V_PLAN_CONTABLE.CLASECUENTA, '')),1) &gt; 0 AND ( V_PLAN_CONTABLE.MOVIMIENTO NOT IN ( 0 ) OR ( V_PLAN_CONTABLE.MAN_CEN_CTO + V_PLAN_CONTABLE.MAN_AUX_TER + V_PLAN_CONTABLE.MAN_AUX_GEN ) NOT IN ( 0 ) ) ORDER BY V_PLAN_CONTABLE.ID) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CTAPADRE":"$CTAPADRE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
