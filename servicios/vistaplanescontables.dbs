	<query id="getVistaplanescontablesSaldoplancontableQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, NOMBRE, ANO, SALDO0, SALDO1, SALDO2, SALDO3, SALDO4, SALDO5, SALDO6, SALDO7, SALDO8, SALDO9, SALDO10, SALDO11, SALDO12, SALDO13, NETO0, NETO1, NETO2, NETO3, NETO4, NETO5, NETO6, NETO7, NETO8, NETO9, NETO10, NETO11, NETO12, NETO13, DEBITO0, DEBITO1, DEBITO2, DEBITO3, DEBITO4, DEBITO5, DEBITO6, DEBITO7, DEBITO8, DEBITO9, DEBITO10, DEBITO11, DEBITO12, DEBITO13, CREDITO0, CREDITO1, CREDITO2, CREDITO3, CREDITO4, CREDITO5, CREDITO6, CREDITO7, CREDITO8, CREDITO9, CREDITO10, CREDITO11, CREDITO12, CREDITO13, AJUSTE0, AJUSTE1, AJUSTE2, AJUSTE3, AJUSTE4, AJUSTE5, AJUSTE6, AJUSTE7, AJUSTE8, AJUSTE9, AJUSTE10, AJUSTE11, AJUSTE12, AJUSTE13, (DEBITO0+DEBITO1+DEBITO2+DEBITO3+DEBITO4+DEBITO5+DEBITO6+DEBITO7+DEBITO8+DEBITO9+DEBITO10+DEBITO11+DEBITO12+DEBITO13) TOTAL_DEBITO, (CREDITO0+CREDITO1+CREDITO2+CREDITO3+CREDITO4+CREDITO5+CREDITO6+CREDITO7+CREDITO8+CREDITO9+CREDITO10+CREDITO11+CREDITO12+CREDITO13) TOTAL_CREDITO FROM ( SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.CODIGO ID, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END CENTRO_COSTO_INFORME, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '999999999999999999' END TERCERO_INFORME, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '999' END SUCURSAL_INFORME, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END AUXILIAR_INFORME, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END REFERENCIA_INFORME, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END FUENTE_RECURSO_INFORME, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END CENTRO_COSTO, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '999999999999999999' END TERCERO, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '999' END SUCURSAL, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END AUXILIAR, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END REFERENCIA, CASE WHEN PLAN_CONTABLE.MOVIMIENTO IN(0) THEN NULL ELSE '99999999999999999999' END FUENTE_RECURSO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.NOMBRE NOMBREUNICO, PLAN_CONTABLE.NATURALEZA, PLAN_CONTABLE.MOVIMIENTO, PLAN_CONTABLE.MAN_CEN_CTO, PLAN_CONTABLE.MAN_AUX_TER, PLAN_CONTABLE.MAN_AUX_GEN, PLAN_CONTABLE.MAN_AUX_REF, PLAN_CONTABLE.MAN_AUX_FUE, 0 MOVIMIENTO_PADRE, 0 MAN_CEN_CTO_PADRE, 0 MAN_AUX_TER_PADRE, 0 MAN_AUX_GEN_PADRE, 0 MAN_AUX_REF_PADRE, 0 MAN_AUX_FUE_PADRE, PLAN_CONTABLE.OBLIGA_TERCERO , PLAN_CONTABLE.OBLIGA_CENTRO , PLAN_CONTABLE.OBLIGA_AUXILIAR , PLAN_CONTABLE.OBLIGA_REFERENCIA , PLAN_CONTABLE.OBLIGA_FUENTE , PLAN_CONTABLE.DINAMICA , PLAN_CONTABLE.PRESUPUESTO_ANUAL , PLAN_CONTABLE.CORRIENTE , PLAN_CONTABLE.FORMATO , PLAN_CONTABLE.CLASECUENTA , PLAN_CONTABLE.BLOQUEACUENTA , PLAN_CONTABLE.SALDOINICIAL , PLAN_CONTABLE.SALDO0 , PLAN_CONTABLE.SALDO1 , PLAN_CONTABLE.SALDO2 , PLAN_CONTABLE.SALDO3 , PLAN_CONTABLE.SALDO4 , PLAN_CONTABLE.SALDO5 , PLAN_CONTABLE.SALDO6 , PLAN_CONTABLE.SALDO7 , PLAN_CONTABLE.SALDO8 , PLAN_CONTABLE.SALDO9 , PLAN_CONTABLE.SALDO10 , PLAN_CONTABLE.SALDO11 , PLAN_CONTABLE.SALDO12 , PLAN_CONTABLE.SALDO13 , PLAN_CONTABLE.NETO0 , PLAN_CONTABLE.NETO1 , PLAN_CONTABLE.NETO2 , PLAN_CONTABLE.NETO3 , PLAN_CONTABLE.NETO4 , PLAN_CONTABLE.NETO5 , PLAN_CONTABLE.NETO6 , PLAN_CONTABLE.NETO7 , PLAN_CONTABLE.NETO8 , PLAN_CONTABLE.NETO9 , PLAN_CONTABLE.NETO10 , PLAN_CONTABLE.NETO11 , PLAN_CONTABLE.NETO12 , PLAN_CONTABLE.NETO13 , PLAN_CONTABLE.DEBITO0 , PLAN_CONTABLE.DEBITO1 , PLAN_CONTABLE.DEBITO2 , PLAN_CONTABLE.DEBITO3 , PLAN_CONTABLE.DEBITO4 , PLAN_CONTABLE.DEBITO5 , PLAN_CONTABLE.DEBITO6 , PLAN_CONTABLE.DEBITO7 , PLAN_CONTABLE.DEBITO8 , PLAN_CONTABLE.DEBITO9 , PLAN_CONTABLE.DEBITO10 , PLAN_CONTABLE.DEBITO11 , PLAN_CONTABLE.DEBITO12 , PLAN_CONTABLE.DEBITO13 , PLAN_CONTABLE.CREDITO0 , PLAN_CONTABLE.CREDITO1 , PLAN_CONTABLE.CREDITO2 , PLAN_CONTABLE.CREDITO3 , PLAN_CONTABLE.CREDITO4 , PLAN_CONTABLE.CREDITO5 , PLAN_CONTABLE.CREDITO6 , PLAN_CONTABLE.CREDITO7 , PLAN_CONTABLE.CREDITO8 , PLAN_CONTABLE.CREDITO9 , PLAN_CONTABLE.CREDITO10 , PLAN_CONTABLE.CREDITO11 , PLAN_CONTABLE.CREDITO12 , PLAN_CONTABLE.CREDITO13 , PLAN_CONTABLE.AJUSTE0 , PLAN_CONTABLE.AJUSTE1 , PLAN_CONTABLE.AJUSTE2 , PLAN_CONTABLE.AJUSTE3 , PLAN_CONTABLE.AJUSTE4 , PLAN_CONTABLE.AJUSTE5 , PLAN_CONTABLE.AJUSTE6 , PLAN_CONTABLE.AJUSTE7 , PLAN_CONTABLE.AJUSTE8 , PLAN_CONTABLE.AJUSTE9 , PLAN_CONTABLE.AJUSTE10 , PLAN_CONTABLE.AJUSTE11 , PLAN_CONTABLE.AJUSTE12 , PLAN_CONTABLE.AJUSTE13 , PLAN_CONTABLE.GENERADESEMBOLSO , PLAN_CONTABLE.CHEQUE , PLAN_CONTABLE.PORCRETENCION , PLAN_CONTABLE.CREDITOEXTERNO , PLAN_CONTABLE.PASARSALDO , PLAN_CONTABLE.COD_EQUIV , PLAN_CONTABLE.TRANSACCIONAL5544 , PLAN_CONTABLE.DESTINO , PLAN_CONTABLE.FORMATOEGRESO , PLAN_CONTABLE.BANCO , PLAN_CONTABLE.PERMITECONSOLIDAR , PLAN_CONTABLE.MAN_FACT_ARRENDAMIENTO , PLAN_CONTABLE.NOTRANSACCIONAL5544 , PLAN_CONTABLE.NOREPORTARRECIPROCAS , PLAN_CONTABLE.TERCEROEQUIVALENTERECIPROCAS , PLAN_CONTABLE.CONCEPTOEX , PLAN_CONTABLE.CUENTA_BANCARIA , PLAN_CONTABLE.TERCEROEX , PLAN_CONTABLE.SUCURSALEX , PLAN_CONTABLE.TIPODESCUENTO_SIA , PLAN_CONTABLE.CODBANCO_SIA , PLAN_CONTABLE.NUMEROCUENTA_SIA , PLAN_CONTABLE.DESTINOCUENTABANCO , PLAN_CONTABLE.CODBANCO_SEREC , PLAN_CONTABLE.NUMEROCUENTA_SEREC , PLAN_CONTABLE.CUENTA_PPTAL , PLAN_CONTABLE.ESOFICIAL , PLAN_CONTABLE.FUENTE , PLAN_CONTABLE.EQUIVPR_DEBITO , PLAN_CONTABLE.EQUIVPR_CREDITO , PLAN_CONTABLE.IVAEX , PLAN_CONTABLE.RETEPRACTICADA , PLAN_CONTABLE.RETEASUMIDA , PLAN_CONTABLE.IVACOMUN , PLAN_CONTABLE.IVASIMPLIFICADO , PLAN_CONTABLE.EXDISTRITAL , PLAN_CONTABLE.ID_NIIF , PLAN_CONTABLE.CODIGO_NIIF , PLAN_CONTABLE.MAN_DISTRI_CCOSTO , PLAN_CONTABLE.RETEICA , PLAN_CONTABLE.CREE_PRACTICADA , PLAN_CONTABLE.CREE_ASUMIDA , PLAN_CONTABLE.CCBALANCE , PLAN_CONTABLE.REPORTASALDORECIPROCAS , PLAN_CONTABLE.MEN , PLAN_CONTABLE.VERIFICAR_MOV , PLAN_CONTABLE.COD_FLUJOCAJA , PLAN_CONTABLE.APLICA_DETERIORO, PLAN_CONTABLE.DEB_RECO_DET, PLAN_CONTABLE.CRE_RECO_DET, PLAN_CONTABLE.DEB_CAUS_DET, PLAN_CONTABLE.CRE_CAUS_DET, PLAN_CONTABLE.DEB_REC_DET, PLAN_CONTABLE.CRE_REC_DET, PLAN_CONTABLE.CREATED_BY , PLAN_CONTABLE.DATE_CREATED , PLAN_CONTABLE.MODIFIED_BY , PLAN_CONTABLE.DATE_MODIFIED, PLAN_CONTABLE.MOSTRARF1001, PLAN_CONTABLE.IND_AGENTE_RETENCION, PLAN_CONTABLE.IND_SUJETO_RETENCION, PLAN_CONTABLE.MOSTRAR_EN_FLUJO, PLAN_CONTABLE.TERCERO_RECIPROCAS, PLAN_CONTABLE.CONTRAPRESTACION, PLAN_CONTABLE.COD_RECONOCIMIENTO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA= :COMPANIA AND ANO= :ANO AND CODIGO = :CUENTA AND NOT EXISTS(SELECT COMPANIA FROM SALDO_AUX_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = SALDO_AUX_CONTABLE.COMPANIA AND PLAN_CONTABLE.ANO = SALDO_AUX_CONTABLE.ANO AND PLAN_CONTABLE.CODIGO = SALDO_AUX_CONTABLE.CODIGO AND PLAN_CONTABLE.MOVIMIENTO NOT IN(0)) UNION ALL SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, TRIM( CONCAT( CONCAT( RPAD(PLAN_CONTABLE.CODIGO,32), RPAD(CASE WHEN MAN_CEN_CTO IN(0) THEN ' ' ELSE SALDO_AUX_CONTABLE.CENTRO_COSTO END,20) ), CONCAT( CONCAT( RPAD(CASE WHEN MAN_AUX_TER IN(0) THEN ' ' ELSE SALDO_AUX_CONTABLE.TERCERO END,18), RPAD(CASE WHEN MAN_AUX_TER IN(0) THEN ' ' ELSE SALDO_AUX_CONTABLE.SUCURSAL END,3) ), CONCAT( RPAD(CASE WHEN MAN_AUX_GEN IN(0) THEN ' ' ELSE SALDO_AUX_CONTABLE.AUXILIAR END,20), CONCAT( RPAD(CASE WHEN MAN_AUX_REF IN(0) THEN ' ' ELSE SALDO_AUX_CONTABLE.REFERENCIA END,20), RPAD(CASE WHEN MAN_AUX_FUE IN(0) THEN ' ' ELSE SALDO_AUX_CONTABLE.FUENTE_RECURSO END,20) ) ) ) ) ) ID, CASE WHEN MAN_CEN_CTO IN(0) THEN NULL ELSE SALDO_AUX_CONTABLE.CENTRO_COSTO END CENTRO_COSTO_INFORME, CASE WHEN MAN_AUX_TER IN(0) THEN NULL ELSE SALDO_AUX_CONTABLE.TERCERO END TERCERO_INFORME, CASE WHEN MAN_AUX_TER IN(0) THEN NULL ELSE SALDO_AUX_CONTABLE.SUCURSAL END SUCURSAL_INFORME, CASE WHEN MAN_AUX_GEN IN(0) THEN NULL ELSE SALDO_AUX_CONTABLE.AUXILIAR END AUXILIAR_INFORME, CASE WHEN MAN_AUX_REF IN(0) THEN NULL ELSE SALDO_AUX_CONTABLE.REFERENCIA END REFERENCIA_INFORME, CASE WHEN MAN_AUX_FUE IN(0) THEN NULL ELSE SALDO_AUX_CONTABLE.FUENTE_RECURSO END FUENTE_RECURSO_INFORME , SALDO_AUX_CONTABLE.CENTRO_COSTO CENTRO_COSTO, SALDO_AUX_CONTABLE.TERCERO TERCERO, SALDO_AUX_CONTABLE.SUCURSAL SUCURSAL, SALDO_AUX_CONTABLE.AUXILIAR AUXILIAR, SALDO_AUX_CONTABLE.REFERENCIA REFERENCIA, SALDO_AUX_CONTABLE.FUENTE_RECURSO FUENTE_RECURSO, CONCAT( CONCAT( CONCAT( CONCAT( CONCAT( PLAN_CONTABLE.NOMBRE, CASE WHEN PLAN_CONTABLE.MAN_AUX_TER &lt;&gt; 0 THEN CONCAT('/', TERCERO.NOMBRE) ELSE NULL END ), CASE WHEN PLAN_CONTABLE.MAN_AUX_GEN &lt;&gt; 0 THEN CONCAT('/', AUXILIAR.NOMBRE) ELSE NULL END ), CASE WHEN PLAN_CONTABLE.MAN_CEN_CTO &lt;&gt; 0 THEN CONCAT('/', CENTRO_COSTO.NOMBRE) ELSE NULL END ), CASE WHEN PLAN_CONTABLE.MAN_AUX_REF &lt;&gt; 0 THEN CONCAT('/', REFERENCIA.NOMBRE) ELSE NULL END ), CASE WHEN PLAN_CONTABLE.MAN_AUX_FUE &lt;&gt; 0 THEN CONCAT('/', FUENTE_RECURSOS.NOMBRE) ELSE NULL END ) NOMBRE, PLAN_CONTABLE.NOMBRE NOMBREUNICO, PLAN_CONTABLE.NATURALEZA, -1 MOVIMIENTO, 0 MAN_CEN_CTO, 0 MAN_AUX_TER, 0 MAN_AUX_GEN, 0 MAN_AUX_REF, 0 MAN_AUX_FUE, PLAN_CONTABLE.MOVIMIENTO MOVIMIENTO_PADRE, PLAN_CONTABLE.MAN_CEN_CTO MAN_CEN_CTO_PADRE, PLAN_CONTABLE.MAN_AUX_TER MAN_AUX_TER_PADRE, PLAN_CONTABLE.MAN_AUX_GEN MAN_AUX_GEN_PADRE, PLAN_CONTABLE.MAN_AUX_REF MAN_AUX_REF_PADRE, PLAN_CONTABLE.MAN_AUX_FUE MAN_AUX_FUE_PADRE, PLAN_CONTABLE.OBLIGA_TERCERO , PLAN_CONTABLE.OBLIGA_CENTRO , PLAN_CONTABLE.OBLIGA_AUXILIAR , PLAN_CONTABLE.OBLIGA_REFERENCIA , PLAN_CONTABLE.OBLIGA_FUENTE , PLAN_CONTABLE.DINAMICA , PLAN_CONTABLE.PRESUPUESTO_ANUAL , PLAN_CONTABLE.CORRIENTE , PLAN_CONTABLE.FORMATO , PLAN_CONTABLE.CLASECUENTA , PLAN_CONTABLE.BLOQUEACUENTA , SALDO_AUX_CONTABLE.SALDOINICIAL , SALDO_AUX_CONTABLE.SALDO0 , SALDO_AUX_CONTABLE.SALDO1 , SALDO_AUX_CONTABLE.SALDO2 , SALDO_AUX_CONTABLE.SALDO3 , SALDO_AUX_CONTABLE.SALDO4 , SALDO_AUX_CONTABLE.SALDO5 , SALDO_AUX_CONTABLE.SALDO6 , SALDO_AUX_CONTABLE.SALDO7 , SALDO_AUX_CONTABLE.SALDO8 , SALDO_AUX_CONTABLE.SALDO9 , SALDO_AUX_CONTABLE.SALDO10 , SALDO_AUX_CONTABLE.SALDO11 , SALDO_AUX_CONTABLE.SALDO12 , SALDO_AUX_CONTABLE.SALDO13 , SALDO_AUX_CONTABLE.NETO0 , SALDO_AUX_CONTABLE.NETO1 , SALDO_AUX_CONTABLE.NETO2 , SALDO_AUX_CONTABLE.NETO3 , SALDO_AUX_CONTABLE.NETO4 , SALDO_AUX_CONTABLE.NETO5 , SALDO_AUX_CONTABLE.NETO6 , SALDO_AUX_CONTABLE.NETO7 , SALDO_AUX_CONTABLE.NETO8 , SALDO_AUX_CONTABLE.NETO9 , SALDO_AUX_CONTABLE.NETO10 , SALDO_AUX_CONTABLE.NETO11 , SALDO_AUX_CONTABLE.NETO12 , SALDO_AUX_CONTABLE.NETO13 , SALDO_AUX_CONTABLE.DEBITO0 , SALDO_AUX_CONTABLE.DEBITO1 , SALDO_AUX_CONTABLE.DEBITO2 , SALDO_AUX_CONTABLE.DEBITO3 , SALDO_AUX_CONTABLE.DEBITO4 , SALDO_AUX_CONTABLE.DEBITO5 , SALDO_AUX_CONTABLE.DEBITO6 , SALDO_AUX_CONTABLE.DEBITO7 , SALDO_AUX_CONTABLE.DEBITO8 , SALDO_AUX_CONTABLE.DEBITO9 , SALDO_AUX_CONTABLE.DEBITO10 , SALDO_AUX_CONTABLE.DEBITO11 , SALDO_AUX_CONTABLE.DEBITO12 , SALDO_AUX_CONTABLE.DEBITO13 , SALDO_AUX_CONTABLE.CREDITO0 , SALDO_AUX_CONTABLE.CREDITO1 , SALDO_AUX_CONTABLE.CREDITO2 , SALDO_AUX_CONTABLE.CREDITO3 , SALDO_AUX_CONTABLE.CREDITO4 , SALDO_AUX_CONTABLE.CREDITO5 , SALDO_AUX_CONTABLE.CREDITO6 , SALDO_AUX_CONTABLE.CREDITO7 , SALDO_AUX_CONTABLE.CREDITO8 , SALDO_AUX_CONTABLE.CREDITO9 , SALDO_AUX_CONTABLE.CREDITO10 , SALDO_AUX_CONTABLE.CREDITO11 , SALDO_AUX_CONTABLE.CREDITO12 , SALDO_AUX_CONTABLE.CREDITO13 , PLAN_CONTABLE.AJUSTE0 , PLAN_CONTABLE.AJUSTE1 , PLAN_CONTABLE.AJUSTE2 , PLAN_CONTABLE.AJUSTE3 , PLAN_CONTABLE.AJUSTE4 , PLAN_CONTABLE.AJUSTE5 , PLAN_CONTABLE.AJUSTE6 , PLAN_CONTABLE.AJUSTE7 , PLAN_CONTABLE.AJUSTE8 , PLAN_CONTABLE.AJUSTE9 , PLAN_CONTABLE.AJUSTE10 , PLAN_CONTABLE.AJUSTE11 , PLAN_CONTABLE.AJUSTE12 , PLAN_CONTABLE.AJUSTE13 , PLAN_CONTABLE.GENERADESEMBOLSO , PLAN_CONTABLE.CHEQUE , PLAN_CONTABLE.PORCRETENCION , PLAN_CONTABLE.CREDITOEXTERNO , PLAN_CONTABLE.PASARSALDO , PLAN_CONTABLE.COD_EQUIV , PLAN_CONTABLE.TRANSACCIONAL5544 , PLAN_CONTABLE.DESTINO , PLAN_CONTABLE.FORMATOEGRESO , PLAN_CONTABLE.BANCO , PLAN_CONTABLE.PERMITECONSOLIDAR , PLAN_CONTABLE.MAN_FACT_ARRENDAMIENTO , PLAN_CONTABLE.NOTRANSACCIONAL5544 , PLAN_CONTABLE.NOREPORTARRECIPROCAS , PLAN_CONTABLE.TERCEROEQUIVALENTERECIPROCAS , PLAN_CONTABLE.CONCEPTOEX , PLAN_CONTABLE.CUENTA_BANCARIA , PLAN_CONTABLE.TERCEROEX , PLAN_CONTABLE.SUCURSALEX , PLAN_CONTABLE.TIPODESCUENTO_SIA , PLAN_CONTABLE.CODBANCO_SIA , PLAN_CONTABLE.NUMEROCUENTA_SIA , PLAN_CONTABLE.DESTINOCUENTABANCO , PLAN_CONTABLE.CODBANCO_SEREC , PLAN_CONTABLE.NUMEROCUENTA_SEREC , PLAN_CONTABLE.CUENTA_PPTAL , PLAN_CONTABLE.ESOFICIAL , PLAN_CONTABLE.FUENTE , PLAN_CONTABLE.EQUIVPR_DEBITO , PLAN_CONTABLE.EQUIVPR_CREDITO , PLAN_CONTABLE.IVAEX , PLAN_CONTABLE.RETEPRACTICADA , PLAN_CONTABLE.RETEASUMIDA , PLAN_CONTABLE.IVACOMUN , PLAN_CONTABLE.IVASIMPLIFICADO , PLAN_CONTABLE.EXDISTRITAL , PLAN_CONTABLE.ID_NIIF , PLAN_CONTABLE.CODIGO_NIIF , PLAN_CONTABLE.MAN_DISTRI_CCOSTO , PLAN_CONTABLE.RETEICA , PLAN_CONTABLE.CREE_PRACTICADA , PLAN_CONTABLE.CREE_ASUMIDA , PLAN_CONTABLE.CCBALANCE , PLAN_CONTABLE.REPORTASALDORECIPROCAS , PLAN_CONTABLE.MEN, PLAN_CONTABLE.VERIFICAR_MOV, PLAN_CONTABLE.COD_FLUJOCAJA, PLAN_CONTABLE.APLICA_DETERIORO, PLAN_CONTABLE.DEB_RECO_DET, PLAN_CONTABLE.CRE_RECO_DET, PLAN_CONTABLE.DEB_CAUS_DET, PLAN_CONTABLE.CRE_CAUS_DET, PLAN_CONTABLE.DEB_REC_DET, PLAN_CONTABLE.CRE_REC_DET, SALDO_AUX_CONTABLE.CREATED_BY, SALDO_AUX_CONTABLE.DATE_CREATED, SALDO_AUX_CONTABLE.MODIFIED_BY, SALDO_AUX_CONTABLE.DATE_MODIFIED, PLAN_CONTABLE.MOSTRARF1001, PLAN_CONTABLE.IND_AGENTE_RETENCION, PLAN_CONTABLE.IND_SUJETO_RETENCION, PLAN_CONTABLE.MOSTRAR_EN_FLUJO, PLAN_CONTABLE.TERCERO_RECIPROCAS, PLAN_CONTABLE.CONTRAPRESTACION, PLAN_CONTABLE.COD_RECONOCIMIENTO FROM PLAN_CONTABLE INNER JOIN SALDO_AUX_CONTABLE ON PLAN_CONTABLE.COMPANIA = SALDO_AUX_CONTABLE.COMPANIA AND PLAN_CONTABLE.ANO = SALDO_AUX_CONTABLE.ANO AND PLAN_CONTABLE.CODIGO = SALDO_AUX_CONTABLE.CODIGO INNER JOIN TERCERO ON SALDO_AUX_CONTABLE.COMPANIA = TERCERO.COMPANIA AND SALDO_AUX_CONTABLE.TERCERO = TERCERO.NIT AND SALDO_AUX_CONTABLE.SUCURSAL = TERCERO.SUCURSAL INNER JOIN CENTRO_COSTO ON SALDO_AUX_CONTABLE.COMPANIA = CENTRO_COSTO.COMPANIA AND SALDO_AUX_CONTABLE.ANO = CENTRO_COSTO.ANO AND SALDO_AUX_CONTABLE.CENTRO_COSTO = CENTRO_COSTO.CODIGO INNER JOIN AUXILIAR ON SALDO_AUX_CONTABLE.COMPANIA = AUXILIAR.COMPANIA AND SALDO_AUX_CONTABLE.ANO = AUXILIAR.ANO AND SALDO_AUX_CONTABLE.AUXILIAR = AUXILIAR.CODIGO INNER JOIN FUENTE_RECURSOS ON SALDO_AUX_CONTABLE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND SALDO_AUX_CONTABLE.ANO = FUENTE_RECURSOS.ANO AND SALDO_AUX_CONTABLE.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO INNER JOIN REFERENCIA ON SALDO_AUX_CONTABLE.COMPANIA = REFERENCIA.COMPANIA AND SALDO_AUX_CONTABLE.ANO = REFERENCIA.ANO AND SALDO_AUX_CONTABLE.REFERENCIA = REFERENCIA.CODIGO WHERE PLAN_CONTABLE.COMPANIA= :COMPANIA AND PLAN_CONTABLE.ANO= :ANO AND SALDO_AUX_CONTABLE.ID= :CUENTA)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)","SALDO0":"$SALDO0","SALDO1":"$SALDO1","SALDO2":"$SALDO2","SALDO3":"$SALDO3","SALDO4":"$SALDO4","SALDO5":"$SALDO5","SALDO6":"$SALDO6","SALDO7":"$SALDO7","SALDO8":"$SALDO8","SALDO9":"$SALDO9","SALDO10":"$SALDO10","SALDO11":"$SALDO11","SALDO12":"$SALDO12","SALDO13":"$SALDO13","NETO0":"$NETO0","NETO1":"$NETO1","NETO2":"$NETO2","NETO3":"$NETO3","NETO4":"$NETO4","NETO5":"$NETO5","NETO6":"$NETO6","NETO7":"$NETO7","NETO8":"$NETO8","NETO9":"$NETO9","NETO10":"$NETO10","NETO11":"$NETO11","NETO12":"$NETO12","NETO13":"$NETO13","DEBITO0":"$DEBITO0","DEBITO1":"$DEBITO1","DEBITO2":"$DEBITO2","DEBITO3":"$DEBITO3","DEBITO4":"$DEBITO4","DEBITO5":"$DEBITO5","DEBITO6":"$DEBITO6","DEBITO7":"$DEBITO7","DEBITO8":"$DEBITO8","DEBITO9":"$DEBITO9","DEBITO10":"$DEBITO10","DEBITO11":"$DEBITO11","DEBITO12":"$DEBITO12","DEBITO13":"$DEBITO13","CREDITO0":"$CREDITO0","CREDITO1":"$CREDITO1","CREDITO2":"$CREDITO2","CREDITO3":"$CREDITO3","CREDITO4":"$CREDITO4","CREDITO5":"$CREDITO5","CREDITO6":"$CREDITO6","CREDITO7":"$CREDITO7","CREDITO8":"$CREDITO8","CREDITO9":"$CREDITO9","CREDITO10":"$CREDITO10","CREDITO11":"$CREDITO11","CREDITO12":"$CREDITO12","CREDITO13":"$CREDITO13","AJUSTE0":"$AJUSTE0","AJUSTE1":"$AJUSTE1","AJUSTE2":"$AJUSTE2","AJUSTE3":"$AJUSTE3","AJUSTE4":"$AJUSTE4","AJUSTE5":"$AJUSTE5","AJUSTE6":"$AJUSTE6","AJUSTE7":"$AJUSTE7","AJUSTE8":"$AJUSTE8","AJUSTE9":"$AJUSTE9","AJUSTE10":"$AJUSTE10","AJUSTE11":"$AJUSTE11","AJUSTE12":"$AJUSTE12","AJUSTE13":"$AJUSTE13","TOTAL_DEBITO":"$TOTAL_DEBITO(type:double)","TOTAL_CREDITO":"$TOTAL_CREDITO(type:double)"}]}}		</result>
