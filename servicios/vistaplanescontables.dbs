	<resource method="GET" path="vistaplanescontables/saldoplancontable">
		<call-query href="getVistaplanescontablesSaldoplancontableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="getVistaplanescontablesPagClaseCuentaIQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE, MAN_AUX_GEN FROM V_PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND CLASECUENTA = 'I' AND (CONCAT(CASE WHEN MAN_AUX_GEN =-1 THEN 'S' ELSE '' END , CONCAT(CASE WHEN MAN_AUX_TER =-1 THEN 'S' ELSE '' END , CONCAT( CASE WHEN MAN_CEN_CTO =-1 THEN 'S' ELSE '' END , CASE WHEN MOVIMIENTO =-1 THEN 'S' ELSE '' END )))) IS NOT NULL AND TERCERO IS NULL AND CENTRO_COSTO IS NULL AND AUXILIAR IS NULL ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MAN_AUX_GEN":"$MAN_AUX_GEN(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vistaplanescontables/clasecuentai/pag">
		<call-query href="getVistaplanescontablesPagClaseCuentaIQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVistaplanescontablesNumClaseCuentaIQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE, MAN_AUX_GEN FROM V_PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND CLASECUENTA = 'I' AND (CONCAT(CASE WHEN MAN_AUX_GEN =-1 THEN 'S' ELSE '' END , CONCAT(CASE WHEN MAN_AUX_TER =-1 THEN 'S' ELSE '' END , CONCAT( CASE WHEN MAN_CEN_CTO =-1 THEN 'S' ELSE '' END , CASE WHEN MOVIMIENTO =-1 THEN 'S' ELSE '' END )))) IS NOT NULL AND TERCERO IS NULL AND CENTRO_COSTO IS NULL AND AUXILIAR IS NULL ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
