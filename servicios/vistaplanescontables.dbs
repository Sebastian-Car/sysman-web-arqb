	<query id="getVistaplanescontablesRetencionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT RETENCIONES.CUENTA_CREDITO,(CASE RETENCIONES.PERMITEMODIFICAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICAR,(CASE RETENCIONES.PERMITEMODIFICARBASE WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARBASE, RETENCIONES.TIPO, RETENCIONES.CODIGO  FROM V_PLAN_CONTABLE INNER JOIN DETALLE_COMPROBANTE_CNT ON V_PLAN_CONTABLE.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND V_PLAN_CONTABLE.ANO = DETALLE_COMPROBANTE_CNT.ANO AND V_PLAN_CONTABLE.ID = DETALLE_COMPROBANTE_CNT.CUENTA INNER JOIN COMPROBANTE_CNTRETENCION ON DETALLE_COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNTRETENCION.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = COMPROBANTE_CNTRETENCION.ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE = COMPROBANTE_CNTRETENCION.TIPO AND DETALLE_COMPROBANTE_CNT.COMPROBANTE = COMPROBANTE_CNTRETENCION.NUMERO INNER JOIN RETENCIONES ON COMPROBANTE_CNTRETENCION.COMPANIA = RETENCIONES.COMPANIA AND COMPROBANTE_CNTRETENCION.CODIGORETENCION = RETENCIONES.CODIGO AND COMPROBANTE_CNTRETENCION.ANO = RETENCIONES.ANO AND COMPROBANTE_CNTRETENCION.TIPORETENCION = RETENCIONES.TIPO WHERE V_PLAN_CONTABLE.CLASECUENTA IN(:CLASE) AND V_PLAN_CONTABLE.COMPANIA= :COMPANIA AND V_PLAN_CONTABLE.ANO= :ANO AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE=:TIPOCOMP AND DETALLE_COMPROBANTE_CNT.COMPROBANTE= :NUMEROCOMP AND RETENCIONES.CUENTA_CREDITO=:CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA_CREDITO":"$CUENTA_CREDITO","PERMITEMODIFICAR":"$PERMITEMODIFICAR(type:boolean)","PERMITEMODIFICARBASE":"$PERMITEMODIFICARBASE(type:boolean)","TIPO":"$TIPO","CODIGO":"$CODIGO"}]}}		</result>
		<param name="CLASE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="NUMEROCOMP" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanescontables/retenciones">
		<call-query href="getVistaplanescontablesRetencionesQuery">
			<with-param name="CLASE" query-param="CLASE"/>
