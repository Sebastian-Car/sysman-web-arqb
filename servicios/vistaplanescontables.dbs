	<query id="getVistaplanescontablesCantidadCuentasHijasPorCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT (V_PLAN_CONTABLE.ID) TOTAL  FROM V_PLAN_CONTABLE LEFT JOIN CENTRO_COSTO ON V_PLAN_CONTABLE.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_CONTABLE.ANO = CENTRO_COSTO.ANO AND V_PLAN_CONTABLE.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON V_PLAN_CONTABLE.COMPANIA = AUXILIAR.COMPANIA AND V_PLAN_CONTABLE.ANO = AUXILIAR.ANO AND V_PLAN_CONTABLE.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN FUENTE_RECURSOS ON V_PLAN_CONTABLE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_PLAN_CONTABLE.ANO = FUENTE_RECURSOS.ANO AND V_PLAN_CONTABLE.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO LEFT JOIN TERCERO ON V_PLAN_CONTABLE.COMPANIA = TERCERO.COMPANIA AND V_PLAN_CONTABLE.TERCERO = TERCERO.NIT AND V_PLAN_CONTABLE.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN REFERENCIA ON V_PLAN_CONTABLE.COMPANIA = REFERENCIA.COMPANIA AND V_PLAN_CONTABLE.ANO = REFERENCIA.ANO AND V_PLAN_CONTABLE.REFERENCIA = REFERENCIA.CODIGO WHERE V_PLAN_CONTABLE.COMPANIA = :COMPANIA AND V_PLAN_CONTABLE.ANO = :ANO AND V_PLAN_CONTABLE.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vistaplanescontables/cantidadcuentashijasporcuenta">
		<call-query href="getVistaplanescontablesCantidadCuentasHijasPorCuentaQuery">
