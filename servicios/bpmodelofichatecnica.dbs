<data name="bpmodelofichatecnica" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpmodelofichatecnicaSelTecniPorSectorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT BP_MODELO_FICHA_TECNICA.SECCION  FROM BP_MODELO_FICHA_TECNICA WHERE BP_MODELO_FICHA_TECNICA.COMPANIA = :COMPANIA AND BP_MODELO_FICHA_TECNICA.SECTOR = :SECTOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SECCION":"$SECCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpmodelofichatecnica/seltecniporsector">
		<call-query href="getBpmodelofichatecnicaSelTecniPorSectorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECTOR" query-param="SECTOR"/>

		</call-query>
	</resource>
	<query id="getBpmodelofichatecnicaListaDetalleFichaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CODIGO, SECTOR, SECCION, ITEM  FROM BP_MODELO_FICHA_TECNICA WHERE COMPANIA= :COMPANIA AND SECTOR = :SECTOR AND SECCION = :SECCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO(type:integer)","SECTOR":"$SECTOR","SECCION":"$SECCION","ITEM":"$ITEM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="SECCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpmodelofichatecnica/listadetalleficha">
		<call-query href="getBpmodelofichatecnicaListaDetalleFichaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="SECCION" query-param="SECCION"/>

		</call-query>
	</resource>
	<query id="getBpmodelofichatecnicaConsultarExistenciaItemQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ITEM  FROM BP_MODELO_FICHA_TECNICA WHERE COMPANIA = :COMPANIA AND SECCION = :SECCION AND ITEM = :ITEM AND SECTOR = :SECTOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ITEM":"$ITEM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SECCION" sqlType="STRING"/>
		<param name="ITEM" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpmodelofichatecnica/consultarexistenciaitem">
		<call-query href="getBpmodelofichatecnicaConsultarExistenciaItemQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SECCION" query-param="SECCION"/>
			<with-param name="ITEM" query-param="ITEM"/>
			<with-param name="SECTOR" query-param="SECTOR"/>

		</call-query>
	</resource>
	<query id="insertBpmodelofichatecnica" keyColumns="COMPANIA,CODIGO,SECTOR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_MODELO_FICHA_TECNICA (COMPANIA, CODIGO, SECTOR, SECCION, ITEM, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :SECTOR, :SECCION, :ITEM, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO(type:integer)","KEY_SECTOR":"$SECTOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="SECCION" sqlType="STRING"/>
		<param name="ITEM" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpmodelofichatecnica">
		<call-query href="insertBpmodelofichatecnica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="SECCION" query-param="SECCION"/>
			<with-param name="ITEM" query-param="ITEM"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpmodelofichatecnica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_MODELO_FICHA_TECNICA WHERE BP_MODELO_FICHA_TECNICA.COMPANIA= :KEY_COMPANIA AND BP_MODELO_FICHA_TECNICA.CODIGO= :KEY_CODIGO AND BP_MODELO_FICHA_TECNICA.SECTOR= :KEY_SECTOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>
		<param name="KEY_SECTOR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpmodelofichatecnica">
		<call-query href="deleteBpmodelofichatecnica">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_SECTOR" query-param="KEY_SECTOR"/>

		</call-query>
	</resource>
	<query id="updateBpmodelofichatecnica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_MODELO_FICHA_TECNICA SET CODIGO=:CODIGO, SECTOR=:SECTOR, SECCION=:SECCION, ITEM=:ITEM, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_MODELO_FICHA_TECNICA.COMPANIA= :KEY_COMPANIA AND BP_MODELO_FICHA_TECNICA.CODIGO= :KEY_CODIGO AND BP_MODELO_FICHA_TECNICA.SECTOR= :KEY_SECTOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="SECCION" sqlType="STRING"/>
		<param name="ITEM" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_SECTOR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpmodelofichatecnica">
		<call-query href="updateBpmodelofichatecnica">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="SECCION" query-param="SECCION"/>
			<with-param name="ITEM" query-param="ITEM"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_SECTOR" query-param="KEY_SECTOR"/>

		</call-query>
	</resource>

</data>