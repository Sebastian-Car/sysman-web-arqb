	<query id="deleteSfcontratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_CONTRATOS WHERE SF_CONTRATOS.COMPANIA= :KEY_COMPANIA AND SF_CONTRATOS.TIPO= :KEY_TIPO AND SF_CONTRATOS.NUMERO= :KEY_NUMERO AND SF_CONTRATOS.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="sfcontratos">
		<call-query href="deleteSfcontratos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_CONTRATOS.COMPANIA, SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO, SF_CONTRATOS.TERCERO, TERCERO.NOMBRE NOMBRE_TERCERO,(TO_CHAR(SF_CONTRATOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_CONTRATOS.FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINALIZACION, SF_CONTRATOS.ANO FROM SF_CONTRATOS INNER JOIN TERCERO ON SF_CONTRATOS.COMPANIA = TERCERO.COMPANIA AND SF_CONTRATOS.TERCERO = TERCERO.NIT AND SF_CONTRATOS.SUCURSAL = TERCERO.SUCURSAL WHERE SF_CONTRATOS.COMPANIA = :COMPANIA AND SF_CONTRATOS.TIPO = :TIPO AND SF_CONTRATOS.ANO = :ANO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(:FECHA_INICIO, '%')) AND (CASE WHEN FECHA_FINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_FINALIZACION) END) LIKE UPPER(CONCAT(:FECHA_FINALIZACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TERCERO":"$TERCERO","NOMBRE_TERCERO":"$NOMBRE_TERCERO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINALIZACION":"$FECHA_FINALIZACION","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINALIZACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcontratos">
		<call-query href="getSfcontratosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE_TERCERO" query-param="NOMBRE_TERCERO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINALIZACION" query-param="FECHA_FINALIZACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_CONTRATOS.COMPANIA, SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO, SF_CONTRATOS.TERCERO, TERCERO.NOMBRE NOMBRE_TERCERO,(TO_CHAR(SF_CONTRATOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_CONTRATOS.FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINALIZACION, SF_CONTRATOS.ANO FROM SF_CONTRATOS INNER JOIN TERCERO ON SF_CONTRATOS.COMPANIA = TERCERO.COMPANIA AND SF_CONTRATOS.TERCERO = TERCERO.NIT AND SF_CONTRATOS.SUCURSAL = TERCERO.SUCURSAL WHERE SF_CONTRATOS.COMPANIA = :COMPANIA AND SF_CONTRATOS.TIPO = :TIPO AND SF_CONTRATOS.ANO = :ANO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(:FECHA_INICIO, '%')) AND (CASE WHEN FECHA_FINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_FINALIZACION) END) LIKE UPPER(CONCAT(:FECHA_FINALIZACION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINALIZACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcontratos/numero">
		<call-query href="getSfcontratosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
