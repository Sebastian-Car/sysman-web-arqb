	<query id="getSfcontratosPagTodosPorEstado2Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(SF_CONTRATOS.TIPO,CONCAT(' - ',SF_CONTRATOS.NUMERO) ) CONTRATO,(TO_CHAR(SF_CONTRATOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_CONTRATOS.FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINALIZACION, SF_CONTRATOS.VALOR_TOTAL, SF_CONTRATOS.OBJETO_CONTRATO, SF_CONTRATOS.TIPO, TO_CHAR(SF_CONTRATOS.NUMERO) NUMERO, SF_CONTRATOS.ESTADO, SF_CONTRATOS.ANO, SF_CONTRATOS.TERCERO, SF_CONTRATOS.SUCURSAL, SF_CONTRATOS.CENTRO_COSTO, SF_CONTRATOS.AUXILIAR, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, AUXILIAR.NOMBRE NOMBREAUXILIAR, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBRE_TERCERO, TERCERO.DIRECCION, TERCERO.TELEFONOS, TERCERO.CODIGOPOSTAL FROM SF_CONTRATOS LEFT JOIN CENTRO_COSTO ON SF_CONTRATOS.COMPANIA = CENTRO_COSTO.COMPANIA AND SF_CONTRATOS.CENTRO_COSTO = CENTRO_COSTO.CODIGO AND SF_CONTRATOS.ANO = CENTRO_COSTO.ANO LEFT JOIN AUXILIAR ON SF_CONTRATOS.COMPANIA = AUXILIAR.COMPANIA AND SF_CONTRATOS.ANO = AUXILIAR.ANO AND SF_CONTRATOS.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN TERCERO ON SF_CONTRATOS.COMPANIA = TERCERO.COMPANIA AND SF_CONTRATOS.TERCERO = TERCERO.NIT AND SF_CONTRATOS.SUCURSAL = TERCERO.SUCURSAL WHERE SF_CONTRATOS.COMPANIA =:COMPANIA AND SF_CONTRATOS.ESTADO =:ESTADO) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIO), '%')) AND (CASE WHEN FECHA_FINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_FINALIZACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINALIZACION), '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN OBJETO_CONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETO_CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO_CONTRATO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTRATO":"$CONTRATO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINALIZACION":"$FECHA_FINALIZACION","VALOR_TOTAL":"$VALOR_TOTAL","OBJETO_CONTRATO":"$OBJETO_CONTRATO","TIPO":"$TIPO","NUMERO":"$NUMERO","ESTADO":"$ESTADO(type:integer)","ANO":"$ANO(type:integer)","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","NOMBRE_CENTRO_COSTO":"$NOMBRE_CENTRO_COSTO","NOMBREAUXILIAR":"$NOMBREAUXILIAR","NOMBRE_TERCERO":"$NOMBRE_TERCERO","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","CODIGOPOSTAL":"$CODIGOPOSTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINALIZACION" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="OBJETO_CONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
