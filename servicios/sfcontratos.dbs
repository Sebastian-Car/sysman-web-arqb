	<query id="getSfcontratosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_CONTRATOS.COMPANIA, SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO,(TO_CHAR(SF_CONTRATOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_CONTRATOS.FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINALIZACION, SF_CONTRATOS.TERCERO, SF_CONTRATOS.SUCURSAL, SF_CONTRATOS.CENTRO_COSTO, SF_CONTRATOS.AUXILIAR, SF_CONTRATOS.VALOR_BASE, SF_CONTRATOS.VALOR_IVA, SF_CONTRATOS.VALOR_RETE, SF_CONTRATOS.VALOR_ICA, SF_CONTRATOS.VALOR_DESCUENTO, SF_CONTRATOS.VALOR_TOTAL, SF_CONTRATOS.TOTAL_TCONTRATADO, SF_CONTRATOS.TIPOCOTIZACION, SF_CONTRATOS.NUMCOTIZACION, SF_CONTRATOS.ESTADO, SF_CONTRATOS.OBJETO_CONTRATO, SF_CONTRATOS.TIEMPO_CONTRATADO, SF_CONTRATOS.CORTE_FACTURACION, SF_CONTRATOS.CREATED_BY,(TO_CHAR(SF_CONTRATOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_CONTRATOS.MODIFIED_BY,(TO_CHAR(SF_CONTRATOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SF_CONTRATOS.ANO, CONCAT(' ', CONCAT(NVL(TERCERO.NOMBRE1, ''), CONCAT(' ', CONCAT(NVL(TERCERO.NOMBRE2, ''), CONCAT(' ', CONCAT(NVL(TERCERO.APELLIDO1 , ''), CONCAT(' ', NVL(TERCERO.APELLIDO2, '')))))))) NOMBRETERCERO, SF_CONTRATOS.VENDEDOR, T.NOMBRE NOMBREVENDEDOR, SF_CONTRATOS.RESOLUCION_ADJUDICACION,(TO_CHAR(SF_CONTRATOS.FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION, SF_CONTRATOS.ACTA_NOTIFIACION,(TO_CHAR(SF_CONTRATOS.FECHA_NOTIFICACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_NOTIFICACION, SF_CONTRATOS.ACTA_VISITA,(TO_CHAR(SF_CONTRATOS.FECHA_VISITA,'DD/MM/YYYY HH24:MI:SS')) FECHA_VISITA, SF_CONTRATOS.LOCAL, SF_LOCALES.ANCHO, SF_LOCALES.LARGO, SF_LOCALES.AREA, CASE WHEN SF_LOCALES.ESTADO = 'A' THEN 'Adjudicado' WHEN SF_LOCALES.ESTADO = 'L' THEN 'Libre' WHEN SF_LOCALES.ESTADO = 'D' THEN 'Proceso Desadjudicación' END NOMBRE_ESTADO, SF_LOCALES.DESCRIPCION, SF_LUGAR.NOMBRE NOMBRE_LUGAR, SF_UBICACION.NOMBRE NOMBRE_UBICACION, SF_LOCALES.CODIGO_ANTERIOR, SF_CONTRATOS.TIPO_PAGO, SF_CONTRATOS.TOTALPERIODO, SF_CONTRATOS.TOTALAREA, SF_CONTRATOS.PORCFONDO, SF_CONTRATOS.EDIFICIO, SF_CONTRATOS.SERVICIOS, SF_CONTRATOS.INCREMENTO, SF_CONTRATOS.INVENTARIO, SF_CONTRATOS.MEDIDORENERGIA, SF_CONTRATOS.DESTINACION,(CASE SF_CONTRATOS.FACTURASERVICIOS WHEN 0 THEN 'false' ELSE 'true' END) FACTURASERVICIOS,(CASE SF_CONTRATOS.APROVACIONCONTRATO WHEN 0 THEN 'false' ELSE 'true' END) APROVACIONCONTRATO, SF_CONTRATOS.NUMFSICOCONTRATO, SF_CONTRATOS.POLIZA, SF_CONTRATOS.ASEGURADORA, TO_CHAR(SF_CONTRATOS.FECHAINICIOPOLIZA, 'dd/MM/YYYY') FECHAINICIOPOLIZA, TO_CHAR(SF_CONTRATOS.FECHAFINPOLIZA, 'dd/MM/YYYY') FECHAFINPOLIZA, SF_CONTRATOS.MESVIGENCIAPOLIZA, SF_CONTRATOS.VALORNUEVAPOLIZA, SF_CONTRATOS.VALORPOLIZA, SF_CONTRATOS.REPRESENTANTELEGAL, TRL.NOMBRE NOMREPLEGAL, SF_CONTRATOS.PORCENTAJECUMPLIMIENTO, SF_CONTRATOS.ORDENADORGASTO, TOG.NOMBRE NOMORDENGASTO, SF_CONTRATOS.RESOLUCIONORDENAGASTO, SF_CONTRATOS.SUSCRIPCIONORDENADORGASTO, SF_CONTRATOS.RESOLTARIFAS, SF_CONTRATOS.VERSIONARRENDAMIENTO,(TO_CHAR(SF_CONTRATOS.FECHAVERSIONARRENDAMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVERSIONARRENDAMIENTO, SF_CONTRATOS.COMITEAPROVATORIO, SF_CONTRATOS.RESOLUREGLAMENTO,(TO_CHAR(SF_CONTRATOS.FECHARESOLUREGLAMENTO,'DD/MM/YYYY HH24:MI:SS')) FECHARESOLUREGLAMENTO, SF_CONTRATOS.VERSIONSOLICITUD,(TO_CHAR(SF_CONTRATOS.FECHAVERSIONSOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHAVERSIONSOLICITUD FROM SF_CONTRATOS INNER JOIN TERCERO ON SF_CONTRATOS.COMPANIA = TERCERO.COMPANIA AND SF_CONTRATOS.TERCERO = TERCERO.NIT AND SF_CONTRATOS.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TERCERO T ON SF_CONTRATOS.COMPANIA = T.COMPANIA AND SF_CONTRATOS.VENDEDOR = T.NIT AND SF_CONTRATOS.SUCURSAL = T.SUCURSAL LEFT JOIN TERCERO TRL ON SF_CONTRATOS.COMPANIA= TRL.COMPANIA AND SF_CONTRATOS.REPRESENTANTELEGAL=TRL.NIT AND SF_CONTRATOS.SUCURSAL =TRL.SUCURSAL LEFT JOIN TERCERO TOG ON SF_CONTRATOS.COMPANIA= TOG.COMPANIA AND SF_CONTRATOS.ORDENADORGASTO=TOG.NIT AND SF_CONTRATOS.SUCURSAL =TOG.SUCURSAL LEFT JOIN SF_LOCALES ON SF_CONTRATOS.COMPANIA = SF_LOCALES.COMPANIA AND SF_CONTRATOS.LOCAL = SF_LOCALES.CODIGO LEFT JOIN SF_LUGAR ON SF_LOCALES.COMPANIA = SF_LUGAR.COMPANIA AND SF_LOCALES.LUGAR = SF_LUGAR.CODIGO LEFT JOIN SF_UBICACION ON SF_LOCALES.COMPANIA = SF_UBICACION.COMPANIA AND SF_LOCALES.UBICACION = SF_UBICACION.CODIGO WHERE SF_CONTRATOS.COMPANIA= :KEY_COMPANIA AND SF_CONTRATOS.TIPO= :KEY_TIPO AND SF_CONTRATOS.NUMERO= :KEY_NUMERO AND SF_CONTRATOS.ANO= :KEY_ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINALIZACION":"$FECHA_FINALIZACION","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_ICA":"$VALOR_ICA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_TOTAL":"$VALOR_TOTAL","TOTAL_TCONTRATADO":"$TOTAL_TCONTRATADO","TIPOCOTIZACION":"$TIPOCOTIZACION","NUMCOTIZACION":"$NUMCOTIZACION(type:long)","ESTADO":"$ESTADO(type:integer)","OBJETO_CONTRATO":"$OBJETO_CONTRATO","TIEMPO_CONTRATADO":"$TIEMPO_CONTRATADO","CORTE_FACTURACION":"$CORTE_FACTURACION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","ANO":"$ANO(type:integer)","NOMBRETERCERO":"$NOMBRETERCERO","VENDEDOR":"$VENDEDOR","NOMBREVENDEDOR":"$NOMBREVENDEDOR","RESOLUCION_ADJUDICACION":"$RESOLUCION_ADJUDICACION(type:integer)","FECHA_RESOLUCION":"$FECHA_RESOLUCION","ACTA_NOTIFIACION":"$ACTA_NOTIFIACION(type:integer)","FECHA_NOTIFICACION":"$FECHA_NOTIFICACION","ACTA_VISITA":"$ACTA_VISITA(type:integer)","FECHA_VISITA":"$FECHA_VISITA","LOCAL":"$LOCAL","ANCHO":"$ANCHO","LARGO":"$LARGO","AREA":"$AREA","NOMBRE_ESTADO":"$NOMBRE_ESTADO","DESCRIPCION":"$DESCRIPCION","NOMBRE_LUGAR":"$NOMBRE_LUGAR","NOMBRE_UBICACION":"$NOMBRE_UBICACION","CODIGO_ANTERIOR":"$CODIGO_ANTERIOR","TIPO_PAGO":"$TIPO_PAGO","TOTALPERIODO":"$TOTALPERIODO(type:long)","TOTALAREA":"$TOTALAREA(type:integer)","PORCFONDO":"$PORCFONDO","EDIFICIO":"$EDIFICIO(type:integer)","SERVICIOS":"$SERVICIOS(type:integer)","INCREMENTO":"$INCREMENTO(type:integer)","INVENTARIO":"$INVENTARIO(type:integer)","MEDIDORENERGIA":"$MEDIDORENERGIA(type:integer)","DESTINACION":"$DESTINACION(type:integer)","FACTURASERVICIOS":"$FACTURASERVICIOS(type:boolean)","APROVACIONCONTRATO":"$APROVACIONCONTRATO(type:boolean)","NUMFSICOCONTRATO":"$NUMFSICOCONTRATO","POLIZA":"$POLIZA","ASEGURADORA":"$ASEGURADORA","FECHAINICIOPOLIZA":"$FECHAINICIOPOLIZA","FECHAFINPOLIZA":"$FECHAFINPOLIZA","MESVIGENCIAPOLIZA":"$MESVIGENCIAPOLIZA","VALORNUEVAPOLIZA":"$VALORNUEVAPOLIZA(type:long)","VALORPOLIZA":"$VALORPOLIZA(type:long)","REPRESENTANTELEGAL":"$REPRESENTANTELEGAL","NOMREPLEGAL":"$NOMREPLEGAL","PORCENTAJECUMPLIMIENTO":"$PORCENTAJECUMPLIMIENTO","ORDENADORGASTO":"$ORDENADORGASTO","NOMORDENGASTO":"$NOMORDENGASTO","RESOLUCIONORDENAGASTO":"$RESOLUCIONORDENAGASTO","SUSCRIPCIONORDENADORGASTO":"$SUSCRIPCIONORDENADORGASTO","RESOLTARIFAS":"$RESOLTARIFAS","VERSIONARRENDAMIENTO":"$VERSIONARRENDAMIENTO","FECHAVERSIONARRENDAMIENTO":"$FECHAVERSIONARRENDAMIENTO","COMITEAPROVATORIO":"$COMITEAPROVATORIO","RESOLUREGLAMENTO":"$RESOLUREGLAMENTO","FECHARESOLUREGLAMENTO":"$FECHARESOLUREGLAMENTO","VERSIONSOLICITUD":"$VERSIONSOLICITUD","FECHAVERSIONSOLICITUD":"$FECHAVERSIONSOLICITUD"}]}}		</result>
