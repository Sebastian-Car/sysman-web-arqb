<data name="sfcontratos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfcontratosPagTipoYNumeroInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(TIPO,CONCAT(' - ',NUMERO) ) CONTRATO, SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO FROM SF_CONTRATOS WHERE SF_CONTRATOS.COMPANIA =:COMPANIA ORDER BY SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTRATO":"$CONTRATO","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcontratos/tipoynumeroinicial/pag">
		<call-query href="getSfcontratosPagTipoYNumeroInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosNumTipoYNumeroInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCAT(TIPO,CONCAT(' - ',NUMERO) ) CONTRATO, SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO FROM SF_CONTRATOS WHERE SF_CONTRATOS.COMPANIA =:COMPANIA ORDER BY SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcontratos/tipoynumeroinicial/num">
		<call-query href="getSfcontratosNumTipoYNumeroInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosPagTipoYNumeroFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(TIPO,CONCAT(' - ',NUMERO) ) CONTRATO, SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO FROM SF_CONTRATOS WHERE SF_CONTRATOS.COMPANIA =:COMPANIA AND ( TIPO =:TIPOCONTRATO AND NUMERO &gt;=:NUMEROCONTRATO ) OR ( TIPO &gt;:TIPOCONTRATO ) ORDER BY SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTRATO":"$CONTRATO","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcontratos/tipoynumerofinal/pag">
		<call-query href="getSfcontratosPagTipoYNumeroFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosNumTipoYNumeroFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCAT(TIPO,CONCAT(' - ',NUMERO) ) CONTRATO, SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO FROM SF_CONTRATOS WHERE SF_CONTRATOS.COMPANIA =:COMPANIA AND ( TIPO =:TIPOCONTRATO AND NUMERO &gt;=:NUMEROCONTRATO ) OR ( TIPO &gt;:TIPOCONTRATO ) ORDER BY SF_CONTRATOS.TIPO, SF_CONTRATOS.NUMERO) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcontratos/tipoynumerofinal/num">
		<call-query href="getSfcontratosNumTipoYNumeroFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosTodosPorContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_CONTRATOS.TERCERO, SF_CONTRATOS.SUCURSAL, SF_CONTRATOS.CENTRO_COSTO, SF_CONTRATOS.AUXILIAR, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, AUXILIAR.NOMBRE NOMBREAUXILIAR, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBRE_TERCERO, TERCERO.DIRECCION, TERCERO.TELEFONOS, TERCERO.CODIGOPOSTAL FROM SF_CONTRATOS LEFT JOIN CENTRO_COSTO ON SF_CONTRATOS.COMPANIA = CENTRO_COSTO.COMPANIA AND SF_CONTRATOS.CENTRO_COSTO = CENTRO_COSTO.CODIGO AND SF_CONTRATOS.ANO = CENTRO_COSTO.ANO LEFT JOIN AUXILIAR ON SF_CONTRATOS.COMPANIA = AUXILIAR.COMPANIA AND SF_CONTRATOS.ANO = AUXILIAR.ANO AND SF_CONTRATOS.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN TERCERO ON SF_CONTRATOS.COMPANIA = TERCERO.COMPANIA AND SF_CONTRATOS.TERCERO = TERCERO.NIT AND SF_CONTRATOS.SUCURSAL = TERCERO.SUCURSAL WHERE SF_CONTRATOS.COMPANIA =:COMPANIA AND SF_CONTRATOS.TIPO =:TIPO AND SF_CONTRATOS.NUMERO =:NUMERO AND SF_CONTRATOS.ANO =:ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","NOMBRE_CENTRO_COSTO":"$NOMBRE_CENTRO_COSTO","NOMBREAUXILIAR":"$NOMBREAUXILIAR","NOMBRE_TERCERO":"$NOMBRE_TERCERO","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","CODIGOPOSTAL":"$CODIGOPOSTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcontratos/todosporcontrato">
		<call-query href="getSfcontratosTodosPorContratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosPagTodosPorTipocontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(SF_CONTRATOS.TIPO,CONCAT(' - ',SF_CONTRATOS.NUMERO) ) CONTRATO,(TO_CHAR(SF_CONTRATOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_CONTRATOS.FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINALIZACION, SF_CONTRATOS.VALOR_TOTAL, SF_CONTRATOS.OBJETO_CONTRATO, SF_CONTRATOS.TIPO, TO_CHAR(SF_CONTRATOS.NUMERO) NUMERO, SF_CONTRATOS.ESTADO, SF_CONTRATOS.ANO, SF_CONTRATOS.TERCERO, SF_CONTRATOS.SUCURSAL, SF_CONTRATOS.CENTRO_COSTO, SF_CONTRATOS.AUXILIAR, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, AUXILIAR.NOMBRE NOMBREAUXILIAR, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBRE_TERCERO, TERCERO.DIRECCION, TERCERO.TELEFONOS, TERCERO.CODIGOPOSTAL FROM SF_CONTRATOS LEFT JOIN CENTRO_COSTO ON SF_CONTRATOS.COMPANIA = CENTRO_COSTO.COMPANIA AND SF_CONTRATOS.CENTRO_COSTO = CENTRO_COSTO.CODIGO AND SF_CONTRATOS.ANO = CENTRO_COSTO.ANO LEFT JOIN AUXILIAR ON SF_CONTRATOS.COMPANIA = AUXILIAR.COMPANIA AND SF_CONTRATOS.ANO = AUXILIAR.ANO AND SF_CONTRATOS.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN TERCERO ON SF_CONTRATOS.COMPANIA = TERCERO.COMPANIA AND SF_CONTRATOS.TERCERO = TERCERO.NIT AND SF_CONTRATOS.SUCURSAL = TERCERO.SUCURSAL WHERE SF_CONTRATOS.COMPANIA =:COMPANIA AND SF_CONTRATOS.ESTADO = 2) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(:CONTRATO, '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIO), '%')) AND (CASE WHEN FECHA_FINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_FINALIZACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINALIZACION), '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN OBJETO_CONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETO_CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO_CONTRATO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN NOMBRE_CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CENTRO_COSTO), '%')) AND (CASE WHEN NOMBREAUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBREAUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAUXILIAR), '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN TELEFONOS IS NULL THEN ' ' ELSE UPPER(TELEFONOS) END) LIKE UPPER(CONCAT(CONCAT('%',:TELEFONOS), '%')) AND (CASE WHEN CODIGOPOSTAL IS NULL THEN ' ' ELSE UPPER(CODIGOPOSTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPOSTAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTRATO":"$CONTRATO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINALIZACION":"$FECHA_FINALIZACION","VALOR_TOTAL":"$VALOR_TOTAL","OBJETO_CONTRATO":"$OBJETO_CONTRATO","TIPO":"$TIPO","NUMERO":"$NUMERO","ESTADO":"$ESTADO(type:integer)","ANO":"$ANO(type:integer)","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","NOMBRE_CENTRO_COSTO":"$NOMBRE_CENTRO_COSTO","NOMBREAUXILIAR":"$NOMBREAUXILIAR","NOMBRE_TERCERO":"$NOMBRE_TERCERO","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","CODIGOPOSTAL":"$CODIGOPOSTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINALIZACION" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="OBJETO_CONTRATO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="NOMBRE_CENTRO_COSTO" sqlType="STRING"/>
		<param name="NOMBREAUXILIAR" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="TELEFONOS" sqlType="STRING"/>
		<param name="CODIGOPOSTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcontratos/todosportipocontrato/pag">
		<call-query href="getSfcontratosPagTodosPorTipocontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINALIZACION" query-param="FECHA_FINALIZACION"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="OBJETO_CONTRATO" query-param="OBJETO_CONTRATO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="NOMBRE_CENTRO_COSTO" query-param="NOMBRE_CENTRO_COSTO"/>
			<with-param name="NOMBREAUXILIAR" query-param="NOMBREAUXILIAR"/>
			<with-param name="NOMBRE_TERCERO" query-param="NOMBRE_TERCERO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="TELEFONOS" query-param="TELEFONOS"/>
			<with-param name="CODIGOPOSTAL" query-param="CODIGOPOSTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfcontratosNumTodosPorTipocontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCAT(SF_CONTRATOS.TIPO,CONCAT(' - ',SF_CONTRATOS.NUMERO) ) CONTRATO,(TO_CHAR(SF_CONTRATOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_CONTRATOS.FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINALIZACION, SF_CONTRATOS.VALOR_TOTAL, SF_CONTRATOS.OBJETO_CONTRATO, SF_CONTRATOS.TIPO, TO_CHAR(SF_CONTRATOS.NUMERO) NUMERO, SF_CONTRATOS.ESTADO, SF_CONTRATOS.ANO, SF_CONTRATOS.TERCERO, SF_CONTRATOS.SUCURSAL, SF_CONTRATOS.CENTRO_COSTO, SF_CONTRATOS.AUXILIAR, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, AUXILIAR.NOMBRE NOMBREAUXILIAR, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBRE_TERCERO, TERCERO.DIRECCION, TERCERO.TELEFONOS, TERCERO.CODIGOPOSTAL FROM SF_CONTRATOS LEFT JOIN CENTRO_COSTO ON SF_CONTRATOS.COMPANIA = CENTRO_COSTO.COMPANIA AND SF_CONTRATOS.CENTRO_COSTO = CENTRO_COSTO.CODIGO AND SF_CONTRATOS.ANO = CENTRO_COSTO.ANO LEFT JOIN AUXILIAR ON SF_CONTRATOS.COMPANIA = AUXILIAR.COMPANIA AND SF_CONTRATOS.ANO = AUXILIAR.ANO AND SF_CONTRATOS.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN TERCERO ON SF_CONTRATOS.COMPANIA = TERCERO.COMPANIA AND SF_CONTRATOS.TERCERO = TERCERO.NIT AND SF_CONTRATOS.SUCURSAL = TERCERO.SUCURSAL WHERE SF_CONTRATOS.COMPANIA =:COMPANIA AND SF_CONTRATOS.ESTADO = 2) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(:CONTRATO, '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIO), '%')) AND (CASE WHEN FECHA_FINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_FINALIZACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINALIZACION), '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN OBJETO_CONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETO_CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO_CONTRATO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN NOMBRE_CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CENTRO_COSTO), '%')) AND (CASE WHEN NOMBREAUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBREAUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAUXILIAR), '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN TELEFONOS IS NULL THEN ' ' ELSE UPPER(TELEFONOS) END) LIKE UPPER(CONCAT(CONCAT('%',:TELEFONOS), '%')) AND (CASE WHEN CODIGOPOSTAL IS NULL THEN ' ' ELSE UPPER(CODIGOPOSTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPOSTAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
