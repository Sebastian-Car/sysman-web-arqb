	<query id="insertSfcontratos" keyColumns="COMPANIA,TIPO,NUMERO,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_CONTRATOS (COMPANIA, TIPO, NUMERO, FECHA_INICIO, FECHA_FINALIZACION, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_ICA, VALOR_DESCUENTO, VALOR_TOTAL, TOTAL_TCONTRATADO, TIPOCOTIZACION, NUMCOTIZACION, ESTADO, OBJETO_CONTRATO, TIEMPO_CONTRATADO, CORTE_FACTURACION, ANO, RESOLUCION_ADJUDICACION, FECHA_RESOLUCION, ACTA_NOTIFIACION, FECHA_NOTIFICACION, ACTA_VISITA, FECHA_VISITA, LOCAL, VENDEDOR, TIPO_PAGO, TOTALPERIODO, TOTALAREA, PORCFONDO, EDIFICIO, SERVICIOS, INCREMENTO, INVENTARIO, MEDIDORENERGIA, DESTINACION, FACTURASERVICIOS, APROVACIONCONTRATO, NUMFSICOCONTRATO, POLIZA, ASEGURADORA, FECHAINICIOPOLIZA, FECHAFINPOLIZA, MESVIGENCIAPOLIZA, VALORNUEVAPOLIZA, VALORPOLIZA, REPRESENTANTELEGAL, PORCENTAJECUMPLIMIENTO, ORDENADORGASTO, RESOLUCIONORDENAGASTO, SUSCRIPCIONORDENADORGASTO, RESOLTARIFAS, VERSIONARRENDAMIENTO, FECHAVERSIONARRENDAMIENTO, COMITEAPROVATORIO, RESOLUREGLAMENTO, FECHARESOLUREGLAMENTO, VERSIONSOLICITUD, FECHAVERSIONSOLICITUD, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :NUMERO, TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS'), :TERCERO, :SUCURSAL, :CENTRO_COSTO, :AUXILIAR, :VALOR_BASE, :VALOR_IVA, :VALOR_RETE, :VALOR_ICA, :VALOR_DESCUENTO, :VALOR_TOTAL, :TOTAL_TCONTRATADO, :TIPOCOTIZACION, :NUMCOTIZACION, :ESTADO, :OBJETO_CONTRATO, :TIEMPO_CONTRATADO, :CORTE_FACTURACION, :ANO, :RESOLUCION_ADJUDICACION, TO_DATE(:FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS'), :ACTA_NOTIFIACION, TO_DATE(:FECHA_NOTIFICACION,'DD/MM/YYYY HH24:MI:SS'), :ACTA_VISITA, TO_DATE(:FECHA_VISITA,'DD/MM/YYYY HH24:MI:SS'), :LOCAL, :VENDEDOR, :TIPO_PAGO, :TOTALPERIODO, :TOTALAREA, :PORCFONDO, :EDIFICIO, :SERVICIOS, :INCREMENTO, :INVENTARIO, :MEDIDORENERGIA, :DESTINACION, :FACTURASERVICIOS, :APROVACIONCONTRATO, :NUMFSICOCONTRATO, :POLIZA, :ASEGURADORA, :FECHAINICIOPOLIZA, :FECHAFINPOLIZA, :MESVIGENCIAPOLIZA, :VALORNUEVAPOLIZA, :VALORPOLIZA, :REPRESENTANTELEGAL, :PORCENTAJECUMPLIMIENTO, :ORDENADORGASTO, :RESOLUCIONORDENAGASTO, :SUSCRIPCIONORDENADORGASTO, :RESOLTARIFAS, :VERSIONARRENDAMIENTO, TO_DATE(:FECHAVERSIONARRENDAMIENTO,'DD/MM/YYYY HH24:MI:SS'), :COMITEAPROVATORIO, :RESOLUREGLAMENTO, TO_DATE(:FECHARESOLUREGLAMENTO,'DD/MM/YYYY HH24:MI:SS'), :VERSIONSOLICITUD, TO_DATE(:FECHAVERSIONSOLICITUD,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO" sqlType="STRING"/>
