	<query id="updateSfcontratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CONTRATOS SET TIPO=:TIPO, NUMERO=:NUMERO, FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINALIZACION=TO_DATE(:FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS'), TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, VALOR_BASE=:VALOR_BASE, VALOR_IVA=:VALOR_IVA, VALOR_RETE=:VALOR_RETE, VALOR_ICA=:VALOR_ICA, VALOR_DESCUENTO=:VALOR_DESCUENTO, VALOR_TOTAL=:VALOR_TOTAL, TOTAL_TCONTRATADO=:TOTAL_TCONTRATADO, TIPOCOTIZACION=:TIPOCOTIZACION, NUMCOTIZACION=:NUMCOTIZACION, ESTADO=:ESTADO, OBJETO_CONTRATO=:OBJETO_CONTRATO, TIEMPO_CONTRATADO=:TIEMPO_CONTRATADO, CORTE_FACTURACION=:CORTE_FACTURACION, ANO=:ANO, RESOLUCION_ADJUDICACION=:RESOLUCION_ADJUDICACION, FECHA_RESOLUCION=TO_DATE(:FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS'), ACTA_NOTIFIACION=:ACTA_NOTIFIACION, FECHA_NOTIFICACION=TO_DATE(:FECHA_NOTIFICACION,'DD/MM/YYYY HH24:MI:SS'), ACTA_VISITA=:ACTA_VISITA, FECHA_VISITA=TO_DATE(:FECHA_VISITA,'DD/MM/YYYY HH24:MI:SS'), LOCAL=:LOCAL, VENDEDOR=:VENDEDOR, TIPO_PAGO=:TIPO_PAGO, TOTALPERIODO=:TOTALPERIODO, TOTALAREA=:TOTALAREA, PORCFONDO=:PORCFONDO, EDIFICIO=:EDIFICIO, SERVICIOS=:SERVICIOS, INCREMENTO=:INCREMENTO, INVENTARIO=:INVENTARIO, MEDIDORENERGIA=:MEDIDORENERGIA, DESTINACION=:DESTINACION, FACTURASERVICIOS=:FACTURASERVICIOS, APROVACIONCONTRATO=:APROVACIONCONTRATO, NUMFSICOCONTRATO=:NUMFSICOCONTRATO, POLIZA=:POLIZA, ASEGURADORA=:ASEGURADORA, FECHAINICIOPOLIZA=:FECHAINICIOPOLIZA, FECHAFINPOLIZA=:FECHAFINPOLIZA, MESVIGENCIAPOLIZA=:MESVIGENCIAPOLIZA, VALORNUEVAPOLIZA=:VALORNUEVAPOLIZA, VALORPOLIZA=:VALORPOLIZA, REPRESENTANTELEGAL=:REPRESENTANTELEGAL, PORCENTAJECUMPLIMIENTO=:PORCENTAJECUMPLIMIENTO, ORDENADORGASTO=:ORDENADORGASTO, RESOLUCIONORDENAGASTO=:RESOLUCIONORDENAGASTO, SUSCRIPCIONORDENADORGASTO=:SUSCRIPCIONORDENADORGASTO, RESOLTARIFAS=:RESOLTARIFAS, VERSIONARRENDAMIENTO=:VERSIONARRENDAMIENTO, FECHAVERSIONARRENDAMIENTO=TO_DATE(:FECHAVERSIONARRENDAMIENTO,'DD/MM/YYYY HH24:MI:SS'), COMITEAPROVATORIO=:COMITEAPROVATORIO, RESOLUREGLAMENTO=:RESOLUREGLAMENTO, FECHARESOLUREGLAMENTO=TO_DATE(:FECHARESOLUREGLAMENTO,'DD/MM/YYYY HH24:MI:SS'), VERSIONSOLICITUD=:VERSIONSOLICITUD, FECHAVERSIONSOLICITUD=TO_DATE(:FECHAVERSIONSOLICITUD,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_CONTRATOS.COMPANIA= :KEY_COMPANIA AND SF_CONTRATOS.TIPO= :KEY_TIPO AND SF_CONTRATOS.NUMERO= :KEY_NUMERO AND SF_CONTRATOS.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

