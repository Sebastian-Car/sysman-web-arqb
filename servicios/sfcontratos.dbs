		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_CONTRATOS.TIPO, TO_CHAR( SF_CONTRATOS.NUMERO ) NUMERO, CONCAT( SF_CONTRATOS.TIPO, CONCAT( ' - ', SF_CONTRATOS.NUMERO ) ) CONTRATO,(TO_CHAR(SF_CONTRATOS.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(SF_CONTRATOS.FECHA_FINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINALIZACION, SF_CONTRATOS.OBJETO_CONTRATO, SF_CONTRATOS.VALOR_TOTAL, TIPO_PAGO.EQUIVALENTE_DIAN, TIPO_PAGO.NOMBRE, TIPO_PAGO.DIAS FROM SF_CONTRATOS LEFT JOIN TIPO_PAGO ON SF_CONTRATOS.COMPANIA = TIPO_PAGO.COMPANIA AND SF_CONTRATOS.TIPO_PAGO = TIPO_PAGO.CODIGO WHERE SF_CONTRATOS.COMPANIA = :COMPANIA AND SF_CONTRATOS.TERCERO = :TERCERO AND SF_CONTRATOS.ESTADO = 2) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(:CONTRATO, '%')) AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIO), '%')) AND (CASE WHEN FECHA_FINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHA_FINALIZACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINALIZACION), '%')) AND (CASE WHEN OBJETO_CONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETO_CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO_CONTRATO), '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN EQUIVALENTE_DIAN IS NULL THEN ' ' ELSE UPPER(EQUIVALENTE_DIAN) END) LIKE UPPER(CONCAT(:EQUIVALENTE_DIAN, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(:DIAS, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
