	<query id="insertSftipocobro" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_TIPO_COBRO (COMPANIA, ANO, CODIGO, NOMBRE, PERIODICIDAD, CONCEPTODEUCAPITAL, CONCEPTODEUINTERES, CONCEPTOSANCION, GENERADEUDA, MANEJAESTRATO, VENCIMIENTO_FACTURACION, DIAS_VALIDEZ, MANEJA_INVENTARIO, CONSECUTIVO_FACTURACION, CPTE_RECAUDO, TIPOCPTE_ANULACION, MANEJA_RESFACTURACION, NORES_FACTURACION, FECRES_FACTURACION, NOINICIAL_FACTURACION, NOFINAL_FACTURACION, FORMATO_FACTURA, LEYENDA_FACTURA, IND_DERECHOSCONEXION, INTERFAZ_RECAUDO, TIPOFACTURA_RECAUDO, TIPOCOBRO_NOFACTURADO, MANEJA_RECAUDOTERCEROS, CLASE_CUENTASRECAUDO, BASEORIGINAL, LIQUIDACION, CODIGOEAN, NOAPLICACAUSACION, INICIAEN, BANCO_CUENTA1, BANCO_CUENTA2, BANCO_CUENTA3, BANCO_CUENTA4, INDPRELIQUIDACION, APLCUENTAREC, MANEJATARIFABASE, MANEJADESCRIP_EST, CPTE_DIFERIDA, FORMATO_PLANTILLA, MAN_ACUERDO_PRED, CLAVETECNICA, FECHA_FIN_RESOLUCION, TIPO_MEDIOPAGO, TIPO_MONEDA, TIPOFACDIAN, FORMATO_FAC_ELECTRONICA, MANEJA_CARTERA, MANEJA_INTERES_CARTERA, CPTE_CAUSACION_INTERES, TIPOCPTE_DEVOLUCION, CONSECUTIVO_COBRO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :PERIODICIDAD, :CONCEPTODEUCAPITAL, :CONCEPTODEUINTERES, :CONCEPTOSANCION, :GENERADEUDA, :MANEJAESTRATO, :VENCIMIENTO_FACTURACION, :DIAS_VALIDEZ, :MANEJA_INVENTARIO, :CONSECUTIVO_FACTURACION, :CPTE_RECAUDO, :TIPOCPTE_ANULACION, :MANEJA_RESFACTURACION, :NORES_FACTURACION, TO_DATE(:FECRES_FACTURACION,'DD/MM/YYYY HH24:MI:SS'), :NOINICIAL_FACTURACION, :NOFINAL_FACTURACION, :FORMATO_FACTURA, :LEYENDA_FACTURA, :IND_DERECHOSCONEXION, :INTERFAZ_RECAUDO, :TIPOFACTURA_RECAUDO, :TIPOCOBRO_NOFACTURADO, :MANEJA_RECAUDOTERCEROS, :CLASE_CUENTASRECAUDO, :BASEORIGINAL, :LIQUIDACION, :CODIGOEAN, :NOAPLICACAUSACION, :INICIAEN, :BANCO_CUENTA1, :BANCO_CUENTA2, :BANCO_CUENTA3, :BANCO_CUENTA4, :INDPRELIQUIDACION, :APLCUENTAREC, :MANEJATARIFABASE, :MANEJADESCRIP_EST, :CPTE_DIFERIDA, :FORMATO_PLANTILLA, :MAN_ACUERDO_PRED, :CLAVETECNICA, TO_DATE(:FECHA_FIN_RESOLUCION,'DD/MM/YYYY HH24:MI:SS'), :TIPO_MEDIOPAGO, :TIPO_MONEDA, :TIPOFACDIAN, :FORMATO_FAC_ELECTRONICA, :MANEJA_CARTERA, :MANEJA_INTERES_CARTERA, :CPTE_CAUSACION_INTERES, :TIPOCPTE_DEVOLUCION, :CONSECUTIVO_COBRO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
