	<query id="getSftipocobroRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA , ANO , CODIGO , NOMBRE , PERIODICIDAD , CONCEPTODEUCAPITAL , CONCEPTODEUINTERES , CONCEPTOSANCION ,(CASE GENERADEUDA WHEN 0 THEN 'false' ELSE 'true' END) GENERADEUDA,(CASE MANEJAESTRATO WHEN 0 THEN 'false' ELSE 'true' END) MANEJAESTRATO, VENCIMIENTO_FACTURACION , DIAS_VALIDEZ ,(CASE MANEJA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INVENTARIO, CONSECUTIVO_FACTURACION , CPTE_RECAUDO , TIPOCPTE_ANULACION ,(CASE MANEJA_RESFACTURACION WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RESFACTURACION, NORES_FACTURACION ,(TO_CHAR(FECRES_FACTURACION,'DD/MM/YYYY HH24:MI:SS')) FECRES_FACTURACION, NOINICIAL_FACTURACION , NOFINAL_FACTURACION , FORMATO_FACTURA , LEYENDA_FACTURA ,(CASE IND_DERECHOSCONEXION WHEN 0 THEN 'false' ELSE 'true' END) IND_DERECHOSCONEXION,(CASE INTERFAZ_RECAUDO WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZ_RECAUDO, TIPOFACTURA_RECAUDO ,(CASE TIPOCOBRO_NOFACTURADO WHEN 0 THEN 'false' ELSE 'true' END) TIPOCOBRO_NOFACTURADO,(CASE MANEJA_RECAUDOTERCEROS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RECAUDOTERCEROS, CLASE_CUENTASRECAUDO , BASEORIGINAL ,(CASE LIQUIDACION WHEN 0 THEN 'false' ELSE 'true' END) LIQUIDACION, CODIGOEAN ,(CASE NOAPLICACAUSACION WHEN 0 THEN 'false' ELSE 'true' END) NOAPLICACAUSACION, INICIAEN , BANCO_CUENTA1 , BANCO_CUENTA2 , BANCO_CUENTA3 , BANCO_CUENTA4 ,(CASE INDPRELIQUIDACION WHEN 0 THEN 'false' ELSE 'true' END) INDPRELIQUIDACION, CREATED_BY ,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY ,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE APLCUENTAREC WHEN 0 THEN 'false' ELSE 'true' END) APLCUENTAREC,(CASE MANEJATARIFABASE WHEN 0 THEN 'false' ELSE 'true' END) MANEJATARIFABASE,(CASE MANEJADESCRIP_EST WHEN 0 THEN 'false' ELSE 'true' END) MANEJADESCRIP_EST,CPTE_DIFERIDA,FORMATO_PLANTILLA,(CASE MAN_ACUERDO_PRED WHEN 0 THEN 'false' ELSE 'true' END) MAN_ACUERDO_PRED, REF_FACTURACION,CLAVETECNICA,(TO_CHAR(FECHA_FIN_RESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FIN_RESOLUCION, TIPO_MEDIOPAGO,TIPO_MONEDA,TIPOFACDIAN,FORMATO_FAC_ELECTRONICA,(CASE MANEJA_CARTERA WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_CARTERA,(CASE MANEJA_INTERES_CARTERA WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INTERES_CARTERA,CPTE_CAUSACION_INTERES, TIPOCPTE_DEVOLUCION,CONSECUTIVO_COBRO FROM SF_TIPO_COBRO WHERE SF_TIPO_COBRO.COMPANIA= :KEY_COMPANIA AND SF_TIPO_COBRO.ANO= :KEY_ANO AND SF_TIPO_COBRO.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","PERIODICIDAD":"$PERIODICIDAD","CONCEPTODEUCAPITAL":"$CONCEPTODEUCAPITAL","CONCEPTODEUINTERES":"$CONCEPTODEUINTERES","CONCEPTOSANCION":"$CONCEPTOSANCION","GENERADEUDA":"$GENERADEUDA(type:boolean)","MANEJAESTRATO":"$MANEJAESTRATO(type:boolean)","VENCIMIENTO_FACTURACION":"$VENCIMIENTO_FACTURACION","DIAS_VALIDEZ":"$DIAS_VALIDEZ(type:integer)","MANEJA_INVENTARIO":"$MANEJA_INVENTARIO(type:boolean)","CONSECUTIVO_FACTURACION":"$CONSECUTIVO_FACTURACION(type:long)","CPTE_RECAUDO":"$CPTE_RECAUDO","TIPOCPTE_ANULACION":"$TIPOCPTE_ANULACION","MANEJA_RESFACTURACION":"$MANEJA_RESFACTURACION(type:boolean)","NORES_FACTURACION":"$NORES_FACTURACION","FECRES_FACTURACION":"$FECRES_FACTURACION","NOINICIAL_FACTURACION":"$NOINICIAL_FACTURACION(type:long)","NOFINAL_FACTURACION":"$NOFINAL_FACTURACION(type:long)","FORMATO_FACTURA":"$FORMATO_FACTURA","LEYENDA_FACTURA":"$LEYENDA_FACTURA","IND_DERECHOSCONEXION":"$IND_DERECHOSCONEXION(type:boolean)","INTERFAZ_RECAUDO":"$INTERFAZ_RECAUDO(type:boolean)","TIPOFACTURA_RECAUDO":"$TIPOFACTURA_RECAUDO(type:integer)","TIPOCOBRO_NOFACTURADO":"$TIPOCOBRO_NOFACTURADO(type:boolean)","MANEJA_RECAUDOTERCEROS":"$MANEJA_RECAUDOTERCEROS(type:boolean)","CLASE_CUENTASRECAUDO":"$CLASE_CUENTASRECAUDO","BASEORIGINAL":"$BASEORIGINAL(type:long)","LIQUIDACION":"$LIQUIDACION(type:boolean)","CODIGOEAN":"$CODIGOEAN","NOAPLICACAUSACION":"$NOAPLICACAUSACION(type:boolean)","INICIAEN":"$INICIAEN(type:long)","BANCO_CUENTA1":"$BANCO_CUENTA1","BANCO_CUENTA2":"$BANCO_CUENTA2","BANCO_CUENTA3":"$BANCO_CUENTA3","BANCO_CUENTA4":"$BANCO_CUENTA4","INDPRELIQUIDACION":"$INDPRELIQUIDACION(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","APLCUENTAREC":"$APLCUENTAREC(type:boolean)","MANEJATARIFABASE":"$MANEJATARIFABASE(type:boolean)","MANEJADESCRIP_EST":"$MANEJADESCRIP_EST(type:boolean)","CPTE_DIFERIDA":"$CPTE_DIFERIDA","FORMATO_PLANTILLA":"$FORMATO_PLANTILLA","MAN_ACUERDO_PRED":"$MAN_ACUERDO_PRED(type:boolean)","REF_FACTURACION":"$REF_FACTURACION","CLAVETECNICA":"$CLAVETECNICA","FECHA_FIN_RESOLUCION":"$FECHA_FIN_RESOLUCION","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_MONEDA":"$TIPO_MONEDA","TIPOFACDIAN":"$TIPOFACDIAN","FORMATO_FAC_ELECTRONICA":"$FORMATO_FAC_ELECTRONICA","MANEJA_CARTERA":"$MANEJA_CARTERA(type:boolean)","MANEJA_INTERES_CARTERA":"$MANEJA_INTERES_CARTERA(type:boolean)","CPTE_CAUSACION_INTERES":"$CPTE_CAUSACION_INTERES","TIPOCPTE_DEVOLUCION":"$TIPOCPTE_DEVOLUCION","CONSECUTIVO_COBRO":"$CONSECUTIVO_COBRO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
