	<query id="deleteSftipocobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_TIPO_COBRO WHERE SF_TIPO_COBRO.COMPANIA= :KEY_COMPANIA AND SF_TIPO_COBRO.ANO= :KEY_ANO AND SF_TIPO_COBRO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sftipocobro">
		<call-query href="deleteSftipocobro">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE,(CASE MANEJA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INVENTARIO,(CASE INTERFAZ_RECAUDO WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZ_RECAUDO, CONSECUTIVO_FACTURACION FROM SF_TIPO_COBRO WHERE COMPANIA =:COMPANIA ORDER BY ANO DESC ,CODIGO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MANEJA_INVENTARIO IS NULL THEN ' ' ELSE UPPER(MANEJA_INVENTARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:MANEJA_INVENTARIO), '%')) AND (CASE WHEN INTERFAZ_RECAUDO IS NULL THEN ' ' ELSE UPPER(INTERFAZ_RECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:INTERFAZ_RECAUDO), '%')) AND (CASE WHEN CONSECUTIVO_FACTURACION IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_FACTURACION) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO_FACTURACION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MANEJA_INVENTARIO":"$MANEJA_INVENTARIO(type:boolean)","INTERFAZ_RECAUDO":"$INTERFAZ_RECAUDO(type:boolean)","CONSECUTIVO_FACTURACION":"$CONSECUTIVO_FACTURACION(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MANEJA_INVENTARIO" sqlType="STRING"/>
		<param name="INTERFAZ_RECAUDO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftipocobro">
		<call-query href="getSftipocobroPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MANEJA_INVENTARIO" query-param="MANEJA_INVENTARIO"/>
			<with-param name="INTERFAZ_RECAUDO" query-param="INTERFAZ_RECAUDO"/>
			<with-param name="CONSECUTIVO_FACTURACION" query-param="CONSECUTIVO_FACTURACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE,(CASE MANEJA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INVENTARIO,(CASE INTERFAZ_RECAUDO WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZ_RECAUDO, CONSECUTIVO_FACTURACION FROM SF_TIPO_COBRO WHERE COMPANIA =:COMPANIA ORDER BY ANO DESC ,CODIGO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MANEJA_INVENTARIO IS NULL THEN ' ' ELSE UPPER(MANEJA_INVENTARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:MANEJA_INVENTARIO), '%')) AND (CASE WHEN INTERFAZ_RECAUDO IS NULL THEN ' ' ELSE UPPER(INTERFAZ_RECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:INTERFAZ_RECAUDO), '%')) AND (CASE WHEN CONSECUTIVO_FACTURACION IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_FACTURACION) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO_FACTURACION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MANEJA_INVENTARIO" sqlType="STRING"/>
		<param name="INTERFAZ_RECAUDO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURACION" sqlType="STRING"/>

	</query>
