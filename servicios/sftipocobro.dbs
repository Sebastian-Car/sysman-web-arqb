<data name="sftipocobro" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSftipocobroAniosordendescQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO  FROM SF_TIPO_COBRO WHERE COMPANIA = :COMPANIA ORDER BY ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipocobro/aniosordendesc">
		<call-query href="getSftipocobroAniosordendescQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSftipocobroNombresporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, UPPER(NOMBRE) NOMBRE  FROM SF_TIPO_COBRO WHERE COMPANIA = :COMPANIA AND ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipocobro/nombresporanio">
		<call-query href="getSftipocobroNombresporanioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroNombresporanioycodQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, UPPER(NOMBRE) NOMBRE FROM SF_TIPO_COBRO WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CODIGO,' ','') ),CONCAT('',CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE (CODIGO,' ','') ),'') ),1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipocobro/nombresporanioycod">
		<call-query href="getSftipocobroNombresporanioycodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroPagTodosPorTipoFacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_TIPO_COBRO.CODIGO, SF_TIPO_COBRO.NOMBRE, SF_TIPO_COBRO.ANO  FROM SF_TIPO_COBRO WHERE SF_TIPO_COBRO.COMPANIA=:COMPANIA AND SF_TIPO_COBRO.CODIGO = :TIPOCOBRO AND SF_TIPO_COBRO.ANO = :ANOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftipocobro/todosportipofactura/pag">
		<call-query href="getSftipocobroPagTodosPorTipoFacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANOCOBRO" query-param="ANOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroNumTodosPorTipoFacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_TIPO_COBRO.CODIGO, SF_TIPO_COBRO.NOMBRE, SF_TIPO_COBRO.ANO  FROM SF_TIPO_COBRO WHERE SF_TIPO_COBRO.COMPANIA=:COMPANIA AND SF_TIPO_COBRO.CODIGO = :TIPOCOBRO AND SF_TIPO_COBRO.ANO = :ANOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipocobro/todosportipofactura/num">
		<call-query href="getSftipocobroNumTodosPorTipoFacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANOCOBRO" query-param="ANOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroPagCodnommanejainventarioporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, UPPER(NOMBRE) NOMBRE,(CASE MANEJA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INVENTARIO,(CASE INTERFAZ_RECAUDO WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZ_RECAUDO,(CASE TIPOCOBRO_NOFACTURADO WHEN 0 THEN 'false' ELSE 'true' END) TIPOCOBRO_NOFACTURADO, CPTE_RECAUDO,(CASE MANEJA_RECAUDOTERCEROS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RECAUDOTERCEROS, CLASE_CUENTASRECAUDO,(CASE INDPRELIQUIDACION WHEN 0 THEN 'false' ELSE 'true' END) INDPRELIQUIDACION,(CASE APLCUENTAREC WHEN 0 THEN 'false' ELSE 'true' END) APLCUENTAREC, REF_FACTURACION, TIPOFACTURA_RECAUDO FROM SF_TIPO_COBRO WHERE COMPANIA =:COMPANIA AND ANO =:ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MANEJA_INVENTARIO IS NULL THEN ' ' ELSE UPPER(MANEJA_INVENTARIO) END) LIKE UPPER(CONCAT(:MANEJA_INVENTARIO, '%')) AND (CASE WHEN INTERFAZ_RECAUDO IS NULL THEN ' ' ELSE UPPER(INTERFAZ_RECAUDO) END) LIKE UPPER(CONCAT(:INTERFAZ_RECAUDO, '%')) AND (CASE WHEN TIPOCOBRO_NOFACTURADO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO_NOFACTURADO) END) LIKE UPPER(CONCAT(:TIPOCOBRO_NOFACTURADO, '%')) AND (CASE WHEN CPTE_RECAUDO IS NULL THEN ' ' ELSE UPPER(CPTE_RECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CPTE_RECAUDO), '%')) AND (CASE WHEN MANEJA_RECAUDOTERCEROS IS NULL THEN ' ' ELSE UPPER(MANEJA_RECAUDOTERCEROS) END) LIKE UPPER(CONCAT(:MANEJA_RECAUDOTERCEROS, '%')) AND (CASE WHEN CLASE_CUENTASRECAUDO IS NULL THEN ' ' ELSE UPPER(CLASE_CUENTASRECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CUENTASRECAUDO), '%')) AND (CASE WHEN INDPRELIQUIDACION IS NULL THEN ' ' ELSE UPPER(INDPRELIQUIDACION) END) LIKE UPPER(CONCAT(:INDPRELIQUIDACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MANEJA_INVENTARIO":"$MANEJA_INVENTARIO(type:boolean)","INTERFAZ_RECAUDO":"$INTERFAZ_RECAUDO(type:boolean)","TIPOCOBRO_NOFACTURADO":"$TIPOCOBRO_NOFACTURADO(type:boolean)","CPTE_RECAUDO":"$CPTE_RECAUDO","MANEJA_RECAUDOTERCEROS":"$MANEJA_RECAUDOTERCEROS(type:boolean)","CLASE_CUENTASRECAUDO":"$CLASE_CUENTASRECAUDO","INDPRELIQUIDACION":"$INDPRELIQUIDACION(type:boolean)","APLCUENTAREC":"$APLCUENTAREC(type:boolean)","REF_FACTURACION":"$REF_FACTURACION","TIPOFACTURA_RECAUDO":"$TIPOFACTURA_RECAUDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MANEJA_INVENTARIO" sqlType="STRING"/>
		<param name="INTERFAZ_RECAUDO" sqlType="STRING"/>
		<param name="TIPOCOBRO_NOFACTURADO" sqlType="STRING"/>
		<param name="CPTE_RECAUDO" sqlType="STRING"/>
		<param name="MANEJA_RECAUDOTERCEROS" sqlType="STRING"/>
		<param name="CLASE_CUENTASRECAUDO" sqlType="STRING"/>
		<param name="INDPRELIQUIDACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftipocobro/codnommanejainventarioporanio/pag">
		<call-query href="getSftipocobroPagCodnommanejainventarioporanioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MANEJA_INVENTARIO" query-param="MANEJA_INVENTARIO"/>
			<with-param name="INTERFAZ_RECAUDO" query-param="INTERFAZ_RECAUDO"/>
			<with-param name="TIPOCOBRO_NOFACTURADO" query-param="TIPOCOBRO_NOFACTURADO"/>
			<with-param name="CPTE_RECAUDO" query-param="CPTE_RECAUDO"/>
			<with-param name="MANEJA_RECAUDOTERCEROS" query-param="MANEJA_RECAUDOTERCEROS"/>
			<with-param name="CLASE_CUENTASRECAUDO" query-param="CLASE_CUENTASRECAUDO"/>
			<with-param name="INDPRELIQUIDACION" query-param="INDPRELIQUIDACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroNumCodnommanejainventarioporanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, UPPER(NOMBRE) NOMBRE,(CASE MANEJA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INVENTARIO,(CASE INTERFAZ_RECAUDO WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZ_RECAUDO,(CASE TIPOCOBRO_NOFACTURADO WHEN 0 THEN 'false' ELSE 'true' END) TIPOCOBRO_NOFACTURADO, CPTE_RECAUDO,(CASE MANEJA_RECAUDOTERCEROS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RECAUDOTERCEROS, CLASE_CUENTASRECAUDO,(CASE INDPRELIQUIDACION WHEN 0 THEN 'false' ELSE 'true' END) INDPRELIQUIDACION,(CASE APLCUENTAREC WHEN 0 THEN 'false' ELSE 'true' END) APLCUENTAREC, REF_FACTURACION, TIPOFACTURA_RECAUDO FROM SF_TIPO_COBRO WHERE COMPANIA =:COMPANIA AND ANO =:ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MANEJA_INVENTARIO IS NULL THEN ' ' ELSE UPPER(MANEJA_INVENTARIO) END) LIKE UPPER(CONCAT(:MANEJA_INVENTARIO, '%')) AND (CASE WHEN INTERFAZ_RECAUDO IS NULL THEN ' ' ELSE UPPER(INTERFAZ_RECAUDO) END) LIKE UPPER(CONCAT(:INTERFAZ_RECAUDO, '%')) AND (CASE WHEN TIPOCOBRO_NOFACTURADO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO_NOFACTURADO) END) LIKE UPPER(CONCAT(:TIPOCOBRO_NOFACTURADO, '%')) AND (CASE WHEN CPTE_RECAUDO IS NULL THEN ' ' ELSE UPPER(CPTE_RECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CPTE_RECAUDO), '%')) AND (CASE WHEN MANEJA_RECAUDOTERCEROS IS NULL THEN ' ' ELSE UPPER(MANEJA_RECAUDOTERCEROS) END) LIKE UPPER(CONCAT(:MANEJA_RECAUDOTERCEROS, '%')) AND (CASE WHEN CLASE_CUENTASRECAUDO IS NULL THEN ' ' ELSE UPPER(CLASE_CUENTASRECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CUENTASRECAUDO), '%')) AND (CASE WHEN INDPRELIQUIDACION IS NULL THEN ' ' ELSE UPPER(INDPRELIQUIDACION) END) LIKE UPPER(CONCAT(:INDPRELIQUIDACION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MANEJA_INVENTARIO" sqlType="STRING"/>
		<param name="INTERFAZ_RECAUDO" sqlType="STRING"/>
		<param name="TIPOCOBRO_NOFACTURADO" sqlType="STRING"/>
		<param name="CPTE_RECAUDO" sqlType="STRING"/>
		<param name="MANEJA_RECAUDOTERCEROS" sqlType="STRING"/>
		<param name="CLASE_CUENTASRECAUDO" sqlType="STRING"/>
		<param name="INDPRELIQUIDACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipocobro/codnommanejainventarioporanio/num">
		<call-query href="getSftipocobroNumCodnommanejainventarioporanioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MANEJA_INVENTARIO" query-param="MANEJA_INVENTARIO"/>
			<with-param name="INTERFAZ_RECAUDO" query-param="INTERFAZ_RECAUDO"/>
			<with-param name="TIPOCOBRO_NOFACTURADO" query-param="TIPOCOBRO_NOFACTURADO"/>
			<with-param name="CPTE_RECAUDO" query-param="CPTE_RECAUDO"/>
			<with-param name="MANEJA_RECAUDOTERCEROS" query-param="MANEJA_RECAUDOTERCEROS"/>
			<with-param name="CLASE_CUENTASRECAUDO" query-param="CLASE_CUENTASRECAUDO"/>
			<with-param name="INDPRELIQUIDACION" query-param="INDPRELIQUIDACION"/>

		</call-query>
	</resource>
	<query id="getSftipocobroPagCodnomporanioycodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, UPPER(NOMBRE) NOMBRE,(CASE MANEJA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INVENTARIO,(CASE INTERFAZ_RECAUDO WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZ_RECAUDO,(CASE TIPOCOBRO_NOFACTURADO WHEN 0 THEN 'false' ELSE 'true' END) TIPOCOBRO_NOFACTURADO, CPTE_RECAUDO,(CASE MANEJA_RECAUDOTERCEROS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RECAUDOTERCEROS, CLASE_CUENTASRECAUDO,(CASE INDPRELIQUIDACION WHEN 0 THEN 'false' ELSE 'true' END) INDPRELIQUIDACION FROM SF_TIPO_COBRO WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPOCOBRO,' ','') ),CONCAT('',CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS( REPLACE(CODIGO,' ','') ),'') ),1) &gt; 0) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MANEJA_INVENTARIO IS NULL THEN ' ' ELSE UPPER(MANEJA_INVENTARIO) END) LIKE UPPER(CONCAT(:MANEJA_INVENTARIO, '%')) AND (CASE WHEN INTERFAZ_RECAUDO IS NULL THEN ' ' ELSE UPPER(INTERFAZ_RECAUDO) END) LIKE UPPER(CONCAT(:INTERFAZ_RECAUDO, '%')) AND (CASE WHEN TIPOCOBRO_NOFACTURADO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO_NOFACTURADO) END) LIKE UPPER(CONCAT(:TIPOCOBRO_NOFACTURADO, '%')) AND (CASE WHEN CPTE_RECAUDO IS NULL THEN ' ' ELSE UPPER(CPTE_RECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CPTE_RECAUDO), '%')) AND (CASE WHEN MANEJA_RECAUDOTERCEROS IS NULL THEN ' ' ELSE UPPER(MANEJA_RECAUDOTERCEROS) END) LIKE UPPER(CONCAT(:MANEJA_RECAUDOTERCEROS, '%')) AND (CASE WHEN CLASE_CUENTASRECAUDO IS NULL THEN ' ' ELSE UPPER(CLASE_CUENTASRECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CUENTASRECAUDO), '%')) AND (CASE WHEN INDPRELIQUIDACION IS NULL THEN ' ' ELSE UPPER(INDPRELIQUIDACION) END) LIKE UPPER(CONCAT(:INDPRELIQUIDACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MANEJA_INVENTARIO":"$MANEJA_INVENTARIO(type:boolean)","INTERFAZ_RECAUDO":"$INTERFAZ_RECAUDO(type:boolean)","TIPOCOBRO_NOFACTURADO":"$TIPOCOBRO_NOFACTURADO(type:boolean)","CPTE_RECAUDO":"$CPTE_RECAUDO","MANEJA_RECAUDOTERCEROS":"$MANEJA_RECAUDOTERCEROS(type:boolean)","CLASE_CUENTASRECAUDO":"$CLASE_CUENTASRECAUDO","INDPRELIQUIDACION":"$INDPRELIQUIDACION(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MANEJA_INVENTARIO" sqlType="STRING"/>
		<param name="INTERFAZ_RECAUDO" sqlType="STRING"/>
		<param name="TIPOCOBRO_NOFACTURADO" sqlType="STRING"/>
		<param name="CPTE_RECAUDO" sqlType="STRING"/>
		<param name="MANEJA_RECAUDOTERCEROS" sqlType="STRING"/>
		<param name="CLASE_CUENTASRECAUDO" sqlType="STRING"/>
		<param name="INDPRELIQUIDACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftipocobro/codnomporanioycod/pag">
		<call-query href="getSftipocobroPagCodnomporanioycodQuery">
