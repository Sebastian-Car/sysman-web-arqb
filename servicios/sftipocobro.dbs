			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroNumCodnomporanioycodQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, UPPER(NOMBRE) NOMBRE,(CASE MANEJA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_INVENTARIO,(CASE INTERFAZ_RECAUDO WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZ_RECAUDO,(CASE TIPOCOBRO_NOFACTURADO WHEN 0 THEN 'false' ELSE 'true' END) TIPOCOBRO_NOFACTURADO, CPTE_RECAUDO,(CASE MANEJA_RECAUDOTERCEROS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RECAUDOTERCEROS, CLASE_CUENTASRECAUDO,(CASE INDPRELIQUIDACION WHEN 0 THEN 'false' ELSE 'true' END) INDPRELIQUIDACION FROM SF_TIPO_COBRO WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPOCOBRO,' ','') ),CONCAT('',CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS( REPLACE(CODIGO,' ','') ),'') ),1) &gt; 0) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MANEJA_INVENTARIO IS NULL THEN ' ' ELSE UPPER(MANEJA_INVENTARIO) END) LIKE UPPER(CONCAT(:MANEJA_INVENTARIO, '%')) AND (CASE WHEN INTERFAZ_RECAUDO IS NULL THEN ' ' ELSE UPPER(INTERFAZ_RECAUDO) END) LIKE UPPER(CONCAT(:INTERFAZ_RECAUDO, '%')) AND (CASE WHEN TIPOCOBRO_NOFACTURADO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO_NOFACTURADO) END) LIKE UPPER(CONCAT(:TIPOCOBRO_NOFACTURADO, '%')) AND (CASE WHEN CPTE_RECAUDO IS NULL THEN ' ' ELSE UPPER(CPTE_RECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CPTE_RECAUDO), '%')) AND (CASE WHEN MANEJA_RECAUDOTERCEROS IS NULL THEN ' ' ELSE UPPER(MANEJA_RECAUDOTERCEROS) END) LIKE UPPER(CONCAT(:MANEJA_RECAUDOTERCEROS, '%')) AND (CASE WHEN CLASE_CUENTASRECAUDO IS NULL THEN ' ' ELSE UPPER(CLASE_CUENTASRECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CUENTASRECAUDO), '%')) AND (CASE WHEN INDPRELIQUIDACION IS NULL THEN ' ' ELSE UPPER(INDPRELIQUIDACION) END) LIKE UPPER(CONCAT(:INDPRELIQUIDACION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MANEJA_INVENTARIO" sqlType="STRING"/>
		<param name="INTERFAZ_RECAUDO" sqlType="STRING"/>
		<param name="TIPOCOBRO_NOFACTURADO" sqlType="STRING"/>
		<param name="CPTE_RECAUDO" sqlType="STRING"/>
		<param name="MANEJA_RECAUDOTERCEROS" sqlType="STRING"/>
		<param name="CLASE_CUENTASRECAUDO" sqlType="STRING"/>
		<param name="INDPRELIQUIDACION" sqlType="STRING"/>

	</query>
