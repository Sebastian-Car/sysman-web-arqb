	<query id="getSftipocobroFormatofacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FORMATO_FACTURA,(CASE MANEJA_RESFACTURACION WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RESFACTURACION,NORES_FACTURACION,(TO_CHAR(FECRES_FACTURACION,'DD/MM/YYYY HH24:MI:SS')) FECRES_FACTURACION, NOINICIAL_FACTURACION, NOFINAL_FACTURACION  FROM SF_TIPO_COBRO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :TIPOCOBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FORMATO_FACTURA":"$FORMATO_FACTURA","MANEJA_RESFACTURACION":"$MANEJA_RESFACTURACION(type:boolean)","NORES_FACTURACION":"$NORES_FACTURACION","FECRES_FACTURACION":"$FECRES_FACTURACION","NOINICIAL_FACTURACION":"$NOINICIAL_FACTURACION(type:long)","NOFINAL_FACTURACION":"$NOFINAL_FACTURACION(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipocobro/formatofactura">
		<call-query href="getSftipocobroFormatofacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroTodosPorCompaniaTipoCobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FORMATO_FACTURA  FROM SF_TIPO_COBRO WHERE COMPANIA = :COMPANIA AND ANO = EXTRACT(YEAR FROM SYSDATE) AND CODIGO = :TIPOCOBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FORMATO_FACTURA":"$FORMATO_FACTURA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipocobro/todosporcompaniatipocobro">
		<call-query href="getSftipocobroTodosPorCompaniaTipoCobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="getSftipocobroPagCodigoYNombrePorTipocobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SF_TIPO_COBRO.CODIGO, SF_TIPO_COBRO.NOMBRE  FROM SF_TIPO_COBRO WHERE SF_TIPO_COBRO.COMPANIA = :COMPANIA AND SF_TIPO_COBRO.CODIGO = :TIPOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
