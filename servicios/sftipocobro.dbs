	<query id="updateSftipocobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_TIPO_COBRO SET ANO=:ANO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, PERIODICIDAD=:PERIODICIDAD, CONCEPTODEUCAPITAL=:CONCEPTODEUCAPITAL, CONCEPTODEUINTERES=:CONCEPTODEUINTERES, CONCEPTOSANCION=:CONCEPTOSANCION, GENERADEUDA=:GENERADEUDA, MANEJAESTRATO=:MANEJAESTRATO, VENCIMIENTO_FACTURACION=:VENCIMIENTO_FACTURACION, DIAS_VALIDEZ=:DIAS_VALIDEZ, MANEJA_INVENTARIO=:MANEJA_INVENTARIO, CONSECUTIVO_FACTURACION=:CONSECUTIVO_FACTURACION, CPTE_RECAUDO=:CPTE_RECAUDO, TIPOCPTE_ANULACION=:TIPOCPTE_ANULACION, MANEJA_RESFACTURACION=:MANEJA_RESFACTURACION, NORES_FACTURACION=:NORES_FACTURACION, FECRES_FACTURACION=TO_DATE(:FECRES_FACTURACION,'DD/MM/YYYY HH24:MI:SS'), NOINICIAL_FACTURACION=:NOINICIAL_FACTURACION, NOFINAL_FACTURACION=:NOFINAL_FACTURACION, FORMATO_FACTURA=:FORMATO_FACTURA, LEYENDA_FACTURA=:LEYENDA_FACTURA, IND_DERECHOSCONEXION=:IND_DERECHOSCONEXION, INTERFAZ_RECAUDO=:INTERFAZ_RECAUDO, TIPOFACTURA_RECAUDO=:TIPOFACTURA_RECAUDO, TIPOCOBRO_NOFACTURADO=:TIPOCOBRO_NOFACTURADO, MANEJA_RECAUDOTERCEROS=:MANEJA_RECAUDOTERCEROS, CLASE_CUENTASRECAUDO=:CLASE_CUENTASRECAUDO, BASEORIGINAL=:BASEORIGINAL, LIQUIDACION=:LIQUIDACION, CODIGOEAN=:CODIGOEAN, NOAPLICACAUSACION=:NOAPLICACAUSACION, INICIAEN=:INICIAEN, BANCO_CUENTA1=:BANCO_CUENTA1, BANCO_CUENTA2=:BANCO_CUENTA2, BANCO_CUENTA3=:BANCO_CUENTA3, BANCO_CUENTA4=:BANCO_CUENTA4, INDPRELIQUIDACION=:INDPRELIQUIDACION, APLCUENTAREC=:APLCUENTAREC, MANEJATARIFABASE=:MANEJATARIFABASE, MANEJADESCRIP_EST=:MANEJADESCRIP_EST, CPTE_DIFERIDA=:CPTE_DIFERIDA, FORMATO_PLANTILLA=:FORMATO_PLANTILLA, MAN_ACUERDO_PRED=:MAN_ACUERDO_PRED, REF_FACTURACION=:REF_FACTURACION, CLAVETECNICA=:CLAVETECNICA, FECHA_FIN_RESOLUCION=TO_DATE(:FECHA_FIN_RESOLUCION,'DD/MM/YYYY HH24:MI:SS'), TIPO_MEDIOPAGO=:TIPO_MEDIOPAGO, TIPO_MONEDA=:TIPO_MONEDA, TIPOFACDIAN=:TIPOFACDIAN, FORMATO_FAC_ELECTRONICA=:FORMATO_FAC_ELECTRONICA, MANEJA_CARTERA=:MANEJA_CARTERA, MANEJA_INTERES_CARTERA=:MANEJA_INTERES_CARTERA, CPTE_CAUSACION_INTERES=:CPTE_CAUSACION_INTERES, TIPOCPTE_DEVOLUCION=:TIPOCPTE_DEVOLUCION, CONSECUTIVO_COBRO=:CONSECUTIVO_COBRO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_TIPO_COBRO.COMPANIA= :KEY_COMPANIA AND SF_TIPO_COBRO.ANO= :KEY_ANO AND SF_TIPO_COBRO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

