<data name="sstdetallematrizriesgos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSstdetallematrizriesgos" keyColumns="COMPANIA,VERSION,PROCESO,GRUPO,FACTOR_RIESGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_DETALLE_MATRIZ_RIESGOS (COMPANIA, VERSION, PROCESO, GRUPO, FACTOR_RIESGO, VALOR_TEXTO, VALOR_NUMERICO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :VERSION, :PROCESO, :GRUPO, :FACTOR_RIESGO, :VALOR_TEXTO, :VALOR_NUMERICO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_VERSION":"$VERSION","KEY_PROCESO":"$PROCESO","KEY_GRUPO":"$GRUPO","KEY_FACTOR_RIESGO":"$FACTOR_RIESGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_TEXTO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_NUMERICO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstdetallematrizriesgos">
		<call-query href="insertSstdetallematrizriesgos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>
			<with-param name="VALOR_TEXTO" query-param="VALOR_TEXTO"/>
			<with-param name="VALOR_NUMERICO" query-param="VALOR_NUMERICO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSstdetallematrizriesgos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_DETALLE_MATRIZ_RIESGOS WHERE SST_DETALLE_MATRIZ_RIESGOS.COMPANIA= :KEY_COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.VERSION= :KEY_VERSION AND SST_DETALLE_MATRIZ_RIESGOS.PROCESO= :KEY_PROCESO AND SST_DETALLE_MATRIZ_RIESGOS.GRUPO= :KEY_GRUPO AND SST_DETALLE_MATRIZ_RIESGOS.FACTOR_RIESGO= :KEY_FACTOR_RIESGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_PROCESO" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_FACTOR_RIESGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sstdetallematrizriesgos">
		<call-query href="deleteSstdetallematrizriesgos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_PROCESO" query-param="KEY_PROCESO"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_FACTOR_RIESGO" query-param="KEY_FACTOR_RIESGO"/>

		</call-query>
	</resource>
	<query id="getSstdetallematrizriesgosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_DETALLE_MATRIZ_RIESGOS.COMPANIA, SST_DETALLE_MATRIZ_RIESGOS.VERSION, SST_DETALLE_MATRIZ_RIESGOS.PROCESO, SST_PROCESOS.PROCESO NOMBRE_PROCESO, SST_PROCESOS.ZONA_LUGAR, SST_DETALLE_MATRIZ_RIESGOS.GRUPO, SST_GRUPO.NOMBRE, SST_DETALLE_MATRIZ_RIESGOS.FACTOR_RIESGO, SST_FACTOR.NOMBRE_FACTOR, SST_DETALLE_MATRIZ_RIESGOS.VALOR_TEXTO, SST_DETALLE_MATRIZ_RIESGOS.VALOR_NUMERICO  FROM SST_DETALLE_MATRIZ_RIESGOS LEFT JOIN SST_FACTOR ON SST_DETALLE_MATRIZ_RIESGOS.COMPANIA = SST_FACTOR.COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.GRUPO = SST_FACTOR.GRUPO AND SST_DETALLE_MATRIZ_RIESGOS.FACTOR_RIESGO = SST_FACTOR.CODIGO_FACTOR LEFT JOIN SST_GRUPO ON SST_GRUPO.COMPANIA = SST_FACTOR.COMPANIA AND SST_GRUPO.GRUPO = SST_FACTOR.GRUPO LEFT JOIN SST_PROCESOS ON SST_DETALLE_MATRIZ_RIESGOS.COMPANIA = SST_PROCESOS.COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.PROCESO = SST_PROCESOS.CODIGO WHERE SST_DETALLE_MATRIZ_RIESGOS.COMPANIA = :COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.VERSION = :VERSION) WHERE (CASE WHEN NOMBRE_PROCESO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROCESO) END)  LIKE UPPER( '%' || :NOMBRE_PROCESO || '%')  AND (CASE WHEN ZONA_LUGAR IS NULL THEN ' ' ELSE UPPER(ZONA_LUGAR) END)  LIKE UPPER( '%' || :ZONA_LUGAR || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRE_FACTOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_FACTOR) END)  LIKE UPPER( '%' || :NOMBRE_FACTOR || '%')  AND (CASE WHEN VALOR_TEXTO IS NULL THEN ' ' ELSE UPPER(VALOR_TEXTO) END)  LIKE UPPER( '%' || :VALOR_TEXTO || '%')  AND (CASE WHEN VALOR_NUMERICO IS NULL THEN ' ' ELSE UPPER(VALOR_NUMERICO) END)  LIKE UPPER(:VALOR_NUMERICO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VERSION":"$VERSION","PROCESO":"$PROCESO","NOMBRE_PROCESO":"$NOMBRE_PROCESO","ZONA_LUGAR":"$ZONA_LUGAR","GRUPO":"$GRUPO","NOMBRE":"$NOMBRE","FACTOR_RIESGO":"$FACTOR_RIESGO","NOMBRE_FACTOR":"$NOMBRE_FACTOR","VALOR_TEXTO":"$VALOR_TEXTO","VALOR_NUMERICO":"$VALOR_NUMERICO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="NOMBRE_PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_FACTOR" sqlType="STRING"/>
		<param name="VALOR_TEXTO" sqlType="STRING"/>
		<param name="VALOR_NUMERICO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstdetallematrizriesgos">
		<call-query href="getSstdetallematrizriesgosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="NOMBRE_PROCESO" query-param="NOMBRE_PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRE_FACTOR" query-param="NOMBRE_FACTOR"/>
			<with-param name="VALOR_TEXTO" query-param="VALOR_TEXTO"/>
			<with-param name="VALOR_NUMERICO" query-param="VALOR_NUMERICO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstdetallematrizriesgosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_DETALLE_MATRIZ_RIESGOS.COMPANIA, SST_DETALLE_MATRIZ_RIESGOS.VERSION, SST_DETALLE_MATRIZ_RIESGOS.PROCESO, SST_PROCESOS.PROCESO NOMBRE_PROCESO, SST_PROCESOS.ZONA_LUGAR, SST_DETALLE_MATRIZ_RIESGOS.GRUPO, SST_GRUPO.NOMBRE, SST_DETALLE_MATRIZ_RIESGOS.FACTOR_RIESGO, SST_FACTOR.NOMBRE_FACTOR, SST_DETALLE_MATRIZ_RIESGOS.VALOR_TEXTO, SST_DETALLE_MATRIZ_RIESGOS.VALOR_NUMERICO  FROM SST_DETALLE_MATRIZ_RIESGOS LEFT JOIN SST_FACTOR ON SST_DETALLE_MATRIZ_RIESGOS.COMPANIA = SST_FACTOR.COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.GRUPO = SST_FACTOR.GRUPO AND SST_DETALLE_MATRIZ_RIESGOS.FACTOR_RIESGO = SST_FACTOR.CODIGO_FACTOR LEFT JOIN SST_GRUPO ON SST_GRUPO.COMPANIA = SST_FACTOR.COMPANIA AND SST_GRUPO.GRUPO = SST_FACTOR.GRUPO LEFT JOIN SST_PROCESOS ON SST_DETALLE_MATRIZ_RIESGOS.COMPANIA = SST_PROCESOS.COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.PROCESO = SST_PROCESOS.CODIGO WHERE SST_DETALLE_MATRIZ_RIESGOS.COMPANIA = :COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.VERSION = :VERSION) WHERE (CASE WHEN NOMBRE_PROCESO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROCESO) END)  LIKE UPPER( '%' || :NOMBRE_PROCESO || '%')  AND (CASE WHEN ZONA_LUGAR IS NULL THEN ' ' ELSE UPPER(ZONA_LUGAR) END)  LIKE UPPER( '%' || :ZONA_LUGAR || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRE_FACTOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_FACTOR) END)  LIKE UPPER( '%' || :NOMBRE_FACTOR || '%')  AND (CASE WHEN VALOR_TEXTO IS NULL THEN ' ' ELSE UPPER(VALOR_TEXTO) END)  LIKE UPPER( '%' || :VALOR_TEXTO || '%')  AND (CASE WHEN VALOR_NUMERICO IS NULL THEN ' ' ELSE UPPER(VALOR_NUMERICO) END)  LIKE UPPER(:VALOR_NUMERICO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="NOMBRE_PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_FACTOR" sqlType="STRING"/>
		<param name="VALOR_TEXTO" sqlType="STRING"/>
		<param name="VALOR_NUMERICO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstdetallematrizriesgos/numero">
		<call-query href="getSstdetallematrizriesgosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="NOMBRE_PROCESO" query-param="NOMBRE_PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRE_FACTOR" query-param="NOMBRE_FACTOR"/>
			<with-param name="VALOR_TEXTO" query-param="VALOR_TEXTO"/>
			<with-param name="VALOR_NUMERICO" query-param="VALOR_NUMERICO"/>

		</call-query>
	</resource>
	<query id="updateSstdetallematrizriesgos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_DETALLE_MATRIZ_RIESGOS SET COMPANIA=:COMPANIA, VERSION=:VERSION, PROCESO=:PROCESO, GRUPO=:GRUPO, FACTOR_RIESGO=:FACTOR_RIESGO, VALOR_TEXTO=:VALOR_TEXTO, VALOR_NUMERICO=:VALOR_NUMERICO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_DETALLE_MATRIZ_RIESGOS.COMPANIA= :KEY_COMPANIA AND SST_DETALLE_MATRIZ_RIESGOS.VERSION= :KEY_VERSION AND SST_DETALLE_MATRIZ_RIESGOS.PROCESO= :KEY_PROCESO AND SST_DETALLE_MATRIZ_RIESGOS.GRUPO= :KEY_GRUPO AND SST_DETALLE_MATRIZ_RIESGOS.FACTOR_RIESGO= :KEY_FACTOR_RIESGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="FACTOR_RIESGO" sqlType="STRING"/>
		<param name="VALOR_TEXTO" sqlType="STRING"/>
		<param name="VALOR_NUMERICO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_PROCESO" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_FACTOR_RIESGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstdetallematrizriesgos">
		<call-query href="updateSstdetallematrizriesgos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="FACTOR_RIESGO" query-param="FACTOR_RIESGO"/>
			<with-param name="VALOR_TEXTO" query-param="VALOR_TEXTO"/>
			<with-param name="VALOR_NUMERICO" query-param="VALOR_NUMERICO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_PROCESO" query-param="KEY_PROCESO"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_FACTOR_RIESGO" query-param="KEY_FACTOR_RIESGO"/>

		</call-query>
	</resource>

</data>