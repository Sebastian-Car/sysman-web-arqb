			<with-param name="AFECTAPPTO" query-param="AFECTAPPTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTransaccionmodelo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TRANSACCIONMODELO WHERE TRANSACCIONMODELO.COMPANIA= :KEY_COMPANIA AND TRANSACCIONMODELO.ANO= :KEY_ANO AND TRANSACCIONMODELO.TIPO= :KEY_TIPO AND TRANSACCIONMODELO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="transaccionmodelo">
		<call-query href="deleteTransaccionmodelo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getTransaccionmodeloPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TRANSACCIONMODELO.COMPANIA, TRANSACCIONMODELO.ANO, TRANSACCIONMODELO.TIPO, TRANSACCIONMODELO.NUMERO, TRANSACCIONMODELO.DESCRIPCION, TIPOTRANSACCION.NOMBRE TIPONOMBRE  FROM TRANSACCIONMODELO INNER JOIN TIPOTRANSACCION ON TRANSACCIONMODELO.COMPANIA = TIPOTRANSACCION.COMPANIA AND TRANSACCIONMODELO.TIPO = TIPOTRANSACCION.CODIGO WHERE TRANSACCIONMODELO.COMPANIA = :COMPANIA ORDER BY TRANSACCIONMODELO.TIPO, TO_CHAR(TRANSACCIONMODELO.NUMERO)) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN TIPONOMBRE IS NULL THEN ' ' ELSE UPPER(TIPONOMBRE) END)  LIKE UPPER( '%' || :TIPONOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO","DESCRIPCION":"$DESCRIPCION","TIPONOMBRE":"$TIPONOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPONOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="transaccionmodelo">
		<call-query href="getTransaccionmodeloPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPONOMBRE" query-param="TIPONOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTransaccionmodeloNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TRANSACCIONMODELO.COMPANIA, TRANSACCIONMODELO.ANO, TRANSACCIONMODELO.TIPO, TRANSACCIONMODELO.NUMERO, TRANSACCIONMODELO.DESCRIPCION, TIPOTRANSACCION.NOMBRE TIPONOMBRE  FROM TRANSACCIONMODELO INNER JOIN TIPOTRANSACCION ON TRANSACCIONMODELO.COMPANIA = TIPOTRANSACCION.COMPANIA AND TRANSACCIONMODELO.TIPO = TIPOTRANSACCION.CODIGO WHERE TRANSACCIONMODELO.COMPANIA = :COMPANIA ORDER BY TRANSACCIONMODELO.TIPO, TO_CHAR(TRANSACCIONMODELO.NUMERO)) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN TIPONOMBRE IS NULL THEN ' ' ELSE UPPER(TIPONOMBRE) END)  LIKE UPPER( '%' || :TIPONOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPONOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transaccionmodelo/numero">
		<call-query href="getTransaccionmodeloNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPONOMBRE" query-param="TIPONOMBRE"/>

		</call-query>
	</resource>
	<query id="getTransaccionmodeloRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT TRANSACCIONMODELO.VLRIVAFACTURADO , TRANSACCIONMODELO.VLRCOMPROBANTE , TRANSACCIONMODELO.VLRBASEGRAVABLE , TRANSACCIONMODELO.VLRAGIRAR ,(CASE TRANSACCIONMODELO.TODOSLOSCENTROS WHEN 0 THEN 'false' ELSE 'true' END) TODOSLOSCENTROS, TRANSACCIONMODELO.TIPO , TRANSACCIONMODELO.TEXTO , TRANSACCIONMODELO.TERCERO , TRANSACCIONMODELO.SUCURSAL , TRANSACCIONMODELO.REFERENCIA ,(CASE TRANSACCIONMODELO.PIDEDOLARES WHEN 0 THEN 'false' ELSE 'true' END) PIDEDOLARES,(CASE TRANSACCIONMODELO.PIDEDOCASOCIADO WHEN 0 THEN 'false' ELSE 'true' END) PIDEDOCASOCIADO,(CASE TRANSACCIONMODELO.PIDECTABANCOS WHEN 0 THEN 'false' ELSE 'true' END) PIDECTABANCOS, TRANSACCIONMODELO.NUMERO ,(CASE TRANSACCIONMODELO.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, TRANSACCIONMODELO.FUENTE_RECURSO ,(TO_CHAR(TRANSACCIONMODELO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, TRANSACCIONMODELO.DESCRIPCION , TRANSACCIONMODELO.COMPANIA , TRANSACCIONMODELO.CLASE , TRANSACCIONMODELO.CENTRO_COSTO , TRANSACCIONMODELO.AUXILIAR , TRANSACCIONMODELO.ANO, TERCERO.NOMBRE NOMBRETERCERO, AUXILIAR.NOMBRE NOMBREAUXILIAR, CENTRO_COSTO.NOMBRE NOMBRECENTROCOSTO, FUENTE_RECURSOS.NOMBRE NOMBRERECURSO, REFERENCIA.NOMBRE NOMBREREFERENCIA, TRANSACCIONMODELO.TIPOGENERAR, TRANSACCIONMODELO.NUMEROGENERAR, TRANSACCIONMODELO.TIPO_GASTO, TRANSACCIONMODELO.MEDIO_PAGO, TRANSACCIONMODELO.CONCEPTO, TRANSACCIONMODELO.RESOLUCION, CENTRO_COSTO_TIPO.NOMBRE NOMBRETIPOGASTO, CONCEPTOSEX.NOMBRE NOMBRECONCEPTO, MEDIOS_DE_PAGO.NOMBRE NOMBREMEDIOPAGO,TRANSACCIONMODELO.TIPO_OPERACION,(CASE TRANSACCIONMODELO.AFECTAPPTO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAPPTO FROM TRANSACCIONMODELO LEFT JOIN TERCERO ON TRANSACCIONMODELO.COMPANIA = TERCERO.COMPANIA AND TRANSACCIONMODELO.TERCERO = TERCERO.NIT AND TRANSACCIONMODELO.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN AUXILIAR ON TRANSACCIONMODELO.COMPANIA = AUXILIAR.COMPANIA AND TRANSACCIONMODELO.ANO = AUXILIAR.ANO AND TRANSACCIONMODELO.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN CENTRO_COSTO ON TRANSACCIONMODELO.COMPANIA = CENTRO_COSTO.COMPANIA AND TRANSACCIONMODELO.ANO = CENTRO_COSTO.ANO AND TRANSACCIONMODELO.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN FUENTE_RECURSOS ON TRANSACCIONMODELO.COMPANIA = FUENTE_RECURSOS.COMPANIA AND TRANSACCIONMODELO.ANO = FUENTE_RECURSOS.ANO AND TRANSACCIONMODELO.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO LEFT JOIN REFERENCIA ON TRANSACCIONMODELO.COMPANIA = REFERENCIA.COMPANIA AND TRANSACCIONMODELO.ANO = REFERENCIA.ANO AND TRANSACCIONMODELO.REFERENCIA = REFERENCIA.CODIGO INNER JOIN TIPOTRANSACCION ON TRANSACCIONMODELO.COMPANIA = TIPOTRANSACCION.COMPANIA AND TRANSACCIONMODELO.TIPO = TIPOTRANSACCION.CODIGO LEFT JOIN CENTRO_COSTO_TIPO ON TRANSACCIONMODELO.TIPO_GASTO = CENTRO_COSTO_TIPO.CODIGO LEFT JOIN CONCEPTOSEX ON TRANSACCIONMODELO.CONCEPTO = CONCEPTOSEX.CODIGO LEFT JOIN MEDIOS_DE_PAGO ON TRANSACCIONMODELO.COMPANIA = MEDIOS_DE_PAGO.COMPANIA AND TRANSACCIONMODELO.MEDIO_PAGO = MEDIOS_DE_PAGO.CODIGO WHERE TRANSACCIONMODELO.COMPANIA= :KEY_COMPANIA AND TRANSACCIONMODELO.ANO= :KEY_ANO AND TRANSACCIONMODELO.TIPO= :KEY_TIPO AND TRANSACCIONMODELO.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLRIVAFACTURADO":"$VLRIVAFACTURADO","VLRCOMPROBANTE":"$VLRCOMPROBANTE","VLRBASEGRAVABLE":"$VLRBASEGRAVABLE","VLRAGIRAR":"$VLRAGIRAR","TODOSLOSCENTROS":"$TODOSLOSCENTROS(type:boolean)","TIPO":"$TIPO","TEXTO":"$TEXTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","REFERENCIA":"$REFERENCIA","PIDEDOLARES":"$PIDEDOLARES(type:boolean)","PIDEDOCASOCIADO":"$PIDEDOCASOCIADO(type:boolean)","PIDECTABANCOS":"$PIDECTABANCOS(type:boolean)","NUMERO":"$NUMERO","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","FUENTE_RECURSO":"$FUENTE_RECURSO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","COMPANIA":"$COMPANIA","CLASE":"$CLASE","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","ANO":"$ANO(type:integer)","NOMBRETERCERO":"$NOMBRETERCERO","NOMBREAUXILIAR":"$NOMBREAUXILIAR","NOMBRECENTROCOSTO":"$NOMBRECENTROCOSTO","NOMBRERECURSO":"$NOMBRERECURSO","NOMBREREFERENCIA":"$NOMBREREFERENCIA","TIPOGENERAR":"$TIPOGENERAR","NUMEROGENERAR":"$NUMEROGENERAR(type:long)","TIPO_GASTO":"$TIPO_GASTO","MEDIO_PAGO":"$MEDIO_PAGO","CONCEPTO":"$CONCEPTO","RESOLUCION":"$RESOLUCION","NOMBRETIPOGASTO":"$NOMBRETIPOGASTO","NOMBRECONCEPTO":"$NOMBRECONCEPTO","NOMBREMEDIOPAGO":"$NOMBREMEDIOPAGO","TIPO_OPERACION":"$TIPO_OPERACION","AFECTAPPTO":"$AFECTAPPTO(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="transaccionmodelo/data">
		<call-query href="getTransaccionmodeloRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateTransaccionmodelo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TRANSACCIONMODELO SET VLRIVAFACTURADO=:VLRIVAFACTURADO, VLRCOMPROBANTE=:VLRCOMPROBANTE, VLRBASEGRAVABLE=:VLRBASEGRAVABLE, VLRAGIRAR=:VLRAGIRAR, TODOSLOSCENTROS=:TODOSLOSCENTROS, TIPO=:TIPO, TEXTO=:TEXTO, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, REFERENCIA=:REFERENCIA, PIDEDOLARES=:PIDEDOLARES, PIDEDOCASOCIADO=:PIDEDOCASOCIADO, PIDECTABANCOS=:PIDECTABANCOS, NUMERO=:NUMERO, MOVIMIENTO=:MOVIMIENTO, FUENTE_RECURSO=:FUENTE_RECURSO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, COMPANIA=:COMPANIA, CLASE=:CLASE, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, ANO=:ANO, TIPOGENERAR=:TIPOGENERAR, NUMEROGENERAR=:NUMEROGENERAR, TIPO_GASTO=:TIPO_GASTO, MEDIO_PAGO=:MEDIO_PAGO, CONCEPTO=:CONCEPTO, RESOLUCION=:RESOLUCION, TIPO_OPERACION=:TIPO_OPERACION, AFECTAPPTO=:AFECTAPPTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TRANSACCIONMODELO.COMPANIA= :KEY_COMPANIA AND TRANSACCIONMODELO.ANO= :KEY_ANO AND TRANSACCIONMODELO.TIPO= :KEY_TIPO AND TRANSACCIONMODELO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VLRIVAFACTURADO" sqlType="STRING"/>
		<param name="VLRCOMPROBANTE" sqlType="STRING"/>
		<param name="VLRBASEGRAVABLE" sqlType="STRING"/>
		<param name="VLRAGIRAR" sqlType="STRING"/>
		<param name="TODOSLOSCENTROS" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
