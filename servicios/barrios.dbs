	<query id="getBarriosPagNombrePorPaisDepartamentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BARRIOS.CODIGO, BARRIOS.NOMBRE, BARRIOS.SECTOR, BARRIOS.CODIGOASOCIACION  FROM BARRIOS WHERE BARRIOS.PAIS = :PAIS AND BARRIOS.DEPARTAMENTO = :DEPARTAMENTO AND BARRIOS.CIUDAD = :CIUDAD ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END)  LIKE UPPER( '%' || :SECTOR || '%')  AND (CASE WHEN CODIGOASOCIACION IS NULL THEN ' ' ELSE UPPER(CODIGOASOCIACION) END)  LIKE UPPER( '%' || :CODIGOASOCIACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SECTOR":"$SECTOR","CODIGOASOCIACION":"$CODIGOASOCIACION"}]}}		</result>
		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
