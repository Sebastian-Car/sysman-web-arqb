		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BARRIOS.CODIGO, BARRIOS.NOMBRE, BARRIOS.SECTOR, BARRIOS.CODIGOASOCIACION  FROM BARRIOS WHERE BARRIOS.PAIS = :PAIS AND BARRIOS.DEPARTAMENTO = :DEPARTAMENTO AND BARRIOS.CIUDAD = :CIUDAD ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END)  LIKE UPPER( '%' || :SECTOR || '%')  AND (CASE WHEN CODIGOASOCIACION IS NULL THEN ' ' ELSE UPPER(CODIGOASOCIACION) END)  LIKE UPPER( '%' || :CODIGOASOCIACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
