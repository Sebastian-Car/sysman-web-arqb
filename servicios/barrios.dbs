	<query id="getBarriosTodosLosBarriosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'X' CODIGO, 'TODAS' NOMBRE  FROM BARRIOS UNION SELECT BARRIOS.CODIGO, BARRIOS.NOMBRE FROM BARRIOS WHERE BARRIOS.PAIS = :PAIS AND BARRIOS.DEPARTAMENTO = :DEPARTAMENTO AND BARRIOS.CIUDAD = :CIUDAD ORDER BY NOMBRE</sql>
