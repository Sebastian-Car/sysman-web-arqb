<data name="evdetalleevaluacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEvdetalleevaluacion" keyColumns="COMPANIA,NUMERO_EVALUACION,CLASE_EVALUACION,TIPO_EVALUACION,CEDULA_EVALUADO,SUCURSAL_EVALUADO,CEDULA_EVALUADOR,SUCURSAL_EVALUADOR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_DETALLE_EVALUACION (COMPANIA, NUMERO_EVALUACION, CARGO_EVALUADOR, CARGO_EVALUADO, CLASE_EVALUACION, FECHA, HORA, TIPO_EVALUACION, OBSERVACIONES, CODIGO_EMPLEADO_EVALUADO, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CODIGO_EMPLEADO_EVALUADOR, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, FECHA_CONCERTACION, EVALUADOR_COMISION, CREATED_BY, DATE_CREATED, ESCALAFON_EVALUADOR, ESCALAFON_EVALUADO, REG_DETALLE, AJUSTE, FECHA_AJUSTE, MOTIVO_AJUSTE) VALUES (:COMPANIA, :NUMERO_EVALUACION, :CARGO_EVALUADOR, :CARGO_EVALUADO, :CLASE_EVALUACION, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), :TIPO_EVALUACION, :OBSERVACIONES, :CODIGO_EMPLEADO_EVALUADO, :CEDULA_EVALUADO, :SUCURSAL_EVALUADO, :CODIGO_EMPLEADO_EVALUADOR, :CEDULA_EVALUADOR, :SUCURSAL_EVALUADOR, TO_DATE(:FECHA_CONCERTACION,'DD/MM/YYYY HH24:MI:SS'), :EVALUADOR_COMISION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :ESCALAFON_EVALUADOR, :ESCALAFON_EVALUADO, :REG_DETALLE, :AJUSTE, TO_DATE(:FECHA_AJUSTE,'DD/MM/YYYY HH24:MI:SS'), :MOTIVO_AJUSTE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","KEY_TIPO_EVALUACION":"$TIPO_EVALUACION","KEY_CEDULA_EVALUADO":"$CEDULA_EVALUADO","KEY_SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","KEY_CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","KEY_SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="CARGO_EVALUADOR" sqlType="STRING"/>
		<param name="CARGO_EVALUADO" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="CODIGO_EMPLEADO_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CODIGO_EMPLEADO_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CONCERTACION" sqlType="STRING"/>
		<param defaultValue="" name="EVALUADOR_COMISION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="ESCALAFON_EVALUADOR" sqlType="STRING"/>
		<param name="ESCALAFON_EVALUADO" sqlType="STRING"/>
		<param defaultValue="0" name="REG_DETALLE" sqlType="STRING"/>
		<param defaultValue="0" name="AJUSTE" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_AJUSTE" sqlType="STRING"/>
		<param defaultValue="" name="MOTIVO_AJUSTE" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evdetalleevaluacion">
		<call-query href="insertEvdetalleevaluacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
