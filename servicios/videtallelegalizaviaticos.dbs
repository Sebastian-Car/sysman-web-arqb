<data name="videtallelegalizaviaticos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVidetallelegalizaviaticosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_DETALLE_LEGALIZA_VIATICOS.COMPANIA, VI_DETALLE_LEGALIZA_VIATICOS.ANO, VI_DETALLE_LEGALIZA_VIATICOS.NUMERO, VI_DETALLE_LEGALIZA_VIATICOS.TIPO_VIATICO, VI_DETALLE_LEGALIZA_VIATICOS.TERCERO, VI_DETALLE_LEGALIZA_VIATICOS.SUCURSAL, VI_DETALLE_LEGALIZA_VIATICOS.NUMERO_AFECTADO, VI_DETALLE_LEGALIZA_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE NOMBRECONCEPTO, VI_DETALLE_LEGALIZA_VIATICOS.VALOR, VI_DETALLE_LEGALIZA_VIATICOS.VALOR_AFECTADO, VI_DETALLE_LEGALIZA_VIATICOS.SALDO, VI_DETALLE_LEGALIZA_VIATICOS.DESCRIPCION  FROM VI_DETALLE_LEGALIZA_VIATICOS INNER JOIN VI_CONCEPTO_VIATICOS ON VI_DETALLE_LEGALIZA_VIATICOS.COMPANIA = VI_CONCEPTO_VIATICOS.COMPANIA AND VI_DETALLE_LEGALIZA_VIATICOS.ANO = VI_CONCEPTO_VIATICOS.ANO AND VI_DETALLE_LEGALIZA_VIATICOS.CODIGO_CONCEPTO = VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO WHERE VI_DETALLE_LEGALIZA_VIATICOS.COMPANIA = :COMPANIA AND VI_DETALLE_LEGALIZA_VIATICOS.ANO = :ANO AND VI_DETALLE_LEGALIZA_VIATICOS.NUMERO = :NUMERO AND VI_DETALLE_LEGALIZA_VIATICOS.TERCERO = :TERCERO AND VI_DETALLE_LEGALIZA_VIATICOS.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN NUMERO_AFECTADO IS NULL THEN ' ' ELSE UPPER(NUMERO_AFECTADO) END)  LIKE UPPER(:NUMERO_AFECTADO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN VALOR_AFECTADO IS NULL THEN ' ' ELSE UPPER(VALOR_AFECTADO) END)  LIKE UPPER(:VALOR_AFECTADO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER(:SALDO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","TIPO_VIATICO":"$TIPO_VIATICO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","NUMERO_AFECTADO":"$NUMERO_AFECTADO(type:long)","CODIGO_CONCEPTO":"$CODIGO_CONCEPTO","NOMBRECONCEPTO":"$NOMBRECONCEPTO","VALOR":"$VALOR","VALOR_AFECTADO":"$VALOR_AFECTADO","SALDO":"$SALDO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_AFECTADO" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_AFECTADO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="videtallelegalizaviaticos">
		<call-query href="getVidetallelegalizaviaticosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_AFECTADO" query-param="NUMERO_AFECTADO"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_AFECTADO" query-param="VALOR_AFECTADO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVidetallelegalizaviaticosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_DETALLE_LEGALIZA_VIATICOS.COMPANIA, VI_DETALLE_LEGALIZA_VIATICOS.ANO, VI_DETALLE_LEGALIZA_VIATICOS.NUMERO, VI_DETALLE_LEGALIZA_VIATICOS.TIPO_VIATICO, VI_DETALLE_LEGALIZA_VIATICOS.TERCERO, VI_DETALLE_LEGALIZA_VIATICOS.SUCURSAL, VI_DETALLE_LEGALIZA_VIATICOS.NUMERO_AFECTADO, VI_DETALLE_LEGALIZA_VIATICOS.CODIGO_CONCEPTO, VI_CONCEPTO_VIATICOS.NOMBRE NOMBRECONCEPTO, VI_DETALLE_LEGALIZA_VIATICOS.VALOR, VI_DETALLE_LEGALIZA_VIATICOS.VALOR_AFECTADO, VI_DETALLE_LEGALIZA_VIATICOS.SALDO, VI_DETALLE_LEGALIZA_VIATICOS.DESCRIPCION  FROM VI_DETALLE_LEGALIZA_VIATICOS INNER JOIN VI_CONCEPTO_VIATICOS ON VI_DETALLE_LEGALIZA_VIATICOS.COMPANIA = VI_CONCEPTO_VIATICOS.COMPANIA AND VI_DETALLE_LEGALIZA_VIATICOS.ANO = VI_CONCEPTO_VIATICOS.ANO AND VI_DETALLE_LEGALIZA_VIATICOS.CODIGO_CONCEPTO = VI_CONCEPTO_VIATICOS.CODIGO_CONCEPTO WHERE VI_DETALLE_LEGALIZA_VIATICOS.COMPANIA = :COMPANIA AND VI_DETALLE_LEGALIZA_VIATICOS.ANO = :ANO AND VI_DETALLE_LEGALIZA_VIATICOS.NUMERO = :NUMERO AND VI_DETALLE_LEGALIZA_VIATICOS.TERCERO = :TERCERO AND VI_DETALLE_LEGALIZA_VIATICOS.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN NUMERO_AFECTADO IS NULL THEN ' ' ELSE UPPER(NUMERO_AFECTADO) END)  LIKE UPPER(:NUMERO_AFECTADO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN VALOR_AFECTADO IS NULL THEN ' ' ELSE UPPER(VALOR_AFECTADO) END)  LIKE UPPER(:VALOR_AFECTADO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER(:SALDO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_AFECTADO" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_AFECTADO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtallelegalizaviaticos/numero">
		<call-query href="getVidetallelegalizaviaticosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_AFECTADO" query-param="NUMERO_AFECTADO"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_AFECTADO" query-param="VALOR_AFECTADO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateVidetallelegalizaviaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_DETALLE_LEGALIZA_VIATICOS SET NUMERO_AFECTADO=:NUMERO_AFECTADO, CODIGO_CONCEPTO=:CODIGO_CONCEPTO, VALOR=:VALOR, VALOR_AFECTADO=:VALOR_AFECTADO, SALDO=:SALDO, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VI_DETALLE_LEGALIZA_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_DETALLE_LEGALIZA_VIATICOS.ANO= :KEY_ANO AND VI_DETALLE_LEGALIZA_VIATICOS.NUMERO= :KEY_NUMERO AND VI_DETALLE_LEGALIZA_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_DETALLE_LEGALIZA_VIATICOS.TERCERO= :KEY_TERCERO AND VI_DETALLE_LEGALIZA_VIATICOS.SUCURSAL= :KEY_SUCURSAL AND VI_DETALLE_LEGALIZA_VIATICOS.CODIGO_CONCEPTO= :KEY_CODIGO_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO_AFECTADO" sqlType="STRING"/>
		<param name="CODIGO_CONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_AFECTADO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CODIGO_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="videtallelegalizaviaticos">
		<call-query href="updateVidetallelegalizaviaticos">
			<with-param name="NUMERO_AFECTADO" query-param="NUMERO_AFECTADO"/>
			<with-param name="CODIGO_CONCEPTO" query-param="CODIGO_CONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_AFECTADO" query-param="VALOR_AFECTADO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPO_VIATICO" query-param="KEY_TIPO_VIATICO"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CODIGO_CONCEPTO" query-param="KEY_CODIGO_CONCEPTO"/>

		</call-query>
	</resource>

</data>