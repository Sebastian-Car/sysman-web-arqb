<data name="tipoplanillasoi" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoplanillasoiTipoplanillasoiQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, CONCAT(CODIGO,CONCAT(' - ',NOMBRE) ) NOMBRE FROM TIPO_PLANILLA_SOI WHERE COMPANIA =:COMPANIA AND TIPO =:TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoplanillasoi/tipoplanillasoi">
		<call-query href="getTipoplanillasoiTipoplanillasoiQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>

</data>