<data name="detallepagoespecial" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDetallepagoespecialPagTodosporpagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D.COMPANIA,D.CODIGOPAGOESP,D.CONSECUTIVO,D.DESCRIPCION,D.CATEGORIAREF,D.CATEGORIAESCALAFONREF,D.DIAS,D.VALOR,D.ANO ,C.NOMBRE_CATEGORIA ,D.ANORANGOPRIMAANUAL FROM DETALLEPAGOESPECIAL D INNER JOIN CATEGORIA C ON D.COMPANIA = C.COMPANIA AND D.CATEGORIAESCALAFONREF = C.ESCALAFON AND D.CATEGORIAREF = C.ID_DE_CATEGORIA AND D.ANO = C.ANO WHERE D.COMPANIA = :COMPANIA AND D.CODIGOPAGOESP = :CODPAGO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGOPAGOESP IS NULL THEN ' ' ELSE UPPER(CODIGOPAGOESP) END) LIKE UPPER(CONCAT(:CODIGOPAGOESP, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CATEGORIAREF IS NULL THEN ' ' ELSE UPPER(CATEGORIAREF) END) LIKE UPPER(CONCAT(CONCAT('%',:CATEGORIAREF), '%')) AND (CASE WHEN CATEGORIAESCALAFONREF IS NULL THEN ' ' ELSE UPPER(CATEGORIAESCALAFONREF) END) LIKE UPPER(CONCAT(CONCAT('%',:CATEGORIAESCALAFONREF), '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(:DIAS, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CATEGORIA), '%')) AND (CASE WHEN ANORANGOPRIMAANUAL IS NULL THEN ' ' ELSE UPPER(ANORANGOPRIMAANUAL) END) LIKE UPPER(CONCAT(:ANORANGOPRIMAANUAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOPAGOESP":"$CODIGOPAGOESP(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","DESCRIPCION":"$DESCRIPCION","CATEGORIAREF":"$CATEGORIAREF","CATEGORIAESCALAFONREF":"$CATEGORIAESCALAFONREF","DIAS":"$DIAS","VALOR":"$VALOR","ANO":"$ANO(type:integer)","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","ANORANGOPRIMAANUAL":"$ANORANGOPRIMAANUAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODPAGO" sqlType="STRING"/>
		<param name="CODIGOPAGOESP" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CATEGORIAREF" sqlType="STRING"/>
		<param name="CATEGORIAESCALAFONREF" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="ANORANGOPRIMAANUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallepagoespecial/todosporpago/pag">
		<call-query href="getDetallepagoespecialPagTodosporpagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODPAGO" query-param="CODPAGO"/>
			<with-param name="CODIGOPAGOESP" query-param="CODIGOPAGOESP"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CATEGORIAREF" query-param="CATEGORIAREF"/>
			<with-param name="CATEGORIAESCALAFONREF" query-param="CATEGORIAESCALAFONREF"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="ANORANGOPRIMAANUAL" query-param="ANORANGOPRIMAANUAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetallepagoespecialNumTodosporpagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT D.COMPANIA,D.CODIGOPAGOESP,D.CONSECUTIVO,D.DESCRIPCION,D.CATEGORIAREF,D.CATEGORIAESCALAFONREF,D.DIAS,D.VALOR,D.ANO ,C.NOMBRE_CATEGORIA ,D.ANORANGOPRIMAANUAL FROM DETALLEPAGOESPECIAL D INNER JOIN CATEGORIA C ON D.COMPANIA = C.COMPANIA AND D.CATEGORIAESCALAFONREF = C.ESCALAFON AND D.CATEGORIAREF = C.ID_DE_CATEGORIA AND D.ANO = C.ANO WHERE D.COMPANIA = :COMPANIA AND D.CODIGOPAGOESP = :CODPAGO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGOPAGOESP IS NULL THEN ' ' ELSE UPPER(CODIGOPAGOESP) END) LIKE UPPER(CONCAT(:CODIGOPAGOESP, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CATEGORIAREF IS NULL THEN ' ' ELSE UPPER(CATEGORIAREF) END) LIKE UPPER(CONCAT(CONCAT('%',:CATEGORIAREF), '%')) AND (CASE WHEN CATEGORIAESCALAFONREF IS NULL THEN ' ' ELSE UPPER(CATEGORIAESCALAFONREF) END) LIKE UPPER(CONCAT(CONCAT('%',:CATEGORIAESCALAFONREF), '%')) AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END) LIKE UPPER(CONCAT(:DIAS, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NOMBRE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_CATEGORIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CATEGORIA), '%')) AND (CASE WHEN ANORANGOPRIMAANUAL IS NULL THEN ' ' ELSE UPPER(ANORANGOPRIMAANUAL) END) LIKE UPPER(CONCAT(:ANORANGOPRIMAANUAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODPAGO" sqlType="STRING"/>
		<param name="CODIGOPAGOESP" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CATEGORIAREF" sqlType="STRING"/>
		<param name="CATEGORIAESCALAFONREF" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE_CATEGORIA" sqlType="STRING"/>
		<param name="ANORANGOPRIMAANUAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallepagoespecial/todosporpago/num">
		<call-query href="getDetallepagoespecialNumTodosporpagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODPAGO" query-param="CODPAGO"/>
			<with-param name="CODIGOPAGOESP" query-param="CODIGOPAGOESP"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CATEGORIAREF" query-param="CATEGORIAREF"/>
			<with-param name="CATEGORIAESCALAFONREF" query-param="CATEGORIAESCALAFONREF"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRE_CATEGORIA" query-param="NOMBRE_CATEGORIA"/>
			<with-param name="ANORANGOPRIMAANUAL" query-param="ANORANGOPRIMAANUAL"/>

		</call-query>
	</resource>
	<query id="insertDetallepagoespecialDetalle" keyColumns="COMPANIA,CODIGOPAGOESP,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLEPAGOESPECIAL (COMPANIA, CODIGOPAGOESP, CONSECUTIVO, DESCRIPCION, CATEGORIAREF, CATEGORIAESCALAFONREF, DIAS, VALOR, ANO, ANORANGOPRIMAANUAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGOPAGOESP, :CONSECUTIVO, :DESCRIPCION, :CATEGORIAREF, :CATEGORIAESCALAFONREF, :DIAS, :VALOR, :ANO, :ANORANGOPRIMAANUAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOPAGOESP":"$CODIGOPAGOESP(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPAGOESP" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="CATEGORIAREF" sqlType="STRING"/>
		<param defaultValue="" name="CATEGORIAESCALAFONREF" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="0" name="ANORANGOPRIMAANUAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detallepagoespecial/detalle">
		<call-query href="insertDetallepagoespecialDetalle">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPAGOESP" query-param="CODIGOPAGOESP"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CATEGORIAREF" query-param="CATEGORIAREF"/>
			<with-param name="CATEGORIAESCALAFONREF" query-param="CATEGORIAESCALAFONREF"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ANORANGOPRIMAANUAL" query-param="ANORANGOPRIMAANUAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDetallepagoespecialDetalle" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DETALLEPAGOESPECIAL WHERE COMPANIA = :KEY_COMPANIA AND CODIGOPAGOESP = :KEY_CODIGOPAGOESP AND CONSECUTIVO = :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPAGOESP" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="detallepagoespecial/detalle">
		<call-query href="deleteDetallepagoespecialDetalle">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPAGOESP" query-param="KEY_CODIGOPAGOESP"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateDetallepagoespecialDetalle" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLEPAGOESPECIAL SET DESCRIPCION=:DESCRIPCION, CATEGORIAREF=:CATEGORIAREF, CATEGORIAESCALAFONREF=:CATEGORIAESCALAFONREF, DIAS=:DIAS, VALOR=:VALOR, ANO=:ANO, ANORANGOPRIMAANUAL=:ANORANGOPRIMAANUAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLEPAGOESPECIAL.COMPANIA= :KEY_COMPANIA AND DETALLEPAGOESPECIAL.CODIGOPAGOESP= :KEY_CODIGOPAGOESP AND DETALLEPAGOESPECIAL.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CATEGORIAREF" sqlType="STRING"/>
		<param name="CATEGORIAESCALAFONREF" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ANORANGOPRIMAANUAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOPAGOESP" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallepagoespecial/detalle">
		<call-query href="updateDetallepagoespecialDetalle">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CATEGORIAREF" query-param="CATEGORIAREF"/>
			<with-param name="CATEGORIAESCALAFONREF" query-param="CATEGORIAESCALAFONREF"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ANORANGOPRIMAANUAL" query-param="ANORANGOPRIMAANUAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOPAGOESP" query-param="KEY_CODIGOPAGOESP"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDetallepagoespecialPagPorpagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONSECUTIVO,DESCRIPCION,ANO FROM DETALLEPAGOESPECIAL WHERE COMPANIA = :COMPANIA AND CODIGOPAGOESP = :PAGO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO(type:integer)","DESCRIPCION":"$DESCRIPCION","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallepagoespecial/porpago/pag">
		<call-query href="getDetallepagoespecialPagPorpagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetallepagoespecialNumPorpagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONSECUTIVO,DESCRIPCION,ANO FROM DETALLEPAGOESPECIAL WHERE COMPANIA = :COMPANIA AND CODIGOPAGOESP = :PAGO) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallepagoespecial/porpago/num">
		<call-query href="getDetallepagoespecialNumPorpagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>

</data>