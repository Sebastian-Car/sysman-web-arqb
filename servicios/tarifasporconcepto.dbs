<data name="tarifasporconcepto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTarifasporconceptoTarifaporlistaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_CONCEPTOS.CODIGO, TARIFAS_POR_CONCEPTO.VALOR, TARIFAS_POR_CONCEPTO.NUMEROLISTA FROM TARIFAS_POR_CONCEPTO INNER JOIN SF_CONCEPTOS ON TARIFAS_POR_CONCEPTO.COMPANIA=SF_CONCEPTOS.COMPANIA AND TARIFAS_POR_CONCEPTO.ANO=SF_CONCEPTOS.ANO AND TARIFAS_POR_CONCEPTO.CONCEPTO=SF_CONCEPTOS.CODIGO WHERE SF_CONCEPTOS.COMPANIA = :COMPANIA AND CODIGO = :CONCEPTO AND NUMEROLISTA = :NUMEROLISTA AND TO_DATE(:FECHA, 'DD/MM/YYYY') BETWEEN TARIFAS_POR_CONCEPTO.FECHAINICIAL AND TARIFAS_POR_CONCEPTO.FECHAFINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","VALOR":"$VALOR","NUMEROLISTA":"$NUMEROLISTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NUMEROLISTA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tarifasporconcepto/tarifaporlista">
		<call-query href="getTarifasporconceptoTarifaporlistaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NUMEROLISTA" query-param="NUMEROLISTA"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getTarifasporconceptoGetlistatarifasxconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT ANO, CONCEPTO, NUMEROLISTA, VALOR,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL FROM TARIFAS_POR_CONCEPTO WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","CONCEPTO":"$CONCEPTO","NUMEROLISTA":"$NUMEROLISTA","VALOR":"$VALOR","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tarifasporconcepto/getlistatarifasxconcepto">
		<call-query href="getTarifasporconceptoGetlistatarifasxconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertTarifasporconcepto" keyColumns="COMPANIA,ANO,CONCEPTO,NUMEROLISTA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TARIFAS_POR_CONCEPTO (COMPANIA, ANO, CONCEPTO, NUMEROLISTA, VALOR, FECHAINICIAL, FECHAFINAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CONCEPTO, :NUMEROLISTA, :VALOR, :FECHAINICIAL, :FECHAFINAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CONCEPTO":"$CONCEPTO","KEY_NUMEROLISTA":"$NUMEROLISTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NUMEROLISTA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINICIAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHAFINAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tarifasporconcepto">
		<call-query href="insertTarifasporconcepto">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NUMEROLISTA" query-param="NUMEROLISTA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTarifasporconcepto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TARIFAS_POR_CONCEPTO WHERE TARIFAS_POR_CONCEPTO.COMPANIA= :KEY_COMPANIA AND TARIFAS_POR_CONCEPTO.ANO= :KEY_ANO AND TARIFAS_POR_CONCEPTO.CONCEPTO= :KEY_CONCEPTO AND TARIFAS_POR_CONCEPTO.NUMEROLISTA= :KEY_NUMEROLISTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_NUMEROLISTA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tarifasporconcepto">
		<call-query href="deleteTarifasporconcepto">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_NUMEROLISTA" query-param="KEY_NUMEROLISTA"/>

		</call-query>
	</resource>
	<query id="getTarifasporconceptoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, CONCEPTO, NUMEROLISTA, VALOR,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL FROM TARIFAS_POR_CONCEPTO WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN NUMEROLISTA IS NULL THEN ' ' ELSE UPPER(NUMEROLISTA) END) LIKE UPPER(CONCAT(:NUMEROLISTA, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONCEPTO":"$CONCEPTO","NUMEROLISTA":"$NUMEROLISTA","VALOR":"$VALOR","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NUMEROLISTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tarifasporconcepto">
		<call-query href="getTarifasporconceptoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NUMEROLISTA" query-param="NUMEROLISTA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTarifasporconceptoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, CONCEPTO, NUMEROLISTA, VALOR,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL FROM TARIFAS_POR_CONCEPTO WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN NUMEROLISTA IS NULL THEN ' ' ELSE UPPER(NUMEROLISTA) END) LIKE UPPER(CONCAT(:NUMEROLISTA, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NUMEROLISTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tarifasporconcepto/numero">
		<call-query href="getTarifasporconceptoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NUMEROLISTA" query-param="NUMEROLISTA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>

		</call-query>
	</resource>
	<query id="getTarifasporconceptoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT TARIFAS_POR_CONCEPTO.COMPANIA, TARIFAS_POR_CONCEPTO.ANO, TARIFAS_POR_CONCEPTO.CONCEPTO, TARIFAS_POR_CONCEPTO.NUMEROLISTA, TARIFAS_POR_CONCEPTO.VALOR, TARIFAS_POR_CONCEPTO.FECHAINICIAL, TARIFAS_POR_CONCEPTO.FECHAFINAL, TARIFAS_POR_CONCEPTO.CREATED_BY, TARIFAS_POR_CONCEPTO.MODIFIED_BY,(TO_CHAR(TARIFAS_POR_CONCEPTO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(TARIFAS_POR_CONCEPTO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM TARIFAS_POR_CONCEPTO WHERE TARIFAS_POR_CONCEPTO.COMPANIA= :KEY_COMPANIA AND TARIFAS_POR_CONCEPTO.ANO= :KEY_ANO AND TARIFAS_POR_CONCEPTO.CONCEPTO= :KEY_CONCEPTO AND TARIFAS_POR_CONCEPTO.NUMEROLISTA= :KEY_NUMEROLISTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CONCEPTO":"$CONCEPTO","NUMEROLISTA":"$NUMEROLISTA","VALOR":"$VALOR","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_NUMEROLISTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tarifasporconcepto/data">
		<call-query href="getTarifasporconceptoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_NUMEROLISTA" query-param="KEY_NUMEROLISTA"/>

		</call-query>
	</resource>
	<query id="updateTarifasporconcepto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TARIFAS_POR_CONCEPTO SET COMPANIA=:COMPANIA, ANO=:ANO, CONCEPTO=:CONCEPTO, NUMEROLISTA=:NUMEROLISTA, VALOR=:VALOR, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE TARIFAS_POR_CONCEPTO.COMPANIA= :KEY_COMPANIA AND TARIFAS_POR_CONCEPTO.ANO= :KEY_ANO AND TARIFAS_POR_CONCEPTO.CONCEPTO= :KEY_CONCEPTO AND TARIFAS_POR_CONCEPTO.NUMEROLISTA= :KEY_NUMEROLISTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NUMEROLISTA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_NUMEROLISTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tarifasporconcepto">
		<call-query href="updateTarifasporconcepto">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NUMEROLISTA" query-param="NUMEROLISTA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_NUMEROLISTA" query-param="KEY_NUMEROLISTA"/>

		</call-query>
	</resource>

</data>