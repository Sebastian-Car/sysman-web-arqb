<data name="esrubrosestdis" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEsrubrosestdis" keyColumns="COMPANIA,COD_ESTUDIO,ANO,TIPO_CPTE,COMPROBANTE,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_RUBROS_EST_DIS (COMPANIA, COD_ESTUDIO, ANO, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CODIGO_CUENTA, AUXILIAR, DEBITO, CREDITO, CENTRO_COSTO, DESTINO, FECHA_DIS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_ESTUDIO, :ANO, :TIPO_CPTE, :COMPROBANTE, :CONSECUTIVO, :CODIGO_CUENTA, :AUXILIAR, :DEBITO, :CREDITO, :CENTRO_COSTO, :DESTINO, TO_DATE(:FECHA_DIS,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO","KEY_ANO":"$ANO(type:integer)","KEY_TIPO_CPTE":"$TIPO_CPTE","KEY_COMPROBANTE":"$COMPROBANTE","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_CUENTA" sqlType="STRING"/>
		<param defaultValue="9999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="0" name="DEBITO" sqlType="STRING"/>
		<param defaultValue="0" name="CREDITO" sqlType="STRING"/>
		<param defaultValue="9999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="" name="DESTINO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_DIS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esrubrosestdis">
		<call-query href="insertEsrubrosestdis">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO_CUENTA" query-param="CODIGO_CUENTA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="DEBITO" query-param="DEBITO"/>
			<with-param name="CREDITO" query-param="CREDITO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="DESTINO" query-param="DESTINO"/>
			<with-param name="FECHA_DIS" query-param="FECHA_DIS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsrubrosestdis" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_RUBROS_EST_DIS WHERE ES_RUBROS_EST_DIS.COMPANIA= :KEY_COMPANIA AND ES_RUBROS_EST_DIS.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_RUBROS_EST_DIS.ANO= :KEY_ANO AND ES_RUBROS_EST_DIS.TIPO_CPTE= :KEY_TIPO_CPTE AND ES_RUBROS_EST_DIS.COMPROBANTE= :KEY_COMPROBANTE AND ES_RUBROS_EST_DIS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_CPTE" sqlType="STRING"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="esrubrosestdis">
		<call-query href="deleteEsrubrosestdis">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_CPTE" query-param="KEY_TIPO_CPTE"/>
			<with-param name="KEY_COMPROBANTE" query-param="KEY_COMPROBANTE"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEsrubrosestdisPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  RUBROS.COMPANIA, RUBROS.COD_ESTUDIO, RUBROS.ANO, RUBROS.TIPO_CPTE, RUBROS.COMPROBANTE, RUBROS.CONSECUTIVO, RUBROS.CODIGO_CUENTA, RUBROS.AUXILIAR, RUBROS.DEBITO, RUBROS.CREDITO, RUBROS.CENTRO_COSTO, RUBROS.DESTINO,(TO_CHAR(RUBROS.FECHA_DIS,'DD/MM/YYYY HH24:MI:SS')) FECHA_DIS, AUXILIAR.NOMBRE NOMBREAUX  FROM ES_RUBROS_EST_DIS RUBROS LEFT JOIN AUXILIAR ON RUBROS.COMPANIA = AUXILIAR.COMPANIA AND RUBROS.ANO = AUXILIAR.ANO AND RUBROS.AUXILIAR = AUXILIAR.CODIGO WHERE RUBROS.COMPANIA = :COMPANIA AND RUBROS.COD_ESTUDIO = :CODIGO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END)  LIKE UPPER( '%' || :TIPO_CPTE || '%')  AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END)  LIKE UPPER(:COMPROBANTE || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CODIGO_CUENTA IS NULL THEN ' ' ELSE UPPER(CODIGO_CUENTA) END)  LIKE UPPER(:CODIGO_CUENTA || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN DEBITO IS NULL THEN ' ' ELSE UPPER(DEBITO) END)  LIKE UPPER(:DEBITO || '%')  AND (CASE WHEN CREDITO IS NULL THEN ' ' ELSE UPPER(CREDITO) END)  LIKE UPPER(:CREDITO || '%')  AND (CASE WHEN NOMBREAUX IS NULL THEN ' ' ELSE UPPER(NOMBREAUX) END)  LIKE UPPER( '%' || :NOMBREAUX || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO","ANO":"$ANO(type:integer)","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CODIGO_CUENTA":"$CODIGO_CUENTA","AUXILIAR":"$AUXILIAR","DEBITO":"$DEBITO","CREDITO":"$CREDITO","CENTRO_COSTO":"$CENTRO_COSTO","DESTINO":"$DESTINO","FECHA_DIS":"$FECHA_DIS","NOMBREAUX":"$NOMBREAUX"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO_CUENTA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="DEBITO" sqlType="STRING"/>
		<param name="CREDITO" sqlType="STRING"/>
		<param name="NOMBREAUX" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esrubrosestdis">
		<call-query href="getEsrubrosestdisPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO_CUENTA" query-param="CODIGO_CUENTA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="DEBITO" query-param="DEBITO"/>
			<with-param name="CREDITO" query-param="CREDITO"/>
			<with-param name="NOMBREAUX" query-param="NOMBREAUX"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsrubrosestdisNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  RUBROS.COMPANIA, RUBROS.COD_ESTUDIO, RUBROS.ANO, RUBROS.TIPO_CPTE, RUBROS.COMPROBANTE, RUBROS.CONSECUTIVO, RUBROS.CODIGO_CUENTA, RUBROS.AUXILIAR, RUBROS.DEBITO, RUBROS.CREDITO, RUBROS.CENTRO_COSTO, RUBROS.DESTINO,(TO_CHAR(RUBROS.FECHA_DIS,'DD/MM/YYYY HH24:MI:SS')) FECHA_DIS, AUXILIAR.NOMBRE NOMBREAUX  FROM ES_RUBROS_EST_DIS RUBROS LEFT JOIN AUXILIAR ON RUBROS.COMPANIA = AUXILIAR.COMPANIA AND RUBROS.ANO = AUXILIAR.ANO AND RUBROS.AUXILIAR = AUXILIAR.CODIGO WHERE RUBROS.COMPANIA = :COMPANIA AND RUBROS.COD_ESTUDIO = :CODIGO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END)  LIKE UPPER( '%' || :TIPO_CPTE || '%')  AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END)  LIKE UPPER(:COMPROBANTE || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CODIGO_CUENTA IS NULL THEN ' ' ELSE UPPER(CODIGO_CUENTA) END)  LIKE UPPER(:CODIGO_CUENTA || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN DEBITO IS NULL THEN ' ' ELSE UPPER(DEBITO) END)  LIKE UPPER(:DEBITO || '%')  AND (CASE WHEN CREDITO IS NULL THEN ' ' ELSE UPPER(CREDITO) END)  LIKE UPPER(:CREDITO || '%')  AND (CASE WHEN NOMBREAUX IS NULL THEN ' ' ELSE UPPER(NOMBREAUX) END)  LIKE UPPER( '%' || :NOMBREAUX || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO_CUENTA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="DEBITO" sqlType="STRING"/>
		<param name="CREDITO" sqlType="STRING"/>
		<param name="NOMBREAUX" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esrubrosestdis/numero">
		<call-query href="getEsrubrosestdisNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO_CUENTA" query-param="CODIGO_CUENTA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="DEBITO" query-param="DEBITO"/>
			<with-param name="CREDITO" query-param="CREDITO"/>
			<with-param name="NOMBREAUX" query-param="NOMBREAUX"/>

		</call-query>
	</resource>
	<query id="updateEsrubrosestdis" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_RUBROS_EST_DIS SET ANO=:ANO, TIPO_CPTE=:TIPO_CPTE, COMPROBANTE=:COMPROBANTE, CONSECUTIVO=:CONSECUTIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_RUBROS_EST_DIS.COMPANIA= :KEY_COMPANIA AND ES_RUBROS_EST_DIS.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_RUBROS_EST_DIS.ANO= :KEY_ANO AND ES_RUBROS_EST_DIS.TIPO_CPTE= :KEY_TIPO_CPTE AND ES_RUBROS_EST_DIS.COMPROBANTE= :KEY_COMPROBANTE AND ES_RUBROS_EST_DIS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_CPTE" sqlType="STRING"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esrubrosestdis">
		<call-query href="updateEsrubrosestdis">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CPTE" query-param="TIPO_CPTE"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_CPTE" query-param="KEY_TIPO_CPTE"/>
			<with-param name="KEY_COMPROBANTE" query-param="KEY_COMPROBANTE"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>