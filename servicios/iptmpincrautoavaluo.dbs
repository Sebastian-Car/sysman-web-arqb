<data name="iptmpincrautoavaluo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIptmpincrautoavaluoPagPrediosconautoavaluoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_TMP_INCR_AUTOAVALUO.COMPANIA, IP_TMP_INCR_AUTOAVALUO.CODIGO, IP_TMP_INCR_AUTOAVALUO.ANO, IP_TMP_INCR_AUTOAVALUO.AUTOAVAL,(CASE IP_TMP_INCR_AUTOAVALUO.INCRE_AUTOAVALUO WHEN 0 THEN 'false' ELSE 'true' END) INCRE_AUTOAVALUO, IP_TMP_INCR_AUTOAVALUO.NUMERO_ORDEN, IP_TMP_INCR_AUTOAVALUO.AVALUO, IP_TMP_INCR_AUTOAVALUO.AVALUO_ANT, IP_TMP_INCR_AUTOAVALUO.NUM_RADICACION  FROM IP_TMP_INCR_AUTOAVALUO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN AUTOAVAL IS NULL THEN ' ' ELSE UPPER(AUTOAVAL) END)  LIKE UPPER(:AUTOAVAL || '%')  AND (CASE WHEN INCRE_AUTOAVALUO IS NULL THEN ' ' ELSE UPPER(INCRE_AUTOAVALUO) END)  LIKE UPPER(:INCRE_AUTOAVALUO || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER(:AVALUO || '%')  AND (CASE WHEN AVALUO_ANT IS NULL THEN ' ' ELSE UPPER(AVALUO_ANT) END)  LIKE UPPER(:AVALUO_ANT || '%')  AND (CASE WHEN NUM_RADICACION IS NULL THEN ' ' ELSE UPPER(NUM_RADICACION) END)  LIKE UPPER(:NUM_RADICACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","AUTOAVAL":"$AUTOAVAL","INCRE_AUTOAVALUO":"$INCRE_AUTOAVALUO(type:boolean)","NUMERO_ORDEN":"$NUMERO_ORDEN","AVALUO":"$AVALUO","AVALUO_ANT":"$AVALUO_ANT","NUM_RADICACION":"$NUM_RADICACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="AUTOAVAL" sqlType="STRING"/>
		<param name="INCRE_AUTOAVALUO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="AVALUO_ANT" sqlType="STRING"/>
		<param name="NUM_RADICACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="iptmpincrautoavaluo/prediosconautoavaluo/pag">
		<call-query href="getIptmpincrautoavaluoPagPrediosconautoavaluoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="AUTOAVAL" query-param="AUTOAVAL"/>
			<with-param name="INCRE_AUTOAVALUO" query-param="INCRE_AUTOAVALUO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="AVALUO_ANT" query-param="AVALUO_ANT"/>
			<with-param name="NUM_RADICACION" query-param="NUM_RADICACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIptmpincrautoavaluoNumPrediosconautoavaluoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_TMP_INCR_AUTOAVALUO.COMPANIA, IP_TMP_INCR_AUTOAVALUO.CODIGO, IP_TMP_INCR_AUTOAVALUO.ANO, IP_TMP_INCR_AUTOAVALUO.AUTOAVAL,(CASE IP_TMP_INCR_AUTOAVALUO.INCRE_AUTOAVALUO WHEN 0 THEN 'false' ELSE 'true' END) INCRE_AUTOAVALUO, IP_TMP_INCR_AUTOAVALUO.NUMERO_ORDEN, IP_TMP_INCR_AUTOAVALUO.AVALUO, IP_TMP_INCR_AUTOAVALUO.AVALUO_ANT, IP_TMP_INCR_AUTOAVALUO.NUM_RADICACION  FROM IP_TMP_INCR_AUTOAVALUO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN AUTOAVAL IS NULL THEN ' ' ELSE UPPER(AUTOAVAL) END)  LIKE UPPER( '%' || :AUTOAVAL || '%')  AND (CASE WHEN INCRE_AUTOAVALUO IS NULL THEN ' ' ELSE UPPER(INCRE_AUTOAVALUO) END)  LIKE UPPER( '%' || :INCRE_AUTOAVALUO || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN AVALUO_ANT IS NULL THEN ' ' ELSE UPPER(AVALUO_ANT) END)  LIKE UPPER( '%' || :AVALUO_ANT || '%')  AND (CASE WHEN NUM_RADICACION IS NULL THEN ' ' ELSE UPPER(NUM_RADICACION) END)  LIKE UPPER( '%' || :NUM_RADICACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="AUTOAVAL" sqlType="STRING"/>
		<param name="INCRE_AUTOAVALUO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="AVALUO_ANT" sqlType="STRING"/>
		<param name="NUM_RADICACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="iptmpincrautoavaluo/prediosconautoavaluo/num">
		<call-query href="getIptmpincrautoavaluoNumPrediosconautoavaluoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="AUTOAVAL" query-param="AUTOAVAL"/>
			<with-param name="INCRE_AUTOAVALUO" query-param="INCRE_AUTOAVALUO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="AVALUO_ANT" query-param="AVALUO_ANT"/>
			<with-param name="NUM_RADICACION" query-param="NUM_RADICACION"/>

		</call-query>
	</resource>
	<query id="updateIptmpincrautoavaluoModifincautoaval" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_TMP_INCR_AUTOAVALUO SET INCRE_AUTOAVALUO=:INCRE_AUTOAVALUO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_TMP_INCR_AUTOAVALUO.COMPANIA= :KEY_COMPANIA AND IP_TMP_INCR_AUTOAVALUO.CODIGO= :KEY_CODIGO AND IP_TMP_INCR_AUTOAVALUO.NUMERO_ORDEN= :KEY_NUMERO_ORDEN AND IP_TMP_INCR_AUTOAVALUO.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="INCRE_AUTOAVALUO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="iptmpincrautoavaluo/modifincautoaval">
		<call-query href="updateIptmpincrautoavaluoModifincautoaval">
			<with-param name="INCRE_AUTOAVALUO" query-param="INCRE_AUTOAVALUO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_NUMERO_ORDEN" query-param="KEY_NUMERO_ORDEN"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>

</data>