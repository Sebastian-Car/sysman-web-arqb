<data name="tiponovedades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTiponovedadesTodosPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TIPO_NOVEDADES.TIPO_NOVEDAD, TIPO_NOVEDADES.NOMBRE_NOVEDAD  FROM TIPO_NOVEDADES WHERE TIPO_NOVEDADES.COMPANIA = :COMPANIA ORDER BY TIPO_NOVEDADES.NOMBRE_NOVEDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_NOVEDAD":"$TIPO_NOVEDAD","NOMBRE_NOVEDAD":"$NOMBRE_NOVEDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiponovedades/todosportipo">
		<call-query href="getTiponovedadesTodosPorTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>