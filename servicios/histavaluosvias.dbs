<data name="histavaluosvias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getHistavaluosviasMaxanoPorIdviaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(ANO) MAX_ANO  FROM HIST_AVALUO_VIA WHERE COMPANIA=:COMPANIA AND ID_VIA =:ID_VIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MAX_ANO":"$MAX_ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="histavaluosvias/maxanoporidvia">
		<call-query href="getHistavaluosviasMaxanoPorIdviaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>

		</call-query>
	</resource>
	<query id="updateHistavaluosviasVidautilPorIdviaAnio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE HIST_AVALUO_VIA SET VIDA_UTIL   = :VIDA_UTIL,   MODIFIED_BY   = :MODIFIED_BY,   DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPANIA  = :COMPANIA AND ID_VIA      = :ID_VIA AND ANO         = :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VIDA_UTIL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="histavaluosvias/vidautilporidviaanio">
		<call-query href="updateHistavaluosviasVidautilPorIdviaAnio">
			<with-param name="VIDA_UTIL" query-param="VIDA_UTIL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertHistavaluosvias" keyColumns="COMPANIA,ID_VIA,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO HIST_AVALUO_VIA (COMPANIA, ID_VIA, ANO, AREA_TERRENO, VAL_UNITARIO, VAL_TERRENO, VAL_OBRA, VIDA_UTIL, FECHA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_VIA, :ANO, :AREA_TERRENO, :VAL_UNITARIO, :VAL_TERRENO, :VAL_OBRA, :VIDA_UTIL, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_VIA":"$ID_VIA","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_TERRENO" sqlType="STRING"/>
		<param defaultValue="0" name="VAL_UNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="VAL_TERRENO" sqlType="STRING"/>
		<param defaultValue="0" name="VAL_OBRA" sqlType="STRING"/>
		<param defaultValue="0" name="VIDA_UTIL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="histavaluosvias">
		<call-query href="insertHistavaluosvias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="AREA_TERRENO" query-param="AREA_TERRENO"/>
			<with-param name="VAL_UNITARIO" query-param="VAL_UNITARIO"/>
			<with-param name="VAL_TERRENO" query-param="VAL_TERRENO"/>
			<with-param name="VAL_OBRA" query-param="VAL_OBRA"/>
			<with-param name="VIDA_UTIL" query-param="VIDA_UTIL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteHistavaluosvias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM HIST_AVALUO_VIA WHERE HIST_AVALUO_VIA.COMPANIA= :KEY_COMPANIA AND HIST_AVALUO_VIA.ID_VIA= :KEY_ID_VIA AND HIST_AVALUO_VIA.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_VIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="histavaluosvias">
		<call-query href="deleteHistavaluosvias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_VIA" query-param="KEY_ID_VIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getHistavaluosviasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_VIA, ANO, AREA_TERRENO, VAL_UNITARIO, VAL_TERRENO, VAL_OBRA, VIDA_UTIL, (NVL(VAL_TERRENO,0)+NVL(VAL_OBRA,0)) VALOR_TOTAL,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM HIST_AVALUO_VIA WHERE COMPANIA = :COMPANIA AND ID_VIA = :ID_VIA ORDER BY ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_VIA":"$ID_VIA","ANO":"$ANO(type:integer)","AREA_TERRENO":"$AREA_TERRENO","VAL_UNITARIO":"$VAL_UNITARIO","VAL_TERRENO":"$VAL_TERRENO","VAL_OBRA":"$VAL_OBRA","VIDA_UTIL":"$VIDA_UTIL","VALOR_TOTAL":"$VALOR_TOTAL","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="histavaluosvias">
		<call-query href="getHistavaluosviasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>

		</call-query>
	</resource>
	<query id="updateHistavaluosvias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE HIST_AVALUO_VIA SET ANO=:ANO, AREA_TERRENO=:AREA_TERRENO, VAL_UNITARIO=:VAL_UNITARIO, VAL_TERRENO=:VAL_TERRENO, VAL_OBRA=:VAL_OBRA, VIDA_UTIL=:VIDA_UTIL, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE HIST_AVALUO_VIA.COMPANIA= :KEY_COMPANIA AND HIST_AVALUO_VIA.ID_VIA= :KEY_ID_VIA AND HIST_AVALUO_VIA.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="AREA_TERRENO" sqlType="STRING"/>
		<param name="VAL_UNITARIO" sqlType="STRING"/>
		<param name="VAL_TERRENO" sqlType="STRING"/>
		<param name="VAL_OBRA" sqlType="STRING"/>
		<param name="VIDA_UTIL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_VIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="histavaluosvias">
		<call-query href="updateHistavaluosvias">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="AREA_TERRENO" query-param="AREA_TERRENO"/>
			<with-param name="VAL_UNITARIO" query-param="VAL_UNITARIO"/>
			<with-param name="VAL_TERRENO" query-param="VAL_TERRENO"/>
			<with-param name="VAL_OBRA" query-param="VAL_OBRA"/>
			<with-param name="VIDA_UTIL" query-param="VIDA_UTIL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_VIA" query-param="KEY_ID_VIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>

</data>