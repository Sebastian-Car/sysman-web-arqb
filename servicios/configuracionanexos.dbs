<data name="configuracionanexos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConfiguracionanexosPagConfigurarAnexosEmpleadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NIVEL_AGRUPAMIENTO.COMPANIA, NIVEL_AGRUPAMIENTO.MODULO, NIVEL_AGRUPAMIENTO.CODIGO, NIVEL_AGRUPAMIENTO.NOMBRE,(CASE NIVEL_AGRUPAMIENTO.ES_ARCHIVO WHEN 0 THEN 'false' ELSE 'true' END) ES_ARCHIVO, CONFIGURACION_ANEXOS.RUTA FROM NIVEL_AGRUPAMIENTO INNER JOIN CONFIGURACION_ANEXOS ON NIVEL_AGRUPAMIENTO.COMPANIA = CONFIGURACION_ANEXOS.COMPANIA AND NIVEL_AGRUPAMIENTO.MODULO = CONFIGURACION_ANEXOS.MODULO AND NIVEL_AGRUPAMIENTO.CODIGO = CONFIGURACION_ANEXOS.NIVEL_AGRUPAMIENTO WHERE NIVEL_AGRUPAMIENTO.COMPANIA =:COMPANIA AND NIVEL_AGRUPAMIENTO.MODULO =:MODULO AND CONFIGURACION_ANEXOS.CODIGO =:REFERENCIA ORDER BY TO_NUMBER(NIVEL_AGRUPAMIENTO.CODIGO)) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ES_ARCHIVO IS NULL THEN ' ' ELSE UPPER(ES_ARCHIVO) END) LIKE UPPER(CONCAT(:ES_ARCHIVO, '%')) AND (CASE WHEN RUTA IS NULL THEN ' ' ELSE UPPER(RUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:RUTA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","MODULO":"$MODULO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ES_ARCHIVO":"$ES_ARCHIVO(type:boolean)","RUTA":"$RUTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ES_ARCHIVO" sqlType="STRING"/>
		<param name="RUTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="configuracionanexos/configuraranexosempleados/pag">
		<call-query href="getConfiguracionanexosPagConfigurarAnexosEmpleadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ES_ARCHIVO" query-param="ES_ARCHIVO"/>
			<with-param name="RUTA" query-param="RUTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConfiguracionanexosNumConfigurarAnexosEmpleadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NIVEL_AGRUPAMIENTO.COMPANIA, NIVEL_AGRUPAMIENTO.MODULO, NIVEL_AGRUPAMIENTO.CODIGO, NIVEL_AGRUPAMIENTO.NOMBRE,(CASE NIVEL_AGRUPAMIENTO.ES_ARCHIVO WHEN 0 THEN 'false' ELSE 'true' END) ES_ARCHIVO, CONFIGURACION_ANEXOS.RUTA FROM NIVEL_AGRUPAMIENTO INNER JOIN CONFIGURACION_ANEXOS ON NIVEL_AGRUPAMIENTO.COMPANIA = CONFIGURACION_ANEXOS.COMPANIA AND NIVEL_AGRUPAMIENTO.MODULO = CONFIGURACION_ANEXOS.MODULO AND NIVEL_AGRUPAMIENTO.CODIGO = CONFIGURACION_ANEXOS.NIVEL_AGRUPAMIENTO WHERE NIVEL_AGRUPAMIENTO.COMPANIA =:COMPANIA AND NIVEL_AGRUPAMIENTO.MODULO =:MODULO AND CONFIGURACION_ANEXOS.CODIGO =:REFERENCIA ORDER BY TO_NUMBER(NIVEL_AGRUPAMIENTO.CODIGO)) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ES_ARCHIVO IS NULL THEN ' ' ELSE UPPER(ES_ARCHIVO) END) LIKE UPPER(CONCAT(:ES_ARCHIVO, '%')) AND (CASE WHEN RUTA IS NULL THEN ' ' ELSE UPPER(RUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:RUTA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ES_ARCHIVO" sqlType="STRING"/>
		<param name="RUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionanexos/configuraranexosempleados/num">
		<call-query href="getConfiguracionanexosNumConfigurarAnexosEmpleadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ES_ARCHIVO" query-param="ES_ARCHIVO"/>
			<with-param name="RUTA" query-param="RUTA"/>

		</call-query>
	</resource>
	<query id="updateConfiguracionanexosRutaAnexosEmpleados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONFIGURACION_ANEXOS SET RUTA=:RUTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONFIGURACION_ANEXOS.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_ANEXOS.MODULO= :KEY_MODULO AND CONFIGURACION_ANEXOS.NIVEL_AGRUPAMIENTO= :KEY_NIVEL_AGRUPAMIENTO AND CONFIGURACION_ANEXOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="RUTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODULO" sqlType="STRING"/>
		<param name="KEY_NIVEL_AGRUPAMIENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="configuracionanexos/rutaanexosempleados">
		<call-query href="updateConfiguracionanexosRutaAnexosEmpleados">
			<with-param name="RUTA" query-param="RUTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MODULO" query-param="KEY_MODULO"/>
			<with-param name="KEY_NIVEL_AGRUPAMIENTO" query-param="KEY_NIVEL_AGRUPAMIENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="insertConfiguracionanexosCrearJerarquia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONFIGURACION_ANEXOS ( COMPANIA, MODULO, NIVEL_AGRUPAMIENTO, CODIGO, CREATED_BY, DATE_CREATED ) SELECT COMPANIA, MODULO, CODIGO, :CODIGO, CREATED_BY, SYSDATE FROM NIVEL_AGRUPAMIENTO WHERE COMPANIA = :COMPANIA AND CODIGO NOT IN ( SELECT NIVEL_AGRUPAMIENTO FROM CONFIGURACION_ANEXOS WHERE COMPANIA = :COMPANIA AND CODIGO =:CODIGO )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="POST" path="configuracionanexos/crearjerarquia">
		<call-query href="insertConfiguracionanexosCrearJerarquia">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertConfiguracionanexos" keyColumns="COMPANIA,MODULO,NIVEL_AGRUPAMIENTO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONFIGURACION_ANEXOS (COMPANIA, MODULO, NIVEL_AGRUPAMIENTO, CODIGO, RUTA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :MODULO, :NIVEL_AGRUPAMIENTO, :CODIGO, :RUTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_MODULO":"$MODULO(type:integer)","KEY_NIVEL_AGRUPAMIENTO":"$NIVEL_AGRUPAMIENTO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="NIVEL_AGRUPAMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="configuracionanexos">
		<call-query href="insertConfiguracionanexos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="NIVEL_AGRUPAMIENTO" query-param="NIVEL_AGRUPAMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="RUTA" query-param="RUTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConfiguracionanexos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONFIGURACION_ANEXOS WHERE CONFIGURACION_ANEXOS.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_ANEXOS.MODULO= :KEY_MODULO AND CONFIGURACION_ANEXOS.NIVEL_AGRUPAMIENTO= :KEY_NIVEL_AGRUPAMIENTO AND CONFIGURACION_ANEXOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODULO" sqlType="INTEGER"/>
		<param name="KEY_NIVEL_AGRUPAMIENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="configuracionanexos">
		<call-query href="deleteConfiguracionanexos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MODULO" query-param="KEY_MODULO"/>
			<with-param name="KEY_NIVEL_AGRUPAMIENTO" query-param="KEY_NIVEL_AGRUPAMIENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateConfiguracionanexos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONFIGURACION_ANEXOS SET NIVEL_AGRUPAMIENTO=:NIVEL_AGRUPAMIENTO, CODIGO=:CODIGO, RUTA=:RUTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONFIGURACION_ANEXOS.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_ANEXOS.MODULO= :KEY_MODULO AND CONFIGURACION_ANEXOS.NIVEL_AGRUPAMIENTO= :KEY_NIVEL_AGRUPAMIENTO AND CONFIGURACION_ANEXOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NIVEL_AGRUPAMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="RUTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODULO" sqlType="STRING"/>
		<param name="KEY_NIVEL_AGRUPAMIENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="configuracionanexos">
		<call-query href="updateConfiguracionanexos">
			<with-param name="NIVEL_AGRUPAMIENTO" query-param="NIVEL_AGRUPAMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="RUTA" query-param="RUTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MODULO" query-param="KEY_MODULO"/>
			<with-param name="KEY_NIVEL_AGRUPAMIENTO" query-param="KEY_NIVEL_AGRUPAMIENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

	<query id="getConfiguracionanexosCargarutaimagenQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONFIGURACION_ANEXOS.COMPANIA, CONFIGURACION_ANEXOS.MODULO, CONFIGURACION_ANEXOS.NIVEL_AGRUPAMIENTO, CONFIGURACION_ANEXOS.CODIGO, CONFIGURACION_ANEXOS.RUTA FROM CONFIGURACION_ANEXOS WHERE CONFIGURACION_ANEXOS.COMPANIA = :COMPANIA AND CONFIGURACION_ANEXOS.MODULO = :MODULO AND CONFIGURACION_ANEXOS.NIVEL_AGRUPAMIENTO = :NIVEL_AGRUPAMIENTO AND CONFIGURACION_ANEXOS.CODIGO = :CODIGO ORDER BY CONFIGURACION_ANEXOS.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","MODULO":"$MODULO(type:integer)","NIVEL_AGRUPAMIENTO":"$NIVEL_AGRUPAMIENTO","CODIGO":"$CODIGO","RUTA":"$RUTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="NIVEL_AGRUPAMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionanexos/cargarutaimagen">
		<call-query href="getConfiguracionanexosCargarutaimagenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="NIVEL_AGRUPAMIENTO" query-param="NIVEL_AGRUPAMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>

</data>