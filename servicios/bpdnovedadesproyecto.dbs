	<query id="getBpdnovedadesproyectoPagBpdnovedadesproyecporanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO CODIGODETALLE, PROYECTO, VALORAPROBADO, VALORPROGRAMADO, ACTIVIDAD, ( CASE SOLOCOMPONENTE WHEN -1 THEN 'SI' WHEN 0 THEN 'NO' END) AS SOLOCOMPONENTE  FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA=:COMPANIA AND SUBSTR(BP_D_NOVEDADPROYECTO.PROYECTO, 1, 4)=:ANO ORDER BY COMPANIA, TIPOT, CLASET, NOVEDAD) WHERE (CASE WHEN CODIGODETALLE IS NULL THEN ' ' ELSE UPPER(CODIGODETALLE) END)  LIKE UPPER(:CODIGODETALLE || '%')  AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END)  LIKE UPPER(:PROYECTO || '%')  AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END)  LIKE UPPER( '%' || :VALORAPROBADO || '%')  AND (CASE WHEN VALORPROGRAMADO IS NULL THEN ' ' ELSE UPPER(VALORPROGRAMADO) END)  LIKE UPPER( '%' || :VALORPROGRAMADO || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN SOLOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(SOLOCOMPONENTE) END)  LIKE UPPER( '%' || :SOLOCOMPONENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGODETALLE":"$CODIGODETALLE","PROYECTO":"$PROYECTO","VALORAPROBADO":"$VALORAPROBADO","VALORPROGRAMADO":"$VALORPROGRAMADO","ACTIVIDAD":"$ACTIVIDAD","SOLOCOMPONENTE":"$SOLOCOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGODETALLE" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>
		<param name="VALORPROGRAMADO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="SOLOCOMPONENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
