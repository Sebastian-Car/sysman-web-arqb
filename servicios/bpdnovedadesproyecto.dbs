			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="PROYINI" query-param="PROYINI"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="VIGENCIA_PLAN_INDICATIVO" query-param="VIGENCIA_PLAN_INDICATIVO"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoPagPorClaseYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.DEPENDENCIA, BP_D_NOVEDADPROYECTO.VIGENCIA_PLAN_INDICATIVO  FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.DEPENDENCIA IS NOT NULL AND BP_D_NOVEDADPROYECTO.CLASET = 'B' AND BP_D_NOVEDADPROYECTO.TIPOT = 'SVP' AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYECTO) WHERE (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END)  LIKE UPPER(:NOVEDAD || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN VIGENCIA_PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PLAN_INDICATIVO) END)  LIKE UPPER(:VIGENCIA_PLAN_INDICATIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOVEDAD":"$NOVEDAD(type:long)","DEPENDENCIA":"$DEPENDENCIA","VIGENCIA_PLAN_INDICATIVO":"$VIGENCIA_PLAN_INDICATIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
