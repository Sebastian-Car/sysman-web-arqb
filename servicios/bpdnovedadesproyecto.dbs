	<query id="updateBpdnovedadesproyectoSubnovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_D_NOVEDADPROYECTO SET CODIGO=:CODIGO, PROYECTO=:PROYECTO, COMPONENTE=:COMPONENTE, ACTIVIDAD=:ACTIVIDAD, ID_META_PRODUCTO=:ID_META_PRODUCTO, SECTOR=:SECTOR, PERIODO=:PERIODO, CANTIDAD_PLAN=:CANTIDAD_PLAN, FUENTERECURSOS=:FUENTERECURSOS, RUBROPRESUPUESTAL=:RUBROPRESUPUESTAL, VALORSOLICITADO=:VALORSOLICITADO, VALORAPROBADO=:VALORAPROBADO, VALORDISMINUIDO=:VALORDISMINUIDO, ESPECIFICACION=:ESPECIFICACION, BARRIO_L=:BARRIO_L, LOCALIZACION=:LOCALIZACION, SOLOCOMPONENTE=:SOLOCOMPONENTE, ACTUALIZADO_EN_PLAN=:ACTUALIZADO_EN_PLAN, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CANTIDAD=:CANTIDAD, TIPOT=:TIPOT, NOVEDAD=:NOVEDAD, DEPENDENCIA=:DEPENDENCIA, CLASET=:CLASET, TIPOCOMPONENTE=:TIPOCOMPONENTE, AUXILIAR=:AUXILIAR, REFERENCIA=:REFERENCIA, CENTRO_COSTO=:CENTRO_COSTO, SECTORRUBRO=:SECTORRUBRO, PROGRAMARUBRO=:PROGRAMARUBRO, SUBPROGRAMARUBRO=:SUBPROGRAMARUBRO, CODIGOPRODUCTO=:CODIGOPRODUCTO, CODIGOBPIN=:CODIGOBPIN, CODIGOCCPET=:CODIGOCCPET, CODIGOCPCDANE=:CODIGOCPCDANE, CODIGOUNIDADEJECUTORA=:CODIGOUNIDADEJECUTORA, CODIGOFUENTE=:CODIGOFUENTE, CODIGOCCPETREGALIAS=:CODIGOCCPETREGALIAS, CODIGOCPCCUIPO=:CODIGOCPCCUIPO, FUENTECUIPO=:FUENTECUIPO, PRODUCTOCUIPO=:PRODUCTOCUIPO, CODIGOBPIMCUIPO=:CODIGOBPIMCUIPO, CODIGOCCPETCUIPO=:CODIGOCCPETCUIPO, CODIGODETALLESECTORIAL=:CODIGODETALLESECTORIAL WHERE BP_D_NOVEDADPROYECTO.COMPANIA= :KEY_COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT= :KEY_TIPOT AND BP_D_NOVEDADPROYECTO.CLASET= :KEY_CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD= :KEY_NOVEDAD AND BP_D_NOVEDADPROYECTO.DEPENDENCIA= :KEY_DEPENDENCIA AND BP_D_NOVEDADPROYECTO.CODIGO= :KEY_CODIGO AND BP_D_NOVEDADPROYECTO.PROYECTO= :KEY_PROYECTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

