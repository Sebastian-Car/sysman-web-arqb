	<query id="getBpdnovedadesproyectoSumatoriaValorsolicitadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(BP_D_NOVEDADPROYECTO.VALORSOLICITADO) SVALORSOLICITADO FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA =:COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT =:TIPO AND BP_D_NOVEDADPROYECTO.CLASET =:CLASE AND BP_D_NOVEDADPROYECTO.NOVEDAD =:NOVEDAD AND BP_D_NOVEDADPROYECTO.DEPENDENCIA =:DEPENDENCIA AND BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL =:RUBRO AND BP_D_NOVEDADPROYECTO.FUENTERECURSOS =:FUENTE_RECURSO AND BP_D_NOVEDADPROYECTO.CENTRO_COSTO =:CENTRO_COSTO AND BP_D_NOVEDADPROYECTO.REFERENCIA =:REFERENCIA AND BP_D_NOVEDADPROYECTO.AUXILIAR =:AUXILIAR GROUP BY BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL, BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.TIPOT, BP_D_NOVEDADPROYECTO.CLASET, BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SVALORSOLICITADO":"$SVALORSOLICITADO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
