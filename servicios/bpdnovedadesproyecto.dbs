	<query id="getBpdnovedadesproyectoPagCoddescporsectorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  S.CODIGO, S.DESCRIPCION  FROM BP_D_NOVEDADPROYECTO BP INNER JOIN SECTORES S ON BP.COMPANIA = S.COMPANIA AND BP.SECTOR = S.CODIGO WHERE BP.COMPANIA = :COMPANIA AND BP.TIPOT = :TIPOT AND BP.PROYECTO = :PROYECTO AND BP.NOVEDAD = :SOLICITUD AND BP.ACTIVIDAD = :ACTIVIDAD) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="SOLICITUD" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
