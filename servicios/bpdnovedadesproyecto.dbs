	<query id="deleteBpdnovedadesproyecto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA= :KEY_COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT= :KEY_TIPOT AND BP_D_NOVEDADPROYECTO.CLASET= :KEY_CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD= :KEY_NOVEDAD AND BP_D_NOVEDADPROYECTO.DEPENDENCIA= :KEY_DEPENDENCIA AND BP_D_NOVEDADPROYECTO.CODIGO= :KEY_CODIGO AND BP_D_NOVEDADPROYECTO.PROYECTO= :KEY_PROYECTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOT" sqlType="STRING"/>
		<param name="KEY_CLASET" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpdnovedadesproyecto">
