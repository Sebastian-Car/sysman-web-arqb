	</resource>
	<query id="getBpdnovedadesproyectoPorNovedadYClaseSvpQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.TIPOT, BP_D_NOVEDADPROYECTO.CLASET, BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.PROYECTO, BP_ACTIVIDADES.CODIGO, BP_ACTIVIDADES.NOMBRE, COMPONENTES_ACTIVIDADES.COSTOTOTAL VALORTOTAL, BP_D_NOVEDADPROYECTO.VALORSOLICITADO  FROM BP_D_NOVEDADPROYECTO INNER JOIN COMPONENTES_ACTIVIDADES ON BP_D_NOVEDADPROYECTO.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD INNER JOIN BP_ACTIVIDADES ON COMPONENTES_ACTIVIDADES.COMPANIA = BP_ACTIVIDADES.COMPANIA AND COMPONENTES_ACTIVIDADES.ACTIVIDAD = BP_ACTIVIDADES.CODIGO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = 'SVP' AND BP_D_NOVEDADPROYECTO.CLASET = 'B' AND BP_D_NOVEDADPROYECTO.NOVEDAD = :NOVEDAD GROUP BY BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.TIPOT, BP_D_NOVEDADPROYECTO.CLASET, BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.PROYECTO, BP_ACTIVIDADES.CODIGO, BP_ACTIVIDADES.NOMBRE, COMPONENTES_ACTIVIDADES.COSTOTOTAL, BP_D_NOVEDADPROYECTO.VALORSOLICITADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","NOVEDAD":"$NOVEDAD(type:long)","PROYECTO":"$PROYECTO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VALORTOTAL":"$VALORTOTAL","VALORSOLICITADO":"$VALORSOLICITADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>

	</query>
