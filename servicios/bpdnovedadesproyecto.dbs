	</resource>
	<query id="getBpdnovedadesproyectoCantidadSubnovedadPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM (NVL(BP_D_NOVEDADPROYECTO.CANTIDAD,0)) CANT  FROM BP_D_NOVEDADPROYECTO INNER JOIN BPTIPONOVEDAD ON BP_D_NOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA AND BP_D_NOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET AND BP_D_NOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = BPNOVEDADPROYECTO.DEPENDENCIA WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = :TIPO AND BP_D_NOVEDADPROYECTO.CLASET ='B' AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = :COMPONENTE AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = :ACTIVIDAD AND BPTIPONOVEDAD.AFECTAPROGRAMACION NOT IN (0) AND BPTIPONOVEDAD.CLASENOVEDAD ='S' AND BPNOVEDADPROYECTO.ESTADO NOT IN ('A','N')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANT":"$CANT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/cantidadsubnovedadportipo">
		<call-query href="getBpdnovedadesproyectoCantidadSubnovedadPorTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>

