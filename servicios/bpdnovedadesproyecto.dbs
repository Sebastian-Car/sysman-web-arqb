	<query id="getBpdnovedadesproyectoCertificadoProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION NOMBREMETAPRODUCTO, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, NVL(CANTIDAD_EJECUTADA,0) CANTIDAD_EJECUTADA1, NVL(NOMBRE,'Sin unidad de medida') NOMBRE_MEDIDA, NVL(META_BRUTA,0) META_BRUTA_AUX, SUM(NVL(BP_D_NOVEDADPROYECTO.CANTIDAD,0)) CANTIDAD_AUX, BP_D_NOVEDADPROYECTO.COMPONENTE  FROM BP_D_NOVEDADPROYECTO INNER JOIN BP_PLAN_INDICATIVO ON BP_D_NOVEDADPROYECTO.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = BP_PLAN_INDICATIVO.ID LEFT JOIN BP_PLAN_INDICATIVO_METAS ON BP_PLAN_INDICATIVO.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA AND BP_PLAN_INDICATIVO.ID = BP_PLAN_INDICATIVO_METAS.ID_PLAN AND BP_PLAN_INDICATIVO.VIGENCIA_INICIAL = BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN LEFT JOIN UNIDADPROYECTOS ON BP_PLAN_INDICATIVO.COMPANIA = UNIDADPROYECTOS.COMPANIA AND BP_PLAN_INDICATIVO.UNIDAD_MEDIDA = UNIDADPROYECTOS.UNIDAD WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.CLASET = 'B' AND BP_D_NOVEDADPROYECTO.TIPOT = 'SVP' AND BP_D_NOVEDADPROYECTO.NOVEDAD = :NOVEDAD AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYECTO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','')),VIGENCIA_META,1) &gt;0 GROUP BY BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.PROYECTO, BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION, BP_PLAN_INDICATIVO_METAS.VIGENCIA_META, CANTIDAD_EJECUTADA, NOMBRE, META_BRUTA, BP_D_NOVEDADPROYECTO.COMPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_META_PRODUCTO":"$ID_META_PRODUCTO","NOMBREMETAPRODUCTO":"$NOMBREMETAPRODUCTO","VIGENCIA_META":"$VIGENCIA_META(type:integer)","CANTIDAD_EJECUTADA1":"$CANTIDAD_EJECUTADA1(type:integer)","NOMBRE_MEDIDA":"$NOMBRE_MEDIDA","META_BRUTA_AUX":"$META_BRUTA_AUX(type:integer)","CANTIDAD_AUX":"$CANTIDAD_AUX(type:integer)","COMPONENTE":"$COMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
