	<query id="getBpdnovedadesproyectoNumListaSubnovedadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BP_D_NOVEDADPROYECTO.COMPANIA, DEPENDENCIA, NOVEDAD, CLASET, TIPOT, BP_D_NOVEDADPROYECTO.CODIGO, PROYECTO, COMPONENTE, ACTIVIDAD, ID_META_PRODUCTO, BP_D_NOVEDADPROYECTO.SECTOR, PERIODO, CANTIDAD_PLAN, CANTIDAD, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, RUBROPRESUPUESTAL, VALORSOLICITADO, VALORAPROBADO, ESPECIFICACION, BARRIO_L, LOCALIZACION,(CASE SOLOCOMPONENTE WHEN 0 THEN 'false' ELSE 'true' END) SOLOCOMPONENTE,(CASE ACTUALIZADO_EN_PLAN WHEN 0 THEN 'false' ELSE 'true' END) ACTUALIZADO_EN_PLAN, VALORDISMINUIDO,TIPOCOMPONENTE, AUXILIAR, REFERENCIA, CENTRO_COSTO, SECTORRUBRO, PROGRAMARUBRO, SUBPROGRAMARUBRO, BP_D_NOVEDADPROYECTO.CODIGOPRODUCTO, BP_D_NOVEDADPROYECTO.CODIGOBPIN, BP_D_NOVEDADPROYECTO.CODIGOCCPET, BP_D_NOVEDADPROYECTO.CODIGOCPCDANE, CODIGOUNIDADEJECUTORA, BP_D_NOVEDADPROYECTO.CODIGOFUENTE, CODIGOCCPETREGALIAS, CODIGOCPCCUIPO, FUENTECUIPO, PRODUCTOCUIPO, CODIGOBPIMCUIPO, CODIGOCCPETCUIPO, CODIGODETALLESECTORIAL, CLASECLASIFICADOR FROM BP_D_NOVEDADPROYECTO LEFT JOIN PLAN_PRESUPUESTAL ON BP_D_NOVEDADPROYECTO.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND BP_D_NOVEDADPROYECTO.ANORUBRO = PLAN_PRESUPUESTAL.ANO AND BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL = PLAN_PRESUPUESTAL.CODIGO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND TIPOT = CASE WHEN :TIPO LIKE 'T' THEN TIPOT ELSE CASE WHEN :TIPO IS NULL THEN TIPOT ELSE :TIPO END END AND DEPENDENCIA = CASE WHEN :DEPENDENCIA LIKE 'T' THEN DEPENDENCIA ELSE CASE WHEN :DEPENDENCIA IS NULL THEN DEPENDENCIA ELSE :DEPENDENCIA END END AND CLASET = NVL(:CLASE,'') AND NOVEDAD = NVL(:NOVEDAD, 0) ORDER BY BP_D_NOVEDADPROYECTO.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(:PROYECTO, '%')) AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPONENTE), '%')) AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:ACTIVIDAD), '%')) AND (CASE WHEN ID_META_PRODUCTO IS NULL THEN ' ' ELSE UPPER(ID_META_PRODUCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_META_PRODUCTO), '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SECTOR), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN CANTIDAD_PLAN IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PLAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDAD_PLAN), '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDAD), '%')) AND (CASE WHEN FUENTERECURSOS IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOS) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTERECURSOS), '%')) AND (CASE WHEN RUBROPRESUPUESTAL IS NULL THEN ' ' ELSE UPPER(RUBROPRESUPUESTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:RUBROPRESUPUESTAL), '%')) AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORSOLICITADO), '%')) AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORAPROBADO), '%')) AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:ESPECIFICACION), '%')) AND (CASE WHEN BARRIO_L IS NULL THEN ' ' ELSE UPPER(BARRIO_L) END) LIKE UPPER(CONCAT(CONCAT('%',:BARRIO_L), '%')) AND (CASE WHEN LOCALIZACION IS NULL THEN ' ' ELSE UPPER(LOCALIZACION) END) LIKE UPPER(CONCAT(CONCAT('%',:LOCALIZACION), '%')) AND (CASE WHEN SOLOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(SOLOCOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:SOLOCOMPONENTE), '%')) AND (CASE WHEN ACTUALIZADO_EN_PLAN IS NULL THEN ' ' ELSE UPPER(ACTUALIZADO_EN_PLAN) END) LIKE UPPER(CONCAT(CONCAT('%',:ACTUALIZADO_EN_PLAN), '%')) AND (CASE WHEN VALORDISMINUIDO IS NULL THEN ' ' ELSE UPPER(VALORDISMINUIDO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORDISMINUIDO), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN SECTORRUBRO IS NULL THEN ' ' ELSE UPPER(SECTORRUBRO) END) LIKE UPPER(CONCAT(CONCAT('%',:SECTORRUBRO), '%')) AND (CASE WHEN PROGRAMARUBRO IS NULL THEN ' ' ELSE UPPER(PROGRAMARUBRO) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMARUBRO), '%')) AND (CASE WHEN SUBPROGRAMARUBRO IS NULL THEN ' ' ELSE UPPER(SUBPROGRAMARUBRO) END) LIKE UPPER(CONCAT(CONCAT('%',:SUBPROGRAMARUBRO), '%')) AND (CASE WHEN CODIGOPRODUCTO IS NULL THEN ' ' ELSE UPPER(CODIGOPRODUCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPRODUCTO), '%')) AND (CASE WHEN CODIGOBPIN IS NULL THEN ' ' ELSE UPPER(CODIGOBPIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOBPIN), '%')) AND (CASE WHEN CODIGOCCPET IS NULL THEN ' ' ELSE UPPER(CODIGOCCPET) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPET), '%')) AND (CASE WHEN CODIGOCPCDANE IS NULL THEN ' ' ELSE UPPER(CODIGOCPCDANE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCPCDANE), '%')) AND (CASE WHEN CODIGOUNIDADEJECUTORA IS NULL THEN ' ' ELSE UPPER(CODIGOUNIDADEJECUTORA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOUNIDADEJECUTORA), '%')) AND (CASE WHEN CODIGOFUENTE IS NULL THEN ' ' ELSE UPPER(CODIGOFUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOFUENTE), '%')) AND (CASE WHEN CODIGOCCPETREGALIAS IS NULL THEN ' ' ELSE UPPER(CODIGOCCPETREGALIAS) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPETREGALIAS), '%')) AND (CASE WHEN CODIGOCPCCUIPO IS NULL THEN ' ' ELSE UPPER(CODIGOCPCCUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCPCCUIPO), '%')) AND (CASE WHEN FUENTECUIPO IS NULL THEN ' ' ELSE UPPER(FUENTECUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTECUIPO), '%')) AND (CASE WHEN PRODUCTOCUIPO IS NULL THEN ' ' ELSE UPPER(PRODUCTOCUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:PRODUCTOCUIPO), '%')) AND (CASE WHEN CODIGOBPIMCUIPO IS NULL THEN ' ' ELSE UPPER(CODIGOBPIMCUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOBPIMCUIPO), '%')) AND (CASE WHEN CODIGOCCPETCUIPO IS NULL THEN ' ' ELSE UPPER(CODIGOCCPETCUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCCPETCUIPO), '%')) AND (CASE WHEN CODIGODETALLESECTORIAL IS NULL THEN ' ' ELSE UPPER(CODIGODETALLESECTORIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGODETALLESECTORIAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="ID_META_PRODUCTO" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CANTIDAD_PLAN" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="FUENTERECURSOS" sqlType="STRING"/>
		<param name="RUBROPRESUPUESTAL" sqlType="STRING"/>
		<param name="VALORSOLICITADO" sqlType="STRING"/>
