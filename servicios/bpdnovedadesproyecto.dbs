	<query id="getBpdnovedadesproyectoTotalValorAprobadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM (BP_D_NOVEDADPROYECTO.VALORAPROBADO) TOTAL_VALORAPROBADO FROM BP_D_NOVEDADPROYECTO LEFT JOIN BPNOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = :TIPO AND BP_D_NOVEDADPROYECTO.CLASET = :CLASE AND BP_D_NOVEDADPROYECTO.DEPENDENCIA= :DEPENDENCIA AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = :COMPONENTE AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = :ACTIVIDAD AND BPNOVEDADPROYECTO.ESTADO = 'V'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_VALORAPROBADO":"$TOTAL_VALORAPROBADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>

	</query>
