<data name="bpdnovedadesproyecto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpdnovedadesproyectoValidaSectorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PROYECTO AS AUXILIAR,SECTOR AS DESTINORECURSOS  FROM BP_D_NOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND NOVEDAD = :NOVEDAD AND BP_D_NOVEDADPROYECTO.TIPOT = 'SCD'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"AUXILIAR":"$AUXILIAR","DESTINORECURSOS":"$DESTINORECURSOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/validasector">
		<call-query href="getBpdnovedadesproyectoValidaSectorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoPagActividadesporsolicitudQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (CONCAT( BP_D_NOVEDADPROYECTO.ACTIVIDAD ,CONCAT( BP_D_NOVEDADPROYECTO.FUENTERECURSOS ,CONCAT(BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO ,BP_D_NOVEDADPROYECTO.SECTOR )))) COD, BP_D_NOVEDADPROYECTO.ACTIVIDAD, BP_ACTIVIDADES.NOMBRE, BP_D_NOVEDADPROYECTO.PROYECTO, PROYECTOS.NOMBREPROYECTO, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, FUENTE_RECURSOS.NOMBRE NOMBRE_FUENTE, BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION, COMPONENTES.NOMBRECOMPONENTE, BP_D_NOVEDADPROYECTO.COMPONENTE, BP_D_NOVEDADPROYECTO.CANTIDAD_PLAN, BP_D_NOVEDADPROYECTO.CANTIDAD, BP_D_NOVEDADPROYECTO.VALORAPROBADO, BP_D_NOVEDADPROYECTO.SECTOR, COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE FROM BP_D_NOVEDADPROYECTO INNER JOIN PROYECTOS ON BP_D_NOVEDADPROYECTO.COMPANIA = PROYECTOS.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = PROYECTOS.CODIGO LEFT JOIN ES_EST_PROY ON PROYECTOS.COMPANIA = ES_EST_PROY.COMPANIA AND PROYECTOS.CODIGO = ES_EST_PROY.COD_PROY LEFT JOIN BP_ACTIVIDADES ON BP_D_NOVEDADPROYECTO.COMPANIA = BP_ACTIVIDADES.COMPANIA AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = BP_ACTIVIDADES.CODIGO INNER JOIN FUENTE_RECURSOS ON BP_D_NOVEDADPROYECTO.COMPANIA = FUENTE_RECURSOS.COMPANIA AND BP_D_NOVEDADPROYECTO.FUENTERECURSOS = FUENTE_RECURSOS.CODIGO LEFT JOIN BP_PLAN_INDICATIVO ON BP_D_NOVEDADPROYECTO.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = BP_PLAN_INDICATIVO.ID INNER JOIN COMPONENTES ON BP_D_NOVEDADPROYECTO.COMPANIA = COMPONENTES.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = COMPONENTES.CODIGOPROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = COMPONENTES.CODIGO INNER JOIN COMPONENTES_ACTIVIDADES ON COMPONENTES.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND COMPONENTES.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND COMPONENTES.CODIGO = COMPONENTES_ACTIVIDADES.COMPONENTE AND COMPONENTES.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE WHERE BP_D_NOVEDADPROYECTO.COMPANIA =:COMPANIA AND BP_D_NOVEDADPROYECTO.NOVEDAD =:NOVEDAD AND BP_D_NOVEDADPROYECTO.TIPOT =:TIPOT AND FUENTE_RECURSOS.ANO =:ANO GROUP BY BP_D_NOVEDADPROYECTO.ACTIVIDAD, BP_ACTIVIDADES.NOMBRE, BP_D_NOVEDADPROYECTO.PROYECTO, PROYECTOS.NOMBREPROYECTO, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, FUENTE_RECURSOS.NOMBRE, BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION, COMPONENTES.NOMBRECOMPONENTE, BP_D_NOVEDADPROYECTO.COMPONENTE, BP_D_NOVEDADPROYECTO.CANTIDAD_PLAN, BP_D_NOVEDADPROYECTO.CANTIDAD, BP_D_NOVEDADPROYECTO.VALORAPROBADO, BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.TIPOT, BP_D_NOVEDADPROYECTO.SECTOR, COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE) INI WHERE (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END) LIKE UPPER(CONCAT(:COD, '%')) AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END) LIKE UPPER(CONCAT(:ACTIVIDAD, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(:PROYECTO, '%')) AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPROYECTO), '%')) AND (CASE WHEN FUENTERECURSOS IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOS) END) LIKE UPPER(CONCAT(:FUENTERECURSOS, '%')) AND (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FUENTE), '%')) AND (CASE WHEN ID_META_PRODUCTO IS NULL THEN ' ' ELSE UPPER(ID_META_PRODUCTO) END) LIKE UPPER(CONCAT(:ID_META_PRODUCTO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPONENTE), '%')) AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(:COMPONENTE, '%')) AND (CASE WHEN CANTIDAD_PLAN IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PLAN) END) LIKE UPPER(CONCAT(:CANTIDAD_PLAN, '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(:CANTIDAD, '%')) AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END) LIKE UPPER(CONCAT(:VALORAPROBADO, '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(:SECTOR, '%')) AND (CASE WHEN TIPOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPONENTE) END) LIKE UPPER(CONCAT(:TIPOCOMPONENTE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD":"$COD","ACTIVIDAD":"$ACTIVIDAD","NOMBRE":"$NOMBRE","PROYECTO":"$PROYECTO","NOMBREPROYECTO":"$NOMBREPROYECTO","FUENTERECURSOS":"$FUENTERECURSOS","NOMBRE_FUENTE":"$NOMBRE_FUENTE","ID_META_PRODUCTO":"$ID_META_PRODUCTO","DESCRIPCION":"$DESCRIPCION","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","COMPONENTE":"$COMPONENTE","CANTIDAD_PLAN":"$CANTIDAD_PLAN","CANTIDAD":"$CANTIDAD","VALORAPROBADO":"$VALORAPROBADO","SECTOR":"$SECTOR","TIPOCOMPONENTE":"$TIPOCOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="FUENTERECURSOS" sqlType="STRING"/>
		<param name="NOMBRE_FUENTE" sqlType="STRING"/>
		<param name="ID_META_PRODUCTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="CANTIDAD_PLAN" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/actividadesporsolicitud/pag">
		<call-query href="getBpdnovedadesproyectoPagActividadesporsolicitudQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD" query-param="COD"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="FUENTERECURSOS" query-param="FUENTERECURSOS"/>
			<with-param name="NOMBRE_FUENTE" query-param="NOMBRE_FUENTE"/>
			<with-param name="ID_META_PRODUCTO" query-param="ID_META_PRODUCTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="CANTIDAD_PLAN" query-param="CANTIDAD_PLAN"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORAPROBADO" query-param="VALORAPROBADO"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoNumActividadesporsolicitudQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (CONCAT( BP_D_NOVEDADPROYECTO.ACTIVIDAD ,CONCAT( BP_D_NOVEDADPROYECTO.FUENTERECURSOS ,CONCAT(BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO ,BP_D_NOVEDADPROYECTO.SECTOR )))) COD, BP_D_NOVEDADPROYECTO.ACTIVIDAD, BP_ACTIVIDADES.NOMBRE, BP_D_NOVEDADPROYECTO.PROYECTO, PROYECTOS.NOMBREPROYECTO, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, FUENTE_RECURSOS.NOMBRE NOMBRE_FUENTE, BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION, COMPONENTES.NOMBRECOMPONENTE, BP_D_NOVEDADPROYECTO.COMPONENTE, BP_D_NOVEDADPROYECTO.CANTIDAD_PLAN, BP_D_NOVEDADPROYECTO.CANTIDAD, BP_D_NOVEDADPROYECTO.VALORAPROBADO, BP_D_NOVEDADPROYECTO.SECTOR, COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE FROM BP_D_NOVEDADPROYECTO INNER JOIN PROYECTOS ON BP_D_NOVEDADPROYECTO.COMPANIA = PROYECTOS.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = PROYECTOS.CODIGO LEFT JOIN ES_EST_PROY ON PROYECTOS.COMPANIA = ES_EST_PROY.COMPANIA AND PROYECTOS.CODIGO = ES_EST_PROY.COD_PROY LEFT JOIN BP_ACTIVIDADES ON BP_D_NOVEDADPROYECTO.COMPANIA = BP_ACTIVIDADES.COMPANIA AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = BP_ACTIVIDADES.CODIGO INNER JOIN FUENTE_RECURSOS ON BP_D_NOVEDADPROYECTO.COMPANIA = FUENTE_RECURSOS.COMPANIA AND BP_D_NOVEDADPROYECTO.FUENTERECURSOS = FUENTE_RECURSOS.CODIGO LEFT JOIN BP_PLAN_INDICATIVO ON BP_D_NOVEDADPROYECTO.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = BP_PLAN_INDICATIVO.ID INNER JOIN COMPONENTES ON BP_D_NOVEDADPROYECTO.COMPANIA = COMPONENTES.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = COMPONENTES.CODIGOPROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = COMPONENTES.CODIGO INNER JOIN COMPONENTES_ACTIVIDADES ON COMPONENTES.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND COMPONENTES.CODIGOPROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND COMPONENTES.CODIGO = COMPONENTES_ACTIVIDADES.COMPONENTE AND COMPONENTES.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE WHERE BP_D_NOVEDADPROYECTO.COMPANIA =:COMPANIA AND BP_D_NOVEDADPROYECTO.NOVEDAD =:NOVEDAD AND BP_D_NOVEDADPROYECTO.TIPOT =:TIPOT AND FUENTE_RECURSOS.ANO =:ANO GROUP BY BP_D_NOVEDADPROYECTO.ACTIVIDAD, BP_ACTIVIDADES.NOMBRE, BP_D_NOVEDADPROYECTO.PROYECTO, PROYECTOS.NOMBREPROYECTO, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, FUENTE_RECURSOS.NOMBRE, BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO, BP_PLAN_INDICATIVO.DESCRIPCION, COMPONENTES.NOMBRECOMPONENTE, BP_D_NOVEDADPROYECTO.COMPONENTE, BP_D_NOVEDADPROYECTO.CANTIDAD_PLAN, BP_D_NOVEDADPROYECTO.CANTIDAD, BP_D_NOVEDADPROYECTO.VALORAPROBADO, BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.TIPOT, BP_D_NOVEDADPROYECTO.SECTOR, COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE) INI WHERE (CASE WHEN COD IS NULL THEN ' ' ELSE UPPER(COD) END) LIKE UPPER(CONCAT(:COD, '%')) AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END) LIKE UPPER(CONCAT(:ACTIVIDAD, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(:PROYECTO, '%')) AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPROYECTO), '%')) AND (CASE WHEN FUENTERECURSOS IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOS) END) LIKE UPPER(CONCAT(:FUENTERECURSOS, '%')) AND (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FUENTE), '%')) AND (CASE WHEN ID_META_PRODUCTO IS NULL THEN ' ' ELSE UPPER(ID_META_PRODUCTO) END) LIKE UPPER(CONCAT(:ID_META_PRODUCTO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPONENTE), '%')) AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(:COMPONENTE, '%')) AND (CASE WHEN CANTIDAD_PLAN IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PLAN) END) LIKE UPPER(CONCAT(:CANTIDAD_PLAN, '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(:CANTIDAD, '%')) AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END) LIKE UPPER(CONCAT(:VALORAPROBADO, '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(:SECTOR, '%')) AND (CASE WHEN TIPOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPONENTE) END) LIKE UPPER(CONCAT(:TIPOCOMPONENTE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COD" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="FUENTERECURSOS" sqlType="STRING"/>
		<param name="NOMBRE_FUENTE" sqlType="STRING"/>
		<param name="ID_META_PRODUCTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="CANTIDAD_PLAN" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/actividadesporsolicitud/num">
		<call-query href="getBpdnovedadesproyectoNumActividadesporsolicitudQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COD" query-param="COD"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="FUENTERECURSOS" query-param="FUENTERECURSOS"/>
			<with-param name="NOMBRE_FUENTE" query-param="NOMBRE_FUENTE"/>
			<with-param name="ID_META_PRODUCTO" query-param="ID_META_PRODUCTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="CANTIDAD_PLAN" query-param="CANTIDAD_PLAN"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORAPROBADO" query-param="VALORAPROBADO"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoPagTodosPorProyiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.DEPENDENCIA, BP_D_NOVEDADPROYECTO.VIGENCIA_PLAN_INDICATIVO  FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.DEPENDENCIA IS NOT NULL AND BP_D_NOVEDADPROYECTO.CLASET = :CLASET AND BP_D_NOVEDADPROYECTO.TIPOT = :TIPOT AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYINI) WHERE (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END)  LIKE UPPER(:NOVEDAD || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN VIGENCIA_PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PLAN_INDICATIVO) END)  LIKE UPPER(:VIGENCIA_PLAN_INDICATIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOVEDAD":"$NOVEDAD(type:long)","DEPENDENCIA":"$DEPENDENCIA","VIGENCIA_PLAN_INDICATIVO":"$VIGENCIA_PLAN_INDICATIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="PROYINI" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/todosporproyini/pag">
		<call-query href="getBpdnovedadesproyectoPagTodosPorProyiniQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="PROYINI" query-param="PROYINI"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="VIGENCIA_PLAN_INDICATIVO" query-param="VIGENCIA_PLAN_INDICATIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoNumTodosPorProyiniQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.DEPENDENCIA, BP_D_NOVEDADPROYECTO.VIGENCIA_PLAN_INDICATIVO  FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.DEPENDENCIA IS NOT NULL AND BP_D_NOVEDADPROYECTO.CLASET = :CLASET AND BP_D_NOVEDADPROYECTO.TIPOT = :TIPOT AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYINI) WHERE (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END)  LIKE UPPER(:NOVEDAD || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN VIGENCIA_PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PLAN_INDICATIVO) END)  LIKE UPPER(:VIGENCIA_PLAN_INDICATIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="PROYINI" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN_INDICATIVO" sqlType="STRING"/>

	</query>
