			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoGetvalorsolicitadoydisminuidoscdymodQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT SUM(BP_D_NOVEDADPROYECTO.VALORSOLICITADO) VALORSOLICITADO, SUM(BP_D_NOVEDADPROYECTO.VALORDISMINUIDO) VALORDISMINUIDO FROM BP_D_NOVEDADPROYECTO INNER JOIN COMPONENTES_ACTIVIDADES ON BP_D_NOVEDADPROYECTO.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND BP_D_NOVEDADPROYECTO.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = BPNOVEDADPROYECTO.DEPENDENCIA INNER JOIN BPTIPONOVEDAD ON BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT AND BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET WHERE COMPONENTES_ACTIVIDADES.COMPANIA = :COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = :PROYECTO AND COMPONENTES_ACTIVIDADES.ACTIVIDAD = :ACTIVIDAD AND COMPONENTES_ACTIVIDADES.COMPONENTE = :COMPONENTE AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = :METAPRODUCTO AND BPNOVEDADPROYECTO.TIPOT IN ('SCD','MOD') AND BPNOVEDADPROYECTO.ESTADO IN ('V') AND BPTIPONOVEDAD.CONTROLASALDOSOLICITADO NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORSOLICITADO":"$VALORSOLICITADO(type:double)","VALORDISMINUIDO":"$VALORDISMINUIDO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="METAPRODUCTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/getvalorsolicitadoydisminuidoscdymod">
		<call-query href="getBpdnovedadesproyectoGetvalorsolicitadoydisminuidoscdymodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="METAPRODUCTO" query-param="METAPRODUCTO"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoGetvalorsolicitadoydisminuidocdpQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT SUM(BP_D_NOVEDADPROYECTO.VALORSOLICITADO) VALORSOLICITADO, SUM(BP_D_NOVEDADPROYECTO.VALORDISMINUIDO) VALORDISMINUIDO FROM BP_D_NOVEDADPROYECTO INNER JOIN COMPONENTES_ACTIVIDADES ON BP_D_NOVEDADPROYECTO.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND BP_D_NOVEDADPROYECTO.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = BPNOVEDADPROYECTO.DEPENDENCIA WHERE COMPONENTES_ACTIVIDADES.COMPANIA = :COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = :PROYECTO AND COMPONENTES_ACTIVIDADES.ACTIVIDAD = :ACTIVIDAD AND COMPONENTES_ACTIVIDADES.COMPONENTE = :COMPONENTE AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = :METAPRODUCTO AND BPNOVEDADPROYECTO.TIPOT IN ('CDP') AND BPNOVEDADPROYECTO.ESTADO IN ('V') AND BPNOVEDADPROYECTO.VOBOBP IN (-1)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORSOLICITADO":"$VALORSOLICITADO(type:integer)","VALORDISMINUIDO":"$VALORDISMINUIDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="METAPRODUCTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/getvalorsolicitadoydisminuidocdp">
		<call-query href="getBpdnovedadesproyectoGetvalorsolicitadoydisminuidocdpQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="METAPRODUCTO" query-param="METAPRODUCTO"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoConsultarproyectoparanovedadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PROYECTO  FROM BP_D_NOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND NOVEDAD = :NOVEDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PROYECTO":"$PROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/consultarproyectoparanovedad">
		<call-query href="getBpdnovedadesproyectoConsultarproyectoparanovedadQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoValidarvistobuenobpQuery"  useConfig="sysmandsunist">
		<sql>SELECT BP_D_NOVEDADPROYECTO.PROYECTO, BP_D_NOVEDADPROYECTO.COMPONENTE, BP_D_NOVEDADPROYECTO.ACTIVIDAD, BP_D_NOVEDADPROYECTO.VALORSOLICITADO, COSTOTOTAL - VALOR_SOLICITADO_ACTIVIDAD AS SALDO, CASE WHEN VALORSOLICITADO &gt; COSTOTOTAL - VALOR_SOLICITADO_ACTIVIDAD THEN 'SI' ELSE 'NO' END AS INCONSISTENCIA FROM BP_D_NOVEDADPROYECTO INNER JOIN COMPONENTES_ACTIVIDADES ON BP_D_NOVEDADPROYECTO.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND BP_D_NOVEDADPROYECTO.COMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD AND BP_D_NOVEDADPROYECTO.PROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = :TIPO AND BP_D_NOVEDADPROYECTO.CLASET = :CLASE AND BP_D_NOVEDADPROYECTO.NOVEDAD = :NOVEDAD GROUP BY BP_D_NOVEDADPROYECTO.PROYECTO, BP_D_NOVEDADPROYECTO.COMPONENTE, BP_D_NOVEDADPROYECTO.ACTIVIDAD, BP_D_NOVEDADPROYECTO.VALORSOLICITADO, COSTOTOTAL - VALOR_SOLICITADO_ACTIVIDAD HAVING CASE WHEN VALORSOLICITADO &gt; COSTOTOTAL - VALOR_SOLICITADO_ACTIVIDAD THEN 'SI' ELSE 'NO' END = 'SI'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PROYECTO":"$PROYECTO","COMPONENTE":"$COMPONENTE","ACTIVIDAD":"$ACTIVIDAD","VALORSOLICITADO":"$VALORSOLICITADO","SALDO":"$SALDO(type:integer)","INCONSISTENCIA":"$INCONSISTENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/validarvistobuenobp">
		<call-query href="getBpdnovedadesproyectoValidarvistobuenobpQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>

		</call-query>
	</resource>
	<query id="updateBpdnovedadesproyectoUpdatedisminucion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_D_NOVEDADPROYECTO SET VALORAPROBADO = CASE WHEN :VALORDISMINUIDO = VALORAPROBADO THEN VALORAPROBADO ELSE (VALORSOLICITADO - :VALORDISMINUIDO) END, VALORDISMINUIDO = CASE WHEN :VALORDISMINUIDO = VALORAPROBADO THEN '0' ELSE :VALORDISMINUIDO END WHERE COMPANIA = :COMPANIA AND TIPOT = :TIPOT AND CLASET = :CLASET AND NOVEDAD = :NOVEDAD AND DEPENDENCIA = :DEPENDENCIA AND CODIGO = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORDISMINUIDO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpdnovedadesproyecto/updatedisminucion">
		<call-query href="updateBpdnovedadesproyectoUpdatedisminucion">
			<with-param name="VALORDISMINUIDO" query-param="VALORDISMINUIDO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
		<query id="getBpdnovedadesproyectoTotalsolicitadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(BP_D_NOVEDADPROYECTO.VALORSOLICITADO) TOTAL_VALORSOLICITADO FROM BP_D_NOVEDADPROYECTO INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = :TIPO AND BP_D_NOVEDADPROYECTO.CLASET = :CLASE AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = :DEPENDENCIA AND BP_D_NOVEDADPROYECTO.PROYECTO = :PROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = :COMPONENTE AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = :ACTIVIDAD AND BPNOVEDADPROYECTO.ESTADO = 'V' AND BPNOVEDADPROYECTO.VOBOBP &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_VALORSOLICITADO":"$TOTAL_VALORSOLICITADO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/totalsolicitado">
		<call-query href="getBpdnovedadesproyectoTotalsolicitadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>

		</call-query>
	</resource>
</data>