	<query id="insertBpdnovedadesproyectoSubnovedades" keyColumns="COMPANIA,TIPOT,CLASET,NOVEDAD,DEPENDENCIA,CODIGO,PROYECTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_D_NOVEDADPROYECTO (COMPANIA, CODIGO, PROYECTO, COMPONENTE, ACTIVIDAD, ID_META_PRODUCTO, SECTOR, PERIODO, CANTIDAD_PLAN, FUENTERECURSOS, RUBROPRESUPUESTAL, VALORSOLICITADO, VALORAPROBADO, VALORDISMINUIDO, ESPECIFICACION, BARRIO_L, LOCALIZACION, SOLOCOMPONENTE, ACTUALIZADO_EN_PLAN, VIGENCIA_PLAN_INDICATIVO, ANORUBRO, CANTIDAD, TIPOT, NOVEDAD, TIPOCOMPONENTE, DEPENDENCIA, CLASET, CREATED_BY, DATE_CREATED, AUXILIAR, REFERENCIA, CENTRO_COSTO, SECTORRUBRO, PROGRAMARUBRO, SUBPROGRAMARUBRO, CODIGOPRODUCTO, CODIGOBPIN, CODIGOCCPET, CODIGOCPCDANE, CODIGOUNIDADEJECUTORA, CODIGOFUENTE, CODIGOCCPETREGALIAS, CODIGOCPCCUIPO, FUENTECUIPO, PRODUCTOCUIPO, CODIGOBPIMCUIPO, CODIGOCCPETCUIPO, CODIGODETALLESECTORIAL) VALUES (:COMPANIA, :CODIGO, :PROYECTO, :COMPONENTE, :ACTIVIDAD, :ID_META_PRODUCTO, :SECTOR, :PERIODO, :CANTIDAD_PLAN, :FUENTERECURSOS, :RUBROPRESUPUESTAL, :VALORSOLICITADO, :VALORAPROBADO, :VALORDISMINUIDO, :ESPECIFICACION, :BARRIO_L, :LOCALIZACION, :SOLOCOMPONENTE, :ACTUALIZADO_EN_PLAN, :VIGENCIA_PLAN_INDICATIVO, :ANORUBRO, :CANTIDAD, :TIPOT, :NOVEDAD, :TIPOCOMPONENTE, :DEPENDENCIA, :CLASET, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :AUXILIAR, :REFERENCIA, :CENTRO_COSTO, :SECTORRUBRO, :PROGRAMARUBRO, :SUBPROGRAMARUBRO, :CODIGOPRODUCTO, :CODIGOBPIN, :CODIGOCCPET, :CODIGOCPCDANE, :CODIGOUNIDADEJECUTORA, :CODIGOFUENTE, :CODIGOCCPETREGALIAS, :CODIGOCPCCUIPO, :FUENTECUIPO, :PRODUCTOCUIPO, :CODIGOBPIMCUIPO, :CODIGOCCPETCUIPO, :CODIGODETALLESECTORIAL)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOT":"$TIPOT","KEY_CLASET":"$CLASET","KEY_NOVEDAD":"$NOVEDAD(type:long)","KEY_DEPENDENCIA":"$DEPENDENCIA","KEY_CODIGO":"$CODIGO","KEY_PROYECTO":"$PROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
