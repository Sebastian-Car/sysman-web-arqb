	<query id="getBpdnovedadesproyectoNumBpdnovedadesproyecporanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO CODIGODETALLE, PROYECTO, VALORAPROBADO, VALORPROGRAMADO, ACTIVIDAD, ( CASE SOLOCOMPONENTE WHEN -1 THEN 'SI' WHEN 0 THEN 'NO' END) AS SOLOCOMPONENTE  FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA=:COMPANIA AND SUBSTR(BP_D_NOVEDADPROYECTO.PROYECTO, 1, 4)=:ANO ORDER BY COMPANIA, TIPOT, CLASET, NOVEDAD) WHERE (CASE WHEN CODIGODETALLE IS NULL THEN ' ' ELSE UPPER(CODIGODETALLE) END)  LIKE UPPER(:CODIGODETALLE || '%')  AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END)  LIKE UPPER(:PROYECTO || '%')  AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END)  LIKE UPPER( '%' || :VALORAPROBADO || '%')  AND (CASE WHEN VALORPROGRAMADO IS NULL THEN ' ' ELSE UPPER(VALORPROGRAMADO) END)  LIKE UPPER( '%' || :VALORPROGRAMADO || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN SOLOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(SOLOCOMPONENTE) END)  LIKE UPPER( '%' || :SOLOCOMPONENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
