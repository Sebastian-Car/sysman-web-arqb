	<query id="getBpdnovedadesproyectoTotalesSubnovedadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_D_NOVEDADPROYECTO.TIPOT, SUM(BP_D_NOVEDADPROYECTO.VALORSOLICITADO) VALORSOLICITADO, SUM(BP_D_NOVEDADPROYECTO.VALORAPROBADO) VALORAPROBADO  FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND TIPOT = CASE WHEN :TIPO LIKE 'T' THEN TIPOT ELSE CASE WHEN :TIPO IS NULL THEN TIPOT ELSE :TIPO END END AND DEPENDENCIA = CASE WHEN :DEPENDENCIA LIKE 'T' THEN DEPENDENCIA ELSE CASE WHEN :DEPENDENCIA IS NULL THEN DEPENDENCIA ELSE :DEPENDENCIA END END AND CLASET = NVL(:CLASE,'') AND NOVEDAD = NVL(:NOVEDAD, 0) GROUP BY BP_D_NOVEDADPROYECTO.TIPOT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOT":"$TIPOT","VALORSOLICITADO":"$VALORSOLICITADO","VALORAPROBADO":"$VALORAPROBADO"
}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpdnovedadesproyecto/totalessubnovedades">
		<call-query href="getBpdnovedadesproyectoTotalesSubnovedadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>

		</call-query>
	</resource>
	<query id="getBpdnovedadesproyectoTodosPortipotclasetnoveQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.TIPOT, BP_D_NOVEDADPROYECTO.CLASET, BP_D_NOVEDADPROYECTO.NOVEDAD, BP_D_NOVEDADPROYECTO.VIGENCIA_PLAN_INDICATIVO  FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA= :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = :TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = :CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = :NOVEDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","NOVEDAD":"$NOVEDAD(type:long)","VIGENCIA_PLAN_INDICATIVO":"$VIGENCIA_PLAN_INDICATIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>

	</query>
