	<query id="getBpdnovedadesproyectoValidacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) EXISTE  FROM BP_D_NOVEDADPROYECTO INNER JOIN BPNOVEDADPROYECTO ON BP_D_NOVEDADPROYECTO.COMPANIA = BPNOVEDADPROYECTO.COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = BPNOVEDADPROYECTO.TIPOT AND BP_D_NOVEDADPROYECTO.CLASET = BPNOVEDADPROYECTO.CLASET AND BP_D_NOVEDADPROYECTO.NOVEDAD = BPNOVEDADPROYECTO.CODIGO AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = BPNOVEDADPROYECTO.DEPENDENCIA LEFT JOIN TIPOADJUDICACION ON BPNOVEDADPROYECTO.MODALIDAD_SELECC = TIPOADJUDICACION.CODIGO LEFT JOIN BPTIPONOVEDAD ON BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT AND BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET LEFT JOIN PLAN_PRESUPUESTAL ON BP_D_NOVEDADPROYECTO.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL = PLAN_PRESUPUESTAL.CODIGO AND BP_D_NOVEDADPROYECTO.ANORUBRO = PLAN_PRESUPUESTAL.ANO INNER JOIN PROYECTOS ON BP_D_NOVEDADPROYECTO.COMPANIA = PROYECTOS.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = PROYECTOS.CODIGO LEFT JOIN COMPONENTES ON BP_D_NOVEDADPROYECTO.TIPOCOMPONENTE = COMPONENTES.TIPOCOMPONENTE AND BP_D_NOVEDADPROYECTO.COMPANIA = COMPONENTES.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = COMPONENTES.CODIGOPROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = COMPONENTES.CODIGO LEFT JOIN FUENTE_RECURSOS ON BP_D_NOVEDADPROYECTO.ANORUBRO = FUENTE_RECURSOS.ANO AND BP_D_NOVEDADPROYECTO.FUENTERECURSOS = FUENTE_RECURSOS.CODIGO AND BP_D_NOVEDADPROYECTO.COMPANIA = FUENTE_RECURSOS.COMPANIA LEFT JOIN BP_ACTIVIDADES ON BP_D_NOVEDADPROYECTO.ACTIVIDAD = BP_ACTIVIDADES.CODIGO AND BP_D_NOVEDADPROYECTO.COMPANIA = BP_ACTIVIDADES.COMPANIA LEFT JOIN BP_PROYECTO_PLAN_INDICATIVO ON BP_D_NOVEDADPROYECTO.TIPOCOMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE AND BP_D_NOVEDADPROYECTO.ACTIVIDAD = BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD AND BP_D_NOVEDADPROYECTO.COMPANIA = BP_PROYECTO_PLAN_INDICATIVO.COMPANIA AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P AND BP_D_NOVEDADPROYECTO.VIGENCIA_PLAN_INDICATIVO = BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P AND BP_D_NOVEDADPROYECTO.ANORUBRO = BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P AND BP_D_NOVEDADPROYECTO.PROYECTO = BP_PROYECTO_PLAN_INDICATIVO.PROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE INNER JOIN DEPENDENCIA ON BP_D_NOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BP_D_NOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN DEPENDENCIA_RESPONSABLE ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND BPNOVEDADPROYECTO.RESPONSABLE = DEPENDENCIA_RESPONSABLE.RESPONSABLE INNER JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA INNER JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE BPNOVEDADPROYECTO.CODIGO = :CODIGO AND BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>

	</query>
