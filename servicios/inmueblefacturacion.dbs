	<query id="getInmueblefacturacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT INMUEBLE_FACTURACION.COMPANIA, TIPO, TIPO_INMUEBLE_FAC.NOMBRE NOMBRETIPO, EDIFICIOS.NOMBRE EDIFICIO, CODIGOINMUEBLE, UBICACION_BIEN.NOMBRE UBICACION, DENOMINACION, DEPARTAMENTO, CIUDAD, AREA, LINDERONORTE, LINDEROSUR, LINDEROORIENTE, LINDEROOCCIDENTE, LINDEROCENIT, LINDERONADIR, CONCEPTO1, CONCEPTO2, CONCEPTO3, OBSERVACIONES, DIRECCION,(CASE COMERCIALIZABLE WHEN 0 THEN 'false' ELSE 'true' END) COMERCIALIZABLE,(CASE DISPONIBLE WHEN 0 THEN 'false' ELSE 'true' END) DISPONIBLE,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,(CASE ARRENDADO WHEN 0 THEN 'false' ELSE 'true' END) ARRENDADO, CONCEPTO4, INMUEBLE_FACTURACION.CREATED_BY,(TO_CHAR(INMUEBLE_FACTURACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, INMUEBLE_FACTURACION.MODIFIED_BY,(TO_CHAR(INMUEBLE_FACTURACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, RUTA_IMAGEN, NOMBRE_IMAGEN FROM INMUEBLE_FACTURACION LEFT JOIN TIPO_INMUEBLE_FAC ON INMUEBLE_FACTURACION.COMPANIA = TIPO_INMUEBLE_FAC.COMPANIA AND INMUEBLE_FACTURACION.TIPO = TIPO_INMUEBLE_FAC.CODIGO LEFT JOIN EDIFICIOS ON INMUEBLE_FACTURACION.COMPANIA = EDIFICIOS.COMPANIA AND INMUEBLE_FACTURACION.EDIFICIO = EDIFICIOS.CODIGO LEFT JOIN UBICACION_BIEN ON INMUEBLE_FACTURACION.COMPANIA = UBICACION_BIEN.COMPANIA AND INMUEBLE_FACTURACION.UBICACION = UBICACION_BIEN.CODIGO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPO), '%')) AND (CASE WHEN EDIFICIO IS NULL THEN ' ' ELSE UPPER(EDIFICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:EDIFICIO), '%')) AND (CASE WHEN CODIGOINMUEBLE IS NULL THEN ' ' ELSE UPPER(CODIGOINMUEBLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOINMUEBLE), '%')) AND (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:UBICACION), '%')) AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END) LIKE UPPER(CONCAT(CONCAT('%',:DENOMINACION), '%')) AND (CASE WHEN DEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(DEPARTAMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:DEPARTAMENTO), '%')) AND (CASE WHEN CIUDAD IS NULL THEN ' ' ELSE UPPER(CIUDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:CIUDAD), '%')) AND (CASE WHEN AREA IS NULL THEN ' ' ELSE UPPER(AREA) END) LIKE UPPER(CONCAT(CONCAT('%',:AREA), '%')) AND (CASE WHEN LINDERONORTE IS NULL THEN ' ' ELSE UPPER(LINDERONORTE) END) LIKE UPPER(CONCAT(CONCAT('%',:LINDERONORTE), '%')) AND (CASE WHEN LINDEROSUR IS NULL THEN ' ' ELSE UPPER(LINDEROSUR) END) LIKE UPPER(CONCAT(CONCAT('%',:LINDEROSUR), '%')) AND (CASE WHEN LINDEROORIENTE IS NULL THEN ' ' ELSE UPPER(LINDEROORIENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:LINDEROORIENTE), '%')) AND (CASE WHEN LINDEROOCCIDENTE IS NULL THEN ' ' ELSE UPPER(LINDEROOCCIDENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:LINDEROOCCIDENTE), '%')) AND (CASE WHEN LINDEROCENIT IS NULL THEN ' ' ELSE UPPER(LINDEROCENIT) END) LIKE UPPER(CONCAT(CONCAT('%',:LINDEROCENIT), '%')) AND (CASE WHEN LINDERONADIR IS NULL THEN ' ' ELSE UPPER(LINDERONADIR) END) LIKE UPPER(CONCAT(CONCAT('%',:LINDERONADIR), '%')) AND (CASE WHEN CONCEPTO1 IS NULL THEN ' ' ELSE UPPER(CONCEPTO1) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO1), '%')) AND (CASE WHEN CONCEPTO2 IS NULL THEN ' ' ELSE UPPER(CONCEPTO2) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO2), '%')) AND (CASE WHEN CONCEPTO3 IS NULL THEN ' ' ELSE UPPER(CONCEPTO3) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO3), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN COMERCIALIZABLE IS NULL THEN ' ' ELSE UPPER(COMERCIALIZABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMERCIALIZABLE), '%')) AND (CASE WHEN DISPONIBLE IS NULL THEN ' ' ELSE UPPER(DISPONIBLE) END) LIKE UPPER(CONCAT(CONCAT('%',:DISPONIBLE), '%')) AND (CASE WHEN ACTIVO IS NULL THEN ' ' ELSE UPPER(ACTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:ACTIVO), '%')) AND (CASE WHEN ARRENDADO IS NULL THEN ' ' ELSE UPPER(ARRENDADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ARRENDADO), '%')) AND (CASE WHEN CONCEPTO4 IS NULL THEN ' ' ELSE UPPER(CONCEPTO4) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO4), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:CREATED_BY), '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_CREATED), '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFIED_BY), '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_MODIFIED), '%')) AND (CASE WHEN RUTA_IMAGEN IS NULL THEN ' ' ELSE UPPER(RUTA_IMAGEN) END) LIKE UPPER(CONCAT(CONCAT('%',:RUTA_IMAGEN), '%')) AND (CASE WHEN NOMBRE_IMAGEN IS NULL THEN ' ' ELSE UPPER(NOMBRE_IMAGEN) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_IMAGEN), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO(type:integer)","NOMBRETIPO":"$NOMBRETIPO","EDIFICIO":"$EDIFICIO","CODIGOINMUEBLE":"$CODIGOINMUEBLE","UBICACION":"$UBICACION","DENOMINACION":"$DENOMINACION","DEPARTAMENTO":"$DEPARTAMENTO(type:integer)","CIUDAD":"$CIUDAD(type:integer)","AREA":"$AREA(type:integer)","LINDERONORTE":"$LINDERONORTE","LINDEROSUR":"$LINDEROSUR","LINDEROORIENTE":"$LINDEROORIENTE","LINDEROOCCIDENTE":"$LINDEROOCCIDENTE","LINDEROCENIT":"$LINDEROCENIT","LINDERONADIR":"$LINDERONADIR","CONCEPTO1":"$CONCEPTO1","CONCEPTO2":"$CONCEPTO2","CONCEPTO3":"$CONCEPTO3","OBSERVACIONES":"$OBSERVACIONES","DIRECCION":"$DIRECCION","COMERCIALIZABLE":"$COMERCIALIZABLE(type:boolean)","DISPONIBLE":"$DISPONIBLE(type:boolean)","ACTIVO":"$ACTIVO(type:boolean)","ARRENDADO":"$ARRENDADO(type:boolean)","CONCEPTO4":"$CONCEPTO4","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","RUTA_IMAGEN":"$RUTA_IMAGEN","NOMBRE_IMAGEN":"$NOMBRE_IMAGEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="EDIFICIO" sqlType="STRING"/>
		<param name="CODIGOINMUEBLE" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="CIUDAD" sqlType="STRING"/>
		<param name="AREA" sqlType="STRING"/>
		<param name="LINDERONORTE" sqlType="STRING"/>
		<param name="LINDEROSUR" sqlType="STRING"/>
		<param name="LINDEROORIENTE" sqlType="STRING"/>
		<param name="LINDEROOCCIDENTE" sqlType="STRING"/>
		<param name="LINDEROCENIT" sqlType="STRING"/>
		<param name="LINDERONADIR" sqlType="STRING"/>
		<param name="CONCEPTO1" sqlType="STRING"/>
		<param name="CONCEPTO2" sqlType="STRING"/>
		<param name="CONCEPTO3" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="COMERCIALIZABLE" sqlType="STRING"/>
		<param name="DISPONIBLE" sqlType="STRING"/>
