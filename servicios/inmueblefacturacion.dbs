		</call-query>
	</resource>
	<query id="insertInmueblefacturacion" keyColumns="COMPANIA,CODIGOINMUEBLE,TIPO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INMUEBLE_FACTURACION (COMPANIA, TIPO, EDIFICIO, CODIGOINMUEBLE, UBICACION, DENOMINACION, DEPARTAMENTO, CIUDAD, AREA, LINDERONORTE, LINDEROSUR, LINDEROORIENTE, LINDEROOCCIDENTE, LINDEROCENIT, LINDERONADIR, CONCEPTO1, CONCEPTO2, CONCEPTO3, OBSERVACIONES, DIRECCION, COMERCIALIZABLE, DISPONIBLE, ACTIVO, ARRENDADO, CONCEPTO4, CREATED_BY, DATE_CREATED, RUTA_IMAGEN, NOMBRE_IMAGEN, TERCERO, SUCURSAL) VALUES (:COMPANIA, :TIPO, :EDIFICIO, :CODIGOINMUEBLE, :UBICACION, :DENOMINACION, :DEPARTAMENTO, :CIUDAD, :AREA, :LINDERONORTE, :LINDEROSUR, :LINDEROORIENTE, :LINDEROOCCIDENTE, :LINDEROCENIT, :LINDERONADIR, :CONCEPTO1, :CONCEPTO2, :CONCEPTO3, :OBSERVACIONES, :DIRECCION, :COMERCIALIZABLE, :DISPONIBLE, :ACTIVO, :ARRENDADO, :CONCEPTO4, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :RUTA_IMAGEN, :NOMBRE_IMAGEN, :TERCERO, :SUCURSAL)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOINMUEBLE":"$CODIGOINMUEBLE","KEY_TIPO":"$TIPO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
