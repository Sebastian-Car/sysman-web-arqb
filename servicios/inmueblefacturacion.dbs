		<param name="LINDEROCENIT" sqlType="STRING"/>
		<param name="LINDERONADIR" sqlType="STRING"/>
		<param name="CONCEPTO1" sqlType="STRING"/>
		<param name="CONCEPTO2" sqlType="STRING"/>
		<param name="CONCEPTO3" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="COMERCIALIZABLE" sqlType="STRING"/>
		<param name="DISPONIBLE" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="ARRENDADO" sqlType="STRING"/>
		<param name="CONCEPTO4" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="RUTA_IMAGEN" sqlType="STRING"/>
		<param name="NOMBRE_IMAGEN" sqlType="STRING"/>

	</query>
