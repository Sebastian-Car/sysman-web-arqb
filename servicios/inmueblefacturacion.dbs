<data name="inmueblefacturacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getInmueblefacturacionPagTodosporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CASE TIPO WHEN 1 THEN 'Local' WHEN 2 THEN 'Mezzanine' WHEN 3 THEN 'Bodega' WHEN 4 THEN 'Sótano' WHEN 5 THEN 'Oficina' WHEN 6 THEN 'Piso' WHEN 7 THEN 'Casa' WHEN 8 THEN 'Lote' WHEN 9 THEN 'Plazoleta' WHEN 10 THEN 'Galeria Bochica' WHEN 11 THEN 'Edificio' WHEN 12 THEN 'Terraza' WHEN 13 THEN 'Baño' WHEN 14 THEN 'Pasillo' WHEN 15 THEN 'Espacio' END NOM_TIPO, CASE EDIFICIO WHEN 1 THEN 'Ascensores' WHEN 2 THEN 'Pedregal' WHEN 3 THEN 'RTN' WHEN 4 THEN 'Bachue' WHEN 5 THEN 'RTS' WHEN 6 THEN 'Bochica' WHEN 7 THEN '0001' WHEN 8 THEN '0003' END NOM_EDIFICIO ,CODIGOINMUEBLE, DENOMINACION, CONCEPTO1, CONCEPTO2, CONCEPTO3,CONCEPTO4, TIPO, AREA FROM INMUEBLE_FACTURACION WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN NOM_TIPO IS NULL THEN ' ' ELSE UPPER(NOM_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_TIPO), '%')) AND (CASE WHEN NOM_EDIFICIO IS NULL THEN ' ' ELSE UPPER(NOM_EDIFICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_EDIFICIO), '%')) AND (CASE WHEN CODIGOINMUEBLE IS NULL THEN ' ' ELSE UPPER(CODIGOINMUEBLE) END) LIKE UPPER(CONCAT(:CODIGOINMUEBLE, '%')) AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END) LIKE UPPER(CONCAT(:DENOMINACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOM_TIPO":"$NOM_TIPO","NOM_EDIFICIO":"$NOM_EDIFICIO","CODIGOINMUEBLE":"$CODIGOINMUEBLE","DENOMINACION":"$DENOMINACION","CONCEPTO1":"$CONCEPTO1","CONCEPTO2":"$CONCEPTO2","CONCEPTO3":"$CONCEPTO3","CONCEPTO4":"$CONCEPTO4","TIPO":"$TIPO(type:integer)","AREA":"$AREA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOM_TIPO" sqlType="STRING"/>
		<param name="NOM_EDIFICIO" sqlType="STRING"/>
		<param name="CODIGOINMUEBLE" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inmueblefacturacion/todosporcompania/pag">
		<call-query href="getInmueblefacturacionPagTodosporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOM_TIPO" query-param="NOM_TIPO"/>
			<with-param name="NOM_EDIFICIO" query-param="NOM_EDIFICIO"/>
			<with-param name="CODIGOINMUEBLE" query-param="CODIGOINMUEBLE"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInmueblefacturacionNumTodosporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CASE TIPO WHEN 1 THEN 'Local' WHEN 2 THEN 'Mezzanine' WHEN 3 THEN 'Bodega' WHEN 4 THEN 'Sótano' WHEN 5 THEN 'Oficina' WHEN 6 THEN 'Piso' WHEN 7 THEN 'Casa' WHEN 8 THEN 'Lote' WHEN 9 THEN 'Plazoleta' WHEN 10 THEN 'Galeria Bochica' WHEN 11 THEN 'Edificio' WHEN 12 THEN 'Terraza' WHEN 13 THEN 'Baño' WHEN 14 THEN 'Pasillo' WHEN 15 THEN 'Espacio' END NOM_TIPO, CASE EDIFICIO WHEN 1 THEN 'Ascensores' WHEN 2 THEN 'Pedregal' WHEN 3 THEN 'RTN' WHEN 4 THEN 'Bachue' WHEN 5 THEN 'RTS' WHEN 6 THEN 'Bochica' WHEN 7 THEN '0001' WHEN 8 THEN '0003' END NOM_EDIFICIO ,CODIGOINMUEBLE, DENOMINACION, CONCEPTO1, CONCEPTO2, CONCEPTO3,CONCEPTO4, TIPO, AREA FROM INMUEBLE_FACTURACION WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN NOM_TIPO IS NULL THEN ' ' ELSE UPPER(NOM_TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_TIPO), '%')) AND (CASE WHEN NOM_EDIFICIO IS NULL THEN ' ' ELSE UPPER(NOM_EDIFICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_EDIFICIO), '%')) AND (CASE WHEN CODIGOINMUEBLE IS NULL THEN ' ' ELSE UPPER(CODIGOINMUEBLE) END) LIKE UPPER(CONCAT(:CODIGOINMUEBLE, '%')) AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END) LIKE UPPER(CONCAT(:DENOMINACION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOM_TIPO" sqlType="STRING"/>
		<param name="NOM_EDIFICIO" sqlType="STRING"/>
		<param name="CODIGOINMUEBLE" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inmueblefacturacion/todosporcompania/num">
		<call-query href="getInmueblefacturacionNumTodosporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOM_TIPO" query-param="NOM_TIPO"/>
			<with-param name="NOM_EDIFICIO" query-param="NOM_EDIFICIO"/>
			<with-param name="CODIGOINMUEBLE" query-param="CODIGOINMUEBLE"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>

		</call-query>
	</resource>
	<query id="getInmueblefacturacionPagTodosporcompaniafinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CASE TIPO WHEN 1 THEN 'Local' WHEN 2 THEN 'Mezzanine' WHEN 3 THEN 'Bodega' WHEN 4 THEN 'Sótano' WHEN 5 THEN 'Oficina' WHEN 6 THEN 'Piso' WHEN 7 THEN 'Casa' WHEN 8 THEN 'Lote' WHEN 9 THEN 'Plazoleta' WHEN 10 THEN 'Galeria Bochica' WHEN 11 THEN 'Edificio' WHEN 12 THEN 'Terraza' WHEN 13 THEN 'Baño' WHEN 14 THEN 'Pasillo' WHEN 15 THEN 'Espacio' END TIPO, CASE EDIFICIO WHEN 1 THEN 'Ascensores' WHEN 2 THEN 'Pedregal' WHEN 3 THEN 'RTN' WHEN 4 THEN 'Bachue' WHEN 5 THEN 'RTS' WHEN 6 THEN 'Bochica' WHEN 7 THEN '0001' WHEN 8 THEN '0003' END EDIFICIO ,CODIGOINMUEBLE, DENOMINACION FROM INMUEBLE_FACTURACION WHERE COMPANIA = :COMPANIA AND CODIGOINMUEBLE BETWEEN :CODIGOINMUEBLEINCIAL AND 'ZZZZZZZZZZ') INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN EDIFICIO IS NULL THEN ' ' ELSE UPPER(EDIFICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:EDIFICIO), '%')) AND (CASE WHEN CODIGOINMUEBLE IS NULL THEN ' ' ELSE UPPER(CODIGOINMUEBLE) END) LIKE UPPER(CONCAT(:CODIGOINMUEBLE, '%')) AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END) LIKE UPPER(CONCAT(CONCAT('%',:DENOMINACION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","EDIFICIO":"$EDIFICIO","CODIGOINMUEBLE":"$CODIGOINMUEBLE","DENOMINACION":"$DENOMINACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINMUEBLEINCIAL" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="EDIFICIO" sqlType="STRING"/>
		<param name="CODIGOINMUEBLE" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inmueblefacturacion/todosporcompaniafinal/pag">
		<call-query href="getInmueblefacturacionPagTodosporcompaniafinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOINMUEBLEINCIAL" query-param="CODIGOINMUEBLEINCIAL"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="EDIFICIO" query-param="EDIFICIO"/>
			<with-param name="CODIGOINMUEBLE" query-param="CODIGOINMUEBLE"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
