	<query id="getInmueblefacturacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT INMUEBLE_FACTURACION.COMPANIA, INMUEBLE_FACTURACION.TIPO, INMUEBLE_FACTURACION.EDIFICIO, INMUEBLE_FACTURACION.CODIGOINMUEBLE, INMUEBLE_FACTURACION.UBICACION, INMUEBLE_FACTURACION.DENOMINACION, INMUEBLE_FACTURACION.DEPARTAMENTO, INMUEBLE_FACTURACION.CIUDAD, INMUEBLE_FACTURACION.AREA, INMUEBLE_FACTURACION.LINDERONORTE, INMUEBLE_FACTURACION.LINDEROSUR, INMUEBLE_FACTURACION.LINDEROORIENTE, INMUEBLE_FACTURACION.LINDEROOCCIDENTE, INMUEBLE_FACTURACION.LINDEROCENIT, INMUEBLE_FACTURACION.LINDERONADIR, INMUEBLE_FACTURACION.CONCEPTO1, SF_CONCEPTOS1.NOMBRE NOMCONCEPTO1, SF_CONCEPTOS1.VALOR_BASE VALORCONCEPTO1, INMUEBLE_FACTURACION.CONCEPTO2, SF_CONCEPTOS2.NOMBRE NOMCONCEPTO2, SF_CONCEPTOS2.VALOR_BASE VALORCONCEPTO2, INMUEBLE_FACTURACION.CONCEPTO3, SF_CONCEPTOS3.NOMBRE NOMCONCEPTO3, SF_CONCEPTOS3.VALOR_BASE VALORCONCEPTO3, INMUEBLE_FACTURACION.CONCEPTO4, SF_CONCEPTOS4.NOMBRE NOMCONCEPTO4, SF_CONCEPTOS4.VALOR_BASE VALORCONCEPTO4, INMUEBLE_FACTURACION.OBSERVACIONES, INMUEBLE_FACTURACION.DIRECCION,(CASE INMUEBLE_FACTURACION.COMERCIALIZABLE WHEN 0 THEN 'false' ELSE 'true' END) COMERCIALIZABLE,(CASE INMUEBLE_FACTURACION.DISPONIBLE WHEN 0 THEN 'false' ELSE 'true' END) DISPONIBLE,(CASE INMUEBLE_FACTURACION.ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,(CASE INMUEBLE_FACTURACION.ARRENDADO WHEN 0 THEN 'false' ELSE 'true' END) ARRENDADO, INMUEBLE_FACTURACION.CONCEPTO4, INMUEBLE_FACTURACION.CREATED_BY,(TO_CHAR(INMUEBLE_FACTURACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, INMUEBLE_FACTURACION.MODIFIED_BY,(TO_CHAR(INMUEBLE_FACTURACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, INMUEBLE_FACTURACION.RUTA_IMAGEN, INMUEBLE_FACTURACION.NOMBRE_IMAGEN, INMUEBLE_FACTURACION.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, TERCERO.SUCURSAL  FROM INMUEBLE_FACTURACION LEFT JOIN SF_CONCEPTOS SF_CONCEPTOS1 ON (SF_CONCEPTOS1.COMPANIA = INMUEBLE_FACTURACION.COMPANIA AND INMUEBLE_FACTURACION.CONCEPTO1 = SF_CONCEPTOS1.CODIGO) LEFT JOIN SF_CONCEPTOS SF_CONCEPTOS2 ON (SF_CONCEPTOS2.COMPANIA = INMUEBLE_FACTURACION.COMPANIA AND INMUEBLE_FACTURACION.CONCEPTO2 = SF_CONCEPTOS2.CODIGO) LEFT JOIN SF_CONCEPTOS SF_CONCEPTOS3 ON (SF_CONCEPTOS3.COMPANIA = INMUEBLE_FACTURACION.COMPANIA AND INMUEBLE_FACTURACION.CONCEPTO3 = SF_CONCEPTOS3.CODIGO) LEFT JOIN SF_CONCEPTOS SF_CONCEPTOS4 ON (SF_CONCEPTOS4.COMPANIA = INMUEBLE_FACTURACION.COMPANIA AND INMUEBLE_FACTURACION.CONCEPTO4 = SF_CONCEPTOS4.CODIGO) LEFT JOIN TERCERO ON INMUEBLE_FACTURACION.COMPANIA = TERCERO.COMPANIA AND INMUEBLE_FACTURACION.TERCERO = TERCERO.NIT AND INMUEBLE_FACTURACION.SUCURSAL = TERCERO.SUCURSAL WHERE INMUEBLE_FACTURACION.COMPANIA= :KEY_COMPANIA AND INMUEBLE_FACTURACION.CODIGOINMUEBLE= :KEY_CODIGOINMUEBLE AND INMUEBLE_FACTURACION.TIPO= :KEY_TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO(type:integer)","EDIFICIO":"$EDIFICIO(type:integer)","CODIGOINMUEBLE":"$CODIGOINMUEBLE","UBICACION":"$UBICACION(type:integer)","DENOMINACION":"$DENOMINACION","DEPARTAMENTO":"$DEPARTAMENTO(type:integer)","CIUDAD":"$CIUDAD(type:integer)","AREA":"$AREA(type:integer)","LINDERONORTE":"$LINDERONORTE","LINDEROSUR":"$LINDEROSUR","LINDEROORIENTE":"$LINDEROORIENTE","LINDEROOCCIDENTE":"$LINDEROOCCIDENTE","LINDEROCENIT":"$LINDEROCENIT","LINDERONADIR":"$LINDERONADIR","CONCEPTO1":"$CONCEPTO1","NOMCONCEPTO1":"$NOMCONCEPTO1","VALORCONCEPTO1":"$VALORCONCEPTO1","CONCEPTO2":"$CONCEPTO2","NOMCONCEPTO2":"$NOMCONCEPTO2","VALORCONCEPTO2":"$VALORCONCEPTO2","CONCEPTO3":"$CONCEPTO3","NOMCONCEPTO3":"$NOMCONCEPTO3","VALORCONCEPTO3":"$VALORCONCEPTO3","CONCEPTO4":"$CONCEPTO4","NOMCONCEPTO4":"$NOMCONCEPTO4","VALORCONCEPTO4":"$VALORCONCEPTO4","OBSERVACIONES":"$OBSERVACIONES","DIRECCION":"$DIRECCION","COMERCIALIZABLE":"$COMERCIALIZABLE(type:boolean)","DISPONIBLE":"$DISPONIBLE(type:boolean)","ACTIVO":"$ACTIVO(type:boolean)","ARRENDADO":"$ARRENDADO(type:boolean)","CONCEPTO4":"$CONCEPTO4","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","RUTA_IMAGEN":"$RUTA_IMAGEN","NOMBRE_IMAGEN":"$NOMBRE_IMAGEN","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOINMUEBLE" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inmueblefacturacion/data">
		<call-query href="getInmueblefacturacionRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOINMUEBLE" query-param="KEY_CODIGOINMUEBLE"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>

