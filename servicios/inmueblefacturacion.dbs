	<query id="updateInmueblefacturacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INMUEBLE_FACTURACION SET COMPANIA=:COMPANIA, TIPO=:TIPO, EDIFICIO=:EDIFICIO, CODIGOINMUEBLE=:CODIGOINMUEBLE, UBICACION=:UBICACION, DENOMINACION=:DENOMINACION, DEPARTAMENTO=:DEPARTAMENTO, CIUDAD=:CIUDAD, AREA=:AREA, LINDERONORTE=:LINDERONORTE, LINDEROSUR=:LINDEROSUR, LINDEROORIENTE=:LINDEROORIENTE, LINDEROOCCIDENTE=:LINDEROOCCIDENTE, LINDEROCENIT=:LINDEROCENIT, LINDERONADIR=:LINDERONADIR, CONCEPTO1=:CONCEPTO1, CONCEPTO2=:CONCEPTO2, CONCEPTO3=:CONCEPTO3, OBSERVACIONES=:OBSERVACIONES, DIRECCION=:DIRECCION, COMERCIALIZABLE=:COMERCIALIZABLE, DISPONIBLE=:DISPONIBLE, ACTIVO=:ACTIVO, ARRENDADO=:ARRENDADO, CONCEPTO4=:CONCEPTO4, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), RUTA_IMAGEN=:RUTA_IMAGEN, NOMBRE_IMAGEN=:NOMBRE_IMAGEN, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL WHERE INMUEBLE_FACTURACION.COMPANIA= :KEY_COMPANIA AND INMUEBLE_FACTURACION.CODIGOINMUEBLE= :KEY_CODIGOINMUEBLE AND INMUEBLE_FACTURACION.TIPO= :KEY_TIPO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="EDIFICIO" sqlType="STRING"/>
		<param name="CODIGOINMUEBLE" sqlType="STRING"/>
