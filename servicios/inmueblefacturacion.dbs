	<query id="getInmueblefacturacionPagTodosfinalporubicacionyterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CASE TIPO WHEN 1 THEN 'Local' WHEN 2 THEN 'Mezzanine' WHEN 3 THEN 'Bodega' WHEN 4 THEN 'Sótano' WHEN 5 THEN 'Oficina' WHEN 6 THEN 'Piso' WHEN 7 THEN 'Casa' WHEN 8 THEN 'Lote' WHEN 9 THEN 'Plazoleta' WHEN 10 THEN 'Galeria Bochica' WHEN 11 THEN 'Edificio' WHEN 12 THEN 'Terraza' WHEN 13 THEN 'Baño' WHEN 14 THEN 'Pasillo' WHEN 15 THEN 'Espacio' END TIPO, CASE EDIFICIO WHEN 1 THEN 'Ascensores' WHEN 2 THEN 'Pedregal' WHEN 3 THEN 'RTN' WHEN 4 THEN 'Bachue' WHEN 5 THEN 'RTS' WHEN 6 THEN 'Bochica' WHEN 7 THEN '0001' WHEN 8 THEN '0003' END EDIFICIO ,CODIGOINMUEBLE, DENOMINACION FROM INMUEBLE_FACTURACION WHERE COMPANIA = :COMPANIA AND CODIGOINMUEBLE BETWEEN :CODIGOINMUEBLEINCIAL AND 'ZZZZZZZZZZ' AND UBICACION BETWEEN :UBICACIONINICIAL AND :UBICACIONFINAL AND TERCERO BETWEEN :TERCEROINICIAL AND :TERCEROFINAL) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN EDIFICIO IS NULL THEN ' ' ELSE UPPER(EDIFICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:EDIFICIO), '%')) AND (CASE WHEN CODIGOINMUEBLE IS NULL THEN ' ' ELSE UPPER(CODIGOINMUEBLE) END) LIKE UPPER(CONCAT(:CODIGOINMUEBLE, '%')) AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END) LIKE UPPER(CONCAT(CONCAT('%',:DENOMINACION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","EDIFICIO":"$EDIFICIO","CODIGOINMUEBLE":"$CODIGOINMUEBLE","DENOMINACION":"$DENOMINACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINMUEBLEINCIAL" sqlType="STRING"/>
		<param name="UBICACIONINICIAL" sqlType="STRING"/>
		<param name="UBICACIONFINAL" sqlType="STRING"/>
