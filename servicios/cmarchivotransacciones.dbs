	<query id="getCmarchivotransaccionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT AF.COMPANIA, AF.CONSECUTIVO_RIPS, IR.RADICADO, AF.NUM_FACTURA, AF.COD_PREST_SERV_SALUD, AF.NOMBRE_RAZON_SOCIAL, AF.NUM_IDENTIF_PRESTADOR, AF.VALOR_TOT_PAGO_COMPARTIDO, AF.VALOR_COMISION, AF.VALOR_TOTAL_DESCUENTOS, AF.VALOR_NETO_A_PAGAR_ENTI_CONTR,(CASE AF.APROBADO WHEN 0 THEN 'false' ELSE 'true' END) APROBADO, AF.APROBADO_POR, TO_CHAR( AF.APROBADO_FECHA, 'DD/MM/YYYY' ) APROBADO_FECHA,(CASE AF.CAUSADO WHEN 0 THEN 'false' ELSE 'true' END) CAUSADO, AF.CAUSADO_POR, TO_CHAR( AF.CAUSADO_FECHA, 'DD/MM/YYYY' ) CAUSADO_FECHA, AF.COMPANIA_COMPROBANTE, AF.NUMERO_COMPROBANTE, CA.CODIGO COMPROBANTE, CA.TIPO_COMPROBANTE NOMBRE_TIPO_COMPROBANTE FROM CM_ARCHIVO_TRANSACCIONES AF INNER JOIN CM_IMPORTARRIPS IR ON IR.COMPANIA = AF.COMPANIA AND AF.CONSECUTIVO_RIPS = IR.CONSECUTIVO AND IR.ESTADO NOT IN ( 'P', 'F' ) LEFT JOIN CM_CAUSACION_AUTOMATICA CA ON CA.COMPANIA = AF.COMPANIA AND CA.TIPO_COMPROBANTE = AF.TIPO_COMPROBANTE WHERE AF.CONSECUTIVO_RIPS = :CONSECUTIVO) INI WHERE (CASE WHEN CONSECUTIVO_RIPS IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_RIPS) END) LIKE UPPER(CONCAT(:CONSECUTIVO_RIPS, '%')) AND (CASE WHEN RADICADO IS NULL THEN ' ' ELSE UPPER(RADICADO) END) LIKE UPPER(CONCAT(:RADICADO, '%')) AND (CASE WHEN NUM_FACTURA IS NULL THEN ' ' ELSE UPPER(NUM_FACTURA) END) LIKE UPPER(CONCAT(CONCAT('%',:NUM_FACTURA), '%')) AND (CASE WHEN COD_PREST_SERV_SALUD IS NULL THEN ' ' ELSE UPPER(COD_PREST_SERV_SALUD) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_PREST_SERV_SALUD), '%')) AND (CASE WHEN NOMBRE_RAZON_SOCIAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_RAZON_SOCIAL) END) LIKE UPPER(CONCAT(:NOMBRE_RAZON_SOCIAL, '%')) AND (CASE WHEN VALOR_TOT_PAGO_COMPARTIDO IS NULL THEN ' ' ELSE UPPER(VALOR_TOT_PAGO_COMPARTIDO) END) LIKE UPPER(CONCAT(:VALOR_TOT_PAGO_COMPARTIDO, '%')) AND (CASE WHEN VALOR_COMISION IS NULL THEN ' ' ELSE UPPER(VALOR_COMISION) END) LIKE UPPER(CONCAT(:VALOR_COMISION, '%')) AND (CASE WHEN VALOR_TOTAL_DESCUENTOS IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL_DESCUENTOS) END) LIKE UPPER(CONCAT(:VALOR_TOTAL_DESCUENTOS, '%')) AND (CASE WHEN VALOR_NETO_A_PAGAR_ENTI_CONTR IS NULL THEN ' ' ELSE UPPER(VALOR_NETO_A_PAGAR_ENTI_CONTR) END) LIKE UPPER(CONCAT(:VALOR_NETO_A_PAGAR_ENTI_CONTR, '%')) AND (CASE WHEN APROBADO IS NULL THEN ' ' ELSE UPPER(APROBADO) END) LIKE UPPER(CONCAT(CONCAT('%',:APROBADO), '%')) AND (CASE WHEN APROBADO_POR IS NULL THEN ' ' ELSE UPPER(APROBADO_POR) END) LIKE UPPER(CONCAT(:APROBADO_POR, '%')) AND (CASE WHEN APROBADO_FECHA IS NULL THEN ' ' ELSE UPPER(APROBADO_FECHA) END) LIKE UPPER(CONCAT(:APROBADO_FECHA, '%')) AND (CASE WHEN CAUSADO IS NULL THEN ' ' ELSE UPPER(CAUSADO) END) LIKE UPPER(CONCAT(CONCAT('%',:CAUSADO), '%')) AND (CASE WHEN CAUSADO_POR IS NULL THEN ' ' ELSE UPPER(CAUSADO_POR) END) LIKE UPPER(CONCAT(:CAUSADO_POR, '%')) AND (CASE WHEN CAUSADO_FECHA IS NULL THEN ' ' ELSE UPPER(CAUSADO_FECHA) END) LIKE UPPER(CONCAT(:CAUSADO_FECHA, '%')) AND (CASE WHEN COMPANIA_COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPANIA_COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA_COMPROBANTE), '%')) AND (CASE WHEN NUMERO_COMPROBANTE IS NULL THEN ' ' ELSE UPPER(NUMERO_COMPROBANTE) END) LIKE UPPER(CONCAT(:NUMERO_COMPROBANTE, '%')) AND (CASE WHEN NOMBRE_TIPO_COMPROBANTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO_COMPROBANTE) END) LIKE UPPER(CONCAT(:NOMBRE_TIPO_COMPROBANTE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
