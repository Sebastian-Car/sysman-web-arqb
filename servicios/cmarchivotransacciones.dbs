	<query id="updateCmarchivotransacciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_ARCHIVO_TRANSACCIONES SET COMPANIA=:COMPANIA, CONSECUTIVO_RIPS=:CONSECUTIVO_RIPS, NUM_FACTURA=:NUM_FACTURA, COD_PREST_SERV_SALUD=:COD_PREST_SERV_SALUD, NOMBRE_RAZON_SOCIAL=:NOMBRE_RAZON_SOCIAL, NUM_IDENTIF_PRESTADOR=:NUM_IDENTIF_PRESTADOR, VALOR_TOT_PAGO_COMPARTIDO=:VALOR_TOT_PAGO_COMPARTIDO, VALOR_COMISION=:VALOR_COMISION, VALOR_TOTAL_DESCUENTOS=:VALOR_TOTAL_DESCUENTOS, VALOR_NETO_A_PAGAR_ENTI_CONTR=:VALOR_NETO_A_PAGAR_ENTI_CONTR, APROBADO=:APROBADO, APROBADO_POR=:APROBADO_POR, APROBADO_FECHA=TO_DATE(:APROBADO_FECHA,'DD/MM/YYYY HH24:MI:SS'), CAUSADO=:CAUSADO, CAUSADO_POR=:CAUSADO_POR, CAUSADO_FECHA=TO_DATE(:CAUSADO_FECHA,'DD/MM/YYYY HH24:MI:SS'), COMPANIA_COMPROBANTE=:COMPANIA_COMPROBANTE, NUMERO_COMPROBANTE=:NUMERO_COMPROBANTE, TIPO_COMPROBANTE=:TIPO_COMPROBANTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CM_ARCHIVO_TRANSACCIONES.CONSECUTIVO_RIPS= :KEY_CONSECUTIVO_RIPS AND CM_ARCHIVO_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND CM_ARCHIVO_TRANSACCIONES.COD_PREST_SERV_SALUD= :KEY_COD_PREST_SERV_SALUD AND CM_ARCHIVO_TRANSACCIONES.NUM_FACTURA= :KEY_NUM_FACTURA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

