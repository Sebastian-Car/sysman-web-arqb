<data name="pagoestampilla" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPagoestampillaExistepagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) CUENTA  FROM PAGO_ESTAMPILLAS WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :TIPOCONTRATO AND NUMERO = :NUMEROCONTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pagoestampilla/existepago">
		<call-query href="getPagoestampillaExistepagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>

		</call-query>
	</resource>
	<query id="insertPagoestampillaPagovacio" keyColumns="COMPANIA,CLASEORDEN,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PAGO_ESTAMPILLAS (COMPANIA, CLASEORDEN, NUMERO, VALOR_PROCULTURA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :NUMERO, :VALOR_PROCULTURA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROCULTURA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="pagoestampilla/pagovacio">
		<call-query href="insertPagoestampillaPagovacio">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALOR_PROCULTURA" query-param="VALOR_PROCULTURA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getPagoestampillaPagadeporteporcontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE PAGAPRODEPORTE WHEN 0 THEN 'false' ELSE 'true' END) PAGAPRODEPORTE FROM PAGO_ESTAMPILLAS WHERE PAGO_ESTAMPILLAS.COMPANIA = :COMPANIA AND PAGO_ESTAMPILLAS.CLASEORDEN = :TIPOCONTRATO AND PAGO_ESTAMPILLAS.NUMERO = :NUMEROCONTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAGAPRODEPORTE":"$PAGAPRODEPORTE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pagoestampilla/pagadeporteporcontrato">
		<call-query href="getPagoestampillaPagadeporteporcontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>

		</call-query>
	</resource>
	<query id="insertPagoestampilla" keyColumns="COMPANIA,CLASEORDEN,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PAGO_ESTAMPILLAS (COMPANIA, CLASEORDEN, NUMERO, PAGAPRODEPORTE, VALOR_PROCULTURA, NOING_PROCULTURA, VALOR_PROADULTOMAYOR, NOING_PROADULTOMAYOR, VALOR_PRODEPORTE, NOING_PRODEPORTE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :NUMERO, :PAGAPRODEPORTE, :VALOR_PROCULTURA, :NOING_PROCULTURA, :VALOR_PROADULTOMAYOR, :NOING_PROADULTOMAYOR, :VALOR_PRODEPORTE, :NOING_PRODEPORTE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="PAGAPRODEPORTE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROCULTURA" sqlType="STRING"/>
		<param defaultValue="0" name="NOING_PROCULTURA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROADULTOMAYOR" sqlType="STRING"/>
		<param defaultValue="0" name="NOING_PROADULTOMAYOR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PRODEPORTE" sqlType="STRING"/>
		<param defaultValue="0" name="NOING_PRODEPORTE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="pagoestampilla">
		<call-query href="insertPagoestampilla">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGAPRODEPORTE" query-param="PAGAPRODEPORTE"/>
			<with-param name="VALOR_PROCULTURA" query-param="VALOR_PROCULTURA"/>
			<with-param name="NOING_PROCULTURA" query-param="NOING_PROCULTURA"/>
			<with-param name="VALOR_PROADULTOMAYOR" query-param="VALOR_PROADULTOMAYOR"/>
			<with-param name="NOING_PROADULTOMAYOR" query-param="NOING_PROADULTOMAYOR"/>
			<with-param name="VALOR_PRODEPORTE" query-param="VALOR_PRODEPORTE"/>
			<with-param name="NOING_PRODEPORTE" query-param="NOING_PRODEPORTE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getPagoestampillaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,CLASEORDEN,NUMERO,(CASE PAGAPRODEPORTE WHEN 0 THEN 'false' ELSE 'true' END) PAGAPRODEPORTE,VALOR_PROCULTURA,NOING_PROCULTURA,VALOR_PROADULTOMAYOR, NOING_PROADULTOMAYOR,VALOR_PRODEPORTE,NOING_PRODEPORTE  FROM PAGO_ESTAMPILLAS WHERE PAGO_ESTAMPILLAS.COMPANIA= :KEY_COMPANIA AND PAGO_ESTAMPILLAS.CLASEORDEN= :KEY_CLASEORDEN AND PAGO_ESTAMPILLAS.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO(type:long)","PAGAPRODEPORTE":"$PAGAPRODEPORTE(type:boolean)","VALOR_PROCULTURA":"$VALOR_PROCULTURA(type:double)","NOING_PROCULTURA":"$NOING_PROCULTURA(type:double)","VALOR_PROADULTOMAYOR":"$VALOR_PROADULTOMAYOR(type:double)","NOING_PROADULTOMAYOR":"$NOING_PROADULTOMAYOR(type:double)","VALOR_PRODEPORTE":"$VALOR_PRODEPORTE(type:double)","NOING_PRODEPORTE":"$NOING_PRODEPORTE(type:double)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="pagoestampilla/data">
		<call-query href="getPagoestampillaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updatePagoestampilla" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PAGO_ESTAMPILLAS SET PAGAPRODEPORTE=:PAGAPRODEPORTE, VALOR_PROCULTURA=:VALOR_PROCULTURA, NOING_PROCULTURA=:NOING_PROCULTURA, VALOR_PROADULTOMAYOR=:VALOR_PROADULTOMAYOR, NOING_PROADULTOMAYOR=:NOING_PROADULTOMAYOR, VALOR_PRODEPORTE=:VALOR_PRODEPORTE, NOING_PRODEPORTE=:NOING_PRODEPORTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PAGO_ESTAMPILLAS.COMPANIA= :KEY_COMPANIA AND PAGO_ESTAMPILLAS.CLASEORDEN= :KEY_CLASEORDEN AND PAGO_ESTAMPILLAS.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAGAPRODEPORTE" sqlType="STRING"/>
		<param name="VALOR_PROCULTURA" sqlType="STRING"/>
		<param name="NOING_PROCULTURA" sqlType="STRING"/>
		<param name="VALOR_PROADULTOMAYOR" sqlType="STRING"/>
		<param name="NOING_PROADULTOMAYOR" sqlType="STRING"/>
		<param name="VALOR_PRODEPORTE" sqlType="STRING"/>
		<param name="NOING_PRODEPORTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="pagoestampilla">
		<call-query href="updatePagoestampilla">
			<with-param name="PAGAPRODEPORTE" query-param="PAGAPRODEPORTE"/>
			<with-param name="VALOR_PROCULTURA" query-param="VALOR_PROCULTURA"/>
			<with-param name="NOING_PROCULTURA" query-param="NOING_PROCULTURA"/>
			<with-param name="VALOR_PROADULTOMAYOR" query-param="VALOR_PROADULTOMAYOR"/>
			<with-param name="NOING_PROADULTOMAYOR" query-param="NOING_PROADULTOMAYOR"/>
			<with-param name="VALOR_PRODEPORTE" query-param="VALOR_PRODEPORTE"/>
			<with-param name="NOING_PRODEPORTE" query-param="NOING_PRODEPORTE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>

</data>