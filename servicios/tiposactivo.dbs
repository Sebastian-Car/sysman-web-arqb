<data name="tiposactivo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTiposactivoTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPO_ACTIVO.CODIGO_TIPOACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO  FROM TIPO_ACTIVO WHERE TIPO_ACTIVO.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_TIPOACTIVO":"$CODIGO_TIPOACTIVO","NOMBRE_TIPOACTIVO":"$NOMBRE_TIPOACTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposactivo/todos">
		<call-query href="getTiposactivoTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTiposactivoPagPorcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPO_ACTIVO.CODIGO_TIPOACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO  FROM TIPO_ACTIVO WHERE TIPO_ACTIVO.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(CODIGO_TIPOACTIVO) END)  LIKE UPPER(:CODIGO_TIPOACTIVO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOACTIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_TIPOACTIVO":"$CODIGO_TIPOACTIVO","NOMBRE_TIPOACTIVO":"$NOMBRE_TIPOACTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_TIPOACTIVO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposactivo/porcompania/pag">
		<call-query href="getTiposactivoPagPorcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_TIPOACTIVO" query-param="CODIGO_TIPOACTIVO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposactivoNumPorcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPO_ACTIVO.CODIGO_TIPOACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO  FROM TIPO_ACTIVO WHERE TIPO_ACTIVO.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(CODIGO_TIPOACTIVO) END)  LIKE UPPER(:CODIGO_TIPOACTIVO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOACTIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_TIPOACTIVO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposactivo/porcompania/num">
		<call-query href="getTiposactivoNumPorcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_TIPOACTIVO" query-param="CODIGO_TIPOACTIVO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>

		</call-query>
	</resource>
	<query id="getTiposactivoPagTipoactivonombrecodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO_TIPOACTIVO, NOMBRE_TIPOACTIVO  FROM TIPO_ACTIVO WHERE COMPANIA = :COMPANIA AND DEPRECIA NOT IN 0) WHERE (CASE WHEN CODIGO_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(CODIGO_TIPOACTIVO) END)  LIKE UPPER(:CODIGO_TIPOACTIVO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOACTIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_TIPOACTIVO":"$CODIGO_TIPOACTIVO","NOMBRE_TIPOACTIVO":"$NOMBRE_TIPOACTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_TIPOACTIVO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposactivo/tipoactivonombrecodigo/pag">
		<call-query href="getTiposactivoPagTipoactivonombrecodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_TIPOACTIVO" query-param="CODIGO_TIPOACTIVO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposactivoNumTipoactivonombrecodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO_TIPOACTIVO, NOMBRE_TIPOACTIVO  FROM TIPO_ACTIVO WHERE COMPANIA = :COMPANIA AND DEPRECIA NOT IN 0) WHERE (CASE WHEN CODIGO_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(CODIGO_TIPOACTIVO) END)  LIKE UPPER(:CODIGO_TIPOACTIVO || '%')  AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOACTIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_TIPOACTIVO" sqlType="STRING"/>
		<param name="NOMBRE_TIPOACTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposactivo/tipoactivonombrecodigo/num">
		<call-query href="getTiposactivoNumTipoactivonombrecodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_TIPOACTIVO" query-param="CODIGO_TIPOACTIVO"/>
			<with-param name="NOMBRE_TIPOACTIVO" query-param="NOMBRE_TIPOACTIVO"/>

		</call-query>
	</resource>

</data>