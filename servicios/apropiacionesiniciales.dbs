	<query id="getApropiacionesinicialesCentrocostoporcuentaanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CENTRO_COSTO  FROM APROPIACIONESINICIALES WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CODIGO = :CODCUENTA AND CENTRO_COSTO &lt;&gt; :CENTROCOSTOEXCLUIDO</sql>
