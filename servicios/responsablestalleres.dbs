<data name="responsablestalleres" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getResponsablestalleresPagNitYNombrePorTallerQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  RESPONSABLES_TALLERES.NIT, RESPONSABLES_TALLERES.NOMBRE, RESPONSABLES_TALLERES.SUCURSAL, RESPONSABLES_TALLERES.SUCURSAL_TALLER  FROM RESPONSABLES_TALLERES WHERE RESPONSABLES_TALLERES.TALLER = :TALLER AND RESPONSABLES_TALLERES.COMPANIA = :COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","SUCURSAL_TALLER":"$SUCURSAL_TALLER"}]}}		</result>
		<param name="TALLER" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="responsablestalleres/nitynombreportaller/pag">
		<call-query href="getResponsablestalleresPagNitYNombrePorTallerQuery">
			<with-param name="TALLER" query-param="TALLER"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getResponsablestalleresNumNitYNombrePorTallerQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  RESPONSABLES_TALLERES.NIT, RESPONSABLES_TALLERES.NOMBRE, RESPONSABLES_TALLERES.SUCURSAL, RESPONSABLES_TALLERES.SUCURSAL_TALLER  FROM RESPONSABLES_TALLERES WHERE RESPONSABLES_TALLERES.TALLER = :TALLER AND RESPONSABLES_TALLERES.COMPANIA = :COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TALLER" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="responsablestalleres/nitynombreportaller/num">
		<call-query href="getResponsablestalleresNumNitYNombrePorTallerQuery">
			<with-param name="TALLER" query-param="TALLER"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getResponsablestalleresCantidadDeTalleresPorNitQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM RESPONSABLES_TALLERES WHERE COMPANIA= :COMPANIA AND NIT= :NIT AND SUCURSAL= :SUCURSAL AND TALLER= :TALLER AND SUCURSAL_TALLER= :SUCURSALTALLER</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TALLER" sqlType="STRING"/>
		<param name="SUCURSALTALLER" sqlType="STRING"/>

	</query>
	<resource method="GET" path="responsablestalleres/cantidaddetallerespornit">
		<call-query href="getResponsablestalleresCantidadDeTalleresPorNitQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TALLER" query-param="TALLER"/>
			<with-param name="SUCURSALTALLER" query-param="SUCURSALTALLER"/>

		</call-query>
	</resource>
	<query id="insertResponsablestalleresRespDmantenimiento" keyColumns="COMPANIA,NIT,SUCURSAL,TALLER,SUCURSAL_TALLER" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO RESPONSABLES_TALLERES (COMPANIA, NIT, SUCURSAL, NOMBRE, TALLER, SUCURSAL_TALLER, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NIT, :SUCURSAL, :NOMBRE, :TALLER, :SUCURSAL_TALLER, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT","KEY_SUCURSAL":"$SUCURSAL","KEY_TALLER":"$TALLER","KEY_SUCURSAL_TALLER":"$SUCURSAL_TALLER"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TALLER" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_TALLER" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="responsablestalleres/respdmantenimiento">
		<call-query href="insertResponsablestalleresRespDmantenimiento">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TALLER" query-param="TALLER"/>
			<with-param name="SUCURSAL_TALLER" query-param="SUCURSAL_TALLER"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getResponsablestalleresTalleresParaMantenimientosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  RESPONSABLES_TALLERES.COMPANIA, RESPONSABLES_TALLERES.NIT, RESPONSABLES_TALLERES.TALLER, RESPONSABLES_TALLERES.NOMBRE, RESPONSABLES_TALLERES.SUCURSAL, RESPONSABLES_TALLERES.SUCURSAL_TALLER  FROM RESPONSABLES_TALLERES WHERE COMPANIA = :COMPANIA AND TALLER = :TALLER AND SUCURSAL_TALLER= :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","TALLER":"$TALLER","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","SUCURSAL_TALLER":"$SUCURSAL_TALLER"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TALLER" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="responsablestalleres/talleresparamantenimientos">
		<call-query href="getResponsablestalleresTalleresParaMantenimientosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TALLER" query-param="TALLER"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="insertResponsablestalleres" keyColumns="COMPANIA,NIT,SUCURSAL,TALLER,SUCURSAL_TALLER" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO RESPONSABLES_TALLERES (COMPANIA, NIT, TALLER, NOMBRE, SUCURSAL, SUCURSAL_TALLER, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NIT, :TALLER, :NOMBRE, :SUCURSAL, :SUCURSAL_TALLER, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT","KEY_SUCURSAL":"$SUCURSAL","KEY_TALLER":"$TALLER","KEY_SUCURSAL_TALLER":"$SUCURSAL_TALLER"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TALLER" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_TALLER" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="responsablestalleres">
		<call-query href="insertResponsablestalleres">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="TALLER" query-param="TALLER"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="SUCURSAL_TALLER" query-param="SUCURSAL_TALLER"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteResponsablestalleres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM RESPONSABLES_TALLERES WHERE RESPONSABLES_TALLERES.COMPANIA= :KEY_COMPANIA AND RESPONSABLES_TALLERES.NIT= :KEY_NIT AND RESPONSABLES_TALLERES.SUCURSAL= :KEY_SUCURSAL AND RESPONSABLES_TALLERES.TALLER= :KEY_TALLER AND RESPONSABLES_TALLERES.SUCURSAL_TALLER= :KEY_SUCURSAL_TALLER</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_TALLER" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_TALLER" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="responsablestalleres">
		<call-query href="deleteResponsablestalleres">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_TALLER" query-param="KEY_TALLER"/>
			<with-param name="KEY_SUCURSAL_TALLER" query-param="KEY_SUCURSAL_TALLER"/>

		</call-query>
	</resource>
	<query id="updateResponsablestalleres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RESPONSABLES_TALLERES SET NIT=:NIT, TALLER=:TALLER, NOMBRE=:NOMBRE, SUCURSAL=:SUCURSAL, SUCURSAL_TALLER=:SUCURSAL_TALLER, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE RESPONSABLES_TALLERES.COMPANIA= :KEY_COMPANIA AND RESPONSABLES_TALLERES.NIT= :KEY_NIT AND RESPONSABLES_TALLERES.SUCURSAL= :KEY_SUCURSAL AND RESPONSABLES_TALLERES.TALLER= :KEY_TALLER AND RESPONSABLES_TALLERES.SUCURSAL_TALLER= :KEY_SUCURSAL_TALLER</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NIT" sqlType="STRING"/>
		<param name="TALLER" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="SUCURSAL_TALLER" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_TALLER" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_TALLER" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="responsablestalleres">
		<call-query href="updateResponsablestalleres">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="TALLER" query-param="TALLER"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="SUCURSAL_TALLER" query-param="SUCURSAL_TALLER"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_TALLER" query-param="KEY_TALLER"/>
			<with-param name="KEY_SUCURSAL_TALLER" query-param="KEY_SUCURSAL_TALLER"/>

		</call-query>
	</resource>

</data>