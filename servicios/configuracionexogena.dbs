<data name="configuracionexogena" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConfiguracionexogenaValidarCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA KEY_COMPANIA ,ANO KEY_ANO,FORMATO KEY_FORMATO,CONCEPTO KEY_CONCEPTO,CUENTA KEY_CUENTA,CLASE_EXOGENA  FROM CONFIGURACION_EXOGENA WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND FORMATO = :FORMATO AND CONCEPTO = :CONCEPTO AND CUENTA = :CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$KEY_COMPANIA","KEY_ANO":"$KEY_ANO(type:integer)","KEY_FORMATO":"$KEY_FORMATO","KEY_CONCEPTO":"$KEY_CONCEPTO","KEY_CUENTA":"$KEY_CUENTA","CLASE_EXOGENA":"$CLASE_EXOGENA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuracionexogena/validarcuenta">
		<call-query href="getConfiguracionexogenaValidarCuentaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="insertConfiguracionexogena" keyColumns="COMPANIA,ANO,FORMATO,CONCEPTO,CUENTA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONFIGURACION_EXOGENA (COMPANIA, ANO, FORMATO, CONCEPTO, CUENTA, CLASE_EXOGENA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :FORMATO, :CONCEPTO, :CUENTA, :CLASE_EXOGENA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_FORMATO":"$FORMATO","KEY_CONCEPTO":"$CONCEPTO","KEY_CUENTA":"$CUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CLASE_EXOGENA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="configuracionexogena">
		<call-query href="insertConfiguracionexogena">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="CLASE_EXOGENA" query-param="CLASE_EXOGENA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConfiguracionexogena" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONFIGURACION_EXOGENA WHERE CONFIGURACION_EXOGENA.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_EXOGENA.ANO= :KEY_ANO AND CONFIGURACION_EXOGENA.FORMATO= :KEY_FORMATO AND CONFIGURACION_EXOGENA.CONCEPTO= :KEY_CONCEPTO AND CONFIGURACION_EXOGENA.CUENTA= :KEY_CUENTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_FORMATO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="configuracionexogena">
		<call-query href="deleteConfiguracionexogena">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_FORMATO" query-param="KEY_FORMATO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>

		</call-query>
	</resource>
	<query id="updateConfiguracionexogena" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONFIGURACION_EXOGENA SET CONCEPTO=:CONCEPTO, CLASE_EXOGENA=:CLASE_EXOGENA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONFIGURACION_EXOGENA.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_EXOGENA.ANO= :KEY_ANO AND CONFIGURACION_EXOGENA.FORMATO= :KEY_FORMATO AND CONFIGURACION_EXOGENA.CONCEPTO= :KEY_CONCEPTO AND CONFIGURACION_EXOGENA.CUENTA= :KEY_CUENTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CLASE_EXOGENA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_FORMATO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="configuracionexogena">
		<call-query href="updateConfiguracionexogena">
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CLASE_EXOGENA" query-param="CLASE_EXOGENA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_FORMATO" query-param="KEY_FORMATO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>

		</call-query>
	</resource>

</data>