<data name="piplanadquisicionesvigencia" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertPiplanadquisicionesvigenciaPlanDeAccion" keyColumns="COMPANIA,TIPO,NUMERO,VIGENCIA_INICIAL,ID_PLAN,CODIGO,VIGENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PI_PLAN_ADQUISICIONES_VIGENCIA (COMPANIA, TIPO, NUMERO, VIGENCIA_INICIAL, ID_PLAN, CODIGO, VIGENCIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :NUMERO, :VIGENCIA_INICIAL, :ID_PLAN, :CODIGO, :VIGENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_CODIGO":"$CODIGO(type:integer)","KEY_VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="piplanadquisicionesvigencia/plandeaccion">
		<call-query href="insertPiplanadquisicionesvigenciaPlanDeAccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getPiplanadquisicionesvigenciaExistenVigenciasAsignadasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM PI_PLAN_ADQUISICIONES_VIGENCIA WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND NUMERO = :NUMERO AND VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND ID_PLAN = :ID_PLAN AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanadquisicionesvigencia/existenvigenciasasignadas">
		<call-query href="getPiplanadquisicionesvigenciaExistenVigenciasAsignadasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getPiplanadquisicionesvigenciaPagValorEstimadoVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PI_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA, PI_PLAN_ADQUISICIONES_VIGENCIA.TIPO, PI_PLAN_ADQUISICIONES_VIGENCIA.NUMERO, PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL, PI_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN, PI_PLAN_ADQUISICIONES_VIGENCIA.CODIGO, PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA, PI_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO_FIN, PI_PLAN_ADQUISICIONES_VIGENCIA.VALOR_EJECUTADO_FIN  FROM PI_PLAN_ADQUISICIONES_VIGENCIA WHERE PI_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA = :COMPANIA AND PI_PLAN_ADQUISICIONES_VIGENCIA.TIPO = :TIPO AND PI_PLAN_ADQUISICIONES_VIGENCIA.NUMERO = :NUMERO AND PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND PI_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN = :ID_PLAN AND PI_PLAN_ADQUISICIONES_VIGENCIA.CODIGO = :CODIGO) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%')  AND (CASE WHEN VALOR_ESTIMADO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_ESTIMADO_FIN) END)  LIKE UPPER( '%' || :VALOR_ESTIMADO_FIN || '%')  AND (CASE WHEN VALOR_EJECUTADO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_FIN) END)  LIKE UPPER( '%' || :VALOR_EJECUTADO_FIN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","ID_PLAN":"$ID_PLAN","CODIGO":"$CODIGO(type:integer)","VIGENCIA":"$VIGENCIA(type:integer)","VALOR_ESTIMADO_FIN":"$VALOR_ESTIMADO_FIN","VALOR_EJECUTADO_FIN":"$VALOR_EJECUTADO_FIN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO_FIN" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_FIN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piplanadquisicionesvigencia/valorestimadovigencia/pag">
		<call-query href="getPiplanadquisicionesvigenciaPagValorEstimadoVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALOR_ESTIMADO_FIN" query-param="VALOR_ESTIMADO_FIN"/>
			<with-param name="VALOR_EJECUTADO_FIN" query-param="VALOR_EJECUTADO_FIN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPiplanadquisicionesvigenciaNumValorEstimadoVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PI_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA, PI_PLAN_ADQUISICIONES_VIGENCIA.TIPO, PI_PLAN_ADQUISICIONES_VIGENCIA.NUMERO, PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL, PI_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN, PI_PLAN_ADQUISICIONES_VIGENCIA.CODIGO, PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA, PI_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO_FIN, PI_PLAN_ADQUISICIONES_VIGENCIA.VALOR_EJECUTADO_FIN  FROM PI_PLAN_ADQUISICIONES_VIGENCIA WHERE PI_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA = :COMPANIA AND PI_PLAN_ADQUISICIONES_VIGENCIA.TIPO = :TIPO AND PI_PLAN_ADQUISICIONES_VIGENCIA.NUMERO = :NUMERO AND PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND PI_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN = :ID_PLAN AND PI_PLAN_ADQUISICIONES_VIGENCIA.CODIGO = :CODIGO) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%')  AND (CASE WHEN VALOR_ESTIMADO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_ESTIMADO_FIN) END)  LIKE UPPER( '%' || :VALOR_ESTIMADO_FIN || '%')  AND (CASE WHEN VALOR_EJECUTADO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_FIN) END)  LIKE UPPER( '%' || :VALOR_EJECUTADO_FIN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO_FIN" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_FIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanadquisicionesvigencia/valorestimadovigencia/num">
		<call-query href="getPiplanadquisicionesvigenciaNumValorEstimadoVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALOR_ESTIMADO_FIN" query-param="VALOR_ESTIMADO_FIN"/>
			<with-param name="VALOR_EJECUTADO_FIN" query-param="VALOR_EJECUTADO_FIN"/>

		</call-query>
	</resource>
	<query id="insertPiplanadquisicionesvigenciaValorEstimadoVigencia" keyColumns="COMPANIA,TIPO,NUMERO,VIGENCIA_INICIAL,ID_PLAN,CODIGO,VIGENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PI_PLAN_ADQUISICIONES_VIGENCIA (COMPANIA, TIPO, NUMERO, VIGENCIA_INICIAL, ID_PLAN, CODIGO, VIGENCIA, VALOR_ESTIMADO_FIN, VALOR_EJECUTADO_FIN, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :NUMERO, :VIGENCIA_INICIAL, :ID_PLAN, :CODIGO, :VIGENCIA, :VALOR_ESTIMADO_FIN, :VALOR_EJECUTADO_FIN, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_CODIGO":"$CODIGO(type:integer)","KEY_VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_ESTIMADO_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_EJECUTADO_FIN" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="piplanadquisicionesvigencia/valorestimadovigencia">
		<call-query href="insertPiplanadquisicionesvigenciaValorEstimadoVigencia">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALOR_ESTIMADO_FIN" query-param="VALOR_ESTIMADO_FIN"/>
			<with-param name="VALOR_EJECUTADO_FIN" query-param="VALOR_EJECUTADO_FIN"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updatePiplanadquisicionesvigenciaValorEstimadoVigencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_PLAN_ADQUISICIONES_VIGENCIA SET TIPO=:TIPO, NUMERO=:NUMERO, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, ID_PLAN=:ID_PLAN, CODIGO=:CODIGO, VIGENCIA=:VIGENCIA, VALOR_ESTIMADO_FIN=:VALOR_ESTIMADO_FIN, VALOR_EJECUTADO_FIN=:VALOR_EJECUTADO_FIN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA= :KEY_COMPANIA AND PI_PLAN_ADQUISICIONES_VIGENCIA.TIPO= :KEY_TIPO AND PI_PLAN_ADQUISICIONES_VIGENCIA.NUMERO= :KEY_NUMERO AND PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN= :KEY_ID_PLAN AND PI_PLAN_ADQUISICIONES_VIGENCIA.CODIGO= :KEY_CODIGO AND PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA= :KEY_VIGENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO_FIN" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_FIN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="piplanadquisicionesvigencia/valorestimadovigencia">
		<call-query href="updatePiplanadquisicionesvigenciaValorEstimadoVigencia">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VALOR_ESTIMADO_FIN" query-param="VALOR_ESTIMADO_FIN"/>
			<with-param name="VALOR_EJECUTADO_FIN" query-param="VALOR_EJECUTADO_FIN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getPiplanadquisicionesvigenciaTotalesEstimadoEjecutadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(PI_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO_FIN)ESTIMADO , SUM(PI_PLAN_ADQUISICIONES_VIGENCIA.VALOR_EJECUTADO_FIN) EJECUTADO  FROM PI_PLAN_ADQUISICIONES_VIGENCIA WHERE PI_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA = :COMPANIA AND PI_PLAN_ADQUISICIONES_VIGENCIA.TIPO = :TIPO AND PI_PLAN_ADQUISICIONES_VIGENCIA.NUMERO = :NUMERO AND PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL = :VIGENCIA_INICIAL AND PI_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN = :ID_PLAN AND PI_PLAN_ADQUISICIONES_VIGENCIA.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTIMADO":"$ESTIMADO(type:integer)","EJECUTADO":"$EJECUTADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanadquisicionesvigencia/totalesestimadoejecutado">
		<call-query href="getPiplanadquisicionesvigenciaTotalesEstimadoEjecutadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="deletePiplanadquisicionesvigencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PI_PLAN_ADQUISICIONES_VIGENCIA WHERE PI_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA= :KEY_COMPANIA AND PI_PLAN_ADQUISICIONES_VIGENCIA.TIPO= :KEY_TIPO AND PI_PLAN_ADQUISICIONES_VIGENCIA.NUMERO= :KEY_NUMERO AND PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN= :KEY_ID_PLAN AND PI_PLAN_ADQUISICIONES_VIGENCIA.CODIGO= :KEY_CODIGO AND PI_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA= :KEY_VIGENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="INTEGER"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="piplanadquisicionesvigencia">
		<call-query href="deletePiplanadquisicionesvigencia">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>

		</call-query>
	</resource>

</data>