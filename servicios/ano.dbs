<data name="ano" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getAniosActivos"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM ANO WHERE COMPANIA=:compania AND PCK_SYSMAN_UTL.FC_VERIFICAR_ESTADOANO(COMPANIA,NUMERO,3,1) IN ('A') ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"numero":"$NUMERO"}]}}		</result>
		<param name="compania" sqlType="STRING"/>
	</query>
	<resource method="GET" path="activo">
		<call-query href="getAniosActivos">
			<with-param name="compania" query-param="compania"/>
		</call-query>
	</resource>

</data>