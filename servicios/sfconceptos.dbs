		</call-query>
	</resource>
	<query id="deleteSfconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_CONCEPTOS WHERE SF_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_CONCEPTOS.ANO= :KEY_ANO AND SF_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfconceptos">
		<call-query href="deleteSfconceptos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSfconceptosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_CONCEPTOS.COMPANIA, SF_CONCEPTOS.ANO, SF_CONCEPTOS.TIPOCOBRO, SF_CONCEPTOS.CODIGO, SF_CONCEPTOS.NOMBRE FROM SF_CONCEPTOS WHERE SF_CONCEPTOS.COMPANIA = :COMPANIA AND SF_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO AND SF_CONCEPTOS.ANO = :ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPOCOBRO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCOBRO), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfconceptos">
		<call-query href="getSfconceptosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfconceptosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_CONCEPTOS.COMPANIA, SF_CONCEPTOS.ANO, SF_CONCEPTOS.TIPOCOBRO, SF_CONCEPTOS.CODIGO, SF_CONCEPTOS.NOMBRE FROM SF_CONCEPTOS WHERE SF_CONCEPTOS.COMPANIA = :COMPANIA AND SF_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO AND SF_CONCEPTOS.ANO = :ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPOCOBRO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCOBRO), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptos/numero">
		<call-query href="getSfconceptosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSfconceptosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_CONCEPTOS.COMPANIA, SF_CONCEPTOS.ANO, SF_CONCEPTOS.TIPOCOBRO, SF_CONCEPTOS.CODIGO, SF_CONCEPTOS.NOMBRE, SF_CONCEPTOS.VALOR_COMPRA, SF_CONCEPTOS.VALOR_BASE, SF_CONCEPTOS.UNIDAD,(CASE SF_CONCEPTOS.APLICAIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICAIVA, SF_CONCEPTOS.PORCENTAJEIVA,(CASE SF_CONCEPTOS.APLICARETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEFUENTE, SF_CONCEPTOS.PORCENTAJERETEFUENTE,(CASE SF_CONCEPTOS.APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, SF_CONCEPTOS.PORCENTAJEDESCUENTO,(CASE SF_CONCEPTOS.APLICAICA WHEN 0 THEN 'false' ELSE 'true' END) APLICAICA, SF_CONCEPTOS.PORCENTAJEICA,(CASE SF_CONCEPTOS.APLICAFORMULA WHEN 0 THEN 'false' ELSE 'true' END) APLICAFORMULA, SF_CONCEPTOS.FORMULA, SF_CONCEPTOS.TIPODECONCEPTO,(CASE SF_CONCEPTOS.PERMITEMODIFICARVALOR WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARVALOR,(CASE SF_CONCEPTOS.AFECTAINVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAINVENTARIO, SF_CONCEPTOS.CODIGOINVENTARIO,(CASE SF_CONCEPTOS.PERMITEMODIFICARCANTIDAD WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARCANTIDAD, SF_CONCEPTOS.CUENTADEBITOBASE, SF_CONCEPTOS.CUENTACREDITOBASE, SF_CONCEPTOS.CUENTADEBITOIVA, SF_CONCEPTOS.CUENTACREDITOIVA, SF_CONCEPTOS.CUENTADEBITORETE, SF_CONCEPTOS.CUENTACREDITORETE, SF_CONCEPTOS.CUENTADEBITODESCUENTO, SF_CONCEPTOS.CUENTACREDITODESCUENTO, SF_CONCEPTOS.CUENTADEBITOICA, SF_CONCEPTOS.CUENTACREDITOICA, SF_CONCEPTOS.CUENTADEBITOUTILIDAD, SF_CONCEPTOS.CUENTACREDITOUTILIDAD, SF_CONCEPTOS.CUENTADEBITOBASE_AV, SF_CONCEPTOS.CUENTACREDITOBASE_AV, SF_CONCEPTOS.CUENTADEBITOIVA_AV, SF_CONCEPTOS.CUENTACREDITOIVA_AV, SF_CONCEPTOS.CUENTADEBITORETE_AV, SF_CONCEPTOS.CUENTACREDITORETE_AV, SF_CONCEPTOS.CUENTADEBITODESCUENTO_AV, SF_CONCEPTOS.CUENTACREDITODESCUENTO_AV, SF_CONCEPTOS.CUENTADEBITOICA_AV, SF_CONCEPTOS.CUENTACREDITOICA_AV, SF_CONCEPTOS.CUENTADEBITOUTILIDAD_AV, SF_CONCEPTOS.CUENTACREDITOUTILIDAD_AV, SF_CONCEPTOS.AUXILIAR, SF_CONCEPTOS.CENTRO_COSTO,(CASE SF_CONCEPTOS.MANEJA_RANGOTIEMPO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RANGOTIEMPO, SF_CONCEPTOS.PORCETAJE_UTILIDAD, SF_CONCEPTOS.EXISTENCIA, SF_CONCEPTOS.CUENTA_RECAUDO, SF_CONCEPTOS.DIGITOS_REDONDEO,(CASE SF_CONCEPTOS.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO, SF_CONCEPTOS.CLASE_CONCEPTO, SF_CONCEPTOS.CTADEBACOMETIDA, SF_CONCEPTOS.CTACREDACOMETIDA, SF_CONCEPTOS.CTADEBACOMETIDA_AV, SF_CONCEPTOS.CTACREDACOMETIDA_AV, SF_CONCEPTOS.CTADEBAIU, SF_CONCEPTOS.CTACREDAIU, SF_CONCEPTOS.CTADEBAIU_AV, SF_CONCEPTOS.CTACREDAIU_AV, SF_CONCEPTOS.CTADEBADMONIMP, SF_CONCEPTOS.CTACREDADMONIMP, SF_CONCEPTOS.CTADEBADMONIMP_AV, SF_CONCEPTOS.CTACREDADMONIMP_AV, SF_CONCEPTOS.CTADEBUTILIDADAIU, SF_CONCEPTOS.CTACREDUTILIDADAIU, SF_CONCEPTOS.CTADEBUTILIDADAIU_AV, SF_CONCEPTOS.CTACREDUTILIDADAIU_AV, SF_CONCEPTOS.CTADEBIVAUTILIDAD, SF_CONCEPTOS.CTACREDIVAUTILIDAD, SF_CONCEPTOS.CTADEBIVAUTILIDAD_AV, SF_CONCEPTOS.CTACREDIVAUTILIDAD_AV, SF_CONCEPTOS.FORMULAR_ACOMETIDA, SF_CONCEPTOS.FORMULAR_AIU, SF_CONCEPTOS.FORMULAR_ADMONIMP, SF_CONCEPTOS.FORMULAR_UTILIDADAIU, SF_CONCEPTOS.FORMULAR_IVAUTILIDAD, SF_CONCEPTOS.AGRUPAR_COMO, SF_CONCEPTOS.CTAORDENDEUDORA_DEBITO, SF_CONCEPTOS.CTAORDENDEUDORA_CREDITO, SF_CONCEPTOS.CANTIDAD_PORDEFECTO,(CASE SF_CONCEPTOS.UNICO_BASEGRAVABLE WHEN 0 THEN 'false' ELSE 'true' END) UNICO_BASEGRAVABLE, SF_CONCEPTOS.CREATED_BY, SF_CONCEPTOS.MODIFIED_BY, SF_CONCEPTOS.FILTROREGIMEN,(TO_CHAR(SF_CONCEPTOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(SF_CONCEPTOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE SF_CONCEPTOS.DESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) DESCUENTO, SF_CONCEPTOS.NIVEL, SF_CONCEPTOS.FACTOR_RED_BASE, SF_CONCEPTOS.FACTOR_RED_BASETOTAL, SF_CONCEPTOS.FACTOR_RED_DESCUENTO, SF_CONCEPTOS.FACTOR_RED_ICA, SF_CONCEPTOS.FACTOR_RED_IVA, SF_CONCEPTOS.FACTOR_RED_RETE, CENTRO_COSTO.NOMBRE NOMBRECENTRO, AUXILIAR.NOMBRE NOMBREAUXILIAR, SF_CONCEPTOS.REFERENCIA, REFERENCIA.NOMBRE NOMBREREFERENCIA, SF_CONCEPTOS.FUENTE_RECURSO, FUENTE_RECURSOS.NOMBRE NOMBREFUENTE,(CASE SF_CONCEPTOS.SINSITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) SINSITUACIONFONDOS,(CASE SF_CONCEPTOS.APLICAIMPOCONSUMO WHEN 0 THEN 'false' ELSE 'true' END) APLICAIMPOCONSUMO, SF_CONCEPTOS.VALOR_IMPOCONSUMO, SF_CONCEPTOS.CTACREDIMPOCONSUMO, SF_CONCEPTOS.CTADEBIMPOCONSUMO, CODEQUIV_DIAN,(CASE DESCUENTOS_FE WHEN 0 THEN 'false' ELSE 'true' END) DESCUENTOS_FE,(CASE CARGO_FE WHEN 0 THEN 'false' ELSE 'true' END) CARGO_FE,(CASE SF_CONCEPTOS.APLICAAUTORENTA WHEN 0 THEN 'false' ELSE 'true' END) APLICAAUTORENTA, SF_CONCEPTOS.PORCENTAJEAUTORENTA, SF_CONCEPTOS.CUENTADEBITOAUTORENTA, SF_CONCEPTOS.CUENTACREDITOAUTORENTA, SF_CONCEPTOS.CUENTADEBITOAUTORENTA_AV, SF_CONCEPTOS.CUENTACREDITOAUTORENTA_AV,(CASE SF_CONCEPTOS.APLICAAUTOICA WHEN 0 THEN 'false' ELSE 'true' END) APLICAAUTOICA, SF_CONCEPTOS.PORCENTAJEAUTOICA, SF_CONCEPTOS.CUENTADEBITOAUTOICA, SF_CONCEPTOS.CUENTACREDITOAUTOICA, SF_CONCEPTOS.CUENTADEBITOAUTOICA_AV, SF_CONCEPTOS.CUENTACREDITOAUTOICA_AV, SF_CONCEPTOS.CODIGO_CCPET, CCPET.NOMBRE NOMBRECCPET, SF_CONCEPTOS.FUENTE_CUIPO, FUENTECUIPO.NOMBRE NOMBREFUENTECUIPO, SF_CONCEPTOS.CODIGOUNIDADEJE, UNIDADEJE.NOMBRE NOMBREUNIDADEJE, SF_CONCEPTOS.CUENTADEBITOPUBLICO, SF_CONCEPTOS.CUENTACREDITOPUBLICO, SF_CONCEPTOS.CUENTADEBITOPRIVADO, SF_CONCEPTOS.CUENTACREDITOPRIVADO ,(CASE SF_CONCEPTOS.APLICARETEIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEIVA, SF_CONCEPTOS.PORCENTAJERETEIVA, SF_CONCEPTOS.CTADEBITORETEIVAACTUAL, SF_CONCEPTOS.CTACREDITORETEIVAACTUAL, SF_CONCEPTOS.CTADEBITORETEIVAANTES, SF_CONCEPTOS.CTACREDITORETEIVAANTES,(CASE SF_CONCEPTOS.ESTAMPILLA_SIGEC WHEN 0 THEN 'false' ELSE 'true' END) ESTAMPILLA_SIGEC,(CASE SF_CONCEPTOS.PERMITE_AJUSTE_DECIMALES WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_AJUSTE_DECIMALES FROM SF_CONCEPTOS LEFT JOIN CENTRO_COSTO ON SF_CONCEPTOS.COMPANIA = CENTRO_COSTO.COMPANIA AND SF_CONCEPTOS.ANO = CENTRO_COSTO.ANO AND SF_CONCEPTOS.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON SF_CONCEPTOS.COMPANIA = AUXILIAR.COMPANIA AND SF_CONCEPTOS.ANO = AUXILIAR.ANO AND SF_CONCEPTOS.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN REFERENCIA ON SF_CONCEPTOS.COMPANIA = REFERENCIA.COMPANIA AND SF_CONCEPTOS.ANO = REFERENCIA.ANO AND SF_CONCEPTOS.REFERENCIA = REFERENCIA.CODIGO LEFT JOIN FUENTE_RECURSOS ON SF_CONCEPTOS.COMPANIA = FUENTE_RECURSOS.COMPANIA AND SF_CONCEPTOS.ANO = FUENTE_RECURSOS.ANO AND SF_CONCEPTOS.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO LEFT JOIN TIPOCLASIFICADOR CCPET ON SF_CONCEPTOS.COMPANIA = CCPET.COMPANIA AND SF_CONCEPTOS.ANO = CCPET.ANO AND SF_CONCEPTOS.CODIGO_CCPET = CCPET.CODIGO LEFT JOIN TIPOCLASIFICADOR FUENTECUIPO ON SF_CONCEPTOS.COMPANIA = FUENTECUIPO.COMPANIA AND SF_CONCEPTOS.ANO = FUENTECUIPO.ANO AND SF_CONCEPTOS.FUENTE_CUIPO = FUENTECUIPO.CODIGO LEFT JOIN TIPOCLASIFICADOR UNIDADEJE ON SF_CONCEPTOS.COMPANIA = UNIDADEJE.COMPANIA AND SF_CONCEPTOS.ANO = UNIDADEJE.ANO AND SF_CONCEPTOS.CODIGOUNIDADEJE = UNIDADEJE.CODIGO WHERE SF_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_CONCEPTOS.ANO= :KEY_ANO AND SF_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_BASE":"$VALOR_BASE","UNIDAD":"$UNIDAD","APLICAIVA":"$APLICAIVA(type:boolean)","PORCENTAJEIVA":"$PORCENTAJEIVA","APLICARETEFUENTE":"$APLICARETEFUENTE(type:boolean)","PORCENTAJERETEFUENTE":"$PORCENTAJERETEFUENTE","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO","APLICAICA":"$APLICAICA(type:boolean)","PORCENTAJEICA":"$PORCENTAJEICA","APLICAFORMULA":"$APLICAFORMULA(type:boolean)","FORMULA":"$FORMULA","TIPODECONCEPTO":"$TIPODECONCEPTO","PERMITEMODIFICARVALOR":"$PERMITEMODIFICARVALOR(type:boolean)","AFECTAINVENTARIO":"$AFECTAINVENTARIO(type:boolean)","CODIGOINVENTARIO":"$CODIGOINVENTARIO","PERMITEMODIFICARCANTIDAD":"$PERMITEMODIFICARCANTIDAD(type:boolean)","CUENTADEBITOBASE":"$CUENTADEBITOBASE","CUENTACREDITOBASE":"$CUENTACREDITOBASE","CUENTADEBITOIVA":"$CUENTADEBITOIVA","CUENTACREDITOIVA":"$CUENTACREDITOIVA","CUENTADEBITORETE":"$CUENTADEBITORETE","CUENTACREDITORETE":"$CUENTACREDITORETE","CUENTADEBITODESCUENTO":"$CUENTADEBITODESCUENTO","CUENTACREDITODESCUENTO":"$CUENTACREDITODESCUENTO","CUENTADEBITOICA":"$CUENTADEBITOICA","CUENTACREDITOICA":"$CUENTACREDITOICA","CUENTADEBITOUTILIDAD":"$CUENTADEBITOUTILIDAD","CUENTACREDITOUTILIDAD":"$CUENTACREDITOUTILIDAD","CUENTADEBITOBASE_AV":"$CUENTADEBITOBASE_AV","CUENTACREDITOBASE_AV":"$CUENTACREDITOBASE_AV","CUENTADEBITOIVA_AV":"$CUENTADEBITOIVA_AV","CUENTACREDITOIVA_AV":"$CUENTACREDITOIVA_AV","CUENTADEBITORETE_AV":"$CUENTADEBITORETE_AV","CUENTACREDITORETE_AV":"$CUENTACREDITORETE_AV","CUENTADEBITODESCUENTO_AV":"$CUENTADEBITODESCUENTO_AV","CUENTACREDITODESCUENTO_AV":"$CUENTACREDITODESCUENTO_AV","CUENTADEBITOICA_AV":"$CUENTADEBITOICA_AV","CUENTACREDITOICA_AV":"$CUENTACREDITOICA_AV","CUENTADEBITOUTILIDAD_AV":"$CUENTADEBITOUTILIDAD_AV","CUENTACREDITOUTILIDAD_AV":"$CUENTACREDITOUTILIDAD_AV",