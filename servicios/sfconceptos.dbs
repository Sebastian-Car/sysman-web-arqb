	<query id="getSfconceptosNumGetconceptosxcontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (CASE SF_CONCEPTOS.PERMITE_AJUSTE_DECIMALES WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_AJUSTE_DECIMALES, SF_DETALLE_CONTRATO.CONCEPTO CODIGO, SF_CONCEPTOS.NOMBRE, SF_DETALLE_CONTRATO.VALOR_BASE, SF_DETALLE_CONTRATO.VALOR_DESCUENTO,(CASE SF_CONCEPTOS.APLICAIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICAIVA, SF_CONCEPTOS.PORCENTAJEIVA,(CASE SF_CONCEPTOS.APLICARETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEFUENTE, SF_CONCEPTOS.PORCENTAJERETEFUENTE,(CASE SF_CONCEPTOS.APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, SF_CONCEPTOS.PORCENTAJEDESCUENTO,(CASE SF_CONCEPTOS.APLICAICA WHEN 0 THEN 'false' ELSE 'true' END) APLICAICA, SF_CONCEPTOS.PORCENTAJEICA,(CASE SF_CONCEPTOS.APLICAFORMULA WHEN 0 THEN 'false' ELSE 'true' END) APLICAFORMULA, PCK_SYSMAN_UTL.FC_EVAL( SF_CONCEPTOS.FORMULA ) FORMULA, SF_CONCEPTOS.TIPODECONCEPTO,(CASE SF_CONCEPTOS.PERMITEMODIFICARVALOR WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARVALOR,(CASE SF_CONCEPTOS.AFECTAINVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAINVENTARIO, SF_CONCEPTOS.CODIGOINVENTARIO,(CASE SF_CONCEPTOS.PERMITEMODIFICARCANTIDAD WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARCANTIDAD,(CASE SF_CONCEPTOS.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO, SF_CONCEPTOS.COMPANIA, SF_CONCEPTOS.ANO, SF_CONCEPTOS.TIPOCOBRO, SF_CONCEPTOS.CUENTADEBITOBASE, SF_CONCEPTOS.CUENTACREDITOBASE, SF_CONCEPTOS.CUENTADEBITOIVA, SF_CONCEPTOS.CUENTACREDITOIVA, SF_CONCEPTOS.CUENTADEBITORETE, SF_CONCEPTOS.CUENTACREDITORETE, SF_CONCEPTOS.CUENTADEBITODESCUENTO, SF_CONCEPTOS.CUENTACREDITODESCUENTO, SF_CONCEPTOS.CUENTADEBITOICA, SF_CONCEPTOS.CUENTACREDITOICA, SF_CONCEPTOS.VALOR_COMPRA, SF_CONCEPTOS.PORCETAJE_UTILIDAD, SF_CONCEPTOS.EXISTENCIA, SF_CONCEPTOS.AUXILIAR, SF_CONCEPTOS.CENTRO_COSTO, SF_CONCEPTOS.CUENTA_RECAUDO, SF_CONCEPTOS.FACTOR_RED_BASE, SF_CONCEPTOS.FACTOR_RED_IVA, SF_CONCEPTOS.FACTOR_RED_RETE, SF_CONCEPTOS.FACTOR_RED_ICA, SF_CONCEPTOS.FACTOR_RED_DESCUENTO, SF_CONCEPTOS.VALOR_IMPOCONSUMO, SF_DETALLE_CONTRATO.SALDO_ACTUAL, SF_DETALLE_CONTRATO.CANTIDAD, SF_DETALLE_CONTRATO.VALOR_UNITARIO, SF_DETALLE_CONTRATO.TARIFA, SF_DETALLE_CONTRATO.CENTRO_UTILIDAD, CENTRO_UTILIDAD.DESCRIPCION NOMBRECENTROUTILIDAD FROM SF_CONCEPTOS INNER JOIN SF_DETALLE_CONTRATO ON SF_CONCEPTOS.COMPANIA = SF_DETALLE_CONTRATO.COMPANIA AND SF_CONCEPTOS.ANO = SF_DETALLE_CONTRATO.ANO AND SF_CONCEPTOS.TIPOCOBRO = SF_DETALLE_CONTRATO.TIPO AND SF_CONCEPTOS.CODIGO = SF_DETALLE_CONTRATO.CONCEPTO LEFT JOIN CENTRO_UTILIDAD ON SF_DETALLE_CONTRATO.COMPANIA = CENTRO_UTILIDAD.COMPANIA AND SF_DETALLE_CONTRATO.ANO = CENTRO_UTILIDAD.ANO AND SF_DETALLE_CONTRATO.CENTRO_UTILIDAD = CENTRO_UTILIDAD.CODIGO WHERE SF_CONCEPTOS.COMPANIA = :COMPANIA AND SF_CONCEPTOS.ESTADO NOT IN ( 0 ) AND SF_CONCEPTOS.TIPODECONCEPTO IN ( 'C' ) AND SF_CONCEPTOS.ANO = :ANO AND SF_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO AND NVL( SF_CONCEPTOS.CUENTA_RECAUDO, - 1 ) = CASE WHEN :POSEECUENTA = 1 THEN TO_NUMBER( :CUENTA ) ELSE NVL( TO_NUMBER( SF_CONCEPTOS.CUENTA_RECAUDO ), - 1 ) END AND SF_DETALLE_CONTRATO.NUMERO = :CONTRATO) INI WHERE (CASE WHEN PERMITE_AJUSTE_DECIMALES IS NULL THEN ' ' ELSE UPPER(PERMITE_AJUSTE_DECIMALES) END) LIKE UPPER(CONCAT(:PERMITE_AJUSTE_DECIMALES, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END) LIKE UPPER(CONCAT(:VALOR_DESCUENTO, '%')) AND (CASE WHEN APLICAIVA IS NULL THEN ' ' ELSE UPPER(APLICAIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICAIVA), '%')) AND (CASE WHEN PORCENTAJEIVA IS NULL THEN ' ' ELSE UPPER(PORCENTAJEIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJEIVA), '%')) AND (CASE WHEN APLICARETEFUENTE IS NULL THEN ' ' ELSE UPPER(APLICARETEFUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICARETEFUENTE), '%')) AND (CASE WHEN PORCENTAJERETEFUENTE IS NULL THEN ' ' ELSE UPPER(PORCENTAJERETEFUENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJERETEFUENTE), '%')) AND (CASE WHEN APLICADESCUENTO IS NULL THEN ' ' ELSE UPPER(APLICADESCUENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICADESCUENTO), '%')) AND (CASE WHEN PORCENTAJEDESCUENTO IS NULL THEN ' ' ELSE UPPER(PORCENTAJEDESCUENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJEDESCUENTO), '%')) AND (CASE WHEN APLICAICA IS NULL THEN ' ' ELSE UPPER(APLICAICA) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICAICA), '%')) AND (CASE WHEN PORCENTAJEICA IS NULL THEN ' ' ELSE UPPER(PORCENTAJEICA) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJEICA), '%')) AND (CASE WHEN APLICAFORMULA IS NULL THEN ' ' ELSE UPPER(APLICAFORMULA) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICAFORMULA), '%')) AND (CASE WHEN FORMULA IS NULL THEN ' ' ELSE UPPER(FORMULA) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMULA), '%')) AND (CASE WHEN TIPODECONCEPTO IS NULL THEN ' ' ELSE UPPER(TIPODECONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPODECONCEPTO), '%')) AND (CASE WHEN PERMITEMODIFICARVALOR IS NULL THEN ' ' ELSE UPPER(PERMITEMODIFICARVALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:PERMITEMODIFICARVALOR), '%')) AND (CASE WHEN AFECTAINVENTARIO IS NULL THEN ' ' ELSE UPPER(AFECTAINVENTARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:AFECTAINVENTARIO), '%')) AND (CASE WHEN CODIGOINVENTARIO IS NULL THEN ' ' ELSE UPPER(CODIGOINVENTARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOINVENTARIO), '%')) AND (CASE WHEN PERMITEMODIFICARCANTIDAD IS NULL THEN ' ' ELSE UPPER(PERMITEMODIFICARCANTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:PERMITEMODIFICARCANTIDAD), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN TIPOCOBRO IS NULL THEN ' ' ELSE UPPER(TIPOCOBRO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCOBRO), '%')) AND (CASE WHEN CUENTADEBITOBASE IS NULL THEN ' ' ELSE UPPER(CUENTADEBITOBASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTADEBITOBASE), '%')) AND (CASE WHEN CUENTACREDITOBASE IS NULL THEN ' ' ELSE UPPER(CUENTACREDITOBASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTACREDITOBASE), '%')) AND (CASE WHEN CUENTADEBITOIVA IS NULL THEN ' ' ELSE UPPER(CUENTADEBITOIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTADEBITOIVA), '%')) AND (CASE WHEN CUENTACREDITOIVA IS NULL THEN ' ' ELSE UPPER(CUENTACREDITOIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTACREDITOIVA), '%')) AND (CASE WHEN CUENTADEBITORETE IS NULL THEN ' ' ELSE UPPER(CUENTADEBITORETE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTADEBITORETE), '%')) AND (CASE WHEN CUENTACREDITORETE IS NULL THEN ' ' ELSE UPPER(CUENTACREDITORETE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTACREDITORETE), '%')) AND (CASE WHEN CUENTADEBITODESCUENTO IS NULL THEN ' ' ELSE UPPER(CUENTADEBITODESCUENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTADEBITODESCUENTO), '%')) AND (CASE WHEN CUENTACREDITODESCUENTO IS NULL THEN ' ' ELSE UPPER(CUENTACREDITODESCUENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTACREDITODESCUENTO), '%')) AND (CASE WHEN CUENTADEBITOICA IS NULL THEN ' ' ELSE UPPER(CUENTADEBITOICA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTADEBITOICA), '%')) AND (CASE WHEN CUENTACREDITOICA IS NULL THEN ' ' ELSE UPPER(CUENTACREDITOICA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTACREDITOICA), '%')) AND (CASE WHEN VALOR_COMPRA IS NULL THEN ' ' ELSE UPPER(VALOR_COMPRA) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_COMPRA), '%')) AND (CASE WHEN PORCETAJE_UTILIDAD IS NULL THEN ' ' ELSE UPPER(PORCETAJE_UTILIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCETAJE_UTILIDAD), '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:EXISTENCIA), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN CUENTA_RECAUDO IS NULL THEN ' ' ELSE UPPER(CUENTA_RECAUDO) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA_RECAUDO), '%')) AND (CASE WHEN FACTOR_RED_BASE IS NULL THEN ' ' ELSE UPPER(FACTOR_RED_BASE) END) LIKE UPPER(CONCAT(CONCAT('%',:FACTOR_RED_BASE), '%')) AND (CASE WHEN FACTOR_RED_IVA IS NULL THEN ' ' ELSE UPPER(FACTOR_RED_IVA) END) LIKE UPPER(CONCAT(CONCAT('%',:FACTOR_RED_IVA), '%')) AND (CASE WHEN FACTOR_RED_RETE IS NULL THEN ' ' ELSE UPPER(FACTOR_RED_RETE) END) LIKE UPPER(CONCAT(CONCAT('%',:FACTOR_RED_RETE), '%')) AND (CASE WHEN FACTOR_RED_ICA IS NULL THEN ' ' ELSE UPPER(FACTOR_RED_ICA) END) LIKE UPPER(CONCAT(CONCAT('%',:FACTOR_RED_ICA), '%')) AND (CASE WHEN FACTOR_RED_DESCUENTO IS NULL THEN ' ' ELSE UPPER(FACTOR_RED_DESCUENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:FACTOR_RED_DESCUENTO), '%')) AND (CASE WHEN VALOR_IMPOCONSUMO IS NULL THEN ' ' ELSE UPPER(VALOR_IMPOCONSUMO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_IMPOCONSUMO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="POSEECUENTA" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="PERMITE_AJUSTE_DECIMALES" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="APLICAIVA" sqlType="STRING"/>
		<param name="PORCENTAJEIVA" sqlType="STRING"/>
		<param name="APLICARETEFUENTE" sqlType="STRING"/>
		<param name="PORCENTAJERETEFUENTE" sqlType="STRING"/>
		<param name="APLICADESCUENTO" sqlType="STRING"/>
		<param name="PORCENTAJEDESCUENTO" sqlType="STRING"/>
		<param name="APLICAICA" sqlType="STRING"/>
		<param name="PORCENTAJEICA" sqlType="STRING"/>
		<param name="APLICAFORMULA" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
