		<param name="AFECTAINVENTARIO" sqlType="STRING"/>
		<param name="CODIGOINVENTARIO" sqlType="STRING"/>
		<param name="PERMITEMODIFICARCANTIDAD" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CUENTADEBITOBASE" sqlType="STRING"/>
		<param name="CUENTACREDITOBASE" sqlType="STRING"/>
		<param name="CUENTADEBITOIVA" sqlType="STRING"/>
		<param name="CUENTACREDITOIVA" sqlType="STRING"/>
		<param name="CUENTADEBITORETE" sqlType="STRING"/>
		<param name="CUENTACREDITORETE" sqlType="STRING"/>
		<param name="CUENTADEBITODESCUENTO" sqlType="STRING"/>
		<param name="CUENTACREDITODESCUENTO" sqlType="STRING"/>
		<param name="CUENTADEBITOICA" sqlType="STRING"/>
		<param name="CUENTACREDITOICA" sqlType="STRING"/>
		<param name="VALOR_COMPRA" sqlType="STRING"/>
		<param name="PORCETAJE_UTILIDAD" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
