	<query id="updateSfconceptosConceptosAdicAlmacen" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CONCEPTOS SET FORMULAR_ACOMETIDA=:FORMULAR_ACOMETIDA, CTADEBACOMETIDA=:CTADEBACOMETIDA, CTACREDACOMETIDA=:CTACREDACOMETIDA, CTADEBACOMETIDA_AV=:CTADEBACOMETIDA_AV, CTACREDACOMETIDA_AV=:CTACREDACOMETIDA_AV, FORMULAR_AIU=:FORMULAR_AIU, CTADEBAIU=:CTADEBAIU, CTACREDAIU=:CTACREDAIU, CTADEBAIU_AV=:CTADEBAIU_AV, CTACREDAIU_AV=:CTACREDAIU_AV, FORMULAR_ADMONIMP=:FORMULAR_ADMONIMP, CTADEBADMONIMP=:CTADEBADMONIMP, CTACREDADMONIMP=:CTACREDADMONIMP, CTADEBADMONIMP_AV=:CTADEBADMONIMP_AV, CTACREDADMONIMP_AV=:CTACREDADMONIMP_AV, FORMULAR_UTILIDADAIU=:FORMULAR_UTILIDADAIU, CTADEBUTILIDADAIU=:CTADEBUTILIDADAIU, CTACREDUTILIDADAIU=:CTACREDUTILIDADAIU, CTADEBUTILIDADAIU_AV=:CTADEBUTILIDADAIU_AV, CTACREDUTILIDADAIU_AV=:CTACREDUTILIDADAIU_AV, FORMULAR_IVAUTILIDAD=:FORMULAR_IVAUTILIDAD, CTADEBIVAUTILIDAD=:CTADEBIVAUTILIDAD, CTACREDIVAUTILIDAD=:CTACREDIVAUTILIDAD, CTADEBIVAUTILIDAD_AV=:CTADEBIVAUTILIDAD_AV, CTACREDIVAUTILIDAD_AV=:CTACREDIVAUTILIDAD_AV, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SF_CONCEPTOS.ANO= :KEY_ANO AND SF_CONCEPTOS.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FORMULAR_ACOMETIDA" sqlType="STRING"/>
		<param name="CTADEBACOMETIDA" sqlType="STRING"/>
		<param name="CTACREDACOMETIDA" sqlType="STRING"/>
		<param name="CTADEBACOMETIDA_AV" sqlType="STRING"/>
		<param name="CTACREDACOMETIDA_AV" sqlType="STRING"/>
		<param name="FORMULAR_AIU" sqlType="STRING"/>
		<param name="CTADEBAIU" sqlType="STRING"/>
