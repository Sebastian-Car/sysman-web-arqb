			<with-param name="CUENTADEBITOPRIVADO" query-param="CUENTADEBITOPRIVADO"/>
			<with-param name="CUENTACREDITOPRIVADO" query-param="CUENTACREDITOPRIVADO"/>
<with-param name="APLICARETEIVA" query-param="APLICARETEIVA"/>
			<with-param name="PORCENTAJERETEIVA" query-param="PORCENTAJERETEIVA"/>
