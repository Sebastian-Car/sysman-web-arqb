	<query id="getSfconceptosObtenerregistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SF_CONCEPTOS.CODIGO, SF_CONCEPTOS.NOMBRE, SF_CONCEPTOS.VALOR_BASE,(CASE SF_CONCEPTOS.APLICAIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICAIVA, SF_CONCEPTOS.PORCENTAJEIVA,(CASE SF_CONCEPTOS.APLICARETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEFUENTE, SF_CONCEPTOS.PORCENTAJERETEFUENTE,(CASE SF_CONCEPTOS.APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, SF_CONCEPTOS.PORCENTAJEDESCUENTO,(CASE SF_CONCEPTOS.APLICAICA WHEN 0 THEN 'false' ELSE 'true' END) APLICAICA, SF_CONCEPTOS.PORCENTAJEICA,(CASE SF_CONCEPTOS.APLICAFORMULA WHEN 0 THEN 'false' ELSE 'true' END) APLICAFORMULA, PCK_SYSMAN_UTL.FC_EVAL(SF_CONCEPTOS.FORMULA) FORMULA, SF_CONCEPTOS.TIPODECONCEPTO,(CASE SF_CONCEPTOS.PERMITEMODIFICARVALOR WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARVALOR,(CASE SF_CONCEPTOS.AFECTAINVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAINVENTARIO, SF_CONCEPTOS.CODIGOINVENTARIO,(CASE SF_CONCEPTOS.PERMITEMODIFICARCANTIDAD WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARCANTIDAD,(CASE SF_CONCEPTOS.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO, SF_CONCEPTOS.COMPANIA, SF_CONCEPTOS.ANO, SF_CONCEPTOS.TIPOCOBRO, SF_CONCEPTOS.CUENTADEBITOBASE, SF_CONCEPTOS.CUENTACREDITOBASE, SF_CONCEPTOS.CUENTADEBITOIVA, SF_CONCEPTOS.CUENTACREDITOIVA, SF_CONCEPTOS.CUENTADEBITORETE, SF_CONCEPTOS.CUENTACREDITORETE, SF_CONCEPTOS.CUENTADEBITODESCUENTO, SF_CONCEPTOS.CUENTACREDITODESCUENTO, SF_CONCEPTOS.CUENTADEBITOICA, SF_CONCEPTOS.CUENTACREDITOICA, SF_CONCEPTOS.VALOR_COMPRA, SF_CONCEPTOS.PORCETAJE_UTILIDAD, SF_CONCEPTOS.EXISTENCIA, SF_CONCEPTOS.AUXILIAR, SF_CONCEPTOS.CENTRO_COSTO, SF_CONCEPTOS.CUENTA_RECAUDO, SF_CONCEPTOS.FACTOR_RED_BASE, SF_CONCEPTOS.FACTOR_RED_IVA, SF_CONCEPTOS.FACTOR_RED_RETE, SF_CONCEPTOS.FACTOR_RED_ICA, SF_CONCEPTOS.FACTOR_RED_DESCUENTO  FROM SF_CONCEPTOS WHERE SF_CONCEPTOS.COMPANIA = :COMPANIA AND SF_CONCEPTOS.ESTADO NOT IN (0) AND SF_CONCEPTOS. TIPODECONCEPTO IN ('C') AND SF_CONCEPTOS.ANO = :ANO AND SF_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO AND SF_CONCEPTOS.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VALOR_BASE":"$VALOR_BASE","APLICAIVA":"$APLICAIVA(type:boolean)","PORCENTAJEIVA":"$PORCENTAJEIVA","APLICARETEFUENTE":"$APLICARETEFUENTE(type:boolean)","PORCENTAJERETEFUENTE":"$PORCENTAJERETEFUENTE","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO","APLICAICA":"$APLICAICA(type:boolean)","PORCENTAJEICA":"$PORCENTAJEICA","APLICAFORMULA":"$APLICAFORMULA(type:boolean)","FORMULA":"$FORMULA","TIPODECONCEPTO":"$TIPODECONCEPTO","PERMITEMODIFICARVALOR":"$PERMITEMODIFICARVALOR(type:boolean)","AFECTAINVENTARIO":"$AFECTAINVENTARIO(type:boolean)","CODIGOINVENTARIO":"$CODIGOINVENTARIO","PERMITEMODIFICARCANTIDAD":"$PERMITEMODIFICARCANTIDAD(type:boolean)","ESTADO":"$ESTADO(type:boolean)","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CUENTADEBITOBASE":"$CUENTADEBITOBASE","CUENTACREDITOBASE":"$CUENTACREDITOBASE","CUENTADEBITOIVA":"$CUENTADEBITOIVA","CUENTACREDITOIVA":"$CUENTACREDITOIVA","CUENTADEBITORETE":"$CUENTADEBITORETE","CUENTACREDITORETE":"$CUENTACREDITORETE","CUENTADEBITODESCUENTO":"$CUENTADEBITODESCUENTO","CUENTACREDITODESCUENTO":"$CUENTACREDITODESCUENTO","CUENTADEBITOICA":"$CUENTADEBITOICA","CUENTACREDITOICA":"$CUENTACREDITOICA","VALOR_COMPRA":"$VALOR_COMPRA","PORCETAJE_UTILIDAD":"$PORCETAJE_UTILIDAD","EXISTENCIA":"$EXISTENCIA","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","CUENTA_RECAUDO":"$CUENTA_RECAUDO","FACTOR_RED_BASE":"$FACTOR_RED_BASE(type:integer)","FACTOR_RED_IVA":"$FACTOR_RED_IVA(type:integer)","FACTOR_RED_RETE":"$FACTOR_RED_RETE(type:integer)","FACTOR_RED_ICA":"$FACTOR_RED_ICA(type:integer)","FACTOR_RED_DESCUENTO":"$FACTOR_RED_DESCUENTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptos/obtenerregistro">
		<call-query href="getSfconceptosObtenerregistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSfconceptosPagTodosPorTipoCQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_CONCEPTOS WHERE TIPODECONCEPTO = 'C' AND COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfconceptos/todosportipoc/pag">
		<call-query href="getSfconceptosPagTodosPorTipoCQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfconceptosNumTodosPorTipoCQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM SF_CONCEPTOS WHERE TIPODECONCEPTO = 'C' AND COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptos/todosportipoc/num">
		<call-query href="getSfconceptosNumTodosPorTipoCQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSfconceptosExtraerregistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_CONCEPTOS.CODIGO, SF_CONCEPTOS.NOMBRE, SF_CONCEPTOS.VALOR_BASE,(CASE SF_CONCEPTOS.APLICAIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICAIVA, SF_CONCEPTOS.PORCENTAJEIVA,(CASE SF_CONCEPTOS.APLICARETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEFUENTE, SF_CONCEPTOS.PORCENTAJERETEFUENTE,(CASE SF_CONCEPTOS.APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, SF_CONCEPTOS.PORCENTAJEDESCUENTO,(CASE SF_CONCEPTOS.APLICAICA WHEN 0 THEN 'false' ELSE 'true' END) APLICAICA, SF_CONCEPTOS.PORCENTAJEICA,(CASE SF_CONCEPTOS.APLICAFORMULA WHEN 0 THEN 'false' ELSE 'true' END) APLICAFORMULA, SF_CONCEPTOS.FORMULA, SF_CONCEPTOS.TIPODECONCEPTO,(CASE SF_CONCEPTOS.PERMITEMODIFICARVALOR WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARVALOR,(CASE SF_CONCEPTOS.AFECTAINVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAINVENTARIO, SF_CONCEPTOS.CODIGOINVENTARIO,(CASE SF_CONCEPTOS.PERMITEMODIFICARCANTIDAD WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARCANTIDAD,(CASE SF_CONCEPTOS.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO, SF_CONCEPTOS.COMPANIA, SF_CONCEPTOS.ANO, SF_CONCEPTOS.TIPOCOBRO, SF_CONCEPTOS.CUENTADEBITOBASE, SF_CONCEPTOS.CUENTACREDITOBASE, SF_CONCEPTOS.CUENTADEBITOIVA, SF_CONCEPTOS.CUENTACREDITOIVA, SF_CONCEPTOS.CUENTADEBITORETE, SF_CONCEPTOS.CUENTACREDITORETE, SF_CONCEPTOS.CUENTADEBITODESCUENTO, SF_CONCEPTOS.CUENTACREDITODESCUENTO, SF_CONCEPTOS.CUENTADEBITOICA, SF_CONCEPTOS.CUENTACREDITOICA, SF_CONCEPTOS.VALOR_COMPRA, SF_CONCEPTOS.PORCETAJE_UTILIDAD, SF_CONCEPTOS.EXISTENCIA, SF_CONCEPTOS.AUXILIAR, SF_CONCEPTOS.CENTRO_COSTO, SF_CONCEPTOS.CUENTA_RECAUDO, SF_CONCEPTOS.FACTOR_RED_BASE, SF_CONCEPTOS.FACTOR_RED_IVA, SF_CONCEPTOS.FACTOR_RED_RETE, SF_CONCEPTOS.FACTOR_RED_ICA, SF_CONCEPTOS.FACTOR_RED_DESCUENTO, SF_CONCEPTOS.FACTOR_RED_BASETOTAL,SF_CONCEPTOS.REFERENCIA , SF_CONCEPTOS.FUENTE_RECURSO ,(CASE SF_CONCEPTOS.APLICAIMPOCONSUMO WHEN 0 THEN 'false' ELSE 'true' END) APLICAIMPOCONSUMO,SF_CONCEPTOS.VALOR_IMPOCONSUMO ,(CASE SF_CONCEPTOS.APLICARETEIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEIVA,SF_CONCEPTOS.PORCENTAJERETEIVA ,SF_CONCEPTOS.CTADEBITORETEIVAACTUAL ,SF_CONCEPTOS.CTACREDITORETEIVAACTUAL ,SF_CONCEPTOS.CTADEBITORETEIVAANTES ,SF_CONCEPTOS.CTACREDITORETEIVAANTES FROM SF_CONCEPTOS WHERE SF_CONCEPTOS.COMPANIA = :COMPANIA AND SF_CONCEPTOS.ESTADO NOT IN (0) AND SF_CONCEPTOS. TIPODECONCEPTO IN ('C') AND SF_CONCEPTOS.ANO = :ANO AND SF_CONCEPTOS.TIPOCOBRO = :TIPOCOBRO AND SF_CONCEPTOS.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VALOR_BASE":"$VALOR_BASE","APLICAIVA":"$APLICAIVA(type:boolean)","PORCENTAJEIVA":"$PORCENTAJEIVA","APLICARETEFUENTE":"$APLICARETEFUENTE(type:boolean)","PORCENTAJERETEFUENTE":"$PORCENTAJERETEFUENTE","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO","APLICAICA":"$APLICAICA(type:boolean)","PORCENTAJEICA":"$PORCENTAJEICA","APLICAFORMULA":"$APLICAFORMULA(type:boolean)","FORMULA":"$FORMULA","TIPODECONCEPTO":"$TIPODECONCEPTO","PERMITEMODIFICARVALOR":"$PERMITEMODIFICARVALOR(type:boolean)","AFECTAINVENTARIO":"$AFECTAINVENTARIO(type:boolean)","CODIGOINVENTARIO":"$CODIGOINVENTARIO","PERMITEMODIFICARCANTIDAD":"$PERMITEMODIFICARCANTIDAD(type:boolean)","ESTADO":"$ESTADO(type:boolean)","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CUENTADEBITOBASE":"$CUENTADEBITOBASE","CUENTACREDITOBASE":"$CUENTACREDITOBASE","CUENTADEBITOIVA":"$CUENTADEBITOIVA","CUENTACREDITOIVA":"$CUENTACREDITOIVA","CUENTADEBITORETE":"$CUENTADEBITORETE","CUENTACREDITORETE":"$CUENTACREDITORETE","CUENTADEBITODESCUENTO":"$CUENTADEBITODESCUENTO","CUENTACREDITODESCUENTO":"$CUENTACREDITODESCUENTO","CUENTADEBITOICA":"$CUENTADEBITOICA","CUENTACREDITOICA":"$CUENTACREDITOICA","VALOR_COMPRA":"$VALOR_COMPRA","PORCETAJE_UTILIDAD":"$PORCETAJE_UTILIDAD","EXISTENCIA":"$EXISTENCIA","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO","CUENTA_RECAUDO":"$CUENTA_RECAUDO","FACTOR_RED_BASE":"$FACTOR_RED_BASE(type:integer)","FACTOR_RED_IVA":"$FACTOR_RED_IVA(type:integer)","FACTOR_RED_RETE":"$FACTOR_RED_RETE(type:integer)","FACTOR_RED_ICA":"$FACTOR_RED_ICA(type:integer)","FACTOR_RED_DESCUENTO":"$FACTOR_RED_DESCUENTO(type:integer)","FACTOR_RED_BASETOTAL":"$FACTOR_RED_BASETOTAL(type:integer)","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","APLICAIMPOCONSUMO":"$APLICAIMPOCONSUMO(type:boolean)","VALOR_IMPOCONSUMO":"$VALOR_IMPOCONSUMO","APLICARETEIVA":"$APLICARETEIVA(type:boolean)","PORCENTAJERETEIVA":"$PORCENTAJERETEIVA","CTADEBITORETEIVAACTUAL":"$CTADEBITORETEIVAACTUAL","CTACREDITORETEIVAACTUAL":"$CTACREDITORETEIVAACTUAL","CTADEBITORETEIVAANTES":"$CTADEBITORETEIVAANTES","CTACREDITORETEIVAANTES":"$CTACREDITORETEIVAANTES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
