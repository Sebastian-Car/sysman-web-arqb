	<query id="getSfconceptosDigitosredondeoconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(DIGITOS_REDONDEO,0) DIGITOSR  FROM SF_CONCEPTOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO AND CODIGO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIGITOSR":"$DIGITOSR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptos/digitosredondeoconcepto">
		<call-query href="getSfconceptosDigitosredondeoconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getSfconceptosExisteCuentaConceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(CODIGOCUENTA.CADENA),PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CUENTA) ) CUENTA FROM ( SELECT CONCAT(CUENTADEBITOBASE,CONCAT(',',CONCAT(CUENTACREDITOBASE,CONCAT(',',CONCAT(CUENTADEBITOIVA,CONCAT(',',CONCAT(CUENTACREDITOIVA ,CONCAT(',',CONCAT(CUENTADEBITORETE,CONCAT(',',CONCAT(CUENTACREDITORETE,CONCAT(',',CONCAT(CUENTADEBITODESCUENTO,CONCAT (',',CONCAT(CUENTACREDITODESCUENTO,CONCAT(',',CONCAT(CUENTADEBITOICA,CONCAT(',',CUENTACREDITOICA) ) ) ) ) ) ) ) ) ) ) ) ) ) ) ) ) ) CADENA FROM SF_CONCEPTOS WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND TIPOCOBRO =:TIPOCOBRO AND CODIGO =:CODIGO ) CODIGOCUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptos/existecuentaconcepto">
		<call-query href="getSfconceptosExisteCuentaConceptoQuery">
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSfconceptosConsultalistadoconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE, VALOR_BASE,(CASE APLICAIVA WHEN 0 THEN 'false' ELSE 'true' END) APLICAIVA, PORCENTAJEIVA,(CASE APLICARETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) APLICARETEFUENTE, PORCENTAJERETEFUENTE,(CASE APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, PORCENTAJEDESCUENTO,(CASE APLICAICA WHEN 0 THEN 'false' ELSE 'true' END) APLICAICA, PORCENTAJEICA,(CASE APLICAFORMULA WHEN 0 THEN 'false' ELSE 'true' END) APLICAFORMULA, FORMULA, TIPODECONCEPTO,(CASE PERMITEMODIFICARVALOR WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARVALOR,(CASE AFECTAINVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAINVENTARIO, CODIGOINVENTARIO,(CASE PERMITEMODIFICARCANTIDAD WHEN 0 THEN 'false' ELSE 'true' END) PERMITEMODIFICARCANTIDAD,(CASE MANEJA_RANGOTIEMPO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_RANGOTIEMPO, COMPANIA, ANO, TIPOCOBRO, CUENTADEBITOBASE, CUENTACREDITOBASE, CUENTADEBITOIVA, CUENTACREDITOIVA, CUENTADEBITORETE, CUENTACREDITORETE, CUENTADEBITODESCUENTO, CUENTACREDITODESCUENTO, CUENTADEBITOICA, CUENTACREDITOICA, VALOR_COMPRA, PORCETAJE_UTILIDAD, EXISTENCIA,(CASE AFECTAINVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAINVENTARIO, AUXILIAR, CENTRO_COSTO  FROM SF_CONCEPTOS WHERE TIPODECONCEPTO = 'C' AND COMPANIA = :COMPANIA AND ANO = EXTRACT(YEAR FROM SYSDATE) AND TIPOCOBRO = :TIPOCOBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VALOR_BASE":"$VALOR_BASE","APLICAIVA":"$APLICAIVA(type:boolean)","PORCENTAJEIVA":"$PORCENTAJEIVA","APLICARETEFUENTE":"$APLICARETEFUENTE(type:boolean)","PORCENTAJERETEFUENTE":"$PORCENTAJERETEFUENTE","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO","APLICAICA":"$APLICAICA(type:boolean)","PORCENTAJEICA":"$PORCENTAJEICA","APLICAFORMULA":"$APLICAFORMULA(type:boolean)","FORMULA":"$FORMULA","TIPODECONCEPTO":"$TIPODECONCEPTO","PERMITEMODIFICARVALOR":"$PERMITEMODIFICARVALOR(type:boolean)","AFECTAINVENTARIO":"$AFECTAINVENTARIO(type:boolean)","CODIGOINVENTARIO":"$CODIGOINVENTARIO","PERMITEMODIFICARCANTIDAD":"$PERMITEMODIFICARCANTIDAD(type:boolean)","MANEJA_RANGOTIEMPO":"$MANEJA_RANGOTIEMPO(type:boolean)","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CUENTADEBITOBASE":"$CUENTADEBITOBASE","CUENTACREDITOBASE":"$CUENTACREDITOBASE","CUENTADEBITOIVA":"$CUENTADEBITOIVA","CUENTACREDITOIVA":"$CUENTACREDITOIVA","CUENTADEBITORETE":"$CUENTADEBITORETE","CUENTACREDITORETE":"$CUENTACREDITORETE","CUENTADEBITODESCUENTO":"$CUENTADEBITODESCUENTO","CUENTACREDITODESCUENTO":"$CUENTACREDITODESCUENTO","CUENTADEBITOICA":"$CUENTADEBITOICA","CUENTACREDITOICA":"$CUENTACREDITOICA","VALOR_COMPRA":"$VALOR_COMPRA","PORCETAJE_UTILIDAD":"$PORCETAJE_UTILIDAD","EXISTENCIA":"$EXISTENCIA","AFECTAINVENTARIO":"$AFECTAINVENTARIO(type:boolean)","AUXILIAR":"$AUXILIAR","CENTRO_COSTO":"$CENTRO_COSTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptos/consultalistadoconcepto">
		<call-query href="getSfconceptosConsultalistadoconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
