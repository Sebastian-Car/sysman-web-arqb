		</call-query>
	</resource>
	<query id="updateSfconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CONCEPTOS SET NOMBRE=:NOMBRE, VALOR_COMPRA=:VALOR_COMPRA, VALOR_BASE=:VALOR_BASE, UNIDAD=:UNIDAD, APLICAIVA=:APLICAIVA, PORCENTAJEIVA=:PORCENTAJEIVA, APLICARETEFUENTE=:APLICARETEFUENTE, PORCENTAJERETEFUENTE=:PORCENTAJERETEFUENTE, APLICADESCUENTO=:APLICADESCUENTO, PORCENTAJEDESCUENTO=:PORCENTAJEDESCUENTO, APLICAICA=:APLICAICA, PORCENTAJEICA=:PORCENTAJEICA, APLICAFORMULA=:APLICAFORMULA, FORMULA=:FORMULA, TIPODECONCEPTO=:TIPODECONCEPTO, PERMITEMODIFICARVALOR=:PERMITEMODIFICARVALOR, AFECTAINVENTARIO=:AFECTAINVENTARIO, CODIGOINVENTARIO=:CODIGOINVENTARIO, PERMITEMODIFICARCANTIDAD=:PERMITEMODIFICARCANTIDAD, CUENTADEBITOBASE=:CUENTADEBITOBASE, CUENTACREDITOBASE=:CUENTACREDITOBASE, CUENTADEBITOIVA=:CUENTADEBITOIVA, CUENTACREDITOIVA=:CUENTACREDITOIVA, CUENTADEBITORETE=:CUENTADEBITORETE, CUENTACREDITORETE=:CUENTACREDITORETE, CUENTADEBITODESCUENTO=:CUENTADEBITODESCUENTO, CUENTACREDITODESCUENTO=:CUENTACREDITODESCUENTO, CUENTADEBITOICA=:CUENTADEBITOICA, CUENTACREDITOICA=:CUENTACREDITOICA, CUENTADEBITOUTILIDAD=:CUENTADEBITOUTILIDAD, CUENTACREDITOUTILIDAD=:CUENTACREDITOUTILIDAD, CUENTADEBITOBASE_AV=:CUENTADEBITOBASE_AV, CUENTACREDITOBASE_AV=:CUENTACREDITOBASE_AV, CUENTADEBITOIVA_AV=:CUENTADEBITOIVA_AV, CUENTACREDITOIVA_AV=:CUENTACREDITOIVA_AV, CUENTADEBITORETE_AV=:CUENTADEBITORETE_AV, CUENTACREDITORETE_AV=:CUENTACREDITORETE_AV, CUENTADEBITODESCUENTO_AV=:CUENTADEBITODESCUENTO_AV, CUENTACREDITODESCUENTO_AV=:CUENTACREDITODESCUENTO_AV, CUENTADEBITOICA_AV=:CUENTADEBITOICA_AV, CUENTACREDITOICA_AV=:CUENTACREDITOICA_AV, CUENTADEBITOUTILIDAD_AV=:CUENTADEBITOUTILIDAD_AV, CUENTACREDITOUTILIDAD_AV=:CUENTACREDITOUTILIDAD_AV, AUXILIAR=:AUXILIAR, CENTRO_COSTO=:CENTRO_COSTO, MANEJA_RANGOTIEMPO=:MANEJA_RANGOTIEMPO, PORCETAJE_UTILIDAD=:PORCETAJE_UTILIDAD, EXISTENCIA=:EXISTENCIA, CUENTA_RECAUDO=:CUENTA_RECAUDO, DIGITOS_REDONDEO=:DIGITOS_REDONDEO, ESTADO=:ESTADO, CLASE_CONCEPTO=:CLASE_CONCEPTO, CTADEBACOMETIDA=:CTADEBACOMETIDA, CTACREDACOMETIDA=:CTACREDACOMETIDA, CTADEBACOMETIDA_AV=:CTADEBACOMETIDA_AV, CTACREDACOMETIDA_AV=:CTACREDACOMETIDA_AV, CTADEBAIU=:CTADEBAIU, CTACREDAIU=:CTACREDAIU, CTADEBAIU_AV=:CTADEBAIU_AV, CTACREDAIU_AV=:CTACREDAIU_AV, CTADEBADMONIMP=:CTADEBADMONIMP, CTACREDADMONIMP=:CTACREDADMONIMP, CTADEBADMONIMP_AV=:CTADEBADMONIMP_AV, CTACREDADMONIMP_AV=:CTACREDADMONIMP_AV, CTADEBUTILIDADAIU=:CTADEBUTILIDADAIU, CTACREDUTILIDADAIU=:CTACREDUTILIDADAIU, CTADEBUTILIDADAIU_AV=:CTADEBUTILIDADAIU_AV, CTACREDUTILIDADAIU_AV=:CTACREDUTILIDADAIU_AV, CTADEBIVAUTILIDAD=:CTADEBIVAUTILIDAD, CTACREDIVAUTILIDAD=:CTACREDIVAUTILIDAD, CTADEBIVAUTILIDAD_AV=:CTADEBIVAUTILIDAD_AV, CTACREDIVAUTILIDAD_AV=:CTACREDIVAUTILIDAD_AV, FORMULAR_ACOMETIDA=:FORMULAR_ACOMETIDA, FORMULAR_AIU=:FORMULAR_AIU, FORMULAR_ADMONIMP=:FORMULAR_ADMONIMP, FORMULAR_UTILIDADAIU=:FORMULAR_UTILIDADAIU, FORMULAR_IVAUTILIDAD=:FORMULAR_IVAUTILIDAD, AGRUPAR_COMO=:AGRUPAR_COMO, CTAORDENDEUDORA_DEBITO=:CTAORDENDEUDORA_DEBITO, CTAORDENDEUDORA_CREDITO=:CTAORDENDEUDORA_CREDITO, CANTIDAD_PORDEFECTO=:CANTIDAD_PORDEFECTO, UNICO_BASEGRAVABLE=:UNICO_BASEGRAVABLE, FILTROREGIMEN=:FILTROREGIMEN, DESCUENTO=:DESCUENTO, NIVEL=:NIVEL, FACTOR_RED_BASE=:FACTOR_RED_BASE, FACTOR_RED_BASETOTAL=:FACTOR_RED_BASETOTAL, FACTOR_RED_DESCUENTO=:FACTOR_RED_DESCUENTO, FACTOR_RED_ICA=:FACTOR_RED_ICA, FACTOR_RED_IVA=:FACTOR_RED_IVA, FACTOR_RED_RETE=:FACTOR_RED_RETE, REFERENCIA=:REFERENCIA, FUENTE_RECURSO=:FUENTE_RECURSO, SINSITUACIONFONDOS=:SINSITUACIONFONDOS, APLICAIMPOCONSUMO=:APLICAIMPOCONSUMO, VALOR_IMPOCONSUMO=:VALOR_IMPOCONSUMO, CTACREDIMPOCONSUMO=:CTACREDIMPOCONSUMO, CTADEBIMPOCONSUMO=:CTADEBIMPOCONSUMO, CODEQUIV_DIAN=:CODEQUIV_DIAN, DESCUENTOS_FE=:DESCUENTOS_FE, CARGO_FE=:CARGO_FE, APLICAAUTORENTA=:APLICAAUTORENTA, PORCENTAJEAUTORENTA=:PORCENTAJEAUTORENTA, CUENTADEBITOAUTORENTA=:CUENTADEBITOAUTORENTA, CUENTACREDITOAUTORENTA=:CUENTACREDITOAUTORENTA, CUENTADEBITOAUTORENTA_AV=:CUENTADEBITOAUTORENTA_AV, CUENTACREDITOAUTORENTA_AV=:CUENTACREDITOAUTORENTA_AV, APLICAAUTOICA=:APLICAAUTOICA, PORCENTAJEAUTOICA=:PORCENTAJEAU