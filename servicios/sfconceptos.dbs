		<param name="CTACREDUTILIDADAIU_AV" sqlType="STRING"/>
		<param name="FORMULAR_IVAUTILIDAD" sqlType="STRING"/>
		<param name="CTADEBIVAUTILIDAD" sqlType="STRING"/>
		<param name="CTACREDIVAUTILIDAD" sqlType="STRING"/>
