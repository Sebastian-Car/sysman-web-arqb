	<query id="updateSfconceptosClaseConceptoC" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CONCEPTOS SET CLASE_CONCEPTO = 'C', MODIFIED_BY 	=:MODIFIED_BY,  										DATE_MODIFIED 	= SYSDATE WHERE COMPANIA 	= :COMPANIA    								AND TIPOCOBRO 	= :TIPOCOBRO 								AND CLASE_CONCEPTO IS NULL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfconceptos/claseconceptoc">
		<call-query href="updateSfconceptosClaseConceptoC">
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="insertSfconceptos" keyColumns="COMPANIA,ANO,TIPOCOBRO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_CONCEPTOS (COMPANIA, ANO, TIPOCOBRO, CODIGO, NOMBRE, VALOR_COMPRA, VALOR_BASE, UNIDAD, APLICAIVA, PORCENTAJEIVA, APLICARETEFUENTE, PORCENTAJERETEFUENTE, APLICADESCUENTO, PORCENTAJEDESCUENTO, APLICAICA, PORCENTAJEICA, APLICAFORMULA, FORMULA, TIPODECONCEPTO, PERMITEMODIFICARVALOR, AFECTAINVENTARIO, CODIGOINVENTARIO, PERMITEMODIFICARCANTIDAD, CUENTADEBITOBASE, CUENTACREDITOBASE, CUENTADEBITOIVA, CUENTACREDITOIVA, CUENTADEBITORETE, CUENTACREDITORETE, CUENTADEBITODESCUENTO, CUENTACREDITODESCUENTO, CUENTADEBITOICA, CUENTACREDITOICA, CUENTADEBITOUTILIDAD, CUENTACREDITOUTILIDAD, CUENTADEBITOBASE_AV, CUENTACREDITOBASE_AV, CUENTADEBITOIVA_AV, CUENTACREDITOIVA_AV, CUENTADEBITORETE_AV, CUENTACREDITORETE_AV, CUENTADEBITODESCUENTO_AV, CUENTACREDITODESCUENTO_AV, CUENTADEBITOICA_AV, CUENTACREDITOICA_AV, CUENTADEBITOUTILIDAD_AV, CUENTACREDITOUTILIDAD_AV, AUXILIAR, CENTRO_COSTO, MANEJA_RANGOTIEMPO, PORCETAJE_UTILIDAD, EXISTENCIA, CUENTA_RECAUDO, DIGITOS_REDONDEO, ESTADO, CLASE_CONCEPTO, CTADEBACOMETIDA, CTACREDACOMETIDA, CTADEBACOMETIDA_AV, CTACREDACOMETIDA_AV, CTADEBAIU, CTACREDAIU, CTADEBAIU_AV, CTACREDAIU_AV, CTADEBADMONIMP, CTACREDADMONIMP, CTADEBADMONIMP_AV, CTACREDADMONIMP_AV, CTADEBUTILIDADAIU, CTACREDUTILIDADAIU, CTADEBUTILIDADAIU_AV, CTACREDUTILIDADAIU_AV, CTADEBIVAUTILIDAD, CTACREDIVAUTILIDAD, CTADEBIVAUTILIDAD_AV, CTACREDIVAUTILIDAD_AV, FORMULAR_ACOMETIDA, FORMULAR_AIU, FORMULAR_ADMONIMP, FORMULAR_UTILIDADAIU, FORMULAR_IVAUTILIDAD, AGRUPAR_COMO, CTAORDENDEUDORA_DEBITO, CTAORDENDEUDORA_CREDITO, CANTIDAD_PORDEFECTO, UNICO_BASEGRAVABLE, FILTROREGIMEN, DESCUENTO, NIVEL, FACTOR_RED_BASE, FACTOR_RED_BASETOTAL, FACTOR_RED_DESCUENTO, FACTOR_RED_ICA, FACTOR_RED_IVA, FACTOR_RED_RETE, REFERENCIA, FUENTE_RECURSO, SINSITUACIONFONDOS, APLICAIMPOCONSUMO, VALOR_IMPOCONSUMO, CTACREDIMPOCONSUMO, CTADEBIMPOCONSUMO, CODEQUIV_DIAN, DESCUENTOS_FE, CARGO_FE, APLICAAUTORENTA, PORCENTAJEAUTORENTA, CUENTADEBITOAUTORENTA, CUENTACREDITOAUTORENTA, CUENTADEBITOAUTORENTA_AV, CUENTA