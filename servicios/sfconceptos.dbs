	<query id="getSfconceptosPagGetconceptosporinmuebleselecionadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT C1.NOMBRE, C1.CODIGO, C1.VALOR_BASE, CASE WHEN (C1.APLICAIVA = 0) THEN 'false' ELSE 'true' END APLICAIVA, C1.PORCENTAJEIVA FROM INMUEBLE_FACTURACION IMF INNER JOIN SF_CONCEPTOS C1 ON (C1.COMPANIA = IMF.COMPANIA AND C1.CODIGO = IMF.CONCEPTO1) WHERE IMF.CODIGOINMUEBLE = :CODIGOINMUEBLE AND C1.ANO = :ANO AND C1.COMPANIA = :COMPANIA UNION SELECT C2.NOMBRE, C2.CODIGO, C2.VALOR_BASE, CASE WHEN (C2.APLICAIVA = 0) THEN 'false' ELSE 'true' END APLICAIVA, C2.PORCENTAJEIVA FROM INMUEBLE_FACTURACION IMF INNER JOIN SF_CONCEPTOS C2 ON (C2.COMPANIA = IMF.COMPANIA AND C2.CODIGO = IMF.CONCEPTO2) WHERE IMF.CODIGOINMUEBLE = :CODIGOINMUEBLE AND C2.ANO = :ANO AND C2.COMPANIA = :COMPANIA UNION SELECT C3.NOMBRE, C3.CODIGO, C3.VALOR_BASE, CASE WHEN (C3.APLICAIVA = 0) THEN 'false' ELSE 'true' END APLICAIVA, C3.PORCENTAJEIVA FROM INMUEBLE_FACTURACION IMF INNER JOIN SF_CONCEPTOS C3 ON (C3.COMPANIA = IMF.COMPANIA AND C3.CODIGO = IMF.CONCEPTO3) WHERE IMF.CODIGOINMUEBLE = :CODIGOINMUEBLE AND C3.ANO = :ANO AND C3.COMPANIA = :COMPANIA UNION SELECT C4.NOMBRE, C4.CODIGO, C4.VALOR_BASE, CASE WHEN (C4.APLICAIVA = 0) THEN 'false' ELSE 'true' END APLICAIVA, C4.PORCENTAJEIVA FROM INMUEBLE_FACTURACION IMF INNER JOIN SF_CONCEPTOS C4 ON (C4.COMPANIA = IMF.COMPANIA AND C4.CODIGO = IMF.CONCEPTO4) WHERE IMF.CODIGOINMUEBLE = :CODIGOINMUEBLE AND C4.ANO = :ANO AND C4.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_BASE), '%')) AND (CASE WHEN APLICAIVA IS NULL THEN ' ' ELSE UPPER(APLICAIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICAIVA), '%')) AND (CASE WHEN PORCENTAJEIVA IS NULL THEN ' ' ELSE UPPER(PORCENTAJEIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJEIVA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","CODIGO":"$CODIGO","VALOR_BASE":"$VALOR_BASE","APLICAIVA":"$APLICAIVA","PORCENTAJEIVA":"$PORCENTAJEIVA"}]}}		</result>
		<param name="CODIGOINMUEBLE" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="APLICAIVA" sqlType="STRING"/>
		<param name="PORCENTAJEIVA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
