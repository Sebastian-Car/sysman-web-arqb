	<query id="getSfconceptosProductosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, CF.NOMBRE DESCRIPCIONPRODUCTO, CF.CODEQUIV_DIAN CODIGOPRODUCTO, U.CODIGO_DIAN UNIDADMEDIDA, CF.VALOR_BASE VALORITEM FROM SF_CONCEPTOS CF INNER JOIN UNIDAD U ON CF.UNIDAD = U.UNIDAD WHERE CF.COMPANIA = :COMPANIA AND CF.ANO = :ANO AND CODEQUIV_DIAN = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCIONPRODUCTO":"$DESCRIPCIONPRODUCTO","CODIGOPRODUCTO":"$CODIGOPRODUCTO","UNIDADMEDIDA":"$UNIDADMEDIDA","VALORITEM":"$VALORITEM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptos/productosporcodigo">
