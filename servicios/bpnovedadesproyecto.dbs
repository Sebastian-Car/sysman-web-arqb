	<query id="getBpnovedadesproyectoPagNovedadoriginalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TO_CHAR(BPNPCDPO.CODIGO) NOVORIGINAL, TO_CHAR(BPNPCDP.CODIGO) NOVEDAD  FROM BPNOVEDADPROYECTO BPNPCDP LEFT JOIN BPNOVEDADPROYECTO BPNPMOD ON BPNPCDP.DEPENDENCIA_AFECTAR = BPNPMOD.DEPENDENCIA AND BPNPCDP.DOCUMENTO_AFECTAR = BPNPMOD.CODIGO AND BPNPCDP.CLASET_AFECTAR = BPNPMOD.CLASET AND BPNPCDP.TIPOT_AFECTAR = BPNPMOD.TIPOT AND BPNPCDP.COMPANIA = BPNPMOD.COMPANIA LEFT JOIN BPNOVEDADPROYECTO ON BPNPMOD.DEPENDENCIA_AFECTAR = BPNOVEDADPROYECTO.DEPENDENCIA AND BPNPMOD.DOCUMENTO_AFECTAR = BPNOVEDADPROYECTO.CODIGO AND BPNPMOD.CLASET_AFECTAR = BPNOVEDADPROYECTO.CLASET AND BPNPMOD.TIPOT_AFECTAR = BPNOVEDADPROYECTO.TIPOT AND BPNPMOD.COMPANIA = BPNOVEDADPROYECTO.COMPANIA LEFT JOIN BPNOVEDADPROYECTO BPNPCDPO ON BPNOVEDADPROYECTO.COMPANIA = BPNPCDPO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BPNPCDPO.TIPOT_AFECTAR AND BPNOVEDADPROYECTO.CLASET = BPNPCDPO.CLASET_AFECTAR AND BPNOVEDADPROYECTO.DEPENDENCIA = BPNPCDPO.DEPENDENCIA_AFECTAR AND BPNOVEDADPROYECTO.CODIGO = BPNPCDPO.DOCUMENTO_AFECTAR WHERE BPNPCDP.FECHA BETWEEN :FECHAINICIAL AND :FECHAFINAL AND BPNPCDPO.TIPOT = :TIPOTFILTRAR AND BPNPCDP.MODIFICACION &lt;&gt;0 UNION SELECT 'TODOS' NOVORIGINAL, 'TODOS' NOVEDAD FROM BPNOVEDADPROYECTO) WHERE (CASE WHEN NOVORIGINAL IS NULL THEN ' ' ELSE UPPER(NOVORIGINAL) END)  LIKE UPPER(:NOVORIGINAL || '%')  AND (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END)  LIKE UPPER(:NOVEDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOVORIGINAL":"$NOVORIGINAL","NOVEDAD":"$NOVEDAD"}]}}		</result>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="TIPOTFILTRAR" sqlType="STRING"/>
		<param name="NOVORIGINAL" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
