	<query id="getBpnovedadesproyectoNumCodigoApruebaFinanciacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.CODIGO,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, BPNOVEDADPROYECTO.NUMERORADICADO, BP_D_NOVEDADPROYECTO.CODIGO CODIGOBPD, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.ESTADO,(CASE BPTIPONOVEDAD.AFECTAPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) AFECTAPROGRAMACION, BPNOVEDADPROYECTO.DEPENDENCIA, BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET  FROM BPNOVEDADPROYECTO INNER JOIN BPTIPONOVEDAD ON BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT INNER JOIN BP_D_NOVEDADPROYECTO ON BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.ESTADO ='V' AND BPTIPONOVEDAD.AFECTAPROGRAMACION NOT IN (0) AND BPNOVEDADPROYECTO.VIGENCIA = :ANO AND BP_D_NOVEDADPROYECTO.PROYECTO = :CODIGOPROYECTO AND BP_D_NOVEDADPROYECTO.COMPONENTE = :COMPONENTE AND NVL(BP_D_NOVEDADPROYECTO.CONPROGRAMACION,0)NOT IN 0 ORDER BY BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NUMERORADICADO IS NULL THEN ' ' ELSE UPPER(NUMERORADICADO) END)  LIKE UPPER( '%' || :NUMERORADICADO || '%')  AND (CASE WHEN CODIGOBPD IS NULL THEN ' ' ELSE UPPER(CODIGOBPD) END)  LIKE UPPER( '%' || :CODIGOBPD || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%')  AND (CASE WHEN AFECTAPROGRAMACION IS NULL THEN ' ' ELSE UPPER(AFECTAPROGRAMACION) END)  LIKE UPPER( '%' || :AFECTAPROGRAMACION || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER( '%' || :TIPOT || '%')  AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END)  LIKE UPPER( '%' || :CLASET || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
