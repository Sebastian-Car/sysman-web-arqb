	<query id="getBpnovedadesproyectoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE BPNOVEDADPROYECTO.MODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) MODIFICACION,TERCERO.NOMBRE NOMBRERESPONSABLE, BPNOVEDADPROYECTO.RESPONSABLE, BPNOVEDADPROYECTO.CARGORESPONSABLE, BPNOVEDADPROYECTO.CARGO_RESPONS_REVIS, BPNOVEDADPROYECTO.RESPONSABLE_REVIS, TERCERO_REVIS.NOMBRE NOMBRE_RESPON_REVIS, BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBREDEPENDECIA, BPNOVEDADPROYECTO.VIGENCIA, BPNOVEDADPROYECTO.IMPUTACIONPRESUPUESTAL,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(BPNOVEDADPROYECTO.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO, BPNOVEDADPROYECTO.NUMERORADICADO, BPNOVEDADPROYECTO.VALORSOLICITADO, BPNOVEDADPROYECTO.VALORAPROBADO, BPNOVEDADPROYECTO.VALORTOTAL, BPNOVEDADPROYECTO.ESTADO, BPNOVEDADPROYECTO.DOCUMENTO_AFECTAR, BPNOVEDADPROYECTO.DEPENDENCIA_AFECTAR, BPNOVEDADPROYECTO.TIPOT_AFECTAR, BPNOVEDADPROYECTO.CLASET_AFECTAR, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.RESOLUCIONMODIFICACION, BPNOVEDADPROYECTO.FECHARESOLICION, BPNOVEDADPROYECTO.TIEMPOEJECUCION,(CASE BPNOVEDADPROYECTO.AFECTADO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADO, BPNOVEDADPROYECTO.ESTADO_MODIFICADOPOR,(TO_CHAR(BPNOVEDADPROYECTO.ESTADO_FECHAMODIFICADO,'DD/MM/YYYY HH24:MI:SS')) ESTADO_FECHAMODIFICADO,(TO_CHAR(BPNOVEDADPROYECTO.ESTADO_HORAMODIFICADO,'DD/MM/YYYY HH24:MI:SS')) ESTADO_HORAMODIFICADO,(CASE BPNOVEDADPROYECTO.VOBOBP WHEN 0 THEN 'false' ELSE 'true' END) VOBOBP,(TO_CHAR(BPNOVEDADPROYECTO.FECHA_ENVIO_BPPIM,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENVIO_BPPIM,(TO_CHAR(BPNOVEDADPROYECTO.FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VOBO,(TO_CHAR(BPNOVEDADPROYECTO.HORA_VOBO,'DD/MM/YYYY HH24:MI:SS')) HORA_VOBO, BPNOVEDADPROYECTO.USUARIO_VOBO,(CASE BPNOVEDADPROYECTO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE BPNOVEDADPROYECTO.DOCUMENTORELACIONADO WHEN 0 THEN 'false' ELSE 'true' END) DOCUMENTORELACIONADO, BPNOVEDADPROYECTO.VALORPROGRAMADO,(CASE BPNOVEDADPROYECTO.CONPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) CONPROGRAMACION, BPNOVEDADPROYECTO.DEPENDENCIA_CREADOR,(TO_CHAR(BPNOVEDADPROYECTO.DEPENDENCIA_FECHACREADO,'DD/MM/YYYY HH24:MI:SS')) DEPENDENCIA_FECHACREADO,(TO_CHAR(BPNOVEDADPROYECTO.DEPENDENCIA_HORACREADO,'DD/MM/YYYY HH24:MI:SS')) DEPENDENCIA_HORACREADO, BPNOVEDADPROYECTO.DEPENDENCIA_MODIFICADOPOR,(TO_CHAR(BPNOVEDADPROYECTO.DEPENDENCIA_FECHAMODIFICADO,'DD/MM/YYYY HH24:MI:SS')) DEPENDENCIA_FECHAMODIFICADO,(TO_CHAR(BPNOVEDADPROYECTO.DEPENDENCIA_HORAMODIFICADO,'DD/MM/YYYY HH24:MI:SS')) DEPENDENCIA_HORAMODIFICADO,(CASE BPNOVEDADPROYECTO.CONCOMPROBANTEPPTAL WHEN 0 THEN 'false' ELSE 'true' END) CONCOMPROBANTEPPTAL, BPNOVEDADPROYECTO.OBSERVACIONES, BPNOVEDADPROYECTO.CREATED_BY,(TO_CHAR(BPNOVEDADPROYECTO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, BPNOVEDADPROYECTO.MODIFIED_BY,(TO_CHAR(BPNOVEDADPROYECTO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(BPNOVEDADPROYECTO.FECHA_VALIDEZ,'DD/MM/YYYY HH24:MI:SS')) FECHA_VALIDEZ,(CASE BPNOVEDADPROYECTO.PROCESOFINANCIERO WHEN 0 THEN 'false' ELSE 'true' END) PROCESOFINANCIERO, BPNOVEDADPROYECTO.NECESIDADN, BPNOVEDADPROYECTO.SUCURSAL, BPNOVEDADPROYECTO.DEPENDENCIA_RESPONS_REVIS, BPNOVEDADPROYECTO.SUCURSAL_REVIS, BPNOVEDADPROYECTO.DEPENDENCIA_SEC, DEPENDENCIASEC.NOMBRE NOMBREDEPENDECIASEC, BPNOVEDADPROYECTO.RESPONSABLE_SEC, TERCEROSEC.NOMBRE NOMBRE_RESPON_SEC, BPNOVEDADPROYECTO.SUCURSAL_SEC, BPNOVEDADPROYECTO.MODALIDAD_SELECC, BPNOVEDADPROYECTO.VALOR_DISMINUIDO, TIPOADJUDICACION.DESCRIPCION  FROM BPNOVEDADPROYECTO INNER JOIN DEPENDENCIA ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN DEPENDENCIA DEPENDENCIASEC ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIASEC.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA_SEC = DEPENDENCIASEC.CODIGO INNER JOIN TERCERO ON BPNOVEDADPROYECTO.COMPANIA = TERCERO.COMPANIA AND BPNOVEDADPROYECTO.RESPONSABLE = TERCERO.NIT AND BPNOVEDADPROYECTO.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN TERCERO TERCEROSEC ON BPNOVEDADPROYECTO.COMPANIA = TERCEROSEC.COMPANIA AND BPNOVEDADPROYECTO.RESPONSABLE_SEC = TERCEROSEC.NIT AND BPNOVEDADPROYECTO.SUCURSAL_SEC = TERCEROSEC.SUCURSAL LEFT JOIN TERCERO TERCERO_REVIS ON BPNOVEDADPROYECTO.COMPANIA = TERCERO_REVIS.COMPANIA AND BPNOVEDADPROYECTO.RESPONSABLE_REVIS = TERCERO_REVIS.NIT AND BPNOVEDADPROYECTO.SUCURSAL_REVIS = TERCERO_REVIS.SUCURSAL LEFT JOIN TIPOADJUDICACION ON BPNOVEDADPROYECTO.COMPANIA = TIPOADJUDICACION.COMPANIA AND BPNOVEDADPROYECTO.MODALIDAD_SELECC = TIPOADJUDICACION.CODIGO WHERE BPNOVEDADPROYECTO.COMPANIA= :KEY_COMPANIA AND BPNOVEDADPROYECTO.TIPOT= :KEY_TIPOT AND BPNOVEDADPROYECTO.CLASET= :KEY_CLASET AND BPNOVEDADPROYECTO.CODIGO= :KEY_CODIGO AND BPNOVEDADPROYECTO.DEPENDENCIA= :KEY_DEPENDENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MODIFICACION":"$MODIFICACION(type:boolean)","NOMBRERESPONSABLE":"$NOMBRERESPONSABLE","RESPONSABLE":"$RESPONSABLE","CARGORESPONSABLE":"$CARGORESPONSABLE","CARGO_RESPONS_REVIS":"$CARGO_RESPONS_REVIS","RESPONSABLE_REVIS":"$RESPONSABLE_REVIS","NOMBRE_RESPON_REVIS":"$NOMBRE_RESPON_REVIS","COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","NOMBREDEPENDECIA":"$NOMBREDEPENDECIA","VIGENCIA":"$VIGENCIA(type:integer)","IMPUTACIONPRESUPUESTAL":"$IMPUTACIONPRESUPUESTAL","FECHA":"$FECHA","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","NUMERORADICADO":"$NUMERORADICADO","VALORSOLICITADO":"$VALORSOLICITADO","VALORAPROBADO":"$VALORAPROBADO","VALORTOTAL":"$VALORTOTAL","ESTADO":"$ESTADO","DOCUMENTO_AFECTAR":"$DOCUMENTO_AFECTAR(type:long)","DEPENDENCIA_AFECTAR":"$DEPENDENCIA_AFECTAR","TIPOT_AFECTAR":"$TIPOT_AFECTAR","CLASET_AFECTAR":"$CLASET_AFECTAR","OBJETO":"$OBJETO","RESOLUCIONMODIFICACION":"$RESOLUCIONMODIFICACION","FECHARESOLICION":"$FECHARESOLICION","TIEMPOEJECUCION":"$TIEMPOEJECUCION","AFECTADO":"$AFECTADO(type:boolean)","ESTADO_MODIFICADOPOR":"$ESTADO_MODIFICADOPOR","ESTADO_FECHAMODIFICADO":"$ESTADO_FECHAMODIFICADO","ESTADO_HORAMODIFICADO":"$ESTADO_HORAMODIFICADO","VOBOBP":"$VOBOBP(type:boolean)","FECHA_ENVIO_BPPIM":"$FECHA_ENVIO_BPPIM","FECHA_VOBO":"$FECHA_VOBO","HORA_VOBO":"$HORA_VOBO","USUARIO_VOBO":"$USUARIO_VOBO","IMPRESO":"$IMPRESO(type:boolean)","DOCUMENTORELACIONADO":"$DOCUMENTORELACIONADO(type:boolean)","VALORPROGRAMADO":"$VALORPROGRAMADO","CONPROGRAMACION":"$CONPROGRAMACION(type:boolean)","DEPENDENCIA_CREADOR":"$DEPENDENCIA_CREADOR","DEPENDENCIA_FECHACREADO":"$DEPENDENCIA_FECHACREADO","DEPENDENCIA_HORACREADO":"$DEPENDENCIA_HORACREADO","DEPENDENCIA_MODIFICADOPOR":"$DEPENDENCIA_MODIFICADOPOR","DEPENDENCIA_FECHAMODIFICADO":"$DEPENDENCIA_FECHAMODIFICADO","DEPENDENCIA_HORAMODIFICADO":"$DEPENDENCIA_HORAMODIFICADO","CONCOMPROBANTEPPTAL":"$CONCOMPROBANTEPPTAL(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","FECHA_VALIDEZ":"$FECHA_VALIDEZ","PROCESOFINANCIERO":"$PROCESOFINANCIERO(type:boolean)","NECESIDADN":"$NECESIDADN","SUCURSAL":"$SUCURSAL","DEPENDENCIA_RESPONS_REVIS":"$DEPENDENCIA_RESPONS_REVIS","SUCURSAL_REVIS":"$SUCURSAL_REVIS","DEPENDENCIA_SEC":"$DEPENDENCIA_SEC","NOMBREDEPENDECIASEC":"$NOMBREDEPENDECIASEC","RESPONSABLE_SEC":"$RESPONSABLE_SEC","NOMBRE_RESPON_SEC":"$NOMBRE_RESPON_SEC","SUCURSAL_SEC":"$SUCURSAL_SEC","MODALIDAD_SELECC":"$MODALIDAD_SELECC","VALOR_DISMINUIDO":"$VALOR_DISMINUIDO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOT" sqlType="STRING"/>
		<param name="KEY_CLASET" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>

	</query>
