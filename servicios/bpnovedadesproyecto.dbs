	<query id="getBpnovedadesproyectoTiponovedadPorDepYResQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET  FROM BPNOVEDADPROYECTO LEFT JOIN BPTIPONOVEDAD ON (BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA) AND (BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT) AND (BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = :DEPENDENCIA AND BPNOVEDADPROYECTO.RESPONSABLE = :RESPONSABLE AND BPNOVEDADPROYECTO.TIPOT = :TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOT":"$TIPOT","CLASET":"$CLASET"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/tiponovedadpordepyres">
		<call-query href="getBpnovedadesproyectoTiponovedadPorDepYResQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoTotalSoliciAprovQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM (D.VALORSOLICITADO) TOTALVALORSOLICITADO, SUM (D.VALORAPROBADO) TOTALVALORAPROBADO  FROM BPNOVEDADPROYECTO N LEFT JOIN BP_D_NOVEDADPROYECTO D ON N.DEPENDENCIA = D.DEPENDENCIA AND N.CODIGO = D.NOVEDAD AND N.CLASET = D.CLASET AND N.TIPOT = D.TIPOT AND N.COMPANIA = D.COMPANIA LEFT JOIN PROYECTOS P ON D.COMPANIA = P.COMPANIA AND D.PROYECTO = P.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE DR ON P.COMPANIA = DR.COMPANIA AND P.DEPENDENCIA = DR.DEPENDENCIA AND P.RESPONSABLE = DR.RESPONSABLE LEFT JOIN DEPENDENCIA DP ON N.COMPANIA = DP.COMPANIA AND N.DEPENDENCIA = DP.CODIGO LEFT JOIN BP_ACTIVIDADES A ON D.COMPANIA = A.COMPANIA AND D.ACTIVIDAD = A.CODIGO LEFT JOIN RESPONSABLE R ON P.RESPONSABLE = R.CEDULA AND P.COMPANIA = R.COMPANIA LEFT JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL WHERE N.COMPANIA = :COMPANIA AND N.FECHA BETWEEN TO_DATE(:FECHAINICIAL, 'DD/MM/YYYY HH24:MI:SS') AND TO_DATE(:FECHAFINAL, 'DD/MM/YYYY HH24:MI:SS') AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROPROYECTO THEN CASE WHEN D.PROYECTO = :FILTROPROYECTO THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todas' &lt;&gt; :FILTRODEPENDENCIA THEN CASE WHEN N.DEPENDENCIA = :FILTRODEPENDENCIA THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROTIPOT THEN CASE WHEN N.TIPOT = :FILTROTIPOT THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'T' &lt;&gt; :FILTROESTADO THEN CASE WHEN N.ESTADO = :FILTROESTADO THEN -1 ELSE 0 END ELSE -1 END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTALVALORSOLICITADO":"$TOTALVALORSOLICITADO","TOTALVALORAPROBADO":"$TOTALVALORAPROBADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FILTROPROYECTO" sqlType="STRING"/>
		<param name="FILTRODEPENDENCIA" sqlType="STRING"/>
		<param name="FILTROTIPOT" sqlType="STRING"/>
		<param name="FILTROESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/totalsoliciaprov">
		<call-query href="getBpnovedadesproyectoTotalSoliciAprovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="FILTROPROYECTO" query-param="FILTROPROYECTO"/>
			<with-param name="FILTRODEPENDENCIA" query-param="FILTRODEPENDENCIA"/>
			<with-param name="FILTROTIPOT" query-param="FILTROTIPOT"/>
			<with-param name="FILTROESTADO" query-param="FILTROESTADO"/>

		</call-query>
	</resource>
	<query id="updateBpnovedadesproyectoActualizaImpreso" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPNOVEDADPROYECTO SET IMPRESO     = :IMPRESO, MODIFIED_BY  =:MODIFIED_BY,   DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPANIA  = :COMPANIA AND TIPOT       = :TIPOT AND CLASET      = :CLASET AND CODIGO      = :CODIGO AND DEPENDENCIA = :DEPENDENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IMPRESO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpnovedadesproyecto/actualizaimpreso">
		<call-query href="updateBpnovedadesproyectoActualizaImpreso">
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPagNombretipotclasetQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.TIPOT, BPTIPONOVEDAD.NOMBRE, BPNOVEDADPROYECTO.CLASET  FROM BPNOVEDADPROYECTO LEFT JOIN BPTIPONOVEDAD ON (BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA) AND (BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT) AND (BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT IN ('SCD', 'MOD') AND TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY') &lt;= TO_DATE(:FECHA,'DD/MM/YYYY')) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER( '%' || :TIPOT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END)  LIKE UPPER( '%' || :CLASET || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOT":"$TIPOT","NOMBRE":"$NOMBRE","CLASET":"$CLASET"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/nombretipotclaset/pag">
		<call-query href="getBpnovedadesproyectoPagNombretipotclasetQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumNombretipotclasetQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.TIPOT, BPTIPONOVEDAD.NOMBRE, BPNOVEDADPROYECTO.CLASET  FROM BPNOVEDADPROYECTO LEFT JOIN BPTIPONOVEDAD ON (BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA) AND (BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT) AND (BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT IN ('SCD', 'MOD') AND TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY') &lt;= TO_DATE(:FECHA,'DD/MM/YYYY')) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER( '%' || :TIPOT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END)  LIKE UPPER( '%' || :CLASET || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/nombretipotclaset/num">
		<call-query href="getBpnovedadesproyectoNumNombretipotclasetQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
