		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumTodosPorTipotQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.TIPOT, BPTIPONOVEDAD.NOMBRE, BPNOVEDADPROYECTO.CLASET  FROM BPNOVEDADPROYECTO LEFT JOIN BPTIPONOVEDAD ON BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT AND BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT NOT IN (:TIPO)) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
