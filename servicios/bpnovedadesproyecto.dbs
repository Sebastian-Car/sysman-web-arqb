			<with-param name="RESPONSABLE_REVIS" query-param="RESPONSABLE_REVIS"/>
			<with-param name="CARGO_RESPONS_REVIS" query-param="CARGO_RESPONS_REVIS"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DEPENDENCIA_RESPONS_REVIS" query-param="DEPENDENCIA_RESPONS_REVIS"/>
			<with-param name="SUCURSAL_REVIS" query-param="SUCURSAL_REVIS"/>
			<with-param name="DEPENDENCIA_SEC" query-param="DEPENDENCIA_SEC"/>
			<with-param name="RESPONSABLE_SEC" query-param="RESPONSABLE_SEC"/>
			<with-param name="MODALIDAD_SELECC" query-param="MODALIDAD_SELECC"/>
			<with-param name="VALOR_DISMINUIDO" query-param="VALOR_DISMINUIDO"/>
			<with-param name="SUCURSAL_SEC" query-param="SUCURSAL_SEC"/>

		</call-query>
