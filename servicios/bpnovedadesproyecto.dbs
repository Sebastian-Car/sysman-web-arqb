	<query id="getBpnovedadesproyectoPagMonitorNovedadesEntreFechasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  N.COMPANIA, N.TIPOT, N.CLASET, N.CODIGO,(CASE N.MODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) MODIFICACION, CASE WHEN N.TIPOT IN ('CDP') AND N.MODIFICACION NOT IN(0) THEN TO_CHAR(N.DOCUMENTO_AFECTAR) ELSE '' END NOVEDAD_ORIG, N.DEPENDENCIA, D.ESPECIFICACION,(TO_CHAR(N.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, N.VIGENCIA,(CASE N.VOBOBP WHEN 0 THEN 'false' ELSE 'true' END) VOBOBP,(TO_CHAR(N.FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VOBO,(TO_CHAR(N.HORA_VOBO,'DD/MM/YYYY HH24:MI:SS')) HORA_VOBO, N.ESTADO, DECODE (N.ESTADO, 'V', 'VIGENTE', 'A','ANULADA','N','No Aprobado','AP','APROBADA','T','Todos') NOMBREESTADO, P.CODIGOBPIM, P.NOMBREPROYECTO PROYECTO, N.OBJETO, D.VALORSOLICITADO VLR_SOLICITADO, D.VALORAPROBADO VAL_APROBADO, D.ACTIVIDAD COD_ACTIVIDAD, A.NOMBRE ACTIVIDAD, D.ID_META_PRODUCTO META_PRODUCTO, D.RUBROPRESUPUESTAL, D.FUENTERECURSOS, DP.NOMBRE NOMDEPENDENCIA, T.NOMBRE RESPONSABLE  FROM BPNOVEDADPROYECTO N LEFT JOIN BP_D_NOVEDADPROYECTO D ON N.DEPENDENCIA = D.DEPENDENCIA AND N.CODIGO = D.NOVEDAD AND N.CLASET = D.CLASET AND N.TIPOT = D.TIPOT AND N.COMPANIA = D.COMPANIA LEFT JOIN PROYECTOS P ON D.COMPANIA = P.COMPANIA AND D.PROYECTO = P.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE DR ON P.COMPANIA = DR.COMPANIA AND P.DEPENDENCIA = DR.DEPENDENCIA AND P.RESPONSABLE = DR.RESPONSABLE LEFT JOIN DEPENDENCIA DP ON N.COMPANIA = DP.COMPANIA AND N.DEPENDENCIA = DP.CODIGO LEFT JOIN BP_ACTIVIDADES A ON D.COMPANIA = A.COMPANIA AND D.ACTIVIDAD = A.CODIGO LEFT JOIN RESPONSABLE R ON P.RESPONSABLE = R.CEDULA AND P.COMPANIA = R.COMPANIA LEFT JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL WHERE N.COMPANIA = :COMPANIA AND TRUNC(N.FECHA) BETWEEN TO_DATE(:FECHAINICIAL, 'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL, 'DD/MM/YYYY') AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROPROYECTO THEN CASE WHEN D.PROYECTO = :FILTROPROYECTO THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todas' &lt;&gt; :FILTRODEPENDENCIA THEN CASE WHEN N.DEPENDENCIA = :FILTRODEPENDENCIA THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROTIPOT THEN CASE WHEN N.TIPOT = :FILTROTIPOT THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'T' &lt;&gt; :FILTROESTADO THEN CASE WHEN N.ESTADO = :FILTROESTADO THEN -1 ELSE 0 END ELSE -1 END) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER( '%' || :TIPOT || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN MODIFICACION IS NULL THEN ' ' ELSE UPPER(MODIFICACION) END)  LIKE UPPER( '%' || :MODIFICACION || '%')  AND (CASE WHEN NOVEDAD_ORIG IS NULL THEN ' ' ELSE UPPER(NOVEDAD_ORIG) END)  LIKE UPPER(:NOVEDAD_ORIG || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%')  AND (CASE WHEN VOBOBP IS NULL THEN ' ' ELSE UPPER(VOBOBP) END)  LIKE UPPER( '%' || :VOBOBP || '%')  AND (CASE WHEN FECHA_VOBO IS NULL THEN ' ' ELSE UPPER(FECHA_VOBO) END)  LIKE UPPER(:FECHA_VOBO || '%')  AND (CASE WHEN NOMBREESTADO IS NULL THEN ' ' ELSE UPPER(NOMBREESTADO) END)  LIKE UPPER(:NOMBREESTADO || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER( '%' || :CODIGOBPIM || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN VLR_SOLICITADO IS NULL THEN ' ' ELSE UPPER(VLR_SOLICITADO) END)  LIKE UPPER( '%' || :VLR_SOLICITADO || '%')  AND (CASE WHEN VAL_APROBADO IS NULL THEN ' ' ELSE UPPER(VAL_APROBADO) END)  LIKE UPPER( '%' || :VAL_APROBADO || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER( '%' || :ACTIVIDAD || '%')  AND (CASE WHEN RUBROPRESUPUESTAL IS NULL THEN ' ' ELSE UPPER(RUBROPRESUPUESTAL) END)  LIKE UPPER( '%' || :RUBROPRESUPUESTAL || '%')  AND (CASE WHEN FUENTERECURSOS IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOS) END)  LIKE UPPER( '%' || :FUENTERECURSOS || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER( '%' || :RESPONSABLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","CODIGO":"$CODIGO","MODIFICACION":"$MODIFICACION(type:boolean)","NOVEDAD_ORIG":"$NOVEDAD_ORIG","DEPENDENCIA":"$DEPENDENCIA","ESPECIFICACION":"$ESPECIFICACION","FECHA":"$FECHA","VIGENCIA":"$VIGENCIA(type:integer)","VOBOBP":"$VOBOBP(type:boolean)","FECHA_VOBO":"$FECHA_VOBO","HORA_VOBO":"$HORA_VOBO","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO","CODIGOBPIM":"$CODIGOBPIM","PROYECTO":"$PROYECTO","OBJETO":"$OBJETO","VLR_SOLICITADO":"$VLR_SOLICITADO","VAL_APROBADO":"$VAL_APROBADO","COD_ACTIVIDAD":"$COD_ACTIVIDAD","ACTIVIDAD":"$ACTIVIDAD","META_PRODUCTO":"$META_PRODUCTO","RUBROPRESUPUESTAL":"$RUBROPRESUPUESTAL","FUENTERECURSOS":"$FUENTERECURSOS","NOMDEPENDENCIA":"$NOMDEPENDENCIA","RESPONSABLE":"$RESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FILTROPROYECTO" sqlType="STRING"/>
		<param name="FILTRODEPENDENCIA" sqlType="STRING"/>
		<param name="FILTROTIPOT" sqlType="STRING"/>
		<param name="FILTROESTADO" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="NOVEDAD_ORIG" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VOBOBP" sqlType="STRING"/>
		<param name="FECHA_VOBO" sqlType="STRING"/>
		<param name="NOMBREESTADO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VLR_SOLICITADO" sqlType="STRING"/>
		<param name="VAL_APROBADO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="RUBROPRESUPUESTAL" sqlType="STRING"/>
		<param name="FUENTERECURSOS" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/monitornovedadesentrefechas/pag">
		<call-query href="getBpnovedadesproyectoPagMonitorNovedadesEntreFechasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="FILTROPROYECTO" query-param="FILTROPROYECTO"/>
			<with-param name="FILTRODEPENDENCIA" query-param="FILTRODEPENDENCIA"/>
			<with-param name="FILTROTIPOT" query-param="FILTROTIPOT"/>
			<with-param name="FILTROESTADO" query-param="FILTROESTADO"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MODIFICACION" query-param="MODIFICACION"/>
			<with-param name="NOVEDAD_ORIG" query-param="NOVEDAD_ORIG"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="VOBOBP" query-param="VOBOBP"/>
			<with-param name="FECHA_VOBO" query-param="FECHA_VOBO"/>
			<with-param name="NOMBREESTADO" query-param="NOMBREESTADO"/>
			<with-param name="CODIGOBPIM" query-param="CODIGOBPIM"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VLR_SOLICITADO" query-param="VLR_SOLICITADO"/>
			<with-param name="VAL_APROBADO" query-param="VAL_APROBADO"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="RUBROPRESUPUESTAL" query-param="RUBROPRESUPUESTAL"/>
			<with-param name="FUENTERECURSOS" query-param="FUENTERECURSOS"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumMonitorNovedadesEntreFechasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  N.COMPANIA, N.TIPOT, N.CLASET, N.CODIGO,(CASE N.MODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) MODIFICACION, CASE WHEN N.TIPOT IN ('CDP') AND N.MODIFICACION NOT IN(0) THEN TO_CHAR(N.DOCUMENTO_AFECTAR) ELSE '' END NOVEDAD_ORIG, N.DEPENDENCIA, D.ESPECIFICACION,(TO_CHAR(N.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, N.VIGENCIA,(CASE N.VOBOBP WHEN 0 THEN 'false' ELSE 'true' END) VOBOBP,(TO_CHAR(N.FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VOBO,(TO_CHAR(N.HORA_VOBO,'DD/MM/YYYY HH24:MI:SS')) HORA_VOBO, N.ESTADO, DECODE (N.ESTADO, 'V', 'VIGENTE', 'A','ANULADA','N','No Aprobado','AP','APROBADA','T','Todos') NOMBREESTADO, P.CODIGOBPIM, P.NOMBREPROYECTO PROYECTO, N.OBJETO, D.VALORSOLICITADO VLR_SOLICITADO, D.VALORAPROBADO VAL_APROBADO, D.ACTIVIDAD COD_ACTIVIDAD, A.NOMBRE ACTIVIDAD, D.ID_META_PRODUCTO META_PRODUCTO, D.RUBROPRESUPUESTAL, D.FUENTERECURSOS, DP.NOMBRE NOMDEPENDENCIA, T.NOMBRE RESPONSABLE  FROM BPNOVEDADPROYECTO N LEFT JOIN BP_D_NOVEDADPROYECTO D ON N.DEPENDENCIA = D.DEPENDENCIA AND N.CODIGO = D.NOVEDAD AND N.CLASET = D.CLASET AND N.TIPOT = D.TIPOT AND N.COMPANIA = D.COMPANIA LEFT JOIN PROYECTOS P ON D.COMPANIA = P.COMPANIA AND D.PROYECTO = P.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE DR ON P.COMPANIA = DR.COMPANIA AND P.DEPENDENCIA = DR.DEPENDENCIA AND P.RESPONSABLE = DR.RESPONSABLE LEFT JOIN DEPENDENCIA DP ON N.COMPANIA = DP.COMPANIA AND N.DEPENDENCIA = DP.CODIGO LEFT JOIN BP_ACTIVIDADES A ON D.COMPANIA = A.COMPANIA AND D.ACTIVIDAD = A.CODIGO LEFT JOIN RESPONSABLE R ON P.RESPONSABLE = R.CEDULA AND P.COMPANIA = R.COMPANIA LEFT JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL WHERE N.COMPANIA = :COMPANIA AND TRUNC(N.FECHA) BETWEEN TO_DATE(:FECHAINICIAL, 'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL, 'DD/MM/YYYY') AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROPROYECTO THEN CASE WHEN D.PROYECTO = :FILTROPROYECTO THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todas' &lt;&gt; :FILTRODEPENDENCIA THEN CASE WHEN N.DEPENDENCIA = :FILTRODEPENDENCIA THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROTIPOT THEN CASE WHEN N.TIPOT = :FILTROTIPOT THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'T' &lt;&gt; :FILTROESTADO THEN CASE WHEN N.ESTADO = :FILTROESTADO THEN -1 ELSE 0 END ELSE -1 END) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER( '%' || :TIPOT || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN MODIFICACION IS NULL THEN ' ' ELSE UPPER(MODIFICACION) END)  LIKE UPPER( '%' || :MODIFICACION || '%')  AND (CASE WHEN NOVEDAD_ORIG IS NULL THEN ' ' ELSE UPPER(NOVEDAD_ORIG) END)  LIKE UPPER(:NOVEDAD_ORIG || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER( '%' || :VIGENCIA || '%')  AND (CASE WHEN VOBOBP IS NULL THEN ' ' ELSE UPPER(VOBOBP) END)  LIKE UPPER( '%' || :VOBOBP || '%')  AND (CASE WHEN FECHA_VOBO IS NULL THEN ' ' ELSE UPPER(FECHA_VOBO) END)  LIKE UPPER(:FECHA_VOBO || '%')  AND (CASE WHEN NOMBREESTADO IS NULL THEN ' ' ELSE UPPER(NOMBREESTADO) END)  LIKE UPPER(:NOMBREESTADO || '%')  AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END)  LIKE UPPER( '%' || :CODIGOBPIM || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN VLR_SOLICITADO IS NULL THEN ' ' ELSE UPPER(VLR_SOLICITADO) END)  LIKE UPPER( '%' || :VLR_SOLICITADO || '%')  AND (CASE WHEN VAL_APROBADO IS NULL THEN ' ' ELSE UPPER(VAL_APROBADO) END)  LIKE UPPER( '%' || :VAL_APROBADO || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER( '%' || :ACTIVIDAD || '%')  AND (CASE WHEN RUBROPRESUPUESTAL IS NULL THEN ' ' ELSE UPPER(RUBROPRESUPUESTAL) END)  LIKE UPPER( '%' || :RUBROPRESUPUESTAL || '%')  AND (CASE WHEN FUENTERECURSOS IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOS) END)  LIKE UPPER( '%' || :FUENTERECURSOS || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER( '%' || :RESPONSABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FILTROPROYECTO" sqlType="STRING"/>
		<param name="FILTRODEPENDENCIA" sqlType="STRING"/>
		<param name="FILTROTIPOT" sqlType="STRING"/>
		<param name="FILTROESTADO" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="NOVEDAD_ORIG" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VOBOBP" sqlType="STRING"/>
		<param name="FECHA_VOBO" sqlType="STRING"/>
		<param name="NOMBREESTADO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VLR_SOLICITADO" sqlType="STRING"/>
		<param name="VAL_APROBADO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="RUBROPRESUPUESTAL" sqlType="STRING"/>
		<param name="FUENTERECURSOS" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>

	</query>
