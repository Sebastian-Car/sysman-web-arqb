	<query id="getBpnovedadesproyectoPagCodobjetoyvaloraprobadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CODIGO, OBJETO, VALORAPROBADO FROM BPNOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND TIPOT = :TIPOT AND VOBOBP NOT IN(0) AND EXTRACT(YEAR FROM FECHA) = :ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END) LIKE UPPER(CONCAT(:VALORAPROBADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","OBJETO":"$OBJETO","VALORAPROBADO":"$VALORAPROBADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/codobjetoyvaloraprobado/pag">
