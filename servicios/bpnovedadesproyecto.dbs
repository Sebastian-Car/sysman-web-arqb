	<query id="getBpnovedadesproyectoNumTodosPorTipotClaseTQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO CODIGONOV, DEPENDENCIA DEPNOV, TIPOT  FROM BPNOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND TIPOT = :TIPOT AND CLASET = :CLASET AND ESTADO NOT IN ('A') ORDER BY CODIGONOV, DEPNOV) WHERE (CASE WHEN CODIGONOV IS NULL THEN ' ' ELSE UPPER(CODIGONOV) END)  LIKE UPPER(:CODIGONOV || '%')  AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="CODIGONOV" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/todosportipotclaset/num">
		<call-query href="getBpnovedadesproyectoNumTodosPorTipotClaseTQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="CODIGONOV" query-param="CODIGONOV"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPorCompaniaYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NUMERORADICADO,(TO_CHAR(FECHA_ENVIO_BPPIM,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENVIO_BPPIM, TO_CHAR(FECHA_VALIDEZ,'DD/MM/YYYY') FECHA_VALIDEZ  FROM BPNOVEDADPROYECTO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = 'SVP' AND BPNOVEDADPROYECTO.CLASET = 'B' AND BPNOVEDADPROYECTO.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NUMERORADICADO":"$NUMERORADICADO","FECHA_ENVIO_BPPIM":"$FECHA_ENVIO_BPPIM","FECHA_VALIDEZ":"$FECHA_VALIDEZ"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/porcompaniaycodigo">
		<call-query href="getBpnovedadesproyectoPorCompaniaYCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoTodosPorCodigoproyQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NUMERORADICADO,(TO_CHAR(FECHA_ENVIO_BPPIM,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENVIO_BPPIM, TO_CHAR(FECHA_VALIDEZ,'DD/MM/YYYY') FECHA_VALIDEZ,CODIGO  FROM BPNOVEDADPROYECTO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = 'SVP' AND BPNOVEDADPROYECTO.CLASET = 'B' AND BPNOVEDADPROYECTO.CODIGO = :NUMERO AND ROWNUM =1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NUMERORADICADO":"$NUMERORADICADO","FECHA_ENVIO_BPPIM":"$FECHA_ENVIO_BPPIM","FECHA_VALIDEZ":"$FECHA_VALIDEZ","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/todosporcodigoproy">
		<call-query href="getBpnovedadesproyectoTodosPorCodigoproyQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPagTodosPorTipoScdFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, VIGENCIA NOMBREPROYECTO  FROM BPNOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND TIPOT IN('SCD') AND CODIGO &gt;= :PROYECTOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREPROYECTO":"$NOMBREPROYECTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/todosportiposcdfinal/pag">
		<call-query href="getBpnovedadesproyectoPagTodosPorTipoScdFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTOINICIAL" query-param="PROYECTOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumTodosPorTipoScdFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, VIGENCIA NOMBREPROYECTO  FROM BPNOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND TIPOT IN('SCD') AND CODIGO &gt;= :PROYECTOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
