	<query id="insertBpnovedadesproyecto" keyColumns="COMPANIA,TIPOT,CLASET,CODIGO,DEPENDENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BPNOVEDADPROYECTO (MODIFICACION, COMPANIA, TIPOT, CLASET, CODIGO, DEPENDENCIA, VIGENCIA, IMPUTACIONPRESUPUESTAL, FECHA, FECHAVENCIMIENTO, NUMERORADICADO, VALORSOLICITADO, VALORAPROBADO, VALORTOTAL, RESPONSABLE, CARGORESPONSABLE, ESTADO, DOCUMENTO_AFECTAR, DEPENDENCIA_AFECTAR, TIPOT_AFECTAR, CLASET_AFECTAR, OBJETO, RESOLUCIONMODIFICACION, FECHARESOLICION, TIEMPOEJECUCION, AFECTADO, ESTADO_MODIFICADOPOR, ESTADO_FECHAMODIFICADO, ESTADO_HORAMODIFICADO, VOBOBP, FECHA_ENVIO_BPPIM, FECHA_VOBO, HORA_VOBO, USUARIO_VOBO, IMPRESO, DOCUMENTORELACIONADO, VALORPROGRAMADO, CONPROGRAMACION, DEPENDENCIA_CREADOR, DEPENDENCIA_FECHACREADO, DEPENDENCIA_HORACREADO, DEPENDENCIA_MODIFICADOPOR, DEPENDENCIA_FECHAMODIFICADO, DEPENDENCIA_HORAMODIFICADO, CONCOMPROBANTEPPTAL, OBSERVACIONES, CREATED_BY, DATE_CREATED, FECHA_VALIDEZ, PROCESOFINANCIERO, NECESIDADN, RESPONSABLE_REVIS, CARGO_RESPONS_REVIS, SUCURSAL, DEPENDENCIA_RESPONS_REVIS, SUCURSAL_REVIS, DEPENDENCIA_SEC, RESPONSABLE_SEC, MODALIDAD_SELECC, VALOR_DISMINUIDO, SUCURSAL_SEC) VALUES (:MODIFICACION, :COMPANIA, :TIPOT, :CLASET, :CODIGO, :DEPENDENCIA, :VIGENCIA, :IMPUTACIONPRESUPUESTAL, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :NUMERORADICADO, :VALORSOLICITADO, :VALORAPROBADO, :VALORTOTAL, :RESPONSABLE, :CARGORESPONSABLE, :ESTADO, :DOCUMENTO_AFECTAR, :DEPENDENCIA_AFECTAR, :TIPOT_AFECTAR, :CLASET_AFECTAR, :OBJETO, :RESOLUCIONMODIFICACION, :FECHARESOLICION, :TIEMPOEJECUCION, :AFECTADO, :ESTADO_MODIFICADOPOR, TO_DATE(:ESTADO_FECHAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:ESTADO_HORAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), :VOBOBP, TO_DATE(:FECHA_ENVIO_BPPIM,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_VOBO,'DD/MM/YYYY HH24:MI:SS'), :USUARIO_VOBO, :IMPRESO, :DOCUMENTORELACIONADO, :VALORPROGRAMADO, :CONPROGRAMACION, :DEPENDENCIA_CREADOR, TO_DATE(:DEPENDENCIA_FECHACREADO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DEPENDENCIA_HORACREADO,'DD/MM/YYYY HH24:MI:SS'), :DEPENDENCIA_MODIFICADOPOR, TO_DATE(:DEPENDENCIA_FECHAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DEPENDENCIA_HORAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), :CONCOMPROBANTEPPTAL, :OBSERVACIONES, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_VALIDEZ,'DD/MM/YYYY HH24:MI:SS'), :PROCESOFINANCIERO, :NECESIDADN, :RESPONSABLE_REVIS, :CARGO_RESPONS_REVIS, :SUCURSAL, :DEPENDENCIA_RESPONS_REVIS, :SUCURSAL_REVIS, :DEPENDENCIA_SEC, :RESPONSABLE_SEC, :MODALIDAD_SELECC, :VALOR_DISMINUIDO, :SUCURSAL_SEC)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOT":"$TIPOT","KEY_CLASET":"$CLASET","KEY_CODIGO":"$CODIGO","KEY_DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param defaultValue="0" name="MODIFICACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
