	<query id="getBpnovedadesproyectoPagListaimpactoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BP_PLAN_INDICATIVO.NOMBRE_INDICADOR  FROM BPNOVEDADPROYECTO INNER JOIN BP_D_NOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA INNER JOIN BP_PLAN_INDICATIVO ON BP_D_NOVEDADPROYECTO.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_D_NOVEDADPROYECTO.ID_META_PRODUCTO = BP_PLAN_INDICATIVO.ID AND BP_D_NOVEDADPROYECTO.VIGENCIA_PLAN_INDICATIVO = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPON AND BPNOVEDADPROYECTO.CLASET = :CLASEN AND BPNOVEDADPROYECTO.CODIGO = :NOVEDAD) WHERE (CASE WHEN NOMBRE_INDICADOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_INDICADOR) END)  LIKE UPPER( '%' || :NOMBRE_INDICADOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_INDICADOR":"$NOMBRE_INDICADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPON" sqlType="STRING"/>
		<param name="CLASEN" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
