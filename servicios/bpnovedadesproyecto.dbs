	<query id="deleteBpnovedadesproyecto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BPNOVEDADPROYECTO WHERE BPNOVEDADPROYECTO.COMPANIA= :KEY_COMPANIA AND BPNOVEDADPROYECTO.TIPOT= :KEY_TIPOT AND BPNOVEDADPROYECTO.CLASET= :KEY_CLASET AND BPNOVEDADPROYECTO.CODIGO= :KEY_CODIGO AND BPNOVEDADPROYECTO.DEPENDENCIA= :KEY_DEPENDENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOT" sqlType="STRING"/>
		<param name="KEY_CLASET" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpnovedadesproyecto">
		<call-query href="deleteBpnovedadesproyecto">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOT" query-param="KEY_TIPOT"/>
			<with-param name="KEY_CLASET" query-param="KEY_CLASET"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.DEPENDENCIA, BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA, DECODE(ESTADO,'V','Vigente','A','Anulada','N','No Aprobado','AP','Aprobada') ESTADO  FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.DEPENDENCIA IS NOT NULL AND BPNOVEDADPROYECTO.VIGENCIA = :VIGENCIASOLICITUD ORDER BY BPNOVEDADPROYECTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBREDEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","DEPENDENCIA":"$DEPENDENCIA","CODIGO":"$CODIGO","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","FECHA":"$FECHA","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="VIGENCIASOLICITUD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREDEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto">
		<call-query href="getBpnovedadesproyectoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="VIGENCIASOLICITUD" query-param="VIGENCIASOLICITUD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBREDEPENDENCIA" query-param="NOMBREDEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.DEPENDENCIA, BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA, DECODE(ESTADO,'V','Vigente','A','Anulada','N','No Aprobado','AP','Aprobada') ESTADO  FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.DEPENDENCIA IS NOT NULL AND BPNOVEDADPROYECTO.VIGENCIA = :VIGENCIASOLICITUD ORDER BY BPNOVEDADPROYECTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBREDEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="VIGENCIASOLICITUD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREDEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/numero">
		<call-query href="getBpnovedadesproyectoNumeroQuery">
