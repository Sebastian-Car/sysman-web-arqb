	<resource method="GET" path="bpnovedadesproyecto/cargardocumentoconimpreso/num">
		<call-query href="getBpnovedadesproyectoNumCargardocumentoconimpresoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TIEMPOEJECUCION" query-param="TIEMPOEJECUCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMERORADICADO" query-param="NUMERORADICADO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="CARGORESPONSABLE" query-param="CARGORESPONSABLE"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="AFECTADO" query-param="AFECTADO"/>
			<with-param name="VALOR_DISMINUIDO" query-param="VALOR_DISMINUIDO"/>
			<with-param name="VALORAPROBADO" query-param="VALORAPROBADO"/>
			<with-param name="VALORSOLICITADO" query-param="VALORSOLICITADO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPagGrillaporusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.DEPENDENCIA, BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA, DECODE(ESTADO,'V','Vigente','A','Anulada','N','No Aprobado','AP','Aprobada') ESTADO  FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.DEPENDENCIA IS NOT NULL AND BPNOVEDADPROYECTO.VIGENCIA = :VIGENCIASOLICITUD AND BPNOVEDADPROYECTO.CREATED_BY = :USUARIO ORDER BY BPNOVEDADPROYECTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBREDEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","DEPENDENCIA":"$DEPENDENCIA","CODIGO":"$CODIGO","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","FECHA":"$FECHA","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="VIGENCIASOLICITUD" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBREDEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
