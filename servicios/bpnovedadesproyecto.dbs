			<with-param name="CLASET" query-param="CLASET"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPagDependenciacompaniaestadoafectadotipoclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE, BPNOVEDADPROYECTO.VIGENCIA, BPNOVEDADPROYECTO.ESTADO, BPNOVEDADPROYECTO.TIEMPOEJECUCION,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, BPNOVEDADPROYECTO.NUMERORADICADO, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.RESPONSABLE, BPNOVEDADPROYECTO.CARGORESPONSABLE, BPNOVEDADPROYECTO.OBSERVACIONES, BPNOVEDADPROYECTO.DEPENDENCIA,(CASE BPNOVEDADPROYECTO.AFECTADO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADO, BPNOVEDADPROYECTO.VALOR_DISMINUIDO, BPNOVEDADPROYECTO.VALORAPROBADO, BPNOVEDADPROYECTO.VALORSOLICITADO, BPNOVEDADPROYECTO.VALORTOTAL FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON (BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO) AND (BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = :DEPENDENCIA AND BPNOVEDADPROYECTO.AFECTADO NOT IN (0) AND BPNOVEDADPROYECTO.TIPOT IN ('SCD') AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.VOBOBP NOT IN (0) AND TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY') &lt;= TO_DATE(:FECHAS,'DD/MM/YYYY')) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(:VIGENCIA, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN TIEMPOEJECUCION IS NULL THEN ' ' ELSE UPPER(TIEMPOEJECUCION) END) LIKE UPPER(CONCAT(:TIEMPOEJECUCION, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN NUMERORADICADO IS NULL THEN ' ' ELSE UPPER(NUMERORADICADO) END) LIKE UPPER(CONCAT(:NUMERORADICADO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE), '%')) AND (CASE WHEN CARGORESPONSABLE IS NULL THEN ' ' ELSE UPPER(CARGORESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CARGORESPONSABLE), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DEPENDENCIA), '%')) AND (CASE WHEN AFECTADO IS NULL THEN ' ' ELSE UPPER(AFECTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:AFECTADO), '%')) AND (CASE WHEN VALOR_DISMINUIDO IS NULL THEN ' ' ELSE UPPER(VALOR_DISMINUIDO) END) LIKE UPPER(CONCAT(:VALOR_DISMINUIDO, '%')) AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END) LIKE UPPER(CONCAT(:VALORAPROBADO, '%')) AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END) LIKE UPPER(CONCAT(:VALORSOLICITADO, '%')) AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END) LIKE UPPER(CONCAT(:VALORTOTAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VIGENCIA":"$VIGENCIA(type:integer)","ESTADO":"$ESTADO","TIEMPOEJECUCION":"$TIEMPOEJECUCION","FECHA":"$FECHA","NUMERORADICADO":"$NUMERORADICADO","OBJETO":"$OBJETO","RESPONSABLE":"$RESPONSABLE","CARGORESPONSABLE":"$CARGORESPONSABLE","OBSERVACIONES":"$OBSERVACIONES","DEPENDENCIA":"$DEPENDENCIA","AFECTADO":"$AFECTADO(type:boolean)","VALOR_DISMINUIDO":"$VALOR_DISMINUIDO","VALORAPROBADO":"$VALORAPROBADO","VALORSOLICITADO":"$VALORSOLICITADO","VALORTOTAL":"$VALORTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="FECHAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TIEMPOEJECUCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMERORADICADO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="CARGORESPONSABLE" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="AFECTADO" sqlType="STRING"/>
		<param name="VALOR_DISMINUIDO" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>
		<param name="VALORSOLICITADO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
