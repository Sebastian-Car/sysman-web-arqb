	</resource>
	<query id="updateBpnovedadesproyecto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPNOVEDADPROYECTO SET MODIFICACION=:MODIFICACION, COMPANIA=:COMPANIA, TIPOT=:TIPOT, CLASET=:CLASET, CODIGO=:CODIGO, DEPENDENCIA=:DEPENDENCIA, VIGENCIA=:VIGENCIA, IMPUTACIONPRESUPUESTAL=:IMPUTACIONPRESUPUESTAL, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), NUMERORADICADO=:NUMERORADICADO, VALORSOLICITADO=:VALORSOLICITADO, VALORAPROBADO=:VALORAPROBADO, VALORTOTAL=:VALORTOTAL, RESPONSABLE=:RESPONSABLE, CARGORESPONSABLE=:CARGORESPONSABLE, ESTADO=:ESTADO, DOCUMENTO_AFECTAR=:DOCUMENTO_AFECTAR, DEPENDENCIA_AFECTAR=:DEPENDENCIA_AFECTAR, TIPOT_AFECTAR=:TIPOT_AFECTAR, CLASET_AFECTAR=:CLASET_AFECTAR, OBJETO=:OBJETO, RESOLUCIONMODIFICACION=:RESOLUCIONMODIFICACION, FECHARESOLICION=:FECHARESOLICION, TIEMPOEJECUCION=:TIEMPOEJECUCION, AFECTADO=:AFECTADO, ESTADO_MODIFICADOPOR=:ESTADO_MODIFICADOPOR, ESTADO_FECHAMODIFICADO=TO_DATE(:ESTADO_FECHAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), ESTADO_HORAMODIFICADO=TO_DATE(:ESTADO_HORAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), VOBOBP=:VOBOBP, FECHA_ENVIO_BPPIM=TO_DATE(:FECHA_ENVIO_BPPIM,'DD/MM/YYYY HH24:MI:SS'), FECHA_VOBO=TO_DATE(:FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS'), HORA_VOBO=TO_DATE(:HORA_VOBO,'DD/MM/YYYY HH24:MI:SS'), USUARIO_VOBO=:USUARIO_VOBO, IMPRESO=:IMPRESO, DOCUMENTORELACIONADO=:DOCUMENTORELACIONADO, VALORPROGRAMADO=:VALORPROGRAMADO, CONPROGRAMACION=:CONPROGRAMACION, DEPENDENCIA_CREADOR=:DEPENDENCIA_CREADOR, DEPENDENCIA_FECHACREADO=TO_DATE(:DEPENDENCIA_FECHACREADO,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA_HORACREADO=TO_DATE(:DEPENDENCIA_HORACREADO,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA_MODIFICADOPOR=:DEPENDENCIA_MODIFICADOPOR, DEPENDENCIA_FECHAMODIFICADO=TO_DATE(:DEPENDENCIA_FECHAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA_HORAMODIFICADO=TO_DATE(:DEPENDENCIA_HORAMODIFICADO,'DD/MM/YYYY HH24:MI:SS'), CONCOMPROBANTEPPTAL=:CONCOMPROBANTEPPTAL, OBSERVACIONES=:OBSERVACIONES, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHA_VALIDEZ=TO_DATE(:FECHA_VALIDEZ,'DD/MM/YYYY HH24:MI:SS'), PROCESOFINANCIERO=:PROCESOFINANCIERO, NECESIDADN=:NECESIDADN, RESPONSABLE_REVIS=:RESPONSABLE_REVIS, CARGO_RESPONS_REVIS=:CARGO_RESPONS_REVIS, SUCURSAL=:SUCURSAL, DEPENDENCIA_RESPONS_REVIS=:DEPENDENCIA_RESPONS_REVIS, SUCURSAL_REVIS=:SUCURSAL_REVIS, DEPENDENCIA_SEC=:DEPENDENCIA_SEC, RESPONSABLE_SEC=:RESPONSABLE_SEC, MODALIDAD_SELECC=:MODALIDAD_SELECC, VALOR_DISMINUIDO=:VALOR_DISMINUIDO, SUCURSAL_SEC=:SUCURSAL_SEC WHERE BPNOVEDADPROYECTO.COMPANIA= :KEY_COMPANIA AND BPNOVEDADPROYECTO.TIPOT= :KEY_TIPOT AND BPNOVEDADPROYECTO.CLASET= :KEY_CLASET AND BPNOVEDADPROYECTO.CODIGO= :KEY_CODIGO AND BPNOVEDADPROYECTO.DEPENDENCIA= :KEY_DEPENDENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
