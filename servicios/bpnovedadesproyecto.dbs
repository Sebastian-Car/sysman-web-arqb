	<query id="getBpnovedadesproyectoPagTodosPorVoboQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE, BPNOVEDADPROYECTO.VIGENCIA, BPNOVEDADPROYECTO.ESTADO, BPNOVEDADPROYECTO.TIEMPOEJECUCION,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, BPNOVEDADPROYECTO.NUMERORADICADO, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.RESPONSABLE, BPNOVEDADPROYECTO.CARGORESPONSABLE, BPNOVEDADPROYECTO.OBSERVACIONES, BPNOVEDADPROYECTO.DEPENDENCIA,(CASE BPNOVEDADPROYECTO.AFECTADO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADO FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON (BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO) AND (BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.ESTADO NOT IN ('A') AND BPNOVEDADPROYECTO.DEPENDENCIA = :DEPENDENCIA AND BPNOVEDADPROYECTO.AFECTADO IN (0) AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.VOBOBP NOT IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VIGENCIA":"$VIGENCIA(type:integer)","ESTADO":"$ESTADO","TIEMPOEJECUCION":"$TIEMPOEJECUCION","FECHA":"$FECHA","NUMERORADICADO":"$NUMERORADICADO","OBJETO":"$OBJETO","RESPONSABLE":"$RESPONSABLE","CARGORESPONSABLE":"$CARGORESPONSABLE","OBSERVACIONES":"$OBSERVACIONES","DEPENDENCIA":"$DEPENDENCIA","AFECTADO":"$AFECTADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/todosporvobo/pag">
