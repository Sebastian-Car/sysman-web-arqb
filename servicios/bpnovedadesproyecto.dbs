	<query id="getBpnovedadesproyectoNumMntrnovedadesfechasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT N.COMPANIA, N.TIPOT, N.CLASET, N.CODIGO,(CASE N.MODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) MODIFICACION, CASE WHEN N.TIPOT IN ('CDP') AND N.MODIFICACION NOT IN(0) THEN TO_CHAR(N.DOCUMENTO_AFECTAR) ELSE '' END NOVEDAD_ORIG, N.DEPENDENCIA, D.ESPECIFICACION,(TO_CHAR(N.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, N.VIGENCIA,(CASE N.VOBOBP WHEN 0 THEN 'false' ELSE 'true' END) VOBOBP,(TO_CHAR(N.FECHA_VOBO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VOBO,(TO_CHAR(N.HORA_VOBO,'DD/MM/YYYY HH24:MI:SS')) HORA_VOBO, N.ESTADO, CASE N.ESTADO WHEN 'V' THEN 'VIGENTE' WHEN 'A' THEN 'ANULADA' WHEN 'N' THEN 'No Aprobado' WHEN 'AP' THEN 'APROBADA' WHEN 'T' THEN 'Todos' END  NOMBREESTADO, P.CODIGOBPIM, P.NOMBREPROYECTO PROYECTO, N.OBJETO, D.VALORSOLICITADO VLR_SOLICITADO, D.VALORAPROBADO VAL_APROBADO, D.VALORDISMINUIDO VLR_DISMINUIDO, D.ACTIVIDAD COD_ACTIVIDAD, A.NOMBRE ACTIVIDAD, D.ID_META_PRODUCTO META_PRODUCTO, D.RUBROPRESUPUESTAL, D.FUENTERECURSOS, DP.NOMBRE NOMDEPENDENCIA, T.NOMBRE RESPONSABLE FROM BPNOVEDADPROYECTO N LEFT JOIN BP_D_NOVEDADPROYECTO D ON N.DEPENDENCIA = D.DEPENDENCIA AND N.CODIGO = D.NOVEDAD AND N.CLASET = D.CLASET AND N.TIPOT = D.TIPOT AND N.COMPANIA = D.COMPANIA LEFT JOIN PROYECTOS P ON D.COMPANIA = P.COMPANIA AND D.PROYECTO = P.CODIGO LEFT JOIN DEPENDENCIA_RESPONSABLE DR ON P.COMPANIA = DR.COMPANIA AND P.DEPENDENCIA = DR.DEPENDENCIA AND P.RESPONSABLE = DR.RESPONSABLE LEFT JOIN DEPENDENCIA DP ON N.COMPANIA = DP.COMPANIA AND N.DEPENDENCIA = DP.CODIGO LEFT JOIN BP_ACTIVIDADES A ON D.COMPANIA = A.COMPANIA AND D.ACTIVIDAD = A.CODIGO LEFT JOIN RESPONSABLE R ON P.RESPONSABLE = R.CEDULA AND P.COMPANIA = R.COMPANIA LEFT JOIN TERCERO T ON R.COMPANIA = T.COMPANIA AND R.CEDULA = T.NIT AND R.SUCURSAL = T.SUCURSAL WHERE N.COMPANIA = :COMPANIA AND TRUNC(N.FECHA) BETWEEN TO_DATE(:FECHAINICIAL, 'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL, 'DD/MM/YYYY') AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROPROYECTO THEN CASE WHEN D.PROYECTO = :FILTROPROYECTO THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todas' &lt;&gt; :FILTRODEPENDENCIA THEN CASE WHEN N.DEPENDENCIA = :FILTRODEPENDENCIA THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'Todos' &lt;&gt; :FILTROTIPOT THEN CASE WHEN N.TIPOT = :FILTROTIPOT THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'T' &lt;&gt; :FILTROESTADO THEN CASE WHEN N.ESTADO = :FILTROESTADO THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'TODOS' &lt;&gt; :DESCRIPCION THEN CASE WHEN D.ID_META_PRODUCTO = :DESCRIPCION THEN -1 ELSE 0 END ELSE -1 END AND -1 = CASE WHEN 'TODOS' &lt;&gt; :COMBO THEN CASE WHEN CASE WHEN N.TIPOT IN ('CDP') AND N.MODIFICACION NOT IN(0) THEN TO_CHAR(N.DOCUMENTO_AFECTAR) ELSE '' END = :COMBO THEN -1 ELSE 0 END ELSE -1 END) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOT), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN MODIFICACION IS NULL THEN ' ' ELSE UPPER(MODIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFICACION), '%')) AND (CASE WHEN NOVEDAD_ORIG IS NULL THEN ' ' ELSE UPPER(NOVEDAD_ORIG) END) LIKE UPPER(CONCAT(:NOVEDAD_ORIG, '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIA), '%')) AND (CASE WHEN VOBOBP IS NULL THEN ' ' ELSE UPPER(VOBOBP) END) LIKE UPPER(CONCAT(CONCAT('%',:VOBOBP), '%')) AND (CASE WHEN FECHA_VOBO IS NULL THEN ' ' ELSE UPPER(FECHA_VOBO) END) LIKE UPPER(CONCAT(:FECHA_VOBO, '%')) AND (CASE WHEN NOMBREESTADO IS NULL THEN ' ' ELSE UPPER(NOMBREESTADO) END) LIKE UPPER(CONCAT(:NOMBREESTADO, '%')) AND (CASE WHEN CODIGOBPIM IS NULL THEN ' ' ELSE UPPER(CODIGOBPIM) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOBPIM), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VLR_SOLICITADO IS NULL THEN ' ' ELSE UPPER(VLR_SOLICITADO) END) LIKE UPPER(CONCAT(CONCAT('%',:VLR_SOLICITADO), '%')) AND (CASE WHEN VAL_APROBADO IS NULL THEN ' ' ELSE UPPER(VAL_APROBADO) END) LIKE UPPER(CONCAT(CONCAT('%',:VAL_APROBADO), '%')) AND (CASE WHEN VLR_DISMINUIDO IS NULL THEN ' ' ELSE UPPER(VLR_DISMINUIDO) END) LIKE UPPER(CONCAT(CONCAT('%',:VLR_DISMINUIDO), '%')) AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:ACTIVIDAD), '%')) AND (CASE WHEN RUBROPRESUPUESTAL IS NULL THEN ' ' ELSE UPPER(RUBROPRESUPUESTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:RUBROPRESUPUESTAL), '%')) AND (CASE WHEN FUENTERECURSOS IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOS) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTERECURSOS), '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FILTROPROYECTO" sqlType="STRING"/>
		<param name="FILTRODEPENDENCIA" sqlType="STRING"/>
		<param name="FILTROTIPOT" sqlType="STRING"/>
		<param name="FILTROESTADO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COMBO" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MODIFICACION" sqlType="STRING"/>
		<param name="NOVEDAD_ORIG" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="VOBOBP" sqlType="STRING"/>
		<param name="FECHA_VOBO" sqlType="STRING"/>
		<param name="NOMBREESTADO" sqlType="STRING"/>
		<param name="CODIGOBPIM" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VLR_SOLICITADO" sqlType="STRING"/>
		<param name="VAL_APROBADO" sqlType="STRING"/>
		<param name="VLR_DISMINUIDO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="RUBROPRESUPUESTAL" sqlType="STRING"/>
		<param name="FUENTERECURSOS" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>

	</query>
