	<query id="getBpnovedadesproyectoNumCargardocumentoconimpresoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE, BPNOVEDADPROYECTO.VIGENCIA, BPNOVEDADPROYECTO.ESTADO, BPNOVEDADPROYECTO.TIEMPOEJECUCION,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, BPNOVEDADPROYECTO.NUMERORADICADO, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.RESPONSABLE, BPNOVEDADPROYECTO.CARGORESPONSABLE, BPNOVEDADPROYECTO.OBSERVACIONES, BPNOVEDADPROYECTO.DEPENDENCIA,(CASE BPNOVEDADPROYECTO.AFECTADO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADO, BPNOVEDADPROYECTO.VALOR_DISMINUIDO, BPNOVEDADPROYECTO.VALORAPROBADO, BPNOVEDADPROYECTO.VALORSOLICITADO, BPNOVEDADPROYECTO.VALORTOTAL  FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON (BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO) AND (BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.ESTADO NOT IN ('A') AND BPNOVEDADPROYECTO.DEPENDENCIA = :DEPENDENCIA AND BPNOVEDADPROYECTO.AFECTADO NOT IN (0) AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.VOBOBP NOT IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%')  AND (CASE WHEN TIEMPOEJECUCION IS NULL THEN ' ' ELSE UPPER(TIEMPOEJECUCION) END)  LIKE UPPER(:TIEMPOEJECUCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN NUMERORADICADO IS NULL THEN ' ' ELSE UPPER(NUMERORADICADO) END)  LIKE UPPER(:NUMERORADICADO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER( '%' || :RESPONSABLE || '%')  AND (CASE WHEN CARGORESPONSABLE IS NULL THEN ' ' ELSE UPPER(CARGORESPONSABLE) END)  LIKE UPPER( '%' || :CARGORESPONSABLE || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN AFECTADO IS NULL THEN ' ' ELSE UPPER(AFECTADO) END)  LIKE UPPER( '%' || :AFECTADO || '%')  AND (CASE WHEN VALOR_DISMINUIDO IS NULL THEN ' ' ELSE UPPER(VALOR_DISMINUIDO) END)  LIKE UPPER(:VALOR_DISMINUIDO || '%')  AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END)  LIKE UPPER(:VALORAPROBADO || '%')  AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END)  LIKE UPPER(:VALORSOLICITADO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
