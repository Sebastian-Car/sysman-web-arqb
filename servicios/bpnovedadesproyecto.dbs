	<query id="getBpnovedadesproyectoNumGrillaporusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.DEPENDENCIA, BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA, DECODE(ESTADO,'V','Vigente','A','Anulada','N','No Aprobado','AP','Aprobada') ESTADO  FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.DEPENDENCIA IS NOT NULL AND BPNOVEDADPROYECTO.VIGENCIA = :VIGENCIASOLICITUD AND BPNOVEDADPROYECTO.CREATED_BY = :USUARIO ORDER BY BPNOVEDADPROYECTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBREDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBREDEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
