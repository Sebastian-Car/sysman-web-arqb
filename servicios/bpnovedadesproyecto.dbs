	<query id="getBpnovedadesproyectoNumTodosPorVoboQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BPNOVEDADPROYECTO.CODIGO, DEPENDENCIA.NOMBRE, BPNOVEDADPROYECTO.VIGENCIA, BPNOVEDADPROYECTO.ESTADO, BPNOVEDADPROYECTO.TIEMPOEJECUCION,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, BPNOVEDADPROYECTO.NUMERORADICADO, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.RESPONSABLE, BPNOVEDADPROYECTO.CARGORESPONSABLE, BPNOVEDADPROYECTO.OBSERVACIONES, BPNOVEDADPROYECTO.DEPENDENCIA,(CASE BPNOVEDADPROYECTO.AFECTADO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADO FROM BPNOVEDADPROYECTO LEFT JOIN DEPENDENCIA ON (BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO) AND (BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.ESTADO NOT IN ('A') AND BPNOVEDADPROYECTO.DEPENDENCIA = :DEPENDENCIA AND BPNOVEDADPROYECTO.AFECTADO IN (0) AND BPNOVEDADPROYECTO.TIPOT = :TIPOT AND BPNOVEDADPROYECTO.CLASET = :CLASET AND BPNOVEDADPROYECTO.VOBOBP NOT IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
