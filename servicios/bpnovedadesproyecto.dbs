	<query id="updateBpnovedadesproyectoIndicadorafectado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPNOVEDADPROYECTO SET AFECTADO=:AFECTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BPNOVEDADPROYECTO.COMPANIA= :KEY_COMPANIA AND BPNOVEDADPROYECTO.TIPOT= :KEY_TIPOT AND BPNOVEDADPROYECTO.CLASET= :KEY_CLASET AND BPNOVEDADPROYECTO.CODIGO= :KEY_CODIGO AND BPNOVEDADPROYECTO.DEPENDENCIA= :KEY_DEPENDENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="AFECTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
