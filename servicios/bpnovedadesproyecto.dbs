	<query id="getBpnovedadesproyectoPagTodosPorTipotClaseTQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO CODIGONOV, DEPENDENCIA DEPNOV, TIPOT  FROM BPNOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND TIPOT = :TIPOT AND CLASET = :CLASET AND ESTADO NOT IN ('A') ORDER BY CODIGONOV, DEPNOV) WHERE (CASE WHEN CODIGONOV IS NULL THEN ' ' ELSE UPPER(CODIGONOV) END)  LIKE UPPER(:CODIGONOV || '%')  AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGONOV":"$CODIGONOV","DEPNOV":"$DEPNOV","TIPOT":"$TIPOT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="CODIGONOV" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
