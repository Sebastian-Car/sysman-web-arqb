	<query id="getBpnovedadesproyectoPagSeleccionmodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.TIPOT, BPTIPONOVEDAD.NOMBRE, BPNOVEDADPROYECTO.CLASET  FROM BPNOVEDADPROYECTO LEFT JOIN BPTIPONOVEDAD ON (BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA) AND (BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT) AND (BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT IN ('SCD') AND TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY') &lt;= TO_DATE(:FECHA,'DD/MM/YYYY')) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END)  LIKE UPPER(:CLASET || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOT":"$TIPOT","NOMBRE":"$NOMBRE","CLASET":"$CLASET"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
