	<query id="getBpnovedadesproyectoConsultarvalordisminuidoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CAST( SUM(BP_D_NOVEDADPROYECTO.VALORDISMINUIDO) as NUMBER) VALOR_DISMINUIDO FROM BPNOVEDADPROYECTO INNER JOIN BP_D_NOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.CLASET = :CLASE AND BPNOVEDADPROYECTO.TIPOT = :TIPO AND BPNOVEDADPROYECTO.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR_DISMINUIDO":"$VALOR_DISMINUIDO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/consultarvalordisminuido">
		<call-query href="getBpnovedadesproyectoConsultarvalordisminuidoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="updateBpnovedadesproyectoUpdatevalordisminuido" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPNOVEDADPROYECTO SET VALOR_DISMINUIDO = :VALOR_DISMINUIDO,   VALORTOTAL     = :VALORTOTAL,   MODIFIED_BY   =:MODIFIED_BY,   DATE_MODIFIED =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPANIA  = :COMPANIA AND TIPOT       = :TIPOT AND CLASET      = :CLASET AND CODIGO      = :CODIGO AND DEPENDENCIA = :DEPENDENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR_DISMINUIDO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpnovedadesproyecto/updatevalordisminuido">
		<call-query href="updateBpnovedadesproyectoUpdatevalordisminuido">
			<with-param name="VALOR_DISMINUIDO" query-param="VALOR_DISMINUIDO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPagListadoporcodigoobjetoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BPNP.CODIGO, BPNP.OBJETO FROM BPNOVEDADPROYECTO BPNP WHERE BPNP.COMPANIA = :COMPANIA AND BPNP.VIGENCIA = :VIGENCIA AND BPNP.TIPOT = :TIPOT ORDER BY BPNP.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","OBJETO":"$OBJETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/listadoporcodigoobjeto/pag">
		<call-query href="getBpnovedadesproyectoPagListadoporcodigoobjetoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumListadoporcodigoobjetoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BPNP.CODIGO, BPNP.OBJETO FROM BPNOVEDADPROYECTO BPNP WHERE BPNP.COMPANIA = :COMPANIA AND BPNP.VIGENCIA = :VIGENCIA AND BPNP.TIPOT = :TIPOT ORDER BY BPNP.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/listadoporcodigoobjeto/num">
		<call-query href="getBpnovedadesproyectoNumListadoporcodigoobjetoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoConsultarvalorfinancieraQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VALORTOTAL  FROM BPNOVEDADPROYECTO WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND TIPOT = :TIPO AND CLASET = :CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORTOTAL":"$VALORTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/consultarvalorfinanciera">
		<call-query href="getBpnovedadesproyectoConsultarvalorfinancieraQuery">
