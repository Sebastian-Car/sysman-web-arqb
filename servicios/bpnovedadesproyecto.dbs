<data name="bpnovedadesproyecto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpnovedadesproyectoPagSinordendecompraauxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.DEPENDENCIA, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.VALORAPROBADO  FROM BPNOVEDADPROYECTO INNER JOIN BP_D_NOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = 'SCD' AND BPNOVEDADPROYECTO.VOBOBP NOT IN (0) AND TO_CHAR(BPNOVEDADPROYECTO.FECHA,'YYYY')= :ANO AND BPNOVEDADPROYECTO.CODIGO NOT IN (SELECT SOLICITUD_SCD_BP FROM ORDENDECOMPRA_AUXILIAR WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA = :NUMERO_ORDEN)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END)  LIKE UPPER(:VALORAPROBADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","OBJETO":"$OBJETO","VALORAPROBADO":"$VALORAPROBADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/sinordendecompraauxiliar/pag">
		<call-query href="getBpnovedadesproyectoPagSinordendecompraauxiliarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VALORAPROBADO" query-param="VALORAPROBADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumSinordendecompraauxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.COMPANIA, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.DEPENDENCIA, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.VALORAPROBADO  FROM BPNOVEDADPROYECTO INNER JOIN BP_D_NOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = 'SCD' AND BPNOVEDADPROYECTO.VOBOBP NOT IN (0) AND TO_CHAR(BPNOVEDADPROYECTO.FECHA,'YYYY')= :ANO AND BPNOVEDADPROYECTO.CODIGO NOT IN (SELECT SOLICITUD_SCD_BP FROM ORDENDECOMPRA_AUXILIAR WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA = :NUMERO_ORDEN)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END)  LIKE UPPER( '%' || :VALORAPROBADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/sinordendecompraauxiliar/num">
		<call-query href="getBpnovedadesproyectoNumSinordendecompraauxiliarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VALORAPROBADO" query-param="VALORAPROBADO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPagConordendecompraauxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT ORDENDECOMPRA_AUXILIAR.COMPANIA, ORDENDECOMPRA_AUXILIAR.TIPOT, ORDENDECOMPRA_AUXILIAR.CLASET, ORDENDECOMPRA_AUXILIAR.SOLICITUD_SCD_BP CODIGO, ORDENDECOMPRA_AUXILIAR.DEPENDENCIA, BPNOVEDADPROYECTO.OBJETO, ORDENDECOMPRA_AUXILIAR.VALOR VALORAPROBADO FROM ORDENDECOMPRA_AUXILIAR INNER JOIN BP_D_NOVEDADPROYECTO ON ORDENDECOMPRA_AUXILIAR.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND ORDENDECOMPRA_AUXILIAR.AUXILIAR = BP_D_NOVEDADPROYECTO.PROYECTO AND ORDENDECOMPRA_AUXILIAR.ACTIVIDAD = BP_D_NOVEDADPROYECTO.ACTIVIDAD AND ORDENDECOMPRA_AUXILIAR.DESTINORECURSOS = BP_D_NOVEDADPROYECTO.SECTOR AND ORDENDECOMPRA_AUXILIAR.FUENTE_RECURSOS = BP_D_NOVEDADPROYECTO.FUENTERECURSOS AND ORDENDECOMPRA_AUXILIAR.COMPONENTES = BP_D_NOVEDADPROYECTO.COMPONENTE AND ORDENDECOMPRA_AUXILIAR.CONSECUTIVO = BP_D_NOVEDADPROYECTO.CODIGO AND ORDENDECOMPRA_AUXILIAR.SOLICITUD_SCD_BP = BP_D_NOVEDADPROYECTO.NOVEDAD INNER JOIN BPNOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA WHERE ORDENDECOMPRA_AUXILIAR.COMPANIA = :COMPANIA AND ORDENDECOMPRA_AUXILIAR.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA_AUXILIAR.ORDENDECOMPRA = :NUMERO_ORDEN) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END) LIKE UPPER(CONCAT(:VALORAPROBADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","OBJETO":"$OBJETO","VALORAPROBADO":"$VALORAPROBADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/conordendecompraauxiliar/pag">
		<call-query href="getBpnovedadesproyectoPagConordendecompraauxiliarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VALORAPROBADO" query-param="VALORAPROBADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumConordendecompraauxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT ORDENDECOMPRA_AUXILIAR.COMPANIA, ORDENDECOMPRA_AUXILIAR.TIPOT, ORDENDECOMPRA_AUXILIAR.CLASET, ORDENDECOMPRA_AUXILIAR.SOLICITUD_SCD_BP CODIGO, ORDENDECOMPRA_AUXILIAR.DEPENDENCIA, BPNOVEDADPROYECTO.OBJETO, ORDENDECOMPRA_AUXILIAR.VALOR VALORAPROBADO FROM ORDENDECOMPRA_AUXILIAR INNER JOIN BP_D_NOVEDADPROYECTO ON ORDENDECOMPRA_AUXILIAR.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND ORDENDECOMPRA_AUXILIAR.AUXILIAR = BP_D_NOVEDADPROYECTO.PROYECTO AND ORDENDECOMPRA_AUXILIAR.ACTIVIDAD = BP_D_NOVEDADPROYECTO.ACTIVIDAD AND ORDENDECOMPRA_AUXILIAR.DESTINORECURSOS = BP_D_NOVEDADPROYECTO.SECTOR AND ORDENDECOMPRA_AUXILIAR.FUENTE_RECURSOS = BP_D_NOVEDADPROYECTO.FUENTERECURSOS AND ORDENDECOMPRA_AUXILIAR.COMPONENTES = BP_D_NOVEDADPROYECTO.COMPONENTE AND ORDENDECOMPRA_AUXILIAR.CONSECUTIVO = BP_D_NOVEDADPROYECTO.CODIGO AND ORDENDECOMPRA_AUXILIAR.SOLICITUD_SCD_BP = BP_D_NOVEDADPROYECTO.NOVEDAD INNER JOIN BPNOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA WHERE ORDENDECOMPRA_AUXILIAR.COMPANIA = :COMPANIA AND ORDENDECOMPRA_AUXILIAR.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA_AUXILIAR.ORDENDECOMPRA = :NUMERO_ORDEN) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN VALORAPROBADO IS NULL THEN ' ' ELSE UPPER(VALORAPROBADO) END) LIKE UPPER(CONCAT(:VALORAPROBADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="VALORAPROBADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/conordendecompraauxiliar/num">
		<call-query href="getBpnovedadesproyectoNumConordendecompraauxiliarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="VALORAPROBADO" query-param="VALORAPROBADO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoPagTodosCmpteAfectadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT BPNOVEDADPROYECTO.CODIGO NUMERO_SOLICITUD, BPNOVEDADPROYECTO.OBJETO,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, BPNOVEDADPROYECTO.VALORSOLICITADO, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.DEPENDENCIA, DEPENDENCIA.NOMBRE, RESPONSABLE.CARGO, BPNOVEDADPROYECTO.CONCOMPROBANTEPPTAL, MIN(BP_D_NOVEDADPROYECTO.PROYECTO) PROYECTO FROM BPNOVEDADPROYECTO INNER JOIN DEPENDENCIA ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN RESPONSABLE ON BPNOVEDADPROYECTO.COMPANIA = RESPONSABLE.COMPANIA AND BPNOVEDADPROYECTO.RESPONSABLE = RESPONSABLE.CEDULA INNER JOIN BP_D_NOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD INNER JOIN PROYECTOS ON BP_D_NOVEDADPROYECTO.COMPANIA = PROYECTOS.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = PROYECTOS.CODIGO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPO AND BPNOVEDADPROYECTO.VIGENCIA = :ANO AND TRUNC(TO_DATE(TO_CHAR(BPNOVEDADPROYECTO.FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')) &lt;= TO_DATE(:FECHAACTUAL, 'DD/MM/YYYY') AND BPNOVEDADPROYECTO.CONCOMPROBANTEPPTAL = 0 AND BPNOVEDADPROYECTO.ESTADO NOT IN ( 'A' ) AND BPNOVEDADPROYECTO.VOBOBP NOT IN ( 0 ) AND BPNOVEDADPROYECTO.IMPRESO NOT IN ( 0) AND ( NVL(BP_D_NOVEDADPROYECTO.VALORSOLICITADO, 0) - NVL(VALORAFECTADO, 0) ) &gt; 0 GROUP BY BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.FECHA, BPNOVEDADPROYECTO.VALORSOLICITADO, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.DEPENDENCIA, DEPENDENCIA.NOMBRE, RESPONSABLE.CARGO, BPNOVEDADPROYECTO.CONCOMPROBANTEPPTAL ORDER BY BPNOVEDADPROYECTO.CODIGO) INI WHERE (CASE WHEN NUMERO_SOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMERO_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_SOLICITUD), '%')) AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORSOLICITADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_SOLICITUD":"$NUMERO_SOLICITUD","OBJETO":"$OBJETO","FECHA":"$FECHA","VALORSOLICITADO":"$VALORSOLICITADO","TIPOT":"$TIPOT","CLASET":"$CLASET","CODIGO":"$CODIGO","DEPENDENCIA":"$DEPENDENCIA","NOMBRE":"$NOMBRE","CARGO":"$CARGO","CONCOMPROBANTEPPTAL":"$CONCOMPROBANTEPPTAL(type:double)","PROYECTO":"$PROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHAACTUAL" sqlType="STRING"/>
		<param name="NUMERO_SOLICITUD" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALORSOLICITADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpnovedadesproyecto/todoscmpteafectado/pag">
		<call-query href="getBpnovedadesproyectoPagTodosCmpteAfectadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHAACTUAL" query-param="FECHAACTUAL"/>
			<with-param name="NUMERO_SOLICITUD" query-param="NUMERO_SOLICITUD"/>
			<with-param name="OBJETO" query-param="OBJETO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALORSOLICITADO" query-param="VALORSOLICITADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpnovedadesproyectoNumTodosCmpteAfectadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BPNOVEDADPROYECTO.CODIGO NUMERO_SOLICITUD, BPNOVEDADPROYECTO.OBJETO,(TO_CHAR(BPNOVEDADPROYECTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, BPNOVEDADPROYECTO.VALORSOLICITADO, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.DEPENDENCIA, DEPENDENCIA.NOMBRE, RESPONSABLE.CARGO, BPNOVEDADPROYECTO.CONCOMPROBANTEPPTAL, MIN(BP_D_NOVEDADPROYECTO.PROYECTO) PROYECTO  FROM BPNOVEDADPROYECTO INNER JOIN DEPENDENCIA ON BPNOVEDADPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPNOVEDADPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN RESPONSABLE ON BPNOVEDADPROYECTO.COMPANIA = RESPONSABLE.COMPANIA AND BPNOVEDADPROYECTO.RESPONSABLE = RESPONSABLE.CEDULA INNER JOIN BP_D_NOVEDADPROYECTO ON BPNOVEDADPROYECTO.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND BPNOVEDADPROYECTO.TIPOT = BP_D_NOVEDADPROYECTO.TIPOT AND BPNOVEDADPROYECTO.CLASET = BP_D_NOVEDADPROYECTO.CLASET AND BPNOVEDADPROYECTO.DEPENDENCIA = BP_D_NOVEDADPROYECTO.DEPENDENCIA AND BPNOVEDADPROYECTO.CODIGO = BP_D_NOVEDADPROYECTO.NOVEDAD INNER JOIN PROYECTOS ON BP_D_NOVEDADPROYECTO.COMPANIA = PROYECTOS.COMPANIA AND BP_D_NOVEDADPROYECTO.PROYECTO = PROYECTOS.CODIGO WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPO AND BPNOVEDADPROYECTO.VIGENCIA = :ANO AND TRUNC(TO_DATE(TO_CHAR(BPNOVEDADPROYECTO.FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')) &lt;= TO_DATE(:FECHAACTUAL, 'DD/MM/YYYY') AND BPNOVEDADPROYECTO.CONCOMPROBANTEPPTAL = 0 AND BPNOVEDADPROYECTO.ESTADO NOT IN ( 'A' ) AND BPNOVEDADPROYECTO.VOBOBP NOT IN ( 0 ) AND BPNOVEDADPROYECTO.IMPRESO NOT IN ( 0) AND ( NVL(BP_D_NOVEDADPROYECTO.VALORSOLICITADO, 0) - NVL(VALORAFECTADO, 0) ) &gt; 0 GROUP BY BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.OBJETO, BPNOVEDADPROYECTO.FECHA, BPNOVEDADPROYECTO.VALORSOLICITADO, BPNOVEDADPROYECTO.TIPOT, BPNOVEDADPROYECTO.CLASET, BPNOVEDADPROYECTO.CODIGO, BPNOVEDADPROYECTO.DEPENDENCIA, DEPENDENCIA.NOMBRE, RESPONSABLE.CARGO, BPNOVEDADPROYECTO.CONCOMPROBANTEPPTAL) WHERE (CASE WHEN NUMERO_SOLICITUD IS NULL THEN ' ' ELSE UPPER(NUMERO_SOLICITUD) END)  LIKE UPPER( '%' || :NUMERO_SOLICITUD || '%')  AND (CASE WHEN OBJETO IS NULL THEN ' ' ELSE UPPER(OBJETO) END)  LIKE UPPER( '%' || :OBJETO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN VALORSOLICITADO IS NULL THEN ' ' ELSE UPPER(VALORSOLICITADO) END)  LIKE UPPER( '%' || :VALORSOLICITADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHAACTUAL" sqlType="STRING"/>
		<param name="NUMERO_SOLICITUD" sqlType="STRING"/>
		<param name="OBJETO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALORSOLICITADO" sqlType="STRING"/>

	</query>
