	<query id="getBpnovedadesproyectoTodasLasClasesAfectartQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT BPNOVEDADPROYECTO.CLASET, BPTIPONOVEDAD.NOMBRE  FROM BPNOVEDADPROYECTO LEFT JOIN BPTIPONOVEDAD ON (BPNOVEDADPROYECTO.COMPANIA = BPTIPONOVEDAD.COMPANIA) AND (BPNOVEDADPROYECTO.TIPOT = BPTIPONOVEDAD.TIPOT) AND (BPNOVEDADPROYECTO.CLASET = BPTIPONOVEDAD.CLASET) WHERE BPNOVEDADPROYECTO.COMPANIA = :COMPANIA AND BPNOVEDADPROYECTO.TIPOT = :TIPOT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASET":"$CLASET","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>

	</query>
