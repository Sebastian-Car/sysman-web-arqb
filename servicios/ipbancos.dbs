<data name="ipbancos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpbancosCodigoYNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGOBANCO, NOMBREBANCO  FROM IP_BANCOS WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBANCO":"$CODIGOBANCO","NOMBREBANCO":"$NOMBREBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/codigoynombreporcompania">
		<call-query href="getIpbancosCodigoYNombrePorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getIpbancosPagCodigoNombreCodcontableYCodasbcPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGOBANCO, NOMBREBANCO, CODIGOCONTABLE, COD_ASBC  FROM IP_BANCOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN CODIGOCONTABLE IS NULL THEN ' ' ELSE UPPER(CODIGOCONTABLE) END)  LIKE UPPER(:CODIGOCONTABLE || '%')  AND (CASE WHEN COD_ASBC IS NULL THEN ' ' ELSE UPPER(COD_ASBC) END)  LIKE UPPER(:COD_ASBC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBANCO":"$CODIGOBANCO","NOMBREBANCO":"$NOMBREBANCO","CODIGOCONTABLE":"$CODIGOCONTABLE","COD_ASBC":"$COD_ASBC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="CODIGOCONTABLE" sqlType="STRING"/>
		<param name="COD_ASBC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipbancos/codigonombrecodcontableycodasbcporcompania/pag">
		<call-query href="getIpbancosPagCodigoNombreCodcontableYCodasbcPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CODIGOCONTABLE" query-param="CODIGOCONTABLE"/>
			<with-param name="COD_ASBC" query-param="COD_ASBC"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpbancosNumCodigoNombreCodcontableYCodasbcPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGOBANCO, NOMBREBANCO, CODIGOCONTABLE, COD_ASBC  FROM IP_BANCOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN CODIGOCONTABLE IS NULL THEN ' ' ELSE UPPER(CODIGOCONTABLE) END)  LIKE UPPER( '%' || :CODIGOCONTABLE || '%')  AND (CASE WHEN COD_ASBC IS NULL THEN ' ' ELSE UPPER(COD_ASBC) END)  LIKE UPPER( '%' || :COD_ASBC || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="CODIGOCONTABLE" sqlType="STRING"/>
		<param name="COD_ASBC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/codigonombrecodcontableycodasbcporcompania/num">
		<call-query href="getIpbancosNumCodigoNombreCodcontableYCodasbcPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CODIGOCONTABLE" query-param="CODIGOCONTABLE"/>
			<with-param name="COD_ASBC" query-param="COD_ASBC"/>

		</call-query>
	</resource>
	<query id="getIpbancosPagTodosPorCodigoBancoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_BANCOS.CODIGOBANCO, IP_BANCOS.NOMBREBANCO  FROM IP_BANCOS WHERE IP_BANCOS.COMPANIA = :COMPANIA ORDER BY CODIGOBANCO) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER(:CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBANCO":"$CODIGOBANCO","NOMBREBANCO":"$NOMBREBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipbancos/todosporcodigobancoinicial/pag">
		<call-query href="getIpbancosPagTodosPorCodigoBancoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpbancosNumTodosPorCodigoBancoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_BANCOS.CODIGOBANCO, IP_BANCOS.NOMBREBANCO  FROM IP_BANCOS WHERE IP_BANCOS.COMPANIA = :COMPANIA ORDER BY CODIGOBANCO) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER(:CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/todosporcodigobancoinicial/num">
		<call-query href="getIpbancosNumTodosPorCodigoBancoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>

		</call-query>
	</resource>
	<query id="getIpbancosPagTodosPorCodigoBancoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_BANCOS.CODIGOBANCO, IP_BANCOS.NOMBREBANCO  FROM IP_BANCOS WHERE IP_BANCOS.COMPANIA = :COMPANIA AND IP_BANCOS.CODIGOBANCO &gt;= :BANCOINICIAL ORDER BY CODIGOBANCO) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER(:CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBANCO":"$CODIGOBANCO","NOMBREBANCO":"$NOMBREBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCOINICIAL" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipbancos/todosporcodigobancofinal/pag">
		<call-query href="getIpbancosPagTodosPorCodigoBancoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="BANCOINICIAL" query-param="BANCOINICIAL"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpbancosNumTodosPorCodigoBancoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_BANCOS.CODIGOBANCO, IP_BANCOS.NOMBREBANCO  FROM IP_BANCOS WHERE IP_BANCOS.COMPANIA = :COMPANIA AND IP_BANCOS.CODIGOBANCO &gt;= :BANCOINICIAL ORDER BY CODIGOBANCO) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER(:CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCOINICIAL" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/todosporcodigobancofinal/num">
		<call-query href="getIpbancosNumTodosPorCodigoBancoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="BANCOINICIAL" query-param="BANCOINICIAL"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>

		</call-query>
	</resource>
	<query id="getIpbancosTodosPorCompaniaEscajaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_BANCOS.CODIGOBANCO, IP_BANCOS.NOMBREBANCO  FROM IP_BANCOS WHERE IP_BANCOS.COMPANIA = :COMPANIA AND IP_BANCOS.ESCAJA NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBANCO":"$CODIGOBANCO","NOMBREBANCO":"$NOMBREBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/todosporcompaniaescaja">
		<call-query href="getIpbancosTodosPorCompaniaEscajaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getIpbancosNombrebancoporcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_BANCOS.NOMBREBANCO  FROM IP_BANCOS WHERE IP_BANCOS.COMPANIA = :COMPANIA AND CODIGOBANCO = :PAGBAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBREBANCO":"$NOMBREBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAGBAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/nombrebancoporcodigo">
		<call-query href="getIpbancosNombrebancoporcodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PAGBAN" query-param="PAGBAN"/>

		</call-query>
	</resource>
	<query id="insertIpbancos" keyColumns="COMPANIA,CODIGOBANCO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_BANCOS (COMPANIA, CODIGOBANCO, NOMBREBANCO, CODIGOCONTABLE, ESCAJA, COD_ASBC, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGOBANCO, :NOMBREBANCO, :CODIGOCONTABLE, :ESCAJA, :COD_ASBC, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOBANCO":"$CODIGOBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCONTABLE" sqlType="STRING"/>
		<param defaultValue="0" name="ESCAJA" sqlType="STRING"/>
		<param defaultValue="0" name="COD_ASBC" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ipbancos">
		<call-query href="insertIpbancos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CODIGOCONTABLE" query-param="CODIGOCONTABLE"/>
			<with-param name="ESCAJA" query-param="ESCAJA"/>
			<with-param name="COD_ASBC" query-param="COD_ASBC"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteIpbancos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_BANCOS WHERE IP_BANCOS.COMPANIA= :KEY_COMPANIA AND IP_BANCOS.CODIGOBANCO= :KEY_CODIGOBANCO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOBANCO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ipbancos">
		<call-query href="deleteIpbancos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOBANCO" query-param="KEY_CODIGOBANCO"/>

		</call-query>
	</resource>
	<query id="getIpbancosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGOBANCO, NOMBREBANCO, CODIGOCONTABLE,(CASE ESCAJA WHEN 0 THEN 'false' ELSE 'true' END) ESCAJA, COD_ASBC  FROM IP_BANCOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER( '%' || :CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN CODIGOCONTABLE IS NULL THEN ' ' ELSE UPPER(CODIGOCONTABLE) END)  LIKE UPPER( '%' || :CODIGOCONTABLE || '%')  AND (CASE WHEN ESCAJA IS NULL THEN ' ' ELSE UPPER(ESCAJA) END)  LIKE UPPER(:ESCAJA || '%')  AND (CASE WHEN COD_ASBC IS NULL THEN ' ' ELSE UPPER(COD_ASBC) END)  LIKE UPPER( '%' || :COD_ASBC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOBANCO":"$CODIGOBANCO","NOMBREBANCO":"$NOMBREBANCO","CODIGOCONTABLE":"$CODIGOCONTABLE","ESCAJA":"$ESCAJA(type:boolean)","COD_ASBC":"$COD_ASBC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="CODIGOCONTABLE" sqlType="STRING"/>
		<param name="ESCAJA" sqlType="STRING"/>
		<param name="COD_ASBC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipbancos">
		<call-query href="getIpbancosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CODIGOCONTABLE" query-param="CODIGOCONTABLE"/>
			<with-param name="ESCAJA" query-param="ESCAJA"/>
			<with-param name="COD_ASBC" query-param="COD_ASBC"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpbancosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGOBANCO, NOMBREBANCO, CODIGOCONTABLE,(CASE ESCAJA WHEN 0 THEN 'false' ELSE 'true' END) ESCAJA, COD_ASBC  FROM IP_BANCOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER( '%' || :CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN CODIGOCONTABLE IS NULL THEN ' ' ELSE UPPER(CODIGOCONTABLE) END)  LIKE UPPER( '%' || :CODIGOCONTABLE || '%')  AND (CASE WHEN ESCAJA IS NULL THEN ' ' ELSE UPPER(ESCAJA) END)  LIKE UPPER( '%' || :ESCAJA || '%')  AND (CASE WHEN COD_ASBC IS NULL THEN ' ' ELSE UPPER(COD_ASBC) END)  LIKE UPPER( '%' || :COD_ASBC || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="CODIGOCONTABLE" sqlType="STRING"/>
		<param name="ESCAJA" sqlType="STRING"/>
		<param name="COD_ASBC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/numero">
		<call-query href="getIpbancosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CODIGOCONTABLE" query-param="CODIGOCONTABLE"/>
			<with-param name="ESCAJA" query-param="ESCAJA"/>
			<with-param name="COD_ASBC" query-param="COD_ASBC"/>

		</call-query>
	</resource>
	<query id="updateIpbancos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_BANCOS SET CODIGOBANCO=:CODIGOBANCO, NOMBREBANCO=:NOMBREBANCO, CODIGOCONTABLE=:CODIGOCONTABLE, ESCAJA=:ESCAJA, COD_ASBC=:COD_ASBC, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE IP_BANCOS.COMPANIA= :KEY_COMPANIA AND IP_BANCOS.CODIGOBANCO= :KEY_CODIGOBANCO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="CODIGOCONTABLE" sqlType="STRING"/>
		<param name="ESCAJA" sqlType="STRING"/>
		<param name="COD_ASBC" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOBANCO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipbancos">
		<call-query href="updateIpbancos">
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="CODIGOCONTABLE" query-param="CODIGOCONTABLE"/>
			<with-param name="ESCAJA" query-param="ESCAJA"/>
			<with-param name="COD_ASBC" query-param="COD_ASBC"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOBANCO" query-param="KEY_CODIGOBANCO"/>

		</call-query>
	</resource>
	<query id="getIpbancosPagToddosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGOBANCO, NOMBREBANCO  FROM IP_BANCOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER(:CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOBANCO":"$CODIGOBANCO","NOMBREBANCO":"$NOMBREBANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipbancos/toddosporcompania/pag">
		<call-query href="getIpbancosPagToddosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpbancosNumToddosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGOBANCO, NOMBREBANCO  FROM IP_BANCOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOBANCO IS NULL THEN ' ' ELSE UPPER(CODIGOBANCO) END)  LIKE UPPER(:CODIGOBANCO || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOBANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipbancos/toddosporcompania/num">
		<call-query href="getIpbancosNumToddosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOBANCO" query-param="CODIGOBANCO"/>
			<with-param name="NOMBREBANCO" query-param="NOMBREBANCO"/>

		</call-query>
	</resource>

</data>