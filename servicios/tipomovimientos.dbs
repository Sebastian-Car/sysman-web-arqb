		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, TIPOMOVIMIENTO.CLASE  FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.TIPOELEMENTO = :TIPO ORDER BY TIPOMOVIMIENTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
