	<query id="getTipomovimientosPagGettipomovimentomovimentosaccesosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, CASE WHEN (NVL(MOVIMIENTOS_ACCESOS.VER, -1) = -1) THEN 'true' ELSE 'false' END VER FROM TIPOMOVIMIENTO LEFT JOIN MOVIMIENTOS_ACCESOS ON (TIPOMOVIMIENTO.COMPANIA = MOVIMIENTOS_ACCESOS.COMPANIA AND TIPOMOVIMIENTO.CODIGO = MOVIMIENTOS_ACCESOS.TIPO AND MOVIMIENTOS_ACCESOS.USUARIO = :USUARIO) WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND MOVIMIENTOS_ACCESOS.APLICACION = :MODULO ORDER BY TIPOMOVIMIENTO.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VER IS NULL THEN ' ' ELSE UPPER(VER) END) LIKE UPPER(CONCAT(CONCAT('%',:VER), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","VER":"$VER"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VER" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipomovimientos/gettipomovimentomovimentosaccesos/pag">
		<call-query href="getTipomovimientosPagGettipomovimentomovimentosaccesosQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VER" query-param="VER"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosNumGettipomovimentomovimentosaccesosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, CASE WHEN (NVL(MOVIMIENTOS_ACCESOS.VER, -1) = -1) THEN 'true' ELSE 'false' END VER FROM TIPOMOVIMIENTO LEFT JOIN MOVIMIENTOS_ACCESOS ON (TIPOMOVIMIENTO.COMPANIA = MOVIMIENTOS_ACCESOS.COMPANIA AND TIPOMOVIMIENTO.CODIGO = MOVIMIENTOS_ACCESOS.TIPO AND MOVIMIENTOS_ACCESOS.USUARIO = :USUARIO) WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND MOVIMIENTOS_ACCESOS.APLICACION = :MODULO ORDER BY TIPOMOVIMIENTO.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VER IS NULL THEN ' ' ELSE UPPER(VER) END) LIKE UPPER(CONCAT(CONCAT('%',:VER), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VER" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/gettipomovimentomovimentosaccesos/num">
		<call-query href="getTipomovimientosNumGettipomovimentomovimentosaccesosQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VER" query-param="VER"/>

