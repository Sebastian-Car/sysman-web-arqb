	<query id="getTipomovimientosPagLotenuminiQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MOVIMIENTO.NUMERO, MOVIMIENTO.DESCRIPCION,(TO_CHAR(MOVIMIENTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM MOVIMIENTO WHERE MOVIMIENTO.COMPANIA =:COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO = :TIPOMOVIMIENTO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA"}]}}		</result>
