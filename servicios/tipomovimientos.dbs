	<query id="updateTipomovimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPOMOVIMIENTO SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, NOMBRECORTO=:NOMBRECORTO, CLASE=:CLASE, COSTEA=:COSTEA, ACTUALIZAMIN=:ACTUALIZAMIN, PIDECENTROCOSTO=:PIDECENTROCOSTO, PIDEORDENCOMPRA=:PIDEORDENCOMPRA, COSTOVENTACONS=:COSTOVENTACONS, NUMEROINICIAL=:NUMEROINICIAL, TIPOELEMENTO=:TIPOELEMENTO, INVENTARIOINICIAL=:INVENTARIOINICIAL, CONCEPTO=:CONCEPTO, TIPOPESONA=:TIPOPESONA, CLASEMOVIMIENTO=:CLASEMOVIMIENTO, TIPOFORMATO=:TIPOFORMATO, GENERAPLACA=:GENERAPLACA, RESPONSABLEALMACEN=:RESPONSABLEALMACEN, CLASEDOCASOCIADO=:CLASEDOCASOCIADO, AFECTAPEDIDO=:AFECTAPEDIDO, DEPANT=:DEPANT, DEPNUE=:DEPNUE, MANEJA_VENTAS=:MANEJA_VENTAS, ACTIVO=:ACTIVO, APLICA_NIIF=:APLICA_NIIF, CLASE_BODEGA_ORIGEN=:CLASE_BODEGA_ORIGEN, CLASE_BODEGA_DESTINO=:CLASE_BODEGA_DESTINO, APLICADETERIORO=:APLICADETERIORO, REVERSADETERIORO=:REVERSADETERIORO, OBLIGA_CAMPOS=:OBLIGA_CAMPOS, CAMBIA_AUX=:CAMBIA_AUX, MAN_CAUSACION=:MAN_CAUSACION, COM_RELACIONADO=:COM_RELACIONADO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CONTRATO_MANUAL=:CONTRATO_MANUAL WHERE TIPOMOVIMIENTO.COMPANIA= :KEY_COMPANIA AND TIPOMOVIMIENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
