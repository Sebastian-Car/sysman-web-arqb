	<query id="getTipomovimientosPagCodigoYNombrePorClaseConceptoYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CLASE NOT IN(:CLASE) AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CONCEPTO,' ','')),CONCAT('',CONCAT(TIPOMOVIMIENTO.CONCEPTO,'')),1)&gt; 0 OR TIPOMOVIMIENTO.CONCEPTO = 'DT' AND TIPOMOVIMIENTO.TIPOELEMENTO NOT IN(:TIPO) ORDER BY TIPOMOVIMIENTO.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
