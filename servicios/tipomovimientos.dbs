		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, TIPOMOVIMIENTO.TIPOFORMATO  FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA ORDER BY TIPOMOVIMIENTO.COMPANIA, TIPOMOVIMIENTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPOFORMATO IS NULL THEN ' ' ELSE UPPER(TIPOFORMATO) END)  LIKE UPPER( '%' || :TIPOFORMATO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPOFORMATO" sqlType="STRING"/>

	</query>
