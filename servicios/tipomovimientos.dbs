	<query id="getTipomovimientosNumTodosPorComprobanteDeReclasificacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT CODIGO,NOMBRE,TIPOELEMENTO,CONCEPTO,TIPOFORMATO FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA AND CONCEPTO = 'T' AND CLASE = 'T' AND CODIGO = :TIPOMOVIMIENTO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
