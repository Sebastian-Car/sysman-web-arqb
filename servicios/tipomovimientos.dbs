	</resource>
	<query id="getTipomovimientosGetgeneraplacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(0) VALOR FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CODIGO = :CODIGO AND ( TIPOMOVIMIENTO.GENERAPLACA NOT IN(0) OR (TIPOMOVIMIENTO.CONCEPTO IN('CR') AND TIPOMOVIMIENTO.TIPOELEMENTO IN('D','N','C','S','E')) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/getgeneraplaca">
		<call-query href="getTipomovimientosGetgeneraplacaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosNombreportipoconceptoclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT TIPOMOVIMIENTO.CODIGO, ( CONCAT(CONCAT(CONCAT(NOMBRE, '('), CODIGO), ')') ) NOMBREMOV,CLASE_BODEGA_ORIGEN,CLASE_BODEGA_DESTINO FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOELEMENTO = :TIPO AND CONCEPTO = :CONCEPTO AND CLASE = :CLASE AND ACTIVO = -1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREMOV":"$NOMBREMOV","CLASE_BODEGA_ORIGEN":"$CLASE_BODEGA_ORIGEN","CLASE_BODEGA_DESTINO":"$CLASE_BODEGA_DESTINO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/nombreportipoconceptoclase">
		<call-query href="getTipomovimientosNombreportipoconceptoclaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>

