	<query id="deleteTipomovimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA= :KEY_COMPANIA AND TIPOMOVIMIENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tipomovimientos">
		<call-query href="deleteTipomovimientos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOMOVIMIENTO.COMPANIA, TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, TIPOMOVIMIENTO.NUMEROINICIAL, CONCEPTO.NOMBRE CONCEPTO, CASE WHEN CLASE = 'E' THEN 'Entrada' WHEN CLASE = 'S' THEN 'Salida' WHEN CLASE = 'T' THEN 'Traspaso' WHEN CLASE = 'D' THEN 'Descargo' END CLASE, TIPOMOVIMIENTO.TIPOFORMATO  FROM TIPOMOVIMIENTO INNER JOIN CONCEPTO ON TIPOMOVIMIENTO.CONCEPTO =CONCEPTO.CODIGO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CLASEMOVIMIENTO= CASE WHEN :CONDICION IS NULL THEN CLASEMOVIMIENTO ELSE :CONDICION END ORDER BY TIPOMOVIMIENTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NUMEROINICIAL IS NULL THEN ' ' ELSE UPPER(NUMEROINICIAL) END)  LIKE UPPER( '%' || :NUMEROINICIAL || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%')  AND (CASE WHEN TIPOFORMATO IS NULL THEN ' ' ELSE UPPER(TIPOFORMATO) END)  LIKE UPPER( '%' || :TIPOFORMATO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NUMEROINICIAL":"$NUMEROINICIAL(type:long)","CONCEPTO":"$CONCEPTO","CLASE":"$CLASE","TIPOFORMATO":"$TIPOFORMATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONDICION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPOFORMATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipomovimientos">
		<call-query href="getTipomovimientosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONDICION" query-param="CONDICION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPOFORMATO" query-param="TIPOFORMATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOMOVIMIENTO.COMPANIA, TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, TIPOMOVIMIENTO.NUMEROINICIAL, CONCEPTO.NOMBRE CONCEPTO, CASE WHEN CLASE = 'E' THEN 'Entrada' WHEN CLASE = 'S' THEN 'Salida' WHEN CLASE = 'T' THEN 'Traspaso' WHEN CLASE = 'D' THEN 'Descargo' END CLASE, TIPOMOVIMIENTO.TIPOFORMATO  FROM TIPOMOVIMIENTO INNER JOIN CONCEPTO ON TIPOMOVIMIENTO.CONCEPTO =CONCEPTO.CODIGO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CLASEMOVIMIENTO= CASE WHEN :CONDICION IS NULL THEN CLASEMOVIMIENTO ELSE :CONDICION END ORDER BY TIPOMOVIMIENTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NUMEROINICIAL IS NULL THEN ' ' ELSE UPPER(NUMEROINICIAL) END)  LIKE UPPER( '%' || :NUMEROINICIAL || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN TIPOFORMATO IS NULL THEN ' ' ELSE UPPER(TIPOFORMATO) END)  LIKE UPPER( '%' || :TIPOFORMATO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONDICION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPOFORMATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/numero">
		<call-query href="getTipomovimientosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONDICION" query-param="CONDICION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPOFORMATO" query-param="TIPOFORMATO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO, NOMBRE, NOMBRECORTO, CLASE,(CASE COSTEA WHEN 0 THEN 'false' ELSE 'true' END) COSTEA,(CASE ACTUALIZAMIN WHEN 0 THEN 'false' ELSE 'true' END) ACTUALIZAMIN,(CASE PIDECENTROCOSTO WHEN 0 THEN 'false' ELSE 'true' END) PIDECENTROCOSTO,(CASE PIDEORDENCOMPRA WHEN 0 THEN 'false' ELSE 'true' END) PIDEORDENCOMPRA,(CASE COSTOVENTACONS WHEN 0 THEN 'false' ELSE 'true' END) COSTOVENTACONS, NUMEROINICIAL, TIPOELEMENTO,(CASE INVENTARIOINICIAL WHEN 0 THEN 'false' ELSE 'true' END) INVENTARIOINICIAL, CONCEPTO, TIPOPESONA, CLASEMOVIMIENTO, TIPOFORMATO,(CASE GENERAPLACA WHEN 0 THEN 'false' ELSE 'true' END) GENERAPLACA,(CASE RESPONSABLEALMACEN WHEN 0 THEN 'false' ELSE 'true' END) RESPONSABLEALMACEN, CLASEDOCASOCIADO,(CASE AFECTAPEDIDO WHEN 0 THEN 'false' ELSE 'true' END) AFECTAPEDIDO, DEPANT, DEPNUE,(CASE MANEJA_VENTAS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_VENTAS,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,(CASE APLICA_NIIF WHEN 0 THEN 'false' ELSE 'true' END) APLICA_NIIF, CLASE_BODEGA_ORIGEN, CLASE_BODEGA_DESTINO,(CASE APLICADETERIORO WHEN 0 THEN 'false' ELSE 'true' END) APLICADETERIORO,(CASE REVERSADETERIORO WHEN 0 THEN 'false' ELSE 'true' END) REVERSADETERIORO,(CASE OBLIGA_CAMPOS WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_CAMPOS,(CASE CAMBIA_AUX WHEN 0 THEN 'false' ELSE 'true' END) CAMBIA_AUX,(CASE MAN_CAUSACION WHEN 0 THEN 'false' ELSE 'true' END) MAN_CAUSACION, COM_RELACIONADO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE CONTRATO_MANUAL WHEN 0 THEN 'false' ELSE 'true' END) CONTRATO_MANUAL FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA= :KEY_COMPANIA AND TIPOMOVIMIENTO.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NOMBRECORTO":"$NOMBRECORTO","CLASE":"$CLASE","COSTEA":"$COSTEA(type:boolean)","ACTUALIZAMIN":"$ACTUALIZAMIN(type:boolean)","PIDECENTROCOSTO":"$PIDECENTROCOSTO(type:boolean)","PIDEORDENCOMPRA":"$PIDEORDENCOMPRA(type:boolean)","COSTOVENTACONS":"$COSTOVENTACONS(type:boolean)","NUMEROINICIAL":"$NUMEROINICIAL(type:long)","TIPOELEMENTO":"$TIPOELEMENTO","INVENTARIOINICIAL":"$INVENTARIOINICIAL(type:boolean)","CONCEPTO":"$CONCEPTO","TIPOPESONA":"$TIPOPESONA","CLASEMOVIMIENTO":"$CLASEMOVIMIENTO","TIPOFORMATO":"$TIPOFORMATO","GENERAPLACA":"$GENERAPLACA(type:boolean)","RESPONSABLEALMACEN":"$RESPONSABLEALMACEN(type:boolean)","CLASEDOCASOCIADO":"$CLASEDOCASOCIADO","AFECTAPEDIDO":"$AFECTAPEDIDO(type:boolean)","DEPANT":"$DEPANT","DEPNUE":"$DEPNUE","MANEJA_VENTAS":"$MANEJA_VENTAS(type:boolean)","ACTIVO":"$ACTIVO(type:boolean)","APLICA_NIIF":"$APLICA_NIIF(type:boolean)","CLASE_BODEGA_ORIGEN":"$CLASE_BODEGA_ORIGEN","CLASE_BODEGA_DESTINO":"$CLASE_BODEGA_DESTINO","APLICADETERIORO":"$APLICADETERIORO(type:boolean)","REVERSADETERIORO":"$REVERSADETERIORO(type:boolean)","OBLIGA_CAMPOS":"$OBLIGA_CAMPOS(type:boolean)","CAMBIA_AUX":"$CAMBIA_AUX(type:boolean)","MAN_CAUSACION":"$MAN_CAUSACION(type:boolean)","COM_RELACIONADO":"$COM_RELACIONADO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CONTRATO_MANUAL":"$CONTRATO_MANUAL(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/data">
