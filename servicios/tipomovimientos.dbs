<data name="tipomovimientos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipomovimientosPagTodosPorClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, TIPOMOVIMIENTO.CLASEMOVIMIENTO, (CASE WHEN UPPER(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA,'PERMITE MODIFICAR FECHA INVENTARIO INICIAL','10', NULL))='SI' THEN -1 ELSE (CASE WHEN INVENTARIOINICIAL=0 THEN -1 ELSE 0 END) END ) EXPR1  FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND (CASE WHEN UPPER(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA,'PERMITE MODIFICAR FECHA INVENTARIO INICIAL','10', NULL))='SI' THEN -1 ELSE (CASE WHEN INVENTARIOINICIAL=0 THEN -1 ELSE 0 END) END ) = -1 ORDER BY TIPOMOVIMIENTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASEMOVIMIENTO":"$CLASEMOVIMIENTO","EXPR1":"$EXPR1(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipomovimientos/todosporclase/pag">
		<call-query href="getTipomovimientosPagTodosPorClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosNumTodosPorClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, TIPOMOVIMIENTO.CLASEMOVIMIENTO, (CASE WHEN UPPER(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA,'PERMITE MODIFICAR FECHA INVENTARIO INICIAL','10', NULL))='SI' THEN -1 ELSE (CASE WHEN INVENTARIOINICIAL=0 THEN -1 ELSE 0 END) END ) EXPR1  FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND (CASE WHEN UPPER(PCK_SYSMAN_UTL.FC_PAR(:COMPANIA,'PERMITE MODIFICAR FECHA INVENTARIO INICIAL','10', NULL))='SI' THEN -1 ELSE (CASE WHEN INVENTARIOINICIAL=0 THEN -1 ELSE 0 END) END ) = -1 ORDER BY TIPOMOVIMIENTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/todosporclase/num">
		<call-query href="getTipomovimientosNumTodosPorClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosPagTodosPorCodigoNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA ORDER BY COMPANIA, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipomovimientos/todosporcodigonombre/pag">
		<call-query href="getTipomovimientosPagTodosPorCodigoNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosNumTodosPorCodigoNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA ORDER BY COMPANIA, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/todosporcodigonombre/num">
		<call-query href="getTipomovimientosNumTodosPorCodigoNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosPagTodosPorCodigoNombreFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :TIPOINICIAL ORDER BY COMPANIA, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipomovimientos/todosporcodigonombrefin/pag">
		<call-query href="getTipomovimientosPagTodosPorCodigoNombreFinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosNumTodosPorCodigoNombreFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA AND CODIGO &gt;= :TIPOINICIAL ORDER BY COMPANIA, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/todosporcodigonombrefin/num">
		<call-query href="getTipomovimientosNumTodosPorCodigoNombreFinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosPagTodosPorNombreMovQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT TIPOMOVIMIENTO.CODIGO, ( CONCAT(CONCAT(CONCAT(NOMBRE, '('), CODIGO), ')') ) NOMBREMOV, TIPOMOVIMIENTO.CLASE, TIPOMOVIMIENTO.TIPOELEMENTO, TIPOMOVIMIENTO.TIPOPESONA, TIPOMOVIMIENTO.CLASEDOCASOCIADO,(CASE TIPOMOVIMIENTO.INVENTARIOINICIAL WHEN 0 THEN 'false' ELSE 'true' END) INVENTARIOINICIAL, TIPOMOVIMIENTO.CONCEPTO,(CASE TIPOMOVIMIENTO.PIDECENTROCOSTO WHEN 0 THEN 'false' ELSE 'true' END) PIDECENTROCOSTO,(CASE TIPOMOVIMIENTO.GENERAPLACA WHEN 0 THEN 'false' ELSE 'true' END) GENERAPLACA, TIPOMOVIMIENTO.TIPOFORMATO,(CASE TIPOMOVIMIENTO.MANEJA_VENTAS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_VENTAS, TIPOMOVIMIENTO.NUMEROINICIAL, TIPOMOVIMIENTO.CLASE_BODEGA_DESTINO, TIPOMOVIMIENTO.CLASE_BODEGA_ORIGEN,(CASE TIPOMOVIMIENTO.OBLIGA_CAMPOS WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_CAMPOS,(CASE TIPOMOVIMIENTO.CAMBIA_AUX WHEN 0 THEN 'false' ELSE 'true' END) CAMBIA_AUX,(CASE TIPOMOVIMIENTO.CONTRATO_MANUAL WHEN 0 THEN 'false' ELSE 'true' END) CONTRATO_MANUAL FROM TIPOMOVIMIENTO FULL JOIN MOVIMIENTOS_ACCESOS ON ( TIPOMOVIMIENTO.COMPANIA = MOVIMIENTOS_ACCESOS.COMPANIA AND TIPOMOVIMIENTO.CODIGO = MOVIMIENTOS_ACCESOS.TIPO AND MOVIMIENTOS_ACCESOS.USUARIO = :USUARIO ) WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND ( MOVIMIENTOS_ACCESOS.VER IS NULL OR MOVIMIENTOS_ACCESOS.VER = - 1 AND MOVIMIENTOS_ACCESOS.APLICACION = :MODULO) AND TIPOMOVIMIENTO.CLASE IN CASE WHEN :CLASEMOVIMIENTO IS NULL THEN CLASE ELSE :CLASEMOVIMIENTO END AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPOELEMENTO, ' ', '')), CONCAT(CONCAT('', TIPOMOVIMIENTO.TIPOELEMENTO),''), 1) &gt; 0 + :AUXILIAR ORDER BY TIPOMOVIMIENTO.CODIGO) INI WHERE (CASE WHEN NOMBREMOV IS NULL THEN ' ' ELSE UPPER(NOMBREMOV) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREMOV), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBREMOV":"$NOMBREMOV","CLASE":"$CLASE","TIPOELEMENTO":"$TIPOELEMENTO","TIPOPESONA":"$TIPOPESONA","CLASEDOCASOCIADO":"$CLASEDOCASOCIADO","INVENTARIOINICIAL":"$INVENTARIOINICIAL(type:boolean)","CONCEPTO":"$CONCEPTO","PIDECENTROCOSTO":"$PIDECENTROCOSTO(type:boolean)","GENERAPLACA":"$GENERAPLACA(type:boolean)","TIPOFORMATO":"$TIPOFORMATO","MANEJA_VENTAS":"$MANEJA_VENTAS(type:boolean)","NUMEROINICIAL":"$NUMEROINICIAL(type:long)","CLASE_BODEGA_DESTINO":"$CLASE_BODEGA_DESTINO","CLASE_BODEGA_ORIGEN":"$CLASE_BODEGA_ORIGEN","OBLIGA_CAMPOS":"$OBLIGA_CAMPOS(type:boolean)","CAMBIA_AUX":"$CAMBIA_AUX(type:boolean)","CONTRATO_MANUAL":"$CONTRATO_MANUAL(type:boolean)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CLASEMOVIMIENTO" sqlType="STRING"/>
		<param name="TIPOELEMENTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="NOMBREMOV" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipomovimientos/todospornombremov/pag">
		<call-query href="getTipomovimientosPagTodosPorNombreMovQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CLASEMOVIMIENTO" query-param="CLASEMOVIMIENTO"/>
			<with-param name="TIPOELEMENTO" query-param="TIPOELEMENTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="NOMBREMOV" query-param="NOMBREMOV"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosNumTodosPorNombreMovQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT TIPOMOVIMIENTO.CODIGO, ( CONCAT(CONCAT(CONCAT(NOMBRE, '('), CODIGO), ')') ) NOMBREMOV, TIPOMOVIMIENTO.CLASE, TIPOMOVIMIENTO.TIPOELEMENTO, TIPOMOVIMIENTO.TIPOPESONA, TIPOMOVIMIENTO.CLASEDOCASOCIADO,(CASE TIPOMOVIMIENTO.INVENTARIOINICIAL WHEN 0 THEN 'false' ELSE 'true' END) INVENTARIOINICIAL, TIPOMOVIMIENTO.CONCEPTO,(CASE TIPOMOVIMIENTO.PIDECENTROCOSTO WHEN 0 THEN 'false' ELSE 'true' END) PIDECENTROCOSTO,(CASE TIPOMOVIMIENTO.GENERAPLACA WHEN 0 THEN 'false' ELSE 'true' END) GENERAPLACA, TIPOMOVIMIENTO.TIPOFORMATO,(CASE TIPOMOVIMIENTO.MANEJA_VENTAS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_VENTAS, TIPOMOVIMIENTO.NUMEROINICIAL, TIPOMOVIMIENTO.CLASE_BODEGA_DESTINO, TIPOMOVIMIENTO.CLASE_BODEGA_ORIGEN,(CASE TIPOMOVIMIENTO.OBLIGA_CAMPOS WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_CAMPOS,(CASE TIPOMOVIMIENTO.CAMBIA_AUX WHEN 0 THEN 'false' ELSE 'true' END) CAMBIA_AUX,(CASE TIPOMOVIMIENTO.CONTRATO_MANUAL WHEN 0 THEN 'false' ELSE 'true' END) CONTRATO_MANUAL FROM TIPOMOVIMIENTO FULL JOIN MOVIMIENTOS_ACCESOS ON ( TIPOMOVIMIENTO.COMPANIA = MOVIMIENTOS_ACCESOS.COMPANIA AND TIPOMOVIMIENTO.CODIGO = MOVIMIENTOS_ACCESOS.TIPO AND MOVIMIENTOS_ACCESOS.USUARIO = :USUARIO ) WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND ( MOVIMIENTOS_ACCESOS.VER IS NULL OR MOVIMIENTOS_ACCESOS.VER = - 1 AND MOVIMIENTOS_ACCESOS.APLICACION = :MODULO) AND TIPOMOVIMIENTO.CLASE IN CASE WHEN :CLASEMOVIMIENTO IS NULL THEN CLASE ELSE :CLASEMOVIMIENTO END AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPOELEMENTO, ' ', '')), CONCAT(CONCAT('', TIPOMOVIMIENTO.TIPOELEMENTO),''), 1) &gt; 0 + :AUXILIAR ORDER BY TIPOMOVIMIENTO.CODIGO) INI WHERE (CASE WHEN NOMBREMOV IS NULL THEN ' ' ELSE UPPER(NOMBREMOV) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREMOV), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CLASEMOVIMIENTO" sqlType="STRING"/>
		<param name="TIPOELEMENTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="NOMBREMOV" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipomovimientos/todospornombremov/num">
		<call-query href="getTipomovimientosNumTodosPorNombreMovQuery">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CLASEMOVIMIENTO" query-param="CLASEMOVIMIENTO"/>
			<with-param name="TIPOELEMENTO" query-param="TIPOELEMENTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="NOMBREMOV" query-param="NOMBREMOV"/>

		</call-query>
	</resource>
	<query id="getTipomovimientosPagTodosPorComprobanteDeReclasificacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CODIGO,NOMBRE,TIPOELEMENTO,CONCEPTO,TIPOFORMATO FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA AND CONCEPTO = 'T' AND CLASE = 'T' AND CODIGO = :TIPOMOVIMIENTO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPOELEMENTO":"$TIPOELEMENTO","CONCEPTO":"$CONCEPTO","TIPOFORMATO":"$TIPOFORMATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipomovimientos/todosporcomprobantedereclasificacion/pag">
		<call-query href="getTipomovimientosPagTodosPorComprobanteDeReclasificacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertTipomovimientos" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOMOVIMIENTO (COMPANIA, CODIGO, NOMBRE, NOMBRECORTO, CLASE, COSTEA, ACTUALIZAMIN, PIDECENTROCOSTO, PIDEORDENCOMPRA, COSTOVENTACONS, NUMEROINICIAL, TIPOELEMENTO, INVENTARIOINICIAL, CONCEPTO, TIPOPESONA, CLASEMOVIMIENTO, TIPOFORMATO, GENERAPLACA, RESPONSABLEALMACEN, CLASEDOCASOCIADO, AFECTAPEDIDO, DEPANT, DEPNUE, MANEJA_VENTAS, ACTIVO, APLICA_NIIF, CLASE_BODEGA_ORIGEN, CLASE_BODEGA_DESTINO, APLICADETERIORO, REVERSADETERIORO, OBLIGA_CAMPOS, CAMBIA_AUX, MAN_CAUSACION, COM_RELACIONADO, CONTRATO_MANUAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :NOMBRECORTO, :CLASE, :COSTEA, :ACTUALIZAMIN, :PIDECENTROCOSTO, :PIDEORDENCOMPRA, :COSTOVENTACONS, :NUMEROINICIAL, :TIPOELEMENTO, :INVENTARIOINICIAL, :CONCEPTO, :TIPOPESONA, :CLASEMOVIMIENTO, :TIPOFORMATO, :GENERAPLACA, :RESPONSABLEALMACEN, :CLASEDOCASOCIADO, :AFECTAPEDIDO, :DEPANT, :DEPNUE, :MANEJA_VENTAS, :ACTIVO, :APLICA_NIIF, :CLASE_BODEGA_ORIGEN, :CLASE_BODEGA_DESTINO, :APLICADETERIORO, :REVERSADETERIORO, :OBLIGA_CAMPOS, :CAMBIA_AUX, :MAN_CAUSACION, :COM_RELACIONADO, :CONTRATO_MANUAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRECORTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param defaultValue="0" name="COSTEA" sqlType="STRING"/>
		<param defaultValue="0" name="ACTUALIZAMIN" sqlType="STRING"/>
		<param defaultValue="0" name="PIDECENTROCOSTO" sqlType="STRING"/>
		<param defaultValue="0" name="PIDEORDENCOMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="COSTOVENTACONS" sqlType="STRING"/>
		<param defaultValue="0" name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="TIPOELEMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="INVENTARIOINICIAL" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO" sqlType="STRING"/>
		<param name="TIPOPESONA" sqlType="STRING"/>
		<param defaultValue="" name="CLASEMOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="TIPOFORMATO" sqlType="STRING"/>
		<param defaultValue="0" name="GENERAPLACA" sqlType="STRING"/>
