	<query id="getTipomovimientosPagPorCompaniaClaseYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOMOVIMIENTO.CODIGO, TIPOMOVIMIENTO.NOMBRE, TIPOMOVIMIENTO.CLASEMOVIMIENTO, TIPOMOVIMIENTO.CLASEDOCASOCIADO  FROM TIPOMOVIMIENTO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CLASE = :CLASE AND TIPOMOVIMIENTO.TIPOELEMENTO = :TIPO ORDER BY TIPOMOVIMIENTO.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASEMOVIMIENTO":"$CLASEMOVIMIENTO","CLASEDOCASOCIADO":"$CLASEDOCASOCIADO"}]}}		</result>
