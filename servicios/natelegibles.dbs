		<param name="TOTAL" sqlType="STRING"/>
		<param name="ACEPTO" sqlType="STRING"/>
		<param name="VERIFICAREDU" sqlType="STRING"/>
		<param name="VERIFICAREXP" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
