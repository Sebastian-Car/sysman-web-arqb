		</call-query>
	</resource>
	<query id="updateNatelegiblesNatelegiblesporconvocatoria" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_ELEGIBLES SET ACEPTO=:ACEPTO, TOTAL=:TOTAL, OBSERVACIONES=:OBSERVACIONES, VERIFICAREDU=:VERIFICAREDU, VERIFICAREXP=:VERIFICAREXP, NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, COMPANIA=:COMPANIA, NRO_CONVOCATORIA=:NRO_CONVOCATORIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_ELEGIBLES.COMPANIA= :KEY_COMPANIA AND NAT_ELEGIBLES.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_ELEGIBLES.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_ELEGIBLES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

