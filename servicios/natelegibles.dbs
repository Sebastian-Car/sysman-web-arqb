			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatelegiblesNumNatelegiblesporconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_ELEGIBLES.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.NOMBRE, NAT_ELEGIBLES.TOTAL,(CASE NAT_ELEGIBLES.ACEPTO WHEN 0 THEN 'false' ELSE 'true' END) ACEPTO, NAT_ELEGIBLES.SUCURSAL, NAT_ELEGIBLES.COMPANIA, NAT_ELEGIBLES.NRO_CONVOCATORIA,(CASE NAT_ELEGIBLES.VERIFICAREDU WHEN 0 THEN 'false' ELSE 'true' END) VERIFICAREDU,(CASE NAT_ELEGIBLES.VERIFICAREXP WHEN 0 THEN 'false' ELSE 'true' END) VERIFICAREXP, NAT_ELEGIBLES.OBSERVACIONES  FROM NAT_ELEGIBLES INNER JOIN NAT_APERTURA_INSCRITOS ON NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = NAT_ELEGIBLES.NRO_CONVOCATORIA AND NAT_APERTURA_INSCRITOS.COMPANIA = NAT_ELEGIBLES.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = NAT_ELEGIBLES.NUMERO_DCTO AND NAT_APERTURA_INSCRITOS.SUCURSAL = NAT_ELEGIBLES.SUCURSAL WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :NO_CONVOCATORIA ORDER BY NAT_ELEGIBLES.TOTAL DESC) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER(:TOTAL || '%')  AND (CASE WHEN ACEPTO IS NULL THEN ' ' ELSE UPPER(ACEPTO) END)  LIKE UPPER(:ACEPTO || '%')  AND (CASE WHEN VERIFICAREDU IS NULL THEN ' ' ELSE UPPER(VERIFICAREDU) END)  LIKE UPPER(:VERIFICAREDU || '%')  AND (CASE WHEN VERIFICAREXP IS NULL THEN ' ' ELSE UPPER(VERIFICAREXP) END)  LIKE UPPER(:VERIFICAREXP || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER(:OBSERVACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="ACEPTO" sqlType="STRING"/>
		<param name="VERIFICAREDU" sqlType="STRING"/>
