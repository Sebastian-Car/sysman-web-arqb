			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatelegiblesPagNatelegiblesporconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_ELEGIBLES.NUMERO_DCTO, NAT_APERTURA_INSCRITOS.NOMBRE, NAT_ELEGIBLES.TOTAL,(CASE NAT_ELEGIBLES.ACEPTO WHEN 0 THEN 'false' ELSE 'true' END) ACEPTO, NAT_ELEGIBLES.SUCURSAL, NAT_ELEGIBLES.COMPANIA, NAT_ELEGIBLES.NRO_CONVOCATORIA,(CASE NAT_ELEGIBLES.VERIFICAREDU WHEN 0 THEN 'false' ELSE 'true' END) VERIFICAREDU,(CASE NAT_ELEGIBLES.VERIFICAREXP WHEN 0 THEN 'false' ELSE 'true' END) VERIFICAREXP, NAT_ELEGIBLES.OBSERVACIONES  FROM NAT_ELEGIBLES INNER JOIN NAT_APERTURA_INSCRITOS ON NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = NAT_ELEGIBLES.NRO_CONVOCATORIA AND NAT_APERTURA_INSCRITOS.COMPANIA = NAT_ELEGIBLES.COMPANIA AND NAT_APERTURA_INSCRITOS.NUMERO_DCTO = NAT_ELEGIBLES.NUMERO_DCTO AND NAT_APERTURA_INSCRITOS.SUCURSAL = NAT_ELEGIBLES.SUCURSAL WHERE NAT_APERTURA_INSCRITOS.COMPANIA = :COMPANIA AND NAT_APERTURA_INSCRITOS.NRO_CONVOCATORIA = :NO_CONVOCATORIA ORDER BY NAT_ELEGIBLES.TOTAL DESC) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER(:TOTAL || '%')  AND (CASE WHEN ACEPTO IS NULL THEN ' ' ELSE UPPER(ACEPTO) END)  LIKE UPPER(:ACEPTO || '%')  AND (CASE WHEN VERIFICAREDU IS NULL THEN ' ' ELSE UPPER(VERIFICAREDU) END)  LIKE UPPER(:VERIFICAREDU || '%')  AND (CASE WHEN VERIFICAREXP IS NULL THEN ' ' ELSE UPPER(VERIFICAREXP) END)  LIKE UPPER(:VERIFICAREXP || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER(:OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","TOTAL":"$TOTAL","ACEPTO":"$ACEPTO(type:boolean)","SUCURSAL":"$SUCURSAL","COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","VERIFICAREDU":"$VERIFICAREDU(type:boolean)","VERIFICAREXP":"$VERIFICAREXP(type:boolean)","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NO_CONVOCATORIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
