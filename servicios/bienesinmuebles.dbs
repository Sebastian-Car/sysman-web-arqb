<data name="bienesinmuebles" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBienesinmuebles" keyColumns="COMPANIA,ELEMENTO,SERIE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BIENES_INMUEBLES (COMPANIA, ELEMENTO, SERIE, FECHA_ADQUISICION, UBICACION, DIRECCION, USO, CLASIFICACION, ESCRITURA, CODIGO_CONTABLE, CODIGO_PREDIAL, MATINMOBILIARIA, VALOR_ACTO, VALOR_TOTAL, AVALUO, AREA, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ELEMENTO, :SERIE, TO_DATE(:FECHA_ADQUISICION,'DD/MM/YYYY HH24:MI:SS'), :UBICACION, :DIRECCION, :USO, :CLASIFICACION, :ESCRITURA, :CODIGO_CONTABLE, :CODIGO_PREDIAL, :MATINMOBILIARIA, :VALOR_ACTO, :VALOR_TOTAL, :AVALUO, :AREA, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ELEMENTO":"$ELEMENTO","KEY_SERIE":"$SERIE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHA_ADQUISICION" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="USO" sqlType="STRING"/>
		<param defaultValue="" name="CLASIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="ESCRITURA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_CONTABLE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_PREDIAL" sqlType="STRING"/>
		<param defaultValue="" name="MATINMOBILIARIA" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_ACTO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_TOTAL" sqlType="STRING"/>
		<param defaultValue="" name="AVALUO" sqlType="STRING"/>
		<param defaultValue="" name="AREA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bienesinmuebles">
		<call-query href="insertBienesinmuebles">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHA_ADQUISICION" query-param="FECHA_ADQUISICION"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="CLASIFICACION" query-param="CLASIFICACION"/>
			<with-param name="ESCRITURA" query-param="ESCRITURA"/>
			<with-param name="CODIGO_CONTABLE" query-param="CODIGO_CONTABLE"/>
			<with-param name="CODIGO_PREDIAL" query-param="CODIGO_PREDIAL"/>
			<with-param name="MATINMOBILIARIA" query-param="MATINMOBILIARIA"/>
			<with-param name="VALOR_ACTO" query-param="VALOR_ACTO"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="AREA" query-param="AREA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBienesinmuebles" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BIENES_INMUEBLES WHERE BIENES_INMUEBLES.COMPANIA= :KEY_COMPANIA AND BIENES_INMUEBLES.ELEMENTO= :KEY_ELEMENTO AND BIENES_INMUEBLES.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bienesinmuebles">
		<call-query href="deleteBienesinmuebles">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getBienesinmueblesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ELEMENTO, SERIE, TO_CHAR(FECHA_ADQUISICION,'DD/MM/YYYY')FECHA_ADQUISICION, UBICACION, OBSERVACIONES FROM BIENES_INMUEBLES) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIE), '%')) AND (CASE WHEN FECHA_ADQUISICION IS NULL THEN ' ' ELSE UPPER(FECHA_ADQUISICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_ADQUISICION), '%')) AND (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:UBICACION), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","FECHA_ADQUISICION":"$FECHA_ADQUISICION","UBICACION":"$UBICACION","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHA_ADQUISICION" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bienesinmuebles">
		<call-query href="getBienesinmueblesPaginaQuery">
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHA_ADQUISICION" query-param="FECHA_ADQUISICION"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBienesinmueblesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ELEMENTO, SERIE, TO_CHAR(FECHA_ADQUISICION,'DD/MM/YYYY')FECHA_ADQUISICION, UBICACION, OBSERVACIONES FROM BIENES_INMUEBLES) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIE), '%')) AND (CASE WHEN FECHA_ADQUISICION IS NULL THEN ' ' ELSE UPPER(FECHA_ADQUISICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_ADQUISICION), '%')) AND (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:UBICACION), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHA_ADQUISICION" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bienesinmuebles/numero">
		<call-query href="getBienesinmueblesNumeroQuery">
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHA_ADQUISICION" query-param="FECHA_ADQUISICION"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="getBienesinmueblesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ELEMENTO, SERIE, TO_CHAR(FECHA_ADQUISICION,'DD/MM/YYYY')FECHA_ADQUISICION, UBICACION, DIRECCION, USO, CLASIFICACION, ESCRITURA, CODIGO_CONTABLE, CODIGO_PREDIAL, MATINMOBILIARIA, VALOR_ACTO, VALOR_TOTAL, AVALUO, AREA, OBSERVACIONES,CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM BIENES_INMUEBLES WHERE BIENES_INMUEBLES.COMPANIA= :KEY_COMPANIA AND BIENES_INMUEBLES.ELEMENTO= :KEY_ELEMENTO AND BIENES_INMUEBLES.SERIE= :KEY_SERIE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","FECHA_ADQUISICION":"$FECHA_ADQUISICION","UBICACION":"$UBICACION","DIRECCION":"$DIRECCION","USO":"$USO","CLASIFICACION":"$CLASIFICACION","ESCRITURA":"$ESCRITURA","CODIGO_CONTABLE":"$CODIGO_CONTABLE","CODIGO_PREDIAL":"$CODIGO_PREDIAL","MATINMOBILIARIA":"$MATINMOBILIARIA","VALOR_ACTO":"$VALOR_ACTO","VALOR_TOTAL":"$VALOR_TOTAL","AVALUO":"$AVALUO","AREA":"$AREA","OBSERVACIONES":"$OBSERVACIONES","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bienesinmuebles/data">
		<call-query href="getBienesinmueblesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="updateBienesinmuebles" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BIENES_INMUEBLES SET COMPANIA=:COMPANIA, ELEMENTO=:ELEMENTO, SERIE=:SERIE, FECHA_ADQUISICION=TO_DATE(:FECHA_ADQUISICION,'DD/MM/YYYY HH24:MI:SS'), UBICACION=:UBICACION, DIRECCION=:DIRECCION, USO=:USO, CLASIFICACION=:CLASIFICACION, ESCRITURA=:ESCRITURA, CODIGO_CONTABLE=:CODIGO_CONTABLE, CODIGO_PREDIAL=:CODIGO_PREDIAL, MATINMOBILIARIA=:MATINMOBILIARIA, VALOR_ACTO=:VALOR_ACTO, VALOR_TOTAL=:VALOR_TOTAL, AVALUO=:AVALUO, AREA=:AREA, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BIENES_INMUEBLES.COMPANIA= :KEY_COMPANIA AND BIENES_INMUEBLES.ELEMENTO= :KEY_ELEMENTO AND BIENES_INMUEBLES.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHA_ADQUISICION" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="CLASIFICACION" sqlType="STRING"/>
		<param name="ESCRITURA" sqlType="STRING"/>
		<param name="CODIGO_CONTABLE" sqlType="STRING"/>
		<param name="CODIGO_PREDIAL" sqlType="STRING"/>
		<param name="MATINMOBILIARIA" sqlType="STRING"/>
		<param name="VALOR_ACTO" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="AREA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bienesinmuebles">
		<call-query href="updateBienesinmuebles">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHA_ADQUISICION" query-param="FECHA_ADQUISICION"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="CLASIFICACION" query-param="CLASIFICACION"/>
			<with-param name="ESCRITURA" query-param="ESCRITURA"/>
			<with-param name="CODIGO_CONTABLE" query-param="CODIGO_CONTABLE"/>
			<with-param name="CODIGO_PREDIAL" query-param="CODIGO_PREDIAL"/>
			<with-param name="MATINMOBILIARIA" query-param="MATINMOBILIARIA"/>
			<with-param name="VALOR_ACTO" query-param="VALOR_ACTO"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="AREA" query-param="AREA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>

</data>