	<query id="getComprobantescntPagListaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.DESCRIPCION, EXTRACT (MONTH FROM COMPROBANTE_CNT.FECHA) MES,(CASE COMPROBANTE_CNT.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, COMPROBANTE_CNT.DEBITOSAFECTADOS, COMPROBANTE_CNT.CREDITOSAFECTADOS FROM COMPROBANTE_CNT WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.TIPO = :TIPO ORDER BY COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION","MES":"$MES(type:integer)","IMPRESO":"$IMPRESO(type:boolean)","DEBITOSAFECTADOS":"$DEBITOSAFECTADOS","CREDITOSAFECTADOS":"$CREDITOSAFECTADOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
