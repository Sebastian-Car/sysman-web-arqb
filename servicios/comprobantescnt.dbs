			<with-param name="SUCURSALCESION" query-param="SUCURSALCESION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROAFECTADO" query-param="NUMEROAFECTADO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntAnoComprobantesQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPROBANTE_CNT.ANO FROM COMPROBANTE_CNT WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA ORDER BY COMPROBANTE_CNT.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
