	</resource>
	<query id="getComprobantescntGetnotasajusteestadosinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, TO_CHAR(COMPROBANTE_CNT.NUMERO) NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA, 'yyyy/MM/dd') FECHA, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TERCERO, COMPROBANTE_CNTAFECTADOS.COMPROBANTE_AFECT, COMPROBANTE_CNT.CONSECUTIVODIAN, COMPROBANTE_CNT.PREFIJODIAN FROM COMPROBANTE_CNT LEFT JOIN COMPROBANTE_CNTAFECTADOS ON (COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNTAFECTADOS.COMPANIA AND COMPROBANTE_CNT.ANO = COMPROBANTE_CNTAFECTADOS.ANO AND COMPROBANTE_CNT.NUMERO = COMPROBANTE_CNTAFECTADOS.COMPROBANTE AND COMPROBANTE_CNT.TIPO = COMPROBANTE_CNTAFECTADOS.TIPO_CPTE) WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TIPO = :TIPOMOVIMIENTO AND COMPROBANTE_CNT.FECHA BETWEEN TO_DATE(:FECHAINICIO,'DD/MM/YYYY') AND TO_DATE(:FECHAFIN,'DD/MM/YYYY')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO","FECHA":"$FECHA","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TERCERO":"$TERCERO","COMPROBANTE_AFECT":"$COMPROBANTE_AFECT(type:long)","CONSECUTIVODIAN":"$CONSECUTIVODIAN","PREFIJODIAN":"$PREFIJODIAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/getnotasajusteestadosinvoway">
		<call-query href="getComprobantescntGetnotasajusteestadosinvowayQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>

		</call-query>
	</resource>
	<query id="getComprobantescntGetnotasclienteinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, TO_CHAR(COMPROBANTE_CNT.NUMERO) NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA, 'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TERCERO, SF_FACTURA.NUMERO_FACTURA FROM COMPROBANTE_CNT INNER JOIN COMPROBANTE_CNTAFECTADOS ON (COMPROBANTE_CNT.COMPANIA = COMPROBANTE_CNTAFECTADOS.COMPANIA AND COMPROBANTE_CNT.ANO = COMPROBANTE_CNTAFECTADOS.ANO AND COMPROBANTE_CNT.TIPO = COMPROBANTE_CNTAFECTADOS.TIPO_CPTE AND COMPROBANTE_CNT.NUMERO = COMPROBANTE_CNTAFECTADOS.COMPROBANTE) INNER JOIN SF_FACTURA ON (SF_FACTURA.COMPANIA = COMPROBANTE_CNTAFECTADOS.COMPANIA AND SF_FACTURA.ANO = COMPROBANTE_CNTAFECTADOS.ANO AND SF_FACTURA.CODIGO_COBRO = COMPROBANTE_CNTAFECTADOS.COMPROBANTE_AFECT) INNER JOIN TIPO_COMPROBANTE ON (COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO ) WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.FECHA BETWEEN TO_DATE(:FECHAINICIO,'DD/MM/YYYY') AND TO_DATE(:FECHAFIN,'DD/MM/YYYY') AND TIPO_COMPROBANTE.CLASE_CONTABLE = :CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO","FECHA":"$FECHA","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TERCERO":"$TERCERO","NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
