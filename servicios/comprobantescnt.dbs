	<query id="updateComprobantescntUpdateenviado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET ENVIADO = -1, MODIFIED_BY = :USUARIO, DATE_MODIFIED = SYSDATE WHERE NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL 	AND CUENTA BETWEEN :CUENTAINICIAL AND :CUENTAFINAL AND COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPO AND PAGOENPLANO = -1 AND ENVIADO = 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="USUARIO" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="NUMEROFINAL" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="CUENTAFINAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="comprobantescnt/updateenviado">
		<call-query href="updateComprobantescntUpdateenviado">
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="NUMEROFINAL" query-param="NUMEROFINAL"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="CUENTAFINAL" query-param="CUENTAFINAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
