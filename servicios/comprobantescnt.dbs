	<resource method="GET" path="comprobantescnt/terencclasecomprobantet/pag">
		<call-query href="getComprobantescntPagTerencclasecomprobantetQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCEROCOMPROBANTE" query-param="TERCEROCOMPROBANTE"/>
			<with-param name="SUCURSALCOMPROBANTE" query-param="SUCURSALCOMPROBANTE"/>
			<with-param name="COMPRELACIONADO" query-param="COMPRELACIONADO"/>
			<with-param name="FECHACOMPROBANTE" query-param="FECHACOMPROBANTE"/>
