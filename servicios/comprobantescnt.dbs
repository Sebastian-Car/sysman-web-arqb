	<query id="getComprobantescntPagConsultalistafacturasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA, 'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.DESCRIPCION, VLRAGIRAR - ( CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS + ABONADO END ) AS SALDO, COMPROBANTE_CNT.NOMBRE_PROYECTO, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TIPOCONTRATO, COMPROBANTE_CNT.NUMEROCONTRATO, COMPROBANTE_CNT.TEXTO, TO_CHAR(COMPROBANTE_CNT.VLRAGIRAR, '999,999,999,999,999,999.99') VALOR, COMPROBANTE_CNT.NRO_DOCUMENTO, COMPROBANTE_CNT.COD_PROYECTO FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:COMPRELACIONADO, ' ', '')), CONCAT('', CONCAT(TO_CHAR(TIPO_COMPROBANTE.CLASE_CONTABLE ), '')), 1) &gt; 0 AND COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHACOMPROBANTE, 'DD/MM/YYYY') AND COMPROBANTE_CNT.ANO BETWEEN 0 AND :ANOCOMPROBANTE AND VLRAGIRAR - ( ( DEBITOSAFECTADOS - CREDITOSAFECTADOS ) + ABONADO ) &gt; 0 AND TIPO_COMPROBANTE.CRUCE_ANTICIPO NOT IN (0) ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN NOMBRE_PROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROYECTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","SALDO":"$SALDO(type:integer)","NOMBRE_PROYECTO":"$NOMBRE_PROYECTO","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO(type:long)","TEXTO":"$TEXTO","VALOR":"$VALOR","NRO_DOCUMENTO":"$NRO_DOCUMENTO","COD_PROYECTO":"$COD_PROYECTO"}]}}		</result>
