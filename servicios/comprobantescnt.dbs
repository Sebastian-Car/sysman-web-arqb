			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntAgruparPorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT ANO FROM COMPROBANTE_CNT GROUP BY ANO ORDER BY ANO DESC</sql>
