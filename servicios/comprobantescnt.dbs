	<query id="getComprobantescntPagTodosOrdenadoFechaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA, 'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TERCERO, TERCERO.NOMBRE FROM COMPROBANTE_CNT INNER JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.TIPO = :TIPOMOVIMIENTO AND COMPROBANTE_CNT.MES = :MES ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.FECHA DESC , COMPROBANTE_CNT.NUMERO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TERCERO":"$TERCERO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

