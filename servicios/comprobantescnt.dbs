	<query id="getComprobantescntPagComprobanteAfectadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO,(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLRAGIRAR VALOR, (VLRAGIRAR-(DEBITOSAFECTADOS+CREDITOSAFECTADOS)) SALDO, COMPROBANTE_CNT.TEXTO, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.ANO FROM COMPROBANTE_CNT WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHAHORA,'DD/MM/YYYY HH24:MI:SS') AND VLRAGIRAR-DEBITOSAFECTADOS+CREDITOSAFECTADOS&gt;0 AND COMPROBANTE_CNT.TIPO = :TIPOCPTEAFECT AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','')), CONCAT(CONCAT('', COMPROBANTE_CNT.TERCERO),'') ,1)&gt;0 AND COMPROBANTE_CNT.SUCURSAL = :SUCURSAL ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END) LIKE UPPER(CONCAT(:TEXTO, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","VALOR":"$VALOR","SALDO":"$SALDO(type:integer)","TEXTO":"$TEXTO","VLR_DOCUMENTO":"$VLR_DOCUMENTO","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAHORA" sqlType="STRING"/>
		<param name="TIPOCPTEAFECT" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantescnt/comprobanteafectado/pag">
		<call-query href="getComprobantescntPagComprobanteAfectadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAHORA" query-param="FECHAHORA"/>
			<with-param name="TIPOCPTEAFECT" query-param="TIPOCPTEAFECT"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="VLR_DOCUMENTO" query-param="VLR_DOCUMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntNumComprobanteAfectadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO,(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLRAGIRAR VALOR, (VLRAGIRAR-(DEBITOSAFECTADOS+CREDITOSAFECTADOS)) SALDO, COMPROBANTE_CNT.TEXTO, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.ANO FROM COMPROBANTE_CNT WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHAHORA,'DD/MM/YYYY HH24:MI:SS') AND VLRAGIRAR-DEBITOSAFECTADOS+CREDITOSAFECTADOS&gt;0 AND COMPROBANTE_CNT.TIPO = :TIPOCPTEAFECT AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','')), CONCAT(CONCAT('', COMPROBANTE_CNT.TERCERO),'') ,1)&gt;0 AND COMPROBANTE_CNT.SUCURSAL = :SUCURSAL ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END) LIKE UPPER(CONCAT(:TEXTO, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAHORA" sqlType="STRING"/>
		<param name="TIPOCPTEAFECT" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
