	<query id="getComprobantescntPagGrillaconfigurardeducibleQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA , COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLR_BASEIVA,(CASE COMPROBANTE_CNT.DEDUCIBLE WHEN 0 THEN 'false' ELSE 'true' END) DEDUCIBLE FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA=TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO=TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANIO AND TIPO_COMPROBANTE.IND_REPORTAR_1001 NOT IN(0) ORDER BY COMPROBANTE_CNT.TIPO,COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VLR_BASEIVA IS NULL THEN ' ' ELSE UPPER(VLR_BASEIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:VLR_BASEIVA), '%')) AND (CASE WHEN DEDUCIBLE IS NULL THEN ' ' ELSE UPPER(DEDUCIBLE) END) LIKE UPPER(CONCAT(CONCAT('%',:DEDUCIBLE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION","VLR_BASEIVA":"$VLR_BASEIVA","DEDUCIBLE":"$DEDUCIBLE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VLR_BASEIVA" sqlType="STRING"/>
		<param name="DEDUCIBLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantescnt/grillaconfigurardeducible/pag">
		<call-query href="getComprobantescntPagGrillaconfigurardeducibleQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VLR_BASEIVA" query-param="VLR_BASEIVA"/>
			<with-param name="DEDUCIBLE" query-param="DEDUCIBLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntNumGrillaconfigurardeducibleQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA , COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLR_BASEIVA,(CASE COMPROBANTE_CNT.DEDUCIBLE WHEN 0 THEN 'false' ELSE 'true' END) DEDUCIBLE FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA=TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO=TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANIO AND TIPO_COMPROBANTE.IND_REPORTAR_1001 NOT IN(0) ORDER BY COMPROBANTE_CNT.TIPO,COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VLR_BASEIVA IS NULL THEN ' ' ELSE UPPER(VLR_BASEIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:VLR_BASEIVA), '%')) AND (CASE WHEN DEDUCIBLE IS NULL THEN ' ' ELSE UPPER(DEDUCIBLE) END) LIKE UPPER(CONCAT(CONCAT('%',:DEDUCIBLE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VLR_BASEIVA" sqlType="STRING"/>
		<param name="DEDUCIBLE" sqlType="STRING"/>

	</query>
