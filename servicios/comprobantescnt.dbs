	<query id="getComprobantescntPorfact_impuestosQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(CONTAB_SYSMAN.BASEIMPUESTOIVA) SUMADEBASEIMPUESTOIVA, CONTAB_SYSMAN.PORCENTAJEIVAX PORCIVA, SUM(CONTAB_SYSMAN.VALORIMPUESTO) SUMADEVALORIMPUESTO FROM ( SELECT C.NUMERO,C.PORCIVA PORCENTAJEIVAX, D.VALOR_IVA VALORIMPUESTO,D.BASE_IVA BASEIMPUESTOIVA FROM COMPROBANTE_CNT C INNER JOIN DETALLE_COMPROBANTE_CNT D ON C.COMPANIA = D.COMPANIA AND C.NUMERO = D.COMPROBANTE AND C.TIPO = D.TIPO_CPTE WHERE C.COMPANIA = :COMPANIA AND C.IMPRESO NOT IN (0) AND C.NUMERO = :NUMERO AND C.TIPO = :TIPO ORDER BY C.NUMERO ) CONTAB_SYSMAN WHERE CONTAB_SYSMAN.PORCENTAJEIVAX &lt;&gt; 0 GROUP BY CONTAB_SYSMAN.PORCENTAJEIVAX</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMADEBASEIMPUESTOIVA":"$SUMADEBASEIMPUESTOIVA(type:integer)","PORCIVA":"$PORCIVA","SUMADEVALORIMPUESTO":"$SUMADEVALORIMPUESTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/porfact_impuestos">
		<call-query href="getComprobantescntPorfact_impuestosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPorfact_impuestoreteivaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(CONTAB_SYSMAN.BASEIMPUESTORETEIVA) SUMADEBASEIMPUESTORETEIVA, CONTAB_SYSMAN.PORCENTAJERETEIVADX PORCENTAJE  SUM(CONTAB_SYSMAN.VALOR_RETEIVA) SUMADERETEIVA FROM( SELECT C.NUMERO,CR.PORCIVA PORCENTAJERETEIVADX, CR.VALOR VALOR_RETEIVA,CR.VALORBASE BASEIMPUESTORETEIVA FROM COMPROBANTE_CNT C INNER JOIN DETALLE_COMPROBANTE_CNT D ON C.COMPANIA = D.COMPANIA AND C.NUMERO = D.COMPROBANTE AND C.TIPO = D.TIPO_CPTE INNER JOIN COMPROBANTE_CNTRETENCION CR ON C.COMPANIA = CR.COMPANIA AND C.ANO = CR.ANO AND C.TIPO = CR.TIPO AND C.NUMERO = CR.NUMERO WHERE C.COMPANIA = :COMPANIA AND C.IMPRESO NOT IN (0) AND C.NUMERO = :NUMERO AND C.TIPO = :TIPO ORDER BY C.NUMERO ) CONTAB_SYSMAN WHERE CONTAB_SYSMAN.PORCENTAJERETEIVADX &lt;&gt; 0 GROUP BY CONTAB_SYSMAN.PORCENTAJERETEIVADX</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMADEBASEIMPUESTORETEIVA":"$SUMADEBASEIMPUESTORETEIVA(type:integer)","PORCENTAJE":"$PORCENTAJE","SUMADERETEIVA":"$SUMADERETEIVA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/porfact_impuestoreteiva">
		<call-query href="getComprobantescntPorfact_impuestoreteivaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPorfact_datacomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT PREFIJO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,NUMTERCERO,VALOR_TOTAL,NATURALEZATERCERO,DIRECCIONTERCERO,CODIGOPOSTALTERCERO,TELEFONOS,EMAILTECERO, PAISTERCERO,DIGITOVERIFICACIONTERCERO,DEPTOTERCERO,CIUDADTERCERO,RAZONSOCIAL,NOMBRETERCERO,DIRECCIONCOMPANIA,CIUDADCOMPANIA, DEPTOCOMPANIA,DIGITOVERIFICACIONCOMPANIA,SUBTOTAL,TIPO_MONEDA,TIPO_MEDIOPAGO,TIPO_PAGO FROM ( SELECT C.PREFIJODIAN PREFIJO, C.FECHA, C.TERCERO NUMTERCERO,SUM(C.VLR_DOCUMENTO) VALOR_TOTAL, T.NATURALEZA NATURALEZATERCERO,T.DIRECCION DIRECCIONTERCERO,T.CODIGOPOSTAL CODIGOPOSTALTERCERO,T.TELEFONOS,T.DIRECCIONEMAIL EMAILTECERO, T.PAIS PAISTERCERO,T.DIGITOVERIFICACION DIGITOVERIFICACIONTERCERO,T.DEPARTAMENTO DEPTOTERCERO,T.CIUDAD CIUDADTERCERO,T.NOMBRE RAZONSOCIAL, T.NOMBRE1 NOMBRETERCERO , CPN.DIRECCION DIRECCIONCOMPANIA,CPN.CIUDAD CIUDADCOMPANIA,CPN.DEPARTAMENTO DEPTOCOMPANIA, TC.DIGITOVERIFICACION DIGITOVERIFICACIONCOMPANIA, SUM(D.VALORTOTAL) SUBTOTAL, RES.TIPO_MONEDA, RES.TIPO_MEDIOPAGO, RES.TIPO_PAGO FROM COMPROBANTE_CNT C INNER JOIN DETALLE_COMPROBANTE_CNT D ON C.COMPANIA = D.COMPANIA AND C.TIPO = D.TIPO_CPTE AND C.NUMERO = D.COMPROBANTE INNER JOIN TERCERO T ON C.COMPANIA = T.COMPANIA AND C.TERCERO = T.NIT AND C.SUCURSAL = T.SUCURSAL INNER JOIN COMPANIA CPN ON CPN.CODIGO = C.COMPANIA LEFT JOIN RESOLUCIONDIAN_CT RES ON RES.COMPANIA = C.COMPANIA AND RES.TIPOCOMPROBANTE = C.TIPO AND RES.NUMERO = C.NUMERO INNER JOIN TERCERO TC ON TC.NIT = CPN.NITCOMPANIA WHERE C.PREFIJODIAN IS NOT NULL AND C.COMPANIA = :COMPANIA AND C.NUMERO = :NUMERO AND C.TIPO = :TIPO GROUP BY C.PREFIJODIAN, C.FECHA, C.TERCERO, T.NATURALEZA, T.DIRECCION, T.CODIGOPOSTAL, T.TELEFONOS, T.DIRECCIONEMAIL, T.PAIS, T.DIGITOVERIFICACION, T.DEPARTAMENTO, T.CIUDAD, T.NOMBRE, T.NOMBRE1, CPN.DIRECCION, CPN.CIUDAD, CPN.DEPARTAMENTO, TC.DIGITOVERIFICACION, RES.TIPO_MONEDA, RES.TIPO_MEDIOPAGO, RES.TIPO_PAGO ORDER BY C.NUMERO) TOTAL_CPTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREFIJO":"$PREFIJO","FECHA":"$FECHA","NUMTERCERO":"$NUMTERCERO","VALOR_TOTAL":"$VALOR_TOTAL(type:integer)","NATURALEZATERCERO":"$NATURALEZATERCERO","DIRECCIONTERCERO":"$DIRECCIONTERCERO","CODIGOPOSTALTERCERO":"$CODIGOPOSTALTERCERO","TELEFONOS":"$TELEFONOS","EMAILTECERO":"$EMAILTECERO","PAISTERCERO":"$PAISTERCERO","DIGITOVERIFICACIONTERCERO":"$DIGITOVERIFICACIONTERCERO(type:long)","DEPTOTERCERO":"$DEPTOTERCERO","CIUDADTERCERO":"$CIUDADTERCERO","RAZONSOCIAL":"$RAZONSOCIAL","NOMBRETERCERO":"$NOMBRETERCERO","DIRECCIONCOMPANIA":"$DIRECCIONCOMPANIA","CIUDADCOMPANIA":"$CIUDADCOMPANIA","DEPTOCOMPANIA":"$DEPTOCOMPANIA","DIGITOVERIFICACIONCOMPANIA":"$DIGITOVERIFICACIONCOMPANIA(type:long)","SUBTOTAL":"$SUBTOTAL(type:integer)","TIPO_MONEDA":"$TIPO_MONEDA","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_PAGO":"$TIPO_PAGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/porfact_datacomprobante">
		<call-query href="getComprobantescntPorfact_datacomprobanteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>

</data>