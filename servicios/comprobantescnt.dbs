		<param name="FECHA_ABONO" sqlType="STRING"/>
		<param name="USUARIO_ABONO" sqlType="STRING"/>
		<param name="FECHAPAGADOGN" sqlType="STRING"/>
		<param name="IND_PAGADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
