<data name="comprobantescnt" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getComprobantescntTodosSinRepetirNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT NUMERO FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPO = :TIPO AND NUMERO BETWEEN :NUMEROINI AND :NUMEROFIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMEROINI" sqlType="STRING"/>
		<param name="NUMEROFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/todossinrepetirnumero">
		<call-query href="getComprobantescntTodosSinRepetirNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMEROINI" query-param="NUMEROINI"/>
			<with-param name="NUMEROFIN" query-param="NUMEROFIN"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPagPorAnioTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO, DESCRIPCION FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPO = :TIPO ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantescnt/poraniotipo/pag">
		<call-query href="getComprobantescntPagPorAnioTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntNumPorAnioTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUMERO, DESCRIPCION FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPO = :TIPO ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/poraniotipo/num">
		<call-query href="getComprobantescntNumPorAnioTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPagPorAnioTipoMayoresaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO, DESCRIPCION FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPO = :TIPO AND NUMERO &gt;= :NUMEROINI ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMEROINI" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantescnt/poraniotipomayoresanumero/pag">
		<call-query href="getComprobantescntPagPorAnioTipoMayoresaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMEROINI" query-param="NUMEROINI"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntNumPorAnioTipoMayoresaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUMERO, DESCRIPCION FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPO = :TIPO AND NUMERO &gt;= :NUMEROINI ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMEROINI" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/poraniotipomayoresanumero/num">
		<call-query href="getComprobantescntNumPorAnioTipoMayoresaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMEROINI" query-param="NUMEROINI"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getComprobantescntLeftTerceroPorAnioTipoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT C.NUMERO,(TO_CHAR(C.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, C.ANO, C.MES, C.DIA,(TO_CHAR(C.FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS')) FECHA_VCN_DOC, C.TEXTO, C.TERCERO, C.VLRAGIRAR, T.NOMBRE, T.NIT, T.DIRECCION FROM COMPROBANTE_CNT C LEFT JOIN TERCERO T ON C.COMPANIA = T.COMPANIA AND C.TERCERO = T.NIT AND C.SUCURSAL = T.SUCURSAL WHERE C.COMPANIA= :COMPANIA AND C.ANO = :ANIO AND C.TIPO = :TIPO AND C.NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","ANO":"$ANO(type:integer)","MES":"$MES(type:long)","DIA":"$DIA(type:long)","FECHA_VCN_DOC":"$FECHA_VCN_DOC","TEXTO":"$TEXTO","TERCERO":"$TERCERO","VLRAGIRAR":"$VLRAGIRAR","NOMBRE":"$NOMBRE","NIT":"$NIT","DIRECCION":"$DIRECCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/leftterceroporaniotiponumero">
		<call-query href="getComprobantescntLeftTerceroPorAnioTipoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="updateComprobantescntPorAnioTipoEntrenumero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET IMPRESO =:IMPRESO, DATE_MODIFIED =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY =:MODIFIED_BY WHERE COMPROBANTE_CNT.COMPANIA= :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.TIPO = :TIPO AND COMPROBANTE_CNT.NUMERO BETWEEN :NUMEROINI AND :NUMEROFIN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IMPRESO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMEROINI" sqlType="STRING"/>
		<param name="NUMEROFIN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="comprobantescnt/poraniotipoentrenumero">
		<call-query href="updateComprobantescntPorAnioTipoEntrenumero">
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMEROINI" query-param="NUMEROINI"/>
			<with-param name="NUMEROFIN" query-param="NUMEROFIN"/>

		</call-query>
	</resource>
	<query id="getComprobantescntCantidadRegistrosPorFacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) CUENTA FROM COMPROBANTE_CNT WHERE COMPANIA=:COMPANIA AND TIPO ='SRV' AND NUMERO = :FACTURA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/cantidadregistrosporfactura">
		<call-query href="getComprobantescntCantidadRegistrosPorFacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FACTURA" query-param="FACTURA"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPagPorTipoYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.TIPO FROM COMPROBANTE_CNT LEFT JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND TIPO_COMPROBANTE.CLASE_CONTABLE ='E' AND COMPROBANTE_CNT.TIPO = :TIPO AND COMPROBANTE_CNT.ANO = :ANO ORDER BY COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantescnt/portipoyanio/pag">
		<call-query href="getComprobantescntPagPorTipoYAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertComprobantescnt" keyColumns="COMPANIA,ANO,TIPO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPROBANTE_CNT (TIPOPAGO_SIA, HORA, SUCURSAL, TIPO, VLR_BASEIVA, PAGOAPODERADO, PAGO_EFECTIVO, FECHAINHUMACION, BANCO, NUMERO, DESCRIPCION, TEXTO, VLR_DOCUMENTO, PAGOENPLANO, TERCERO, ENTREGADO, ENVIADO, FECHA_VCN_DOC, CREATED_BY, CONTRIBUYENTE, REFERENCIA, CENTRO_COSTO, COD_PROYECTO, CONCEPTO_SF, AUXILIAR, GIROELECTRONICO, FECHA, PORCIVA, TIPOPAGO, CUENTA, ANO, VLRAGIRAR, CEDULAINHUMACION, NRO_DOCUMENTO, FECHAPAGADOGN, COMPANIA, ORDENADOR, NUMEROCONTRATO, NONIIF, PAGADOGN, IMPRESO, VLR_BASE, DATE_CREATED, CODI_SIA, DEPENDENCIACNT, IND_ANTICIPO, TIPOCONTRATO, CUENTABANCO, TIPO_CAJA, CODIGO_FLUJO_EFECTIVO, PLANO_NOMINA, INFORMECOVID, FECHACONSIGNACION, PREFIJODIAN, CONSECUTIVODIAN, RESOLUCIONDIAN, CONSFACTURA, LEGALIZADO, TIPO_SIGEC, FECHA_FIRME) VALUES (:TIPOPAGO_SIA, TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), :SUCURSAL, :TIPO, :VLR_BASEIVA, :PAGOAPODERADO, :PAGO_EFECTIVO, TO_DATE(:FECHAINHUMACION,'DD/MM/YYYY HH24:MI:SS'), :BANCO, :NUMERO, :DESCRIPCION, :TEXTO, :VLR_DOCUMENTO, :PAGOENPLANO, :TERCERO, :ENTREGADO, :ENVIADO, TO_DATE(:FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, :CONTRIBUYENTE, :REFERENCIA, :CENTRO_COSTO, :COD_PROYECTO, :CONCEPTO_SF, :AUXILIAR, :GIROELECTRONICO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :PORCIVA, :TIPOPAGO, :CUENTA, :ANO, :VLRAGIRAR, :CEDULAINHUMACION, :NRO_DOCUMENTO, TO_DATE(:FECHAPAGADOGN,'DD/MM/YYYY HH24:MI:SS'), :COMPANIA, :ORDENADOR, :NUMEROCONTRATO, :NONIIF, :PAGADOGN, :IMPRESO, :VLR_BASE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CODI_SIA, :DEPENDENCIACNT, :IND_ANTICIPO, :TIPOCONTRATO, :CUENTABANCO, :TIPO_CAJA, :CODIGO_FLUJO_EFECTIVO, :PLANO_NOMINA, :INFORMECOVID, TO_DATE(:FECHACONSIGNACION,'DD/MM/YYYY HH24:MI:SS'), :PREFIJODIAN, :CONSECUTIVODIAN, :RESOLUCIONDIAN, :CONSFACTURA, :LEGALIZADO, :TIPO_SIGEC, TO_DATE(:FECHA_FIRME,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param defaultValue="" name="TIPOPAGO_SIA" sqlType="STRING"/>
		<param defaultValue="" name="HORA" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="0" name="VLR_BASEIVA" sqlType="STRING"/>
		<param defaultValue="0" name="PAGOAPODERADO" sqlType="STRING"/>
		<param defaultValue="0" name="PAGO_EFECTIVO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINHUMACION" sqlType="STRING"/>
		<param defaultValue="" name="BANCO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="TEXTO" sqlType="STRING"/>
		<param defaultValue="0" name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="PAGOENPLANO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="0" name="ENTREGADO" sqlType="STRING"/>
		<param defaultValue="0" name="ENVIADO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_VCN_DOC" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param defaultValue="" name="CONTRIBUYENTE" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="" name="COD_PROYECTO" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTO_SF" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="0" name="GIROELECTRONICO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVA" sqlType="STRING"/>
		<param defaultValue="" name="TIPOPAGO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="0" name="VLRAGIRAR" sqlType="STRING"/>
		<param defaultValue="" name="CEDULAINHUMACION" sqlType="STRING"/>
		<param defaultValue="" name="NRO_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAPAGADOGN" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="" name="ORDENADOR" sqlType="STRING"/>
		<param defaultValue="" name="NUMEROCONTRATO" sqlType="STRING"/>
		<param defaultValue="0" name="NONIIF" sqlType="STRING"/>
		<param defaultValue="0" name="PAGADOGN" sqlType="STRING"/>
		<param defaultValue="0" name="IMPRESO" sqlType="STRING"/>
		<param defaultValue="0" name="VLR_BASE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="CODI_SIA" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIACNT" sqlType="STRING"/>
		<param defaultValue="0" name="IND_ANTICIPO" sqlType="STRING"/>
		<param defaultValue="" name="TIPOCONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTABANCO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CAJA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_FLUJO_EFECTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="PLANO_NOMINA" sqlType="STRING"/>
		<param defaultValue="0" name="INFORMECOVID" sqlType="STRING"/>
		<param defaultValue="" name="FECHACONSIGNACION" sqlType="STRING"/>
		<param defaultValue="" name="PREFIJODIAN" sqlType="STRING"/>
		<param defaultValue="" name="CONSECUTIVODIAN" sqlType="STRING"/>
		<param defaultValue="" name="RESOLUCIONDIAN" sqlType="STRING"/>
		<param defaultValue="" name="CONSFACTURA" sqlType="STRING"/>
		<param defaultValue="0" name="LEGALIZADO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_SIGEC" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FIRME" sqlType="STRING"/>
	</query>
	<resource method="POST" path="comprobantescnt">
		<call-query href="insertComprobantescnt">
			<with-param name="TIPOPAGO_SIA" query-param="TIPOPAGO_SIA"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="VLR_BASEIVA" query-param="VLR_BASEIVA"/>
			<with-param name="PAGOAPODERADO" query-param="PAGOAPODERADO"/>
			<with-param name="PAGO_EFECTIVO" query-param="PAGO_EFECTIVO"/>
			<with-param name="FECHAINHUMACION" query-param="FECHAINHUMACION"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="VLR_DOCUMENTO" query-param="VLR_DOCUMENTO"/>
			<with-param name="PAGOENPLANO" query-param="PAGOENPLANO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="ENTREGADO" query-param="ENTREGADO"/>
			<with-param name="ENVIADO" query-param="ENVIADO"/>
			<with-param name="FECHA_VCN_DOC" query-param="FECHA_VCN_DOC"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="CONTRIBUYENTE" query-param="CONTRIBUYENTE"/>
