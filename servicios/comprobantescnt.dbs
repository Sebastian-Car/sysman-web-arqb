	<query id="getComprobantescntRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, TO_CHAR(COMPROBANTE_CNT.NUMERO) NUMERO, COMPROBANTE_CNT.TERCERO, COMPROBANTE_CNT.SUCURSAL, COMPROBANTE_CNT.CENTRO_COSTO, COMPROBANTE_CNT.AUXILIAR, COMPROBANTE_CNT.REFERENCIA, COMPROBANTE_CNT.FUENTE_RECURSO,(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_CNT.MES, COMPROBANTE_CNT.DIA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLR_BASE, COMPROBANTE_CNT.TEXTO, COMPROBANTE_CNT.NRO_DOCUMENTO,(TO_CHAR(COMPROBANTE_CNT.FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS')) FECHA_VCN_DOC, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.DEBITO, COMPROBANTE_CNT.CREDITO, COMPROBANTE_CNT.ABONADO, COMPROBANTE_CNT.CUENTA,(CASE COMPROBANTE_CNT.ENTREGADO WHEN 0 THEN 'false' ELSE 'true' END) ENTREGADO,(CASE COMPROBANTE_CNT.PAGADOBANCO WHEN 0 THEN 'false' ELSE 'true' END) PAGADOBANCO,(CASE COMPROBANTE_CNT.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE COMPROBANTE_CNT.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO, COMPROBANTE_CNT.VLR_BASEIVA, COMPROBANTE_CNT.VLRAGIRAR, COMPROBANTE_CNT.REGISTRO, COMPROBANTE_CNT.TIPODEPRESUPUESTO, COMPROBANTE_CNT.DEBITOSAFECTADOS, COMPROBANTE_CNT.CREDITOSAFECTADOS, COMPROBANTE_CNT.TIPOCONTRATO, COMPROBANTE_CNT.NUMEROCONTRATO, COMPROBANTE_CNT.TASADECAMBIO, COMPROBANTE_CNT.BANCO, COMPROBANTE_CNT.CUENTABANCO, COMPROBANTE_CNT.PORCIVA, COMPROBANTE_CNT.ORDENADOR, COMPROBANTE_CNT.ORDENADORSUCURSAL,(CASE COMPROBANTE_CNT.PAGOENPLANO WHEN 0 THEN 'false' ELSE 'true' END) PAGOENPLANO,(CASE COMPROBANTE_CNT.ENVIADO WHEN 0 THEN 'false' ELSE 'true' END) ENVIADO,(CASE COMPROBANTE_CNT.PAGOAPODERADO WHEN 0 THEN 'false' ELSE 'true' END) PAGOAPODERADO, COMPROBANTE_CNT.TIPOPAGO,(TO_CHAR(COMPROBANTE_CNT.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, COMPROBANTE_CNT.TERCERO_NSESION, COMPROBANTE_CNT.SUCURSAL_NSESION,(CASE COMPROBANTE_CNT.PAGO_EFECTIVO WHEN 0 THEN 'false' ELSE 'true' END) PAGO_EFECTIVO,(CASE COMPROBANTE_CNT.PROGRAMADO WHEN 0 THEN 'false' ELSE 'true' END) PROGRAMADO,(TO_CHAR(COMPROBANTE_CNT.FECHAPROGPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPROGPAGO,(TO_CHAR(COMPROBANTE_CNT.FECHARECEPCION,'DD/MM/YYYY HH24:MI:SS')) FECHARECEPCION,(CASE COMPROBANTE_CNT.PAGADOGN WHEN 0 THEN 'false' ELSE 'true' END) PAGADOGN,(TO_CHAR(COMPROBANTE_CNT.FECHAPAGADOGN,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGADOGN,(TO_CHAR(COMPROBANTE_CNT.FECHAINHUMACION,'DD/MM/YYYY HH24:MI:SS')) FECHAINHUMACION, COMPROBANTE_CNT.CEDULAINHUMACION, COMPROBANTE_CNT.CONSECUTIVOWF, COMPROBANTE_CNT.DEBITOSAFECTADOS_CXP, COMPROBANTE_CNT.CREDITOSAFECTADOS_CXP,(TO_CHAR(COMPROBANTE_CNT.FECHA_ABONO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ABONO, COMPROBANTE_CNT.ABONOCXP, COMPROBANTE_CNT.USUARIO_ABONO,(CASE COMPROBANTE_CNT.GIROELECTRONICO WHEN 0 THEN 'false' ELSE 'true' END) GIROELECTRONICO, COMPROBANTE_CNT.TIPOPAGO_SIA, COMPROBANTE_CNT.COD_PROYECTO, COMPROBANTE_CNT.NOMBRE_PROYECTO, COMPROBANTE_CNT.CODI_SIA, COMPROBANTE_CNT.CONSFACTURA, COMPROBANTE_CNT.CONTRIBUYENTE, COMPROBANTE_CNT.MODIFICADOR_CH,(TO_CHAR(COMPROBANTE_CNT.FECHA_MODIFICADOR_CH,'DD/MM/YYYY HH24:MI:SS')) FECHA_MODIFICADOR_CH, COMPROBANTE_CNT.DEPENDENCIACNT, COMPROBANTE_CNT.CONCEPTO_SF,(CASE COMPROBANTE_CNT.IND_ANTICIPO WHEN 0 THEN 'false' ELSE 'true' END) IND_ANTICIPO, COMPROBANTE_CNT.CREATED_BY,(TO_CHAR(COMPROBANTE_CNT.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, COMPROBANTE_CNT.MODIFIED_BY,(TO_CHAR(COMPROBANTE_CNT.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE COMPROBANTE_CNT.NONIIF WHEN 0 THEN 'false' ELSE 'true' END) NONIIF, TERCERO.NOMBRE NOMBRETERCERO,(CASE TERCERO.AUTORETENEDOR WHEN 0 THEN 'false' ELSE 'true' END) AUTORETENEDOR, TERCERO.REGIMEN,(CASE TERCERO.LEY1450 WHEN 0 THEN 'false' ELSE 'true' END) LEY1450,(CASE TERCERO.LEY1819 WHEN 0 THEN 'false' ELSE 'true' END) LEY1819, COMPROBANTE_CNT.TIPO_CAJA,COMPROBANTE_CNT.CODIGO_FLUJO_EFECTIVO,(CASE PLANO_NOMINA WHEN 0 THEN 'false' ELSE 'true' END) PLANO_NOMINA,(CASE COMPROBANTE_CNT.INFORMECOVID WHEN 0 THEN 'false' ELSE 'true' END) INFORMECOVID,(TO_CHAR(COMPROBANTE_CNT.FECHACONSIGNACION,'DD/MM/YYYY HH24:MI:SS')) FECHACONSIGNACION, COMPROBANTE_CNT.PREFIJODIAN, COMPROBANTE_CNT.CONSECUTIVODIAN, COMPROBANTE_CNT.RESOLUCIONDIAN,(CASE COMPROBANTE_CNT.LEGALIZADO WHEN 0 THEN 'false' ELSE 'true' END) LEGALIZADO, TO_CHAR(COMPROBANTE_CNT.TIPO_SIGEC) TIPO_SIGEC,(TO_CHAR(COMPROBANTE_CNT.FECHA_FIRME,'DD/MM/YYYY HH24:MI:SS')) FECHA_FIRME FROM COMPROBANTE_CNT INNER JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL WHERE COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_CNT.ANO= :KEY_ANO AND COMPROBANTE_CNT.TIPO= :KEY_TIPO AND COMPROBANTE_CNT.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","FECHA":"$FECHA","MES":"$MES(type:long)","DIA":"$DIA(type:long)","DESCRIPCION":"$DESCRIPCION","VLR_BASE":"$VLR_BASE","TEXTO":"$TEXTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","FECHA_VCN_DOC":"$FECHA_VCN_DOC","VLR_DOCUMENTO":"$VLR_DOCUMENTO","DEBITO":"$DEBITO","CREDITO":"$CREDITO","ABONADO":"$ABONADO","CUENTA":"$CUENTA","ENTREGADO":"$ENTREGADO(type:boolean)","PAGADOBANCO":"$PAGADOBANCO(type:boolean)","IMPRESO":"$IMPRESO(type:boolean)","ANULADO":"$ANULADO(type:boolean)","VLR_BASEIVA":"$VLR_BASEIVA","VLRAGIRAR":"$VLRAGIRAR","REGISTRO":"$REGISTRO(type:long)","TIPODEPRESUPUESTO":"$TIPODEPRESUPUESTO","DEBITOSAFECTADOS":"$DEBITOSAFECTADOS","CREDITOSAFECTADOS":"$CREDITOSAFECTADOS","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO(type:long)","TASADECAMBIO":"$TASADECAMBIO","BANCO":"$BANCO","CUENTABANCO":"$CUENTABANCO","PORCIVA":"$PORCIVA","ORDENADOR":"$ORDENADOR","ORDENADORSUCURSAL":"$ORDENADORSUCURSAL","PAGOENPLANO":"$PAGOENPLANO(type:boolean)","ENVIADO":"$ENVIADO(type:boolean)","PAGOAPODERADO":"$PAGOAPODERADO(type:boolean)","TIPOPAGO":"$TIPOPAGO","HORA":"$HORA","TERCERO_NSESION":"$TERCERO_NSESION","SUCURSAL_NSESION":"$SUCURSAL_NSESION","PAGO_EFECTIVO":"$PAGO_EFECTIVO(type:boolean)","PROGRAMADO":"$PROGRAMADO(type:boolean)","FECHAPROGPAGO":"$FECHAPROGPAGO","FECHARECEPCION":"$FECHARECEPCION","PAGADOGN":"$PAGADOGN(type:boolean)","FECHAPAGADOGN":"$FECHAPAGADOGN","FECHAINHUMACION":"$FECHAINHUMACION","CEDULAINHUMACION":"$CEDULAINHUMACION","CONSECUTIVOWF":"$CONSECUTIVOWF(type:integer)","DEBITOSAFECTADOS_CXP":"$DEBITOSAFECTADOS_CXP","CREDITOSAFECTADOS_CXP":"$CREDITOSAFECTADOS_CXP","FECHA_ABONO":"$FECHA_ABONO","ABONOCXP":"$ABONOCXP","USUARIO_ABONO":"$USUARIO_ABONO","GIROELECTRONICO":"$GIROELECTRONICO(type:boolean)","TIPOPAGO_SIA":"$TIPOPAGO_SIA","COD_PROYECTO":"$COD_PROYECTO","NOMBRE_PROYECTO":"$NOMBRE_PROYECTO","CODI_SIA":"$CODI_SIA","CONSFACTURA":"$CONSFACTURA","CONTRIBUYENTE":"$CONTRIBUYENTE","MODIFICADOR_CH":"$MODIFICADOR_CH","FECHA_MODIFICADOR_CH":"$FECHA_MODIFICADOR_CH","DEPENDENCIACNT":"$DEPENDENCIACNT","CONCEPTO_SF":"$CONCEPTO_SF","IND_ANTICIPO":"$IND_ANTICIPO(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NONIIF":"$NONIIF(type:boolean)","NOMBRETERCERO":"$NOMBRETERCERO","AUTORETENEDOR":"$AUTORETENEDOR(type:boolean)","REGIMEN":"$REGIMEN","LEY1450":"$LEY1450(type:boolean)","LEY1819":"$LEY1819(type:boolean)","TIPO_CAJA":"$TIPO_CAJA","CODIGO_FLUJO_EFECTIVO":"$CODIGO_FLUJO_EFECTIVO","PLANO_NOMINA":"$PLANO_NOMINA(type:boolean)","INFORMECOVID":"$INFORMECOVID(type:boolean)","FECHACONSIGNACION":"$FECHACONSIGNACION","PREFIJODIAN":"$PREFIJODIAN","CONSECUTIVODIAN":"$CONSECUTIVODIAN","RESOLUCIONDIAN":"$RESOLUCIONDIAN","LEGALIZADO":"$LEGALIZADO(type:boolean)","TIPO_SIGEC":"$TIPO_SIGEC","FECHA_FIRME":"$FECHA_FIRME"}]}}		</result>
