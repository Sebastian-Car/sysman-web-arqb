	<query id="updateComprobantescntPortiponumero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET FECHARECEPCION=TO_DATE(:FECHARECEPCION,'DD/MM/YYYY HH24:MI:SS'), PROGRAMADO=:PROGRAMADO, FECHAPROGPAGO=TO_DATE(:FECHAPROGPAGO,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_CNT.ANO= :KEY_ANO AND COMPROBANTE_CNT.TIPO= :KEY_TIPO AND COMPROBANTE_CNT.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHARECEPCION" sqlType="STRING"/>
		<param name="PROGRAMADO" sqlType="STRING"/>
		<param name="FECHAPROGPAGO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="comprobantescnt/portiponumero">
		<call-query href="updateComprobantescntPortiponumero">
			<with-param name="FECHARECEPCION" query-param="FECHARECEPCION"/>
			<with-param name="PROGRAMADO" query-param="PROGRAMADO"/>
			<with-param name="FECHAPROGPAGO" query-param="FECHAPROGPAGO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntExistentePorConceptosfQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT 'X' EXISTE FROM COMPROBANTE_CNT WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.CONCEPTO_SF= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
