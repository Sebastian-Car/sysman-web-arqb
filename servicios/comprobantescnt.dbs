	<query id="getComprobantescntGetdocumentossoporteconusltainvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, TO_CHAR(COMPROBANTE_CNT.NUMERO) NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA, 'yyyy/MM/dd') FECHA, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TERCERO, COMPROBANTE_CNT.CONSECUTIVODIAN, COMPROBANTE_CNT.PREFIJODIAN FROM COMPROBANTE_CNT WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.FECHA BETWEEN TO_DATE(:FECHAINICIO,'DD/MM/YYYY') AND TO_DATE(:FECHAFIN,'DD/MM/YYYY') AND COMPROBANTE_CNT.PREFIJODIAN IS NOT NULL AND COMPROBANTE_CNT.CONSECUTIVODIAN IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO","FECHA":"$FECHA","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TERCERO":"$TERCERO","CONSECUTIVODIAN":"$CONSECUTIVODIAN","PREFIJODIAN":"$PREFIJODIAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>

	</query>

