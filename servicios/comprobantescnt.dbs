		</call-query>
	</resource>
	<query id="getComprobantescntNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, TO_CHAR(COMPROBANTE_CNT.NUMERO) NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TERCERO, TERCERO.NOMBRE, COMPROBANTE_CNT.PREFIJODIAN, COMPROBANTE_CNT.CONSECUTIVODIAN, COMPROBANTE_CNT.RESOLUCIONDIAN FROM COMPROBANTE_CNT INNER JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL WHERE COMPROBANTE_CNT.COMPANIA =:COMPANIA AND COMPROBANTE_CNT.ANO =:ANO AND COMPROBANTE_CNT.TIPO =:TIPOMOVIMIENTO AND COMPROBANTE_CNT.MES =:MES ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PREFIJODIAN IS NULL THEN ' ' ELSE UPPER(PREFIJODIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:PREFIJODIAN), '%')) AND (CASE WHEN CONSECUTIVODIAN IS NULL THEN ' ' ELSE UPPER(CONSECUTIVODIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVODIAN), '%')) AND (CASE WHEN RESOLUCIONDIAN IS NULL THEN ' ' ELSE UPPER(RESOLUCIONDIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:RESOLUCIONDIAN), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PREFIJODIAN" sqlType="STRING"/>
		<param name="CONSECUTIVODIAN" sqlType="STRING"/>
		<param name="RESOLUCIONDIAN" sqlType="STRING"/>

	</query>
