ION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN VLRAGIRAR IS NULL THEN ' ' ELSE UPPER(VLRAGIRAR) END) LIKE UPPER(CONCAT(:VLRAGIRAR, '%')) AND (CASE WHEN PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PROGRAMADO) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMADO), '%')) AND (CASE WHEN FECHAPROGPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPROGPAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAPROGPAGO), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN FECHARECEPCION IS NULL THEN ' ' ELSE UPPER(FECHARECEPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHARECEPCION), '%')) ) A) FIN</sql>
