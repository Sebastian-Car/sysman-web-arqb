	<query id="getComprobantescntNumJoinTerceroYTipocomprobantePorAnioYMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, CONCAT(CONCAT(TIPO, ' - '), TIPO_COMPROBANTE.NOMBRE) TIPOYNOMBRE,(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_CNT.VLRAGIRAR, COMPROBANTE_CNT.DEBITOSAFECTADOS, COMPROBANTE_CNT.CREDITOSAFECTADOS, COMPROBANTE_CNT.ABONADO, TERCERO.NOMBRE NOMBRETERCERO,(TO_CHAR(COMPROBANTE_CNT.FECHA_ABONO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ABONO, COMPROBANTE_CNT.USUARIO_ABONO, CASE WHEN VLRAGIRAR - DEBITOSAFECTADOS &gt; 0 THEN VLRAGIRAR -DEBITOSAFECTADOS - ABONADO ELSE 0 END SALDOT,(TO_CHAR(COMPROBANTE_CNT.FECHAPAGADOGN,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGADOGN,(CASE COMPROBANTE_CNT.IND_PAGADO WHEN 0 THEN 'false' ELSE 'true' END) IND_PAGADO FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO AND COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA INNER JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANIO AND COMPROBANTE_CNT.MES = :MES AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ('P') ORDER BY COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN TIPOYNOMBRE IS NULL THEN ' ' ELSE UPPER(TIPOYNOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOYNOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VLRAGIRAR IS NULL THEN ' ' ELSE UPPER(VLRAGIRAR) END) LIKE UPPER(CONCAT(:VLRAGIRAR, '%')) AND (CASE WHEN DEBITOSAFECTADOS IS NULL THEN ' ' ELSE UPPER(DEBITOSAFECTADOS) END) LIKE UPPER(CONCAT(:DEBITOSAFECTADOS, '%')) AND (CASE WHEN CREDITOSAFECTADOS IS NULL THEN ' ' ELSE UPPER(CREDITOSAFECTADOS) END) LIKE UPPER(CONCAT(:CREDITOSAFECTADOS, '%')) AND (CASE WHEN ABONADO IS NULL THEN ' ' ELSE UPPER(ABONADO) END) LIKE UPPER(CONCAT(:ABONADO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(:NOMBRETERCERO, '%')) AND (CASE WHEN FECHA_ABONO IS NULL THEN ' ' ELSE UPPER(FECHA_ABONO) END) LIKE UPPER(CONCAT(:FECHA_ABONO, '%')) AND (CASE WHEN USUARIO_ABONO IS NULL THEN ' ' ELSE UPPER(USUARIO_ABONO) END) LIKE UPPER(CONCAT(CONCAT('%',:USUARIO_ABONO), '%')) AND (CASE WHEN SALDOT IS NULL THEN ' ' ELSE UPPER(SALDOT) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDOT), '%')) AND (CASE WHEN FECHAPAGADOGN IS NULL THEN ' ' ELSE UPPER(FECHAPAGADOGN) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAPAGADOGN), '%')) AND (CASE WHEN IND_PAGADO IS NULL THEN ' ' ELSE UPPER(IND_PAGADO) END) LIKE UPPER(CONCAT(CONCAT('%',:IND_PAGADO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
