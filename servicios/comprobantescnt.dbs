	<query id="insertComprobantescntCorpoboyacaServicio" keyColumns="COMPANIA,ANO,TIPO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPROBANTE_CNT (COMPANIA, ANO, TIPO, NUMERO, FECHA, TERCERO, SUCURSAL, DESCRIPCION, FECHA_VCN_DOC, VLR_DOCUMENTO, DEBITO, CREDITO, VLRAGIRAR, TEXTO, FECHAPAGADOGN, NRO_DOCUMENTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO, :NUMERO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :TERCERO, :SUCURSAL, :DESCRIPCION, TO_DATE(:FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS'), :VLR_DOCUMENTO, :DEBITO, :CREDITO, :VLRAGIRAR, :TEXTO, TO_DATE(:FECHAPAGADOGN,'DD/MM/YYYY HH24:MI:SS'), :NRO_DOCUMENTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
