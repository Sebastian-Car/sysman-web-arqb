	<query id="getComprobantescntTodosEntreTercerosYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPO, NUMERO, ANO, TO_CHAR(FECHA_VCN_DOC,'DD/MM/YYYY')FECHA_VCN_DOC, VLR_DOCUMENTO, SUCURSAL, TERCERO, VLRAGIRAR, TO_CHAR(FECHA,'DD/MM/YYYY') FECHA FROM COMPROBANTE_CNT WHERE COMPANIA =:COMPANIA AND TIPO = CASE WHEN :TIPO IS NOT NULL THEN :TIPO ELSE TIPO END AND CONCAT(TERCERO,SUCURSAL) BETWEEN CONCAT(:TERCEROI,:SUCURSALI) AND CONCAT(:TERCEROF,:SUCURSALF)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","ANO":"$ANO(type:integer)","FECHA_VCN_DOC":"$FECHA_VCN_DOC","VLR_DOCUMENTO":"$VLR_DOCUMENTO","SUCURSAL":"$SUCURSAL","TERCERO":"$TERCERO","VLRAGIRAR":"$VLRAGIRAR","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TERCEROI" sqlType="STRING"/>
		<param name="SUCURSALI" sqlType="STRING"/>
		<param name="TERCEROF" sqlType="STRING"/>
		<param name="SUCURSALF" sqlType="STRING"/>

