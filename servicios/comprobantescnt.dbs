	<query id="getComprobantescntPagGetnumcomprobanteiniegrQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA, 'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.TERCERO, TERCERO.NOMBRE, COMPROBANTE_CNT.VLR_DOCUMENTO FROM COMPROBANTE_CNT INNER JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TIPO_COMPROBANTE T ON ( COMPROBANTE_CNT.COMPANIA = T.COMPANIA AND COMPROBANTE_CNT.TIPO = T.CODIGO) WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.NRO_DOCUMENTO BETWEEN :CHEQUE_I AND :CHEQUE_F AND COMPROBANTE_CNT.FECHA BETWEEN :FECHAINICIAL AND :FECHAFINAL AND T.CLASE_CONTABLE = 'E' AND COMPROBANTE_CNT.GIROELECTRONICO NOT IN (0) ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.FECHA) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:VLR_DOCUMENTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","TERCERO":"$TERCERO","NOMBRE":"$NOMBRE","VLR_DOCUMENTO":"$VLR_DOCUMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CHEQUE_I" sqlType="STRING"/>
		<param name="CHEQUE_F" sqlType="STRING"/>
