<query id="getComprobantescntAlertacorreoanticipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT C.COMPANIA, C.ANO, C.TIPO, C.NUMERO, C.TERCERO, C.SUCURSAL, C.DESCRIPCION,TO_CHAR(C.FECHA_VCN_DOC,'DD/MM/YYYY') FECHA_VCN_DOC, TO_CHAR(C.FECHA,'DD/MM/YYYY')FECHA, T.DIRECCIONEMAIL,T.NOMBRE, C.VLR_DOCUMENTO FROM COMPROBANTE_CNT C INNER JOIN TERCERO T ON C.COMPANIA = T.COMPANIA AND C.TERCERO = T.NIT AND C.SUCURSAL = T.SUCURSAL WHERE C.COMPANIA = :COMPANIA AND C.TIPO IN ('ANT') AND C.LEGALIZADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","DESCRIPCION":"$DESCRIPCION","FECHA_VCN_DOC":"$FECHA_VCN_DOC","FECHA":"$FECHA","DIRECCIONEMAIL":"$DIRECCIONEMAIL","NOMBRE":"$NOMBRE","VLR_DOCUMENTO":"$VLR_DOCUMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/alertacorreoanticipo">
		<call-query href="getComprobantescntAlertacorreoanticipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
