	<query id="getComprobantescntNumFiltrarordenpagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.DESCRIPCION, (CASE WHEN COMPRELACIONADO = 'P' THEN (VLRAGIRAR - (DEBITOSAFECTADOS + CREDITOSAFECTADOS + ABONADO)) ELSE VLRAGIRAR END) AS SALDO, COMPROBANTE_CNT.NOMBRE_PROYECTO, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TIPOCONTRATO, COMPROBANTE_CNT.NUMEROCONTRATO , COMPROBANTE_CNT.TEXTO, TO_CHAR(COMPROBANTE_CNT.VLRAGIRAR, '999,999,999,999,999,999.99') VALOR, COMPROBANTE_CNT.NRO_DOCUMENTO, COMPROBANTE_CNT.COD_PROYECTO, TIPO_COMPROBANTE.CLASE_CONTABLE FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND TIPO_COMPROBANTE.CLASE_CONTABLE = :COMPRELACIONADO AND COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY') AND COMPROBANTE_CNT.ANO BETWEEN 1 AND :ANOCOMPROBANTE AND CASE WHEN COMPRELACIONADO = 'P' THEN (VLRAGIRAR - (DEBITOSAFECTADOS + CREDITOSAFECTADOS + ABONADO)) ELSE VLRAGIRAR END &gt; 0 AND TIPODEPRESUPUESTO IS NOT NULL AND REGISTRO IS NOT NULL ORDER BY COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN NOMBRE_PROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROYECTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="COMPRELACIONADO" sqlType="STRING"/>
