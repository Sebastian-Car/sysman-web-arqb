	<query id="getComprobantescntPagTodosPorNumeroTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.TIPO FROM COMPROBANTE_CNT LEFT JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO AND COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA WHERE COMPROBANTE_CNT.COMPANIA =:COMPANIA AND COMPROBANTE_CNT.TIPO = :TIPOS AND COMPROBANTE_CNT.ANO = :ANIO AND TIPO_COMPROBANTE.CLASE_CONTABLE = 'P' ORDER BY COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOS" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
