	<query id="updateComprobantescntFechaUsuarioYAbono" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET ABONADO=:ABONADO, FECHA_ABONO=TO_DATE(:FECHA_ABONO,'DD/MM/YYYY HH24:MI:SS'), USUARIO_ABONO=:USUARIO_ABONO, FECHAPAGADOGN=TO_DATE(:FECHAPAGADOGN,'DD/MM/YYYY HH24:MI:SS'), IND_PAGADO=:IND_PAGADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_CNT.ANO= :KEY_ANO AND COMPROBANTE_CNT.TIPO= :KEY_TIPO AND COMPROBANTE_CNT.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

