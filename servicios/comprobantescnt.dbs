	<query id="getComprobantescntPagComprobantepptalmasivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.DESCRIPCION FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON TIPO_COMPROBANTE.COMPANIA = COMPROBANTE_CNT.COMPANIA AND TIPO_COMPROBANTE.CODIGO = COMPROBANTE_CNT.TIPO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.MES = :MES AND COMPROBANTE_CNT.TIPO = :TIPO AND TIPO_COMPROBANTE.GENERA_CTE_PPTAL_MASIVO &lt;&gt; 0 ORDER BY COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
