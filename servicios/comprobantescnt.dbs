	<query id="updateComprobantescnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET TIPOPAGO_SIA=:TIPOPAGO_SIA, HORA=TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), SUCURSAL=:SUCURSAL, VLR_BASEIVA=:VLR_BASEIVA, PAGOAPODERADO=:PAGOAPODERADO, PAGO_EFECTIVO=:PAGO_EFECTIVO, FECHAINHUMACION=TO_DATE(:FECHAINHUMACION,'DD/MM/YYYY HH24:MI:SS'), BANCO=:BANCO, DESCRIPCION=:DESCRIPCION, TEXTO=:TEXTO, VLR_DOCUMENTO=:VLR_DOCUMENTO, PAGOENPLANO=:PAGOENPLANO, TERCERO=:TERCERO, ENTREGADO=:ENTREGADO, ENVIADO=:ENVIADO, FECHA_VCN_DOC=TO_DATE(:FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, CONTRIBUYENTE=:CONTRIBUYENTE, REFERENCIA=:REFERENCIA, CENTRO_COSTO=:CENTRO_COSTO, COD_PROYECTO=:COD_PROYECTO, CONCEPTO_SF=:CONCEPTO_SF, AUXILIAR=:AUXILIAR, GIROELECTRONICO=:GIROELECTRONICO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), PORCIVA=:PORCIVA, TIPOPAGO=:TIPOPAGO, CUENTA=:CUENTA, VLRAGIRAR=:VLRAGIRAR, CEDULAINHUMACION=:CEDULAINHUMACION, NRO_DOCUMENTO=:NRO_DOCUMENTO, FECHAPAGADOGN=TO_DATE(:FECHAPAGADOGN,'DD/MM/YYYY HH24:MI:SS'), ORDENADOR=:ORDENADOR, NUMEROCONTRATO=:NUMEROCONTRATO, NONIIF=:NONIIF, PAGADOGN=:PAGADOGN, IMPRESO=:IMPRESO, VLR_BASE=:VLR_BASE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CODI_SIA=:CODI_SIA, DEPENDENCIACNT=:DEPENDENCIACNT, IND_ANTICIPO=:IND_ANTICIPO, ORDENADORSUCURSAL=:ORDENADORSUCURSAL, TIPOCONTRATO=:TIPOCONTRATO, CUENTABANCO=:CUENTABANCO, TIPO_CAJA=:TIPO_CAJA, CODIGO_FLUJO_EFECTIVO=:CODIGO_FLUJO_EFECTIVO, PLANO_NOMINA=:PLANO_NOMINA, INFORMECOVID=:INFORMECOVID, FECHACONSIGNACION=TO_DATE(:FECHACONSIGNACION,'DD/MM/YYYY HH24:MI:SS'), CONSFACTURA=:CONSFACTURA, LEGALIZADO=:LEGALIZADO, TIPO_SIGEC=:TIPO_SIGEC, FECHA_FIRME=TO_DATE(:FECHA_FIRME,'DD/MM/YYYY HH24:MI:SS') WHERE COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_CNT.ANO= :KEY_ANO AND COMPROBANTE_CNT.TIPO= :KEY_TIPO AND COMPROBANTE_CNT.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

