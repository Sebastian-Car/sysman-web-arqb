	<query id="getComprobantescntNumProgramacionpagosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO,(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_CNT.DESCRIPCION, TERCERO.NOMBRE, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.VLRAGIRAR,(CASE COMPROBANTE_CNT.PROGRAMADO WHEN 0 THEN 'false' ELSE 'true' END) PROGRAMADO,(TO_CHAR(COMPROBANTE_CNT.FECHAPROGPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPROGPAGO, VLRAGIRAR - ( CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS END ) SALDO,(TO_CHAR(COMPROBANTE_CNT.FECHARECEPCION,'DD/MM/YYYY HH24:MI:SS')) FECHARECEPCION FROM COMPROBANTE_CNT INNER JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO INNER JOIN ORDENADOR ON COMPROBANTE_CNT.COMPANIA = ORDENADOR.COMPANIA AND COMPROBANTE_CNT.ORDENADOR = ORDENADOR.CEDULA AND COMPROBANTE_CNT.ORDENADORSUCURSAL = ORDENADOR.SUCURSAL WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.MES = :MES AND VLRAGIRAR - ( CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS END ) + ABONADO &lt;&gt; 0 AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ( 'P' ) ORDER BY COMPROBANTE_CNT.FECHA DESC, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN VLRAGIRAR IS NULL THEN ' ' ELSE UPPER(VLRAGIRAR) END) LIKE UPPER(CONCAT(:VLRAGIRAR, '%')) AND (CASE WHEN PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PROGRAMADO) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMADO), '%')) AND (CASE WHEN FECHAPROGPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPROGPAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAPROGPAGO), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN FECHARECEPCION IS NULL THEN ' ' ELSE UPPER(FECHARECEPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHARECEPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="VLRAGIRAR" sqlType="STRING"/>
		<param name="PROGRAMADO" sqlType="STRING"/>
		<param name="FECHAPROGPAGO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="FECHARECEPCION" sqlType="STRING"/>

	</query>
