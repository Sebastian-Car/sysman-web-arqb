	<query id="updateComprobantescntSetupdateconseccomprcnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET PREFIJODIAN=:PREFIJODIAN, CONSECUTIVODIAN=:CONSECUTIVODIAN, RESOLUCIONDIAN=:RESOLUCIONDIAN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPROBANTE_CNT.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_CNT.ANO= :KEY_ANO AND COMPROBANTE_CNT.TIPO= :KEY_TIPO AND COMPROBANTE_CNT.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PREFIJODIAN" sqlType="STRING"/>
		<param name="CONSECUTIVODIAN" sqlType="STRING"/>
		<param name="RESOLUCIONDIAN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="comprobantescnt/setupdateconseccomprcnt">
		<call-query href="updateComprobantescntSetupdateconseccomprcnt">
			<with-param name="PREFIJODIAN" query-param="PREFIJODIAN"/>
			<with-param name="CONSECUTIVODIAN" query-param="CONSECUTIVODIAN"/>
			<with-param name="RESOLUCIONDIAN" query-param="RESOLUCIONDIAN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPagProgramacionpagosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO,(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_CNT.DESCRIPCION, TERCERO.NOMBRE, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.VLRAGIRAR,(CASE COMPROBANTE_CNT.PROGRAMADO WHEN 0 THEN 'false' ELSE 'true' END) PROGRAMADO,(TO_CHAR(COMPROBANTE_CNT.FECHAPROGPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPROGPAGO, VLRAGIRAR - ( CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS END ) SALDO,(TO_CHAR(COMPROBANTE_CNT.FECHARECEPCION,'DD/MM/YYYY HH24:MI:SS')) FECHARECEPCION FROM COMPROBANTE_CNT INNER JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO INNER JOIN ORDENADOR ON COMPROBANTE_CNT.COMPANIA = ORDENADOR.COMPANIA AND COMPROBANTE_CNT.ORDENADOR = ORDENADOR.CEDULA AND COMPROBANTE_CNT.ORDENADORSUCURSAL = ORDENADOR.SUCURSAL WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.MES = :MES AND VLRAGIRAR - ( CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS END ) + ABONADO &lt;&gt; 0 AND TIPO_COMPROBANTE.CLASE_CONTABLE IN ( 'P' ) ORDER BY COMPROBANTE_CNT.FECHA DESC, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN VLRAGIRAR IS NULL THEN ' ' ELSE UPPER(VLRAGIRAR) END) LIKE UPPER(CONCAT(:VLRAGIRAR, '%')) AND (CASE WHEN PROGRAMADO IS NULL THEN ' ' ELSE UPPER(PROGRAMADO) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMADO), '%')) AND (CASE WHEN FECHAPROGPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPROGPAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAPROGPAGO), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALDO), '%')) AND (CASE WHEN FECHARECEPCION IS NULL THEN ' ' ELSE UPPER(FECHARECEPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHARECEPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","NOMBRE":"$NOMBRE","VLR_DOCUMENTO":"$VLR_DOCUMENTO","VLRAGIRAR":"$VLRAGIRAR","PROGRAMADO":"$PROGRAMADO(type:boolean)","FECHAPROGPAGO":"$FECHAPROGPAGO","SALDO":"$SALDO","FECHARECEPCION":"$FECHARECEPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="VLRAGIRAR" sqlType="STRING"/>
		<param name="PROGRAMADO" sqlType="STRING"/>
		<param name="FECHAPROGPAGO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="FECHARECEPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
