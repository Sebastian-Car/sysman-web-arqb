		<sql>SELECT COMPROBANTE_CNT.TIPO TIPO_CPTE_AFECT FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND TIPO_COMPROBANTE.CLASE_CONTABLE = :COMPRELACIONADO AND COMPROBANTE_CNT.FECHA &lt;= TRUNC(TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY HH24:MI:SS')) AND COMPROBANTE_CNT.ANO BETWEEN 0 AND :ANOCOMPROBANTE AND VLRAGIRAR - CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS + ABONADO END &gt; 0 GROUP BY COMPROBANTE_CNT.TIPO ORDER BY COMPROBANTE_CNT.TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="COMPRELACIONADO" sqlType="STRING"/>
		<param name="FECHACOMPROBANTE" sqlType="STRING"/>
		<param name="ANOCOMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/todosporcompaniatipoafectado">
		<call-query href="getComprobantescntTodosPorCompaniaTipoAfectadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCEROCOMPROBANTE" query-param="TERCEROCOMPROBANTE"/>
			<with-param name="SUCURSALCOMPROBANTE" query-param="SUCURSALCOMPROBANTE"/>
			<with-param name="COMPRELACIONADO" query-param="COMPRELACIONADO"/>
			<with-param name="FECHACOMPROBANTE" query-param="FECHACOMPROBANTE"/>
			<with-param name="ANOCOMPROBANTE" query-param="ANOCOMPROBANTE"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPagTodosPorNumeroFechaComprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.NUMERO,(TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLRAGIRAR VALOR, (VLRAGIRAR-(DEBITOSAFECTADOS+CREDITOSAFECTADOS)) SALDO, COMPROBANTE_CNT.TEXTO, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.ANO FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND TIPO_COMPROBANTE.CLASE_CONTABLE = :COMPRELACIONADO AND COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY HH24:MI:SS') AND COMPROBANTE_CNT.ANO BETWEEN 0 AND :ANOCOMPROBANTE AND COMPROBANTE_CNT.TIPO =:TIPO AND VLRAGIRAR - CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS + ABONADO END &gt; 0 ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END) LIKE UPPER(CONCAT(:TEXTO, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","VALOR":"$VALOR","SALDO":"$SALDO","TEXTO":"$TEXTO","VLR_DOCUMENTO":"$VLR_DOCUMENTO","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="COMPRELACIONADO" sqlType="STRING"/>
		<param name="FECHACOMPROBANTE" sqlType="STRING"/>
		<param name="ANOCOMPROBANTE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
