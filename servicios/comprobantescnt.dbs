	<query id="updateComprobantescntDatosTerceroCesion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_CNT SET TERCERO_NSESION = :NITCESION , SUCURSAL_NSESION = :SUCURSALCESION , DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPOCONTRATO AND NUMEROCONTRATO = :NUMEROAFECTADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NITCESION" sqlType="STRING"/>
		<param name="SUCURSALCESION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROAFECTADO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="comprobantescnt/datostercerocesion">
		<call-query href="updateComprobantescntDatosTerceroCesion">
