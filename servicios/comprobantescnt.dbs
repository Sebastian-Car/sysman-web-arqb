	<query id="getComprobantescntPagTipocpteafectvQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA,'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TIPOCONTRATO, NVL(COMPROBANTE_CNT.NUMEROCONTRATO,0) NUMEROCONTRATO, COMPROBANTE_CNT.TEXTO, TO_CHAR(COMPROBANTE_CNT.VLRAGIRAR, '999,999,999,999,999,999.99') VALOR, COMPROBANTE_CNT.COD_PROYECTO, COMPROBANTE_CNT.NRO_DOCUMENTO FROM COMPROBANTE_CNT INNER JOIN DETALLE_COMPROBANTE_CNT ON COMPROBANTE_CNT.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND COMPROBANTE_CNT.TIPO = DETALLE_COMPROBANTE_CNT.TIPO_CPTE AND COMPROBANTE_CNT.ANO = DETALLE_COMPROBANTE_CNT.ANO AND COMPROBANTE_CNT.NUMERO = DETALLE_COMPROBANTE_CNT.COMPROBANTE INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND TIPO_COMPROBANTE.CLASE_CONTABLE = :COMPRELACIONADO AND COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY') AND DETALLE_COMPROBANTE_CNT.VALOR_DEBITO &gt; 0 GROUP BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.FECHA, COMPROBANTE_CNT.DESCRIPCION, COMPROBANTE_CNT.VLRAGIRAR, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPOCONTRATO, COMPROBANTE_CNT.NUMEROCONTRATO, COMPROBANTE_CNT.TEXTO, COMPROBANTE_CNT.COD_PROYECTO, COMPROBANTE_CNT.NRO_DOCUMENTO HAVING SUM((VALOR_DEBITO + VALOR_CREDITO) - (DEBITO_AFECTADO + CREDITO_AFECTADO) - ABONOINICIAL) &gt; 0) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO(type:integer)","TEXTO":"$TEXTO","VALOR":"$VALOR","COD_PROYECTO":"$COD_PROYECTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="COMPRELACIONADO" sqlType="STRING"/>
		<param name="FECHACOMPROBANTE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
