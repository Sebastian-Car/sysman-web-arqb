	<query id="getComprobantescntGetpagosbancodeoccidenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) OVER() AS TOTAL_REGISTROS, SUM(VALORTRANSACCION) OVER() AS VALOR_TOTAL, CUENTAORIGEN, ANOPAGO, MESPAGO, DIAPAGO, NOMBREBENEFICIARIO, NIT, COMPROBANTE, FORMA_PAGO, VALORTRANSACCION, TEXTO, BANCODESTINO, CUENTADESTINO, TIPO_CUENTA FROM ( SELECT NVL(CUENTABANCOS.CUENTANUMERO,'0') CUENTAORIGEN, EXTRACT(YEAR FROM COMPROBANTE_CNT.FECHAPAGADOGN) ANOPAGO, EXTRACT(MONTH FROM COMPROBANTE_CNT.FECHAPAGADOGN) MESPAGO, EXTRACT(DAY FROM COMPROBANTE_CNT.FECHAPAGADOGN) DIAPAGO, CASE WHEN NVL( COMPROBANTE_CNT.PAGOAPODERADO, 0 ) NOT IN ( 0 ) THEN APODERADO.NOMBRE ELSE TERCERO.NOMBRE END AS NOMBREBENEFICIARIO, CASE WHEN NVL( COMPROBANTE_CNT.PAGOAPODERADO, 0 ) NOT IN ( 0 ) THEN APODERADO.NIT ELSE TERCERO.NIT END AS NIT, COMPROBANTE_CNT.NUMERO COMPROBANTE, CASE WHEN NVL( PAGO_EFECTIVO, 0 ) &lt;&gt; 0 THEN '4' ELSE CASE WHEN NRO_DOCUMENTO IS NOT NULL THEN '1' ELSE CASE WHEN COMPROBANTE_CNT.BANCO IN ( '23' ) THEN '2' ELSE '3' END END END AS FORMA_PAGO, COMPROBANTE_CNT.VLRAGIRAR VALORTRANSACCION, NVL(COMPROBANTE_CNT.TEXTO,' ') TEXTO, NVL(COMPROBANTE_CNT.BANCO,' ') BANCODESTINO, NVL(COMPROBANTE_CNT.CUENTABANCO, ' ') CUENTADESTINO, NVL(TERCEROPAGOS.TIPOCUENTA, ' ') TIPO_CUENTA FROM CUENTABANCOS LEFT JOIN ( ( COMPROBANTE_CNT LEFT JOIN TERCERO ON COMPROBANTE_CNT.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_CNT.TERCERO = TERCERO.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN TERCERO APODERADO ON TERCERO.COMPANIA = APODERADO.COMPANIA AND TERCERO.NITAPODERADO = APODERADO.NIT AND TERCERO.SUCURSALAPODERADO = APODERADO.SUCURSAL ) LEFT JOIN TERCEROPAGOS ON COMPROBANTE_CNT.TERCERO = TERCEROPAGOS.NIT AND COMPROBANTE_CNT.SUCURSAL = TERCEROPAGOS.SUCURSAL AND COMPROBANTE_CNT.COMPANIA = TERCEROPAGOS.COMPANIA AND COMPROBANTE_CNT.BANCO = TERCEROPAGOS.BANCO AND COMPROBANTE_CNT.CUENTABANCO = TERCEROPAGOS.CUENTA ) ON CUENTABANCOS.IDCONTABLE = COMPROBANTE_CNT.CUENTA AND CUENTABANCOS.ANO = COMPROBANTE_CNT.ANO AND CUENTABANCOS.COMPANIA = COMPROBANTE_CNT.COMPANIA WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.ANO = :ANO AND COMPROBANTE_CNT.TIPO = :TIPOEGRESO AND COMPROBANTE_CNT.CUENTA BETWEEN :CUENTAINICIAL AND :CUENTAFINAL AND COMPROBANTE_CNT.NUMERO BETWEEN :EGRESOINICIAL AND :EGRESOFINAL AND COMPROBANTE_CNT.TERCERO BETWEEN :TERCEROINICIAL AND :TERCEROFINAL AND COMPROBANTE_CNT.FECHAPAGADOGN = TO_DATE(:FECHA,'DD/MM/YYYY') AND COMPROBANTE_CNT.PAGOENPLANO NOT IN ( 0 ) AND COMPROBANTE_CNT.ENVIADO IN ( 0 ) ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_REGISTROS":"$TOTAL_REGISTROS(type:integer)","VALOR_TOTAL":"$VALOR_TOTAL(type:double)","CUENTAORIGEN":"$CUENTAORIGEN","ANOPAGO":"$ANOPAGO(type:integer)","MESPAGO":"$MESPAGO(type:integer)","DIAPAGO":"$DIAPAGO(type:integer)","NOMBREBENEFICIARIO":"$NOMBREBENEFICIARIO","NIT":"$NIT","COMPROBANTE":"$COMPROBANTE(type:long)","FORMA_PAGO":"$FORMA_PAGO","VALORTRANSACCION":"$VALORTRANSACCION","TEXTO":"$TEXTO","BANCODESTINO":"$BANCODESTINO","CUENTADESTINO":"$CUENTADESTINO","TIPO_CUENTA":"$TIPO_CUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOEGRESO" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="CUENTAFINAL" sqlType="STRING"/>
		<param name="EGRESOINICIAL" sqlType="STRING"/>
		<param name="EGRESOFINAL" sqlType="STRING"/>
		<param name="TERCEROINICIAL" sqlType="STRING"/>
		<param name="TERCEROFINAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantescnt/getpagosbancodeoccidente">
		<call-query href="getComprobantescntGetpagosbancodeoccidenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOEGRESO" query-param="TIPOEGRESO"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="CUENTAFINAL" query-param="CUENTAFINAL"/>
			<with-param name="EGRESOINICIAL" query-param="EGRESOINICIAL"/>
			<with-param name="EGRESOFINAL" query-param="EGRESOFINAL"/>
			<with-param name="TERCEROINICIAL" query-param="TERCEROINICIAL"/>
			<with-param name="TERCEROFINAL" query-param="TERCEROFINAL"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getComprobantescntPagConsultalistaanticipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.ANO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO, TO_CHAR(COMPROBANTE_CNT.FECHA, 'DD/MM/YYYY') FECHA, COMPROBANTE_CNT.DESCRIPCION, VLRAGIRAR - ( CASE WHEN DEBITOSAFECTADOS &gt; 0 AND DEBITOSAFECTADOS = CREDITOSAFECTADOS THEN DEBITOSAFECTADOS ELSE DEBITOSAFECTADOS - CREDITOSAFECTADOS + ABONADO END ) AS SALDO, COMPROBANTE_CNT.NOMBRE_PROYECTO, COMPROBANTE_CNT.VLR_DOCUMENTO, COMPROBANTE_CNT.TIPOCONTRATO, COMPROBANTE_CNT.NUMEROCONTRATO, COMPROBANTE_CNT.TEXTO, TO_CHAR(COMPROBANTE_CNT.VLRAGIRAR, '999,999,999,999,999,999.99') VALOR, COMPROBANTE_CNT.NRO_DOCUMENTO, COMPROBANTE_CNT.COD_PROYECTO FROM COMPROBANTE_CNT INNER JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO WHERE COMPROBANTE_CNT.COMPANIA = :COMPANIA AND COMPROBANTE_CNT.TERCERO = :TERCEROCOMPROBANTE AND COMPROBANTE_CNT.SUCURSAL = :SUCURSALCOMPROBANTE AND COMPROBANTE_CNT.FECHA &lt;= TO_DATE(:FECHACOMPROBANTE, 'DD/MM/YYYY') AND COMPROBANTE_CNT.ANO BETWEEN 0 AND :ANOCOMPROBANTE AND VLRAGIRAR - ( ( DEBITOSAFECTADOS - CREDITOSAFECTADOS ) + ABONADO ) &gt; 0 AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:COMPRELACIONADO, ' ', '')), CONCAT('', CONCAT(TO_CHAR(TIPO_COMPROBANTE.TIPO_ANTICIPO ), '')), 1) &gt; 0 AND COMPROBANTE_CNT.IND_ANTICIPO NOT IN (0) ORDER BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.NUMERO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN NOMBRE_PROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROYECTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","SALDO":"$SALDO(type:integer)","NOMBRE_PROYECTO":"$NOMBRE_PROYECTO","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO(type:long)","TEXTO":"$TEXTO","VALOR":"$VALOR","NRO_DOCUMENTO":"$NRO_DOCUMENTO","COD_PROYECTO":"$COD_PROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="FECHACOMPROBANTE" sqlType="STRING"/>
		<param name="ANOCOMPROBANTE" sqlType="STRING"/>
		<param name="COMPRELACIONADO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
