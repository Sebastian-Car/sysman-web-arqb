<data name="nivelesagrupamiento" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNivelesagrupamiento" keyColumns="COMPANIA,MODULO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NIVEL_AGRUPAMIENTO (COMPANIA, MODULO, CODIGO, NOMBRE, DOMINIO, ES_ARCHIVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :MODULO, :CODIGO, :NOMBRE, :DOMINIO, :ES_ARCHIVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_MODULO":"$MODULO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DOMINIO" sqlType="STRING"/>
		<param defaultValue="0" name="ES_ARCHIVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="nivelesagrupamiento">
		<call-query href="insertNivelesagrupamiento">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DOMINIO" query-param="DOMINIO"/>
			<with-param name="ES_ARCHIVO" query-param="ES_ARCHIVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNivelesagrupamiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NIVEL_AGRUPAMIENTO WHERE NIVEL_AGRUPAMIENTO.COMPANIA= :KEY_COMPANIA AND NIVEL_AGRUPAMIENTO.MODULO= :KEY_MODULO AND NIVEL_AGRUPAMIENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODULO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="nivelesagrupamiento">
		<call-query href="deleteNivelesagrupamiento">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MODULO" query-param="KEY_MODULO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getNivelesagrupamientoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, MODULO, CODIGO, NOMBRE ,DOMINIO,(CASE ES_ARCHIVO WHEN 0 THEN 'false' ELSE 'true' END) ES_ARCHIVO FROM NIVEL_AGRUPAMIENTO WHERE COMPANIA = :COMPANIA AND MODULO = :MODULO ORDER BY TO_NUMBER(CODIGO)) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DOMINIO IS NULL THEN ' ' ELSE UPPER(DOMINIO) END) LIKE UPPER(CONCAT(CONCAT('%',:DOMINIO), '%')) AND (CASE WHEN ES_ARCHIVO IS NULL THEN ' ' ELSE UPPER(ES_ARCHIVO) END) LIKE UPPER(CONCAT(:ES_ARCHIVO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","MODULO":"$MODULO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DOMINIO":"$DOMINIO","ES_ARCHIVO":"$ES_ARCHIVO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DOMINIO" sqlType="STRING"/>
		<param name="ES_ARCHIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nivelesagrupamiento">
		<call-query href="getNivelesagrupamientoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DOMINIO" query-param="DOMINIO"/>
			<with-param name="ES_ARCHIVO" query-param="ES_ARCHIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNivelesagrupamientoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, MODULO, CODIGO, NOMBRE ,DOMINIO,(CASE ES_ARCHIVO WHEN 0 THEN 'false' ELSE 'true' END) ES_ARCHIVO FROM NIVEL_AGRUPAMIENTO WHERE COMPANIA = :COMPANIA AND MODULO = :MODULO ORDER BY TO_NUMBER(CODIGO)) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DOMINIO IS NULL THEN ' ' ELSE UPPER(DOMINIO) END) LIKE UPPER(CONCAT(CONCAT('%',:DOMINIO), '%')) AND (CASE WHEN ES_ARCHIVO IS NULL THEN ' ' ELSE UPPER(ES_ARCHIVO) END) LIKE UPPER(CONCAT(:ES_ARCHIVO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DOMINIO" sqlType="STRING"/>
		<param name="ES_ARCHIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nivelesagrupamiento/numero">
		<call-query href="getNivelesagrupamientoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DOMINIO" query-param="DOMINIO"/>
			<with-param name="ES_ARCHIVO" query-param="ES_ARCHIVO"/>

		</call-query>
	</resource>
	<query id="updateNivelesagrupamiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NIVEL_AGRUPAMIENTO SET MODULO=:MODULO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, DOMINIO=:DOMINIO, ES_ARCHIVO=:ES_ARCHIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NIVEL_AGRUPAMIENTO.COMPANIA= :KEY_COMPANIA AND NIVEL_AGRUPAMIENTO.MODULO= :KEY_MODULO AND NIVEL_AGRUPAMIENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODULO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DOMINIO" sqlType="STRING"/>
		<param name="ES_ARCHIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_MODULO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="nivelesagrupamiento">
		<call-query href="updateNivelesagrupamiento">
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DOMINIO" query-param="DOMINIO"/>
			<with-param name="ES_ARCHIVO" query-param="ES_ARCHIVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_MODULO" query-param="KEY_MODULO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>