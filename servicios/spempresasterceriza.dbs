<data name="spempresasterceriza" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpempresastercerizaPagNombreporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EMPRESAS_TER.ID, EMPRESAS_TER.NOMBRE, EMPRESAS_TER.NIT  FROM SP_EMPRESAS_TERCERIZA EMPRESAS_TER WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","NIT":"$NIT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spempresasterceriza/nombreporcompania/pag">
		<call-query href="getSpempresastercerizaPagNombreporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaNumNombreporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EMPRESAS_TER.ID, EMPRESAS_TER.NOMBRE, EMPRESAS_TER.NIT  FROM SP_EMPRESAS_TERCERIZA EMPRESAS_TER WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/nombreporcompania/num">
		<call-query href="getSpempresastercerizaNumNombreporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaPagPorCompaniaNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID,NIT,NOMBRE  FROM SP_EMPRESAS_TERCERIZA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spempresasterceriza/porcompanianombre/pag">
		<call-query href="getSpempresastercerizaPagPorCompaniaNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaNumPorCompaniaNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID,NIT,NOMBRE  FROM SP_EMPRESAS_TERCERIZA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/porcompanianombre/num">
		<call-query href="getSpempresastercerizaNumPorCompaniaNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaTodasPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID, NOMBRE  FROM SP_EMPRESAS_TERCERIZA WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/todasporcompania">
		<call-query href="getSpempresastercerizaTodasPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaIdnombretporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  EMPRESAS_TER.ID, EMPRESAS_TER.NOMBRE  FROM SP_EMPRESAS_TERCERIZA EMPRESAS_TER WHERE COMPANIA = :COMPANIA UNION SELECT 'T', 'TODAS' FROM DUAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/idnombretporcompania">
		<call-query href="getSpempresastercerizaIdnombretporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaTodasPorIdYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'T' ID, 'Todas' NOMBRE  FROM COMPANIA WHERE CODIGO = :COMPANIA UNION ALL SELECT SP_EMPRESAS_TERCERIZA.ID, SP_EMPRESAS_TERCERIZA.NOMBRE FROM SP_EMPRESAS_TERCERIZA WHERE SP_EMPRESAS_TERCERIZA.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/todasporidynombre">
		<call-query href="getSpempresastercerizaTodasPorIdYNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaTodasPorNitQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID, NIT, NOMBRE  FROM SP_EMPRESAS_TERCERIZA WHERE COMPANIA=:COMPANIA AND NIT =:NIT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/todaspornit">
		<call-query href="getSpempresastercerizaTodasPorNitQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>

		</call-query>
	</resource>
	<query id="insertSpempresasterceriza" keyColumns="ID,COMPANIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_EMPRESAS_TERCERIZA (COMPANIA, ID, NIT, DV, NOMBRE, SIGLA, UBICACION, CODIGO_EAN, LOGO, DATE_CREATED, CREATED_BY, ANO, SUCURSAL) VALUES (:COMPANIA, :ID, :NIT, :DV, :NOMBRE, :SIGLA, :UBICACION, :CODIGO_EAN, :LOGO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, :ANO, :SUCURSAL)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ID":"$ID","KEY_COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param defaultValue="" name="DV" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="SIGLA" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_EAN" sqlType="STRING"/>
		<param defaultValue="" name="LOGO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spempresasterceriza">
		<call-query href="insertSpempresasterceriza">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="DV" query-param="DV"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="CODIGO_EAN" query-param="CODIGO_EAN"/>
			<with-param name="LOGO" query-param="LOGO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="deleteSpempresasterceriza" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_EMPRESAS_TERCERIZA WHERE SP_EMPRESAS_TERCERIZA.ID= :KEY_ID AND SP_EMPRESAS_TERCERIZA.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spempresasterceriza">
		<call-query href="deleteSpempresasterceriza">
			<with-param name="KEY_ID" query-param="KEY_ID"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_EMPRESAS_TERCERIZA.COMPANIA, SP_EMPRESAS_TERCERIZA.ID, SP_EMPRESAS_TERCERIZA.NIT, SP_EMPRESAS_TERCERIZA.NOMBRE  FROM SP_EMPRESAS_TERCERIZA WHERE COMPANIA =:COMPANIA) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spempresasterceriza">
		<call-query href="getSpempresastercerizaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_EMPRESAS_TERCERIZA.COMPANIA, SP_EMPRESAS_TERCERIZA.ID, SP_EMPRESAS_TERCERIZA.NIT, SP_EMPRESAS_TERCERIZA.NOMBRE  FROM SP_EMPRESAS_TERCERIZA WHERE COMPANIA =:COMPANIA) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/numero">
		<call-query href="getSpempresastercerizaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpempresastercerizaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_EMPRESAS_TERCERIZA.COMPANIA, SP_EMPRESAS_TERCERIZA.ID, SP_EMPRESAS_TERCERIZA.NIT, SP_EMPRESAS_TERCERIZA.DV, SP_EMPRESAS_TERCERIZA.NOMBRE, SP_EMPRESAS_TERCERIZA.SIGLA, SP_EMPRESAS_TERCERIZA.UBICACION, SP_EMPRESAS_TERCERIZA.CODIGO_EAN, SP_EMPRESAS_TERCERIZA.LOGO,(TO_CHAR(SP_EMPRESAS_TERCERIZA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_EMPRESAS_TERCERIZA.CREATED_BY,(TO_CHAR(SP_EMPRESAS_TERCERIZA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SP_EMPRESAS_TERCERIZA.MODIFIED_BY  FROM SP_EMPRESAS_TERCERIZA WHERE SP_EMPRESAS_TERCERIZA.ID= :KEY_ID AND SP_EMPRESAS_TERCERIZA.COMPANIA= :KEY_COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","NIT":"$NIT","DV":"$DV(type:long)","NOMBRE":"$NOMBRE","SIGLA":"$SIGLA","UBICACION":"$UBICACION","CODIGO_EAN":"$CODIGO_EAN","LOGO":"$LOGO","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spempresasterceriza/data">
		<call-query href="getSpempresastercerizaRegistroQuery">
			<with-param name="KEY_ID" query-param="KEY_ID"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateSpempresasterceriza" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_EMPRESAS_TERCERIZA SET NIT=:NIT, DV=:DV, NOMBRE=:NOMBRE, SIGLA=:SIGLA, UBICACION=:UBICACION, CODIGO_EAN=:CODIGO_EAN, LOGO=:LOGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_EMPRESAS_TERCERIZA.ID= :KEY_ID AND SP_EMPRESAS_TERCERIZA.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NIT" sqlType="STRING"/>
		<param name="DV" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="CODIGO_EAN" sqlType="STRING"/>
		<param name="LOGO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spempresasterceriza">
		<call-query href="updateSpempresasterceriza">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="DV" query-param="DV"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="CODIGO_EAN" query-param="CODIGO_EAN"/>
			<with-param name="LOGO" query-param="LOGO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>

</data>