	<query id="getOrdenescompraPagPortipocontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, TIPOORDENDECOMPRA.NOMBRE  FROM ORDENDECOMPRA LEFT JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.NUMERO BETWEEN :TIPOCONTRATOINICIAL AND 9999999999999999 UNION SELECT 9999999999999999 NUMERO, '9999999999999999' NOMBRE FROM DUAL ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
