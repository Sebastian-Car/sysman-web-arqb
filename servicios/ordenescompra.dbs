	<query id="updateOrdenescompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET SUCURSAL=:SUCURSAL, CONVENIO=:CONVENIO, NUMPERSONASCONTRATADAS=:NUMPERSONASCONTRATADAS, TIPODIA=:TIPODIA, UNIDAD_PLAZO=:UNIDAD_PLAZO, FECHAADJUDICACION=TO_DATE(:FECHAADJUDICACION,'DD/MM/YYYY HH24:MI:SS'), VALORINTERVENCION=:VALORINTERVENCION, DESTINO=:DESTINO, TIPOINTERVENTOR=:TIPOINTERVENTOR, FECHAEVALUACION=TO_DATE(:FECHAEVALUACION,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, PORINPREVISTOS=:PORINPREVISTOS, ACTOAPERTURA=:ACTOAPERTURA, FORMADEPAGO=:FORMADEPAGO, ESTUDIOSPREVIOS=:ESTUDIOSPREVIOS, PROFESION=:PROFESION, APORTESEN=:APORTESEN, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TOPEVEHICULO=:TOPEVEHICULO, MONEDAREF=:MONEDAREF, INFORMESAUDITORIA=:INFORMESAUDITORIA, FECHARECPUBLIC=TO_DATE(:FECHARECPUBLIC,'DD/MM/YYYY HH24:MI:SS'), COMPONENTEBP=:COMPONENTEBP, CARGOINTERVENTOR=:CARGOINTERVENTOR, FUNCION=:FUNCION, FECHAAPERTURA=TO_DATE(:FECHAAPERTURA,'DD/MM/YYYY HH24:MI:SS'), FACULTADESCONTRATISTA=:FACULTADESCONTRATISTA, NUMEROCONTRATOINTERV=:NUMEROCONTRATOINTERV, CLASE_CONVENIO=:CLASE_CONVENIO, INTERVENTOR=:INTERVENTOR, OBLIGACIONC=:OBLIGACIONC, PLAZODEENTREGA=:PLAZODEENTREGA, CAPACIDADTOTALCONTRATACION=:CAPACIDADTOTALCONTRATACION, CODPAIS=:CODPAIS, NUM_CONVENIO=:NUM_CONVENIO, SUCURSALINTERVENTOR=:SUCURSALINTERVENTOR, SUCURSAL_ORDENADOR=:SUCURSAL_ORDENADOR, CEDULACONTRATISTA=:CEDULACONTRATISTA, TIPOCONTR_SECOP=:TIPOCONTR_SECOP, MONEDAPAGO=:MONEDAPAGO, FECHAPSUSPENSION=TO_DATE(:FECHAPSUSPENSION,'DD/MM/YYYY HH24:MI:SS'), CUMPLIMIENTO=:CUMPLIMIENTO, PORCDESCGLOBAL=:PORCDESCGLOBAL, NOTAS=:NOTAS, NROINVITACION=:NROINVITACION, FECHAINICIO=TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), CLASIFICACIONCC=:CLASIFICACIONCC, LICITACIONOCONCURSO=:LICITACIONOCONCURSO, FECHATERDEFINITIVOS=TO_DATE(:FECHATERDEFINITIVOS,'DD/MM/YYYY HH24:MI:SS'), FECHA_NACTO=TO_DATE(:FECHA_NACTO,'DD/MM/YYYY HH24:MI:SS'), INDICADORENVIO=:INDICADORENVIO, NUMEROACTA=:NUMEROACTA, INDICADORCUMPLIMIENTO=:INDICADORCUMPLIMIENTO, HONORARIOS=:HONORARIOS, DESC_ESTPREVIOS=: