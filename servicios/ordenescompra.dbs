	<query id="getOrdenescompraNumMovasociadocompQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUMERO,TERCERO,TO_CHAR(FECHAFINALIZACION, 'DD/MM/YYYY') FECHAVENCIMIENTO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, DESCRIPCION FROM ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN IN (:CLASEORDEN) AND VACIA IN ('N') AND ( CASE WHEN :CLASE_MOV = 'E' OR (:CLASE_DOCASMOV = 'J' AND :CLASE_MOV = 'E') THEN ESTADO ELSE 'X' END) &lt;&gt; ('A')) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN FECHAVENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAVENCIMIENTO) END) LIKE UPPER(CONCAT(:FECHAVENCIMIENTO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
