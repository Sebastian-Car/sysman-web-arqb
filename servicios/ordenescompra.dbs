	<query id="updateOrdenescompraObraPublica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET PORCADMINISTRACIONOP=:PORCADMINISTRACIONOP, PORCIMPREVISTOSOP=:PORCIMPREVISTOSOP, PORCUTILIDADESOP=:PORCUTILIDADESOP, VALORCOSTODIRECTO=:VALORCOSTODIRECTO, IVASOBREUTILIDADESOP=:IVASOBREUTILIDADESOP, VALORTOTALOP=:VALORTOTALOP, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PORCADMINISTRACIONOP" sqlType="STRING"/>
		<param name="PORCIMPREVISTOSOP" sqlType="STRING"/>
		<param name="PORCUTILIDADESOP" sqlType="STRING"/>
		<param name="VALORCOSTODIRECTO" sqlType="STRING"/>
		<param name="IVASOBREUTILIDADESOP" sqlType="STRING"/>
		<param name="VALORTOTALOP" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/obrapublica">
		<call-query href="updateOrdenescompraObraPublica">
			<with-param name="PORCADMINISTRACIONOP" query-param="PORCADMINISTRACIONOP"/>
			<with-param name="PORCIMPREVISTOSOP" query-param="PORCIMPREVISTOSOP"/>
			<with-param name="PORCUTILIDADESOP" query-param="PORCUTILIDADESOP"/>
			<with-param name="VALORCOSTODIRECTO" query-param="VALORCOSTODIRECTO"/>
			<with-param name="IVASOBREUTILIDADESOP" query-param="IVASOBREUTILIDADESOP"/>
			<with-param name="VALORTOTALOP" query-param="VALORTOTALOP"/>
