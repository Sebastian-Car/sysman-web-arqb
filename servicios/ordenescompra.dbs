	<query id="insertOrdenescompraModificacionesContratos" keyColumns="COMPANIA,CLASEORDEN,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ORDENDECOMPRA (COMPANIA, NUMERO, CLASEORDEN, APORTESTE_AD, CONSECUTIVOADICIONES, TERCERO, SUCURSAL, IMPRESO, DEPENDENCIA, OBJETOCONTRATO, NUMEROAFECTADO, SUCURSALCESION, CLASENOVEDAD, TIPODIA, NITCESION, FECHAINICIAL, FECHAFINAL, FECHAVENCIMIENTO, FECHA, DURACION, VALORTOTAL, CONSIDERANDOS, DESCRIPCION, RESOAPOLIZA, ANEXOPOLIZA, FECHAMODPOLIZA, SUCURSALINTERVENTOR, CLASEDISPONIBILIDAD, VALORDISPONIBILIDAD, VALORRESERVA, DESTINO, PROYECTO, INTERVENTOR, CEDULAINTERVENTOR, CARGOINTERVENTOR, NUMEROCONTRATOINTERV, VALORINTERVENCION, TIPOINTERVENTOR, CREATED_BY, DATE_CREATED, TIPOAFECTADO, ORDENADOR_MODIF, FECHAFINALMODIF, FECHAFINALACTUAL) VALUES (:COMPANIA, :NUMERO, :CLASEORDEN, :APORTESTE_AD, :CONSECUTIVOADICIONES, :TERCERO, :SUCURSAL, :IMPRESO, :DEPENDENCIA, :OBJETOCONTRATO, :NUMEROAFECTADO, :SUCURSALCESION, :CLASENOVEDAD, :TIPODIA, :NITCESION, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :DURACION, :VALORTOTAL, :CONSIDERANDOS, :DESCRIPCION, :RESOAPOLIZA, :ANEXOPOLIZA, TO_DATE(:FECHAMODPOLIZA,'DD/MM/YYYY HH24:MI:SS'), :SUCURSALINTERVENTOR, :CLASEDISPONIBILIDAD, :VALORDISPONIBILIDAD, :VALORRESERVA, :DESTINO, :PROYECTO, :INTERVENTOR, :CEDULAINTERVENTOR, :CARGOINTERVENTOR, :NUMEROCONTRATOINTERV, :VALORINTERVENCION, :TIPOINTERVENTOR, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :TIPOAFECTADO, :ORDENADOR_MODIF, TO_DATE(:FECHAFINALMODIF,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINALACTUAL,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_NUMERO":"$NUMERO"}]}}		</result>
