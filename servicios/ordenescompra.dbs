	<query id="updateOrdenescompraEdicionpornovedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET COMPANIA=:COMPANIA, CLASEORDEN=:CLASEORDEN, ORDENDECOMPRA=:ORDENDECOMPRA, NOVEDAD=:NOVEDAD, CLASET=:CLASET, TIPOT=:TIPOT, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), ANO=:ANO, NUMERO=:NUMERO, VALORTOTAL=:VALORTOTAL, OBSERVACIONES=:OBSERVACIONES, POREJECUCION=:POREJECUCION, VISITAIN=:VISITAIN, RESULTADOS=:RESULTADOS, INDADICION=:INDADICION, DIAS_CONTRATO=:DIAS_CONTRATO, VLR_ALQ_VEHICULO=:VLR_ALQ_VEHICULO, CLASENOVEDAD=:CLASENOVEDAD, TIPOMODELO=:TIPOMODELO, TIPOFORMATO=:TIPOFORMATO, VALOR_LIBERADO=:VALOR_LIBERADO, INDICADOR_CUMPLIMIENTO=:INDICADOR_CUMPLIMIENTO, TIPO_RETENCION=:TIPO_RETENCION, APORTESTE=:APORTESTE, CONSIDERANDOS=:CONSIDERANDOS, ORDENADOR=:ORDENADOR, IMPRESO=:IMPRESO, CALIFICACIONCONTR=:CALIFICACIONCONTR, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="POREJECUCION" sqlType="STRING"/>
		<param name="VISITAIN" sqlType="STRING"/>
		<param name="RESULTADOS" sqlType="STRING"/>
		<param name="INDADICION" sqlType="STRING"/>
		<param name="DIAS_CONTRATO" sqlType="STRING"/>
		<param name="VLR_ALQ_VEHICULO" sqlType="STRING"/>
		<param name="CLASENOVEDAD" sqlType="STRING"/>
		<param name="TIPOMODELO" sqlType="STRING"/>
