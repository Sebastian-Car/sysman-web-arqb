	<query id="getOrdenescompraOrigenObraPublicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ORDENDECOMPRA.PORCADMINISTRACIONOP, ORDENDECOMPRA.PORCIMPREVISTOSOP, ORDENDECOMPRA.PORCUTILIDADESOP, ORDENDECOMPRA.VALORCOSTODIRECTO, ORDENDECOMPRA.IVASOBREUTILIDADESOP, ORDENDECOMPRA.VALORTOTALOP, ORDENDECOMPRA.VALORCOSTODIRECTO  FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO = :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PORCADMINISTRACIONOP":"$PORCADMINISTRACIONOP","PORCIMPREVISTOSOP":"$PORCIMPREVISTOSOP","PORCUTILIDADESOP":"$PORCUTILIDADESOP","VALORCOSTODIRECTO":"$VALORCOSTODIRECTO","IVASOBREUTILIDADESOP":"$IVASOBREUTILIDADESOP","VALORTOTALOP":"$VALORTOTALOP","VALORCOSTODIRECTO":"$VALORCOSTODIRECTO"}]}}		</result>
