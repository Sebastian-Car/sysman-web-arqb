			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>

		</call-query>
	</resource>
	<query id="insertOrdenescompraOrdenInventarioInicial" keyColumns="COMPANIA,CLASEORDEN,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ORDENDECOMPRA (COMPANIA, CLASEORDEN, NUMERO, TERCERO, SUCURSAL, DEPENDENCIA, RESPONSABLE, FECHA, DESCRIPCION, CREATED_BY, DATE_CREATED, SUCURSAL_RESPONSABLE) VALUES (:COMPANIA, :CLASEORDEN, :NUMERO, :TERCERO, :SUCURSAL, :DEPENDENCIA, :RESPONSABLE, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :SUCURSAL_RESPONSABLE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ordenescompra/ordeninventarioinicial">
		<call-query href="insertOrdenescompraOrdenInventarioInicial">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="SUCURSAL_RESPONSABLE" query-param="SUCURSAL_RESPONSABLE"/>

		</call-query>
	</resource>
	<query id="updateOrdenescompraOrdenInventarioInicial" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA   SET DEPENDENCIA = :DEPENDENCIA, RESPONSABLE = :RESPONSABLE, DESCRIPCION = :DESCRIPCION, SUCURSAL_RESPONSABLE = :SUCURSAL_RESPONSABLE, FECHA = :FECHA, TERCERO = :TERCERO, SUCURSAL = :SUCURSAL, MODIFIED_BY = :MODIFIED_BY, DATE_MODIFIED = :DATE_MODIFIED WHERE   COMPANIA = :KEY_COMPANIA  AND NUMERO = :KEY_NUMERO AND CLASEORDEN =  :KEY_CLASEORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/ordeninventarioinicial">
