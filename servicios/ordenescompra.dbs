	<query id="updateOrdenescompraRegistroDeNovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET VALORTOTAL=:VALORTOTAL, NUMERO=:NUMERO, HONORARIOS=:HONORARIOS, VEHICULO=:VEHICULO, CLASEORDEN=:CLASEORDEN, DEPENDENCIA=:DEPENDENCIA, VALOR_ANTICIPO=:VALOR_ANTICIPO, ANTCAMORTIZADO=:ANTCAMORTIZADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="HONORARIOS" sqlType="STRING"/>
		<param name="VEHICULO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="VALOR_ANTICIPO" sqlType="STRING"/>
		<param name="ANTCAMORTIZADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
