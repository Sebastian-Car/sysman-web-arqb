	<query id="updateOrdenescompraPortipordam" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET FECHAFINALIZACION=TO_DATE(:FECHAFINALIZACION,'DD/MM/YYYY HH24:MI:SS'), VALORFINAL=:VALORFINAL, DESCRIPCION=:DESCRIPCION, ESTADO=:ESTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
