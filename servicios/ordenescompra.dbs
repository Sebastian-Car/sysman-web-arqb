	<query id="getOrdenescompraMovimientostiempoQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(MOD.DURACION),NULL) TOTAL FROM ORDENDECOMPRA ODC LEFT JOIN ORDENDECOMPRA MOD ON ODC.COMPANIA = MOD.COMPANIA AND ODC.CLASEORDEN = MOD.TIPOAFECTADO AND ODC.NUMERO = MOD.NUMEROAFECTADO WHERE ODC.COMPANIA = :COMPANIA AND ODC.CLASEORDEN = :CLASEORDEN AND ODC.NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
