	<query id="getOrdenescompraPagPorauxtipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, TERCERO.NOMBRE, ORDENDECOMPRA.DESCRIPCION  FROM ORDENDECOMPRA LEFT JOIN TERCERO ON ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :AUXTIPO ORDER BY ORDENDECOMPRA.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="AUXTIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
