	<query id="getOrdenescompraPagHastaFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') FECHA, TO_CHAR(SUBSTR(ORDENDECOMPRA.DESCRIPCION,1,255)) DESCRIPCION, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.CLASEORDEN FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.FECHA &lt;= TO_DATE(:FECHAINI,'DD/MM/YYYY HH24:MI:SS') ORDER BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END) LIKE UPPER(CONCAT(:VALORTOTAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","VALORTOTAL":"$VALORTOTAL","CLASEORDEN":"$CLASEORDEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/hastafecha/pag">
		<call-query href="getOrdenescompraPagHastaFechaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumHastaFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') FECHA, TO_CHAR(SUBSTR(ORDENDECOMPRA.DESCRIPCION,1,255)) DESCRIPCION, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.CLASEORDEN FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.FECHA &lt;= TO_DATE(:FECHAINI,'DD/MM/YYYY HH24:MI:SS') ORDER BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END) LIKE UPPER(CONCAT(:VALORTOTAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/hastafecha/num">
		<call-query href="getOrdenescompraNumHastaFechaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraExisteEstampillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'X' VALOR  FROM ORDENDECOMPRA INNER JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO AND ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.NUMERO = :NUMERO AND TIPOORDENDECOMPRA.ESTAMPILLA NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/existeestampilla">
		<call-query href="getOrdenescompraExisteEstampillaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraExisteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' VALOR  FROM ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND NUMERO = :CONSECUTIVO AND EXTRACT(YEAR FROM FECHA) = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/existe">
		<call-query href="getOrdenescompraExisteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPagTodosPorTerceroSucursalFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.OBJETOCONTRATO, (NVL(VALORTOTAL,0)-NVL(VALORPAGOS,0)) SALDO, ORDENDECOMPRA.VALORPAGOS  FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND (NVL(VALORTOTAL,0)-NVL(VALORPAGOS,0))&gt;0 AND ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.SUCURSAL = :SUCURSAL AND ( CASE WHEN FECHAFIRMA IS NULL THEN ORDENDECOMPRA.FECHA ELSE CASE WHEN FECHAFIRMA&lt;ORDENDECOMPRA.FECHA THEN FECHAFIRMA ELSE ORDENDECOMPRA.FECHA END END) &lt;= :FECHA) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END)  LIKE UPPER(:CLASEORDEN || '%')  AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END)  LIKE UPPER( '%' || :OBJETOCONTRATO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","CLASEORDEN":"$CLASEORDEN","VALORTOTAL":"$VALORTOTAL","OBJETOCONTRATO":"$OBJETOCONTRATO","SALDO":"$SALDO","VALORPAGOS":"$VALORPAGOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/todosportercerosucursalfecha/pag">
