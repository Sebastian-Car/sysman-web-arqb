			<with-param name="TERCERO" query-param="TERCERO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraVigenciaDeContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASENOVEDAD.NOMBRE, ORDENDECOMPRA.CONSECUTIVOADICIONES, EXTRACT(YEAR FROM ORDENDECOMPRA.FECHA) AS VIGENCIAF, ORDENDECOMPRA.CONSIDERANDOS  FROM ORDENDECOMPRA INNER JOIN CLASENOVEDAD ON ORDENDECOMPRA.CLASENOVEDAD = CLASENOVEDAD.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.NUMERO = :NUMERO AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.NUMEROAFECTADO = :NUMEROAFECTADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","CONSECUTIVOADICIONES":"$CONSECUTIVOADICIONES","VIGENCIAF":"$VIGENCIAF(type:integer)","CONSIDERANDOS":"$CONSIDERANDOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROAFECTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/vigenciadecontrato">
		<call-query href="getOrdenescompraVigenciaDeContratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMEROAFECTADO" query-param="NUMEROAFECTADO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPorCedulaExpedidaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TERCERO.EXPEDIDACEDULA  FROM ORDENDECOMPRA INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.INTERVENTOR = TERCERO.NOMBRE AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXPEDIDACEDULA":"$EXPEDIDACEDULA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/porcedulaexpedida">
		<call-query href="getOrdenescompraPorCedulaExpedidaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPagOrdentipordaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.SUCURSAL, ORDENDECOMPRA.DEPENDENCIA,(TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, TRIM(TERCERO.NOMBRE) NOMBRE,(TO_CHAR(ORDENDECOMPRA.FECHAFINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALIZACION, ORDENDECOMPRA.VALORFINAL, ORDENDECOMPRA.DESCRIPCION, ORDENDECOMPRA.ESTADO, ORDENDECOMPRA.VALORTOTAL  FROM ORDENDECOMPRA LEFT JOIN TERCERO ON ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = 'RDA' ORDER BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHAFINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHAFINALIZACION) END)  LIKE UPPER(:FECHAFINALIZACION || '%')  AND (CASE WHEN VALORFINAL IS NULL THEN ' ' ELSE UPPER(VALORFINAL) END)  LIKE UPPER(:VALORFINAL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","DEPENDENCIA":"$DEPENDENCIA","FECHA":"$FECHA","NOMBRE":"$NOMBRE","FECHAFINALIZACION":"$FECHAFINALIZACION","VALORFINAL":"$VALORFINAL","DESCRIPCION":"$DESCRIPCION","ESTADO":"$ESTADO","VALORTOTAL":"$VALORTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAFINALIZACION" sqlType="STRING"/>
		<param name="VALORFINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/ordentiporda/pag">
		<call-query href="getOrdenescompraPagOrdentipordaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHAFINALIZACION" query-param="FECHAFINALIZACION"/>
			<with-param name="VALORFINAL" query-param="VALORFINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumOrdentipordaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.SUCURSAL, ORDENDECOMPRA.DEPENDENCIA,(TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, TRIM(TERCERO.NOMBRE) NOMBRE,(TO_CHAR(ORDENDECOMPRA.FECHAFINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALIZACION, ORDENDECOMPRA.VALORFINAL, ORDENDECOMPRA.DESCRIPCION, ORDENDECOMPRA.ESTADO, ORDENDECOMPRA.VALORTOTAL  FROM ORDENDECOMPRA LEFT JOIN TERCERO ON ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = 'RDA' ORDER BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHAFINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHAFINALIZACION) END)  LIKE UPPER(:FECHAFINALIZACION || '%')  AND (CASE WHEN VALORFINAL IS NULL THEN ' ' ELSE UPPER(VALORFINAL) END)  LIKE UPPER(:VALORFINAL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAFINALIZACION" sqlType="STRING"/>
		<param name="VALORFINAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/ordentiporda/num">
		<call-query href="getOrdenescompraNumOrdentipordaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHAFINALIZACION" query-param="FECHAFINALIZACION"/>
			<with-param name="VALORFINAL" query-param="VALORFINAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPagListaDeNovedadesPorClaseordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') AS FECHA, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.NOMBRECONTRATISTA, TO_CHAR(ORDENDECOMPRA.FECHAFINALIZACION,'DD/MM/YYYY') AS FECHAFINALIZACION FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND EXTRACT(YEAR FROM ORDENDECOMPRA.FECHA) = :ANO ORDER BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRECONTRATISTA IS NULL THEN ' ' ELSE UPPER(NOMBRECONTRATISTA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECONTRATISTA), '%')) AND (CASE WHEN FECHAFINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHAFINALIZACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAFINALIZACION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","FECHA":"$FECHA","TERCERO":"$TERCERO","NOMBRECONTRATISTA":"$NOMBRECONTRATISTA","FECHAFINALIZACION":"$FECHAFINALIZACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRECONTRATISTA" sqlType="STRING"/>
		<param name="FECHAFINALIZACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/listadenovedadesporclaseorden/pag">
		<call-query href="getOrdenescompraPagListaDeNovedadesPorClaseordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRECONTRATISTA" query-param="NOMBRECONTRATISTA"/>
			<with-param name="FECHAFINALIZACION" query-param="FECHAFINALIZACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumListaDeNovedadesPorClaseordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') AS FECHA, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.NOMBRECONTRATISTA, TO_CHAR(ORDENDECOMPRA.FECHAFINALIZACION,'DD/MM/YYYY') AS FECHAFINALIZACION FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND EXTRACT(YEAR FROM ORDENDECOMPRA.FECHA) = :ANO ORDER BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRECONTRATISTA IS NULL THEN ' ' ELSE UPPER(NOMBRECONTRATISTA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECONTRATISTA), '%')) AND (CASE WHEN FECHAFINALIZACION IS NULL THEN ' ' ELSE UPPER(FECHAFINALIZACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAFINALIZACION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRECONTRATISTA" sqlType="STRING"/>
		<param name="FECHAFINALIZACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/listadenovedadesporclaseorden/num">
		<call-query href="getOrdenescompraNumListaDeNovedadesPorClaseordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRECONTRATISTA" query-param="NOMBRECONTRATISTA"/>
			<with-param name="FECHAFINALIZACION" query-param="FECHAFINALIZACION"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraRegistroDeNovedadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(ORDENDECOMPRA.TERCERO,CONCAT(' - ',ORDENDECOMPRA.NOMBRECONTRATISTA) ) AFAVORDE, ORDENDECOMPRA.CLASEORDEN, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') FECHA, TO_CHAR(ORDENDECOMPRA.FECHAFIRMA,'DD/MM/YYYY') FECHAFIRMA, TO_CHAR(ORDENDECOMPRA.FECHAINICIO,'DD/MM/YYYY') FECHAINICIO, ORDENDECOMPRA.PLAZODEENTREGA, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.HONORARIOS, ORDENDECOMPRA.VEHICULO, ORDENDECOMPRA.CREATED_BY,(TO_CHAR(ORDENDECOMPRA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, ORDENDECOMPRA.MODIFIED_BY,(TO_CHAR(ORDENDECOMPRA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ORDENDECOMPRA.DEPENDENCIA,(TO_CHAR(FECHAFINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALIZACION,(TO_CHAR(FECHAPOLIZAS,'DD/MM/YYYY HH24:MI:SS')) FECHAPOLIZAS, VALORFINAL, CLASEDISPONIBILIDAD, TERCERO,(TO_CHAR(FECHA_NACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_NACTO, ORDENDECOMPRA.VALOR_ANTICIPO, ANTCAMORTIZADO,(CASE ORDENDECOMPRA.APLICA_ACTAS_INICIO WHEN 0 THEN 'false' ELSE 'true' END) APLICA_ACTAS_INICIO, ORDENDECOMPRA.VALOR_ANTICIPO - ORDENDECOMPRA.ANTCAMORTIZADO VALORANTICIPOAMORTIZAR FROM ORDENDECOMPRA ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA =:KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO =:KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"AFAVORDE":"$AFAVORDE","CLASEORDEN":"$CLASEORDEN","FECHA":"$FECHA","FECHAFIRMA":"$FECHAFIRMA","FECHAINICIO":"$FECHAINICIO","PLAZODEENTREGA":"$PLAZODEENTREGA","OBJETOCONTRATO":"$OBJETOCONTRATO","VALORTOTAL":"$VALORTOTAL","NUMERO":"$NUMERO","HONORARIOS":"$HONORARIOS","VEHICULO":"$VEHICULO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DEPENDENCIA":"$DEPENDENCIA","FECHAFINALIZACION":"$FECHAFINALIZACION","FECHAPOLIZAS":"$FECHAPOLIZAS","VALORFINAL":"$VALORFINAL","CLASEDISPONIBILIDAD":"$CLASEDISPONIBILIDAD","TERCERO":"$TERCERO","FECHA_NACTO":"$FECHA_NACTO","VALOR_ANTICIPO":"$VALOR_ANTICIPO","ANTCAMORTIZADO":"$ANTCAMORTIZADO","APLICA_ACTAS_INICIO":"$APLICA_ACTAS_INICIO(type:boolean)","VALORANTICIPOAMORTIZAR":"$VALORANTICIPOAMORTIZAR(type:double)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
