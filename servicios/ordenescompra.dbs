		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/plazoentregayfechafinalizacion">
		<call-query href="updateOrdenescompraPlazoEntregaYFechaFinalizacion">
			<with-param name="PLAZOENTREGA" query-param="PLAZOENTREGA"/>
			<with-param name="FECHAFINALIZACION" query-param="FECHAFINALIZACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
