	<query id="getOrdenescompraNumTodosPorTerceroSucursalFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.OBJETOCONTRATO, (NVL(VALORTOTAL,0)-NVL(VALORPAGOS,0)) SALDO, ORDENDECOMPRA.VALORPAGOS  FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND (NVL(VALORTOTAL,0)-NVL(VALORPAGOS,0))&gt;0 AND ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.SUCURSAL = :SUCURSAL AND ( CASE WHEN FECHAFIRMA IS NULL THEN ORDENDECOMPRA.FECHA ELSE CASE WHEN FECHAFIRMA&lt;ORDENDECOMPRA.FECHA THEN FECHAFIRMA ELSE ORDENDECOMPRA.FECHA END END) &lt;= :FECHA) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END)  LIKE UPPER(:CLASEORDEN || '%')  AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END)  LIKE UPPER( '%' || :OBJETOCONTRATO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>

	</query>
