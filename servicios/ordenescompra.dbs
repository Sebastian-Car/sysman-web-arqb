	<query id="getOrdenescompraPagTodosPorCompaniaTipoContratoTerceroSucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, (CONCAT(NUMEROCONTRATO ,CONCAT(' ' , OBJETOCONTRATO ))) DESCRIP, ORDENDECOMPRA.OBJETOCONTRATO FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:TIPOCONTRATO AND ORDENDECOMPRA.TERCERO =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL AND ( CASE WHEN FECHAFIRMA IS NULL THEN FECHA ELSE ( CASE WHEN FECHAFIRMA &lt; FECHA THEN FECHAFIRMA ELSE FECHA END ) END ) &lt;=:FECHA AND NVL(ESTADO,'') NOT IN 'A' AND ( ORDENDECOMPRA.NITCESION =:CONSTANTE_TERCERO OR NITCESION = ' ' ) UNION SELECT ORDENDECOMPRA.NUMERO, (CONCAT(NUMEROCONTRATO ,CONCAT(' ' ,OBJETOCONTRATO ))) DESCRIP, ORDENDECOMPRA.OBJETOCONTRATO FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:TIPOCONTRATO AND ORDENDECOMPRA.NITCESION =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL AND ( CASE WHEN FECHAFIRMA IS NULL THEN FECHA ELSE ( CASE WHEN FECHAFIRMA &lt; FECHA THEN FECHAFIRMA ELSE FECHA END ) END ) &lt;=:FECHA AND NVL(ESTADO,'') NOT IN ( 'A' ) AND ORDENDECOMPRA.CLASENOVEDAD = 'C' ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIP IS NULL THEN ' ' ELSE UPPER(DESCRIP) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIP), '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","DESCRIP":"$DESCRIP","OBJETOCONTRATO":"$OBJETOCONTRATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CONSTANTE_TERCERO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIP" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/todosporcompaniatipocontratotercerosucursal/pag">
		<call-query href="getOrdenescompraPagTodosPorCompaniaTipoContratoTerceroSucursalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CONSTANTE_TERCERO" query-param="CONSTANTE_TERCERO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIP" query-param="DESCRIP"/>
			<with-param name="OBJETOCONTRATO" query-param="OBJETOCONTRATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumTodosPorCompaniaTipoContratoTerceroSucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, (CONCAT(NUMEROCONTRATO ,CONCAT(' ' , OBJETOCONTRATO ))) DESCRIP, ORDENDECOMPRA.OBJETOCONTRATO FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:TIPOCONTRATO AND ORDENDECOMPRA.TERCERO =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL AND ( CASE WHEN FECHAFIRMA IS NULL THEN FECHA ELSE ( CASE WHEN FECHAFIRMA &lt; FECHA THEN FECHAFIRMA ELSE FECHA END ) END ) &lt;=:FECHA AND NVL(ESTADO,'') NOT IN 'A' AND ( ORDENDECOMPRA.NITCESION =:CONSTANTE_TERCERO OR NITCESION = ' ' ) UNION SELECT ORDENDECOMPRA.NUMERO, (CONCAT(NUMEROCONTRATO ,CONCAT(' ' ,OBJETOCONTRATO ))) DESCRIP, ORDENDECOMPRA.OBJETOCONTRATO FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:TIPOCONTRATO AND ORDENDECOMPRA.NITCESION =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL AND ( CASE WHEN FECHAFIRMA IS NULL THEN FECHA ELSE ( CASE WHEN FECHAFIRMA &lt; FECHA THEN FECHAFIRMA ELSE FECHA END ) END ) &lt;=:FECHA AND NVL(ESTADO,'') NOT IN ( 'A' ) AND ORDENDECOMPRA.CLASENOVEDAD = 'C' ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIP IS NULL THEN ' ' ELSE UPPER(DESCRIP) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIP), '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CONSTANTE_TERCERO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIP" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/todosporcompaniatipocontratotercerosucursal/num">
