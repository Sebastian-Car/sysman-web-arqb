	<query id="getOrdenescompraValortotalmodificacionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT (ORDENDECOMPRA.VALORFINAL + NVL(ADICIONES.VALORTOTAL,0)) VALORTOTAL, CAST((ORDENDECOMPRA.VALORFINAL + NVL(ADICIONES.VALORTOTAL,0) + NVL(NOTA_CREDITO.VALOR,0))AS BINARY_DOUBLE)- NVL(MOVIMIENTO.VALORTR, 0) VALORREINTEGRO, ORDENDECOMPRA.VACIA FROM ORDENDECOMPRA LEFT JOIN ( SELECT COMPANIA, TIPOAFECTADO, NUMEROAFECTADO, SUM(VALORTOTAL) VALORTOTAL FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.TIPOAFECTADO = :CLASEORDEN AND ORDENDECOMPRA.NUMEROAFECTADO = :NUMERO GROUP BY COMPANIA, TIPOAFECTADO, NUMEROAFECTADO) ADICIONES ON ADICIONES.COMPANIA = ORDENDECOMPRA.COMPANIA AND ADICIONES.TIPOAFECTADO = ORDENDECOMPRA.CLASEORDEN AND ADICIONES.NUMEROAFECTADO = ORDENDECOMPRA.NUMERO LEFT JOIN ( SELECT COMPANIA, CLASEORDEN, ORDENDECOMPRA, SUM(VALOR) VALOR FROM VLR_NOTA_CREDITO WHERE VLR_NOTA_CREDITO.COMPANIA = :COMPANIA AND VLR_NOTA_CREDITO.CLASEORDEN = :CLASEORDEN AND VLR_NOTA_CREDITO.ORDENDECOMPRA = :NUMERO GROUP BY COMPANIA, CLASEORDEN, ORDENDECOMPRA) NOTA_CREDITO ON NOTA_CREDITO.COMPANIA = ORDENDECOMPRA.COMPANIA AND NOTA_CREDITO.CLASEORDEN = ORDENDECOMPRA.CLASEORDEN AND NOTA_CREDITO.ORDENDECOMPRA = ORDENDECOMPRA.NUMERO LEFT JOIN ( SELECT COMPANIA, TIPOMOVASOCIADO, MOVASOCIADO, SUM(VALORTOTAL) VALORTR FROM MOVIMIENTO WHERE MOVIMIENTO.COMPANIA = :COMPANIA AND MOVIMIENTO.TIPOMOVASOCIADO = :CLASEORDEN AND MOVIMIENTO.MOVASOCIADO = :NUMERO GROUP BY COMPANIA, TIPOMOVASOCIADO, MOVASOCIADO ) MOVIMIENTO ON MOVIMIENTO.COMPANIA = ORDENDECOMPRA.COMPANIA AND MOVIMIENTO.TIPOMOVASOCIADO = ORDENDECOMPRA.CLASEORDEN AND MOVIMIENTO.MOVASOCIADO = ORDENDECOMPRA.NUMERO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORTOTAL":"$VALORTOTAL","VALORREINTEGRO":"$VALORREINTEGRO","VACIA":"$VACIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
