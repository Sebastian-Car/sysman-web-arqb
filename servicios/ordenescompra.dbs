	<query id="getOrdenescompraTodosOrdenInventarioInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CLASEORDEN, NUMERO, TERCERO, SUCURSAL, DEPENDENCIA, RESPONSABLE, SUCURSAL_RESPONSABLE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DESCRIPCION, OBJETOCONTRATO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TIPOAFECTADO  FROM ORDENDECOMPRA WHERE COMPANIA = :KEY_COMPANIA AND NUMERO = :KEY_NUMERO AND CLASEORDEN = :KEY_CLASEORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL_RESPONSABLE":"$SUCURSAL_RESPONSABLE","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","OBJETOCONTRATO":"$OBJETOCONTRATO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","TIPOAFECTADO":"$TIPOAFECTADO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>

	</query>
