	<query id="getOrdenescompraTotalfacturasporterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) TOTAL FROM ORDENDECOMPRA ORD INNER JOIN TERCERO T ON ORD.COMPANIA = T.COMPANIA AND ORD.TERCERO = T.NIT AND ORD.SUCURSAL = T.SUCURSAL INNER JOIN SF_OBJETO_COBRO SF ON SF.COMPANIA = T.COMPANIA AND SF.TERCERO = T.NIT AND SF.SUCURSAL = T.SUCURSAL WHERE ORD.SUJETOAREPORTAR NOT IN (0) AND ORD.TERCERO = :TERCERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TERCERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/totalfacturasportercero">
		<call-query href="getOrdenescompraTotalfacturasporterceroQuery">
			<with-param name="TERCERO" query-param="TERCERO"/>

		</call-query>
	</resource>
		<query id="getOrdenescompraPagListarporfechafirmaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, DEPENDENCIA.NOMBRE, TO_CHAR(ORDENDECOMPRA.FECHA, 'DD/MM/YYYY') FECHA, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.MODIFICACION_TIEMPO FROM ORDENDECOMPRA INNER JOIN DEPENDENCIA ON ORDENDECOMPRA.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDECOMPRA.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEF AND TO_CHAR(ORDENDECOMPRA.FECHAFIRMA, 'YYYY') = :ANO ORDER BY ORDENDECOMPRA.FECHA DESC, ORDENDECOMPRA.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) AND (CASE WHEN MODIFICACION_TIEMPO IS NULL THEN ' ' ELSE UPPER(MODIFICACION_TIEMPO) END) LIKE UPPER(CONCAT(:MODIFICACION_TIEMPO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","NOMBRE":"$NOMBRE","FECHA":"$FECHA","OBJETOCONTRATO":"$OBJETOCONTRATO","MODIFICACION_TIEMPO":"$MODIFICACION_TIEMPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEF" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>
		<param name="MODIFICACION_TIEMPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/listarporfechafirma/pag">
		<call-query href="getOrdenescompraPagListarporfechafirmaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEF" query-param="CLASEF"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBJETOCONTRATO" query-param="OBJETOCONTRATO"/>
			<with-param name="MODIFICACION_TIEMPO" query-param="MODIFICACION_TIEMPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumListarporfechafirmaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, DEPENDENCIA.NOMBRE, TO_CHAR(ORDENDECOMPRA.FECHA, 'DD/MM/YYYY') FECHA, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.MODIFICACION_TIEMPO FROM ORDENDECOMPRA INNER JOIN DEPENDENCIA ON ORDENDECOMPRA.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDECOMPRA.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEF AND TO_CHAR(ORDENDECOMPRA.FECHAFIRMA, 'YYYY') = :ANO ORDER BY ORDENDECOMPRA.FECHA DESC, ORDENDECOMPRA.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) AND (CASE WHEN MODIFICACION_TIEMPO IS NULL THEN ' ' ELSE UPPER(MODIFICACION_TIEMPO) END) LIKE UPPER(CONCAT(:MODIFICACION_TIEMPO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEF" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>
		<param name="MODIFICACION_TIEMPO" sqlType="STRING"/>

	</query>
