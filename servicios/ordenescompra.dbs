	</resource>
	<query id="getOrdenescompraPagTodosPorCgrQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, TERCERO.NOMBRE, ORDENDECOMPRA.CGR_CONCEPTO, CGR_CODIGOS.NOMBRE NOMBRECONCEPTO, ORDENDECOMPRA.CGR_TIPO_GASTO, TIPODESTINO.NOMBRE NOMBREGASTO, ORDENDECOMPRA.CGR_SEGMENTO, CGR_SEGMENTO.NOMBRE NOMBRESEGMENTO  FROM ORDENDECOMPRA INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN CGR_CODIGOS ON ORDENDECOMPRA.CGR_CONCEPTO = CGR_CODIGOS.CODIGO LEFT JOIN TIPODESTINO ON ORDENDECOMPRA.CGR_TIPO_GASTO = TIPODESTINO.CODIGO LEFT JOIN CGR_SEGMENTO ON ORDENDECOMPRA.CGR_SEGMENTO = CGR_SEGMENTO.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA) WHERE (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END)  LIKE UPPER( '%' || :CLASEORDEN || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN NOMBREGASTO IS NULL THEN ' ' ELSE UPPER(NOMBREGASTO) END)  LIKE UPPER( '%' || :NOMBREGASTO || '%')  AND (CASE WHEN NOMBRESEGMENTO IS NULL THEN ' ' ELSE UPPER(NOMBRESEGMENTO) END)  LIKE UPPER( '%' || :NOMBRESEGMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","NOMBRE":"$NOMBRE","CGR_CONCEPTO":"$CGR_CONCEPTO","NOMBRECONCEPTO":"$NOMBRECONCEPTO","CGR_TIPO_GASTO":"$CGR_TIPO_GASTO","NOMBREGASTO":"$NOMBREGASTO","CGR_SEGMENTO":"$CGR_SEGMENTO","NOMBRESEGMENTO":"$NOMBRESEGMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="NOMBREGASTO" sqlType="STRING"/>
		<param name="NOMBRESEGMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
