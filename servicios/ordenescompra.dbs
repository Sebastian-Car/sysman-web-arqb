	<query id="updateOrdenescompraUpdatevlrdevuelto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET VLR_DEVUELTO = VALORTOTAL + :VALOR WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND NUMERO = :ORDENDECOMPRA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>

	</query>
