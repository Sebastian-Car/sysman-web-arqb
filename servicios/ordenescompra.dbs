	<query id="getOrdenescompraTotalAdicionesPorNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(ORDENDECOMPRA.VALORTOTAL) AS TOTAL_ADICIONES  FROM ((TIPOORDENDECOMPRA INNER JOIN ORDENDECOMPRA ON (TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA) AND (TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN)) INNER JOIN tercero ON (ORDENDECOMPRA.COMPANIA = tercero.COMPANIA) AND (ORDENDECOMPRA.TERCERO = tercero.NIT)) INNER JOIN ordendecompra ORDENDECOMPRA_1 ON (ORDENDECOMPRA.NumeroAfectado = ORDENDECOMPRA_1.NUMERO) AND (ORDENDECOMPRA.TipoAfectado = ORDENDECOMPRA_1.CLASEORDEN) AND (ORDENDECOMPRA.COMPANIA = ORDENDECOMPRA_1.COMPANIA) WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.NumeroAfectado = :NUMERO AND ORDENDECOMPRA.CLASENOVEDAD ='D' AND TIPOORDENDECOMPRA.Clase ='M' GROUP BY TIPOORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.TipoAfectado, ORDENDECOMPRA.NumeroAfectado, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_ADICIONES":"$TOTAL_ADICIONES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/totaladicionespornumero">
		<call-query href="getOrdenescompraTotalAdicionesPorNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPagRevisionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, TIPOORDENDECOMPRA.NOMBRE, ORDENDECOMPRA.CLASEORDEN, (CONCAT( NUMERO ,CONCAT( ' - ' , NOMBRE)) ) CONTRATO, CONCAT(ORDENDECOMPRA.NUMERO ,CONCAT('-' ,ORDENDECOMPRA.CLASEORDEN)) UNICO FROM ORDENDECOMPRA INNER JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND NVL(TIPOORDENDECOMPRA.CLASE,'C') = 'C' ORDER BY ORDENDECOMPRA.NUMERO) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","NOMBRE":"$NOMBRE","CLASEORDEN":"$CLASEORDEN","CONTRATO":"$CONTRATO","UNICO":"$UNICO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/revision/pag">
		<call-query href="getOrdenescompraPagRevisionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumRevisionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, TIPOORDENDECOMPRA.NOMBRE, ORDENDECOMPRA.CLASEORDEN, (CONCAT( NUMERO ,CONCAT( ' - ' , NOMBRE)) ) CONTRATO, CONCAT(ORDENDECOMPRA.NUMERO ,CONCAT('-' ,ORDENDECOMPRA.CLASEORDEN)) UNICO FROM ORDENDECOMPRA INNER JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND NVL(TIPOORDENDECOMPRA.CLASE,'C') = 'C' ORDER BY ORDENDECOMPRA.NUMERO) INI WHERE (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/revision/num">
		<call-query href="getOrdenescompraNumRevisionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPagOrigenRevisionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TIPOORDENDECOMPRA.NOMBRE NOMBRENOVEDAD, ORDENDECOMPRA.NUMERO NUMERONOVEDAD, ORDENDECOMPRA.CONSECUTIVOADICIONES CONSECUTIVO, ORDENDECOMPRA.DESCRIPCION OBSERVACIONESNOVEDAD, 'Contratos' MODULO  FROM ORDENDECOMPRA LEFT JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.TIPOAFECTADO = :CONTRATO AND ORDENDECOMPRA.NUMEROAFECTADO = :NUMEROAFECTADO) WHERE (CASE WHEN NOMBRENOVEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRENOVEDAD) END)  LIKE UPPER( '%' || :NOMBRENOVEDAD || '%')  AND (CASE WHEN NUMERONOVEDAD IS NULL THEN ' ' ELSE UPPER(NUMERONOVEDAD) END)  LIKE UPPER(:NUMERONOVEDAD || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN OBSERVACIONESNOVEDAD IS NULL THEN ' ' ELSE UPPER(OBSERVACIONESNOVEDAD) END)  LIKE UPPER( '%' || :OBSERVACIONESNOVEDAD || '%')  AND (CASE WHEN MODULO IS NULL THEN ' ' ELSE UPPER(MODULO) END)  LIKE UPPER( '%' || :MODULO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRENOVEDAD":"$NOMBRENOVEDAD","NUMERONOVEDAD":"$NUMERONOVEDAD","CONSECUTIVO":"$CONSECUTIVO","OBSERVACIONESNOVEDAD":"$OBSERVACIONESNOVEDAD","MODULO":"$MODULO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="NUMEROAFECTADO" sqlType="STRING"/>
		<param name="NOMBRENOVEDAD" sqlType="STRING"/>
		<param name="NUMERONOVEDAD" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACIONESNOVEDAD" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/origenrevision/pag">
		<call-query href="getOrdenescompraPagOrigenRevisionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="NUMEROAFECTADO" query-param="NUMEROAFECTADO"/>
			<with-param name="NOMBRENOVEDAD" query-param="NOMBRENOVEDAD"/>
			<with-param name="NUMERONOVEDAD" query-param="NUMERONOVEDAD"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="OBSERVACIONESNOVEDAD" query-param="OBSERVACIONESNOVEDAD"/>
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumOrigenRevisionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TIPOORDENDECOMPRA.NOMBRE NOMBRENOVEDAD, ORDENDECOMPRA.NUMERO NUMERONOVEDAD, ORDENDECOMPRA.CONSECUTIVOADICIONES CONSECUTIVO, ORDENDECOMPRA.DESCRIPCION OBSERVACIONESNOVEDAD, 'Contratos' MODULO  FROM ORDENDECOMPRA LEFT JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.TIPOAFECTADO = :CONTRATO AND ORDENDECOMPRA.NUMEROAFECTADO = :NUMEROAFECTADO) WHERE (CASE WHEN NOMBRENOVEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRENOVEDAD) END)  LIKE UPPER( '%' || :NOMBRENOVEDAD || '%')  AND (CASE WHEN NUMERONOVEDAD IS NULL THEN ' ' ELSE UPPER(NUMERONOVEDAD) END)  LIKE UPPER(:NUMERONOVEDAD || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN OBSERVACIONESNOVEDAD IS NULL THEN ' ' ELSE UPPER(OBSERVACIONESNOVEDAD) END)  LIKE UPPER( '%' || :OBSERVACIONESNOVEDAD || '%')  AND (CASE WHEN MODULO IS NULL THEN ' ' ELSE UPPER(MODULO) END)  LIKE UPPER( '%' || :MODULO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="NUMEROAFECTADO" sqlType="STRING"/>
		<param name="NOMBRENOVEDAD" sqlType="STRING"/>
		<param name="NUMERONOVEDAD" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="OBSERVACIONESNOVEDAD" sqlType="STRING"/>
		<param name="MODULO" sqlType="STRING"/>

	</query>
