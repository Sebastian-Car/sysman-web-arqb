<data name="ordenescompra" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getOrdenescompraPagInformacionBancoProyectosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA_AUXILIAR.COMPANIA, ORDENDECOMPRA_AUXILIAR.CLASEORDEN, ORDENDECOMPRA_AUXILIAR.ORDENDECOMPRA, ORDENDECOMPRA_AUXILIAR.SOLICITUD_SCD_BP, ORDENDECOMPRA_AUXILIAR.ACTIVIDAD, ORDENDECOMPRA_AUXILIAR.DESTINORECURSOS, ORDENDECOMPRA_AUXILIAR.AUXILIAR PROYECTO, ORDENDECOMPRA_AUXILIAR.FUENTE_RECURSOS, FUENTE_RECURSOS.NOMBRE NOMBRE_FUENTE, ORDENDECOMPRA_AUXILIAR.META_PROD META_PRODUCTO, ORDENDECOMPRA_AUXILIAR.COMPONENTES COMPONENTE, ORDENDECOMPRA_AUXILIAR.CANTIDAD_PRODUCTO_C, ORDENDECOMPRA_AUXILIAR.CANTIDAD_PLAN, ORDENDECOMPRA_AUXILIAR.VALOR  FROM ORDENDECOMPRA_AUXILIAR INNER JOIN BP_D_NOVEDADPROYECTO ON ORDENDECOMPRA_AUXILIAR.COMPANIA = BP_D_NOVEDADPROYECTO.COMPANIA AND ORDENDECOMPRA_AUXILIAR.AUXILIAR = BP_D_NOVEDADPROYECTO.PROYECTO AND ORDENDECOMPRA_AUXILIAR.ACTIVIDAD = BP_D_NOVEDADPROYECTO.ACTIVIDAD AND ORDENDECOMPRA_AUXILIAR.DESTINORECURSOS = BP_D_NOVEDADPROYECTO.SECTOR AND ORDENDECOMPRA_AUXILIAR.FUENTE_RECURSOS = BP_D_NOVEDADPROYECTO.FUENTERECURSOS AND ORDENDECOMPRA_AUXILIAR.COMPONENTES = BP_D_NOVEDADPROYECTO.COMPONENTE AND ORDENDECOMPRA_AUXILIAR.CONSECUTIVO = BP_D_NOVEDADPROYECTO.CODIGO AND ORDENDECOMPRA_AUXILIAR.SOLICITUD_SCD_BP = BP_D_NOVEDADPROYECTO.NOVEDAD LEFT JOIN FUENTE_RECURSOS ON BP_D_NOVEDADPROYECTO.COMPANIA = FUENTE_RECURSOS.COMPANIA AND BP_D_NOVEDADPROYECTO.FUENTERECURSOS = FUENTE_RECURSOS.CODIGO AND BP_D_NOVEDADPROYECTO.ANORUBRO = FUENTE_RECURSOS.ANO WHERE BP_D_NOVEDADPROYECTO.COMPANIA = :COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = 'SCD' AND ORDENDECOMPRA_AUXILIAR.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA_AUXILIAR.ORDENDECOMPRA = :NUMEROORDEN) WHERE (CASE WHEN SOLICITUD_SCD_BP IS NULL THEN ' ' ELSE UPPER(SOLICITUD_SCD_BP) END)  LIKE UPPER(:SOLICITUD_SCD_BP || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN DESTINORECURSOS IS NULL THEN ' ' ELSE UPPER(DESTINORECURSOS) END)  LIKE UPPER(:DESTINORECURSOS || '%')  AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END)  LIKE UPPER(:PROYECTO || '%')  AND (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END)  LIKE UPPER( '%' || :NOMBRE_FUENTE || '%')  AND (CASE WHEN META_PRODUCTO IS NULL THEN ' ' ELSE UPPER(META_PRODUCTO) END)  LIKE UPPER(:META_PRODUCTO || '%')  AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER(:COMPONENTE || '%')  AND (CASE WHEN CANTIDAD_PRODUCTO_C IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PRODUCTO_C) END)  LIKE UPPER(:CANTIDAD_PRODUCTO_C || '%')  AND (CASE WHEN CANTIDAD_PLAN IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PLAN) END)  LIKE UPPER(:CANTIDAD_PLAN || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA(type:long)","SOLICITUD_SCD_BP":"$SOLICITUD_SCD_BP(type:double)","ACTIVIDAD":"$ACTIVIDAD","DESTINORECURSOS":"$DESTINORECURSOS","PROYECTO":"$PROYECTO","FUENTE_RECURSOS":"$FUENTE_RECURSOS","NOMBRE_FUENTE":"$NOMBRE_FUENTE","META_PRODUCTO":"$META_PRODUCTO","COMPONENTE":"$COMPONENTE","CANTIDAD_PRODUCTO_C":"$CANTIDAD_PRODUCTO_C(type:double)","CANTIDAD_PLAN":"$CANTIDAD_PLAN(type:double)","VALOR":"$VALOR(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="SOLICITUD_SCD_BP" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="DESTINORECURSOS" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOMBRE_FUENTE" sqlType="STRING"/>
		<param name="META_PRODUCTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="CANTIDAD_PRODUCTO_C" sqlType="STRING"/>
		<param name="CANTIDAD_PLAN" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/informacionbancoproyectos/pag">
		<call-query href="getOrdenescompraPagInformacionBancoProyectosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>
			<with-param name="SOLICITUD_SCD_BP" query-param="SOLICITUD_SCD_BP"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="DESTINORECURSOS" query-param="DESTINORECURSOS"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="NOMBRE_FUENTE" query-param="NOMBRE_FUENTE"/>
			<with-param name="META_PRODUCTO" query-param="META_PRODUCTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="CANTIDAD_PRODUCTO_C" query-param="CANTIDAD_PRODUCTO_C"/>
			<with-param name="CANTIDAD_PLAN" query-param="CANTIDAD_PLAN"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="updateOrdenescompraDescripcion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET DESCRIPCION = :DESCRIPCION,     DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),     MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA    AND NUMERO = :ORDEN    AND CLASEORDEN = :CLASEORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/descripcion">
		<call-query href="updateOrdenescompraDescripcion">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>

		</call-query>
	</resource>
	<query id="updateOrdenescompraValorTotal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET VALORTOTAL = :VALORTOTAL,     DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),     MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :COMPANIA    AND NUMERO = :ORDEN    AND CLASEORDEN = :CLASEORDEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/valortotal">
		<call-query href="updateOrdenescompraValorTotal">
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>

		</call-query>
	</resource>
	<query id="updateOrdenescompraFormadepago" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET FORMADEPAGO = :FORMA_PAGO WHERE COMPANIA =:COMPANIA AND CLASEORDEN = :TIPOCONTRATO AND NUMERO = :NUMEROCONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FORMA_PAGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/formadepago">
		<call-query href="updateOrdenescompraFormadepago">
			<with-param name="FORMA_PAGO" query-param="FORMA_PAGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumeroCuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM ORDENDECOMPRA WHERE COMPANIA= :COMPANIA AND CLASEORDEN = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/numerocuentas">
		<call-query href="getOrdenescompraNumeroCuentasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPagoestampillasconterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.TERCERO,(TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.TERCERO, TERCERO.NOMBRE, TERCERO.REGIMEN, PAGO_ESTAMPILLAS.VALOR_PROCULTURA , PAGO_ESTAMPILLAS.VALOR_PROADULTOMAYOR , PAGO_ESTAMPILLAS.VALOR_PRODEPORTE ,(CASE PAGO_ESTAMPILLAS.PAGAPRODEPORTE WHEN 0 THEN 'false' ELSE 'true' END) PAGAPRODEPORTE FROM ORDENDECOMPRA INNER JOIN PAGO_ESTAMPILLAS ON ORDENDECOMPRA.COMPANIA = PAGO_ESTAMPILLAS.COMPANIA AND ORDENDECOMPRA.NUMERO = PAGO_ESTAMPILLAS.NUMERO AND ORDENDECOMPRA.CLASEORDEN = PAGO_ESTAMPILLAS.CLASEORDEN INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.TERCERO = TERCERO.NIT WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :TIPOCONTRATO AND ORDENDECOMPRA.NUMERO = :NUMEROCONTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO(type:long)","TERCERO":"$TERCERO","FECHA":"$FECHA","VALORTOTAL":"$VALORTOTAL(type:double)","TERCERO":"$TERCERO","NOMBRE":"$NOMBRE","REGIMEN":"$REGIMEN","VALOR_PROCULTURA":"$VALOR_PROCULTURA(type:double)","VALOR_PROADULTOMAYOR":"$VALOR_PROADULTOMAYOR(type:double)","VALOR_PRODEPORTE":"$VALOR_PRODEPORTE(type:double)","PAGAPRODEPORTE":"$PAGAPRODEPORTE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/pagoestampillascontercero">
		<call-query href="getOrdenescompraPagoestampillasconterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraTerceroconestampillapornumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ORDENDECOMPRA.VALORTOTAL,ORDENDECOMPRA.TERCERO,ORDENDECOMPRA.SUCURSAL  FROM ORDENDECOMPRA INNER JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO AND ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :TIPOCONTRATO AND ORDENDECOMPRA.NUMERO = :NUMEROCONTRATO AND TIPOORDENDECOMPRA.ESTAMPILLA NOT IN 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORTOTAL":"$VALORTOTAL(type:double)","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMEROCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/terceroconestampillapornumero">
		<call-query href="getOrdenescompraTerceroconestampillapornumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="NUMEROCONTRATO" query-param="NUMEROCONTRATO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPagConConvenioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, TERCERO.NOMBRE, ORDENDECOMPRA.VALORTOTAL VALOR, ORDENDECOMPRA.CLASEORDEN TIPO, ORDENDECOMPRA.DESCRIPCION,(CASE TIPOORDENDECOMPRA.CONVENIO WHEN 0 THEN 'false' ELSE 'true' END) CONVENIO FROM ORDENDECOMPRA INNER JOIN TERCERO ON ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA INNER JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND TIPOORDENDECOMPRA.CONVENIO NOT IN (0) AND EXTRACT(YEAR FROM ORDENDECOMPRA.FECHA) = :ANO ORDER BY ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","NOMBRE":"$NOMBRE","VALOR":"$VALOR(type:double)","TIPO":"$TIPO","DESCRIPCION":"$DESCRIPCION","CONVENIO":"$CONVENIO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra/conconvenio/pag">
		<call-query href="getOrdenescompraPagConConvenioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumConConvenioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, TERCERO.NOMBRE, ORDENDECOMPRA.VALORTOTAL VALOR, ORDENDECOMPRA.CLASEORDEN TIPO, ORDENDECOMPRA.DESCRIPCION,(CASE TIPOORDENDECOMPRA.CONVENIO WHEN 0 THEN 'false' ELSE 'true' END) CONVENIO FROM ORDENDECOMPRA INNER JOIN TERCERO ON ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA INNER JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND TIPOORDENDECOMPRA.CONVENIO NOT IN (0) AND EXTRACT(YEAR FROM ORDENDECOMPRA.FECHA) = :ANO ORDER BY ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/conconvenio/num">
		<call-query href="getOrdenescompraNumConConvenioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="insertOrdenescompra" keyColumns="COMPANIA,CLASEORDEN,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
