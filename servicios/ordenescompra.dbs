	<query id="updateOrdenescompraModificacionContratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET APORTESTE_AD=:APORTESTE_AD, CONSECUTIVOADICIONES=:CONSECUTIVOADICIONES, TIPODIA=:TIPODIA, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, IMPRESO=:IMPRESO, DEPENDENCIA=:DEPENDENCIA, OBJETOCONTRATO=:OBJETOCONTRATO, SUCURSALCESION=:SUCURSALCESION, NUMEROAFECTADO=:NUMEROAFECTADO, CLASENOVEDAD=:CLASENOVEDAD, NITCESION=:NITCESION, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DURACION=:DURACION, VALORTOTAL=:VALORTOTAL, CONSIDERANDOS=:CONSIDERANDOS, DESCRIPCION=:DESCRIPCION, RESOAPOLIZA=:RESOAPOLIZA, ANEXOPOLIZA=:ANEXOPOLIZA, SUCURSALINTERVENTOR=:SUCURSALINTERVENTOR, FECHAMODPOLIZA=TO_DATE(:FECHAMODPOLIZA,'DD/MM/YYYY HH24:MI:SS'), CLASEDISPONIBILIDAD=:CLASEDISPONIBILIDAD, VALORDISPONIBILIDAD=:VALORDISPONIBILIDAD, VALORRESERVA=:VALORRESERVA, DESTINO=:DESTINO, PROYECTO=:PROYECTO, INTERVENTOR=:INTERVENTOR, CEDULAINTERVENTOR=:CEDULAINTERVENTOR, CARGOINTERVENTOR=:CARGOINTERVENTOR, NUMEROCONTRATOINTERV=:NUMEROCONTRATOINTERV, VALORINTERVENCION=:VALORINTERVENCION, TIPOINTERVENTOR=:TIPOINTERVENTOR, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), TIPOAFECTADO=:TIPOAFECTADO, ORDENADOR_MODIF=:ORDENADOR_MODIF, FECHAFINALMODIF=TO_DATE(:FECHAFINALMODIF,'DD/MM/YYYY HH24:MI:SS'), FECHAFINALACTUAL=TO_DATE(:FECHAFINALACTUAL,'DD/MM/YYYY HH24:MI:SS') WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

