	<query id="getOrdenescompraPagFechaYAfectadoPorTipocontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') FECHA, CONCAT(NOMBRE , CONCAT(' - ' , NUMEROAFECTADO)) AFECTADO FROM ORDENDECOMPRA LEFT JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.TIPOAFECTADO = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:TIPOCONTRATO ORDER BY ORDENDECOMPRA.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","FECHA":"$FECHA","AFECTADO":"$AFECTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
