			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CONSTANTE_TERCERO" query-param="CONSTANTE_TERCERO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DESCRIP" query-param="DESCRIP"/>
			<with-param name="OBJETOCONTRATO" query-param="OBJETOCONTRATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumContratosegunclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ORDENDECOMPRA.NUMERO, (CONCAT(NUMEROCONTRATO ,CONCAT( ' ' ,OBJETOCONTRATO ))) DESCRIP, ORDENDECOMPRA.OBJETOCONTRATO FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:TIPOCONTRATO AND ORDENDECOMPRA.TERCERO =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL AND TRUNC(CASE WHEN FECHAFIRMA IS NULL THEN FECHA ELSE(CASE WHEN FECHAFIRMA &lt; FECHA THEN FECHAFIRMA ELSE FECHA END) END) &lt;= TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS') AND NVL(ESTADO,' ') NOT IN 'A' AND ( ORDENDECOMPRA.NITCESION =:CONSTANTE_TERCERO OR NITCESION = ' ' ) UNION SELECT ORDENDECOMPRA.NUMERO, (CONCAT( NUMEROCONTRATO ,CONCAT( ' ' ,OBJETOCONTRATO ))) DESCRIP, ORDENDECOMPRA.OBJETOCONTRATO FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:TIPOCONTRATO AND ORDENDECOMPRA.NITCESION =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL AND TRUNC(CASE WHEN FECHAFIRMA IS NULL THEN FECHA ELSE(CASE WHEN FECHAFIRMA &lt; FECHA THEN FECHAFIRMA ELSE FECHA END) END) &lt;= TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS') AND NVL(ESTADO,' ') NOT IN ( 'A' ) AND ORDENDECOMPRA.CLASENOVEDAD = 'C' ORDER BY NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIP IS NULL THEN ' ' ELSE UPPER(DESCRIP) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIP), '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CONSTANTE_TERCERO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIP" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>

	</query>
