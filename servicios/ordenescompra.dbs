	<query id="getOrdenescompraPagNumeroAfectadoEnModificacionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY')FECHA, TERCERO.NOMBRE NOMBRE_TERCERO, ORDENDECOMPRA.CLASEORDEN, TIPOORDENDECOMPRA.NOMBRE, ORDENDECOMPRA.ORDENADOR  FROM ORDENDECOMPRA LEFT JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN TIPOORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = TIPOORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TIPOORDENDECOMPRA.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.SUCURSAL = :SUCURSAL AND NVL(TIPOORDENDECOMPRA.CLASE, '') NOT IN('M') ORDER BY ORDENDECOMPRA.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END)  LIKE UPPER( '%' || :NOMBRE_TERCERO || '%')  AND (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END)  LIKE UPPER(:CLASEORDEN || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","FECHA":"$FECHA","NOMBRE_TERCERO":"$NOMBRE_TERCERO","CLASEORDEN":"$CLASEORDEN","NOMBRE":"$NOMBRE","ORDENADOR":"$ORDENADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
