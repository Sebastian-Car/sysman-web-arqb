	<query id="getOrdenescompraPagTodosportipoyterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO, DESCRIPCION FROM ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN BETWEEN :TIPOCONTRATOINICIAL AND :TIPOCONTRATOFINAL AND TERCERO BETWEEN :TERCEROINICIAL AND :TERCEROFINAL ORDER BY COMPANIA, NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
