	<query id="getOrdenescompraAnioPorTipoDeAdjudicacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(ORDENDECOMPRA.FECHA,'YYYY') ANIO  FROM ORDENDECOMPRA INNER JOIN TIPOADJUDICACION ON ORDENDECOMPRA.TIPOADJUDICACION = TIPOADJUDICACION.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.TIPOADJUDICACION = :MODALIDAD AND TO_CHAR(ORDENDECOMPRA.FECHA,'YYYY') BETWEEN :ANIOINICIAL AND :ANIOFINAL AND ORDENDECOMPRA.DEPENDENCIA = :DEPENDENCIA GROUP BY TO_CHAR(ORDENDECOMPRA.FECHA,'YYYY')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANIO":"$ANIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="ANIOINICIAL" sqlType="STRING"/>
		<param name="ANIOFINAL" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
