	<query id="getOrdenescompraConsultapotnovedadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOVEDADCONTRATO.COMPANIA, NOVEDADCONTRATO.CLASEORDEN, NOVEDADCONTRATO.ORDENDECOMPRA, NOVEDADCONTRATO.NOVEDAD, NOVEDADCONTRATO.CLASET, NOVEDADCONTRATO.TIPOT,(TO_CHAR(NOVEDADCONTRATO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(NOVEDADCONTRATO.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(NOVEDADCONTRATO.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(NOVEDADCONTRATO.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO, NOVEDADCONTRATO.ANO, NOVEDADCONTRATO.NUMERO, NOVEDADCONTRATO.VALORTOTAL, NOVEDADCONTRATO.OBSERVACIONES, NOVEDADCONTRATO.POREJECUCION, NOVEDADCONTRATO.VISITAIN, NOVEDADCONTRATO.RESULTADOS,(CASE NOVEDADCONTRATO.INDADICION WHEN 0 THEN 'false' ELSE 'true' END) INDADICION, NOVEDADCONTRATO.DIAS_CONTRATO, NOVEDADCONTRATO.VLR_ALQ_VEHICULO, CLASETRANSACCIONC.CLASENOVEDAD, CLASETRANSACCIONC.TIPOMODELO, CLASETRANSACCIONC.TIPOFORMATO, NOVEDADCONTRATO.VALOR_LIBERADO,(CASE NOVEDADCONTRATO.INDICADOR_CUMPLIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) INDICADOR_CUMPLIMIENTO, NOVEDADCONTRATO.TIPO_RETENCION, NOVEDADCONTRATO.APORTESTE, NOVEDADCONTRATO.CONSIDERANDOS, NOVEDADCONTRATO.ORDENADOR,(CASE NOVEDADCONTRATO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, NOVEDADCONTRATO.CALIFICACIONCONTR,(TO_CHAR(NOVEDADCONTRATO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, NOVEDADCONTRATO.CREATED_BY, NOVEDADCONTRATO.MODIFIED_BY,(TO_CHAR(NOVEDADCONTRATO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, NOVEDADCONTRATO.SUCURSAL, NOVEDADCONTRATO.CALIFICACION, NOVEDADCONTRATO.JUSTIFICACION, CLASETRANSACCIONC.APLICA_CALIFICACION  FROM NOVEDADCONTRATO LEFT JOIN CLASETRANSACCIONC ON NOVEDADCONTRATO.TIPOT = CLASETRANSACCIONC.TIPOT AND NOVEDADCONTRATO.CLASET = CLASETRANSACCIONC.CLASET WHERE COMPANIA = :KEY_COMPANIA AND CLASEORDEN = :KEY_CLASEORDEN AND ORDENDECOMPRA = :KEY_ORDENDECOMPRA AND NOVEDAD = :KEY_NOVEDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","NOVEDAD":"$NOVEDAD","CLASET":"$CLASET","TIPOT":"$TIPOT","FECHA":"$FECHA","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO","VALORTOTAL":"$VALORTOTAL","OBSERVACIONES":"$OBSERVACIONES","POREJECUCION":"$POREJECUCION","VISITAIN":"$VISITAIN(type:integer)","RESULTADOS":"$RESULTADOS","INDADICION":"$INDADICION(type:boolean)","DIAS_CONTRATO":"$DIAS_CONTRATO","VLR_ALQ_VEHICULO":"$VLR_ALQ_VEHICULO","CLASENOVEDAD":"$CLASENOVEDAD","TIPOMODELO":"$TIPOMODELO","TIPOFORMATO":"$TIPOFORMATO","VALOR_LIBERADO":"$VALOR_LIBERADO","INDICADOR_CUMPLIMIENTO":"$INDICADOR_CUMPLIMIENTO(type:boolean)","TIPO_RETENCION":"$TIPO_RETENCION","APORTESTE":"$APORTESTE","CONSIDERANDOS":"$CONSIDERANDOS","ORDENADOR":"$ORDENADOR","IMPRESO":"$IMPRESO(type:boolean)","CALIFICACIONCONTR":"$CALIFICACIONCONTR","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","SUCURSAL":"$SUCURSAL","CALIFICACION":"$CALIFICACION","JUSTIFICACION":"$JUSTIFICACION","APLICA_CALIFICACION":"$APLICA_CALIFICACION(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/consultapotnovedad">
		<call-query href="getOrdenescompraConsultapotnovedadQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
