    <query id="getOrdenescompraPagMovasociadocompQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO,TERCERO,TO_CHAR(FECHAFINALIZACION, 'DD/MM/YYYY') FECHAVENCIMIENTO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, DESCRIPCION FROM ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN IN (:CLASEORDEN) AND VACIA IN ('N') AND ( CASE WHEN :CLASE_MOV = 'E' OR (:CLASE_DOCASMOV = 'J' AND :CLASE_MOV = 'E') THEN ESTADO ELSE 'X' END) &lt;&gt; ('A')) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN FECHAVENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAVENCIMIENTO) END) LIKE UPPER(CONCAT(:FECHAVENCIMIENTO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","TERCERO":"$TERCERO","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="CLASE_MOV" sqlType="STRING"/>
		<param name="CLASE_DOCASMOV" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
