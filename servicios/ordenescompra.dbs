	<query id="getOrdenescompraListadosDnpQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ORDENDECOMPRA.SECTOR, AUXILIAR_COMPRO.CUENTA , AUXILIAR_COMPRO.TIPO_COMPROBANTE, AUXILIAR_COMPRO.COMPROBANTE, ORDENDECOMPRA.NOMBRE_PROGRAMA, ORDENDECOMPRA.NOMBRE_PROYECTO, :VIGENCIA VIGENCIA, TIPOADJUDICACION.DESCRIPCION AS MODALIDADDECONTRATACION, CASE WHEN AUXILIAR_COMPRO.TIPOCONTRATO='ADI' THEN 'OTROSI' ELSE AUXILIAR_COMPRO.TIPOCONTRATO END TIPOCONTRATO, AUXILIAR_COMPRO.NUMEROCONTRATO, TO_CHAR(ORDENDECOMPRA.FECHASUSCRIPCION, 'DD/MM/YYYY') FECHASUSCRIPCION, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.VALORTOTAL AS VALOR_CONTRATO, AUXILIAR_COMPRO.VALOR_REGALIAS, V_RESUMENPPTO_F.APRDEFINITIVA + V_RESUMENPPTO_F.ADICION + V_RESUMENPPTO_F.REDUCCION + V_RESUMENPPTO_F.TRASLADO AS CONSTITUCION_RESERVA, TOTAL_CHA.TOTAL_CHA, REGALIAS_EGR.REGALIAS_EGR + REGALIAS_CHA.REGALIAS_CHA AS VALOR_REGALIAS_VIGENCIAS, ORDENDECOMPRA.NOMBRECONTRATISTA, TO_CHAR(ORDENDECOMPRA.FECHAINICIO,'DD/MM/YYYY') AS FECHA, ORDENDECOMPRA.DURACION, NOVEDAD.DIAS_SUSPENSION, NOVEDAD.DIAS_PRORROGA, TO_CHAR(ORDENDECOMPRA.FECHAFINALIZACION,'DD/MM/YYYY') AS FECHAFINALIZACION, CASE TERCERO.TIPOID WHEN 'N' THEN 'NIT' WHEN 'C' THEN 'CC' WHEN 'E' THEN 'CE' WHEN 'T' THEN 'TI' WHEN 'R' THEN 'CCTR' END TIPOID, TERCERO.NIT, TERCERO.PROPIETARIO, ORDENDECOMPRA.INTERVENTOR, NVL(ORDENDECOMPRA.PORCESTADOEJECUCION,0) AS PORCENTAJE, VISITAS.VISITAS, ORDENDECOMPRA.ESTADO  FROM ORDENDECOMPRA LEFT JOIN (SELECT COMPANIA, ORDENDECOMPRA, CLASEORDEN, SUM( CASE WHEN TIPOT IN('ADI') THEN DIAS_CONTRATO ELSE 0 END) DIAS_PRORROGA, SUM( CASE WHEN TIPOT IN('ACS') THEN DIAS_CONTRATO ELSE 0 END) DIAS_SUSPENSION FROM NOVEDADCONTRATO WHERE TIPOT IN('ADI','ACS') GROUP BY COMPANIA, ORDENDECOMPRA, CLASEORDEN )NOVEDAD ON ORDENDECOMPRA.COMPANIA = NOVEDAD.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = NOVEDAD.CLASEORDEN AND ORDENDECOMPRA.NUMERO = NOVEDAD.ORDENDECOMPRA LEFT JOIN (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.NUMERO ORDENDECOMPRA, ORDENDECOMPRA.CLASEORDEN, CASE WHEN DETALLE_COMPROBANTE_CNT.NATURALEZA='D' THEN SUM(DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO) ELSE SUM(DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - DETALLE_COMPROBANTE_CNT.VALOR_DEBITO) END REGALIAS_EGR FROM ORDENDECOMPRA INNER JOIN DETALLE_COMPROBANTE_CNT ON ORDENDECOMPRA.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = DETALLE_COMPROBANTE_CNT.TIPOCONTRATO AND ORDENDECOMPRA.NUMERO = DETALLE_COMPROBANTE_CNT.NUMEROCONTRATO INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO WHERE PLAN_CONTABLE.CLASECUENTA IN('B') AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE='EGR' AND EXISTS (SELECT 'X' FROM DETALLE_COMPROBANTE_PPTAL WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE_AFECT = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.CMPTE_AFECTADO = DETALLE_COMPROBANTE_PPTAL.CMPTE_AFECTADO ) GROUP BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN, DETALLE_COMPROBANTE_CNT.NATURALEZA, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, PLAN_CONTABLE.CLASECUENTA )REGALIAS_EGR ON ORDENDECOMPRA.COMPANIA = REGALIAS_EGR.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = REGALIAS_EGR.CLASEORDEN AND ORDENDECOMPRA.NUMERO = REGALIAS_EGR.ORDENDECOMPRA LEFT JOIN (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.NUMERO ORDENDECOMPRA, ORDENDECOMPRA.CLASEORDEN, ABS(SUM( CASE WHEN DETALLE_COMPROBANTE_CNT.NATURALEZA='D' THEN DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO ELSE DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - DETALLE_COMPROBANTE_CNT.VALOR_DEBITO END)) REGALIAS_CHA FROM ORDENDECOMPRA INNER JOIN DETALLE_COMPROBANTE_CNT ON ORDENDECOMPRA.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = DETALLE_COMPROBANTE_CNT.TIPOCONTRATO AND ORDENDECOMPRA.NUMERO = DETALLE_COMPROBANTE_CNT.NUMEROCONTRATO INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND PLAN_CONTABLE.CLASECUENTA IN('E') AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE='CHA' AND EXISTS (SELECT 'X' FROM DETALLE_COMPROBANTE_PPTAL WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE_AFECT = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND DETALLE_COMPROBANTE_CNT.CMPTE_AFECTADO = DETALLE_COMPROBANTE_PPTAL.COMPROBANTE ) GROUP BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN, DETALLE_COMPROBANTE_CNT.NATURALEZA, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, PLAN_CONTABLE.CLASECUENTA )REGALIAS_CHA ON ORDENDECOMPRA.COMPANIA = REGALIAS_CHA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = REGALIAS_CHA.CLASEORDEN AND ORDENDECOMPRA.NUMERO = REGALIAS_CHA.ORDENDECOMPRA LEFT JOIN (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.NUMERO ORDENDECOMPRA, ORDENDECOMPRA.CLASEORDEN, CASE WHEN DETALLE_COMPROBANTE_CNT.NATURALEZA='D' THEN SUM(DETALLE_COMPROBANTE_CNT.VALOR_DEBITO - DETALLE_COMPROBANTE_CNT.VALOR_CREDITO) ELSE SUM(DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - DETALLE_COMPROBANTE_CNT.VALOR_DEBITO) END TOTAL_CHA FROM ORDENDECOMPRA INNER JOIN DETALLE_COMPROBANTE_CNT ON ORDENDECOMPRA.COMPANIA = DETALLE_COMPROBANTE_CNT.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = DETALLE_COMPROBANTE_CNT.TIPOCONTRATO AND ORDENDECOMPRA.NUMERO = DETALLE_COMPROBANTE_CNT.NUMEROCONTRATO INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND PLAN_CONTABLE.CLASECUENTA IN('B') AND DETALLE_COMPROBANTE_CNT.TIPO_CPTE='CHA' GROUP BY ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN, DETALLE_COMPROBANTE_CNT.NATURALEZA, DETALLE_COMPROBANTE_CNT.TIPO_CPTE, PLAN_CONTABLE.CLASECUENTA )TOTAL_CHA ON ORDENDECOMPRA.COMPANIA = TOTAL_CHA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = TOTAL_CHA.CLASEORDEN AND ORDENDECOMPRA.NUMERO = TOTAL_CHA.ORDENDECOMPRA LEFT JOIN (SELECT COMPANIA, ORDENDECOMPRA, CLASEORDEN, MAX(VISITAIN) VISITAS FROM NOVEDADCONTRATO GROUP BY COMPANIA, ORDENDECOMPRA, CLASEORDEN )VISITAS ON ORDENDECOMPRA.COMPANIA = VISITAS.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = VISITAS.CLASEORDEN AND ORDENDECOMPRA.NUMERO = VISITAS.ORDENDECOMPRA LEFT JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.TERCERO = TERCERO.NIT INNER JOIN (SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPOCONTRATO, COMPROBANTE_PPTAL.NUMEROCONTRATO, SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO) AS VALOR_CONTRATO, SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO) AS VALOR_REGALIAS, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, CASE WHEN DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE='REX' THEN 'X' ELSE '' END TIPO_COMPROBANTE FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN COMPROBANTE_PPTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COMPROBANTE_PPTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.COMPROBANTE = COMPROBANTE_PPTAL.NUMERO AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = COMPROBANTE_PPTAL.TIPO AND DETALLE_COMPROBANTE_PPTAL.ANO = COMPROBANTE_PPTAL.ANO WHERE COMPROBANTE_PPTAL.TIPOCONTRATO IS NOT NULL GROUP BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPOCONTRATO, COMPROBANTE_PPTAL.NUMEROCONTRATO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE )AUXILIAR_COMPRO ON ORDENDECOMPRA.COMPANIA = AUXILIAR_COMPRO.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = AUXILIAR_COMPRO.TIPOCONTRATO AND ORDENDECOMPRA.NUMERO = AUXILIAR_COMPRO.NUMEROCONTRATO LEFT JOIN V_RESUMENPPTO_F ON AUXILIAR_COMPRO.COMPANIA = V_RESUMENPPTO_F.COMPANIA AND AUXILIAR_COMPRO.ANO = V_RESUMENPPTO_F.ANO AND AUXILIAR_COMPRO.CUENTA = V_RESUMENPPTO_F.ID LEFT JOIN TIPOADJUDICACION ON ORDENDECOMPRA.COMPANIA = TIPOADJUDICACION.COMPANIA AND ORDENDECOMPRA.TIPOADJUDICACION = TIPOADJUDICACION.CODIGO WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.FECHA BETWEEN :FECHAINICIAL AND :FECHAFINAL AND ORDENDECOMPRA.ESTADO IN ('T','L')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SECTOR":"$SECTOR","CUENTA":"$CUENTA","TIPO_COMPROBANTE":"$TIPO_COMPROBANTE","COMPROBANTE":"$COMPROBANTE(type:long)","NOMBRE_PROGRAMA":"$NOMBRE_PROGRAMA","NOMBRE_PROYECTO":"$NOMBRE_PROYECTO","VIGENCIA":"$VIGENCIA","MODALIDADDECONTRATACION":"$MODALIDADDECONTRATACION","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO(type:long)","FECHASUSCRIPCION":"$FECHASUSCRIPCION","OBJETOCONTRATO":"$OBJETOCONTRATO","VALOR_CONTRATO":"$VALOR_CONTRATO","VALOR_REGALIAS":"$VALOR_REGALIAS(type:double)","CONSTITUCION_RESERVA":"$CONSTITUCION_RESERVA(type:integer)","TOTAL_CHA":"$TOTAL_CHA(type:double)","VALOR_REGALIAS_VIGENCIAS":"$VALOR_REGALIAS_VIGENCIAS(type:integer)","NOMBRECONTRATISTA":"$NOMBRECONTRATISTA","FECHA":"$FECHA","DURACION":"$DURACION","DIAS_SUSPENSION":"$DIAS_SUSPENSION(type:double)","DIAS_PRORROGA":"$DIAS_PRORROGA(type:double)","FECHAFINALIZACION":"$FECHAFINALIZACION","TIPOID":"$TIPOID","NIT":"$NIT","PROPIETARIO":"$PROPIETARIO","INTERVENTOR":"$INTERVENTOR","PORCENTAJE":"$PORCENTAJE(type:integer)","VISITAS":"$VISITAS(type:double)","ESTADO":"$ESTADO"}]}}		</result>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/listadosdnp">
		<call-query href="getOrdenescompraListadosDnpQuery">
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumeroPorClaseordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/numeroporclaseorden">
		<call-query href="getOrdenescompraNumeroPorClaseordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>

		</call-query>
	</resource>
	<query id="updateOrdenescompraValorTotalPorClaseYNumero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA  SET VALORTOTAL    = :VALORTOTAL,     DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),     MODIFIED_BY   = :MODIFIED_BY WHERE COMPANIA    = :COMPANIA   AND CLASEORDEN  = :CLASEORDEN   AND NUMERO      = :NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/valortotalporclaseynumero">
		<call-query href="updateOrdenescompraValorTotalPorClaseYNumero">
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="updateOrdenescompraOrdenadorModif" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA  SET ORDENADOR_MODIF = :ORDENADORMODIF ,  DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),MODIFIED_BY=:MODIFIED_BY  WHERE COMPANIA        = :COMPANIA   AND CLASEORDEN      = :TIPOAFECTADO   AND NUMERO          = :NUMEROAFECTADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ORDENADORMODIF" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOAFECTADO" sqlType="STRING"/>
		<param name="NUMEROAFECTADO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/ordenadormodif">
		<call-query href="updateOrdenescompraOrdenadorModif">
			<with-param name="ORDENADORMODIF" query-param="ORDENADORMODIF"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOAFECTADO" query-param="TIPOAFECTADO"/>
			<with-param name="NUMEROAFECTADO" query-param="NUMEROAFECTADO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPlazosDeOrdenQuery"  useConfig="sysmandsunist">
		<sql>SELECT VALORTOTAL, VALORFINAL,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, PLAZODEENTREGA,(TO_CHAR(NVL(FECHAFINALMODIF,FECHAFINALIZACION),'DD/MM/YYYY HH24:MI:SS')) FECHAFINALIZACION, DURACION FROM ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORTOTAL":"$VALORTOTAL","VALORFINAL":"$VALORFINAL","FECHA":"$FECHA","PLAZODEENTREGA":"$PLAZODEENTREGA","FECHAFINALIZACION":"$FECHAFINALIZACION","DURACION":"$DURACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/plazosdeorden">
		<call-query href="getOrdenescompraPlazosDeOrdenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="updateOrdenescompraPorPlazos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ORDENDECOMPRA SET VALORTOTAL = :VALORTOTAL , PLAZODEENTREGA = :PLAZOENTREGA, FECHAFINALIZACION = :FECHAFINALIZACION,     DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA    = :COMPANIA   AND CLASEORDEN  = :CLASEORDEN   AND NUMERO      = :NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PLAZOENTREGA" sqlType="STRING"/>
		<param name="FECHAFINALIZACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ordenescompra/porplazos">
		<call-query href="updateOrdenescompraPorPlazos">
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
