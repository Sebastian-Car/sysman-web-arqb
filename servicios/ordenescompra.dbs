	<query id="getOrdenescompraPagAfectacionManualQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ORDENDECOMPRA.COMPANIA COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, TRIM(TERCERO.NOMBRE) NOMBRETERCERO, ORDENDECOMPRA.DESCRIPCION, CASE ORDENDECOMPRA.VACIA WHEN 'S' THEN 'SI' WHEN 'N' THEN 'NO' END VACIALB, ORDENDECOMPRA.VACIA, ORDENDECOMPRA.USUARIOAFECTO,(TO_CHAR(ORDENDECOMPRA.FECHAAFECTO,'DD/MM/YYYY HH24:MI:SS')) FECHAAFECTO FROM ORDENDECOMPRA INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL WHERE ORDENDECOMPRA.VACIA = 'N' AND ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CODIGO ORDER BY ORDENDECOMPRA.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN VACIALB IS NULL THEN ' ' ELSE UPPER(VACIALB) END)  LIKE UPPER( '%' || :VACIALB || '%')  AND (CASE WHEN USUARIOAFECTO IS NULL THEN ' ' ELSE UPPER(USUARIOAFECTO) END)  LIKE UPPER( '%' || :USUARIOAFECTO || '%')  AND (CASE WHEN FECHAAFECTO IS NULL THEN ' ' ELSE UPPER(FECHAAFECTO) END)  LIKE UPPER( '%' || :FECHAAFECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","NOMBRETERCERO":"$NOMBRETERCERO","DESCRIPCION":"$DESCRIPCION","VACIALB":"$VACIALB","VACIA":"$VACIA","USUARIOAFECTO":"$USUARIOAFECTO","FECHAAFECTO":"$FECHAAFECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VACIALB" sqlType="STRING"/>
		<param name="USUARIOAFECTO" sqlType="STRING"/>
		<param name="FECHAAFECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
