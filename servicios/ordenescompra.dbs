	<query id="getOrdenescompraExpedidcedporintervQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TERCERO.EXPEDIDACEDULA  FROM ORDENDECOMPRA INNER JOIN TERCERO ON (ORDENDECOMPRA.INTERVENTOR = TERCERO.NOMBRE) AND (ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA) AND (ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL) WHERE ORDENDECOMPRA.NUMERO = :NUMERO AND ORDENDECOMPRA.COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXPEDIDACEDULA":"$EXPEDIDACEDULA"}]}}		</result>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
