	<query id="deleteOrdenescompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ordenescompra">
		<call-query href="deleteOrdenescompra">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, DEPENDENCIA.NOMBRE, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') FECHA, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.MODIFICACION_TIEMPO FROM ORDENDECOMPRA INNER JOIN DEPENDENCIA ON ORDENDECOMPRA.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDECOMPRA.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:CLASEF AND TO_CHAR(ORDENDECOMPRA.FECHA,'YYYY') =:ANO ORDER BY ORDENDECOMPRA.FECHA DESC, ORDENDECOMPRA.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) AND (CASE WHEN MODIFICACION_TIEMPO IS NULL THEN ' ' ELSE UPPER(MODIFICACION_TIEMPO) END) LIKE UPPER(CONCAT(:MODIFICACION_TIEMPO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","NOMBRE":"$NOMBRE","FECHA":"$FECHA","OBJETOCONTRATO":"$OBJETOCONTRATO","MODIFICACION_TIEMPO":"$MODIFICACION_TIEMPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEF" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>
		<param name="MODIFICACION_TIEMPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ordenescompra">
		<call-query href="getOrdenescompraPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEF" query-param="CLASEF"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBJETOCONTRATO" query-param="OBJETOCONTRATO"/>
			<with-param name="MODIFICACION_TIEMPO" query-param="MODIFICACION_TIEMPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, DEPENDENCIA.NOMBRE, TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY') FECHA, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.MODIFICACION_TIEMPO FROM ORDENDECOMPRA INNER JOIN DEPENDENCIA ON ORDENDECOMPRA.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDECOMPRA.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL WHERE ORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.CLASEORDEN =:CLASEF AND TO_CHAR(ORDENDECOMPRA.FECHA,'YYYY') =:ANO ORDER BY ORDENDECOMPRA.FECHA DESC, ORDENDECOMPRA.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) AND (CASE WHEN MODIFICACION_TIEMPO IS NULL THEN ' ' ELSE UPPER(MODIFICACION_TIEMPO) END) LIKE UPPER(CONCAT(:MODIFICACION_TIEMPO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEF" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>
		<param name="MODIFICACION_TIEMPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/numero">
		<call-query href="getOrdenescompraNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEF" query-param="CLASEF"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBJETOCONTRATO" query-param="OBJETOCONTRATO"/>
			<with-param name="MODIFICACION_TIEMPO" query-param="MODIFICACION_TIEMPO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT ORDENDECOMPRA.COMPANIA,(TO_CHAR(ORDENDECOMPRA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(ORDENDECOMPRA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ORDENDECOMPRA.MODIFIED_BY, ORDENDECOMPRA.CREATED_BY, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.FUNCION, ORDENDECOMPRA.CLASE, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.SUCURSAL, ORDENDECOMPRA.VALORTOTALOP, ORDENDECOMPRA.DEPENDENCIA, ORDENDECOMPRA.ORDENADOR, ORDENDECOMPRA.CODEQUIVALENTE,(TO_CHAR(ORDENDECOMPRA.FECHABANCOPROYECTOS,'DD/MM/YYYY HH24:MI:SS')) FECHABANCOPROYECTOS,(TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(ORDENDECOMPRA.FECHAFINALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALIZACION,(TO_CHAR(ORDENDECOMPRA.FECHADILIGENCIAMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHADILIGENCIAMIENTO, ORDENDECOMPRA.DURACION, ORDENDECOMPRA.PLAZODEENTREGA, ORDENDECOMPRA.UNIDAD_PLAZO, ORDENDECOMPRA.TIPODIA, ORDENDECOMPRA.LUGARDEENTREGA, ORDENDECOMPRA.SUCURSALINTERVENTOR, ORDENDECOMPRA.CLASECONTRATO, ORDENDECOMPRA.SUCURSAL_ORDENADOR, ORDENDECOMPRA.TIPOADJUDICACION, ORDENDECOMPRA.SECTOR, ORDENDECOMPRA.TIPOLOGIA, ORDENDECOMPRA.HONORARIOS, ORDENDECOMPRA.NUMEROACTA, ORDENDECOMPRA.TIPO_CONTRATO_CAS, ORDENDECOMPRA.R6_CLASIFICACION,(CASE ORDENDECOMPRA.INFORMESAUDITORIA WHEN 0 THEN 'false' ELSE 'true' END) INFORMESAUDITORIA,(CASE ORDENDECOMPRA.ACTUALIZAPLANDECOMPRAS WHEN 0 THEN 'false' ELSE 'true' END) ACTUALIZAPLANDECOMPRAS,(CASE ORDENDECOMPRA.EMERGENCIAIN WHEN 0 THEN 'false' ELSE 'true' END) EMERGENCIAIN,(CASE ORDENDECOMPRA.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, ORDENDECOMPRA.NUMPERSONASCONTRATADAS, ORDENDECOMPRA.FORMADEPAGO, ORDENDECOMPRA.GARANTIA, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.VEHICULO, ORDENDECOMPRA.CONSIDERANDOS, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.VALORFINAL, ORDENDECOMPRA.MONEDAPAGO, ORDENDECOMPRA.TOPEVEHICULO, ORDENDECOMPRA.MONEDAREF, ORDENDECOMPRA.PORC_ANTICIPO, ORDENDECOMPRA.VALOR_ANTICIPO, ORDENDECOMPRA.VALORMONEDAREF, ORDENDECOMPRA.APORTESTE, ORDENDECOMPRA.APORTESEN,(CASE ORDENDECOMPRA.CONVENIO WHEN 0 THEN 'false' ELSE 'true' END) CONVENIO, ORDENDECOMPRA.CLASE_CONVENIO, ORDENDECOMPRA.NUM_CONVENIO, ORDENDECOMPRA.TIPOCONTR_SECOP,(CASE ORDENDECOMPRA.IMPORTARPRE WHEN 0 THEN 'false' ELSE 'true' END) IMPORTARPRE, ORDENDECOMPRA.PORCIVAGLOBAL, ORDENDECOMPRA.PORCDESCGLOBAL, ORDENDECOMPRA.PORADMINISTRACION, ORDENDECOMPRA.PORINPREVISTOS,(CASE ORDENDECOMPRA.REPORTAR_SICE WHEN 0 THEN 'false' ELSE 'true' END) REPORTAR_SICE, ORDENDECOMPRA.PORUTILIDADES,(CASE ORDENDECOMPRA.PRECIOS_UNITARIOS WHEN 0 THEN 'false' ELSE 'true' END) PRECIOS_UNITARIOS, ORDENDECOMPRA.NOMBRECONTRATISTA, ORDENDECOMPRA.CEDULACONTRATISTA, ORDENDECOMPRA.PROFESION,(TO_CHAR(ORDENDECOMPRA.FECHA_NACTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_NACTO, ORDENDECOMPRA.TIPOCONTRATISTA, ORDENDECOMPRA.EXPERIENCIA, ORDENDECOMPRA.CALIFICACION, ORDENDECOMPRA.FACULTADESCONTRATISTA, ORDENDECOMPRA.OBLIGACIONC, ORDENDECOMPRA.NORMASAPLICA, ORDENDECOMPRA.OBLIGACIONESENTIDAD, ORDENDECOMPRA.NOTAS, ORDENDECOMPRA.DESC_ESTPREVIOS, ORDENDECOMPRA.CAPACIDADTOTALCONTRATACION, ORDENDECOMPRA.CAPACIDADRESIDUAL, ORDENDECOMPRA.INTERVENTOR, ORDENDECOMPRA.CEDULAINTERVENTOR, ORDENDECOMPRA.CARGOINTERVENTOR, ORDENDECOMPRA.TIPOINTERVENTOR, ORDENDECOMPRA.ACTO_ADMIN_INTERVENTOR, ORDENDECOMPRA.NUMEROCONTRATOINTERV, ORDENDECOMPRA.VALORINTERVENCION, TERCERO.CODIGORUP, ORDENDECOMPRA.ESTADO, ORDENDECOMPRA.PORCESTADOEJECUCION, ORDENDECOMPRA.CUMPLIMIENTO,(TO_CHAR(ORDENDECOMPRA.FECHAPOLIZAS,'DD/MM/YYYY HH24:MI:SS')) FECHAPOLIZAS, ORDENDECOMPRA.RESOPOLIZA, ORDENDECOMPRA.CLASIFICACIONCC, ORDENDECOMPRA.REGISTROBPI, ORDENDECOMPRA.ACTOAPERTURA, ORDENDECOMPRA.ESTUDIOSPREVIOS, ORDENDECOMPRA.ACTA_LIQUIDACION, ORDENDECOMPRA.VALORPAGOS, ORDENDECOMPRA.VALRECIBO, ORDENDECOMPRA.ENTRECAUDA, ORDENDECOMPRA.RECPUBLICACION, ORDENDECOMPRA.NROLICITACION, ORDENDECOMPRA.NROINVITACION, ORDENDECOMPRA.NUMRECIBO, ORDENDECOMPRA.NOPROCESO,(CASE ORDENDECOMPRA.LICITACIONOCONCURSO WHEN 0 THEN 'false' ELSE 'true' END) LICITACIONOCONCURSO,(CASE ORDENDECOMPRA.TERMINOSDEREFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) TERMINOSDEREFERENCIA, ORDENDECOMPRA.NOMBRE_PROGRAMA, ORDENDECOMPRA.NOMBRE_PROYECTO, ORDENDECOMPRA.PERS_INV_CONTRATO,(TO_CHAR(ORDENDECOMPRA.FECHAPREPLIEGOS,'DD/MM/YYYY HH24:MI:SS')) FECHAPREPLIEGOS,(TO_CHAR(ORDENDECOMPRA.FECHATERDEFINITIVOS,'DD/MM/YYYY HH24:MI:SS')) FECHATERDEFINITIVOS,(TO_CHAR(ORDENDECOMPRA.FECHAFIJACION,'DD/MM/YYYY HH24:MI:SS')) FECHAFIJACION,(TO_CHAR(ORDENDECOMPRA.FECHADESFIJACION,'DD/MM/YYYY HH24:MI:SS')) FECHADESFIJACION,(TO_CHAR(ORDENDECOMPRA.FECHAAPERTURA,'DD/MM/YYYY HH24:MI:SS')) FECHAAPERTURA,(TO_CHAR(ORDENDECOMPRA.FECHACIERRE,'DD/MM/YYYY HH24:MI:SS')) FECHACIERRE,(TO_CHAR(ORDENDECOMPRA.FECHAADJUDICACION,'DD/MM/YYYY HH24:MI:SS')) FECHAADJUDICACION,(TO_CHAR(ORDENDECOMPRA.FECHALEGALIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHALEGALIZACION,(TO_CHAR(ORDENDECOMPRA.FECHAPUBLICACION,'DD/MM/YYYY HH24:MI:SS')) FECHAPUBLICACION,(TO_CHAR(ORDENDECOMPRA.FECHASUSCRIPCION,'DD/MM/YYYY HH24:MI:SS')) FECHASUSCRIPCION,(TO_CHAR(ORDENDECOMPRA.FECHAPAGOS,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOS,(TO_CHAR(ORDENDECOMPRA.FECHAPSUSPENSION,'DD/MM/YYYY HH24:MI:SS')) FECHAPSUSPENSION,(TO_CHAR(ORDENDECOMPRA.FECHAREINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAREINICIO,(TO_CHAR(ORDENDECOMPRA.FECHARECIBO,'DD/MM/YYYY HH24:MI:SS')) FECHARECIBO,(TO_CHAR(ORDENDECOMPRA.FECHAEVALUACION,'DD/MM/YYYY HH24:MI:SS')) FECHAEVALUACION,(TO_CHAR(ORDENDECOMPRA.FECHAANULACION,'DD/MM/YYYY HH24:MI:SS')) FECHAANULACION,(TO_CHAR(ORDENDECOMPRA.FECHALIQUIDACION,'DD/MM/YYYY HH24:MI:SS')) FECHALIQUIDACION,(TO_CHAR(ORDENDECOMPRA.FECHARECPUBLIC,'DD/MM/YYYY HH24:MI:SS')) FECHARECPUBLIC,(TO_CHAR(ORDENDECOMPRA.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(ORDENDECOMPRA.FECHAFIRMA,'DD/MM/YYYY HH24:MI:SS')) FECHAFIRMA,(TO_CHAR(ORDENDECOMPRA.FECHAINVITACION,'DD/MM/YYYY HH24:MI:SS')) FECHAINVITACION,(CASE ORDENDECOMPRA.INDICADORCUMPLIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) INDICADORCUMPLIMIENTO,(CASE ORDENDECOMPRA.INDICADORENVIO WHEN 0 THEN 'false' ELSE 'true' END) INDICADORENVIO, ORDENDECOMPRA.CLASEDISPONIBILIDAD, V_ORDENDECOMPRA_AUX.AUXILIAR, ORDENDECOMPRA.DESTINO, ORDENDECOMPRA.COMPONENTEBP, ORDENDECOMPRA.VALORDISPONIBILIDAD, ORDENDECOMPRA.VALORRESERVA, ORDENDECOMPRA.DESCRIPCION, V_ORDENDECOMPRA_FTERECURSO.FUENTE_RECURSO FUENTERECURSOS, V_ORDENDECOMPRA_DIS.COMPROBANTES DISPONIBILIDAD, V_ORDENDECOMPRA_DIS.FECHACDP FECHADEDISPONIBILIDAD, V_ORDENDECOMPRA_RUBRO.RUBRONOMBRE RUBRO, V_ORDENDECOMPRA_RUBRO.RUBRO CODIGOS_RUBROS, V_ORDENDECOMPRA_RUBRO.RUBRONOMBRE DESCRIPCION_RUBROS, V_ORDENDECOMPRA_RES.NUMERO RESERVA, V_ORDENDECOMPRA_RES.FECHACDP FECHAREGISTRO, V_ORDENDECOMPRA_RES.COMPROBANTES RUBRORESERVA, ORDENDECOMPRA.SUCURSALCONTRATISTA,(TO_CHAR(ORDENDECOMPRA.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(ORDENDECOMPRA.FECHAFINALMODIF,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALMODIF, ORDENDECOMPRA.CGR_TIPO_GASTO, ORDENDECOMPRA.CGR_CONCEPTO, ORDENDECOMPRA.CGR_SEGMENTO, ORDENDECOMPRA.DESTINOFIN, ORDENDECOMPRA.ANTCAMORTIZADO, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, ORDENDECOMPRA.MODIFICACION_TIEMPO, ORDENDECOMPRA.LINK_SECOPII,(TO_CHAR(ORDENDECOMPRA.FECHAFINALN,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALN, ORDENDECOMPRA.FUENTEDERECURSO, ORDENDECOMPRA.ABOGADOENCARG, TERCERO1.NOMBRE NOMBREABOG, TERCERO1.CARGO CARGOABOG, TO_CHAR(ORDENDECOMPRA.PLATAFORMA) AS PLATAFORMA, ORDENDECOMPRA.EQUIV_SIGEC, ORDENDECOMPRA.CONTSECOP, ORDENDECOMPRA.VLR_DEVUELTO, ORDENDECOMPRA.EQUIV_SECOP,(CASE ORDENDECOMPRA.SUJETOAREPORTAR WHEN 0 THEN 'false' ELSE 'true' END) SUJETOAREPORTAR,(CASE ORDENDECOMPRA.APLICA_ACTAS_INICIO WHEN 0 THEN 'false' ELSE 'true' END) APLICA_ACTAS_INICIO,(TO_CHAR(ORDENDECOMPRA.FECHADEENTREGA,'DD/MM/YYYY HH24:MI:SS')) FECHADEENTREGA FROM ORDENDECOMPRA INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN V_ORDENDECOMPRA_DIS ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_DIS.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_DIS.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_DIS.NUMERO LEFT JOIN V_ORDENDECOMPRA_RES ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_RES.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_RES.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_RES.NUMERO LEFT JOIN V_ORDENDECOMPRA_RUBRO ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_RUBRO.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_RUBRO.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_RUBRO.NUMERO LEFT JOIN V_ORDENDECOMPRA_FTERECURSO ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_FTERECURSO.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_FTERECURSO.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_FTERECURSO.NUMERO LEFT JOIN V_ORDENDECOMPRA_AUX ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_AUX.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_AUX.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_AUX.NUMERO LEFT JOIN DEPENDENCIA ON ORDENDECOMPRA.COMPANIA = DEPENDENCIA.COMPANIA AND ORDENDECOMPRA.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN TERCERO TERCERO1 ON ORDENDECOMPRA.COMPANIA = TERCERO1.COMPANIA AND ORDENDECOMPRA.ABOGADOENCARG = TERCERO1.NIT WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","CREATED_BY":"$CREATED_BY","NUMERO":"$NUMERO","CLASEORDEN":"$CLASEORDEN","FUNCION":"$FUNCION","CLASE":"$CLASE","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","VALORTOTALOP":"$VALORTOTALOP","DEPENDENCIA":"$DEPENDENCIA","ORDENADOR":"$ORDENADOR","CODEQUIVALENTE":"$CODEQUIVALENTE","FECHABANCOPROYECTOS":"$FECHABANCOPROYECTOS","FECHA":"$FECHA","FECHAFINALIZACION":"$FECHAFINALIZACION","FECHADILIGENCIAMIENTO":"$FECHADILIGENCIAMIENTO","DURACION":"$DURACION","PLAZODEENTREGA":"$PLAZODEENTREGA","UNIDAD_PLAZO":"$UNIDAD_PLAZO","TIPODIA":"$TIPODIA","LUGARDEENTREGA":"$LUGARDEENTREGA","SUCURSALINTERVENTOR":"$SUCURSALINTERVENTOR","CLASECONTRATO":"$CLASECONTRATO","SUCURSAL_ORDENADOR":"$SUCURSAL_ORDENADOR","TIPOADJUDICACION":"$TIPOADJUDICACION","SECTOR":"$SECTOR","TIPOLOGIA":"$TIPOLOGIA","HONORARIOS":"$HONORARIOS","NUMEROACTA":"$NUMEROACTA","TIPO_CONTRATO_CAS":"$TIPO_CONTRATO_CAS","R6_CLASIFICACION":"$R6_CLASIFICACION","INFORMESAUDITORIA":"$INFORMESAUDITORIA(type:boolean)","ACTUALIZAPLANDECOMPRAS":"$ACTUALIZAPLANDECOMPRAS(type:boolean)","EMERGENCIAIN":"$EMERGENCIAIN(type:boolean)","IMPRESO":"$IMPRESO(type:boolean)","NUMPERSONASCONTRATADAS":"$NUMPERSONASCONTRATADAS","FORMADEPAGO":"$FORMADEPAGO","GARANTIA":"$GARANTIA","OBJETOCONTRATO":"$OBJETOCONTRATO","VEHICULO":"$VEHICULO","CONSIDERANDOS":"$CONSIDERANDOS","VALORTOTAL":"$VALORTOTAL","VALORFINAL":"$VALORFINAL","MONEDAPAGO":"$MONEDAPAGO","TOPEVEHICULO":"$TOPEVEHICULO","MONEDAREF":"$MONEDAREF","PORC_ANTICIPO":"$PORC_ANTICIPO","VALOR_ANTICIPO":"$VALOR_ANTICIPO","VALORMONEDAREF":"$VALORMONEDAREF","APORTESTE":"$APORTESTE","APORTESEN":"$APORTESEN","CONVENIO":"$CONVENIO(type:boolean)","CLASE_CONVENIO":"$CLASE_CONVENIO","NUM_CONVENIO":"$NUM_CONVENIO","TIPOCONTR_SECOP":"$TIPOCONTR_SECOP","IMPORTARPRE":"$IMPORTARPRE(type:boolean)","PORCIVAGLOBAL":"$PORCIVAGLOBAL","PORCDESCGLOBAL":"$PORCDESCGLOBAL","PORADMINISTRACION":"$PORADMINISTRACION","PORINPREVISTOS":"$PORINPREVISTOS","REPORTAR_SICE":"$REPORTAR_SICE(type:boolean)","PORUTILIDADES":"$PORUTILIDADES","PRECIOS_UNITARIOS":"$PRECIOS_UNITARIOS(type:boolean)","NOMBRECONTRATISTA":"$NOMBRECONTRATISTA","CEDULACONTRATISTA":"$CEDULACONTRATISTA","PROFESION":"$PROFESION","FECHA_NACTO":"$FECHA_NACTO","TIPOCONTRATISTA":"$TIPOCONTRATISTA","EXPERIENCIA":"$EXPERIENCIA","CALIFICACION":"$CALIFICACION","FACULTADESCONTRATISTA":"$FACULTADESCONTRATISTA","OBLIGACIONC":"$OBLIGACIONC","NORMASAPLICA":"$NORMASAPLICA","OBLIGACIONESENTIDAD":"$OBLIGACIONESENTIDAD","NOTAS":"$NOTAS","DESC_ESTPREVIOS":"$DESC_ESTPREVIOS","CAPACIDADTOTALCONTRATACION":"$CAPACIDADTOTALCONTRATACION","CAPACIDADRESIDUAL":"$CAPACIDADRESIDUAL","INTERVENTOR":"$INTERVENTOR","CEDULAINTERVENTOR":"$CEDULAINTERVENTOR","CARGOINTERVENTOR":"$CARGOINTERVENTOR","TIPOINTERVENTOR":"$TIPOINTERVENTOR","ACTO_ADMIN_INTERVENTOR":"$ACTO_ADMIN_INTERVENTOR","NUMEROCONTRATOINTERV":"$NUMEROCONTRATOINTERV","VALORINTERVENCION":"$VALORINTERVENCION","CODIGORUP":"$CODIGORUP","ESTADO":"$ESTADO","PORCESTADOEJECUCION":"$PORCESTADOEJECUCION","CUMPLIMIENTO":"$CUMPLIMIENTO","FECHAPOLIZAS":"$FECHAPOLIZAS","RESOPOLIZA":"$RESOPOLIZA","CLASIFICACIONCC":"$CLASIFICACIONCC","REGISTROBPI":"$REGISTROBPI","ACTOAPERTURA":"$ACTOAPERTURA","ESTUDIOSPREVIOS":"$ESTUDIOSPREVIOS","ACTA_LIQUIDACION":"$ACTA_LIQUIDACION","VALORPAGOS":"$VALORPAGOS","VALRECIBO":"$VALRECIBO","ENTRECAUDA":"$ENTRECAUDA","RECPUBLICACION":"$RECPUBLICACION","NROLICITACION":"$NROLICITACION","NROINVITACION":"$NROINVITACION","NUMRECIBO":"$NUMRECIBO","NOPROCESO":"$NOPROCESO","LICITACIONOCONCURSO":"$LICITACIONOCONCURSO(type:boolean)","TERMINOSDEREFERENCIA":"$TERMINOSDEREFERENCIA(type:boolean)","NOMBRE_PROGRAMA":"$NOMBRE_PROGRAMA","NOMBRE_PROYECTO":"$NOMBRE_PROYECTO","PERS_INV_CONTRATO":"$PERS_INV_CONTRATO","FECHAPREPLIEGOS":"$FECHAPREPLIEGOS","FECHATERDEFINITIVOS":"$FECHATERDEFINITIVOS","FECHAFIJACION":"$FECHAFIJACION","FECHADESFIJACION":"$FECHADESFIJACION","FECHAAPERTURA":"$FECHAAPERTURA","FECHACIERRE":"$FECHACIERRE","FECHAADJUDICACION":"$FECHAADJUDICACION","FECHALEGALIZACION":"$FECHALEGALIZACION","FECHAPUBLICACION":"$FECHAPUBLICACION","FECHASUSCRIPCION":"$FECHASUSCRIPCION","FECHAPAGOS":"$FECHAPAGOS","FECHAPSUSPENSION":"$FECHAPSUSPENSION","FECHAREINICIO":"$FECHAREINICIO","FECHARECIBO":"$FECHARECIBO","FECHAEVALUACION":"$FECHAEVALUACION","FECHAANULACION":"$FECHAANULACION","FECHALIQUIDACION":"$FECHALIQUIDACION","FECHARECPUBLIC":"$FECHARECPUBLIC","FECHAINICIO":"$FECHAINICIO","FECHAFIRMA":"$FECHAFIRMA","FECHAINVITACION":"$FECHAINVITACION","INDICADORCUMPLIMIENTO":"$INDICADORCUMPLIMIENTO(type:boolean)","INDICADORENVIO":"$INDICADORENVIO(type:boolean)","CLASEDISPONIBILIDAD":"$CLASEDISPONIBILIDAD","AUXILIAR":"$AUXILIAR","DESTINO":"$DESTINO","COMPONENTEBP":"$COMPONENTEBP","VALORDISPONIBILIDAD":"$VALORDISPONIBILIDAD","VALORRESERVA":"$VALORRESERVA","DESCRIPCION":"$DESCRIPCION","FUENTERECURSOS":"$FUENTERECURSOS","DISPONIBILIDAD":"$DISPONIBILIDAD","FECHADEDISPONIBILIDAD":"$FECHADEDISPONIBILIDAD","RUBRO":"$RUBRO","CODIGOS_RUBROS":"$CODIGOS_RUBROS","DESCRIPCION_RUBROS":"$DESCRIPCION_RUBROS","RESERVA":"$RESERVA","FECHAREGISTRO":"$FECHAREGISTRO","RUBRORESERVA":"$RUBRORESERVA","SUCURSALCONTRATISTA":"$SUCURSALCONTRATISTA","FECHAFINAL":"$FECHAFINAL","FECHAFINALMODIF":"$FECHAFINALMODIF","CGR_TIPO_GASTO":"$CGR_TIPO_GASTO","CGR_CONCEPTO":"$CGR_CONCEPTO","CGR_SEGMENTO":"$CGR_SEGMENTO","DESTINOFIN":"$DESTINOFIN","ANTCAMORTIZADO":"$ANTCAMORTIZADO","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","MODIFICACION_TIEMPO":"$MODIFICACION_TIEMPO","LINK_SECOPII":"$LINK_SECOPII","FECHAFINALN":"$FECHAFINALN","FUENTEDERECURSO":"$FUENTEDERECURSO","ABOGADOENCARG":"$ABOGADOENCARG","NOMBREABOG":"$NOMBREABOG","CARGOABOG":"$CARGOABOG","PLATAFORMA":"$PLATAFORMA","EQUIV_SIGEC":"$EQUIV_SIGEC","CONTSECOP":"$CONTSECOP","VLR_DEVUELTO":"$VLR_DEVUELTO","EQUIV_SECOP":"$EQUIV_SECOP","SUJETOAREPORTAR":"$SUJETOAREPORTAR(type:boolean)","APLICA_ACTAS_INICIO":"$APLICA_ACTAS_INICIO(type:boolean)","FECHADEENTREGA":"$FECHADEENTREGA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/data">
		<call-query href="getOrdenescompraRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
