			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getOrdenescompraNumPorauxtipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ORDENDECOMPRA.NUMERO, TERCERO.NOMBRE, ORDENDECOMPRA.DESCRIPCION  FROM ORDENDECOMPRA LEFT JOIN TERCERO ON ORDENDECOMPRA.TERCERO = TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL = TERCERO.SUCURSAL AND ORDENDECOMPRA.COMPANIA = TERCERO.COMPANIA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :AUXTIPO ORDER BY ORDENDECOMPRA.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
