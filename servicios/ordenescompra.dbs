	<query id="getOrdenescompraGenModiContratosQuery"  useConfig="sysmandsunist">
		<sql>SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.NUMERO, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.CONSECUTIVOADICIONES, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.TIPODIA, ORDENDECOMPRA.APORTESTE_AD, ORDENDECOMPRA.CONSECUTIVOADICIONES, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.SUCURSAL,(CASE ORDENDECOMPRA.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, ORDENDECOMPRA.DEPENDENCIA, ORDENDECOMPRA.OBJETOCONTRATO, ORDENDECOMPRA.SUCURSALCESION, ORDENDECOMPRA.NUMEROAFECTADO, ORDENDECOMPRA.CLASENOVEDAD,ORDENDECOMPRA.SUCURSALINTERVENTOR, ORDENDECOMPRA.NITCESION,(TO_CHAR(ORDENDECOMPRA.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(ORDENDECOMPRA.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(ORDENDECOMPRA.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO,(TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ORDENDECOMPRA.DURACION, ORDENDECOMPRA.VALORTOTAL, ORDENDECOMPRA.CONSIDERANDOS, ORDENDECOMPRA.DESCRIPCION, ORDENDECOMPRA.RESOAPOLIZA, ORDENDECOMPRA.ANEXOPOLIZA,(TO_CHAR(ORDENDECOMPRA.FECHAMODPOLIZA,'DD/MM/YYYY HH24:MI:SS')) FECHAMODPOLIZA, ORDENDECOMPRA.CLASEDISPONIBILIDAD, V_ORDENDECOMPRA_RES.NUMERO RESERVA, V_ORDENDECOMPRA_RES.FECHACDP FECHAREGISTRO, V_ORDENDECOMPRA_RES.COMPROBANTES RUBRORESERVA, ORDENDECOMPRA.VALORDISPONIBILIDAD, ORDENDECOMPRA.VALORRESERVA, ORDENDECOMPRA.DESTINO, ORDENDECOMPRA.PROYECTO, ORDENDECOMPRA.INTERVENTOR, ORDENDECOMPRA.CEDULAINTERVENTOR, ORDENDECOMPRA.CARGOINTERVENTOR, ORDENDECOMPRA.NUMEROCONTRATOINTERV, ORDENDECOMPRA.VALORINTERVENCION, ORDENDECOMPRA.TIPOINTERVENTOR, ORDENDECOMPRA.CREATED_BY,(TO_CHAR(ORDENDECOMPRA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, ORDENDECOMPRA.MODIFIED_BY,(TO_CHAR(ORDENDECOMPRA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ORDENDECOMPRA.TIPOAFECTADO, ORDENDECOMPRA.ORDENADOR_MODIF,(TO_CHAR(ORDENDECOMPRA.FECHAFINALMODIF,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALMODIF,(TO_CHAR(ORDENDECOMPRA.FECHAFINALACTUAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINALACTUAL, TERCERO.NOMBRE NOMBRETERCERO, V_ORDENDECOMPRA_FTERECURSO.FUENTE_RECURSO FUENTERECURSOS, V_ORDENDECOMPRA_DIS.COMPROBANTES DISPONIBILIDAD, V_ORDENDECOMPRA_DIS.FECHACDP FECHADEDISPONIBILIDAD, V_ORDENDECOMPRA_RUBRO.RUBRO FROM ORDENDECOMPRA INNER JOIN TERCERO ON ORDENDECOMPRA.COMPANIA=TERCERO.COMPANIA AND ORDENDECOMPRA.TERCERO=TERCERO.NIT AND ORDENDECOMPRA.SUCURSAL=TERCERO.SUCURSAL LEFT JOIN V_ORDENDECOMPRA_DIS ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_DIS.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_DIS.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_DIS.NUMERO LEFT JOIN V_ORDENDECOMPRA_AUX ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_AUX.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_AUX.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_AUX.NUMERO LEFT JOIN V_ORDENDECOMPRA_RES ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_RES.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_RES.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_RES.NUMERO LEFT JOIN V_ORDENDECOMPRA_RUBRO ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_RUBRO.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_RUBRO.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_RUBRO.NUMERO LEFT JOIN V_ORDENDECOMPRA_FTERECURSO ON ORDENDECOMPRA.COMPANIA = V_ORDENDECOMPRA_FTERECURSO.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = V_ORDENDECOMPRA_FTERECURSO.CLASEORDEN AND ORDENDECOMPRA.NUMERO = V_ORDENDECOMPRA_FTERECURSO.NUMERO WHERE ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND ORDENDECOMPRA.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO","CLASEORDEN":"$CLASEORDEN","CONSECUTIVOADICIONES":"$CONSECUTIVOADICIONES","TERCERO":"$TERCERO","TIPODIA":"$TIPODIA","APORTESTE_AD":"$APORTESTE_AD","CONSECUTIVOADICIONES":"$CONSECUTIVOADICIONES","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","IMPRESO":"$IMPRESO(type:boolean)","DEPENDENCIA":"$DEPENDENCIA","OBJETOCONTRATO":"$OBJETOCONTRATO","SUCURSALCESION":"$SUCURSALCESION","NUMEROAFECTADO":"$NUMEROAFECTADO","CLASENOVEDAD":"$CLASENOVEDAD","SUCURSALINTERVENTOR":"$SUCURSALINTERVENTOR","NITCESION":"$NITCESION","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","FECHA":"$FECHA","DURACION":"$DURACION","VALORTOTAL":"$VALORTOTAL","CONSIDERANDOS":"$CONSIDERANDOS","DESCRIPCION":"$DESCRIPCION","RESOAPOLIZA":"$RESOAPOLIZA","ANEXOPOLIZA":"$ANEXOPOLIZA","FECHAMODPOLIZA":"$FECHAMODPOLIZA","CLASEDISPONIBILIDAD":"$CLASEDISPONIBILIDAD","RESERVA":"$RESERVA","FECHAREGISTRO":"$FECHAREGISTRO","RUBRORESERVA":"$RUBRORESERVA","VALORDISPONIBILIDAD":"$VALORDISPONIBILIDAD","VALORRESERVA":"$VALORRESERVA","DESTINO":"$DESTINO","PROYECTO":"$PROYECTO","INTERVENTOR":"$INTERVENTOR","CEDULAINTERVENTOR":"$CEDULAINTERVENTOR","CARGOINTERVENTOR":"$CARGOINTERVENTOR","NUMEROCONTRATOINTERV":"$NUMEROCONTRATOINTERV","VALORINTERVENCION":"$VALORINTERVENCION","TIPOINTERVENTOR":"$TIPOINTERVENTOR","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","TIPOAFECTADO":"$TIPOAFECTADO","ORDENADOR_MODIF":"$ORDENADOR_MODIF","FECHAFINALMODIF":"$FECHAFINALMODIF","FECHAFINALACTUAL":"$FECHAFINALACTUAL","NOMBRETERCERO":"$NOMBRETERCERO","FUENTERECURSOS":"$FUENTERECURSOS","DISPONIBILIDAD":"$DISPONIBILIDAD","FECHADEDISPONIBILIDAD":"$FECHADEDISPONIBILIDAD","RUBRO":"$RUBRO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ordenescompra/genmodicontratos">
		<call-query href="getOrdenescompraGenModiContratosQuery">
