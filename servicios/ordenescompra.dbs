	<query id="getOrdenescompraDuracionporordencompraQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DURACION  FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DURACION":"$DURACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
