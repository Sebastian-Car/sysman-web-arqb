	<query id="getOrdenescompraPagPorModificacionesDeContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.CLASEORDEN, ORDENDECOMPRA.NUMERO , ORDENDECOMPRA.NUMEROAFECTADO, ORDENDECOMPRA.TERCERO, ORDENDECOMPRA.DEPENDENCIA,(TO_CHAR(ORDENDECOMPRA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ORDENDECOMPRA.OBJETOCONTRATO FROM ORDENDECOMPRA WHERE ORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA.TIPOAFECTADO = :TIPOAFECTADO AND EXTRACT(YEAR FROM ORDENDECOMPRA.FECHA) = :FECHAORDEN ORDER BY NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NUMEROAFECTADO IS NULL THEN ' ' ELSE UPPER(NUMEROAFECTADO) END) LIKE UPPER(CONCAT(:NUMEROAFECTADO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN OBJETOCONTRATO IS NULL THEN ' ' ELSE UPPER(OBJETOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:OBJETOCONTRATO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","NUMEROAFECTADO":"$NUMEROAFECTADO","TERCERO":"$TERCERO","DEPENDENCIA":"$DEPENDENCIA","FECHA":"$FECHA","OBJETOCONTRATO":"$OBJETOCONTRATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="TIPOAFECTADO" sqlType="STRING"/>
		<param name="FECHAORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NUMEROAFECTADO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBJETOCONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
