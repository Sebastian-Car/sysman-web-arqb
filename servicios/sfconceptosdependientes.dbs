<data name="sfconceptosdependientes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSfconceptosdependientes" keyColumns="COMPANIA,ANO,TIPOCOBRO,CONCEPTO_DEPENDIENTE,CONCEPTO_INDEPENDIENTE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_CONCEPTOS_DEPENDIENTES (COMPANIA, ANO, TIPOCOBRO, CONCEPTO_INDEPENDIENTE, CONCEPTO_DEPENDIENTE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPOCOBRO, :CONCEPTO_INDEPENDIENTE, :CONCEPTO_DEPENDIENTE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_CONCEPTO_DEPENDIENTE":"$CONCEPTO_DEPENDIENTE","KEY_CONCEPTO_INDEPENDIENTE":"$CONCEPTO_INDEPENDIENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO_INDEPENDIENTE" sqlType="STRING"/>
		<param name="CONCEPTO_DEPENDIENTE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfconceptosdependientes">
		<call-query href="insertSfconceptosdependientes">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO_INDEPENDIENTE" query-param="CONCEPTO_INDEPENDIENTE"/>
			<with-param name="CONCEPTO_DEPENDIENTE" query-param="CONCEPTO_DEPENDIENTE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSfconceptosdependientes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_CONCEPTOS_DEPENDIENTES WHERE SF_CONCEPTOS_DEPENDIENTES.COMPANIA= :KEY_COMPANIA AND SF_CONCEPTOS_DEPENDIENTES.ANO= :KEY_ANO AND SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_DEPENDIENTE= :KEY_CONCEPTO_DEPENDIENTE AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_INDEPENDIENTE= :KEY_CONCEPTO_INDEPENDIENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO_DEPENDIENTE" sqlType="STRING"/>
		<param name="KEY_CONCEPTO_INDEPENDIENTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfconceptosdependientes">
		<call-query href="deleteSfconceptosdependientes">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO_DEPENDIENTE" query-param="KEY_CONCEPTO_DEPENDIENTE"/>
			<with-param name="KEY_CONCEPTO_INDEPENDIENTE" query-param="KEY_CONCEPTO_INDEPENDIENTE"/>

		</call-query>
	</resource>
	<query id="getSfconceptosdependientesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_CONCEPTOS_DEPENDIENTES.COMPANIA, SF_CONCEPTOS_DEPENDIENTES.ANO, SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO, SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_INDEPENDIENTE, SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_DEPENDIENTE, SF_CONCEPTOS.NOMBRE  FROM SF_CONCEPTOS_DEPENDIENTES LEFT JOIN SF_CONCEPTOS ON SF_CONCEPTOS_DEPENDIENTES.COMPANIA = SF_CONCEPTOS.COMPANIA AND SF_CONCEPTOS_DEPENDIENTES.ANO = SF_CONCEPTOS.ANO AND SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO = SF_CONCEPTOS.TIPOCOBRO AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_DEPENDIENTE = SF_CONCEPTOS.CODIGO WHERE SF_CONCEPTOS_DEPENDIENTES.COMPANIA = :COMPANIA AND SF_CONCEPTOS_DEPENDIENTES.ANO = :ANO AND SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO = :TIPOCOBRO AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_INDEPENDIENTE = :CODIGO) WHERE (CASE WHEN CONCEPTO_DEPENDIENTE IS NULL THEN ' ' ELSE UPPER(CONCEPTO_DEPENDIENTE) END)  LIKE UPPER(:CONCEPTO_DEPENDIENTE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CONCEPTO_INDEPENDIENTE":"$CONCEPTO_INDEPENDIENTE","CONCEPTO_DEPENDIENTE":"$CONCEPTO_DEPENDIENTE","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONCEPTO_DEPENDIENTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfconceptosdependientes">
		<call-query href="getSfconceptosdependientesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONCEPTO_DEPENDIENTE" query-param="CONCEPTO_DEPENDIENTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfconceptosdependientesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_CONCEPTOS_DEPENDIENTES.COMPANIA, SF_CONCEPTOS_DEPENDIENTES.ANO, SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO, SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_INDEPENDIENTE, SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_DEPENDIENTE, SF_CONCEPTOS.NOMBRE  FROM SF_CONCEPTOS_DEPENDIENTES LEFT JOIN SF_CONCEPTOS ON SF_CONCEPTOS_DEPENDIENTES.COMPANIA = SF_CONCEPTOS.COMPANIA AND SF_CONCEPTOS_DEPENDIENTES.ANO = SF_CONCEPTOS.ANO AND SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO = SF_CONCEPTOS.TIPOCOBRO AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_DEPENDIENTE = SF_CONCEPTOS.CODIGO WHERE SF_CONCEPTOS_DEPENDIENTES.COMPANIA = :COMPANIA AND SF_CONCEPTOS_DEPENDIENTES.ANO = :ANO AND SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO = :TIPOCOBRO AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_INDEPENDIENTE = :CODIGO) WHERE (CASE WHEN CONCEPTO_DEPENDIENTE IS NULL THEN ' ' ELSE UPPER(CONCEPTO_DEPENDIENTE) END)  LIKE UPPER(:CONCEPTO_DEPENDIENTE || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONCEPTO_DEPENDIENTE" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfconceptosdependientes/numero">
		<call-query href="getSfconceptosdependientesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONCEPTO_DEPENDIENTE" query-param="CONCEPTO_DEPENDIENTE"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateSfconceptosdependientes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CONCEPTOS_DEPENDIENTES SET CONCEPTO_DEPENDIENTE=:CONCEPTO_DEPENDIENTE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_CONCEPTOS_DEPENDIENTES.COMPANIA= :KEY_COMPANIA AND SF_CONCEPTOS_DEPENDIENTES.ANO= :KEY_ANO AND SF_CONCEPTOS_DEPENDIENTES.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_DEPENDIENTE= :KEY_CONCEPTO_DEPENDIENTE AND SF_CONCEPTOS_DEPENDIENTES.CONCEPTO_INDEPENDIENTE= :KEY_CONCEPTO_INDEPENDIENTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONCEPTO_DEPENDIENTE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO_DEPENDIENTE" sqlType="STRING"/>
		<param name="KEY_CONCEPTO_INDEPENDIENTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfconceptosdependientes">
		<call-query href="updateSfconceptosdependientes">
			<with-param name="CONCEPTO_DEPENDIENTE" query-param="CONCEPTO_DEPENDIENTE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO_DEPENDIENTE" query-param="KEY_CONCEPTO_DEPENDIENTE"/>
			<with-param name="KEY_CONCEPTO_INDEPENDIENTE" query-param="KEY_CONCEPTO_INDEPENDIENTE"/>

		</call-query>
	</resource>

</data>