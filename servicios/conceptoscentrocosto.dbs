<data name="conceptoscentrocosto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertConceptoscentrocosto" keyColumns="COMPANIA,ANO,ID_DE_CONCEPTO,ID_CENTRO_DE_COSTO,CODAUXILIAR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONCEPTO_CENTROCOSTO (CODAUXILIAR, ANO, ID_DE_CONCEPTO, ID_CENTRO_DE_COSTO, CTA_CREDITO, CTA_DEBITO, CTA_DEBITO1, CTA_CREDITO1, COMPANIA, PORCENTAJE, DATE_CREATED, CREATED_BY) VALUES (:CODAUXILIAR, :ANO, :ID_DE_CONCEPTO, :ID_CENTRO_DE_COSTO, :CTA_CREDITO, :CTA_DEBITO, :CTA_DEBITO1, :CTA_CREDITO1, :COMPANIA, :PORCENTAJE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","KEY_ID_CENTRO_DE_COSTO":"$ID_CENTRO_DE_COSTO","KEY_CODAUXILIAR":"$CODAUXILIAR"}]}}		</result>
		<param defaultValue="99999999999999999999" name="CODAUXILIAR" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param defaultValue="" name="CTA_CREDITO" sqlType="STRING"/>
		<param defaultValue="" name="CTA_DEBITO" sqlType="STRING"/>
		<param defaultValue="" name="CTA_DEBITO1" sqlType="STRING"/>
		<param defaultValue="" name="CTA_CREDITO1" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="conceptoscentrocosto">
		<call-query href="insertConceptoscentrocosto">
			<with-param name="CODAUXILIAR" query-param="CODAUXILIAR"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="ID_CENTRO_DE_COSTO" query-param="ID_CENTRO_DE_COSTO"/>
			<with-param name="CTA_CREDITO" query-param="CTA_CREDITO"/>
			<with-param name="CTA_DEBITO" query-param="CTA_DEBITO"/>
			<with-param name="CTA_DEBITO1" query-param="CTA_DEBITO1"/>
			<with-param name="CTA_CREDITO1" query-param="CTA_CREDITO1"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConceptoscentrocosto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONCEPTO_CENTROCOSTO WHERE CONCEPTO_CENTROCOSTO.COMPANIA= :KEY_COMPANIA AND CONCEPTO_CENTROCOSTO.ANO= :KEY_ANO AND CONCEPTO_CENTROCOSTO.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO AND CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO= :KEY_ID_CENTRO_DE_COSTO AND CONCEPTO_CENTROCOSTO.CODAUXILIAR= :KEY_CODAUXILIAR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="INTEGER"/>
		<param name="KEY_ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="KEY_CODAUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="conceptoscentrocosto">
		<call-query href="deleteConceptoscentrocosto">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>
			<with-param name="KEY_ID_CENTRO_DE_COSTO" query-param="KEY_ID_CENTRO_DE_COSTO"/>
			<with-param name="KEY_CODAUXILIAR" query-param="KEY_CODAUXILIAR"/>

		</call-query>
	</resource>
	<query id="getConceptoscentrocostoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCEPTO_CENTROCOSTO.COMPANIA, CONCEPTO_CENTROCOSTO.ANO, CONCEPTO_CENTROCOSTO.ID_DE_CONCEPTO, CENTRO_COSTO.NOMBRE NOMCENTROCOSTO, CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO, CONCEPTO_CENTROCOSTO.CTA_CREDITO, CONCEPTO_CENTROCOSTO.CTA_DEBITO, CONCEPTO_CENTROCOSTO.CTA_DEBITO1, CONCEPTO_CENTROCOSTO.CTA_CREDITO1, CONCEPTO_CENTROCOSTO.CODAUXILIAR, AUXILIAR.NOMBRE NOMBRE_AUX, CONCEPTO_CENTROCOSTO.PORCENTAJE FROM CONCEPTO_CENTROCOSTO LEFT JOIN CENTRO_COSTO ON CONCEPTO_CENTROCOSTO.COMPANIA = CENTRO_COSTO.COMPANIA AND CONCEPTO_CENTROCOSTO.ANO = CENTRO_COSTO.ANO AND CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON CONCEPTO_CENTROCOSTO.COMPANIA = AUXILIAR.COMPANIA AND CONCEPTO_CENTROCOSTO.ANO = AUXILIAR.ANO AND CONCEPTO_CENTROCOSTO.CODAUXILIAR = AUXILIAR.CODIGO WHERE CONCEPTO_CENTROCOSTO.COMPANIA = :COMPANIA AND CONCEPTO_CENTROCOSTO.ID_DE_CONCEPTO = :CONCEPTO AND CONCEPTO_CENTROCOSTO.ANO = :ANIO ORDER BY CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO) INI WHERE (CASE WHEN NOMCENTROCOSTO IS NULL THEN ' ' ELSE UPPER(NOMCENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMCENTROCOSTO), '%')) AND (CASE WHEN ID_CENTRO_DE_COSTO IS NULL THEN ' ' ELSE UPPER(ID_CENTRO_DE_COSTO) END) LIKE UPPER(CONCAT(:ID_CENTRO_DE_COSTO, '%')) AND (CASE WHEN CTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CTA_CREDITO) END) LIKE UPPER(CONCAT(:CTA_CREDITO, '%')) AND (CASE WHEN CTA_DEBITO IS NULL THEN ' ' ELSE UPPER(CTA_DEBITO) END) LIKE UPPER(CONCAT(:CTA_DEBITO, '%')) AND (CASE WHEN CTA_DEBITO1 IS NULL THEN ' ' ELSE UPPER(CTA_DEBITO1) END) LIKE UPPER(CONCAT(:CTA_DEBITO1, '%')) AND (CASE WHEN CTA_CREDITO1 IS NULL THEN ' ' ELSE UPPER(CTA_CREDITO1) END) LIKE UPPER(CONCAT(:CTA_CREDITO1, '%')) AND (CASE WHEN CODAUXILIAR IS NULL THEN ' ' ELSE UPPER(CODAUXILIAR) END) LIKE UPPER(CONCAT(:CODAUXILIAR, '%')) AND (CASE WHEN NOMBRE_AUX IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUX), '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(:PORCENTAJE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMCENTROCOSTO":"$NOMCENTROCOSTO","ID_CENTRO_DE_COSTO":"$ID_CENTRO_DE_COSTO","CTA_CREDITO":"$CTA_CREDITO","CTA_DEBITO":"$CTA_DEBITO","CTA_DEBITO1":"$CTA_DEBITO1","CTA_CREDITO1":"$CTA_CREDITO1","CODAUXILIAR":"$CODAUXILIAR","NOMBRE_AUX":"$NOMBRE_AUX","PORCENTAJE":"$PORCENTAJE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NOMCENTROCOSTO" sqlType="STRING"/>
		<param name="ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="CTA_CREDITO" sqlType="STRING"/>
		<param name="CTA_DEBITO" sqlType="STRING"/>
		<param name="CTA_DEBITO1" sqlType="STRING"/>
		<param name="CTA_CREDITO1" sqlType="STRING"/>
		<param name="CODAUXILIAR" sqlType="STRING"/>
		<param name="NOMBRE_AUX" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptoscentrocosto">
		<call-query href="getConceptoscentrocostoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="NOMCENTROCOSTO" query-param="NOMCENTROCOSTO"/>
			<with-param name="ID_CENTRO_DE_COSTO" query-param="ID_CENTRO_DE_COSTO"/>
			<with-param name="CTA_CREDITO" query-param="CTA_CREDITO"/>
			<with-param name="CTA_DEBITO" query-param="CTA_DEBITO"/>
			<with-param name="CTA_DEBITO1" query-param="CTA_DEBITO1"/>
			<with-param name="CTA_CREDITO1" query-param="CTA_CREDITO1"/>
			<with-param name="CODAUXILIAR" query-param="CODAUXILIAR"/>
			<with-param name="NOMBRE_AUX" query-param="NOMBRE_AUX"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptoscentrocostoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCEPTO_CENTROCOSTO.COMPANIA, CONCEPTO_CENTROCOSTO.ANO, CONCEPTO_CENTROCOSTO.ID_DE_CONCEPTO, CENTRO_COSTO.NOMBRE NOMCENTROCOSTO, CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO, CONCEPTO_CENTROCOSTO.CTA_CREDITO, CONCEPTO_CENTROCOSTO.CTA_DEBITO, CONCEPTO_CENTROCOSTO.CTA_DEBITO1, CONCEPTO_CENTROCOSTO.CTA_CREDITO1, CONCEPTO_CENTROCOSTO.CODAUXILIAR, AUXILIAR.NOMBRE NOMBRE_AUX, CONCEPTO_CENTROCOSTO.PORCENTAJE FROM CONCEPTO_CENTROCOSTO LEFT JOIN CENTRO_COSTO ON CONCEPTO_CENTROCOSTO.COMPANIA = CENTRO_COSTO.COMPANIA AND CONCEPTO_CENTROCOSTO.ANO = CENTRO_COSTO.ANO AND CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON CONCEPTO_CENTROCOSTO.COMPANIA = AUXILIAR.COMPANIA AND CONCEPTO_CENTROCOSTO.ANO = AUXILIAR.ANO AND CONCEPTO_CENTROCOSTO.CODAUXILIAR = AUXILIAR.CODIGO WHERE CONCEPTO_CENTROCOSTO.COMPANIA = :COMPANIA AND CONCEPTO_CENTROCOSTO.ID_DE_CONCEPTO = :CONCEPTO AND CONCEPTO_CENTROCOSTO.ANO = :ANIO ORDER BY CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO) INI WHERE (CASE WHEN NOMCENTROCOSTO IS NULL THEN ' ' ELSE UPPER(NOMCENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMCENTROCOSTO), '%')) AND (CASE WHEN ID_CENTRO_DE_COSTO IS NULL THEN ' ' ELSE UPPER(ID_CENTRO_DE_COSTO) END) LIKE UPPER(CONCAT(:ID_CENTRO_DE_COSTO, '%')) AND (CASE WHEN CTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CTA_CREDITO) END) LIKE UPPER(CONCAT(:CTA_CREDITO, '%')) AND (CASE WHEN CTA_DEBITO IS NULL THEN ' ' ELSE UPPER(CTA_DEBITO) END) LIKE UPPER(CONCAT(:CTA_DEBITO, '%')) AND (CASE WHEN CTA_DEBITO1 IS NULL THEN ' ' ELSE UPPER(CTA_DEBITO1) END) LIKE UPPER(CONCAT(:CTA_DEBITO1, '%')) AND (CASE WHEN CTA_CREDITO1 IS NULL THEN ' ' ELSE UPPER(CTA_CREDITO1) END) LIKE UPPER(CONCAT(:CTA_CREDITO1, '%')) AND (CASE WHEN CODAUXILIAR IS NULL THEN ' ' ELSE UPPER(CODAUXILIAR) END) LIKE UPPER(CONCAT(:CODAUXILIAR, '%')) AND (CASE WHEN NOMBRE_AUX IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUX), '%')) AND (CASE WHEN PORCENTAJE IS NULL THEN ' ' ELSE UPPER(PORCENTAJE) END) LIKE UPPER(CONCAT(:PORCENTAJE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NOMCENTROCOSTO" sqlType="STRING"/>
		<param name="ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="CTA_CREDITO" sqlType="STRING"/>
		<param name="CTA_DEBITO" sqlType="STRING"/>
		<param name="CTA_DEBITO1" sqlType="STRING"/>
		<param name="CTA_CREDITO1" sqlType="STRING"/>
		<param name="CODAUXILIAR" sqlType="STRING"/>
		<param name="NOMBRE_AUX" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptoscentrocosto/numero">
		<call-query href="getConceptoscentrocostoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="NOMCENTROCOSTO" query-param="NOMCENTROCOSTO"/>
			<with-param name="ID_CENTRO_DE_COSTO" query-param="ID_CENTRO_DE_COSTO"/>
			<with-param name="CTA_CREDITO" query-param="CTA_CREDITO"/>
			<with-param name="CTA_DEBITO" query-param="CTA_DEBITO"/>
			<with-param name="CTA_DEBITO1" query-param="CTA_DEBITO1"/>
			<with-param name="CTA_CREDITO1" query-param="CTA_CREDITO1"/>
			<with-param name="CODAUXILIAR" query-param="CODAUXILIAR"/>
			<with-param name="NOMBRE_AUX" query-param="NOMBRE_AUX"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>

		</call-query>
	</resource>
	<query id="updateConceptoscentrocosto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONCEPTO_CENTROCOSTO SET CODAUXILIAR=:CODAUXILIAR, ANO=:ANO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, ID_CENTRO_DE_COSTO=:ID_CENTRO_DE_COSTO, CTA_CREDITO=:CTA_CREDITO, CTA_DEBITO=:CTA_DEBITO, CTA_DEBITO1=:CTA_DEBITO1, CTA_CREDITO1=:CTA_CREDITO1, PORCENTAJE=:PORCENTAJE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONCEPTO_CENTROCOSTO.COMPANIA= :KEY_COMPANIA AND CONCEPTO_CENTROCOSTO.ANO= :KEY_ANO AND CONCEPTO_CENTROCOSTO.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO AND CONCEPTO_CENTROCOSTO.ID_CENTRO_DE_COSTO= :KEY_ID_CENTRO_DE_COSTO AND CONCEPTO_CENTROCOSTO.CODAUXILIAR= :KEY_CODAUXILIAR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODAUXILIAR" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="CTA_CREDITO" sqlType="STRING"/>
		<param name="CTA_DEBITO" sqlType="STRING"/>
		<param name="CTA_DEBITO1" sqlType="STRING"/>
		<param name="CTA_CREDITO1" sqlType="STRING"/>
		<param name="PORCENTAJE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="KEY_CODAUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="conceptoscentrocosto">
		<call-query href="updateConceptoscentrocosto">
			<with-param name="CODAUXILIAR" query-param="CODAUXILIAR"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="ID_CENTRO_DE_COSTO" query-param="ID_CENTRO_DE_COSTO"/>
			<with-param name="CTA_CREDITO" query-param="CTA_CREDITO"/>
			<with-param name="CTA_DEBITO" query-param="CTA_DEBITO"/>
			<with-param name="CTA_DEBITO1" query-param="CTA_DEBITO1"/>
			<with-param name="CTA_CREDITO1" query-param="CTA_CREDITO1"/>
			<with-param name="PORCENTAJE" query-param="PORCENTAJE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>
			<with-param name="KEY_ID_CENTRO_DE_COSTO" query-param="KEY_ID_CENTRO_DE_COSTO"/>
			<with-param name="KEY_CODAUXILIAR" query-param="KEY_CODAUXILIAR"/>

		</call-query>
	</resource>

</data>