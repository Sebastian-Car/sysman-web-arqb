<data name="spordentrabajonovedades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSpordentrabajonovedades" keyColumns="COMPANIA,CLASEDOC,NUMORDEN,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_ORDENTRABAJONOVEDADES (COMPANIA, CLASEDOC, NUMORDEN, CONSECUTIVO, DESCRIPCION, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CLASEDOC, :NUMORDEN, :CONSECUTIVO, :DESCRIPCION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEDOC":"$CLASEDOC","KEY_NUMORDEN":"$NUMORDEN(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spordentrabajonovedades">
		<call-query href="insertSpordentrabajonovedades">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteSpordentrabajonovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_ORDENTRABAJONOVEDADES WHERE SP_ORDENTRABAJONOVEDADES.COMPANIA= :KEY_COMPANIA AND SP_ORDENTRABAJONOVEDADES.CLASEDOC= :KEY_CLASEDOC AND SP_ORDENTRABAJONOVEDADES.NUMORDEN= :KEY_NUMORDEN AND SP_ORDENTRABAJONOVEDADES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEDOC" sqlType="STRING"/>
		<param name="KEY_NUMORDEN" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spordentrabajonovedades">
		<call-query href="deleteSpordentrabajonovedades">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEDOC" query-param="KEY_CLASEDOC"/>
			<with-param name="KEY_NUMORDEN" query-param="KEY_NUMORDEN"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSpordentrabajonovedadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CLASEDOC, NUMORDEN, CONSECUTIVO, DESCRIPCION  FROM SP_ORDENTRABAJONOVEDADES WHERE COMPANIA = :COMPANIA AND CLASEDOC = :CLASEDOC AND NUMORDEN = :NUMORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEDOC":"$CLASEDOC","NUMORDEN":"$NUMORDEN(type:long)","CONSECUTIVO":"$CONSECUTIVO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEDOC" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spordentrabajonovedades">
		<call-query href="getSpordentrabajonovedadesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEDOC" query-param="CLASEDOC"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>

		</call-query>
	</resource>
	<query id="updateSpordentrabajonovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_ORDENTRABAJONOVEDADES SET DESCRIPCION=:DESCRIPCION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_ORDENTRABAJONOVEDADES.COMPANIA= :KEY_COMPANIA AND SP_ORDENTRABAJONOVEDADES.CLASEDOC= :KEY_CLASEDOC AND SP_ORDENTRABAJONOVEDADES.NUMORDEN= :KEY_NUMORDEN AND SP_ORDENTRABAJONOVEDADES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEDOC" sqlType="STRING"/>
		<param name="KEY_NUMORDEN" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spordentrabajonovedades">
		<call-query href="updateSpordentrabajonovedades">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEDOC" query-param="KEY_CLASEDOC"/>
			<with-param name="KEY_NUMORDEN" query-param="KEY_NUMORDEN"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>