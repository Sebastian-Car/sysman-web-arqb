<data name="vpbeneficiarios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVpbeneficiariosPagBeneficiarioporproyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VP.ID, VP.IP_CODIGO, VP.NOMBRE_USUARIO NOMBRE, VP.IP_NUMERO_ORDEN  FROM VP_BENEFICIARIOS VP WHERE VP.COMPANIA = :COMPANIA AND VP.CODIGO_PROYECTO = :CODIGO_PROYECTO AND VP.CLASE = :CLASE ORDER BY VP.ID) WHERE (CASE WHEN IP_CODIGO IS NULL THEN ' ' ELSE UPPER(IP_CODIGO) END)  LIKE UPPER(:IP_CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","IP_CODIGO":"$IP_CODIGO","NOMBRE":"$NOMBRE","IP_NUMERO_ORDEN":"$IP_NUMERO_ORDEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpbeneficiarios/beneficiarioporproyecto/pag">
		<call-query href="getVpbeneficiariosPagBeneficiarioporproyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpbeneficiariosNumBeneficiarioporproyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VP.ID, VP.IP_CODIGO, VP.NOMBRE_USUARIO NOMBRE, VP.IP_NUMERO_ORDEN  FROM VP_BENEFICIARIOS VP WHERE VP.COMPANIA = :COMPANIA AND VP.CODIGO_PROYECTO = :CODIGO_PROYECTO AND VP.CLASE = :CLASE ORDER BY VP.ID) WHERE (CASE WHEN IP_CODIGO IS NULL THEN ' ' ELSE UPPER(IP_CODIGO) END)  LIKE UPPER(:IP_CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpbeneficiarios/beneficiarioporproyecto/num">
		<call-query href="getVpbeneficiariosNumBeneficiarioporproyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertVpbeneficiariosInsertplusvalia" keyColumns="ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VP_BENEFICIARIOS (ID_PROYECTO, COMPANIA, CODIGO_PROYECTO, CLASE, IP_CODIGO, IP_NUMERO_ORDEN, TERCERO, SUCURSAL, NOMBRE_USUARIO, AREA_BRUTA, AFECTACIONES, AREA_NETA, CONTRIBUCION, ID_HECHOS_PROYECTOS, CODIGO_HECHO, DATE_CREATED, CREATED_BY) VALUES (:ID_PROYECTO, :COMPANIA, :CODIGO_PROYECTO, :CLASE, :IP_CODIGO, :IP_NUMERO_ORDEN, :TERCERO, :SUCURSAL, :NOMBRE_USUARIO, :AREA_BRUTA, :AFECTACIONES, :AREA_NETA, :CONTRIBUCION, :ID_HECHOS_PROYECTOS, :CODIGO_HECHO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ID":"$ID"}]}}		</result>
		<param name="ID_PROYECTO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="IP_NUMERO_ORDEN" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_USUARIO" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_BRUTA" sqlType="STRING"/>
		<param defaultValue="0" name="AFECTACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_NETA" sqlType="STRING"/>
		<param defaultValue="0" name="CONTRIBUCION" sqlType="STRING"/>
		<param defaultValue="" name="ID_HECHOS_PROYECTOS" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_HECHO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vpbeneficiarios/insertplusvalia">
		<call-query href="insertVpbeneficiariosInsertplusvalia">
			<with-param name="ID_PROYECTO" query-param="ID_PROYECTO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="IP_NUMERO_ORDEN" query-param="IP_NUMERO_ORDEN"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE_USUARIO" query-param="NOMBRE_USUARIO"/>
			<with-param name="AREA_BRUTA" query-param="AREA_BRUTA"/>
			<with-param name="AFECTACIONES" query-param="AFECTACIONES"/>
			<with-param name="AREA_NETA" query-param="AREA_NETA"/>
			<with-param name="CONTRIBUCION" query-param="CONTRIBUCION"/>
			<with-param name="ID_HECHOS_PROYECTOS" query-param="ID_HECHOS_PROYECTOS"/>
			<with-param name="CODIGO_HECHO" query-param="CODIGO_HECHO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getVpbeneficiariosReadplusvaliaQuery"  useConfig="sysmandsunist">
		<sql>SELECT VP_BENEFICIARIOS.ID, VP_BENEFICIARIOS.ID_PROYECTO, VP_BENEFICIARIOS.COMPANIA, VP_BENEFICIARIOS.CODIGO_PROYECTO, CONCAT(VP_BENEFICIARIOS.CODIGO_PROYECTO ,CONCAT( ' - ' , VP_PROYECTOS.DESCRIPCION)) PRODESC, VP_BENEFICIARIOS.CLASE, VP_BENEFICIARIOS.IP_CODIGO, VP_BENEFICIARIOS.IP_NUMERO_ORDEN, VP_BENEFICIARIOS.NOMBRE_USUARIO, VP_BENEFICIARIOS.AREA_BRUTA, VP_BENEFICIARIOS.AFECTACIONES, VP_BENEFICIARIOS.AREA_NETA, VP_BENEFICIARIOS.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, VP_BENEFICIARIOS.SUCURSAL, VP_BENEFICIARIOS.CREATED_BY,(TO_CHAR(VP_BENEFICIARIOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VP_BENEFICIARIOS.MODIFIED_BY,(TO_CHAR(VP_BENEFICIARIOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM VP_BENEFICIARIOS INNER JOIN TERCERO ON VP_BENEFICIARIOS.COMPANIA = TERCERO.COMPANIA AND VP_BENEFICIARIOS.TERCERO = TERCERO.NIT AND VP_BENEFICIARIOS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN VP_PROYECTOS ON VP_BENEFICIARIOS.ID_PROYECTO = VP_PROYECTOS.ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","ID_PROYECTO":"$ID_PROYECTO","COMPANIA":"$COMPANIA","CODIGO_PROYECTO":"$CODIGO_PROYECTO","PRODESC":"$PRODESC","CLASE":"$CLASE","IP_CODIGO":"$IP_CODIGO","IP_NUMERO_ORDEN":"$IP_NUMERO_ORDEN","NOMBRE_USUARIO":"$NOMBRE_USUARIO","AREA_BRUTA":"$AREA_BRUTA","AFECTACIONES":"$AFECTACIONES","AREA_NETA":"$AREA_NETA","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","SUCURSAL":"$SUCURSAL","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
 
	</query>
	<resource method="GET" path="vpbeneficiarios/readplusvalia">
		<call-query href="getVpbeneficiariosReadplusvaliaQuery">
 
		</call-query>
	</resource>
	<query id="updateVpbeneficiariosActualizarplusvalia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VP_BENEFICIARIOS SET COMPANIA=:COMPANIA, ID_PROYECTO=:ID_PROYECTO, CODIGO_PROYECTO=:CODIGO_PROYECTO, CLASE=:CLASE, IP_CODIGO=:IP_CODIGO, IP_NUMERO_ORDEN=:IP_NUMERO_ORDEN, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, NOMBRE_USUARIO=:NOMBRE_USUARIO, AREA_BRUTA=:AREA_BRUTA, AFECTACIONES=:AFECTACIONES, AREA_NETA=:AREA_NETA, DIRECCION_CORRESPONDENCIA=:DIRECCION_CORRESPONDENCIA, MATRICULA_INMOBILIARIA=:MATRICULA_INMOBILIARIA, DIRECCION=:DIRECCION, FRENTE_PREDIO=:FRENTE_PREDIO, RADICADO_CORRESPONDENCIA=:RADICADO_CORRESPONDENCIA, CEDULA_CATASTRAL=:CEDULA_CATASTRAL, TELEFONO_PROPIETARIO=:TELEFONO_PROPIETARIO, DOCUMENTO_PROPIETARIO=:DOCUMENTO_PROPIETARIO, CESIONES_PUBLICAS=:CESIONES_PUBLICAS, METROS_LIQUIDADOS=:METROS_LIQUIDADOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VP_BENEFICIARIOS.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PROYECTO" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="IP_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE_USUARIO" sqlType="STRING"/>
		<param name="AREA_BRUTA" sqlType="STRING"/>
		<param name="AFECTACIONES" sqlType="STRING"/>
		<param name="AREA_NETA" sqlType="STRING"/>
		<param name="DIRECCION_CORRESPONDENCIA" sqlType="STRING"/>
		<param name="MATRICULA_INMOBILIARIA" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="FRENTE_PREDIO" sqlType="STRING"/>
		<param name="RADICADO_CORRESPONDENCIA" sqlType="STRING"/>
		<param name="CEDULA_CATASTRAL" sqlType="STRING"/>
		<param name="TELEFONO_PROPIETARIO" sqlType="STRING"/>
		<param name="DOCUMENTO_PROPIETARIO" sqlType="STRING"/>
		<param name="CESIONES_PUBLICAS" sqlType="STRING"/>
		<param name="METROS_LIQUIDADOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vpbeneficiarios/actualizarplusvalia">
		<call-query href="updateVpbeneficiariosActualizarplusvalia">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PROYECTO" query-param="ID_PROYECTO"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="IP_NUMERO_ORDEN" query-param="IP_NUMERO_ORDEN"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE_USUARIO" query-param="NOMBRE_USUARIO"/>
			<with-param name="AREA_BRUTA" query-param="AREA_BRUTA"/>
			<with-param name="AFECTACIONES" query-param="AFECTACIONES"/>
			<with-param name="AREA_NETA" query-param="AREA_NETA"/>
			<with-param name="DIRECCION_CORRESPONDENCIA" query-param="DIRECCION_CORRESPONDENCIA"/>
			<with-param name="MATRICULA_INMOBILIARIA" query-param="MATRICULA_INMOBILIARIA"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="FRENTE_PREDIO" query-param="FRENTE_PREDIO"/>
			<with-param name="RADICADO_CORRESPONDENCIA" query-param="RADICADO_CORRESPONDENCIA"/>
			<with-param name="CEDULA_CATASTRAL" query-param="CEDULA_CATASTRAL"/>
			<with-param name="TELEFONO_PROPIETARIO" query-param="TELEFONO_PROPIETARIO"/>
			<with-param name="DOCUMENTO_PROPIETARIO" query-param="DOCUMENTO_PROPIETARIO"/>
			<with-param name="CESIONES_PUBLICAS" query-param="CESIONES_PUBLICAS"/>
			<with-param name="METROS_LIQUIDADOS" query-param="METROS_LIQUIDADOS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getVpbeneficiariosSelectplusvaliaQuery"  useConfig="sysmandsunist">
		<sql>SELECT VP_BENEFICIARIOS.ID, VP_BENEFICIARIOS.ID_PROYECTO, VP_BENEFICIARIOS.COMPANIA, VP_BENEFICIARIOS.CODIGO_PROYECTO, CONCAT(VP_BENEFICIARIOS.CODIGO_PROYECTO,CONCAT(' - ',VP_PROYECTOS.DESCRIPCION) ) PRODESC, VP_BENEFICIARIOS.CLASE, VP_BENEFICIARIOS.IP_CODIGO, VP_BENEFICIARIOS.IP_NUMERO_ORDEN, VP_BENEFICIARIOS.NOMBRE_USUARIO, VP_BENEFICIARIOS.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, VP_BENEFICIARIOS.SUCURSAL, VP_BENEFICIARIOS.AREA_FISICA, VP_BENEFICIARIOS.CREATED_BY,(TO_CHAR(VP_BENEFICIARIOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VP_BENEFICIARIOS.MODIFIED_BY,(TO_CHAR(VP_BENEFICIARIOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, VP_BENEFICIARIOS.AREA_BRUTA, VP_BENEFICIARIOS.FRENTE_PREDIO, VP_BENEFICIARIOS.DIRECCION_CORRESPONDENCIA, VP_BENEFICIARIOS.MATRICULA_INMOBILIARIA, VP_BENEFICIARIOS.DIRECCION, VP_BENEFICIARIOS.AFECTACIONES, VP_BENEFICIARIOS.AREA_NETA, VP_BENEFICIARIOS.RADICADO_CORRESPONDENCIA, VP_BENEFICIARIOS.CEDULA_CATASTRAL, VP_BENEFICIARIOS.TELEFONO_PROPIETARIO, VP_BENEFICIARIOS.DOCUMENTO_PROPIETARIO, VP_BENEFICIARIOS.CESIONES_PUBLICAS, VP_BENEFICIARIOS.METROS_LIQUIDADOS FROM VP_BENEFICIARIOS INNER JOIN TERCERO ON VP_BENEFICIARIOS.COMPANIA = TERCERO.COMPANIA AND VP_BENEFICIARIOS.TERCERO = TERCERO.NIT AND VP_BENEFICIARIOS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN VP_PROYECTOS ON VP_BENEFICIARIOS.ID_PROYECTO = VP_PROYECTOS.ID WHERE VP_BENEFICIARIOS.ID =:KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","ID_PROYECTO":"$ID_PROYECTO","COMPANIA":"$COMPANIA","CODIGO_PROYECTO":"$CODIGO_PROYECTO","PRODESC":"$PRODESC","CLASE":"$CLASE","IP_CODIGO":"$IP_CODIGO","IP_NUMERO_ORDEN":"$IP_NUMERO_ORDEN","NOMBRE_USUARIO":"$NOMBRE_USUARIO","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","SUCURSAL":"$SUCURSAL","AREA_FISICA":"$AREA_FISICA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","AREA_BRUTA":"$AREA_BRUTA","FRENTE_PREDIO":"$FRENTE_PREDIO","DIRECCION_CORRESPONDENCIA":"$DIRECCION_CORRESPONDENCIA","MATRICULA_INMOBILIARIA":"$MATRICULA_INMOBILIARIA","DIRECCION":"$DIRECCION","AFECTACIONES":"$AFECTACIONES","AREA_NETA":"$AREA_NETA","RADICADO_CORRESPONDENCIA":"$RADICADO_CORRESPONDENCIA","CEDULA_CATASTRAL":"$CEDULA_CATASTRAL","TELEFONO_PROPIETARIO":"$TELEFONO_PROPIETARIO","DOCUMENTO_PROPIETARIO":"$DOCUMENTO_PROPIETARIO","CESIONES_PUBLICAS":"$CESIONES_PUBLICAS","METROS_LIQUIDADOS":"$METROS_LIQUIDADOS"}]}}		</result>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpbeneficiarios/selectplusvalia">
		<call-query href="getVpbeneficiariosSelectplusvaliaQuery">
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getVpbeneficiariosPagTerceroporproyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VP.ID, VP.TERCERO IP_CODIGO, VP.NOMBRE_USUARIO NOMBRE  FROM VP_BENEFICIARIOS VP INNER JOIN TERCERO ON VP.COMPANIA = TERCERO.COMPANIA AND VP.TERCERO = TERCERO.NIT AND VP.SUCURSAL = TERCERO.SUCURSAL WHERE VP.COMPANIA = :COMPANIA AND VP.CODIGO_PROYECTO = :CODIGO_PROYECTO AND VP.CLASE = :CLASE ORDER BY VP.ID) WHERE (CASE WHEN IP_CODIGO IS NULL THEN ' ' ELSE UPPER(IP_CODIGO) END)  LIKE UPPER( '%' || :IP_CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","IP_CODIGO":"$IP_CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpbeneficiarios/terceroporproyecto/pag">
		<call-query href="getVpbeneficiariosPagTerceroporproyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpbeneficiariosNumTerceroporproyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VP.ID, VP.TERCERO IP_CODIGO, VP.NOMBRE_USUARIO NOMBRE  FROM VP_BENEFICIARIOS VP INNER JOIN TERCERO ON VP.COMPANIA = TERCERO.COMPANIA AND VP.TERCERO = TERCERO.NIT AND VP.SUCURSAL = TERCERO.SUCURSAL WHERE VP.COMPANIA = :COMPANIA AND VP.CODIGO_PROYECTO = :CODIGO_PROYECTO AND VP.CLASE = :CLASE ORDER BY VP.ID) WHERE (CASE WHEN IP_CODIGO IS NULL THEN ' ' ELSE UPPER(IP_CODIGO) END)  LIKE UPPER( '%' || :IP_CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpbeneficiarios/terceroporproyecto/num">
		<call-query href="getVpbeneficiariosNumTerceroporproyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertVpbeneficiarios" keyColumns="ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VP_BENEFICIARIOS (ID_PROYECTO, COMPANIA, CODIGO_PROYECTO, CLASE, IP_CODIGO, IP_NUMERO_ORDEN, TERCERO, SUCURSAL, AREA_FISICA, NOMBRE_USUARIO, AREA_BRUTA, AFECTACIONES, AREA_NETA, DESTINACION_ECONOMICA, GRADO_BENEFICIO, DIRECCION_CORRESPONDENCIA, MATRICULA_INMOBILIARIA, DIRECCION, AREA_AFECTADA, AREA_GRAVADA, FRENTE_PREDIO, RADICADO_CORRESPONDENCIA, CEDULA_CATASTRAL, TELEFONO_PROPIETARIO, DOCUMENTO_PROPIETARIO, CESIONES_PUBLICAS, METROS_LIQUIDADOS, CODIGOETAPA, NUMERO_RESOLUCION, EN_ACUERDO, PREDIAL_EXCLUIDO, PORCENTAJE_PARTICIPACION, DATE_CREATED, CREATED_BY) VALUES (:ID_PROYECTO, :COMPANIA, :CODIGO_PROYECTO, :CLASE, :IP_CODIGO, :IP_NUMERO_ORDEN, :TERCERO, :SUCURSAL, :AREA_FISICA, :NOMBRE_USUARIO, :AREA_BRUTA, :AFECTACIONES, :AREA_NETA, :DESTINACION_ECONOMICA, :GRADO_BENEFICIO, :DIRECCION_CORRESPONDENCIA, :MATRICULA_INMOBILIARIA, :DIRECCION, :AREA_AFECTADA, :AREA_GRAVADA, :FRENTE_PREDIO, :RADICADO_CORRESPONDENCIA, :CEDULA_CATASTRAL, :TELEFONO_PROPIETARIO, :DOCUMENTO_PROPIETARIO, :CESIONES_PUBLICAS, :METROS_LIQUIDADOS, :CODIGOETAPA, :NUMERO_RESOLUCION, :EN_ACUERDO, :PREDIAL_EXCLUIDO, :PORCENTAJE_PARTICIPACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ID":"$ID"}]}}		</result>
		<param name="ID_PROYECTO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="IP_NUMERO_ORDEN" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_FISICA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_USUARIO" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_BRUTA" sqlType="STRING"/>
		<param defaultValue="0" name="AFECTACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_NETA" sqlType="STRING"/>
		<param defaultValue="" name="DESTINACION_ECONOMICA" sqlType="STRING"/>
		<param defaultValue="" name="GRADO_BENEFICIO" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION_CORRESPONDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="MATRICULA_INMOBILIARIA" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_AFECTADA" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_GRAVADA" sqlType="STRING"/>
		<param defaultValue="" name="FRENTE_PREDIO" sqlType="STRING"/>
		<param defaultValue="" name="RADICADO_CORRESPONDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="CEDULA_CATASTRAL" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO_PROPIETARIO" sqlType="STRING"/>
		<param defaultValue="" name="DOCUMENTO_PROPIETARIO" sqlType="STRING"/>
		<param defaultValue="" name="CESIONES_PUBLICAS" sqlType="STRING"/>
		<param defaultValue="" name="METROS_LIQUIDADOS" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOETAPA" sqlType="STRING"/>
		<param defaultValue="" name="NUMERO_RESOLUCION" sqlType="STRING"/>
		<param defaultValue="0" name="EN_ACUERDO" sqlType="STRING"/>
		<param defaultValue="0" name="PREDIAL_EXCLUIDO" sqlType="STRING"/>
		<param defaultValue="100" name="PORCENTAJE_PARTICIPACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
