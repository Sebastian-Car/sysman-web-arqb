	<query id="getVpbeneficiariosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT VP_BENEFICIARIOS.ID, VP_BENEFICIARIOS.ID_PROYECTO, VP_BENEFICIARIOS.COMPANIA, VP_BENEFICIARIOS.CODIGO_PROYECTO, CONCAT(VP_BENEFICIARIOS.CODIGO_PROYECTO ,CONCAT( ' - ' , VP_PROYECTOS.DESCRIPCION)) PRODESC, VP_BENEFICIARIOS.CLASE, VP_BENEFICIARIOS.IP_CODIGO, VP_BENEFICIARIOS.IP_NUMERO_ORDEN, VP_BENEFICIARIOS.NOMBRE_USUARIO, VP_BENEFICIARIOS.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, VP_BENEFICIARIOS.SUCURSAL, VP_BENEFICIARIOS.AREA_FISICA, VP_BENEFICIARIOS.DESTINACION_ECONOMICA, VP_DES.CODIGO FACTOR_DESTINACION_ECONOMICA, VP_BENEFICIARIOS.GRADO_BENEFICIO, VP_BEN.CODIGO FACTOR_GRADO_BENEFICIO, VP_BENEFICIARIOS.DIRECCION_CORRESPONDENCIA, VP_BENEFICIARIOS.NUMERO_RESOLUCION,(CASE VP_BENEFICIARIOS.EN_ACUERDO WHEN 0 THEN 'false' ELSE 'true' END) EN_ACUERDO, VP_BENEFICIARIOS.AREA_AFECTADA, VP_BENEFICIARIOS.AREA_GRAVADA, VP_BENEFICIARIOS.CEDULA_CATASTRAL, VP_BENEFICIARIOS.DOCUMENTO_PROPIETARIO, VP_BENEFICIARIOS.MATRICULA_INMOBILIARIA, VP_BENEFICIARIOS.DIRECCION, VP_BENEFICIARIOS.CREATED_BY,(TO_CHAR(VP_BENEFICIARIOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, VP_BENEFICIARIOS.MODIFIED_BY,(TO_CHAR(VP_BENEFICIARIOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, VP_BENEFICIARIOS.AREA_BRUTA, VP_BENEFICIARIOS.AFECTACIONES, VP_BENEFICIARIOS.AREA_NETA, VP_BENEFICIARIOS.CODIGOETAPA, VP_ETAPAS_PROCESO.NOMBRE NOMBRE_ETAPA,(CASE VP_BENEFICIARIOS.PREDIAL_EXCLUIDO WHEN 0 THEN 'false' ELSE 'true' END) PREDIAL_EXCLUIDO, VP_BENEFICIARIOS.PORCENTAJE_PARTICIPACION FROM VP_BENEFICIARIOS INNER JOIN TERCERO ON VP_BENEFICIARIOS.COMPANIA = TERCERO.COMPANIA AND VP_BENEFICIARIOS.TERCERO = TERCERO.NIT AND VP_BENEFICIARIOS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN VP_PROYECTOS ON VP_BENEFICIARIOS.ID_PROYECTO = VP_PROYECTOS.ID LEFT JOIN VP_ETAPAS_PROCESO ON VP_BENEFICIARIOS.CODIGOETAPA = VP_ETAPAS_PROCESO.CODIGO LEFT JOIN VP_FACTORES VP_DES ON VP_BENEFICIARIOS.DESTINACION_ECONOMICA = VP_DES.ID LEFT JOIN VP_FACTORES VP_BEN ON VP_BENEFICIARIOS.GRADO_BENEFICIO = VP_BEN.ID WHERE VP_BENEFICIARIOS.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","ID_PROYECTO":"$ID_PROYECTO","COMPANIA":"$COMPANIA","CODIGO_PROYECTO":"$CODIGO_PROYECTO","PRODESC":"$PRODESC","CLASE":"$CLASE","IP_CODIGO":"$IP_CODIGO","IP_NUMERO_ORDEN":"$IP_NUMERO_ORDEN","NOMBRE_USUARIO":"$NOMBRE_USUARIO","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","SUCURSAL":"$SUCURSAL","AREA_FISICA":"$AREA_FISICA","DESTINACION_ECONOMICA":"$DESTINACION_ECONOMICA","FACTOR_DESTINACION_ECONOMICA":"$FACTOR_DESTINACION_ECONOMICA","GRADO_BENEFICIO":"$GRADO_BENEFICIO","FACTOR_GRADO_BENEFICIO":"$FACTOR_GRADO_BENEFICIO","DIRECCION_CORRESPONDENCIA":"$DIRECCION_CORRESPONDENCIA","NUMERO_RESOLUCION":"$NUMERO_RESOLUCION","EN_ACUERDO":"$EN_ACUERDO(type:boolean)","AREA_AFECTADA":"$AREA_AFECTADA","AREA_GRAVADA":"$AREA_GRAVADA","CEDULA_CATASTRAL":"$CEDULA_CATASTRAL","DOCUMENTO_PROPIETARIO":"$DOCUMENTO_PROPIETARIO","MATRICULA_INMOBILIARIA":"$MATRICULA_INMOBILIARIA","DIRECCION":"$DIRECCION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","AREA_BRUTA":"$AREA_BRUTA","AFECTACIONES":"$AFECTACIONES","AREA_NETA":"$AREA_NETA","CODIGOETAPA":"$CODIGOETAPA(type:integer)","NOMBRE_ETAPA":"$NOMBRE_ETAPA","PREDIAL_EXCLUIDO":"$PREDIAL_EXCLUIDO(type:boolean)","PORCENTAJE_PARTICIPACION":"$PORCENTAJE_PARTICIPACION(type:double)"}]}}		</result>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
