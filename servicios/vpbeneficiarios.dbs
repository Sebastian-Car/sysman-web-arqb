	<query id="updateVpbeneficiarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VP_BENEFICIARIOS SET COMPANIA=:COMPANIA, ID_PROYECTO=:ID_PROYECTO, CODIGO_PROYECTO=:CODIGO_PROYECTO, CLASE=:CLASE, IP_CODIGO=:IP_CODIGO, IP_NUMERO_ORDEN=:IP_NUMERO_ORDEN, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, AREA_FISICA=:AREA_FISICA, NOMBRE_USUARIO=:NOMBRE_USUARIO, DESTINACION_ECONOMICA=:DESTINACION_ECONOMICA, GRADO_BENEFICIO=:GRADO_BENEFICIO, DIRECCION_CORRESPONDENCIA=:DIRECCION_CORRESPONDENCIA, MATRICULA_INMOBILIARIA=:MATRICULA_INMOBILIARIA, DIRECCION=:DIRECCION, AREA_AFECTADA=:AREA_AFECTADA, AREA_GRAVADA=:AREA_GRAVADA, CEDULA_CATASTRAL=:CEDULA_CATASTRAL, DOCUMENTO_PROPIETARIO=:DOCUMENTO_PROPIETARIO, CODIGOETAPA=:CODIGOETAPA, NUMERO_RESOLUCION=:NUMERO_RESOLUCION, EN_ACUERDO=:EN_ACUERDO, PREDIAL_EXCLUIDO=:PREDIAL_EXCLUIDO, PORCENTAJE_PARTICIPACION=:PORCENTAJE_PARTICIPACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VP_BENEFICIARIOS.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
