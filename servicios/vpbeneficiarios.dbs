	<query id="deleteVpbeneficiarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VP_BENEFICIARIOS WHERE VP_BENEFICIARIOS.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vpbeneficiarios">
