	</resource>
	<query id="getVpbeneficiariosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT VP_BENEFICIARIOS.ID, VP_BENEFICIARIOS.COMPANIA, VP_BENEFICIARIOS.IP_CODIGO,(CASE VP_BENEFICIARIOS.PREDIAL_EXCLUIDO WHEN 0 THEN 'false' ELSE 'true' END) PREDIAL_EXCLUIDO, VP_BENEFICIARIOS.PORCENTAJE_PARTICIPACION, VP_BENEFICIARIOS.CEDULA_CATASTRAL, VP_BENEFICIARIOS.DOCUMENTO_PROPIETARIO, VP_BENEFICIARIOS.NOMBRE_USUARIO, VP_BENEFICIARIOS.TERCERO, TERCERO.NOMBRE, TO_CHAR( CASE WHEN VP_BENEFICIARIOS.CLASE = ('45') THEN VP_BENEFICIARIOS.AREA_GRAVADA ELSE VP_BENEFICIARIOS.AREA_NETA END) AREA_TOTAL FROM VP_BENEFICIARIOS INNER JOIN TERCERO ON VP_BENEFICIARIOS.COMPANIA = TERCERO.COMPANIA AND VP_BENEFICIARIOS.TERCERO = TERCERO.NIT AND VP_BENEFICIARIOS.SUCURSAL = TERCERO.SUCURSAL WHERE VP_BENEFICIARIOS.COMPANIA = :COMPANIA AND VP_BENEFICIARIOS.ID_PROYECTO = :PROYECTO) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN IP_CODIGO IS NULL THEN ' ' ELSE UPPER(IP_CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:IP_CODIGO), '%')) AND (CASE WHEN PREDIAL_EXCLUIDO IS NULL THEN ' ' ELSE UPPER(PREDIAL_EXCLUIDO) END) LIKE UPPER(CONCAT(CONCAT('%',:PREDIAL_EXCLUIDO), '%')) AND (CASE WHEN PORCENTAJE_PARTICIPACION IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_PARTICIPACION) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE_PARTICIPACION), '%')) AND (CASE WHEN CEDULA_CATASTRAL IS NULL THEN ' ' ELSE UPPER(CEDULA_CATASTRAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CEDULA_CATASTRAL), '%')) AND (CASE WHEN DOCUMENTO_PROPIETARIO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO_PROPIETARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:DOCUMENTO_PROPIETARIO), '%')) AND (CASE WHEN NOMBRE_USUARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_USUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_USUARIO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN AREA_TOTAL IS NULL THEN ' ' ELSE UPPER(AREA_TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:AREA_TOTAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","IP_CODIGO":"$IP_CODIGO","PREDIAL_EXCLUIDO":"$PREDIAL_EXCLUIDO(type:boolean)","PORCENTAJE_PARTICIPACION":"$PORCENTAJE_PARTICIPACION(type:double)","CEDULA_CATASTRAL":"$CEDULA_CATASTRAL","DOCUMENTO_PROPIETARIO":"$DOCUMENTO_PROPIETARIO","NOMBRE_USUARIO":"$NOMBRE_USUARIO","TERCERO":"$TERCERO","NOMBRE":"$NOMBRE","AREA_TOTAL":"$AREA_TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="PREDIAL_EXCLUIDO" sqlType="STRING"/>
		<param name="PORCENTAJE_PARTICIPACION" sqlType="STRING"/>
		<param name="CEDULA_CATASTRAL" sqlType="STRING"/>
		<param name="DOCUMENTO_PROPIETARIO" sqlType="STRING"/>
		<param name="NOMBRE_USUARIO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="AREA_TOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vpbeneficiarios">
		<call-query href="getVpbeneficiariosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="PREDIAL_EXCLUIDO" query-param="PREDIAL_EXCLUIDO"/>
			<with-param name="PORCENTAJE_PARTICIPACION" query-param="PORCENTAJE_PARTICIPACION"/>
			<with-param name="CEDULA_CATASTRAL" query-param="CEDULA_CATASTRAL"/>
			<with-param name="DOCUMENTO_PROPIETARIO" query-param="DOCUMENTO_PROPIETARIO"/>
			<with-param name="NOMBRE_USUARIO" query-param="NOMBRE_USUARIO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="AREA_TOTAL" query-param="AREA_TOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVpbeneficiariosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT VP_BENEFICIARIOS.ID, VP_BENEFICIARIOS.COMPANIA, VP_BENEFICIARIOS.IP_CODIGO,(CASE VP_BENEFICIARIOS.PREDIAL_EXCLUIDO WHEN 0 THEN 'false' ELSE 'true' END) PREDIAL_EXCLUIDO, VP_BENEFICIARIOS.PORCENTAJE_PARTICIPACION, VP_BENEFICIARIOS.CEDULA_CATASTRAL, VP_BENEFICIARIOS.DOCUMENTO_PROPIETARIO, VP_BENEFICIARIOS.NOMBRE_USUARIO, VP_BENEFICIARIOS.TERCERO, TERCERO.NOMBRE, TO_CHAR( CASE WHEN VP_BENEFICIARIOS.CLASE = ('45') THEN VP_BENEFICIARIOS.AREA_GRAVADA ELSE VP_BENEFICIARIOS.AREA_NETA END) AREA_TOTAL FROM VP_BENEFICIARIOS INNER JOIN TERCERO ON VP_BENEFICIARIOS.COMPANIA = TERCERO.COMPANIA AND VP_BENEFICIARIOS.TERCERO = TERCERO.NIT AND VP_BENEFICIARIOS.SUCURSAL = TERCERO.SUCURSAL WHERE VP_BENEFICIARIOS.COMPANIA = :COMPANIA AND VP_BENEFICIARIOS.ID_PROYECTO = :PROYECTO) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN IP_CODIGO IS NULL THEN ' ' ELSE UPPER(IP_CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:IP_CODIGO), '%')) AND (CASE WHEN PREDIAL_EXCLUIDO IS NULL THEN ' ' ELSE UPPER(PREDIAL_EXCLUIDO) END) LIKE UPPER(CONCAT(CONCAT('%',:PREDIAL_EXCLUIDO), '%')) AND (CASE WHEN PORCENTAJE_PARTICIPACION IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_PARTICIPACION) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE_PARTICIPACION), '%')) AND (CASE WHEN CEDULA_CATASTRAL IS NULL THEN ' ' ELSE UPPER(CEDULA_CATASTRAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CEDULA_CATASTRAL), '%')) AND (CASE WHEN DOCUMENTO_PROPIETARIO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO_PROPIETARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:DOCUMENTO_PROPIETARIO), '%')) AND (CASE WHEN NOMBRE_USUARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_USUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_USUARIO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN AREA_TOTAL IS NULL THEN ' ' ELSE UPPER(AREA_TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:AREA_TOTAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="PREDIAL_EXCLUIDO" sqlType="STRING"/>
		<param name="PORCENTAJE_PARTICIPACION" sqlType="STRING"/>
		<param name="CEDULA_CATASTRAL" sqlType="STRING"/>
		<param name="DOCUMENTO_PROPIETARIO" sqlType="STRING"/>
		<param name="NOMBRE_USUARIO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="AREA_TOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vpbeneficiarios/numero">
		<call-query href="getVpbeneficiariosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
