<data name="evfunciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEvfuncionesPagGrillaFuncionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_FUNCIONES.NUMERO_MANUAL, EV_FUNCIONES.VERSION, TO_CHAR(EV_FUNCIONES.DESCRIPCION) DESCRIPCION, EV_FUNCIONES.CONSECUTIVO, EV_FUNCIONES.TIPO_FUNCION, EV_TIPO_FUNCION.NOMBRE  FROM EV_FUNCIONES INNER JOIN EV_MANUAL ON EV_FUNCIONES.COMPANIA = EV_MANUAL.COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL = EV_MANUAL.NUMERO_MANUAL AND EV_FUNCIONES.VERSION = EV_MANUAL.VERSION INNER JOIN PERSONAL ON EV_MANUAL.COMPANIA = PERSONAL.COMPANIA AND EV_MANUAL.CARGO = PERSONAL.ID_DE_CARGO AND EV_MANUAL.ESCALAFON = PERSONAL.ESCALAFON AND EV_MANUAL.CATEGORIA = PERSONAL.ID_DE_CATEGORIA LEFT JOIN EV_TIPO_FUNCION ON EV_FUNCIONES.COMPANIA = EV_TIPO_FUNCION.COMPANIA AND EV_FUNCIONES.TIPO_FUNCION = EV_TIPO_FUNCION.CODIGO WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.NUMERO_DCTO = :NRODOCUMENTO AND PERSONAL.SUCURSAL = :SUCURSAL AND PERSONAL.ESTADO_ACTUAL NOT IN (3) AND EV_MANUAL.ESTADO IN ('A')) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN TIPO_FUNCION IS NULL THEN ' ' ELSE UPPER(TIPO_FUNCION) END)  LIKE UPPER(:TIPO_FUNCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_MANUAL":"$NUMERO_MANUAL","VERSION":"$VERSION","DESCRIPCION":"$DESCRIPCION","CONSECUTIVO":"$CONSECUTIVO(type:long)","TIPO_FUNCION":"$TIPO_FUNCION","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRODOCUMENTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evfunciones/grillafunciones/pag">
		<call-query href="getEvfuncionesPagGrillaFuncionesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRODOCUMENTO" query-param="NRODOCUMENTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvfuncionesNumGrillaFuncionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_FUNCIONES.NUMERO_MANUAL, EV_FUNCIONES.VERSION, TO_CHAR(EV_FUNCIONES.DESCRIPCION) DESCRIPCION, EV_FUNCIONES.CONSECUTIVO, EV_FUNCIONES.TIPO_FUNCION, EV_TIPO_FUNCION.NOMBRE  FROM EV_FUNCIONES INNER JOIN EV_MANUAL ON EV_FUNCIONES.COMPANIA = EV_MANUAL.COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL = EV_MANUAL.NUMERO_MANUAL AND EV_FUNCIONES.VERSION = EV_MANUAL.VERSION INNER JOIN PERSONAL ON EV_MANUAL.COMPANIA = PERSONAL.COMPANIA AND EV_MANUAL.CARGO = PERSONAL.ID_DE_CARGO AND EV_MANUAL.ESCALAFON = PERSONAL.ESCALAFON AND EV_MANUAL.CATEGORIA = PERSONAL.ID_DE_CATEGORIA LEFT JOIN EV_TIPO_FUNCION ON EV_FUNCIONES.COMPANIA = EV_TIPO_FUNCION.COMPANIA AND EV_FUNCIONES.TIPO_FUNCION = EV_TIPO_FUNCION.CODIGO WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.NUMERO_DCTO = :NRODOCUMENTO AND PERSONAL.SUCURSAL = :SUCURSAL AND PERSONAL.ESTADO_ACTUAL NOT IN (3) AND EV_MANUAL.ESTADO IN ('A')) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN TIPO_FUNCION IS NULL THEN ' ' ELSE UPPER(TIPO_FUNCION) END)  LIKE UPPER(:TIPO_FUNCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRODOCUMENTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evfunciones/grillafunciones/num">
		<call-query href="getEvfuncionesNumGrillaFuncionesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRODOCUMENTO" query-param="NRODOCUMENTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getEvfuncionesPagFuncionesgrilladesdenombramientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_FUNCIONES.NUMERO_MANUAL , EV_FUNCIONES.VERSION, TO_CHAR(SUBSTR(EV_FUNCIONES.DESCRIPCION,0,1900)) DESCRIPCION, EV_FUNCIONES.CONSECUTIVO, EV_FUNCIONES.TIPO_FUNCION, EV_TIPO_FUNCION.NOMBRE  FROM EV_FUNCIONES INNER JOIN EV_MANUAL ON EV_FUNCIONES.COMPANIA = EV_MANUAL.COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL = EV_MANUAL.NUMERO_MANUAL AND EV_FUNCIONES.VERSION = EV_MANUAL.VERSION LEFT JOIN CARGOS ON CARGOS.COMPANIA = EV_MANUAL.COMPANIA AND CARGOS.ID_DE_CARGO = EV_MANUAL.CARGO LEFT JOIN EV_TIPO_FUNCION ON EV_FUNCIONES.COMPANIA = EV_TIPO_FUNCION.COMPANIA AND EV_FUNCIONES.TIPO_FUNCION = EV_TIPO_FUNCION.CODIGO INNER JOIN DEPENDENCIA ON EV_MANUAL.COMPANIA = DEPENDENCIA.COMPANIA AND EV_MANUAL.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE EV_MANUAL.COMPANIA = :COMPANIA AND EV_MANUAL.CARGO = :CARGO AND EV_MANUAL.DEPENDENCIA = :DEPENDENCIA AND EV_MANUAL.ESTADO IN ('A')) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN TIPO_FUNCION IS NULL THEN ' ' ELSE UPPER(TIPO_FUNCION) END)  LIKE UPPER(:TIPO_FUNCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_MANUAL":"$NUMERO_MANUAL","VERSION":"$VERSION","DESCRIPCION":"$DESCRIPCION","CONSECUTIVO":"$CONSECUTIVO(type:long)","TIPO_FUNCION":"$TIPO_FUNCION","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evfunciones/funcionesgrilladesdenombramiento/pag">
		<call-query href="getEvfuncionesPagFuncionesgrilladesdenombramientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvfuncionesNumFuncionesgrilladesdenombramientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_FUNCIONES.NUMERO_MANUAL , EV_FUNCIONES.VERSION, TO_CHAR(SUBSTR(EV_FUNCIONES.DESCRIPCION,0,1900)) DESCRIPCION, EV_FUNCIONES.CONSECUTIVO, EV_FUNCIONES.TIPO_FUNCION, EV_TIPO_FUNCION.NOMBRE  FROM EV_FUNCIONES INNER JOIN EV_MANUAL ON EV_FUNCIONES.COMPANIA = EV_MANUAL.COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL = EV_MANUAL.NUMERO_MANUAL AND EV_FUNCIONES.VERSION = EV_MANUAL.VERSION LEFT JOIN CARGOS ON CARGOS.COMPANIA = EV_MANUAL.COMPANIA AND CARGOS.ID_DE_CARGO = EV_MANUAL.CARGO LEFT JOIN EV_TIPO_FUNCION ON EV_FUNCIONES.COMPANIA = EV_TIPO_FUNCION.COMPANIA AND EV_FUNCIONES.TIPO_FUNCION = EV_TIPO_FUNCION.CODIGO INNER JOIN DEPENDENCIA ON EV_MANUAL.COMPANIA = DEPENDENCIA.COMPANIA AND EV_MANUAL.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE EV_MANUAL.COMPANIA = :COMPANIA AND EV_MANUAL.CARGO = :CARGO AND EV_MANUAL.DEPENDENCIA = :DEPENDENCIA AND EV_MANUAL.ESTADO IN ('A')) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN TIPO_FUNCION IS NULL THEN ' ' ELSE UPPER(TIPO_FUNCION) END)  LIKE UPPER(:TIPO_FUNCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evfunciones/funcionesgrilladesdenombramiento/num">
		<call-query href="getEvfuncionesNumFuncionesgrilladesdenombramientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertEvfunciones" keyColumns="COMPANIA,NUMERO_MANUAL,VERSION,TIPO_FUNCION,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_FUNCIONES (COMPANIA, NUMERO_MANUAL, VERSION, TIPO_FUNCION, CONSECUTIVO, DESCRIPCION, CARGO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NUMERO_MANUAL, :VERSION, :TIPO_FUNCION, :CONSECUTIVO, :DESCRIPCION, :CARGO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_MANUAL":"$NUMERO_MANUAL","KEY_VERSION":"$VERSION","KEY_TIPO_FUNCION":"$TIPO_FUNCION","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="CARGO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evfunciones">
		<call-query href="insertEvfunciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteEvfunciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_FUNCIONES WHERE EV_FUNCIONES.COMPANIA= :KEY_COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_FUNCIONES.VERSION= :KEY_VERSION AND EV_FUNCIONES.TIPO_FUNCION= :KEY_TIPO_FUNCION AND EV_FUNCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_MANUAL" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_TIPO_FUNCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="evfunciones">
		<call-query href="deleteEvfunciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_MANUAL" query-param="KEY_NUMERO_MANUAL"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_TIPO_FUNCION" query-param="KEY_TIPO_FUNCION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEvfuncionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT EV_FUNCIONES.COMPANIA, EV_FUNCIONES.NUMERO_MANUAL, EV_MANUAL.NOMBRE_MANUAL, EV_FUNCIONES.VERSION, EV_FUNCIONES.TIPO_FUNCION, EV_TIPO_FUNCION.NOMBRE, CARGOS.NOMBRE_DEL_CARGO, EV_FUNCIONES.CONSECUTIVO FROM EV_FUNCIONES INNER JOIN EV_TIPO_FUNCION ON EV_TIPO_FUNCION.COMPANIA = EV_FUNCIONES.COMPANIA AND EV_TIPO_FUNCION.CODIGO = EV_FUNCIONES.TIPO_FUNCION LEFT JOIN EV_MANUAL ON EV_FUNCIONES.COMPANIA = EV_MANUAL.COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL = EV_MANUAL.NUMERO_MANUAL AND EV_FUNCIONES.VERSION = EV_MANUAL.VERSION LEFT JOIN CARGOS ON EV_FUNCIONES.COMPANIA = CARGOS.COMPANIA AND EV_FUNCIONES.CARGO = CARGOS.ID_DE_CARGO WHERE EV_FUNCIONES.COMPANIA = :COMPANIA AND -1 = CASE WHEN :NUMERO IS NULL THEN -1 WHEN EV_MANUAL.NUMERO_MANUAL = :NUMERO THEN -1 ELSE 0 END AND -1 = CASE WHEN :VERSION IS NULL THEN -1 WHEN EV_MANUAL.VERSION = :VERSION THEN -1 ELSE 0 END) INI WHERE (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_MANUAL), '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN TIPO_FUNCION IS NULL THEN ' ' ELSE UPPER(TIPO_FUNCION) END) LIKE UPPER(CONCAT(:TIPO_FUNCION, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEL_CARGO), '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_MANUAL":"$NUMERO_MANUAL","NOMBRE_MANUAL":"$NOMBRE_MANUAL","VERSION":"$VERSION","TIPO_FUNCION":"$TIPO_FUNCION","NOMBRE":"$NOMBRE","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="NOMBRE_MANUAL" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evfunciones">
		<call-query href="getEvfuncionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="NOMBRE_MANUAL" query-param="NOMBRE_MANUAL"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvfuncionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT EV_FUNCIONES.COMPANIA, EV_FUNCIONES.NUMERO_MANUAL, EV_MANUAL.NOMBRE_MANUAL, EV_FUNCIONES.VERSION, EV_FUNCIONES.TIPO_FUNCION, EV_TIPO_FUNCION.NOMBRE, CARGOS.NOMBRE_DEL_CARGO, EV_FUNCIONES.CONSECUTIVO FROM EV_FUNCIONES INNER JOIN EV_TIPO_FUNCION ON EV_TIPO_FUNCION.COMPANIA = EV_FUNCIONES.COMPANIA AND EV_TIPO_FUNCION.CODIGO = EV_FUNCIONES.TIPO_FUNCION LEFT JOIN EV_MANUAL ON EV_FUNCIONES.COMPANIA = EV_MANUAL.COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL = EV_MANUAL.NUMERO_MANUAL AND EV_FUNCIONES.VERSION = EV_MANUAL.VERSION LEFT JOIN CARGOS ON EV_FUNCIONES.COMPANIA = CARGOS.COMPANIA AND EV_FUNCIONES.CARGO = CARGOS.ID_DE_CARGO WHERE EV_FUNCIONES.COMPANIA = :COMPANIA AND -1 = CASE WHEN :NUMERO IS NULL THEN -1 WHEN EV_MANUAL.NUMERO_MANUAL = :NUMERO THEN -1 ELSE 0 END AND -1 = CASE WHEN :VERSION IS NULL THEN -1 WHEN EV_MANUAL.VERSION = :VERSION THEN -1 ELSE 0 END) INI WHERE (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_MANUAL), '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN TIPO_FUNCION IS NULL THEN ' ' ELSE UPPER(TIPO_FUNCION) END) LIKE UPPER(CONCAT(:TIPO_FUNCION, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEL_CARGO), '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="NOMBRE_MANUAL" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evfunciones/numero">
		<call-query href="getEvfuncionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="NOMBRE_MANUAL" query-param="NOMBRE_MANUAL"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEvfuncionesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT EV_FUNCIONES.COMPANIA, EV_FUNCIONES.NUMERO_MANUAL, EV_MANUAL.NOMBRE_MANUAL, EV_FUNCIONES.VERSION, EV_FUNCIONES.TIPO_FUNCION, EV_TIPO_FUNCION.NOMBRE, EV_FUNCIONES.CONSECUTIVO, EV_FUNCIONES.DESCRIPCION, EV_MANUAL.SIGLA, EV_FUNCIONES.CREATED_BY,(TO_CHAR(EV_FUNCIONES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, EV_FUNCIONES.MODIFIED_BY,(TO_CHAR(EV_FUNCIONES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, EV_FUNCIONES.CARGO, CARGOS.NOMBRE_DEL_CARGO FROM EV_FUNCIONES INNER JOIN EV_TIPO_FUNCION ON EV_TIPO_FUNCION.COMPANIA = EV_FUNCIONES.COMPANIA AND EV_TIPO_FUNCION.CODIGO = EV_FUNCIONES.TIPO_FUNCION LEFT JOIN EV_MANUAL ON EV_FUNCIONES.COMPANIA = EV_MANUAL.COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL = EV_MANUAL.NUMERO_MANUAL AND EV_FUNCIONES.VERSION = EV_MANUAL.VERSION LEFT JOIN CARGOS ON EV_FUNCIONES.COMPANIA = CARGOS.COMPANIA AND EV_FUNCIONES.CARGO = CARGOS.ID_DE_CARGO WHERE EV_FUNCIONES.COMPANIA= :KEY_COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_FUNCIONES.VERSION= :KEY_VERSION AND EV_FUNCIONES.TIPO_FUNCION= :KEY_TIPO_FUNCION AND EV_FUNCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_MANUAL":"$NUMERO_MANUAL","NOMBRE_MANUAL":"$NOMBRE_MANUAL","VERSION":"$VERSION","TIPO_FUNCION":"$TIPO_FUNCION","NOMBRE":"$NOMBRE","CONSECUTIVO":"$CONSECUTIVO(type:long)","DESCRIPCION":"$DESCRIPCION","SIGLA":"$SIGLA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CARGO":"$CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_MANUAL" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_TIPO_FUNCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evfunciones/data">
		<call-query href="getEvfuncionesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_MANUAL" query-param="KEY_NUMERO_MANUAL"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_TIPO_FUNCION" query-param="KEY_TIPO_FUNCION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateEvfunciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_FUNCIONES SET NUMERO_MANUAL=:NUMERO_MANUAL, VERSION=:VERSION, TIPO_FUNCION=:TIPO_FUNCION, DESCRIPCION=:DESCRIPCION, CARGO=:CARGO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE EV_FUNCIONES.COMPANIA= :KEY_COMPANIA AND EV_FUNCIONES.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_FUNCIONES.VERSION= :KEY_VERSION AND EV_FUNCIONES.TIPO_FUNCION= :KEY_TIPO_FUNCION AND EV_FUNCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="TIPO_FUNCION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_MANUAL" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_TIPO_FUNCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evfunciones">
		<call-query href="updateEvfunciones">
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIPO_FUNCION" query-param="TIPO_FUNCION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_MANUAL" query-param="KEY_NUMERO_MANUAL"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_TIPO_FUNCION" query-param="KEY_TIPO_FUNCION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>