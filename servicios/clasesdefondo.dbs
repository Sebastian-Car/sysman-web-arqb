<data name="clasesdefondo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getClasesdefondoCodigoYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASEDEFONDO.CODIGO, CLASEDEFONDO.NOMBRE  FROM CLASEDEFONDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="clasesdefondo/codigoynombre">
		<call-query href="getClasesdefondoCodigoYNombreQuery">
 
		</call-query>
	</resource>
	<query id="getClasesdefondoNombrestiposdefondoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, NOMBRE FROM CLASEDEFONDO WHERE INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CODIGOS,' ','') ),CONCAT( '', CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(CODIGO,' ','') ), '')),1) &gt; 0 ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="CODIGOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesdefondo/nombrestiposdefondo">
		<call-query href="getClasesdefondoNombrestiposdefondoQuery">
			<with-param name="CODIGOS" query-param="CODIGOS"/>

		</call-query>
	</resource>
	<query id="getClasesdefondoFondounionQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASEDEFONDO.CODIGO, CLASEDEFONDO.NOMBRE FROM CLASEDEFONDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="clasesdefondo/fondounion">
		<call-query href="getClasesdefondoFondounionQuery">
 
		</call-query>
	</resource>
	<query id="getClasesdefondoFondosespecificosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM CLASEDEFONDO WHERE CODIGO IN ('CES','AFP','EPS','ARL','APV','AFC','CCF', 'FMP','SIN') ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="clasesdefondo/fondosespecificos">
		<call-query href="getClasesdefondoFondosespecificosQuery">
 
		</call-query>
	</resource>

</data>