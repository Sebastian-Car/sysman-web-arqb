<data name="natjurexperiencia" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatjurexperiencia" keyColumns="COMPANIA,NUMERO,NITSOCIEDAD,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_JUREXPERIENCIA (NUMERO, NITSOCIEDAD, ENTIDADCONTRATA, TIPO, TELEFONO, FECHATERMINA, VALORSERVICIO, CREATED_BY, DATE_CREATED, COMPANIA, SUCURSAL) VALUES (:NUMERO, :NITSOCIEDAD, :ENTIDADCONTRATA, :TIPO, :TELEFONO, TO_DATE(:FECHATERMINA,'DD/MM/YYYY HH24:MI:SS'), :VALORSERVICIO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :COMPANIA, :SUCURSAL)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO","KEY_NITSOCIEDAD":"$NITSOCIEDAD","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NITSOCIEDAD" sqlType="STRING"/>
		<param defaultValue="" name="ENTIDADCONTRATA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO" sqlType="STRING"/>
		<param defaultValue="" name="FECHATERMINA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORSERVICIO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natjurexperiencia">
		<call-query href="insertNatjurexperiencia">
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NITSOCIEDAD" query-param="NITSOCIEDAD"/>
			<with-param name="ENTIDADCONTRATA" query-param="ENTIDADCONTRATA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FECHATERMINA" query-param="FECHATERMINA"/>
			<with-param name="VALORSERVICIO" query-param="VALORSERVICIO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="deleteNatjurexperiencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_JUREXPERIENCIA WHERE NAT_JUREXPERIENCIA.COMPANIA= :KEY_COMPANIA AND NAT_JUREXPERIENCIA.NUMERO= :KEY_NUMERO AND NAT_JUREXPERIENCIA.NITSOCIEDAD= :KEY_NITSOCIEDAD AND NAT_JUREXPERIENCIA.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_NITSOCIEDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natjurexperiencia">
		<call-query href="deleteNatjurexperiencia">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_NITSOCIEDAD" query-param="KEY_NITSOCIEDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatjurexperienciaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_JUREXPERIENCIA.NUMERO, NAT_JUREXPERIENCIA.NITSOCIEDAD, NAT_JUREXPERIENCIA.ENTIDADCONTRATA, NAT_JUREXPERIENCIA.TIPO, NAT_JUREXPERIENCIA.TELEFONO,(TO_CHAR(NAT_JUREXPERIENCIA.FECHATERMINA,'DD/MM/YYYY HH24:MI:SS')) FECHATERMINA, NAT_JUREXPERIENCIA.VALORSERVICIO, NAT_JUREXPERIENCIA.COMPANIA, NAT_JUREXPERIENCIA.SUCURSAL, CASE WHEN NAT_JUREXPERIENCIA.TIPO = 'PUB' THEN 'PUBLICA' ELSE 'PRIVADA' END NOMBRE_TIPO  FROM NAT_JUREXPERIENCIA WHERE NAT_JUREXPERIENCIA.COMPANIA =:COMPANIA AND NAT_JUREXPERIENCIA.NITSOCIEDAD = :NIT AND NAT_JUREXPERIENCIA.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ENTIDADCONTRATA IS NULL THEN ' ' ELSE UPPER(ENTIDADCONTRATA) END)  LIKE UPPER( '%' || :ENTIDADCONTRATA || '%')  AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END)  LIKE UPPER( '%' || :TELEFONO || '%')  AND (CASE WHEN FECHATERMINA IS NULL THEN ' ' ELSE UPPER(FECHATERMINA) END)  LIKE UPPER(:FECHATERMINA || '%')  AND (CASE WHEN VALORSERVICIO IS NULL THEN ' ' ELSE UPPER(VALORSERVICIO) END)  LIKE UPPER( '%' || :VALORSERVICIO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER(:NOMBRE_TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","NITSOCIEDAD":"$NITSOCIEDAD","ENTIDADCONTRATA":"$ENTIDADCONTRATA","TIPO":"$TIPO","TELEFONO":"$TELEFONO","FECHATERMINA":"$FECHATERMINA","VALORSERVICIO":"$VALORSERVICIO","COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NOMBRE_TIPO":"$NOMBRE_TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ENTIDADCONTRATA" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="FECHATERMINA" sqlType="STRING"/>
		<param name="VALORSERVICIO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natjurexperiencia">
		<call-query href="getNatjurexperienciaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ENTIDADCONTRATA" query-param="ENTIDADCONTRATA"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FECHATERMINA" query-param="FECHATERMINA"/>
			<with-param name="VALORSERVICIO" query-param="VALORSERVICIO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatjurexperienciaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_JUREXPERIENCIA.NUMERO, NAT_JUREXPERIENCIA.NITSOCIEDAD, NAT_JUREXPERIENCIA.ENTIDADCONTRATA, NAT_JUREXPERIENCIA.TIPO, NAT_JUREXPERIENCIA.TELEFONO,(TO_CHAR(NAT_JUREXPERIENCIA.FECHATERMINA,'DD/MM/YYYY HH24:MI:SS')) FECHATERMINA, NAT_JUREXPERIENCIA.VALORSERVICIO, NAT_JUREXPERIENCIA.COMPANIA, NAT_JUREXPERIENCIA.SUCURSAL, CASE WHEN NAT_JUREXPERIENCIA.TIPO = 'PUB' THEN 'PUBLICA' ELSE 'PRIVADA' END NOMBRE_TIPO  FROM NAT_JUREXPERIENCIA WHERE NAT_JUREXPERIENCIA.COMPANIA =:COMPANIA AND NAT_JUREXPERIENCIA.NITSOCIEDAD = :NIT AND NAT_JUREXPERIENCIA.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ENTIDADCONTRATA IS NULL THEN ' ' ELSE UPPER(ENTIDADCONTRATA) END)  LIKE UPPER( '%' || :ENTIDADCONTRATA || '%')  AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END)  LIKE UPPER( '%' || :TELEFONO || '%')  AND (CASE WHEN FECHATERMINA IS NULL THEN ' ' ELSE UPPER(FECHATERMINA) END)  LIKE UPPER(:FECHATERMINA || '%')  AND (CASE WHEN VALORSERVICIO IS NULL THEN ' ' ELSE UPPER(VALORSERVICIO) END)  LIKE UPPER( '%' || :VALORSERVICIO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER(:NOMBRE_TIPO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ENTIDADCONTRATA" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="FECHATERMINA" sqlType="STRING"/>
		<param name="VALORSERVICIO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natjurexperiencia/numero">
		<call-query href="getNatjurexperienciaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ENTIDADCONTRATA" query-param="ENTIDADCONTRATA"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FECHATERMINA" query-param="FECHATERMINA"/>
			<with-param name="VALORSERVICIO" query-param="VALORSERVICIO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>

		</call-query>
	</resource>
	<query id="updateNatjurexperiencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_JUREXPERIENCIA SET NUMERO=:NUMERO, NITSOCIEDAD=:NITSOCIEDAD, ENTIDADCONTRATA=:ENTIDADCONTRATA, TIPO=:TIPO, TELEFONO=:TELEFONO, FECHATERMINA=TO_DATE(:FECHATERMINA,'DD/MM/YYYY HH24:MI:SS'), VALORSERVICIO=:VALORSERVICIO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), COMPANIA=:COMPANIA, SUCURSAL=:SUCURSAL WHERE NAT_JUREXPERIENCIA.COMPANIA= :KEY_COMPANIA AND NAT_JUREXPERIENCIA.NUMERO= :KEY_NUMERO AND NAT_JUREXPERIENCIA.NITSOCIEDAD= :KEY_NITSOCIEDAD AND NAT_JUREXPERIENCIA.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO" sqlType="STRING"/>
		<param name="NITSOCIEDAD" sqlType="STRING"/>
		<param name="ENTIDADCONTRATA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="FECHATERMINA" sqlType="STRING"/>
		<param name="VALORSERVICIO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_NITSOCIEDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natjurexperiencia">
		<call-query href="updateNatjurexperiencia">
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NITSOCIEDAD" query-param="NITSOCIEDAD"/>
			<with-param name="ENTIDADCONTRATA" query-param="ENTIDADCONTRATA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="FECHATERMINA" query-param="FECHATERMINA"/>
			<with-param name="VALORSERVICIO" query-param="VALORSERVICIO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_NITSOCIEDAD" query-param="KEY_NITSOCIEDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>