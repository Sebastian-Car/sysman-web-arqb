<data name="inventarioscontabilidad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getInventarioscontabilidadExisteElementoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM INVENTARIOCONTABILIDAD WHERE COMPANIA= :COMPANIA AND ANO= :ANO AND CODIGOELEMENTO= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioscontabilidad/existeelemento">
		<call-query href="getInventarioscontabilidadExisteElementoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertInventarioscontabilidadInvContabilidad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INVENTARIOCONTABILIDAD (COMPANIA, CODIGOELEMENTO, ANO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGOELEMENTO, :ANO, :CREATED_BY, :DATE_CREATED)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="inventarioscontabilidad/invcontabilidad">
		<call-query href="insertInventarioscontabilidadInvContabilidad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="getInventarioscontabilidadPagCodigoNombreConMovQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRECORTO  FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO NOT IN (0)) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END)  LIKE UPPER( '%' || :NOMBRECORTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRECORTO":"$NOMBRECORTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarioscontabilidad/codigonombreconmov/pag">
		<call-query href="getInventarioscontabilidadPagCodigoNombreConMovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRECORTO" query-param="NOMBRECORTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventarioscontabilidadNumCodigoNombreConMovQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRECORTO  FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO NOT IN (0)) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END)  LIKE UPPER( '%' || :NOMBRECORTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioscontabilidad/codigonombreconmov/num">
		<call-query href="getInventarioscontabilidadNumCodigoNombreConMovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRECORTO" query-param="NOMBRECORTO"/>

		</call-query>
	</resource>
	<query id="getInventarioscontabilidadContieneElementosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM INVENTARIOCONTABILIDAD WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGOELEMENTO= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioscontabilidad/contieneelementos">
		<call-query href="getInventarioscontabilidadContieneElementosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertInventarioscontabilidad" keyColumns="COMPANIA,CODIGOELEMENTO,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INVENTARIOCONTABILIDAD (COMPANIA, CODIGOELEMENTO, ANO, AJUSINFLACREDITO, AJUSINFLADEBITO, AJUSDEPRECCREDITO, AJUSDEPRECDEBITO, DEPRECCREDITO, DEPRECDEBITO, COSTOSALDB, COSTOSALCR, COSTOSALAJDB, COSTOSALAJCR, AJUSINFLADEBITOS, AJUSINFLACREDITOS, DEPRECDEBITOS, DEPRECCREDITOS, AJUSDEPRECDEBITOS, AJUSDEPRECCREDITOS, DEPACUMULADADB, DEPACUMULADACR, AJUSTEDEPRECIACIONDB, AJUSTEDEPRECIACIONCR, DEPRECDEBITOCOMODATO1, DEPRECCREDITOCOMODATO, DEPRECDEBITOSCOMODATO, DEPRECCREDITOSCOMODATO, DEPACUMULADADBCOMODATO, DEPACUMULADACRCOMODATO, DEPCUANTIAMIN_DEB, DEPCUANTIAMIN_CRE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGOELEMENTO, :ANO, :AJUSINFLACREDITO, :AJUSINFLADEBITO, :AJUSDEPRECCREDITO, :AJUSDEPRECDEBITO, :DEPRECCREDITO, :DEPRECDEBITO, :COSTOSALDB, :COSTOSALCR, :COSTOSALAJDB, :COSTOSALAJCR, :AJUSINFLADEBITOS, :AJUSINFLACREDITOS, :DEPRECDEBITOS, :DEPRECCREDITOS, :AJUSDEPRECDEBITOS, :AJUSDEPRECCREDITOS, :DEPACUMULADADB, :DEPACUMULADACR, :AJUSTEDEPRECIACIONDB, :AJUSTEDEPRECIACIONCR, :DEPRECDEBITOCOMODATO1, :DEPRECCREDITOCOMODATO, :DEPRECDEBITOSCOMODATO, :DEPRECCREDITOSCOMODATO, :DEPACUMULADADBCOMODATO, :DEPACUMULADACRCOMODATO, :DEPCUANTIAMIN_DEB, :DEPCUANTIAMIN_CRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOELEMENTO":"$CODIGOELEMENTO","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="AJUSINFLACREDITO" sqlType="STRING"/>
		<param defaultValue="" name="AJUSINFLADEBITO" sqlType="STRING"/>
		<param defaultValue="" name="AJUSDEPRECCREDITO" sqlType="STRING"/>
		<param defaultValue="" name="AJUSDEPRECDEBITO" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECCREDITO" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECDEBITO" sqlType="STRING"/>
		<param defaultValue="" name="COSTOSALDB" sqlType="STRING"/>
		<param defaultValue="" name="COSTOSALCR" sqlType="STRING"/>
		<param defaultValue="" name="COSTOSALAJDB" sqlType="STRING"/>
		<param defaultValue="" name="COSTOSALAJCR" sqlType="STRING"/>
		<param defaultValue="" name="AJUSINFLADEBITOS" sqlType="STRING"/>
		<param defaultValue="" name="AJUSINFLACREDITOS" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECDEBITOS" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECCREDITOS" sqlType="STRING"/>
		<param defaultValue="" name="AJUSDEPRECDEBITOS" sqlType="STRING"/>
		<param defaultValue="" name="AJUSDEPRECCREDITOS" sqlType="STRING"/>
		<param defaultValue="" name="DEPACUMULADADB" sqlType="STRING"/>
		<param defaultValue="" name="DEPACUMULADACR" sqlType="STRING"/>
		<param defaultValue="" name="AJUSTEDEPRECIACIONDB" sqlType="STRING"/>
		<param defaultValue="" name="AJUSTEDEPRECIACIONCR" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECDEBITOCOMODATO1" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECCREDITOCOMODATO" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECDEBITOSCOMODATO" sqlType="STRING"/>
		<param defaultValue="" name="DEPRECCREDITOSCOMODATO" sqlType="STRING"/>
		<param defaultValue="" name="DEPACUMULADADBCOMODATO" sqlType="STRING"/>
		<param defaultValue="" name="DEPACUMULADACRCOMODATO" sqlType="STRING"/>
		<param defaultValue="" name="DEPCUANTIAMIN_DEB" sqlType="STRING"/>
		<param defaultValue="" name="DEPCUANTIAMIN_CRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="inventarioscontabilidad">
