			<with-param name="DEPRECCREDITOSCOMODATO" query-param="DEPRECCREDITOSCOMODATO"/>
			<with-param name="DEPACUMULADADBCOMODATO" query-param="DEPACUMULADADBCOMODATO"/>
			<with-param name="DEPACUMULADACRCOMODATO" query-param="DEPACUMULADACRCOMODATO"/>
			<with-param name="DEPCUANTIAMIN_DEB" query-param="DEPCUANTIAMIN_DEB"/>
			<with-param name="DEPCUANTIAMIN_CRE" query-param="DEPCUANTIAMIN_CRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteInventarioscontabilidad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM INVENTARIOCONTABILIDAD WHERE INVENTARIOCONTABILIDAD.COMPANIA= :KEY_COMPANIA AND INVENTARIOCONTABILIDAD.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND INVENTARIOCONTABILIDAD.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="inventarioscontabilidad">
		<call-query href="deleteInventarioscontabilidad">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getInventarioscontabilidadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGOELEMENTO, ANO, AJUSINFLACREDITO, AJUSINFLADEBITO, AJUSDEPRECCREDITO, AJUSDEPRECDEBITO, DEPRECCREDITO, DEPRECDEBITO  FROM INVENTARIOCONTABILIDAD WHERE INVENTARIOCONTABILIDAD.COMPANIA = :COMPANIA AND INVENTARIOCONTABILIDAD.CODIGOELEMENTO = :CODIGO AND INVENTARIOCONTABILIDAD.ANO = :ANO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN AJUSINFLACREDITO IS NULL THEN ' ' ELSE UPPER(AJUSINFLACREDITO) END)  LIKE UPPER(:AJUSINFLACREDITO || '%')  AND (CASE WHEN AJUSINFLADEBITO IS NULL THEN ' ' ELSE UPPER(AJUSINFLADEBITO) END)  LIKE UPPER(:AJUSINFLADEBITO || '%')  AND (CASE WHEN AJUSDEPRECCREDITO IS NULL THEN ' ' ELSE UPPER(AJUSDEPRECCREDITO) END)  LIKE UPPER(:AJUSDEPRECCREDITO || '%')  AND (CASE WHEN AJUSDEPRECDEBITO IS NULL THEN ' ' ELSE UPPER(AJUSDEPRECDEBITO) END)  LIKE UPPER(:AJUSDEPRECDEBITO || '%')  AND (CASE WHEN DEPRECCREDITO IS NULL THEN ' ' ELSE UPPER(DEPRECCREDITO) END)  LIKE UPPER(:DEPRECCREDITO || '%')  AND (CASE WHEN DEPRECDEBITO IS NULL THEN ' ' ELSE UPPER(DEPRECDEBITO) END)  LIKE UPPER(:DEPRECDEBITO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","ANO":"$ANO(type:integer)","AJUSINFLACREDITO":"$AJUSINFLACREDITO","AJUSINFLADEBITO":"$AJUSINFLADEBITO","AJUSDEPRECCREDITO":"$AJUSDEPRECCREDITO","AJUSDEPRECDEBITO":"$AJUSDEPRECDEBITO","DEPRECCREDITO":"$DEPRECCREDITO","DEPRECDEBITO":"$DEPRECDEBITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="AJUSINFLACREDITO" sqlType="STRING"/>
		<param name="AJUSINFLADEBITO" sqlType="STRING"/>
		<param name="AJUSDEPRECCREDITO" sqlType="STRING"/>
		<param name="AJUSDEPRECDEBITO" sqlType="STRING"/>
		<param name="DEPRECCREDITO" sqlType="STRING"/>
		<param name="DEPRECDEBITO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarioscontabilidad">
		<call-query href="getInventarioscontabilidadPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="AJUSINFLACREDITO" query-param="AJUSINFLACREDITO"/>
			<with-param name="AJUSINFLADEBITO" query-param="AJUSINFLADEBITO"/>
			<with-param name="AJUSDEPRECCREDITO" query-param="AJUSDEPRECCREDITO"/>
			<with-param name="AJUSDEPRECDEBITO" query-param="AJUSDEPRECDEBITO"/>
			<with-param name="DEPRECCREDITO" query-param="DEPRECCREDITO"/>
			<with-param name="DEPRECDEBITO" query-param="DEPRECDEBITO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventarioscontabilidadNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGOELEMENTO, ANO, AJUSINFLACREDITO, AJUSINFLADEBITO, AJUSDEPRECCREDITO, AJUSDEPRECDEBITO, DEPRECCREDITO, DEPRECDEBITO  FROM INVENTARIOCONTABILIDAD WHERE INVENTARIOCONTABILIDAD.COMPANIA = :COMPANIA AND INVENTARIOCONTABILIDAD.CODIGOELEMENTO = :CODIGO AND INVENTARIOCONTABILIDAD.ANO = :ANO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN AJUSINFLACREDITO IS NULL THEN ' ' ELSE UPPER(AJUSINFLACREDITO) END)  LIKE UPPER( '%' || :AJUSINFLACREDITO || '%')  AND (CASE WHEN AJUSINFLADEBITO IS NULL THEN ' ' ELSE UPPER(AJUSINFLADEBITO) END)  LIKE UPPER( '%' || :AJUSINFLADEBITO || '%')  AND (CASE WHEN AJUSDEPRECCREDITO IS NULL THEN ' ' ELSE UPPER(AJUSDEPRECCREDITO) END)  LIKE UPPER( '%' || :AJUSDEPRECCREDITO || '%')  AND (CASE WHEN AJUSDEPRECDEBITO IS NULL THEN ' ' ELSE UPPER(AJUSDEPRECDEBITO) END)  LIKE UPPER( '%' || :AJUSDEPRECDEBITO || '%')  AND (CASE WHEN DEPRECCREDITO IS NULL THEN ' ' ELSE UPPER(DEPRECCREDITO) END)  LIKE UPPER( '%' || :DEPRECCREDITO || '%')  AND (CASE WHEN DEPRECDEBITO IS NULL THEN ' ' ELSE UPPER(DEPRECDEBITO) END)  LIKE UPPER( '%' || :DEPRECDEBITO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="AJUSINFLACREDITO" sqlType="STRING"/>
		<param name="AJUSINFLADEBITO" sqlType="STRING"/>
		<param name="AJUSDEPRECCREDITO" sqlType="STRING"/>
		<param name="AJUSDEPRECDEBITO" sqlType="STRING"/>
		<param name="DEPRECCREDITO" sqlType="STRING"/>
		<param name="DEPRECDEBITO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarioscontabilidad/numero">
		<call-query href="getInventarioscontabilidadNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="AJUSINFLACREDITO" query-param="AJUSINFLACREDITO"/>
			<with-param name="AJUSINFLADEBITO" query-param="AJUSINFLADEBITO"/>
			<with-param name="AJUSDEPRECCREDITO" query-param="AJUSDEPRECCREDITO"/>
			<with-param name="AJUSDEPRECDEBITO" query-param="AJUSDEPRECDEBITO"/>
			<with-param name="DEPRECCREDITO" query-param="DEPRECCREDITO"/>
			<with-param name="DEPRECDEBITO" query-param="DEPRECDEBITO"/>

		</call-query>
	</resource>
	<query id="getInventarioscontabilidadRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CODIGOELEMENTO, ANO, AJUSINFLACREDITO, AJUSINFLADEBITO, AJUSDEPRECCREDITO, AJUSDEPRECDEBITO, DEPRECCREDITO, DEPRECDEBITO, COSTOSALDB, COSTOSALCR, COSTOSALAJDB, COSTOSALAJCR, AJUSINFLADEBITOS, AJUSINFLACREDITOS, DEPRECDEBITOS, DEPRECCREDITOS, AJUSDEPRECDEBITOS, AJUSDEPRECCREDITOS, DEPACUMULADADB, DEPACUMULADACR, AJUSTEDEPRECIACIONDB, AJUSTEDEPRECIACIONCR, DEPRECDEBITOCOMODATO1, DEPRECCREDITOCOMODATO, DEPRECDEBITOSCOMODATO, DEPRECCREDITOSCOMODATO, DEPACUMULADADBCOMODATO, DEPACUMULADACRCOMODATO, DEPCUANTIAMIN_DEB, DEPCUANTIAMIN_CRE, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM INVENTARIOCONTABILIDAD WHERE INVENTARIOCONTABILIDAD.COMPANIA= :KEY_COMPANIA AND INVENTARIOCONTABILIDAD.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND INVENTARIOCONTABILIDAD.ANO= :KEY_ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","ANO":"$ANO(type:integer)","AJUSINFLACREDITO":"$AJUSINFLACREDITO","AJUSINFLADEBITO":"$AJUSINFLADEBITO","AJUSDEPRECCREDITO":"$AJUSDEPRECCREDITO","AJUSDEPRECDEBITO":"$AJUSDEPRECDEBITO","DEPRECCREDITO":"$DEPRECCREDITO","DEPRECDEBITO":"$DEPRECDEBITO","COSTOSALDB":"$COSTOSALDB","COSTOSALCR":"$COSTOSALCR","COSTOSALAJDB":"$COSTOSALAJDB","COSTOSALAJCR":"$COSTOSALAJCR","AJUSINFLADEBITOS":"$AJUSINFLADEBITOS","AJUSINFLACREDITOS":"$AJUSINFLACREDITOS","DEPRECDEBITOS":"$DEPRECDEBITOS","DEPRECCREDITOS":"$DEPRECCREDITOS","AJUSDEPRECDEBITOS":"$AJUSDEPRECDEBITOS","AJUSDEPRECCREDITOS":"$AJUSDEPRECCREDITOS","DEPACUMULADADB":"$DEPACUMULADADB","DEPACUMULADACR":"$DEPACUMULADACR","AJUSTEDEPRECIACIONDB":"$AJUSTEDEPRECIACIONDB","AJUSTEDEPRECIACIONCR":"$AJUSTEDEPRECIACIONCR","DEPRECDEBITOCOMODATO1":"$DEPRECDEBITOCOMODATO1","DEPRECCREDITOCOMODATO":"$DEPRECCREDITOCOMODATO","DEPRECDEBITOSCOMODATO":"$DEPRECDEBITOSCOMODATO","DEPRECCREDITOSCOMODATO":"$DEPRECCREDITOSCOMODATO","DEPACUMULADADBCOMODATO":"$DEPACUMULADADBCOMODATO","DEPACUMULADACRCOMODATO":"$DEPACUMULADACRCOMODATO","DEPCUANTIAMIN_DEB":"$DEPCUANTIAMIN_DEB","DEPCUANTIAMIN_CRE":"$DEPCUANTIAMIN_CRE","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
