			<with-param name="DEPRECCREDITO" query-param="DEPRECCREDITO"/>
			<with-param name="DEPRECDEBITO" query-param="DEPRECDEBITO"/>
			<with-param name="COSTOSALDB" query-param="COSTOSALDB"/>
			<with-param name="COSTOSALCR" query-param="COSTOSALCR"/>
			<with-param name="COSTOSALAJDB" query-param="COSTOSALAJDB"/>
			<with-param name="COSTOSALAJCR" query-param="COSTOSALAJCR"/>
			<with-param name="AJUSINFLADEBITOS" query-param="AJUSINFLADEBITOS"/>
			<with-param name="AJUSINFLACREDITOS" query-param="AJUSINFLACREDITOS"/>
			<with-param name="DEPRECDEBITOS" query-param="DEPRECDEBITOS"/>
			<with-param name="DEPRECCREDITOS" query-param="DEPRECCREDITOS"/>
			<with-param name="AJUSDEPRECDEBITOS" query-param="AJUSDEPRECDEBITOS"/>
			<with-param name="AJUSDEPRECCREDITOS" query-param="AJUSDEPRECCREDITOS"/>
			<with-param name="DEPACUMULADADB" query-param="DEPACUMULADADB"/>
			<with-param name="DEPACUMULADACR" query-param="DEPACUMULADACR"/>
			<with-param name="AJUSTEDEPRECIACIONDB" query-param="AJUSTEDEPRECIACIONDB"/>
			<with-param name="AJUSTEDEPRECIACIONCR" query-param="AJUSTEDEPRECIACIONCR"/>
			<with-param name="DEPRECDEBITOCOMODATO1" query-param="DEPRECDEBITOCOMODATO1"/>
			<with-param name="DEPRECCREDITOCOMODATO" query-param="DEPRECCREDITOCOMODATO"/>
