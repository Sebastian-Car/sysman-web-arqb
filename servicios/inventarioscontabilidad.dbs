	<query id="updateInventarioscontabilidad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVENTARIOCONTABILIDAD SET COMPANIA=:COMPANIA, CODIGOELEMENTO=:CODIGOELEMENTO, ANO=:ANO, AJUSINFLACREDITO=:AJUSINFLACREDITO, AJUSINFLADEBITO=:AJUSINFLADEBITO, AJUSDEPRECCREDITO=:AJUSDEPRECCREDITO, AJUSDEPRECDEBITO=:AJUSDEPRECDEBITO, DEPRECCREDITO=:DEPRECCREDITO, DEPRECDEBITO=:DEPRECDEBITO, COSTOSALDB=:COSTOSALDB, COSTOSALCR=:COSTOSALCR, COSTOSALAJDB=:COSTOSALAJDB, COSTOSALAJCR=:COSTOSALAJCR, AJUSINFLADEBITOS=:AJUSINFLADEBITOS, AJUSINFLACREDITOS=:AJUSINFLACREDITOS, DEPRECDEBITOS=:DEPRECDEBITOS, DEPRECCREDITOS=:DEPRECCREDITOS, AJUSDEPRECDEBITOS=:AJUSDEPRECDEBITOS, AJUSDEPRECCREDITOS=:AJUSDEPRECCREDITOS, DEPACUMULADADB=:DEPACUMULADADB, DEPACUMULADACR=:DEPACUMULADACR, AJUSTEDEPRECIACIONDB=:AJUSTEDEPRECIACIONDB, AJUSTEDEPRECIACIONCR=:AJUSTEDEPRECIACIONCR, DEPRECDEBITOCOMODATO1=:DEPRECDEBITOCOMODATO1, DEPRECCREDITOCOMODATO=:DEPRECCREDITOCOMODATO, DEPRECDEBITOSCOMODATO=:DEPRECDEBITOSCOMODATO, DEPRECCREDITOSCOMODATO=:DEPRECCREDITOSCOMODATO, DEPACUMULADADBCOMODATO=:DEPACUMULADADBCOMODATO, DEPACUMULADACRCOMODATO=:DEPACUMULADACRCOMODATO, DEPCUANTIAMIN_DEB=:DEPCUANTIAMIN_DEB, DEPCUANTIAMIN_CRE=:DEPCUANTIAMIN_CRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE INVENTARIOCONTABILIDAD.COMPANIA= :KEY_COMPANIA AND INVENTARIOCONTABILIDAD.CODIGOELEMENTO= :KEY_CODIGOELEMENTO AND INVENTARIOCONTABILIDAD.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
