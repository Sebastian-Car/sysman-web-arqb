<data name="piprogramacionfisica" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPiprogramacionfisicaExisteProgramacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) EXISTE  FROM PI_PROGRAMACION_FISICA WHERE PI_PROGRAMACION_FISICA.COMPANIA =:COMPANIA AND PI_PROGRAMACION_FISICA.TIPO =:TIPO AND PI_PROGRAMACION_FISICA.NUMERO =:NUMERO AND PI_PROGRAMACION_FISICA.ID_PLAN =:ID_PLAN AND PI_PROGRAMACION_FISICA.VIGENCIA_INICIAL =:VIGENCIA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piprogramacionfisica/existeprogramacion">
		<call-query href="getPiprogramacionfisicaExisteProgramacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="insertPiprogramacionfisica" keyColumns="COMPANIA,TIPO,NUMERO,ID_PLAN,VIGENCIA_INICIAL,VIGENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PI_PROGRAMACION_FISICA (COMPANIA, TIPO, NUMERO, ID_PLAN, VIGENCIA_INICIAL, VIGENCIA, FECHA_INICIAL_FIN, ES_NUEVO, FECHA_FINAL_FIN, PROGRAMADO_TR1_FIN, EJECUTADO_TR1_FIN, PROGRAMADO_TR2_FIN, EJECUTADO_TR2_FIN, PROGRAMADO_TR3_FIN, EJECUTADO_TR3_FIN, PROGRAMADO_TR4_FIN, EJECUTADO_TR4_FIN, POBLACION_OBJETIVO, UBICACION_GEOGRAFICA, IMPACTO_SOCIAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :NUMERO, :ID_PLAN, :VIGENCIA_INICIAL, :VIGENCIA, TO_DATE(:FECHA_INICIAL_FIN,'DD/MM/YYYY HH24:MI:SS'), :ES_NUEVO, TO_DATE(:FECHA_FINAL_FIN,'DD/MM/YYYY HH24:MI:SS'), :PROGRAMADO_TR1_FIN, :EJECUTADO_TR1_FIN, :PROGRAMADO_TR2_FIN, :EJECUTADO_TR2_FIN, :PROGRAMADO_TR3_FIN, :EJECUTADO_TR3_FIN, :PROGRAMADO_TR4_FIN, :EJECUTADO_TR4_FIN, :POBLACION_OBJETIVO, :UBICACION_GEOGRAFICA, :IMPACTO_SOCIAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_ID_PLAN":"$ID_PLAN","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","KEY_VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIAL_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="ES_NUEVO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="PROGRAMADO_TR1_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="EJECUTADO_TR1_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="PROGRAMADO_TR2_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="EJECUTADO_TR2_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="PROGRAMADO_TR3_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="EJECUTADO_TR3_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="PROGRAMADO_TR4_FIN" sqlType="STRING"/>
		<param defaultValue="0" name="EJECUTADO_TR4_FIN" sqlType="STRING"/>
		<param defaultValue="" name="POBLACION_OBJETIVO" sqlType="STRING"/>
		<param defaultValue="" name="UBICACION_GEOGRAFICA" sqlType="STRING"/>
		<param defaultValue="" name="IMPACTO_SOCIAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="piprogramacionfisica">
		<call-query href="insertPiprogramacionfisica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="FECHA_INICIAL_FIN" query-param="FECHA_INICIAL_FIN"/>
			<with-param name="ES_NUEVO" query-param="ES_NUEVO"/>
			<with-param name="FECHA_FINAL_FIN" query-param="FECHA_FINAL_FIN"/>
			<with-param name="PROGRAMADO_TR1_FIN" query-param="PROGRAMADO_TR1_FIN"/>
			<with-param name="EJECUTADO_TR1_FIN" query-param="EJECUTADO_TR1_FIN"/>
			<with-param name="PROGRAMADO_TR2_FIN" query-param="PROGRAMADO_TR2_FIN"/>
			<with-param name="EJECUTADO_TR2_FIN" query-param="EJECUTADO_TR2_FIN"/>
			<with-param name="PROGRAMADO_TR3_FIN" query-param="PROGRAMADO_TR3_FIN"/>
			<with-param name="EJECUTADO_TR3_FIN" query-param="EJECUTADO_TR3_FIN"/>
			<with-param name="PROGRAMADO_TR4_FIN" query-param="PROGRAMADO_TR4_FIN"/>
			<with-param name="EJECUTADO_TR4_FIN" query-param="EJECUTADO_TR4_FIN"/>
			<with-param name="POBLACION_OBJETIVO" query-param="POBLACION_OBJETIVO"/>
			<with-param name="UBICACION_GEOGRAFICA" query-param="UBICACION_GEOGRAFICA"/>
			<with-param name="IMPACTO_SOCIAL" query-param="IMPACTO_SOCIAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePiprogramacionfisica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PI_PROGRAMACION_FISICA WHERE PI_PROGRAMACION_FISICA.COMPANIA= :KEY_COMPANIA AND PI_PROGRAMACION_FISICA.TIPO= :KEY_TIPO AND PI_PROGRAMACION_FISICA.NUMERO= :KEY_NUMERO AND PI_PROGRAMACION_FISICA.ID_PLAN= :KEY_ID_PLAN AND PI_PROGRAMACION_FISICA.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PROGRAMACION_FISICA.VIGENCIA= :KEY_VIGENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="INTEGER"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="piprogramacionfisica">
		<call-query href="deletePiprogramacionfisica">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>

		</call-query>
	</resource>
	<query id="getPiprogramacionfisicaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, TIPO, NUMERO, ID_PLAN, VIGENCIA_INICIAL, VIGENCIA,(TO_CHAR(FECHA_INICIAL_FIN,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL_FIN,(CASE ES_NUEVO WHEN 0 THEN 'false' ELSE 'true' END) ES_NUEVO,(TO_CHAR(FECHA_FINAL_FIN,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_FIN, PROGRAMADO_TR1_FIN + PROGRAMADO_TR2_FIN + PROGRAMADO_TR3_FIN + PROGRAMADO_TR4_FIN CANTIDADPROGRAMADA, EJECUTADO_TR1_FIN + EJECUTADO_TR2_FIN + EJECUTADO_TR3_FIN + EJECUTADO_TR4_FIN CANTIDADEJECUTADA, PCK_SYSMAN_UTL.FC_ROUND( CASE WHEN EJECUTADO_TR1_FIN + EJECUTADO_TR2_FIN + EJECUTADO_TR3_FIN + EJECUTADO_TR4_FIN &lt;&gt; 0 AND PROGRAMADO_TR1_FIN + PROGRAMADO_TR2_FIN + PROGRAMADO_TR3_FIN + PROGRAMADO_TR4_FIN &lt;&gt; 0 THEN (EJECUTADO_TR1_FIN + EJECUTADO_TR2_FIN + EJECUTADO_TR3_FIN + EJECUTADO_TR4_FIN)/ (PROGRAMADO_TR1_FIN + PROGRAMADO_TR2_FIN + PROGRAMADO_TR3_FIN + PROGRAMADO_TR4_FIN) * 100 ELSE 0 END,2) EJECUCION, PROGRAMADO_TR1_FIN, EJECUTADO_TR1_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR1_FIN &lt;&gt; 0 AND EJECUTADO_TR1_FIN &lt;&gt; 0 THEN (EJECUTADO_TR1_FIN / PROGRAMADO_TR1_FIN)*100 ELSE 0 END,2) EJECUCIONUNO, PROGRAMADO_TR2_FIN, EJECUTADO_TR2_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR2_FIN &lt;&gt; 0 AND EJECUTADO_TR2_FIN &lt;&gt; 0 THEN (EJECUTADO_TR2_FIN / PROGRAMADO_TR2_FIN)*100 ELSE 0 END,2) EJECUCIONDOS, PROGRAMADO_TR3_FIN, EJECUTADO_TR3_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR3_FIN &lt;&gt; 0 AND EJECUTADO_TR3_FIN &lt;&gt; 0 THEN (EJECUTADO_TR3_FIN / PROGRAMADO_TR3_FIN)*100 ELSE 0 END,2) EJECUCIONTRES, PROGRAMADO_TR4_FIN, EJECUTADO_TR4_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR4_FIN &lt;&gt; 0 AND EJECUTADO_TR4_FIN &lt;&gt; 0 THEN (EJECUTADO_TR4_FIN / PROGRAMADO_TR4_FIN)*100 ELSE 0 END,2) EJECUCIONCUATRO, POBLACION_OBJETIVO, UBICACION_GEOGRAFICA, IMPACTO_SOCIAL  FROM PI_PROGRAMACION_FISICA WHERE COMPANIA =:COMPANIA AND TIPO =:TIPO AND NUMERO =:NUMERO AND ID_PLAN =:ID_PLAN AND VIGENCIA_INICIAL =:VIGENCIA_INICIAL) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN FECHA_INICIAL_FIN IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL_FIN) END)  LIKE UPPER( '%' || :FECHA_INICIAL_FIN || '%')  AND (CASE WHEN FECHA_FINAL_FIN IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL_FIN) END)  LIKE UPPER( '%' || :FECHA_FINAL_FIN || '%')  AND (CASE WHEN CANTIDADPROGRAMADA IS NULL THEN ' ' ELSE UPPER(CANTIDADPROGRAMADA) END)  LIKE UPPER(:CANTIDADPROGRAMADA || '%')  AND (CASE WHEN CANTIDADEJECUTADA IS NULL THEN ' ' ELSE UPPER(CANTIDADEJECUTADA) END)  LIKE UPPER(:CANTIDADEJECUTADA || '%')  AND (CASE WHEN EJECUCION IS NULL THEN ' ' ELSE UPPER(EJECUCION) END)  LIKE UPPER(:EJECUCION || '%')  AND (CASE WHEN PROGRAMADO_TR1_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR1_FIN) END)  LIKE UPPER(:PROGRAMADO_TR1_FIN || '%')  AND (CASE WHEN EJECUTADO_TR1_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR1_FIN) END)  LIKE UPPER(:EJECUTADO_TR1_FIN || '%')  AND (CASE WHEN EJECUCIONUNO IS NULL THEN ' ' ELSE UPPER(EJECUCIONUNO) END)  LIKE UPPER(:EJECUCIONUNO || '%')  AND (CASE WHEN PROGRAMADO_TR2_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR2_FIN) END)  LIKE UPPER(:PROGRAMADO_TR2_FIN || '%')  AND (CASE WHEN EJECUTADO_TR2_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR2_FIN) END)  LIKE UPPER(:EJECUTADO_TR2_FIN || '%')  AND (CASE WHEN EJECUCIONDOS IS NULL THEN ' ' ELSE UPPER(EJECUCIONDOS) END)  LIKE UPPER(:EJECUCIONDOS || '%')  AND (CASE WHEN PROGRAMADO_TR3_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR3_FIN) END)  LIKE UPPER(:PROGRAMADO_TR3_FIN || '%')  AND (CASE WHEN EJECUTADO_TR3_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR3_FIN) END)  LIKE UPPER(:EJECUTADO_TR3_FIN || '%')  AND (CASE WHEN EJECUCIONTRES IS NULL THEN ' ' ELSE UPPER(EJECUCIONTRES) END)  LIKE UPPER(:EJECUCIONTRES || '%')  AND (CASE WHEN PROGRAMADO_TR4_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR4_FIN) END)  LIKE UPPER(:PROGRAMADO_TR4_FIN || '%')  AND (CASE WHEN EJECUTADO_TR4_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR4_FIN) END)  LIKE UPPER(:EJECUTADO_TR4_FIN || '%')  AND (CASE WHEN EJECUCIONCUATRO IS NULL THEN ' ' ELSE UPPER(EJECUCIONCUATRO) END)  LIKE UPPER(:EJECUCIONCUATRO || '%')  AND (CASE WHEN POBLACION_OBJETIVO IS NULL THEN ' ' ELSE UPPER(POBLACION_OBJETIVO) END)  LIKE UPPER( '%' || :POBLACION_OBJETIVO || '%')  AND (CASE WHEN UBICACION_GEOGRAFICA IS NULL THEN ' ' ELSE UPPER(UBICACION_GEOGRAFICA) END)  LIKE UPPER( '%' || :UBICACION_GEOGRAFICA || '%')  AND (CASE WHEN IMPACTO_SOCIAL IS NULL THEN ' ' ELSE UPPER(IMPACTO_SOCIAL) END)  LIKE UPPER( '%' || :IMPACTO_SOCIAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","ID_PLAN":"$ID_PLAN","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","VIGENCIA":"$VIGENCIA(type:integer)","FECHA_INICIAL_FIN":"$FECHA_INICIAL_FIN","ES_NUEVO":"$ES_NUEVO(type:boolean)","FECHA_FINAL_FIN":"$FECHA_FINAL_FIN","CANTIDADPROGRAMADA":"$CANTIDADPROGRAMADA","CANTIDADEJECUTADA":"$CANTIDADEJECUTADA","EJECUCION":"$EJECUCION","PROGRAMADO_TR1_FIN":"$PROGRAMADO_TR1_FIN","EJECUTADO_TR1_FIN":"$EJECUTADO_TR1_FIN","EJECUCIONUNO":"$EJECUCIONUNO","PROGRAMADO_TR2_FIN":"$PROGRAMADO_TR2_FIN","EJECUTADO_TR2_FIN":"$EJECUTADO_TR2_FIN","EJECUCIONDOS":"$EJECUCIONDOS","PROGRAMADO_TR3_FIN":"$PROGRAMADO_TR3_FIN","EJECUTADO_TR3_FIN":"$EJECUTADO_TR3_FIN","EJECUCIONTRES":"$EJECUCIONTRES","PROGRAMADO_TR4_FIN":"$PROGRAMADO_TR4_FIN","EJECUTADO_TR4_FIN":"$EJECUTADO_TR4_FIN","EJECUCIONCUATRO":"$EJECUCIONCUATRO","POBLACION_OBJETIVO":"$POBLACION_OBJETIVO","UBICACION_GEOGRAFICA":"$UBICACION_GEOGRAFICA","IMPACTO_SOCIAL":"$IMPACTO_SOCIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="FECHA_INICIAL_FIN" sqlType="STRING"/>
		<param name="FECHA_FINAL_FIN" sqlType="STRING"/>
		<param name="CANTIDADPROGRAMADA" sqlType="STRING"/>
		<param name="CANTIDADEJECUTADA" sqlType="STRING"/>
		<param name="EJECUCION" sqlType="STRING"/>
		<param name="PROGRAMADO_TR1_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR1_FIN" sqlType="STRING"/>
		<param name="EJECUCIONUNO" sqlType="STRING"/>
		<param name="PROGRAMADO_TR2_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR2_FIN" sqlType="STRING"/>
		<param name="EJECUCIONDOS" sqlType="STRING"/>
		<param name="PROGRAMADO_TR3_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR3_FIN" sqlType="STRING"/>
		<param name="EJECUCIONTRES" sqlType="STRING"/>
		<param name="PROGRAMADO_TR4_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR4_FIN" sqlType="STRING"/>
		<param name="EJECUCIONCUATRO" sqlType="STRING"/>
		<param name="POBLACION_OBJETIVO" sqlType="STRING"/>
		<param name="UBICACION_GEOGRAFICA" sqlType="STRING"/>
		<param name="IMPACTO_SOCIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piprogramacionfisica">
		<call-query href="getPiprogramacionfisicaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="FECHA_INICIAL_FIN" query-param="FECHA_INICIAL_FIN"/>
			<with-param name="FECHA_FINAL_FIN" query-param="FECHA_FINAL_FIN"/>
			<with-param name="CANTIDADPROGRAMADA" query-param="CANTIDADPROGRAMADA"/>
			<with-param name="CANTIDADEJECUTADA" query-param="CANTIDADEJECUTADA"/>
			<with-param name="EJECUCION" query-param="EJECUCION"/>
			<with-param name="PROGRAMADO_TR1_FIN" query-param="PROGRAMADO_TR1_FIN"/>
			<with-param name="EJECUTADO_TR1_FIN" query-param="EJECUTADO_TR1_FIN"/>
			<with-param name="EJECUCIONUNO" query-param="EJECUCIONUNO"/>
			<with-param name="PROGRAMADO_TR2_FIN" query-param="PROGRAMADO_TR2_FIN"/>
			<with-param name="EJECUTADO_TR2_FIN" query-param="EJECUTADO_TR2_FIN"/>
			<with-param name="EJECUCIONDOS" query-param="EJECUCIONDOS"/>
			<with-param name="PROGRAMADO_TR3_FIN" query-param="PROGRAMADO_TR3_FIN"/>
			<with-param name="EJECUTADO_TR3_FIN" query-param="EJECUTADO_TR3_FIN"/>
			<with-param name="EJECUCIONTRES" query-param="EJECUCIONTRES"/>
			<with-param name="PROGRAMADO_TR4_FIN" query-param="PROGRAMADO_TR4_FIN"/>
			<with-param name="EJECUTADO_TR4_FIN" query-param="EJECUTADO_TR4_FIN"/>
			<with-param name="EJECUCIONCUATRO" query-param="EJECUCIONCUATRO"/>
			<with-param name="POBLACION_OBJETIVO" query-param="POBLACION_OBJETIVO"/>
			<with-param name="UBICACION_GEOGRAFICA" query-param="UBICACION_GEOGRAFICA"/>
			<with-param name="IMPACTO_SOCIAL" query-param="IMPACTO_SOCIAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPiprogramacionfisicaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, TIPO, NUMERO, ID_PLAN, VIGENCIA_INICIAL, VIGENCIA,(TO_CHAR(FECHA_INICIAL_FIN,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL_FIN,(CASE ES_NUEVO WHEN 0 THEN 'false' ELSE 'true' END) ES_NUEVO,(TO_CHAR(FECHA_FINAL_FIN,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_FIN, PROGRAMADO_TR1_FIN + PROGRAMADO_TR2_FIN + PROGRAMADO_TR3_FIN + PROGRAMADO_TR4_FIN CANTIDADPROGRAMADA, EJECUTADO_TR1_FIN + EJECUTADO_TR2_FIN + EJECUTADO_TR3_FIN + EJECUTADO_TR4_FIN CANTIDADEJECUTADA, PCK_SYSMAN_UTL.FC_ROUND( CASE WHEN EJECUTADO_TR1_FIN + EJECUTADO_TR2_FIN + EJECUTADO_TR3_FIN + EJECUTADO_TR4_FIN &lt;&gt; 0 AND PROGRAMADO_TR1_FIN + PROGRAMADO_TR2_FIN + PROGRAMADO_TR3_FIN + PROGRAMADO_TR4_FIN &lt;&gt; 0 THEN (EJECUTADO_TR1_FIN + EJECUTADO_TR2_FIN + EJECUTADO_TR3_FIN + EJECUTADO_TR4_FIN)/ (PROGRAMADO_TR1_FIN + PROGRAMADO_TR2_FIN + PROGRAMADO_TR3_FIN + PROGRAMADO_TR4_FIN) * 100 ELSE 0 END,2) EJECUCION, PROGRAMADO_TR1_FIN, EJECUTADO_TR1_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR1_FIN &lt;&gt; 0 AND EJECUTADO_TR1_FIN &lt;&gt; 0 THEN (EJECUTADO_TR1_FIN / PROGRAMADO_TR1_FIN)*100 ELSE 0 END,2) EJECUCIONUNO, PROGRAMADO_TR2_FIN, EJECUTADO_TR2_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR2_FIN &lt;&gt; 0 AND EJECUTADO_TR2_FIN &lt;&gt; 0 THEN (EJECUTADO_TR2_FIN / PROGRAMADO_TR2_FIN)*100 ELSE 0 END,2) EJECUCIONDOS, PROGRAMADO_TR3_FIN, EJECUTADO_TR3_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR3_FIN &lt;&gt; 0 AND EJECUTADO_TR3_FIN &lt;&gt; 0 THEN (EJECUTADO_TR3_FIN / PROGRAMADO_TR3_FIN)*100 ELSE 0 END,2) EJECUCIONTRES, PROGRAMADO_TR4_FIN, EJECUTADO_TR4_FIN, PCK_SYSMAN_UTL.FC_ROUND(CASE WHEN PROGRAMADO_TR4_FIN &lt;&gt; 0 AND EJECUTADO_TR4_FIN &lt;&gt; 0 THEN (EJECUTADO_TR4_FIN / PROGRAMADO_TR4_FIN)*100 ELSE 0 END,2) EJECUCIONCUATRO, POBLACION_OBJETIVO, UBICACION_GEOGRAFICA, IMPACTO_SOCIAL  FROM PI_PROGRAMACION_FISICA WHERE COMPANIA =:COMPANIA AND TIPO =:TIPO AND NUMERO =:NUMERO AND ID_PLAN =:ID_PLAN AND VIGENCIA_INICIAL =:VIGENCIA_INICIAL) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN FECHA_INICIAL_FIN IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL_FIN) END)  LIKE UPPER( '%' || :FECHA_INICIAL_FIN || '%')  AND (CASE WHEN FECHA_FINAL_FIN IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL_FIN) END)  LIKE UPPER( '%' || :FECHA_FINAL_FIN || '%')  AND (CASE WHEN CANTIDADPROGRAMADA IS NULL THEN ' ' ELSE UPPER(CANTIDADPROGRAMADA) END)  LIKE UPPER(:CANTIDADPROGRAMADA || '%')  AND (CASE WHEN CANTIDADEJECUTADA IS NULL THEN ' ' ELSE UPPER(CANTIDADEJECUTADA) END)  LIKE UPPER(:CANTIDADEJECUTADA || '%')  AND (CASE WHEN EJECUCION IS NULL THEN ' ' ELSE UPPER(EJECUCION) END)  LIKE UPPER(:EJECUCION || '%')  AND (CASE WHEN PROGRAMADO_TR1_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR1_FIN) END)  LIKE UPPER(:PROGRAMADO_TR1_FIN || '%')  AND (CASE WHEN EJECUTADO_TR1_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR1_FIN) END)  LIKE UPPER(:EJECUTADO_TR1_FIN || '%')  AND (CASE WHEN EJECUCIONUNO IS NULL THEN ' ' ELSE UPPER(EJECUCIONUNO) END)  LIKE UPPER(:EJECUCIONUNO || '%')  AND (CASE WHEN PROGRAMADO_TR2_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR2_FIN) END)  LIKE UPPER(:PROGRAMADO_TR2_FIN || '%')  AND (CASE WHEN EJECUTADO_TR2_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR2_FIN) END)  LIKE UPPER(:EJECUTADO_TR2_FIN || '%')  AND (CASE WHEN EJECUCIONDOS IS NULL THEN ' ' ELSE UPPER(EJECUCIONDOS) END)  LIKE UPPER(:EJECUCIONDOS || '%')  AND (CASE WHEN PROGRAMADO_TR3_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR3_FIN) END)  LIKE UPPER(:PROGRAMADO_TR3_FIN || '%')  AND (CASE WHEN EJECUTADO_TR3_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR3_FIN) END)  LIKE UPPER(:EJECUTADO_TR3_FIN || '%')  AND (CASE WHEN EJECUCIONTRES IS NULL THEN ' ' ELSE UPPER(EJECUCIONTRES) END)  LIKE UPPER(:EJECUCIONTRES || '%')  AND (CASE WHEN PROGRAMADO_TR4_FIN IS NULL THEN ' ' ELSE UPPER(PROGRAMADO_TR4_FIN) END)  LIKE UPPER(:PROGRAMADO_TR4_FIN || '%')  AND (CASE WHEN EJECUTADO_TR4_FIN IS NULL THEN ' ' ELSE UPPER(EJECUTADO_TR4_FIN) END)  LIKE UPPER(:EJECUTADO_TR4_FIN || '%')  AND (CASE WHEN EJECUCIONCUATRO IS NULL THEN ' ' ELSE UPPER(EJECUCIONCUATRO) END)  LIKE UPPER(:EJECUCIONCUATRO || '%')  AND (CASE WHEN POBLACION_OBJETIVO IS NULL THEN ' ' ELSE UPPER(POBLACION_OBJETIVO) END)  LIKE UPPER( '%' || :POBLACION_OBJETIVO || '%')  AND (CASE WHEN UBICACION_GEOGRAFICA IS NULL THEN ' ' ELSE UPPER(UBICACION_GEOGRAFICA) END)  LIKE UPPER( '%' || :UBICACION_GEOGRAFICA || '%')  AND (CASE WHEN IMPACTO_SOCIAL IS NULL THEN ' ' ELSE UPPER(IMPACTO_SOCIAL) END)  LIKE UPPER( '%' || :IMPACTO_SOCIAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="FECHA_INICIAL_FIN" sqlType="STRING"/>
		<param name="FECHA_FINAL_FIN" sqlType="STRING"/>
		<param name="CANTIDADPROGRAMADA" sqlType="STRING"/>
		<param name="CANTIDADEJECUTADA" sqlType="STRING"/>
		<param name="EJECUCION" sqlType="STRING"/>
		<param name="PROGRAMADO_TR1_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR1_FIN" sqlType="STRING"/>
		<param name="EJECUCIONUNO" sqlType="STRING"/>
		<param name="PROGRAMADO_TR2_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR2_FIN" sqlType="STRING"/>
		<param name="EJECUCIONDOS" sqlType="STRING"/>
		<param name="PROGRAMADO_TR3_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR3_FIN" sqlType="STRING"/>
		<param name="EJECUCIONTRES" sqlType="STRING"/>
		<param name="PROGRAMADO_TR4_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR4_FIN" sqlType="STRING"/>
		<param name="EJECUCIONCUATRO" sqlType="STRING"/>
		<param name="POBLACION_OBJETIVO" sqlType="STRING"/>
		<param name="UBICACION_GEOGRAFICA" sqlType="STRING"/>
		<param name="IMPACTO_SOCIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piprogramacionfisica/numero">
		<call-query href="getPiprogramacionfisicaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="FECHA_INICIAL_FIN" query-param="FECHA_INICIAL_FIN"/>
			<with-param name="FECHA_FINAL_FIN" query-param="FECHA_FINAL_FIN"/>
			<with-param name="CANTIDADPROGRAMADA" query-param="CANTIDADPROGRAMADA"/>
			<with-param name="CANTIDADEJECUTADA" query-param="CANTIDADEJECUTADA"/>
			<with-param name="EJECUCION" query-param="EJECUCION"/>
			<with-param name="PROGRAMADO_TR1_FIN" query-param="PROGRAMADO_TR1_FIN"/>
			<with-param name="EJECUTADO_TR1_FIN" query-param="EJECUTADO_TR1_FIN"/>
			<with-param name="EJECUCIONUNO" query-param="EJECUCIONUNO"/>
			<with-param name="PROGRAMADO_TR2_FIN" query-param="PROGRAMADO_TR2_FIN"/>
			<with-param name="EJECUTADO_TR2_FIN" query-param="EJECUTADO_TR2_FIN"/>
			<with-param name="EJECUCIONDOS" query-param="EJECUCIONDOS"/>
			<with-param name="PROGRAMADO_TR3_FIN" query-param="PROGRAMADO_TR3_FIN"/>
			<with-param name="EJECUTADO_TR3_FIN" query-param="EJECUTADO_TR3_FIN"/>
			<with-param name="EJECUCIONTRES" query-param="EJECUCIONTRES"/>
			<with-param name="PROGRAMADO_TR4_FIN" query-param="PROGRAMADO_TR4_FIN"/>
			<with-param name="EJECUTADO_TR4_FIN" query-param="EJECUTADO_TR4_FIN"/>
			<with-param name="EJECUCIONCUATRO" query-param="EJECUCIONCUATRO"/>
			<with-param name="POBLACION_OBJETIVO" query-param="POBLACION_OBJETIVO"/>
			<with-param name="UBICACION_GEOGRAFICA" query-param="UBICACION_GEOGRAFICA"/>
			<with-param name="IMPACTO_SOCIAL" query-param="IMPACTO_SOCIAL"/>

		</call-query>
	</resource>
	<query id="updatePiprogramacionfisica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_PROGRAMACION_FISICA SET VIGENCIA=:VIGENCIA, FECHA_INICIAL_FIN=TO_DATE(:FECHA_INICIAL_FIN,'DD/MM/YYYY HH24:MI:SS'), ES_NUEVO=:ES_NUEVO, FECHA_FINAL_FIN=TO_DATE(:FECHA_FINAL_FIN,'DD/MM/YYYY HH24:MI:SS'), PROGRAMADO_TR1_FIN=:PROGRAMADO_TR1_FIN, EJECUTADO_TR1_FIN=:EJECUTADO_TR1_FIN, PROGRAMADO_TR2_FIN=:PROGRAMADO_TR2_FIN, EJECUTADO_TR2_FIN=:EJECUTADO_TR2_FIN, PROGRAMADO_TR3_FIN=:PROGRAMADO_TR3_FIN, EJECUTADO_TR3_FIN=:EJECUTADO_TR3_FIN, PROGRAMADO_TR4_FIN=:PROGRAMADO_TR4_FIN, EJECUTADO_TR4_FIN=:EJECUTADO_TR4_FIN, POBLACION_OBJETIVO=:POBLACION_OBJETIVO, UBICACION_GEOGRAFICA=:UBICACION_GEOGRAFICA, IMPACTO_SOCIAL=:IMPACTO_SOCIAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_PROGRAMACION_FISICA.COMPANIA= :KEY_COMPANIA AND PI_PROGRAMACION_FISICA.TIPO= :KEY_TIPO AND PI_PROGRAMACION_FISICA.NUMERO= :KEY_NUMERO AND PI_PROGRAMACION_FISICA.ID_PLAN= :KEY_ID_PLAN AND PI_PROGRAMACION_FISICA.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PROGRAMACION_FISICA.VIGENCIA= :KEY_VIGENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="FECHA_INICIAL_FIN" sqlType="STRING"/>
		<param name="ES_NUEVO" sqlType="STRING"/>
		<param name="FECHA_FINAL_FIN" sqlType="STRING"/>
		<param name="PROGRAMADO_TR1_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR1_FIN" sqlType="STRING"/>
		<param name="PROGRAMADO_TR2_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR2_FIN" sqlType="STRING"/>
		<param name="PROGRAMADO_TR3_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR3_FIN" sqlType="STRING"/>
		<param name="PROGRAMADO_TR4_FIN" sqlType="STRING"/>
		<param name="EJECUTADO_TR4_FIN" sqlType="STRING"/>
		<param name="POBLACION_OBJETIVO" sqlType="STRING"/>
		<param name="UBICACION_GEOGRAFICA" sqlType="STRING"/>
		<param name="IMPACTO_SOCIAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="piprogramacionfisica">
		<call-query href="updatePiprogramacionfisica">
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="FECHA_INICIAL_FIN" query-param="FECHA_INICIAL_FIN"/>
			<with-param name="ES_NUEVO" query-param="ES_NUEVO"/>
			<with-param name="FECHA_FINAL_FIN" query-param="FECHA_FINAL_FIN"/>
			<with-param name="PROGRAMADO_TR1_FIN" query-param="PROGRAMADO_TR1_FIN"/>
			<with-param name="EJECUTADO_TR1_FIN" query-param="EJECUTADO_TR1_FIN"/>
			<with-param name="PROGRAMADO_TR2_FIN" query-param="PROGRAMADO_TR2_FIN"/>
			<with-param name="EJECUTADO_TR2_FIN" query-param="EJECUTADO_TR2_FIN"/>
			<with-param name="PROGRAMADO_TR3_FIN" query-param="PROGRAMADO_TR3_FIN"/>
			<with-param name="EJECUTADO_TR3_FIN" query-param="EJECUTADO_TR3_FIN"/>
			<with-param name="PROGRAMADO_TR4_FIN" query-param="PROGRAMADO_TR4_FIN"/>
			<with-param name="EJECUTADO_TR4_FIN" query-param="EJECUTADO_TR4_FIN"/>
			<with-param name="POBLACION_OBJETIVO" query-param="POBLACION_OBJETIVO"/>
			<with-param name="UBICACION_GEOGRAFICA" query-param="UBICACION_GEOGRAFICA"/>
			<with-param name="IMPACTO_SOCIAL" query-param="IMPACTO_SOCIAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>

		</call-query>
	</resource>

</data>