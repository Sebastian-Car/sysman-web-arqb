	<query id="getTipoordenescompraTodosConTipoFormatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE, TIPOORDENDECOMPRA.TIPOFORMATO  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND NVL(TIPOORDENDECOMPRA.CLASE, '') &lt;&gt; 'M' AND TIPOORDENDECOMPRA.ACTIVO NOT IN (0) ORDER BY TIPOORDENDECOMPRA.COMPANIA, TIPOORDENDECOMPRA.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","TIPOFORMATO":"$TIPOFORMATO"}]}}		</result>
