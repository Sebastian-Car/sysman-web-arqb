<data name="tipoordenescompra" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoordenescompraTodosPorClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND NVL(TIPOORDENDECOMPRA.CLASE,'') &lt;&gt; 'M' AND TIPOORDENDECOMPRA.ACTIVO = 0 ORDER BY TIPOORDENDECOMPRA.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosporclase">
		<call-query href="getTipoordenescompraTodosPorClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTodosPorClaseYCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND NVL(TIPOORDENDECOMPRA.CLASE,' ') NOT IN ('M') AND TIPOORDENDECOMPRA.ACTIVO IN (0) AND TIPOORDENDECOMPRA.MANEJA IN ('E', 'A') ORDER BY TIPOORDENDECOMPRA.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosporclaseycodigo">
		<call-query href="getTipoordenescompraTodosPorClaseYCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTodosnumeracionunicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOORDENDECOMPRA.CODIGO  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND TIPOORDENDECOMPRA.NUMERACIONUNICA NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosnumeracionunica">
		<call-query href="getTipoordenescompraTodosnumeracionunicaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTodosPorTipoContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT NOMBRE ,(CASE CONVENIO WHEN 0 THEN 'false' ELSE 'true' END) CONVENIO,(CASE APLICA_ACTA_INICIO WHEN 0 THEN 'false' ELSE 'true' END) APLICA_ACTA_INICIO,(CASE OBLIGA_CAMPOS WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_CAMPOS FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.CODIGO = :TIPOCONTRATO AND COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","CONVENIO":"$CONVENIO(type:boolean)","APLICA_ACTA_INICIO":"$APLICA_ACTA_INICIO(type:boolean)","OBLIGA_CAMPOS":"$OBLIGA_CAMPOS(type:boolean)"}]}}		</result>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosportipocontrato">
		<call-query href="getTipoordenescompraTodosPorTipoContratoQuery">
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTipoFormatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOFORMATO,(CASE CONVENIO WHEN 0 THEN 'false' ELSE 'true' END) CONVENIO FROM TIPOORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CODIGO = :CLASEORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOFORMATO":"$TIPOFORMATO","CONVENIO":"$CONVENIO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/tipoformato">
		<call-query href="getTipoordenescompraTipoFormatoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTodosOrdenCodigoNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA ORDER BY TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosordencodigonombre">
		<call-query href="getTipoordenescompraTodosOrdenCodigoNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTodosPorCompaniaTerceroSucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE  FROM TIPOORDENDECOMPRA INNER JOIN ORDENDECOMPRA ON TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA AND TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND (ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.CLASENOVEDAD &lt;&gt; 'C' OR ORDENDECOMPRA.NITCESION = :TERCERO) AND ORDENDECOMPRA.SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosporcompaniatercerosucursal">
		<call-query href="getTipoordenescompraTodosPorCompaniaTerceroSucursalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTodosPorCompaniaTerceroSucursalConteoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT('X') CONTEO  FROM TIPOORDENDECOMPRA LEFT JOIN ORDENDECOMPRA ON TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA AND TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND (ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.CLASENOVEDAD &lt;&gt; 'C' OR ORDENDECOMPRA.NITCESION = :TERCERO) AND ORDENDECOMPRA.SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosporcompaniatercerosucursalconteo">
		<call-query href="getTipoordenescompraTodosPorCompaniaTerceroSucursalConteoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraTodosPorCompaniaTerceroSucursalDistinctQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE  FROM TIPOORDENDECOMPRA LEFT JOIN ORDENDECOMPRA ON TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA AND TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND ORDENDECOMPRA.TERCERO = :TERCERO AND ORDENDECOMPRA.SUCURSAL = :SUCURSAL ORDER BY TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/todosporcompaniatercerosucursaldistinct">
		<call-query href="getTipoordenescompraTodosPorCompaniaTerceroSucursalDistinctQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="insertTipoordenescompra" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOORDENDECOMPRA (COMPANIA, CODIGO, NOMBRE, NUMEROINICIAL, NUMERACIONUNICA, TIPOFORMATO, VIGENCIA_SGC, VERSION_SGC, CODIGO_SGC, GENERACONTRATO, FORMATO_ALMACEN, INF_FUNCIONAL, TIPO_MODELO, CLASE, MANEJA, CREATED_BY, DATE_CREATED, CON_SALDO) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :NUMEROINICIAL, :NUMERACIONUNICA, :TIPOFORMATO, TO_DATE(:VIGENCIA_SGC,'DD/MM/YYYY HH24:MI:SS'), :VERSION_SGC, :CODIGO_SGC, :GENERACONTRATO, :FORMATO_ALMACEN, :INF_FUNCIONAL, :TIPO_MODELO, :CLASE, :MANEJA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CON_SALDO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="NUMEROINICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERACIONUNICA" sqlType="STRING"/>
		<param defaultValue="" name="TIPOFORMATO" sqlType="STRING"/>
		<param defaultValue="" name="VIGENCIA_SGC" sqlType="STRING"/>
		<param defaultValue="" name="VERSION_SGC" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_SGC" sqlType="STRING"/>
		<param defaultValue="0" name="GENERACONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO_ALMACEN" sqlType="STRING"/>
		<param defaultValue="0" name="INF_FUNCIONAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_MODELO" sqlType="STRING"/>
		<param defaultValue="" name="CLASE" sqlType="STRING"/>
		<param defaultValue="" name="MANEJA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="CON_SALDO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tipoordenescompra">
		<call-query href="insertTipoordenescompra">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="NUMERACIONUNICA" query-param="NUMERACIONUNICA"/>
			<with-param name="TIPOFORMATO" query-param="TIPOFORMATO"/>
			<with-param name="VIGENCIA_SGC" query-param="VIGENCIA_SGC"/>
			<with-param name="VERSION_SGC" query-param="VERSION_SGC"/>
			<with-param name="CODIGO_SGC" query-param="CODIGO_SGC"/>
			<with-param name="GENERACONTRATO" query-param="GENERACONTRATO"/>
			<with-param name="FORMATO_ALMACEN" query-param="FORMATO_ALMACEN"/>
			<with-param name="INF_FUNCIONAL" query-param="INF_FUNCIONAL"/>
			<with-param name="TIPO_MODELO" query-param="TIPO_MODELO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="MANEJA" query-param="MANEJA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CON_SALDO" query-param="CON_SALDO"/>

		</call-query>
	</resource>
	<query id="deleteTipoordenescompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND TIPOORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tipoordenescompra">
		<call-query href="deleteTipoordenescompra">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, NUMEROINICIAL, FORMATO_ALMACEN  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA ORDER BY TIPOORDENDECOMPRA.COMPANIA, TIPOORDENDECOMPRA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NUMEROINICIAL IS NULL THEN ' ' ELSE UPPER(NUMEROINICIAL) END)  LIKE UPPER(:NUMEROINICIAL || '%')  AND (CASE WHEN FORMATO_ALMACEN IS NULL THEN ' ' ELSE UPPER(FORMATO_ALMACEN) END)  LIKE UPPER( '%' || :FORMATO_ALMACEN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NUMEROINICIAL":"$NUMEROINICIAL","FORMATO_ALMACEN":"$FORMATO_ALMACEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="FORMATO_ALMACEN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoordenescompra">
		<call-query href="getTipoordenescompraPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="FORMATO_ALMACEN" query-param="FORMATO_ALMACEN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, NUMEROINICIAL, FORMATO_ALMACEN  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA ORDER BY TIPOORDENDECOMPRA.COMPANIA, TIPOORDENDECOMPRA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NUMEROINICIAL IS NULL THEN ' ' ELSE UPPER(NUMEROINICIAL) END)  LIKE UPPER( '%' || :NUMEROINICIAL || '%')  AND (CASE WHEN FORMATO_ALMACEN IS NULL THEN ' ' ELSE UPPER(FORMATO_ALMACEN) END)  LIKE UPPER( '%' || :FORMATO_ALMACEN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="FORMATO_ALMACEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/numero">
		<call-query href="getTipoordenescompraNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="FORMATO_ALMACEN" query-param="FORMATO_ALMACEN"/>

		</call-query>
	</resource>
	<query id="getTipoordenescompraRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO, NOMBRE, NUMEROINICIAL,(CASE NUMERACIONUNICA WHEN 0 THEN 'false' ELSE 'true' END) NUMERACIONUNICA, TIPOFORMATO,(TO_CHAR(VIGENCIA_SGC,'DD/MM/YYYY HH24:MI:SS')) VIGENCIA_SGC, VERSION_SGC, CODIGO_SGC,(CASE GENERACONTRATO WHEN 0 THEN 'false' ELSE 'true' END) GENERACONTRATO, FORMATO_ALMACEN,(CASE INF_FUNCIONAL WHEN 0 THEN 'false' ELSE 'true' END) INF_FUNCIONAL, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE CON_SALDO WHEN 0 THEN 'false' ELSE 'true' END) CON_SALDO FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND TIPOORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NUMEROINICIAL":"$NUMEROINICIAL","NUMERACIONUNICA":"$NUMERACIONUNICA(type:boolean)","TIPOFORMATO":"$TIPOFORMATO","VIGENCIA_SGC":"$VIGENCIA_SGC","VERSION_SGC":"$VERSION_SGC","CODIGO_SGC":"$CODIGO_SGC","GENERACONTRATO":"$GENERACONTRATO(type:boolean)","FORMATO_ALMACEN":"$FORMATO_ALMACEN","INF_FUNCIONAL":"$INF_FUNCIONAL(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CON_SALDO":"$CON_SALDO(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoordenescompra/data">
		<call-query href="getTipoordenescompraRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateTipoordenescompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPOORDENDECOMPRA SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, NUMEROINICIAL=:NUMEROINICIAL, NUMERACIONUNICA=:NUMERACIONUNICA, TIPOFORMATO=:TIPOFORMATO, VIGENCIA_SGC=TO_DATE(:VIGENCIA_SGC,'DD/MM/YYYY HH24:MI:SS'), VERSION_SGC=:VERSION_SGC, CODIGO_SGC=:CODIGO_SGC, GENERACONTRATO=:GENERACONTRATO, FORMATO_ALMACEN=:FORMATO_ALMACEN, INF_FUNCIONAL=:INF_FUNCIONAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CON_SALDO=:CON_SALDO WHERE TIPOORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND TIPOORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="NUMERACIONUNICA" sqlType="STRING"/>
		<param name="TIPOFORMATO" sqlType="STRING"/>
		<param name="VIGENCIA_SGC" sqlType="STRING"/>
		<param name="VERSION_SGC" sqlType="STRING"/>
		<param name="CODIGO_SGC" sqlType="STRING"/>
		<param name="GENERACONTRATO" sqlType="STRING"/>
		<param name="FORMATO_ALMACEN" sqlType="STRING"/>
		<param name="INF_FUNCIONAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="CON_SALDO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipoordenescompra">
		<call-query href="updateTipoordenescompra">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="NUMERACIONUNICA" query-param="NUMERACIONUNICA"/>
			<with-param name="TIPOFORMATO" query-param="TIPOFORMATO"/>
