	<query id="getTipoordenescompraTodosPorTipoDeContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT CODIGO, NOMBRE  FROM (SELECT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE FROM TIPOORDENDECOMPRA LEFT JOIN ORDENDECOMPRA ON TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA AND TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN WHERE TIPOORDENDECOMPRA.COMPANIA =:COMPANIA AND ORDENDECOMPRA.TERCERO =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL AND NVL(ORDENDECOMPRA.CLASENOVEDAD,' ') NOT IN('C') GROUP BY TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE UNION SELECT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE FROM TIPOORDENDECOMPRA LEFT JOIN ORDENDECOMPRA ON TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA AND TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN WHERE TIPOORDENDECOMPRA.COMPANIA=:COMPANIA AND ORDENDECOMPRA.NITCESION =:TERCERO AND ORDENDECOMPRA.SUCURSAL =:SUCURSAL GROUP BY TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE ) ORDER BY CODIGO, NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
