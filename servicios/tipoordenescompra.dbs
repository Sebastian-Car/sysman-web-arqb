	<query id="insertTipoordenescompraTipocontratos" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOORDENDECOMPRA (ACTIVO, ARRENDAMIENTO, CLASE, CODCONTTOLIMA, CODDIAN, CODIGO, CODIGOCONTRATO_FUT, CODIGO_R6, CODIGO_SGC, COMPANIA, CONVENIO, CREATED_BY, DATE_CREATED, ESTAMPILLA, FORMATO_ALMACEN, GENERACONTRATO, INCLUIR_INFORMES, MANEJA, MODALIDAD, NOMBRE, NOVEDADNOMINA, NUMERACIONUNICA, NUMEROINICIAL, TIPOCONTRATO_CGR, TIPOCONTRATO_FUT, TIPOCONTRATOS, TIPOCONTRATO_SIA, TIPOFORMATO, TIPOFUT, TIPO_MODELO, TIPOORDENDECOMPRA, TIPOSIA, VERSION_SGC, VIGENCIA_SGC, IND_CIRCULAR_UNICA, ESTAMPILLA_SIGEC, TIPO_SIGEC, OBLIGA_CAMPOS, APLICA_ACTA_INICIO, INF_FUNCIONAL, CON_SALDO, ES_OBRAPUB) VALUES (:ACTIVO, :ARRENDAMIENTO, :CLASE, :CODCONTTOLIMA, :CODDIAN, :CODIGO, :CODIGOCONTRATO_FUT, :CODIGO_R6, :CODIGO_SGC, :COMPANIA, :CONVENIO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :ESTAMPILLA, :FORMATO_ALMACEN, :GENERACONTRATO, :INCLUIR_INFORMES, :MANEJA, :MODALIDAD, :NOMBRE, :NOVEDADNOMINA, :NUMERACIONUNICA, :NUMEROINICIAL, :TIPOCONTRATO_CGR, :TIPOCONTRATO_FUT, :TIPOCONTRATOS, :TIPOCONTRATO_SIA, :TIPOFORMATO, :TIPOFUT, :TIPO_MODELO, :TIPOORDENDECOMPRA, :TIPOSIA, :VERSION_SGC, TO_DATE(:VIGENCIA_SGC,'DD/MM/YYYY HH24:MI:SS'), :IND_CIRCULAR_UNICA, :ESTAMPILLA_SIGEC, :TIPO_SIGEC, :OBLIGA_CAMPOS, :APLICA_ACTA_INICIO, :INF_FUNCIONAL, :CON_SALDO, :ES_OBRAPUB)</sql>
