	<query id="getTipoordenescompraNumListarTipocontratosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, CLASE, CODCONTTOLIMA, CODDIAN, NUMEROINICIAL, TIPOFORMATO  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA ORDER BY TIPOORDENDECOMPRA.COMPANIA, TIPOORDENDECOMPRA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%')  AND (CASE WHEN CODCONTTOLIMA IS NULL THEN ' ' ELSE UPPER(CODCONTTOLIMA) END)  LIKE UPPER(:CODCONTTOLIMA || '%')  AND (CASE WHEN CODDIAN IS NULL THEN ' ' ELSE UPPER(CODDIAN) END)  LIKE UPPER(:CODDIAN || '%')  AND (CASE WHEN NUMEROINICIAL IS NULL THEN ' ' ELSE UPPER(NUMEROINICIAL) END)  LIKE UPPER( '%' || :NUMEROINICIAL || '%')  AND (CASE WHEN TIPOFORMATO IS NULL THEN ' ' ELSE UPPER(TIPOFORMATO) END)  LIKE UPPER( '%' || :TIPOFORMATO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
