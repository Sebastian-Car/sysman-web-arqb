	<query id="getTipoordenescompraRegistroTipocontratosQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO,(CASE ARRENDAMIENTO WHEN 0 THEN 'false' ELSE 'true' END) ARRENDAMIENTO, CLASE, CODCONTTOLIMA, CODDIAN, CODIGO, CODIGOCONTRATO_FUT, CODIGO_R6, CODIGO_SGC, COMPANIA,(CASE CONVENIO WHEN 0 THEN 'false' ELSE 'true' END) CONVENIO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE ESTAMPILLA WHEN 0 THEN 'false' ELSE 'true' END) ESTAMPILLA, FORMATO_ALMACEN,(CASE GENERACONTRATO WHEN 0 THEN 'false' ELSE 'true' END) GENERACONTRATO,(CASE INCLUIR_INFORMES WHEN 0 THEN 'false' ELSE 'true' END) INCLUIR_INFORMES, MANEJA, MODALIDAD, MODIFIED_BY, NOMBRE,(CASE NOVEDADNOMINA WHEN 0 THEN 'false' ELSE 'true' END) NOVEDADNOMINA,(CASE NUMERACIONUNICA WHEN 0 THEN 'false' ELSE 'true' END) NUMERACIONUNICA, NUMEROINICIAL, TIPOCONTRATO_CGR, TIPOCONTRATO_FUT, TIPOCONTRATOS, TIPOCONTRATO_SIA, TIPOFORMATO, TIPOFUT, TIPO_MODELO, TIPOORDENDECOMPRA, TIPOSIA, VERSION_SGC,(TO_CHAR(VIGENCIA_SGC,'DD/MM/YYYY HH24:MI:SS')) VIGENCIA_SGC,(CASE IND_CIRCULAR_UNICA WHEN 0 THEN 'false' ELSE 'true' END) IND_CIRCULAR_UNICA,(CASE ESTAMPILLA_SIGEC WHEN 0 THEN 'false' ELSE 'true' END) ESTAMPILLA_SIGEC, TIPO_SIGEC,(CASE OBLIGA_CAMPOS WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_CAMPOS,(CASE APLICA_ACTA_INICIO WHEN 0 THEN 'false' ELSE 'true' END) APLICA_ACTA_INICIO,(CASE INF_FUNCIONAL WHEN 0 THEN 'false' ELSE 'true' END) INF_FUNCIONAL,(CASE CON_SALDO WHEN 0 THEN 'false' ELSE 'true' END) CON_SALDO,(CASE ES_OBRAPUB WHEN 0 THEN 'false' ELSE 'true' END) ES_OBRAPUB FROM TIPOORDENDECOMPRA WHERE COMPANIA = :KEY_COMPANIA AND CODIGO = :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ACTIVO":"$ACTIVO(type:boolean)","ARRENDAMIENTO":"$ARRENDAMIENTO(type:boolean)","CLASE":"$CLASE","CODCONTTOLIMA":"$CODCONTTOLIMA","CODDIAN":"$CODDIAN","CODIGO":"$CODIGO","CODIGOCONTRATO_FUT":"$CODIGOCONTRATO_FUT","CODIGO_R6":"$CODIGO_R6","CODIGO_SGC":"$CODIGO_SGC","COMPANIA":"$COMPANIA","CONVENIO":"$CONVENIO(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","ESTAMPILLA":"$ESTAMPILLA(type:boolean)","FORMATO_ALMACEN":"$FORMATO_ALMACEN","GENERACONTRATO":"$GENERACONTRATO(type:boolean)","INCLUIR_INFORMES":"$INCLUIR_INFORMES(type:boolean)","MANEJA":"$MANEJA","MODALIDAD":"$MODALIDAD","MODIFIED_BY":"$MODIFIED_BY","NOMBRE":"$NOMBRE","NOVEDADNOMINA":"$NOVEDADNOMINA(type:boolean)","NUMERACIONUNICA":"$NUMERACIONUNICA(type:boolean)","NUMEROINICIAL":"$NUMEROINICIAL","TIPOCONTRATO_CGR":"$TIPOCONTRATO_CGR","TIPOCONTRATO_FUT":"$TIPOCONTRATO_FUT","TIPOCONTRATOS":"$TIPOCONTRATOS","TIPOCONTRATO_SIA":"$TIPOCONTRATO_SIA","TIPOFORMATO":"$TIPOFORMATO","TIPOFUT":"$TIPOFUT","TIPO_MODELO":"$TIPO_MODELO","TIPOORDENDECOMPRA":"$TIPOORDENDECOMPRA","TIPOSIA":"$TIPOSIA","VERSION_SGC":"$VERSION_SGC","VIGENCIA_SGC":"$VIGENCIA_SGC","IND_CIRCULAR_UNICA":"$IND_CIRCULAR_UNICA(type:boolean)","ESTAMPILLA_SIGEC":"$ESTAMPILLA_SIGEC(type:boolean)","TIPO_SIGEC":"$TIPO_SIGEC","OBLIGA_CAMPOS":"$OBLIGA_CAMPOS(type:boolean)","APLICA_ACTA_INICIO":"$APLICA_ACTA_INICIO(type:boolean)","INF_FUNCIONAL":"$INF_FUNCIONAL(type:boolean)","CON_SALDO":"$CON_SALDO(type:boolean)","ES_OBRAPUB":"$ES_OBRAPUB(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
