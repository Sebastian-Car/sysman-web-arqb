	<query id="updateTipoordenescompraTipocontratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPOORDENDECOMPRA SET ACTIVO=:ACTIVO, ARRENDAMIENTO=:ARRENDAMIENTO, CLASE=:CLASE, CODCONTTOLIMA=:CODCONTTOLIMA, CODDIAN=:CODDIAN, CODIGO=:CODIGO, CODIGOCONTRATO_FUT=:CODIGOCONTRATO_FUT, CODIGO_R6=:CODIGO_R6, CODIGO_SGC=:CODIGO_SGC, CONVENIO=:CONVENIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), ESTAMPILLA=:ESTAMPILLA, FORMATO_ALMACEN=:FORMATO_ALMACEN, GENERACONTRATO=:GENERACONTRATO, INCLUIR_INFORMES=:INCLUIR_INFORMES, MANEJA=:MANEJA, MODALIDAD=:MODALIDAD, MODIFIED_BY=:MODIFIED_BY, NOMBRE=:NOMBRE, NOVEDADNOMINA=:NOVEDADNOMINA, NUMERACIONUNICA=:NUMERACIONUNICA, NUMEROINICIAL=:NUMEROINICIAL, TIPOCONTRATO_CGR=:TIPOCONTRATO_CGR, TIPOCONTRATO_FUT=:TIPOCONTRATO_FUT, TIPOCONTRATOS=:TIPOCONTRATOS, TIPOCONTRATO_SIA=:TIPOCONTRATO_SIA, TIPOFORMATO=:TIPOFORMATO, TIPOFUT=:TIPOFUT, TIPO_MODELO=:TIPO_MODELO, TIPOORDENDECOMPRA=:TIPOORDENDECOMPRA, TIPOSIA=:TIPOSIA, VERSION_SGC=:VERSION_SGC, VIGENCIA_SGC=TO_DATE(:VIGENCIA_SGC,'DD/MM/YYYY HH24:MI:SS'), IND_CIRCULAR_UNICA=:IND_CIRCULAR_UNICA, ESTAMPILLA_SIGEC=:ESTAMPILLA_SIGEC, TIPO_SIGEC=:TIPO_SIGEC, OBLIGA_CAMPOS=:OBLIGA_CAMPOS, APLICA_ACTA_INICIO=:APLICA_ACTA_INICIO, INF_FUNCIONAL=:INF_FUNCIONAL, CON_SALDO=:CON_SALDO, ES_OBRAPUB=:ES_OBRAPUB WHERE TIPOORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND TIPOORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
