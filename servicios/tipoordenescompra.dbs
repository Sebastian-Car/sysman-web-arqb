	<query id="getTipoordenescompraNumeracionUnicaPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE NUMERACIONUNICA WHEN 0 THEN 'false' ELSE 'true' END) NUMERACIONUNICA,NVL(NOMBRE,' ') NOMBRE, NVL(MANEJA,'') MANEJA, NVL(TIPOFORMATO,'') TIPOFORMATO, NVL(TIPO_MODELO,'') TIPO_MODELO, NVL(CONVENIO,0) CONVENIO  FROM TIPOORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CODIGO = :TIPOCONTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERACIONUNICA":"$NUMERACIONUNICA(type:boolean)","NOMBRE":"$NOMBRE","MANEJA":"$MANEJA","TIPOFORMATO":"$TIPOFORMATO","TIPO_MODELO":"$TIPO_MODELO","CONVENIO":"$CONVENIO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>

	</query>
