	<query id="getTipoordenescompraPagCodnombreporclaseycodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND NVL(TIPOORDENDECOMPRA.CLASE, ' ') NOT IN ( 'M' ) AND TIPOORDENDECOMPRA.ACTIVO IN ( 0 ) AND TIPOORDENDECOMPRA.CODIGO IN ( 'CDS', 'ODC', 'CDC', 'OIE', 'OIT', 'CCV' ) ORDER BY TIPOORDENDECOMPRA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
