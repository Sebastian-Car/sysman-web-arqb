	<query id="getTipoordenescompraPagListarTipocontratosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, CLASE, CODCONTTOLIMA, CODDIAN, NUMEROINICIAL, TIPOFORMATO  FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA ORDER BY TIPOORDENDECOMPRA.COMPANIA, TIPOORDENDECOMPRA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%')  AND (CASE WHEN CODCONTTOLIMA IS NULL THEN ' ' ELSE UPPER(CODCONTTOLIMA) END)  LIKE UPPER(:CODCONTTOLIMA || '%')  AND (CASE WHEN CODDIAN IS NULL THEN ' ' ELSE UPPER(CODDIAN) END)  LIKE UPPER(:CODDIAN || '%')  AND (CASE WHEN NUMEROINICIAL IS NULL THEN ' ' ELSE UPPER(NUMEROINICIAL) END)  LIKE UPPER( '%' || :NUMEROINICIAL || '%')  AND (CASE WHEN TIPOFORMATO IS NULL THEN ' ' ELSE UPPER(TIPOFORMATO) END)  LIKE UPPER( '%' || :TIPOFORMATO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE":"$CLASE","CODCONTTOLIMA":"$CODCONTTOLIMA","CODDIAN":"$CODDIAN","NUMEROINICIAL":"$NUMEROINICIAL","TIPOFORMATO":"$TIPOFORMATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODCONTTOLIMA" sqlType="STRING"/>
		<param name="CODDIAN" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="TIPOFORMATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
