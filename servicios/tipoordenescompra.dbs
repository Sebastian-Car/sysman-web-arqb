		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT TIPOORDENDECOMPRA.CODIGO, TIPOORDENDECOMPRA.NOMBRE FROM TIPOORDENDECOMPRA WHERE TIPOORDENDECOMPRA.COMPANIA = :COMPANIA AND NVL(TIPOORDENDECOMPRA.CLASE, ' ') NOT IN ( 'M' ) AND TIPOORDENDECOMPRA.ACTIVO IN ( 0 ) AND TIPOORDENDECOMPRA.CODIGO IN ( 'CDS', 'ODC', 'CDC', 'OIE', 'OIT', 'CCV' ) ORDER BY TIPOORDENDECOMPRA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
