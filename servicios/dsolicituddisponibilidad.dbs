	<query id="deleteDsolicituddisponibilidad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_SOLICITUDDISPONIBILIDAD WHERE D_SOLICITUDDISPONIBILIDAD.COMPANIA= :KEY_COMPANIA AND D_SOLICITUDDISPONIBILIDAD.ANO= :KEY_ANO AND D_SOLICITUDDISPONIBILIDAD.CONSECUTIVO= :KEY_CONSECUTIVO AND D_SOLICITUDDISPONIBILIDAD.NUMERO= :KEY_NUMERO AND D_SOLICITUDDISPONIBILIDAD.RUBRO= :KEY_RUBRO AND D_SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD= :KEY_TIPO_SOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_RUBRO" sqlType="STRING"/>
		<param name="KEY_TIPO_SOLICITUD" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="dsolicituddisponibilidad">
		<call-query href="deleteDsolicituddisponibilidad">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_RUBRO" query-param="KEY_RUBRO"/>
			<with-param name="KEY_TIPO_SOLICITUD" query-param="KEY_TIPO_SOLICITUD"/>

		</call-query>
	</resource>
	<query id="getDsolicituddisponibilidadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DS.COMPANIA, DS.ANO, DS.NUMERO, DS.CONSECUTIVO, DS.RUBRO, BPPI.ID ID_PLAN_INDICATIVO, BP.ID_PLAN, DS.FUENTE, DS.CENTRO_COSTO, DS.REFERENCIA, FR.NOMBRE NOMBRE_FUENTE, CC.NOMBRE NOMBRE_CENTRO, RF.NOMBRE NOMBRE_REFERENCIA, AX.NOMBRE NOMBRE_AUXILIAR, DS.VALOR, DS.VALOR_BASE, DS.IMPUESTO, DS.AUXILIAR, DS.AUXILIAR, DS.TERCERO, DS.SUCURSAL, DS.TIPO_SOLICITUD, DS.VIGENCIA_INICIAL, DS.CODIGO, DS.SECTOR, DS.PROGRAMA, DS.SUBPROGRAMA, DS.CODIGOBPIN, DS.CODIGOPRODUCTO, DS.CODIGOCCPET, DS.CODIGOCPCDANE, DS.CODIGOUNIDADEJE, DS.CODIGOFUENTE, DS.CODIGOCCPETREGA, DS.POLITICA_PUBLICA, DS.DETALLE_SECTORIAL FROM D_SOLICITUDDISPONIBILIDAD DS LEFT JOIN BP_PLAN_ADQUISICIONES BP ON DS.COMPANIA = BP.COMPANIA AND DS.VIGENCIA_INICIAL = BP.VIGENCIA_INICIAL AND DS.ID_PLAN = BP.ID_PLAN AND DS.CODIGO = BP.CODIGO LEFT JOIN FUENTE_RECURSOS FR ON DS.COMPANIA = FR.COMPANIA AND DS.ANO = FR.ANO AND DS.FUENTE = FR.CODIGO LEFT JOIN CENTRO_COSTO CC ON DS.COMPANIA = CC.COMPANIA AND DS.ANO = CC.ANO AND DS.CENTRO_COSTO = CC.CODIGO LEFT JOIN REFERENCIA RF ON DS.COMPANIA = RF.COMPANIA AND DS.ANO = RF.ANO AND DS.REFERENCIA = RF.CODIGO LEFT JOIN AUXILIAR AX ON DS.COMPANIA = AX.COMPANIA AND DS.ANO = AX.ANO AND DS.AUXILIAR = AX.CODIGO LEFT JOIN BP_PLAN_INDICATIVO BPPI ON DS.COMPANIA = BPPI.COMPANIA AND DS.ID_PLAN_INDICATIVO = BPPI.ID AND DS.VIGENCIA_INICIAL = BPPI.VIGENCIA_INICIAL WHERE DS.COMPANIA = :COMPANIA AND DS.NUMERO = :NUMERO AND DS.TIPO_SOLICITUD = :TIPOSOLICITUD ORDER BY CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","RUBRO":"$RUBRO","ID_PLAN_INDICATIVO":"$ID_PLAN_INDICATIVO","ID_PLAN":"$ID_PLAN","FUENTE":"$FUENTE","CENTRO_COSTO":"$CENTRO_COSTO","REFERENCIA":"$REFERENCIA","NOMBRE_FUENTE":"$NOMBRE_FUENTE","NOMBRE_CENTRO":"$NOMBRE_CENTRO","NOMBRE_REFERENCIA":"$NOMBRE_REFERENCIA","NOMBRE_AUXILIAR":"$NOMBRE_AUXILIAR","VALOR":"$VALOR","VALOR_BASE":"$VALOR_BASE","IMPUESTO":"$IMPUESTO","AUXILIAR":"$AUXILIAR","AUXILIAR":"$AUXILIAR","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","CODIGO":"$CODIGO(type:long)","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","CODIGOBPIN":"$CODIGOBPIN","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CODIGOCCPET":"$CODIGOCCPET","CODIGOCPCDANE":"$CODIGOCPCDANE","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOFUENTE":"$CODIGOFUENTE","CODIGOCCPETREGA":"$CODIGOCCPETREGA","POLITICA_PUBLICA":"$POLITICA_PUBLICA","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPOSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dsolicituddisponibilidad">
		<call-query href="getDsolicituddisponibilidadPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPOSOLICITUD" query-param="TIPOSOLICITUD"/>

		</call-query>
	</resource>
	<query id="updateDsolicituddisponibilidad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_SOLICITUDDISPONIBILIDAD SET RUBRO=:RUBRO, FUENTE=:FUENTE, CENTRO_COSTO=:CENTRO_COSTO, REFERENCIA=:REFERENCIA, VALOR=:VALOR, VALOR_BASE=:VALOR_BASE, IMPUESTO=:IMPUESTO, AUXILIAR=:AUXILIAR, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, ID_PLAN=:ID_PLAN, CODIGO=:CODIGO, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, TIPO_SOLICITUD=:TIPO_SOLICITUD, ID_PLAN_INDICATIVO=:ID_PLAN_INDICATIVO, SECTOR=:SECTOR, PROGRAMA=:PROGRAMA, SUBPROGRAMA=:SUBPROGRAMA, CODIGOBPIN=:CODIGOBPIN, CODIGOPRODUCTO=:CODIGOPRODUCTO, CODIGOCCPET=:CODIGOCCPET, CODIGOCPCDANE=:CODIGOCPCDANE, CODIGOUNIDADEJE=:CODIGOUNIDADEJE, CODIGOFUENTE=:CODIGOFUENTE, CODIGOCCPETREGA=:CODIGOCCPETREGA, POLITICA_PUBLICA=:POLITICA_PUBLICA, DETALLE_SECTORIAL=:DETALLE_SECTORIAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_SOLICITUDDISPONIBILIDAD.COMPANIA= :KEY_COMPANIA AND D_SOLICITUDDISPONIBILIDAD.ANO= :KEY_ANO AND D_SOLICITUDDISPONIBILIDAD.CONSECUTIVO= :KEY_CONSECUTIVO AND D_SOLICITUDDISPONIBILIDAD.NUMERO= :KEY_NUMERO AND D_SOLICITUDDISPONIBILIDAD.RUBRO= :KEY_RUBRO AND D_SOLICITUDDISPONIBILIDAD.TIPO_SOLICITUD= :KEY_TIPO_SOLICITUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="RUBRO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
        <param name="IMPUESTO" sqlType="STRING"/>
