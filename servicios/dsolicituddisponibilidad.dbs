<data name="dsolicituddisponibilidad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDsolicituddisponibilidadValordetallesolicitudQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(VALOR,0) VALOR FROM D_SOLICITUDDISPONIBILIDAD WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CONSECUTIVO = :CONSECUTIVO AND NUMERO = :NUMERO AND RUBRO = :RUBRO AND TIPO_SOLICITUD = :TIPO_SOLICITUD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="TIPO_SOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dsolicituddisponibilidad/valordetallesolicitud">
		<call-query href="getDsolicituddisponibilidadValordetallesolicitudQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="TIPO_SOLICITUD" query-param="TIPO_SOLICITUD"/>

		</call-query>
	</resource>
	<query id="insertDsolicituddisponibilidad" keyColumns="COMPANIA,ANO,CONSECUTIVO,NUMERO,RUBRO,TIPO_SOLICITUD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_SOLICITUDDISPONIBILIDAD (COMPANIA, ANO, NUMERO, CONSECUTIVO, RUBRO, FUENTE, CENTRO_COSTO, REFERENCIA, VALOR, VALOR_BASE, IMPUESTO, AUXILIAR, TERCERO, SUCURSAL, ID_PLAN, CODIGO, VIGENCIA_INICIAL, ID_PLAN_INDICATIVO, TIPO_SOLICITUD, SECTOR, PROGRAMA, SUBPROGRAMA, CODIGOBPIN, CODIGOPRODUCTO, CODIGOCCPET, CODIGOCPCDANE, CODIGOUNIDADEJE, CODIGOFUENTE, CODIGOCCPETREGA, POLITICA_PUBLICA, DETALLE_SECTORIAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :NUMERO, :CONSECUTIVO, :RUBRO, :FUENTE, :CENTRO_COSTO, :REFERENCIA, :VALOR, :VALOR_BASE, :IMPUESTO, :AUXILIAR, :TERCERO, :SUCURSAL, :ID_PLAN, :CODIGO, :VIGENCIA_INICIAL, :ID_PLAN_INDICATIVO, :TIPO_SOLICITUD, :SECTOR, :PROGRAMA, :SUBPROGRAMA, :CODIGOBPIN, :CODIGOPRODUCTO, :CODIGOCCPET, :CODIGOCPCDANE, :CODIGOUNIDADEJE, :CODIGOFUENTE, :CODIGOCCPETREGA, :POLITICA_PUBLICA, :DETALLE_SECTORIAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)","KEY_NUMERO":"$NUMERO(type:long)","KEY_RUBRO":"$RUBRO","KEY_TIPO_SOLICITUD":"$TIPO_SOLICITUD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_BASE" sqlType="STRING"/>
        <param defaultValue="" name="IMPUESTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="ID_PLAN" sqlType="STRING"/>
		<param defaultValue="1" name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param defaultValue="" name="ID_PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="TIPO_SOLICITUD" sqlType="STRING"/>
		<param defaultValue="" name="SECTOR" sqlType="STRING"/>
		<param defaultValue="" name="PROGRAMA" sqlType="STRING"/>
		<param defaultValue="" name="SUBPROGRAMA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOBPIN" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOPRODUCTO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCCPET" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCPCDANE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOUNIDADEJE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOFUENTE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCCPETREGA" sqlType="STRING"/>
		<param defaultValue="" name="POLITICA_PUBLICA" sqlType="STRING"/>
		<param defaultValue="" name="DETALLE_SECTORIAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dsolicituddisponibilidad">
