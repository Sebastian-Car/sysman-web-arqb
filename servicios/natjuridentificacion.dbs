<data name="natjuridentificacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatjuridentificacion" keyColumns="COMPANIA,NITSOCIEDAD,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_JURIDENTIFICACION (COMPANIA, NITSOCIEDAD, SUCURSAL, SIGLA, ORDEN, CUAL, TIPO, CLASE, DOMICILIO, APARTADOAEREO, TIPOID_REPRE, NUMERO_IDREPRE, SUCURSAL_REPRE, CARACTER, CONTRATACION, INHABILIDAD, OBS_REPRE, FIRMAREPRE, OBSERVACIONES, RESPONSABLE, SUCURSAL_RESPONSABLE, RESPFIRMA, ENTRE_CIUDAD, CREATED_BY, FECHA_DILIG, DATE_CREATED, FECHA) VALUES (:COMPANIA, :NITSOCIEDAD, :SUCURSAL, :SIGLA, :ORDEN, :CUAL, :TIPO, :CLASE, :DOMICILIO, :APARTADOAEREO, :TIPOID_REPRE, :NUMERO_IDREPRE, :SUCURSAL_REPRE, :CARACTER, :CONTRATACION, :INHABILIDAD, :OBS_REPRE, :FIRMAREPRE, :OBSERVACIONES, :RESPONSABLE, :SUCURSAL_RESPONSABLE, :RESPFIRMA, :ENTRE_CIUDAD, :CREATED_BY, TO_DATE(:FECHA_DILIG,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NITSOCIEDAD":"$NITSOCIEDAD","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITSOCIEDAD" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="SIGLA" sqlType="STRING"/>
		<param defaultValue="" name="ORDEN" sqlType="STRING"/>
		<param defaultValue="" name="CUAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="CLASE" sqlType="STRING"/>
		<param defaultValue="" name="DOMICILIO" sqlType="STRING"/>
		<param defaultValue="" name="APARTADOAEREO" sqlType="STRING"/>
		<param name="TIPOID_REPRE" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NUMERO_IDREPRE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_REPRE" sqlType="STRING"/>
		<param defaultValue="" name="CARACTER" sqlType="STRING"/>
		<param defaultValue="0" name="CONTRATACION" sqlType="STRING"/>
		<param defaultValue="" name="INHABILIDAD" sqlType="STRING"/>
		<param defaultValue="" name="OBS_REPRE" sqlType="STRING"/>
		<param defaultValue="" name="FIRMAREPRE" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="" name="RESPFIRMA" sqlType="STRING"/>
		<param defaultValue="" name="ENTRE_CIUDAD" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_DILIG" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>

	</query>
