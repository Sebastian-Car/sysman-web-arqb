	<query id="deleteNatjuridentificacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_JURIDENTIFICACION WHERE NAT_JURIDENTIFICACION.COMPANIA= :KEY_COMPANIA AND NAT_JURIDENTIFICACION.NITSOCIEDAD= :KEY_NITSOCIEDAD AND NAT_JURIDENTIFICACION.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NITSOCIEDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natjuridentificacion">
		<call-query href="deleteNatjuridentificacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NITSOCIEDAD" query-param="KEY_NITSOCIEDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatjuridentificacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_JURIDENTIFICACION.COMPANIA, NAT_JURIDENTIFICACION.SUCURSAL, NAT_JURIDENTIFICACION.NITSOCIEDAD, TERCERO_SOCIEDAD.NOMBRE NOMBRE_SOCIEDAD, NAT_JURIDENTIFICACION.NUMERO_IDREPRE, TERCERO_REPRESENTANTE.NOMBRE NOMBRES, NAT_JURIDENTIFICACION.OBSERVACIONES  FROM NAT_JURIDENTIFICACION LEFT JOIN TERCERO TERCERO_REPRESENTANTE ON NAT_JURIDENTIFICACION.COMPANIA = TERCERO_REPRESENTANTE.COMPANIA AND NAT_JURIDENTIFICACION.NUMERO_IDREPRE = TERCERO_REPRESENTANTE.NIT AND NAT_JURIDENTIFICACION.SUCURSAL_REPRE = TERCERO_REPRESENTANTE.SUCURSAL LEFT JOIN TERCERO TERCERO_SOCIEDAD ON NAT_JURIDENTIFICACION.COMPANIA = TERCERO_SOCIEDAD.COMPANIA AND NAT_JURIDENTIFICACION.NITSOCIEDAD = TERCERO_SOCIEDAD.NIT AND NAT_JURIDENTIFICACION.SUCURSAL_REPRE = TERCERO_SOCIEDAD.SUCURSAL WHERE NAT_JURIDENTIFICACION.COMPANIA = :COMPANIA) WHERE (CASE WHEN NITSOCIEDAD IS NULL THEN ' ' ELSE UPPER(NITSOCIEDAD) END)  LIKE UPPER(:NITSOCIEDAD || '%')  AND (CASE WHEN NOMBRE_SOCIEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_SOCIEDAD) END)  LIKE UPPER( '%' || :NOMBRE_SOCIEDAD || '%')  AND (CASE WHEN NUMERO_IDREPRE IS NULL THEN ' ' ELSE UPPER(NUMERO_IDREPRE) END)  LIKE UPPER(:NUMERO_IDREPRE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NITSOCIEDAD":"$NITSOCIEDAD","NOMBRE_SOCIEDAD":"$NOMBRE_SOCIEDAD","NUMERO_IDREPRE":"$NUMERO_IDREPRE","NOMBRES":"$NOMBRES","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITSOCIEDAD" sqlType="STRING"/>
		<param name="NOMBRE_SOCIEDAD" sqlType="STRING"/>
		<param name="NUMERO_IDREPRE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natjuridentificacion">
		<call-query href="getNatjuridentificacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITSOCIEDAD" query-param="NITSOCIEDAD"/>
			<with-param name="NOMBRE_SOCIEDAD" query-param="NOMBRE_SOCIEDAD"/>
			<with-param name="NUMERO_IDREPRE" query-param="NUMERO_IDREPRE"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatjuridentificacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_JURIDENTIFICACION.COMPANIA, NAT_JURIDENTIFICACION.SUCURSAL, NAT_JURIDENTIFICACION.NITSOCIEDAD, TERCERO_SOCIEDAD.NOMBRE NOMBRE_SOCIEDAD, NAT_JURIDENTIFICACION.NUMERO_IDREPRE, TERCERO_REPRESENTANTE.NOMBRE NOMBRES, NAT_JURIDENTIFICACION.OBSERVACIONES  FROM NAT_JURIDENTIFICACION LEFT JOIN TERCERO TERCERO_REPRESENTANTE ON NAT_JURIDENTIFICACION.COMPANIA = TERCERO_REPRESENTANTE.COMPANIA AND NAT_JURIDENTIFICACION.NUMERO_IDREPRE = TERCERO_REPRESENTANTE.NIT AND NAT_JURIDENTIFICACION.SUCURSAL_REPRE = TERCERO_REPRESENTANTE.SUCURSAL LEFT JOIN TERCERO TERCERO_SOCIEDAD ON NAT_JURIDENTIFICACION.COMPANIA = TERCERO_SOCIEDAD.COMPANIA AND NAT_JURIDENTIFICACION.NITSOCIEDAD = TERCERO_SOCIEDAD.NIT AND NAT_JURIDENTIFICACION.SUCURSAL_REPRE = TERCERO_SOCIEDAD.SUCURSAL WHERE NAT_JURIDENTIFICACION.COMPANIA = :COMPANIA) WHERE (CASE WHEN NITSOCIEDAD IS NULL THEN ' ' ELSE UPPER(NITSOCIEDAD) END)  LIKE UPPER(:NITSOCIEDAD || '%')  AND (CASE WHEN NOMBRE_SOCIEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_SOCIEDAD) END)  LIKE UPPER( '%' || :NOMBRE_SOCIEDAD || '%')  AND (CASE WHEN NUMERO_IDREPRE IS NULL THEN ' ' ELSE UPPER(NUMERO_IDREPRE) END)  LIKE UPPER(:NUMERO_IDREPRE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITSOCIEDAD" sqlType="STRING"/>
		<param name="NOMBRE_SOCIEDAD" sqlType="STRING"/>
		<param name="NUMERO_IDREPRE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natjuridentificacion/numero">
		<call-query href="getNatjuridentificacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITSOCIEDAD" query-param="NITSOCIEDAD"/>
			<with-param name="NOMBRE_SOCIEDAD" query-param="NOMBRE_SOCIEDAD"/>
			<with-param name="NUMERO_IDREPRE" query-param="NUMERO_IDREPRE"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="getNatjuridentificacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_JURIDENTIFICACION.COMPANIA, NAT_JURIDENTIFICACION.NITSOCIEDAD, NAT_JURIDENTIFICACION.SUCURSAL, NAT_JURIDENTIFICACION.SIGLA, NAT_JURIDENTIFICACION.ORDEN, NAT_JURIDENTIFICACION.CUAL, NAT_JURIDENTIFICACION.TIPO, NAT_JURIDENTIFICACION.CLASE, NAT_JURIDENTIFICACION.DOMICILIO, NAT_JURIDENTIFICACION.APARTADOAEREO, NAT_JURIDENTIFICACION.TIPOID_REPRE, NAT_JURIDENTIFICACION.NUMERO_IDREPRE, NAT_JURIDENTIFICACION.SUCURSAL_REPRE, NAT_JURIDENTIFICACION.CARACTER, NAT_JURIDENTIFICACION.CONTRATACION, NAT_JURIDENTIFICACION.INHABILIDAD, NAT_JURIDENTIFICACION.OBS_REPRE, NAT_JURIDENTIFICACION.FIRMAREPRE, NAT_JURIDENTIFICACION.OBSERVACIONES, NAT_JURIDENTIFICACION.RESPONSABLE, NAT_JURIDENTIFICACION.SUCURSAL_RESPONSABLE, NAT_JURIDENTIFICACION.RESPFIRMA, NAT_JURIDENTIFICACION.ENTRE_CIUDAD, NAT_JURIDENTIFICACION.CREATED_BY, NAT_JURIDENTIFICACION.MODIFIED_BY,(TO_CHAR(NAT_JURIDENTIFICACION.FECHA_DILIG,'DD/MM/YYYY HH24:MI:SS')) FECHA_DILIG,(TO_CHAR(NAT_JURIDENTIFICACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(NAT_JURIDENTIFICACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(NAT_JURIDENTIFICACION.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, TERCERO_SOCIENDAD.NOMBRE AS RAZONSOCIAL, UPPER(PAISES.NOMBRE) AS PAIS_NOMBRE, UPPER(DEPARTAMENTO.NOMBRE) DEPARTAMENTO_NOMBRE, UPPER(CIUDAD.NOMBRE) MUNICIPIO_NOMBRE, TERCERO_RESP_LEGAL.NOMBRE AS NOMBRES, TERCERO_RESP_LEGAL.APELLIDO1, TERCERO_RESP_LEGAL.APELLIDO2, UPPER(TIPOS_DOCUMENTOS.DESCRIPCION) TIPO_DOCU, TERCERO_RESP_LEGAL.DIRECCION, TERCERO_RESP_LEGAL.FAX, TERCERO_RESP_LEGAL.TELEFONOS, TERCERO_RESPONSABLE.NOMBRE NOMBRE_RESPONSABLE, RESPONSABLE.CARGO CARGO_RESPONSABLE  FROM NAT_JURIDENTIFICACION INNER JOIN TERCERO TERCERO_SOCIENDAD ON NAT_JURIDENTIFICACION.COMPANIA = TERCERO_SOCIENDAD.COMPANIA AND NAT_JURIDENTIFICACION.NITSOCIEDAD =TERCERO_SOCIENDAD.NIT AND NAT_JURIDENTIFICACION.SUCURSAL = TERCERO_SOCIENDAD.SUCURSAL LEFT JOIN PAISES ON TERCERO_SOCIENDAD.PAIS = PAISES.PAIS LEFT JOIN DEPARTAMENTO ON TERCERO_SOCIENDAD.PAIS = DEPARTAMENTO.PAIS AND TERCERO_SOCIENDAD.DEPARTAMENTO= DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON TERCERO_SOCIENDAD.PAIS =CIUDAD.PAIS AND TERCERO_SOCIENDAD.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND TERCERO_SOCIENDAD.CIUDAD = CIUDAD.CODIGO LEFT JOIN TERCERO TERCERO_RESP_LEGAL ON NAT_JURIDENTIFICACION.COMPANIA = TERCERO_RESP_LEGAL.COMPANIA AND NAT_JURIDENTIFICACION.NUMERO_IDREPRE =TERCERO_RESP_LEGAL.NIT AND NAT_JURIDENTIFICACION.SUCURSAL = TERCERO_RESP_LEGAL.SUCURSAL LEFT JOIN TIPOS_DOCUMENTOS ON TERCERO_RESP_LEGAL.COMPANIA = TIPOS_DOCUMENTOS.COMPANIA AND TERCERO_RESP_LEGAL.TIPOID = TIPOS_DOCUMENTOS.DCTO_IDENTIDAD LEFT JOIN TERCERO TERCERO_RESPONSABLE ON NAT_JURIDENTIFICACION.COMPANIA = TERCERO_RESPONSABLE.COMPANIA AND NAT_JURIDENTIFICACION.RESPONSABLE = TERCERO_RESPONSABLE.NIT AND NAT_JURIDENTIFICACION.SUCURSAL_RESPONSABLE =TERCERO_RESPONSABLE.SUCURSAL INNER JOIN RESPONSABLE ON RESPONSABLE.COMPANIA = TERCERO_RESPONSABLE.COMPANIA AND RESPONSABLE.CEDULA = TERCERO_RESPONSABLE.NIT AND RESPONSABLE.SUCURSAL = TERCERO_RESPONSABLE.SUCURSAL WHERE NAT_JURIDENTIFICACION.COMPANIA= :KEY_COMPANIA AND NAT_JURIDENTIFICACION.NITSOCIEDAD= :KEY_NITSOCIEDAD AND NAT_JURIDENTIFICACION.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NITSOCIEDAD":"$NITSOCIEDAD","SUCURSAL":"$SUCURSAL","SIGLA":"$SIGLA","ORDEN":"$ORDEN","CUAL":"$CUAL","TIPO":"$TIPO","CLASE":"$CLASE","DOMICILIO":"$DOMICILIO","APARTADOAEREO":"$APARTADOAEREO","TIPOID_REPRE":"$TIPOID_REPRE","NUMERO_IDREPRE":"$NUMERO_IDREPRE","SUCURSAL_REPRE":"$SUCURSAL_REPRE","CARACTER":"$CARACTER","CONTRATACION":"$CONTRATACION","INHABILIDAD":"$INHABILIDAD","OBS_REPRE":"$OBS_REPRE","FIRMAREPRE":"$FIRMAREPRE","OBSERVACIONES":"$OBSERVACIONES","RESPONSABLE":"$RESPONSABLE","SUCURSAL_RESPONSABLE":"$SUCURSAL_RESPONSABLE","RESPFIRMA":"$RESPFIRMA","ENTRE_CIUDAD":"$ENTRE_CIUDAD","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","FECHA_DILIG":"$FECHA_DILIG","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","FECHA":"$FECHA","RAZONSOCIAL":"$RAZONSOCIAL","PAIS_NOMBRE":"$PAIS_NOMBRE","DEPARTAMENTO_NOMBRE":"$DEPARTAMENTO_NOMBRE","MUNICIPIO_NOMBRE":"$MUNICIPIO_NOMBRE","NOMBRES":"$NOMBRES","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","TIPO_DOCU":"$TIPO_DOCU","DIRECCION":"$DIRECCION","FAX":"$FAX","TELEFONOS":"$TELEFONOS","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","CARGO_RESPONSABLE":"$CARGO_RESPONSABLE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NITSOCIEDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natjuridentificacion/data">
		<call-query href="getNatjuridentificacionRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NITSOCIEDAD" query-param="KEY_NITSOCIEDAD"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateNatjuridentificacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_JURIDENTIFICACION SET COMPANIA=:COMPANIA, NITSOCIEDAD=:NITSOCIEDAD, SUCURSAL=:SUCURSAL, SIGLA=:SIGLA, ORDEN=:ORDEN, CUAL=:CUAL, TIPO=:TIPO, CLASE=:CLASE, DOMICILIO=:DOMICILIO, APARTADOAEREO=:APARTADOAEREO, TIPOID_REPRE=:TIPOID_REPRE, NUMERO_IDREPRE=:NUMERO_IDREPRE, SUCURSAL_REPRE=:SUCURSAL_REPRE, CARACTER=:CARACTER, CONTRATACION=:CONTRATACION, INHABILIDAD=:INHABILIDAD, OBS_REPRE=:OBS_REPRE, FIRMAREPRE=:FIRMAREPRE, OBSERVACIONES=:OBSERVACIONES, RESPONSABLE=:RESPONSABLE, SUCURSAL_RESPONSABLE=:SUCURSAL_RESPONSABLE, RESPFIRMA=:RESPFIRMA, ENTRE_CIUDAD=:ENTRE_CIUDAD, MODIFIED_BY=:MODIFIED_BY, FECHA_DILIG=TO_DATE(:FECHA_DILIG,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_JURIDENTIFICACION.COMPANIA= :KEY_COMPANIA AND NAT_JURIDENTIFICACION.NITSOCIEDAD= :KEY_NITSOCIEDAD AND NAT_JURIDENTIFICACION.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NITSOCIEDAD" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="CUAL" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
