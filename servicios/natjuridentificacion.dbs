		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NITSOCIEDAD" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natjuridentificacion">
		<call-query href="updateNatjuridentificacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NITSOCIEDAD" query-param="NITSOCIEDAD"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="CUAL" query-param="CUAL"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="DOMICILIO" query-param="DOMICILIO"/>
			<with-param name="APARTADOAEREO" query-param="APARTADOAEREO"/>
			<with-param name="TIPOID_REPRE" query-param="TIPOID_REPRE"/>
			<with-param name="NUMERO_IDREPRE" query-param="NUMERO_IDREPRE"/>
			<with-param name="SUCURSAL_REPRE" query-param="SUCURSAL_REPRE"/>
			<with-param name="CARACTER" query-param="CARACTER"/>
