<data name="fuentesfutcategorias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFuentesfutcategoriasPagTodosPorCompaniaAnoYFormularioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT FUENTESFUTCATEGORIAS.CODIGO_FUT, CONCAT(CODIGO_FUT,CONCAT(' - ',NOMBRE_FUT) ) NOMBRE FROM FUENTESFUTCATEGORIAS WHERE FUENTESFUTCATEGORIAS.COMPANIA =:COMPANIA AND FUENTESFUTCATEGORIAS.ANO =:ANO AND FUENTESFUTCATEGORIAS.CODIGO_FORMULARIO =:CODIGO ORDER BY CODIGO_FUT) INI WHERE (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END) LIKE UPPER(CONCAT(:CODIGO_FUT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_FUT":"$CODIGO_FUT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuentesfutcategorias/todosporcompaniaanoyformulario/pag">
		<call-query href="getFuentesfutcategoriasPagTodosPorCompaniaAnoYFormularioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutcategoriasNumTodosPorCompaniaAnoYFormularioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT FUENTESFUTCATEGORIAS.CODIGO_FUT, CONCAT(CODIGO_FUT,CONCAT(' - ',NOMBRE_FUT) ) NOMBRE FROM FUENTESFUTCATEGORIAS WHERE FUENTESFUTCATEGORIAS.COMPANIA =:COMPANIA AND FUENTESFUTCATEGORIAS.ANO =:ANO AND FUENTESFUTCATEGORIAS.CODIGO_FORMULARIO =:CODIGO ORDER BY CODIGO_FUT) INI WHERE (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END) LIKE UPPER(CONCAT(:CODIGO_FUT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfutcategorias/todosporcompaniaanoyformulario/num">
		<call-query href="getFuentesfutcategoriasNumTodosPorCompaniaAnoYFormularioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getFuentesfutcategoriasPagCodigoYNombrePorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FUENTESFUTCATEGORIAS.CODIGO_FUT, FUENTESFUTCATEGORIAS.NOMBRE_FUT  FROM FUENTESFUTCATEGORIAS WHERE COMPANIA = :COMPANIA AND FUENTESFUTCATEGORIAS.ANO = :ANO ORDER BY FUENTESFUTCATEGORIAS.CODIGO_FUT) WHERE (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER(:CODIGO_FUT || '%')  AND (CASE WHEN NOMBRE_FUT IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUT) END)  LIKE UPPER( '%' || :NOMBRE_FUT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_FUT":"$CODIGO_FUT","NOMBRE_FUT":"$NOMBRE_FUT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE_FUT" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuentesfutcategorias/codigoynombreporanio/pag">
		<call-query href="getFuentesfutcategoriasPagCodigoYNombrePorAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE_FUT" query-param="NOMBRE_FUT"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutcategoriasNumCodigoYNombrePorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FUENTESFUTCATEGORIAS.CODIGO_FUT, FUENTESFUTCATEGORIAS.NOMBRE_FUT  FROM FUENTESFUTCATEGORIAS WHERE COMPANIA = :COMPANIA AND FUENTESFUTCATEGORIAS.ANO = :ANO ORDER BY FUENTESFUTCATEGORIAS.CODIGO_FUT) WHERE (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER(:CODIGO_FUT || '%')  AND (CASE WHEN NOMBRE_FUT IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUT) END)  LIKE UPPER( '%' || :NOMBRE_FUT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE_FUT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfutcategorias/codigoynombreporanio/num">
		<call-query href="getFuentesfutcategoriasNumCodigoYNombrePorAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE_FUT" query-param="NOMBRE_FUT"/>

		</call-query>
	</resource>
	<query id="insertFuentesfutcategorias" keyColumns="COMPANIA,ANO,CODIGO_FUT" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FUENTESFUTCATEGORIAS (COMPANIA, ANO, CODIGO_FUT, NOMBRE_FUT, CODIGO_FORMULARIO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO_FUT, :NOMBRE_FUT, :CODIGO_FORMULARIO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO_FUT":"$CODIGO_FUT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE_FUT" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_FORMULARIO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="fuentesfutcategorias">
		<call-query href="insertFuentesfutcategorias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE_FUT" query-param="NOMBRE_FUT"/>
			<with-param name="CODIGO_FORMULARIO" query-param="CODIGO_FORMULARIO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteFuentesfutcategorias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FUENTESFUTCATEGORIAS WHERE FUENTESFUTCATEGORIAS.COMPANIA= :KEY_COMPANIA AND FUENTESFUTCATEGORIAS.ANO= :KEY_ANO AND FUENTESFUTCATEGORIAS.CODIGO_FUT= :KEY_CODIGO_FUT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_FUT" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="fuentesfutcategorias">
		<call-query href="deleteFuentesfutcategorias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO_FUT" query-param="KEY_CODIGO_FUT"/>

		</call-query>
	</resource>
	<query id="getFuentesfutcategoriasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, CODIGO_FUT, NOMBRE_FUT, CODIGO_FORMULARIO  FROM FUENTESFUTCATEGORIAS WHERE COMPANIA = :COMPANIA ORDER BY ANO, CODIGO_FUT) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER(:CODIGO_FUT || '%')  AND (CASE WHEN NOMBRE_FUT IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUT) END)  LIKE UPPER( '%' || :NOMBRE_FUT || '%')  AND (CASE WHEN CODIGO_FORMULARIO IS NULL THEN ' ' ELSE UPPER(CODIGO_FORMULARIO) END)  LIKE UPPER(:CODIGO_FORMULARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO_FUT":"$CODIGO_FUT","NOMBRE_FUT":"$NOMBRE_FUT","CODIGO_FORMULARIO":"$CODIGO_FORMULARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE_FUT" sqlType="STRING"/>
		<param name="CODIGO_FORMULARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="fuentesfutcategorias">
		<call-query href="getFuentesfutcategoriasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE_FUT" query-param="NOMBRE_FUT"/>
			<with-param name="CODIGO_FORMULARIO" query-param="CODIGO_FORMULARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFuentesfutcategoriasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO, CODIGO_FUT, NOMBRE_FUT, CODIGO_FORMULARIO  FROM FUENTESFUTCATEGORIAS WHERE COMPANIA = :COMPANIA ORDER BY ANO, CODIGO_FUT) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER(:CODIGO_FUT || '%')  AND (CASE WHEN NOMBRE_FUT IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUT) END)  LIKE UPPER( '%' || :NOMBRE_FUT || '%')  AND (CASE WHEN CODIGO_FORMULARIO IS NULL THEN ' ' ELSE UPPER(CODIGO_FORMULARIO) END)  LIKE UPPER(:CODIGO_FORMULARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE_FUT" sqlType="STRING"/>
		<param name="CODIGO_FORMULARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="fuentesfutcategorias/numero">
		<call-query href="getFuentesfutcategoriasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE_FUT" query-param="NOMBRE_FUT"/>
			<with-param name="CODIGO_FORMULARIO" query-param="CODIGO_FORMULARIO"/>

		</call-query>
	</resource>
	<query id="updateFuentesfutcategorias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FUENTESFUTCATEGORIAS SET ANO=:ANO, CODIGO_FUT=:CODIGO_FUT, NOMBRE_FUT=:NOMBRE_FUT, CODIGO_FORMULARIO=:CODIGO_FORMULARIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FUENTESFUTCATEGORIAS.COMPANIA= :KEY_COMPANIA AND FUENTESFUTCATEGORIAS.ANO= :KEY_ANO AND FUENTESFUTCATEGORIAS.CODIGO_FUT= :KEY_CODIGO_FUT</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO_FUT" sqlType="STRING"/>
		<param name="NOMBRE_FUT" sqlType="STRING"/>
		<param name="CODIGO_FORMULARIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO_FUT" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="fuentesfutcategorias">
		<call-query href="updateFuentesfutcategorias">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO_FUT" query-param="CODIGO_FUT"/>
			<with-param name="NOMBRE_FUT" query-param="NOMBRE_FUT"/>
			<with-param name="CODIGO_FORMULARIO" query-param="CODIGO_FORMULARIO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO_FUT" query-param="KEY_CODIGO_FUT"/>

		</call-query>
	</resource>

</data>