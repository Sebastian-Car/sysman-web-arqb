<data name="natrelaciondiarios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatrelaciondiarios" keyColumns="COMPANIA,NRO_CONVOCATORIA,DIARIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_RELACION_DIARIOS (COMPANIA, NRO_CONVOCATORIA, DIARIO, SECCION, FECHA, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NRO_CONVOCATORIA, :DIARIO, :SECCION, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","KEY_DIARIO":"$DIARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="DIARIO" sqlType="STRING"/>
		<param defaultValue="" name="SECCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natrelaciondiarios">
		<call-query href="insertNatrelaciondiarios">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="DIARIO" query-param="DIARIO"/>
			<with-param name="SECCION" query-param="SECCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteNatrelaciondiarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_RELACION_DIARIOS WHERE NAT_RELACION_DIARIOS.COMPANIA= :KEY_COMPANIA AND NAT_RELACION_DIARIOS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_RELACION_DIARIOS.DIARIO= :KEY_DIARIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_DIARIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natrelaciondiarios">
		<call-query href="deleteNatrelaciondiarios">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_DIARIO" query-param="KEY_DIARIO"/>

		</call-query>
	</resource>
	<query id="getNatrelaciondiariosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_RELACION_DIARIOS.COMPANIA , NAT_RELACION_DIARIOS.NRO_CONVOCATORIA , NAT_RELACION_DIARIOS.DIARIO , NAT_DIARIOS.NOMBRE,(TO_CHAR(NAT_RELACION_DIARIOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, NAT_RELACION_DIARIOS.SECCION  FROM NAT_RELACION_DIARIOS LEFT JOIN NAT_DIARIOS ON NAT_RELACION_DIARIOS.COMPANIA = NAT_DIARIOS.COMPANIA AND NAT_RELACION_DIARIOS.DIARIO = NAT_DIARIOS.DIARIO WHERE NAT_RELACION_DIARIOS.COMPANIA = :COMPANIA AND NAT_RELACION_DIARIOS.NRO_CONVOCATORIA = :CONVOCATORIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER( '%' || :NRO_CONVOCATORIA || '%')  AND (CASE WHEN DIARIO IS NULL THEN ' ' ELSE UPPER(DIARIO) END)  LIKE UPPER(:DIARIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN SECCION IS NULL THEN ' ' ELSE UPPER(SECCION) END)  LIKE UPPER( '%' || :SECCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","DIARIO":"$DIARIO","NOMBRE":"$NOMBRE","FECHA":"$FECHA","SECCION":"$SECCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="DIARIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="SECCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natrelaciondiarios">
		<call-query href="getNatrelaciondiariosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="DIARIO" query-param="DIARIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="SECCION" query-param="SECCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatrelaciondiariosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_RELACION_DIARIOS.COMPANIA , NAT_RELACION_DIARIOS.NRO_CONVOCATORIA , NAT_RELACION_DIARIOS.DIARIO , NAT_DIARIOS.NOMBRE,(TO_CHAR(NAT_RELACION_DIARIOS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, NAT_RELACION_DIARIOS.SECCION  FROM NAT_RELACION_DIARIOS LEFT JOIN NAT_DIARIOS ON NAT_RELACION_DIARIOS.COMPANIA = NAT_DIARIOS.COMPANIA AND NAT_RELACION_DIARIOS.DIARIO = NAT_DIARIOS.DIARIO WHERE NAT_RELACION_DIARIOS.COMPANIA = :COMPANIA AND NAT_RELACION_DIARIOS.NRO_CONVOCATORIA = :CONVOCATORIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER( '%' || :NRO_CONVOCATORIA || '%')  AND (CASE WHEN DIARIO IS NULL THEN ' ' ELSE UPPER(DIARIO) END)  LIKE UPPER(:DIARIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN SECCION IS NULL THEN ' ' ELSE UPPER(SECCION) END)  LIKE UPPER( '%' || :SECCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONVOCATORIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="DIARIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="SECCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natrelaciondiarios/numero">
		<call-query href="getNatrelaciondiariosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONVOCATORIA" query-param="CONVOCATORIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="DIARIO" query-param="DIARIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="SECCION" query-param="SECCION"/>

		</call-query>
	</resource>
	<query id="updateNatrelaciondiarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_RELACION_DIARIOS SET COMPANIA=:COMPANIA, NRO_CONVOCATORIA=:NRO_CONVOCATORIA, DIARIO=:DIARIO, SECCION=:SECCION, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_RELACION_DIARIOS.COMPANIA= :KEY_COMPANIA AND NAT_RELACION_DIARIOS.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA AND NAT_RELACION_DIARIOS.DIARIO= :KEY_DIARIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="DIARIO" sqlType="STRING"/>
		<param name="SECCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="KEY_DIARIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natrelaciondiarios">
		<call-query href="updateNatrelaciondiarios">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="DIARIO" query-param="DIARIO"/>
			<with-param name="SECCION" query-param="SECCION"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NRO_CONVOCATORIA" query-param="KEY_NRO_CONVOCATORIA"/>
			<with-param name="KEY_DIARIO" query-param="KEY_DIARIO"/>

		</call-query>
	</resource>

</data>