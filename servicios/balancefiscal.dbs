<data name="balancefiscal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBalancefiscalGetmaxconsecutivocompbalfiscalQuery"  useConfig="sysmandsunist">
		<sql>SELECT MAX(COMPROBANTE) COMPROBANTE FROM BALANCE_FISCAL WHERE Compania = :COMPANIA AND BALANCE_FISCAL.ANO = :ANO ORDER BY BALANCE_FISCAL.COMPANIA DESC , BALANCE_FISCAL.ANO DESC , BALANCE_FISCAL.MES DESC , BALANCE_FISCAL.DIA DESC , BALANCE_FISCAL.COMPROBANTE DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="balancefiscal/getmaxconsecutivocompbalfiscal">
		<call-query href="getBalancefiscalGetmaxconsecutivocompbalfiscalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="insertBalancefiscal" keyColumns="COMPANIA,ANO,MES,DIA,COMPROBANTE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BALANCE_FISCAL (COMPANIA, ANO, MES, DIA, COMPROBANTE, FECHA, OBSERVACIONES, IMPRESO, DEBITO, CREDITO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :MES, :DIA, :COMPROBANTE, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACIONES, :IMPRESO, :DEBITO, :CREDITO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_DIA":"$DIA(type:integer)","KEY_COMPROBANTE":"$COMPROBANTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="" name="IMPRESO" sqlType="STRING"/>
		<param defaultValue="" name="DEBITO" sqlType="STRING"/>
		<param defaultValue="" name="CREDITO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="balancefiscal">
		<call-query href="insertBalancefiscal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DIA" query-param="DIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="DEBITO" query-param="DEBITO"/>
			<with-param name="CREDITO" query-param="CREDITO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBalancefiscal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BALANCE_FISCAL WHERE BALANCE_FISCAL.COMPANIA= :KEY_COMPANIA AND BALANCE_FISCAL.ANO= :KEY_ANO AND BALANCE_FISCAL.MES= :KEY_MES AND BALANCE_FISCAL.DIA= :KEY_DIA AND BALANCE_FISCAL.COMPROBANTE= :KEY_COMPROBANTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_DIA" sqlType="INTEGER"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="balancefiscal">
		<call-query href="deleteBalancefiscal">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_DIA" query-param="KEY_DIA"/>
			<with-param name="KEY_COMPROBANTE" query-param="KEY_COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="getBalancefiscalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, MES, DIA, COMPROBANTE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, (DEBITO+CREDITO) VALOR, OBSERVACIONES,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO FROM BALANCE_FISCAL) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) AND (CASE WHEN DIA IS NULL THEN ' ' ELSE UPPER(DIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIA), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(CONCAT('%',:IMPRESO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","DIA":"$DIA(type:integer)","COMPROBANTE":"$COMPROBANTE","FECHA":"$FECHA","VALOR":"$VALOR(type:integer)","OBSERVACIONES":"$OBSERVACIONES","IMPRESO":"$IMPRESO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="balancefiscal">
		<call-query href="getBalancefiscalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DIA" query-param="DIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBalancefiscalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, MES, DIA, COMPROBANTE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, (DEBITO+CREDITO) VALOR, OBSERVACIONES,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO FROM BALANCE_FISCAL) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) AND (CASE WHEN DIA IS NULL THEN ' ' ELSE UPPER(DIA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIA), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(CONCAT('%',:IMPRESO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="balancefiscal/numero">
		<call-query href="getBalancefiscalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DIA" query-param="DIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>

		</call-query>
	</resource>
	<query id="getBalancefiscalRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPROBANTE,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, (DEBITO+CREDITO) VALOR, OBSERVACIONES,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED FROM BALANCE_FISCAL WHERE BALANCE_FISCAL.COMPANIA= :KEY_COMPANIA AND BALANCE_FISCAL.ANO= :KEY_ANO AND BALANCE_FISCAL.MES= :KEY_MES AND BALANCE_FISCAL.DIA= :KEY_DIA AND BALANCE_FISCAL.COMPROBANTE= :KEY_COMPROBANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE","FECHA":"$FECHA","VALOR":"$VALOR(type:integer)","OBSERVACIONES":"$OBSERVACIONES","IMPRESO":"$IMPRESO(type:boolean)","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_DIA" sqlType="STRING"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="balancefiscal/data">
		<call-query href="getBalancefiscalRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_DIA" query-param="KEY_DIA"/>
			<with-param name="KEY_COMPROBANTE" query-param="KEY_COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="updateBalancefiscal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BALANCE_FISCAL SET OBSERVACIONES=:OBSERVACIONES, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DIA=:DIA, MES=:MES, ANO=:ANO, IMPRESO=:IMPRESO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BALANCE_FISCAL.COMPANIA= :KEY_COMPANIA AND BALANCE_FISCAL.ANO= :KEY_ANO AND BALANCE_FISCAL.MES= :KEY_MES AND BALANCE_FISCAL.DIA= :KEY_DIA AND BALANCE_FISCAL.COMPROBANTE= :KEY_COMPROBANTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DIA" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_DIA" sqlType="STRING"/>
		<param name="KEY_COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="balancefiscal">
		<call-query href="updateBalancefiscal">
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DIA" query-param="DIA"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_DIA" query-param="KEY_DIA"/>
			<with-param name="KEY_COMPROBANTE" query-param="KEY_COMPROBANTE"/>

		</call-query>
	</resource>

</data>