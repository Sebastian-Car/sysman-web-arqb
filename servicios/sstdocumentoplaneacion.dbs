<data name="sstdocumentoplaneacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSstdocumentoplaneacion" keyColumns="COMPANIA,ANO,TIPO,ACTIVIDADES,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_DOCUMENTO_PLANEACION (COMPANIA, ANO, CONSECUTIVO, ACTIVIDADES, TIPO, NOMBRE_ARCHIVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CONSECUTIVO, :ACTIVIDADES, :TIPO, :NOMBRE_ARCHIVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_ACTIVIDADES":"$ACTIVIDADES","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstdocumentoplaneacion">
		<call-query href="insertSstdocumentoplaneacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSstdocumentoplaneacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_DOCUMENTO_PLANEACION WHERE SST_DOCUMENTO_PLANEACION.COMPANIA= :KEY_COMPANIA AND SST_DOCUMENTO_PLANEACION.ANO= :KEY_ANO AND SST_DOCUMENTO_PLANEACION.TIPO= :KEY_TIPO AND SST_DOCUMENTO_PLANEACION.ACTIVIDADES= :KEY_ACTIVIDADES AND SST_DOCUMENTO_PLANEACION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ACTIVIDADES" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sstdocumentoplaneacion">
		<call-query href="deleteSstdocumentoplaneacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ACTIVIDADES" query-param="KEY_ACTIVIDADES"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSstdocumentoplaneacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, ACTIVIDADES, TIPO, NOMBRE_ARCHIVO,CONSECUTIVO  FROM SST_DOCUMENTO_PLANEACION WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPOACT AND ACTIVIDADES = :ACTIVIDAD) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN ACTIVIDADES IS NULL THEN ' ' ELSE UPPER(ACTIVIDADES) END)  LIKE UPPER( '%' || :ACTIVIDADES || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END)  LIKE UPPER( '%' || :NOMBRE_ARCHIVO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ACTIVIDADES":"$ACTIVIDADES","TIPO":"$TIPO","NOMBRE_ARCHIVO":"$NOMBRE_ARCHIVO","CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOACT" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstdocumentoplaneacion">
		<call-query href="getSstdocumentoplaneacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOACT" query-param="TIPOACT"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstdocumentoplaneacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO, ACTIVIDADES, TIPO, NOMBRE_ARCHIVO,CONSECUTIVO  FROM SST_DOCUMENTO_PLANEACION WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPOACT AND ACTIVIDADES = :ACTIVIDAD) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN ACTIVIDADES IS NULL THEN ' ' ELSE UPPER(ACTIVIDADES) END)  LIKE UPPER( '%' || :ACTIVIDADES || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%')  AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END)  LIKE UPPER( '%' || :NOMBRE_ARCHIVO || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOACT" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstdocumentoplaneacion/numero">
		<call-query href="getSstdocumentoplaneacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOACT" query-param="TIPOACT"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateSstdocumentoplaneacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_DOCUMENTO_PLANEACION SET COMPANIA=:COMPANIA, ANO=:ANO, ACTIVIDADES=:ACTIVIDADES, TIPO=:TIPO, CONSECUTIVO=:CONSECUTIVO, NOMBRE_ARCHIVO=:NOMBRE_ARCHIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_DOCUMENTO_PLANEACION.COMPANIA= :KEY_COMPANIA AND SST_DOCUMENTO_PLANEACION.ANO= :KEY_ANO AND SST_DOCUMENTO_PLANEACION.TIPO= :KEY_TIPO AND SST_DOCUMENTO_PLANEACION.ACTIVIDADES= :KEY_ACTIVIDADES AND SST_DOCUMENTO_PLANEACION.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ACTIVIDADES" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstdocumentoplaneacion">
		<call-query href="updateSstdocumentoplaneacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ACTIVIDADES" query-param="KEY_ACTIVIDADES"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>