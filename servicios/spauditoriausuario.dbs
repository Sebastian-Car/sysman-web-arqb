<data name="spauditoriausuario" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpauditoriausuarioPagAuditoriaSuscriptorPorCicloYCodigoRutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, CONSECUTIVO, USO, USO_ANT, ESTRATO, ESTRATO_ANT, CASE ESTADO WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' ELSE '' END ESTADO, CASE ESTADO_ANT WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' ELSE '' END ESTADO_ANT, TO_CHAR(DATE_CREATED,'DD/MM/YYYY') FECHA_MODIF, TO_CHAR(DATE_CREATED,'HH24:mi:ss') HORA_MODIF, CREATED_BY USUARIO, OBSERVACION  FROM SP_AUDITORIA_USUARIO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA) WHERE (CASE WHEN USO IS NULL THEN ' ' ELSE UPPER(USO) END)  LIKE UPPER(:USO || '%')  AND (CASE WHEN USO_ANT IS NULL THEN ' ' ELSE UPPER(USO_ANT) END)  LIKE UPPER(:USO_ANT || '%')  AND (CASE WHEN ESTRATO IS NULL THEN ' ' ELSE UPPER(ESTRATO) END)  LIKE UPPER(:ESTRATO || '%')  AND (CASE WHEN ESTRATO_ANT IS NULL THEN ' ' ELSE UPPER(ESTRATO_ANT) END)  LIKE UPPER(:ESTRATO_ANT || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%')  AND (CASE WHEN ESTADO_ANT IS NULL THEN ' ' ELSE UPPER(ESTADO_ANT) END)  LIKE UPPER( '%' || :ESTADO_ANT || '%')  AND (CASE WHEN FECHA_MODIF IS NULL THEN ' ' ELSE UPPER(FECHA_MODIF) END)  LIKE UPPER( '%' || :FECHA_MODIF || '%')  AND (CASE WHEN HORA_MODIF IS NULL THEN ' ' ELSE UPPER(HORA_MODIF) END)  LIKE UPPER( '%' || :HORA_MODIF || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","CONSECUTIVO":"$CONSECUTIVO","USO":"$USO","USO_ANT":"$USO_ANT","ESTRATO":"$ESTRATO","ESTRATO_ANT":"$ESTRATO_ANT","ESTADO":"$ESTADO","ESTADO_ANT":"$ESTADO_ANT","FECHA_MODIF":"$FECHA_MODIF","HORA_MODIF":"$HORA_MODIF","USUARIO":"$USUARIO","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="USO_ANT" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="ESTRATO_ANT" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="ESTADO_ANT" sqlType="STRING"/>
		<param name="FECHA_MODIF" sqlType="STRING"/>
		<param name="HORA_MODIF" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spauditoriausuario/auditoriasuscriptorporcicloycodigoruta/pag">
		<call-query href="getSpauditoriausuarioPagAuditoriaSuscriptorPorCicloYCodigoRutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="USO_ANT" query-param="USO_ANT"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="ESTRATO_ANT" query-param="ESTRATO_ANT"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="ESTADO_ANT" query-param="ESTADO_ANT"/>
			<with-param name="FECHA_MODIF" query-param="FECHA_MODIF"/>
			<with-param name="HORA_MODIF" query-param="HORA_MODIF"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpauditoriausuarioNumAuditoriaSuscriptorPorCicloYCodigoRutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, CONSECUTIVO, USO, USO_ANT, ESTRATO, ESTRATO_ANT, CASE ESTADO WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' ELSE '' END ESTADO, CASE ESTADO_ANT WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' ELSE '' END ESTADO_ANT, TO_CHAR(DATE_CREATED,'DD/MM/YYYY') FECHA_MODIF, TO_CHAR(DATE_CREATED,'HH24:mi:ss') HORA_MODIF, CREATED_BY USUARIO, OBSERVACION  FROM SP_AUDITORIA_USUARIO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA) WHERE (CASE WHEN USO IS NULL THEN ' ' ELSE UPPER(USO) END)  LIKE UPPER(:USO || '%')  AND (CASE WHEN USO_ANT IS NULL THEN ' ' ELSE UPPER(USO_ANT) END)  LIKE UPPER( '%' || :USO_ANT || '%')  AND (CASE WHEN ESTRATO IS NULL THEN ' ' ELSE UPPER(ESTRATO) END)  LIKE UPPER( '%' || :ESTRATO || '%')  AND (CASE WHEN ESTRATO_ANT IS NULL THEN ' ' ELSE UPPER(ESTRATO_ANT) END)  LIKE UPPER( '%' || :ESTRATO_ANT || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%')  AND (CASE WHEN ESTADO_ANT IS NULL THEN ' ' ELSE UPPER(ESTADO_ANT) END)  LIKE UPPER( '%' || :ESTADO_ANT || '%')  AND (CASE WHEN FECHA_MODIF IS NULL THEN ' ' ELSE UPPER(FECHA_MODIF) END)  LIKE UPPER( '%' || :FECHA_MODIF || '%')  AND (CASE WHEN HORA_MODIF IS NULL THEN ' ' ELSE UPPER(HORA_MODIF) END)  LIKE UPPER( '%' || :HORA_MODIF || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="USO_ANT" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="ESTRATO_ANT" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="ESTADO_ANT" sqlType="STRING"/>
		<param name="FECHA_MODIF" sqlType="STRING"/>
		<param name="HORA_MODIF" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spauditoriausuario/auditoriasuscriptorporcicloycodigoruta/num">
		<call-query href="getSpauditoriausuarioNumAuditoriaSuscriptorPorCicloYCodigoRutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="USO_ANT" query-param="USO_ANT"/>
			<with-param name="ESTRATO" query-param="ESTRATO"/>
			<with-param name="ESTRATO_ANT" query-param="ESTRATO_ANT"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="ESTADO_ANT" query-param="ESTADO_ANT"/>
			<with-param name="FECHA_MODIF" query-param="FECHA_MODIF"/>
			<with-param name="HORA_MODIF" query-param="HORA_MODIF"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>

		</call-query>
	</resource>
	<query id="getSpauditoriausuarioCodigofechaestadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGORUTA, TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS') FECHAESTADO  FROM SP_AUDITORIA_USUARIO WHERE COMPANIA = :COMPANIA AND CODIGORUTA = :CODIGORUTAACTUAL AND ESTADO &lt;&gt; ESTADO_ANT AND ESTADO = :ESTADO ORDER BY TO_CHAR(DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS') DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","FECHAESTADO":"$FECHAESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTAACTUAL" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spauditoriausuario/codigofechaestado">
		<call-query href="getSpauditoriausuarioCodigofechaestadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGORUTAACTUAL" query-param="CODIGORUTAACTUAL"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>

</data>