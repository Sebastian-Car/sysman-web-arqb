<data name="tasasinteres" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTasasinteresConsultarTasasEnFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT EXTRACT(YEAR FROM FECHA_FINAL) ANOTASA,(TO_CHAR(TASAS_INTERES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, TASAS_INTERES.CUENTA_CONTABLE, TASAS_INTERES.TASA FROM TASAS_INTERES WHERE FECHA_FINAL IS NOT NULL AND :FECHA BETWEEN FECHA_INICIAL AND FECHA_FINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANOTASA":"$ANOTASA(type:integer)","FECHA_FINAL":"$FECHA_FINAL","CUENTA_CONTABLE":"$CUENTA_CONTABLE","TASA":"$TASA"}]}}		</result>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tasasinteres/consultartasasenfecha">
		<call-query href="getTasasinteresConsultarTasasEnFechaQuery">
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="insertTasasinteres" keyColumns="" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TASAS_INTERES (FECHA_INICIAL, FECHA_FINAL, TASA, RESOLUCION, FECHA_RESOLUCION, ANO, CUENTA_CONTABLE, TASA_TES, DATE_CREATED, CREATED_BY) VALUES (TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), :TASA, :RESOLUCION, TO_DATE(:FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS'), :ANO, :CUENTA_CONTABLE, :TASA_TES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_FECHA_INICIAL":"$FECHA_INICIAL","KEY_FECHA_FINAL":"$FECHA_FINAL"}]}}		</result>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="0" name="TASA" sqlType="STRING"/>
		<param defaultValue="" name="RESOLUCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_RESOLUCION" sqlType="STRING"/>
		<param defaultValue="" name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param defaultValue="" name="TASA_TES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tasasinteres">
		<call-query href="insertTasasinteres">
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASA" query-param="TASA"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>
			<with-param name="FECHA_RESOLUCION" query-param="FECHA_RESOLUCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="TASA_TES" query-param="TASA_TES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTasasinteres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TASAS_INTERES WHERE TASAS_INTERES.FECHA_INICIAL= TO_DATE(:KEY_FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS') AND TASAS_INTERES.FECHA_FINAL= TO_DATE(:KEY_FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_FECHA_INICIAL" sqlType="STRING"/>
		<param name="KEY_FECHA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tasasinteres">
		<call-query href="deleteTasasinteres">
			<with-param name="KEY_FECHA_INICIAL" query-param="KEY_FECHA_INICIAL"/>
			<with-param name="KEY_FECHA_FINAL" query-param="KEY_FECHA_FINAL"/>

		</call-query>
	</resource>
	<query id="getTasasinteresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ANO, TO_CHAR(TASAS_INTERES.FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS') FECHA_INICIAL, TO_CHAR(TASAS_INTERES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS') FECHA_FINAL, TRIM(TO_CHAR(TASAS_INTERES.TASA,CONCAT(RPAD('9',18,'9'),'0D99') ) ) TASA, TASAS_INTERES.TASA_TES, TASAS_INTERES.RESOLUCION, TO_CHAR(TASAS_INTERES.FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS') FECHA_RESOLUCION ,CUENTA_CONTABLE FROM TASAS_INTERES ORDER BY TASAS_INTERES.FECHA_INICIAL) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIAL), '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINAL), '%')) AND (CASE WHEN TASA IS NULL THEN ' ' ELSE UPPER(TASA) END) LIKE UPPER(CONCAT(:TASA, '%')) AND (CASE WHEN TASA_TES IS NULL THEN ' ' ELSE UPPER(TASA_TES) END) LIKE UPPER(CONCAT(:TASA_TES, '%')) AND (CASE WHEN RESOLUCION IS NULL THEN ' ' ELSE UPPER(RESOLUCION) END) LIKE UPPER(CONCAT(CONCAT('%',:RESOLUCION), '%')) AND (CASE WHEN FECHA_RESOLUCION IS NULL THEN ' ' ELSE UPPER(FECHA_RESOLUCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_RESOLUCION), '%')) AND (CASE WHEN CUENTA_CONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTA_CONTABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA_CONTABLE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","TASA":"$TASA","TASA_TES":"$TASA_TES","RESOLUCION":"$RESOLUCION","FECHA_RESOLUCION":"$FECHA_RESOLUCION","CUENTA_CONTABLE":"$CUENTA_CONTABLE"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="TASA" sqlType="STRING"/>
		<param name="TASA_TES" sqlType="STRING"/>
		<param name="RESOLUCION" sqlType="STRING"/>
		<param name="FECHA_RESOLUCION" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tasasinteres">
		<call-query href="getTasasinteresPaginaQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASA" query-param="TASA"/>
			<with-param name="TASA_TES" query-param="TASA_TES"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>
			<with-param name="FECHA_RESOLUCION" query-param="FECHA_RESOLUCION"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTasasinteresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ANO, TO_CHAR(TASAS_INTERES.FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS') FECHA_INICIAL, TO_CHAR(TASAS_INTERES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS') FECHA_FINAL, TRIM(TO_CHAR(TASAS_INTERES.TASA,CONCAT(RPAD('9',18,'9'),'0D99') ) ) TASA, TASAS_INTERES.TASA_TES, TASAS_INTERES.RESOLUCION, TO_CHAR(TASAS_INTERES.FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS') FECHA_RESOLUCION ,CUENTA_CONTABLE FROM TASAS_INTERES ORDER BY TASAS_INTERES.FECHA_INICIAL) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INICIAL), '%')) AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FINAL), '%')) AND (CASE WHEN TASA IS NULL THEN ' ' ELSE UPPER(TASA) END) LIKE UPPER(CONCAT(:TASA, '%')) AND (CASE WHEN TASA_TES IS NULL THEN ' ' ELSE UPPER(TASA_TES) END) LIKE UPPER(CONCAT(:TASA_TES, '%')) AND (CASE WHEN RESOLUCION IS NULL THEN ' ' ELSE UPPER(RESOLUCION) END) LIKE UPPER(CONCAT(CONCAT('%',:RESOLUCION), '%')) AND (CASE WHEN FECHA_RESOLUCION IS NULL THEN ' ' ELSE UPPER(FECHA_RESOLUCION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_RESOLUCION), '%')) AND (CASE WHEN CUENTA_CONTABLE IS NULL THEN ' ' ELSE UPPER(CUENTA_CONTABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA_CONTABLE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="TASA" sqlType="STRING"/>
		<param name="TASA_TES" sqlType="STRING"/>
		<param name="RESOLUCION" sqlType="STRING"/>
		<param name="FECHA_RESOLUCION" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tasasinteres/numero">
		<call-query href="getTasasinteresNumeroQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASA" query-param="TASA"/>
			<with-param name="TASA_TES" query-param="TASA_TES"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>
			<with-param name="FECHA_RESOLUCION" query-param="FECHA_RESOLUCION"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>

		</call-query>
	</resource>
	<query id="updateTasasinteres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TASAS_INTERES SET FECHA_INICIAL=TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TASA=:TASA, RESOLUCION=:RESOLUCION, FECHA_RESOLUCION=TO_DATE(:FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS'), ANO=:ANO, CUENTA_CONTABLE=:CUENTA_CONTABLE, TASA_TES=:TASA_TES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TASAS_INTERES.FECHA_INICIAL= TO_DATE(:KEY_FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS') AND TASAS_INTERES.FECHA_FINAL= TO_DATE(:KEY_FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="TASA" sqlType="STRING"/>
		<param name="RESOLUCION" sqlType="STRING"/>
		<param name="FECHA_RESOLUCION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA_CONTABLE" sqlType="STRING"/>
		<param name="TASA_TES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_FECHA_INICIAL" sqlType="STRING"/>
		<param name="KEY_FECHA_FINAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tasasinteres">
		<call-query href="updateTasasinteres">
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="TASA" query-param="TASA"/>
			<with-param name="RESOLUCION" query-param="RESOLUCION"/>
			<with-param name="FECHA_RESOLUCION" query-param="FECHA_RESOLUCION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA_CONTABLE" query-param="CUENTA_CONTABLE"/>
			<with-param name="TASA_TES" query-param="TASA_TES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_FECHA_INICIAL" query-param="KEY_FECHA_INICIAL"/>
			<with-param name="KEY_FECHA_FINAL" query-param="KEY_FECHA_FINAL"/>

		</call-query>
	</resource>

</data>