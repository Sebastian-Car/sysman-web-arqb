<data name="ssttransaccionactividad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSsttransaccionactividadPagActividadInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_TRAN.COMPANIA, SST_TRAN.TIPO_TRANSACCION, SST_TRAN.TRANSACCION, SST_TRAN.ACTIVIDAD, SST_TIPO.NOMBRE  FROM SST_TRANSACCION_ACTIVIDAD SST_TRAN INNER JOIN SST_TIPO_ACTIVIDAD SST_TIPO ON SST_TRAN.COMPANIA = SST_TIPO.COMPANIA AND SST_TRAN.ACTIVIDAD = SST_TIPO.CODIGO AND SST_TRAN.TIPO_TRANSACCION = SST_TIPO.TIPO_TRANSACCION WHERE SST_TRAN.COMPANIA = :COMPANIA AND SST_TRAN.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL ORDER BY SST_TRAN.ACTIVIDAD) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPO_TRANSACCION IS NULL THEN ' ' ELSE UPPER(TIPO_TRANSACCION) END)  LIKE UPPER( '%' || :TIPO_TRANSACCION || '%')  AND (CASE WHEN TRANSACCION IS NULL THEN ' ' ELSE UPPER(TRANSACCION) END)  LIKE UPPER( '%' || :TRANSACCION || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","TRANSACCION":"$TRANSACCION(type:long)","ACTIVIDAD":"$ACTIVIDAD(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttransaccionactividad/actividadinicial/pag">
		<call-query href="getSsttransaccionactividadPagActividadInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionactividadNumActividadInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_TRAN.COMPANIA, SST_TRAN.TIPO_TRANSACCION, SST_TRAN.TRANSACCION, SST_TRAN.ACTIVIDAD, SST_TIPO.NOMBRE  FROM SST_TRANSACCION_ACTIVIDAD SST_TRAN INNER JOIN SST_TIPO_ACTIVIDAD SST_TIPO ON SST_TRAN.COMPANIA = SST_TIPO.COMPANIA AND SST_TRAN.ACTIVIDAD = SST_TIPO.CODIGO AND SST_TRAN.TIPO_TRANSACCION = SST_TIPO.TIPO_TRANSACCION WHERE SST_TRAN.COMPANIA = :COMPANIA AND SST_TRAN.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL ORDER BY SST_TRAN.ACTIVIDAD) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPO_TRANSACCION IS NULL THEN ' ' ELSE UPPER(TIPO_TRANSACCION) END)  LIKE UPPER( '%' || :TIPO_TRANSACCION || '%')  AND (CASE WHEN TRANSACCION IS NULL THEN ' ' ELSE UPPER(TRANSACCION) END)  LIKE UPPER( '%' || :TRANSACCION || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttransaccionactividad/actividadinicial/num">
		<call-query href="getSsttransaccionactividadNumActividadInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionactividadPagActividadFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_TRAN.COMPANIA, SST_TRAN.TIPO_TRANSACCION, SST_TRAN.TRANSACCION, SST_TRAN.ACTIVIDAD, SST_TIPO.NOMBRE  FROM SST_TRANSACCION_ACTIVIDAD SST_TRAN INNER JOIN SST_TIPO_ACTIVIDAD SST_TIPO ON SST_TRAN.COMPANIA = SST_TIPO.COMPANIA AND SST_TRAN.ACTIVIDAD = SST_TIPO.CODIGO AND SST_TRAN.TIPO_TRANSACCION = SST_TIPO.TIPO_TRANSACCION WHERE SST_TRAN.COMPANIA = :COMPANIA AND SST_TRAN.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL AND SST_TRAN.ACTIVIDAD &gt;= :ACTIVIDADINICIAL ORDER BY SST_TRAN.ACTIVIDAD) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPO_TRANSACCION IS NULL THEN ' ' ELSE UPPER(TIPO_TRANSACCION) END)  LIKE UPPER( '%' || :TIPO_TRANSACCION || '%')  AND (CASE WHEN TRANSACCION IS NULL THEN ' ' ELSE UPPER(TRANSACCION) END)  LIKE UPPER( '%' || :TRANSACCION || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","TRANSACCION":"$TRANSACCION(type:long)","ACTIVIDAD":"$ACTIVIDAD(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="ACTIVIDADINICIAL" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
