	</resource>
	<query id="getSsttransaccionactividadNumActividadFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_TRAN.COMPANIA, SST_TRAN.TIPO_TRANSACCION, SST_TRAN.TRANSACCION, SST_TRAN.ACTIVIDAD, SST_TIPO.NOMBRE  FROM SST_TRANSACCION_ACTIVIDAD SST_TRAN INNER JOIN SST_TIPO_ACTIVIDAD SST_TIPO ON SST_TRAN.COMPANIA = SST_TIPO.COMPANIA AND SST_TRAN.ACTIVIDAD = SST_TIPO.CODIGO AND SST_TRAN.TIPO_TRANSACCION = SST_TIPO.TIPO_TRANSACCION WHERE SST_TRAN.COMPANIA = :COMPANIA AND SST_TRAN.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL AND SST_TRAN.ACTIVIDAD &gt;= :ACTIVIDADINICIAL ORDER BY SST_TRAN.ACTIVIDAD) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPO_TRANSACCION IS NULL THEN ' ' ELSE UPPER(TIPO_TRANSACCION) END)  LIKE UPPER( '%' || :TIPO_TRANSACCION || '%')  AND (CASE WHEN TRANSACCION IS NULL THEN ' ' ELSE UPPER(TRANSACCION) END)  LIKE UPPER( '%' || :TRANSACCION || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
