<data name="natenfermedadpersonal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatenfermedadpersonal" keyColumns="COMPANIA,CONSECUTIVO,NUMERO_DCTO,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_ENFERMEDAD_PERSONAL (COMPANIA, CONSECUTIVO, NUMERO_DCTO, SUCURSAL, ID_DE_EMPLEADO, TIPOEXAMEN, ID_ENF_PER, FECHA_APARICION, ESTADO, EXAMEN_REALIZADO, TRATAMIENTO, OBSERVACIONES_EP, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CONSECUTIVO, :NUMERO_DCTO, :SUCURSAL, :ID_DE_EMPLEADO, :TIPOEXAMEN, :ID_ENF_PER, TO_DATE(:FECHA_APARICION,'DD/MM/YYYY HH24:MI:SS'), :ESTADO, :EXAMEN_REALIZADO, :TRATAMIENTO, :OBSERVACIONES_EP, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NUMERO_DCTO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="" name="TIPOEXAMEN" sqlType="STRING"/>
		<param name="ID_ENF_PER" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_APARICION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="EXAMEN_REALIZADO" sqlType="STRING"/>
		<param name="TRATAMIENTO" sqlType="STRING"/>
		<param name="OBSERVACIONES_EP" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natenfermedadpersonal">
		<call-query href="insertNatenfermedadpersonal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="TIPOEXAMEN" query-param="TIPOEXAMEN"/>
			<with-param name="ID_ENF_PER" query-param="ID_ENF_PER"/>
			<with-param name="FECHA_APARICION" query-param="FECHA_APARICION"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="EXAMEN_REALIZADO" query-param="EXAMEN_REALIZADO"/>
			<with-param name="TRATAMIENTO" query-param="TRATAMIENTO"/>
			<with-param name="OBSERVACIONES_EP" query-param="OBSERVACIONES_EP"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteNatenfermedadpersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_ENFERMEDAD_PERSONAL WHERE NAT_ENFERMEDAD_PERSONAL.COMPANIA= :KEY_COMPANIA AND NAT_ENFERMEDAD_PERSONAL.CONSECUTIVO= :KEY_CONSECUTIVO AND NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_ENFERMEDAD_PERSONAL.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natenfermedadpersonal">
		<call-query href="deleteNatenfermedadpersonal">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatenfermedadpersonalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NAT_ENFERMEDAD_PERSONAL.COMPANIA, NAT_ENFERMEDAD_PERSONAL.CONSECUTIVO, NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO, NAT_ENFERMEDAD_PERSONAL.SUCURSAL, UPPER(CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRECOMPLETO, SST_TIPOEXAMEN.NOMBRE NOMBRETIPOEXAMEN,(TO_CHAR(NAT_ENFERMEDAD_PERSONAL.FECHA_APARICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_APARICION, NAT_ENFERMEDAD_PERSONAL.ESTADO FROM NAT_ENFERMEDAD_PERSONAL INNER JOIN NAT_DATOS_PERSONALES ON NAT_ENFERMEDAD_PERSONAL.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_ENFERMEDAD_PERSONAL.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL LEFT JOIN SST_TIPOEXAMEN ON NAT_ENFERMEDAD_PERSONAL.COMPANIA = SST_TIPOEXAMEN.COMPANIA AND NAT_ENFERMEDAD_PERSONAL.TIPOEXAMEN = SST_TIPOEXAMEN.CODIGO LEFT JOIN TIPO_ENFERMEDADES ON NAT_ENFERMEDAD_PERSONAL.ID_ENF_PER = TIPO_ENFERMEDADES.CODIGOEN WHERE NAT_ENFERMEDAD_PERSONAL.COMPANIA =:COMPANIA ORDER BY NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO, NAT_ENFERMEDAD_PERSONAL.FECHA_APARICION) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN NOMBRETIPOEXAMEN IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOEXAMEN) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPOEXAMEN), '%')) AND (CASE WHEN FECHA_APARICION IS NULL THEN ' ' ELSE UPPER(FECHA_APARICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_APARICION), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NOMBRECOMPLETO":"$NOMBRECOMPLETO","NOMBRETIPOEXAMEN":"$NOMBRETIPOEXAMEN","FECHA_APARICION":"$FECHA_APARICION","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NOMBRETIPOEXAMEN" sqlType="STRING"/>
		<param name="FECHA_APARICION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natenfermedadpersonal">
		<call-query href="getNatenfermedadpersonalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="NOMBRETIPOEXAMEN" query-param="NOMBRETIPOEXAMEN"/>
			<with-param name="FECHA_APARICION" query-param="FECHA_APARICION"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatenfermedadpersonalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NAT_ENFERMEDAD_PERSONAL.COMPANIA, NAT_ENFERMEDAD_PERSONAL.CONSECUTIVO, NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO, NAT_ENFERMEDAD_PERSONAL.SUCURSAL, UPPER(CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRECOMPLETO, SST_TIPOEXAMEN.NOMBRE NOMBRETIPOEXAMEN,(TO_CHAR(NAT_ENFERMEDAD_PERSONAL.FECHA_APARICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_APARICION, NAT_ENFERMEDAD_PERSONAL.ESTADO FROM NAT_ENFERMEDAD_PERSONAL INNER JOIN NAT_DATOS_PERSONALES ON NAT_ENFERMEDAD_PERSONAL.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_ENFERMEDAD_PERSONAL.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL LEFT JOIN SST_TIPOEXAMEN ON NAT_ENFERMEDAD_PERSONAL.COMPANIA = SST_TIPOEXAMEN.COMPANIA AND NAT_ENFERMEDAD_PERSONAL.TIPOEXAMEN = SST_TIPOEXAMEN.CODIGO LEFT JOIN TIPO_ENFERMEDADES ON NAT_ENFERMEDAD_PERSONAL.ID_ENF_PER = TIPO_ENFERMEDADES.CODIGOEN WHERE NAT_ENFERMEDAD_PERSONAL.COMPANIA =:COMPANIA ORDER BY NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO, NAT_ENFERMEDAD_PERSONAL.FECHA_APARICION) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN NOMBRETIPOEXAMEN IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOEXAMEN) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPOEXAMEN), '%')) AND (CASE WHEN FECHA_APARICION IS NULL THEN ' ' ELSE UPPER(FECHA_APARICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_APARICION), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NOMBRETIPOEXAMEN" sqlType="STRING"/>
		<param name="FECHA_APARICION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natenfermedadpersonal/numero">
		<call-query href="getNatenfermedadpersonalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="NOMBRETIPOEXAMEN" query-param="NOMBRETIPOEXAMEN"/>
			<with-param name="FECHA_APARICION" query-param="FECHA_APARICION"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getNatenfermedadpersonalRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_ENFERMEDAD_PERSONAL.COMPANIA, NAT_ENFERMEDAD_PERSONAL.CONSECUTIVO, NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO, NAT_ENFERMEDAD_PERSONAL.SUCURSAL, NAT_ENFERMEDAD_PERSONAL.TIPOEXAMEN, NAT_ENFERMEDAD_PERSONAL.ID_ENF_PER,(TO_CHAR(NAT_ENFERMEDAD_PERSONAL.FECHA_APARICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_APARICION, NAT_ENFERMEDAD_PERSONAL.ESTADO, NAT_ENFERMEDAD_PERSONAL.EXAMEN_REALIZADO, NAT_ENFERMEDAD_PERSONAL.TRATAMIENTO, NAT_ENFERMEDAD_PERSONAL.OBSERVACIONES_EP, SST_TIPOEXAMEN.NOMBRE NOMBRETIPOEXAMEN, TIPO_ENFERMEDADES.NOMBRE_ENFERMEDAD NOMBRE_ENFERMEDAD, NAT_ENFERMEDAD_PERSONAL.CREATED_BY,(TO_CHAR(NAT_ENFERMEDAD_PERSONAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, NAT_ENFERMEDAD_PERSONAL.MODIFIED_BY,(TO_CHAR(NAT_ENFERMEDAD_PERSONAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM NAT_ENFERMEDAD_PERSONAL LEFT JOIN SST_TIPOEXAMEN ON NAT_ENFERMEDAD_PERSONAL.COMPANIA = SST_TIPOEXAMEN.COMPANIA AND NAT_ENFERMEDAD_PERSONAL.TIPOEXAMEN = SST_TIPOEXAMEN.CODIGO LEFT JOIN TIPO_ENFERMEDADES ON NAT_ENFERMEDAD_PERSONAL.ID_ENF_PER = TIPO_ENFERMEDADES.CODIGOEN WHERE NAT_ENFERMEDAD_PERSONAL.COMPANIA= :KEY_COMPANIA AND NAT_ENFERMEDAD_PERSONAL.CONSECUTIVO= :KEY_CONSECUTIVO AND NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_ENFERMEDAD_PERSONAL.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","TIPOEXAMEN":"$TIPOEXAMEN","ID_ENF_PER":"$ID_ENF_PER","FECHA_APARICION":"$FECHA_APARICION","ESTADO":"$ESTADO","EXAMEN_REALIZADO":"$EXAMEN_REALIZADO","TRATAMIENTO":"$TRATAMIENTO","OBSERVACIONES_EP":"$OBSERVACIONES_EP","NOMBRETIPOEXAMEN":"$NOMBRETIPOEXAMEN","NOMBRE_ENFERMEDAD":"$NOMBRE_ENFERMEDAD","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natenfermedadpersonal/data">
		<call-query href="getNatenfermedadpersonalRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateNatenfermedadpersonal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_ENFERMEDAD_PERSONAL SET COMPANIA=:COMPANIA, CONSECUTIVO=:CONSECUTIVO, NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, TIPOEXAMEN=:TIPOEXAMEN, ID_ENF_PER=:ID_ENF_PER, FECHA_APARICION=TO_DATE(:FECHA_APARICION,'DD/MM/YYYY HH24:MI:SS'), ESTADO=:ESTADO, EXAMEN_REALIZADO=:EXAMEN_REALIZADO, TRATAMIENTO=:TRATAMIENTO, OBSERVACIONES_EP=:OBSERVACIONES_EP, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_ENFERMEDAD_PERSONAL.COMPANIA= :KEY_COMPANIA AND NAT_ENFERMEDAD_PERSONAL.CONSECUTIVO= :KEY_CONSECUTIVO AND NAT_ENFERMEDAD_PERSONAL.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_ENFERMEDAD_PERSONAL.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPOEXAMEN" sqlType="STRING"/>
		<param name="ID_ENF_PER" sqlType="STRING"/>
		<param name="FECHA_APARICION" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="EXAMEN_REALIZADO" sqlType="STRING"/>
		<param name="TRATAMIENTO" sqlType="STRING"/>
		<param name="OBSERVACIONES_EP" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natenfermedadpersonal">
		<call-query href="updateNatenfermedadpersonal">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPOEXAMEN" query-param="TIPOEXAMEN"/>
			<with-param name="ID_ENF_PER" query-param="ID_ENF_PER"/>
			<with-param name="FECHA_APARICION" query-param="FECHA_APARICION"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="EXAMEN_REALIZADO" query-param="EXAMEN_REALIZADO"/>
			<with-param name="TRATAMIENTO" query-param="TRATAMIENTO"/>
			<with-param name="OBSERVACIONES_EP" query-param="OBSERVACIONES_EP"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

