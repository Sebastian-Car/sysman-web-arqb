<data name="natcompensatorios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatcompensatorios" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,CO_TIPODOCUSOPO,CO_NUME,CP_CODIGOPERSONA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_COMPENSATORIO (CO_TIPODOCUSOPO, CO_NUME, CO_FECHRESODECR, CO_DIAS, CO_VALOR, CO_DIAS_PENDIENTES, CO_DIAS_ACUMULADOS, CO_FECHDESDE, CO_FECHHASTA, DP_NUMEDOCU, COMPANIA, SUCURSAL, CP_CODIGOPERSONA, DATE_CREATED, CREATED_BY) VALUES (:CO_TIPODOCUSOPO, :CO_NUME, TO_DATE(:CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), :CO_DIAS, :CO_VALOR, :CO_DIAS_PENDIENTES, :CO_DIAS_ACUMULADOS, TO_DATE(:CO_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:CO_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), :DP_NUMEDOCU, :COMPANIA, :SUCURSAL, :CP_CODIGOPERSONA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_CO_TIPODOCUSOPO":"$CO_TIPODOCUSOPO","KEY_CO_NUME":"$CO_NUME","KEY_CO_FECHRESODECR":"$CO_FECHRESODECR","KEY_CP_CODIGOPERSONA":"$CP_CODIGOPERSONA(type:integer)"}]}}		</result>
		<param name="CO_TIPODOCUSOPO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param name="CO_FECHRESODECR" sqlType="STRING"/>
		<param defaultValue="0" name="CO_DIAS" sqlType="STRING"/>
		<param defaultValue="0" name="CO_VALOR" sqlType="STRING"/>
		<param defaultValue="0" name="CO_DIAS_PENDIENTES" sqlType="STRING"/>
		<param defaultValue="0" name="CO_DIAS_ACUMULADOS" sqlType="STRING"/>
		<param defaultValue="" name="CO_FECHDESDE" sqlType="STRING"/>
		<param defaultValue="" name="CO_FECHHASTA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CP_CODIGOPERSONA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natcompensatorios">
		<call-query href="insertNatcompensatorios">
			<with-param name="CO_TIPODOCUSOPO" query-param="CO_TIPODOCUSOPO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="CO_FECHRESODECR" query-param="CO_FECHRESODECR"/>
			<with-param name="CO_DIAS" query-param="CO_DIAS"/>
			<with-param name="CO_VALOR" query-param="CO_VALOR"/>
			<with-param name="CO_DIAS_PENDIENTES" query-param="CO_DIAS_PENDIENTES"/>
			<with-param name="CO_DIAS_ACUMULADOS" query-param="CO_DIAS_ACUMULADOS"/>
			<with-param name="CO_FECHDESDE" query-param="CO_FECHDESDE"/>
			<with-param name="CO_FECHHASTA" query-param="CO_FECHHASTA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CP_CODIGOPERSONA" query-param="CP_CODIGOPERSONA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatcompensatorios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_COMPENSATORIO WHERE NAT_COMPENSATORIO.COMPANIA= :KEY_COMPANIA AND NAT_COMPENSATORIO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_COMPENSATORIO.SUCURSAL= :KEY_SUCURSAL AND NAT_COMPENSATORIO.CO_TIPODOCUSOPO= :KEY_CO_TIPODOCUSOPO AND NAT_COMPENSATORIO.CO_NUME= :KEY_CO_NUME AND NAT_COMPENSATORIO.CO_FECHRESODECR= TO_DATE(:KEY_CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')  AND NAT_COMPENSATORIO.CP_CODIGOPERSONA= :KEY_CP_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CO_TIPODOCUSOPO" sqlType="STRING"/>
		<param name="KEY_CO_NUME" sqlType="STRING"/>
		<param name="KEY_CO_FECHRESODECR" sqlType="STRING"/>
		<param name="KEY_CP_CODIGOPERSONA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="natcompensatorios">
		<call-query href="deleteNatcompensatorios">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CO_TIPODOCUSOPO" query-param="KEY_CO_TIPODOCUSOPO"/>
			<with-param name="KEY_CO_NUME" query-param="KEY_CO_NUME"/>
			<with-param name="KEY_CO_FECHRESODECR" query-param="KEY_CO_FECHRESODECR"/>
			<with-param name="KEY_CP_CODIGOPERSONA" query-param="KEY_CP_CODIGOPERSONA"/>

		</call-query>
	</resource>
	<query id="getNatcompensatoriosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_TIPO_ACTO_ADTIVO.TIPOACTOADTIVO, NAT_TIPO_ACTO_ADTIVO.CODIGO, NAT_COMPENSATORIO.CO_NUME,(TO_CHAR(NAT_COMPENSATORIO.CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) CO_FECHRESODECR, NAT_COMPENSATORIO.CO_DIAS, NAT_COMPENSATORIO.CO_VALOR, NAT_COMPENSATORIO.CO_DIAS_PENDIENTES, NAT_COMPENSATORIO.CO_DIAS_ACUMULADOS,(TO_CHAR(NAT_COMPENSATORIO.CO_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) CO_FECHDESDE,(TO_CHAR(NAT_COMPENSATORIO.CO_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) CO_FECHHASTA, NAT_COMPENSATORIO.DP_NUMEDOCU, NAT_COMPENSATORIO.COMPANIA, NAT_COMPENSATORIO.SUCURSAL, NAT_COMPENSATORIO.CP_CODIGOPERSONA, NAT_COMPENSATORIO.CO_TIPODOCUSOPO  FROM NAT_COMPENSATORIO LEFT JOIN NAT_TIPO_ACTO_ADTIVO ON NAT_COMPENSATORIO.CO_TIPODOCUSOPO = NAT_TIPO_ACTO_ADTIVO.CODIGO WHERE NAT_COMPENSATORIO.COMPANIA = :COMPANIA AND NAT_COMPENSATORIO.DP_NUMEDOCU = :DP_NUMEDOCU ORDER BY NAT_COMPENSATORIO.CO_FECHHASTA DESC) WHERE (CASE WHEN TIPOACTOADTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTOADTIVO) END)  LIKE UPPER( '%' || :TIPOACTOADTIVO || '%')  AND (CASE WHEN CO_NUME IS NULL THEN ' ' ELSE UPPER(CO_NUME) END)  LIKE UPPER( '%' || :CO_NUME || '%')  AND (CASE WHEN CO_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(CO_FECHRESODECR) END)  LIKE UPPER( '%' || :CO_FECHRESODECR || '%')  AND (CASE WHEN CO_DIAS IS NULL THEN ' ' ELSE UPPER(CO_DIAS) END)  LIKE UPPER(:CO_DIAS || '%')  AND (CASE WHEN CO_VALOR IS NULL THEN ' ' ELSE UPPER(CO_VALOR) END)  LIKE UPPER(:CO_VALOR || '%')  AND (CASE WHEN CO_DIAS_PENDIENTES IS NULL THEN ' ' ELSE UPPER(CO_DIAS_PENDIENTES) END)  LIKE UPPER(:CO_DIAS_PENDIENTES || '%')  AND (CASE WHEN CO_DIAS_ACUMULADOS IS NULL THEN ' ' ELSE UPPER(CO_DIAS_ACUMULADOS) END)  LIKE UPPER(:CO_DIAS_ACUMULADOS || '%')  AND (CASE WHEN CO_FECHDESDE IS NULL THEN ' ' ELSE UPPER(CO_FECHDESDE) END)  LIKE UPPER( '%' || :CO_FECHDESDE || '%')  AND (CASE WHEN CO_FECHHASTA IS NULL THEN ' ' ELSE UPPER(CO_FECHHASTA) END)  LIKE UPPER( '%' || :CO_FECHHASTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOACTOADTIVO":"$TIPOACTOADTIVO","CODIGO":"$CODIGO(type:integer)","CO_NUME":"$CO_NUME","CO_FECHRESODECR":"$CO_FECHRESODECR","CO_DIAS":"$CO_DIAS","CO_VALOR":"$CO_VALOR","CO_DIAS_PENDIENTES":"$CO_DIAS_PENDIENTES(type:integer)","CO_DIAS_ACUMULADOS":"$CO_DIAS_ACUMULADOS(type:integer)","CO_FECHDESDE":"$CO_FECHDESDE","CO_FECHHASTA":"$CO_FECHHASTA","DP_NUMEDOCU":"$DP_NUMEDOCU","COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","CP_CODIGOPERSONA":"$CP_CODIGOPERSONA(type:integer)","CO_TIPODOCUSOPO":"$CO_TIPODOCUSOPO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="TIPOACTOADTIVO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param name="CO_FECHRESODECR" sqlType="STRING"/>
		<param name="CO_DIAS" sqlType="STRING"/>
		<param name="CO_VALOR" sqlType="STRING"/>
		<param name="CO_DIAS_PENDIENTES" sqlType="STRING"/>
		<param name="CO_DIAS_ACUMULADOS" sqlType="STRING"/>
		<param name="CO_FECHDESDE" sqlType="STRING"/>
		<param name="CO_FECHHASTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natcompensatorios">
		<call-query href="getNatcompensatoriosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="TIPOACTOADTIVO" query-param="TIPOACTOADTIVO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="CO_FECHRESODECR" query-param="CO_FECHRESODECR"/>
			<with-param name="CO_DIAS" query-param="CO_DIAS"/>
			<with-param name="CO_VALOR" query-param="CO_VALOR"/>
			<with-param name="CO_DIAS_PENDIENTES" query-param="CO_DIAS_PENDIENTES"/>
			<with-param name="CO_DIAS_ACUMULADOS" query-param="CO_DIAS_ACUMULADOS"/>
			<with-param name="CO_FECHDESDE" query-param="CO_FECHDESDE"/>
			<with-param name="CO_FECHHASTA" query-param="CO_FECHHASTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatcompensatoriosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_TIPO_ACTO_ADTIVO.TIPOACTOADTIVO, NAT_TIPO_ACTO_ADTIVO.CODIGO, NAT_COMPENSATORIO.CO_NUME,(TO_CHAR(NAT_COMPENSATORIO.CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) CO_FECHRESODECR, NAT_COMPENSATORIO.CO_DIAS, NAT_COMPENSATORIO.CO_VALOR, NAT_COMPENSATORIO.CO_DIAS_PENDIENTES, NAT_COMPENSATORIO.CO_DIAS_ACUMULADOS,(TO_CHAR(NAT_COMPENSATORIO.CO_FECHDESDE,'DD/MM/YYYY HH24:MI:SS')) CO_FECHDESDE,(TO_CHAR(NAT_COMPENSATORIO.CO_FECHHASTA,'DD/MM/YYYY HH24:MI:SS')) CO_FECHHASTA, NAT_COMPENSATORIO.DP_NUMEDOCU, NAT_COMPENSATORIO.COMPANIA, NAT_COMPENSATORIO.SUCURSAL, NAT_COMPENSATORIO.CP_CODIGOPERSONA, NAT_COMPENSATORIO.CO_TIPODOCUSOPO  FROM NAT_COMPENSATORIO LEFT JOIN NAT_TIPO_ACTO_ADTIVO ON NAT_COMPENSATORIO.CO_TIPODOCUSOPO = NAT_TIPO_ACTO_ADTIVO.CODIGO WHERE NAT_COMPENSATORIO.COMPANIA = :COMPANIA AND NAT_COMPENSATORIO.DP_NUMEDOCU = :DP_NUMEDOCU ORDER BY NAT_COMPENSATORIO.CO_FECHHASTA DESC) WHERE (CASE WHEN TIPOACTOADTIVO IS NULL THEN ' ' ELSE UPPER(TIPOACTOADTIVO) END)  LIKE UPPER( '%' || :TIPOACTOADTIVO || '%')  AND (CASE WHEN CO_NUME IS NULL THEN ' ' ELSE UPPER(CO_NUME) END)  LIKE UPPER( '%' || :CO_NUME || '%')  AND (CASE WHEN CO_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(CO_FECHRESODECR) END)  LIKE UPPER( '%' || :CO_FECHRESODECR || '%')  AND (CASE WHEN CO_DIAS IS NULL THEN ' ' ELSE UPPER(CO_DIAS) END)  LIKE UPPER(:CO_DIAS || '%')  AND (CASE WHEN CO_VALOR IS NULL THEN ' ' ELSE UPPER(CO_VALOR) END)  LIKE UPPER(:CO_VALOR || '%')  AND (CASE WHEN CO_DIAS_PENDIENTES IS NULL THEN ' ' ELSE UPPER(CO_DIAS_PENDIENTES) END)  LIKE UPPER(:CO_DIAS_PENDIENTES || '%')  AND (CASE WHEN CO_DIAS_ACUMULADOS IS NULL THEN ' ' ELSE UPPER(CO_DIAS_ACUMULADOS) END)  LIKE UPPER(:CO_DIAS_ACUMULADOS || '%')  AND (CASE WHEN CO_FECHDESDE IS NULL THEN ' ' ELSE UPPER(CO_FECHDESDE) END)  LIKE UPPER( '%' || :CO_FECHDESDE || '%')  AND (CASE WHEN CO_FECHHASTA IS NULL THEN ' ' ELSE UPPER(CO_FECHHASTA) END)  LIKE UPPER( '%' || :CO_FECHHASTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="TIPOACTOADTIVO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param name="CO_FECHRESODECR" sqlType="STRING"/>
		<param name="CO_DIAS" sqlType="STRING"/>
		<param name="CO_VALOR" sqlType="STRING"/>
		<param name="CO_DIAS_PENDIENTES" sqlType="STRING"/>
		<param name="CO_DIAS_ACUMULADOS" sqlType="STRING"/>
		<param name="CO_FECHDESDE" sqlType="STRING"/>
		<param name="CO_FECHHASTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natcompensatorios/numero">
		<call-query href="getNatcompensatoriosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="TIPOACTOADTIVO" query-param="TIPOACTOADTIVO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="CO_FECHRESODECR" query-param="CO_FECHRESODECR"/>
			<with-param name="CO_DIAS" query-param="CO_DIAS"/>
			<with-param name="CO_VALOR" query-param="CO_VALOR"/>
			<with-param name="CO_DIAS_PENDIENTES" query-param="CO_DIAS_PENDIENTES"/>
			<with-param name="CO_DIAS_ACUMULADOS" query-param="CO_DIAS_ACUMULADOS"/>
			<with-param name="CO_FECHDESDE" query-param="CO_FECHDESDE"/>
			<with-param name="CO_FECHHASTA" query-param="CO_FECHHASTA"/>

		</call-query>
	</resource>
	<query id="updateNatcompensatorios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_COMPENSATORIO SET CO_TIPODOCUSOPO=:CO_TIPODOCUSOPO, CO_NUME=:CO_NUME, CO_FECHRESODECR=TO_DATE(:CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), CO_DIAS=:CO_DIAS, CO_VALOR=:CO_VALOR, CO_DIAS_PENDIENTES=:CO_DIAS_PENDIENTES, CO_DIAS_ACUMULADOS=:CO_DIAS_ACUMULADOS, CO_FECHDESDE=TO_DATE(:CO_FECHDESDE,'DD/MM/YYYY HH24:MI:SS'), CO_FECHHASTA=TO_DATE(:CO_FECHHASTA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_COMPENSATORIO.COMPANIA= :KEY_COMPANIA AND NAT_COMPENSATORIO.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_COMPENSATORIO.SUCURSAL= :KEY_SUCURSAL AND NAT_COMPENSATORIO.CO_TIPODOCUSOPO= :KEY_CO_TIPODOCUSOPO AND NAT_COMPENSATORIO.CO_NUME= :KEY_CO_NUME AND NAT_COMPENSATORIO.CO_FECHRESODECR= TO_DATE(:KEY_CO_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')  AND NAT_COMPENSATORIO.CP_CODIGOPERSONA= :KEY_CP_CODIGOPERSONA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CO_TIPODOCUSOPO" sqlType="STRING"/>
		<param name="CO_NUME" sqlType="STRING"/>
		<param name="CO_FECHRESODECR" sqlType="STRING"/>
		<param name="CO_DIAS" sqlType="STRING"/>
		<param name="CO_VALOR" sqlType="STRING"/>
		<param name="CO_DIAS_PENDIENTES" sqlType="STRING"/>
		<param name="CO_DIAS_ACUMULADOS" sqlType="STRING"/>
		<param name="CO_FECHDESDE" sqlType="STRING"/>
		<param name="CO_FECHHASTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CO_TIPODOCUSOPO" sqlType="STRING"/>
		<param name="KEY_CO_NUME" sqlType="STRING"/>
		<param name="KEY_CO_FECHRESODECR" sqlType="STRING"/>
		<param name="KEY_CP_CODIGOPERSONA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natcompensatorios">
		<call-query href="updateNatcompensatorios">
			<with-param name="CO_TIPODOCUSOPO" query-param="CO_TIPODOCUSOPO"/>
			<with-param name="CO_NUME" query-param="CO_NUME"/>
			<with-param name="CO_FECHRESODECR" query-param="CO_FECHRESODECR"/>
			<with-param name="CO_DIAS" query-param="CO_DIAS"/>
			<with-param name="CO_VALOR" query-param="CO_VALOR"/>
			<with-param name="CO_DIAS_PENDIENTES" query-param="CO_DIAS_PENDIENTES"/>
			<with-param name="CO_DIAS_ACUMULADOS" query-param="CO_DIAS_ACUMULADOS"/>
			<with-param name="CO_FECHDESDE" query-param="CO_FECHDESDE"/>
			<with-param name="CO_FECHHASTA" query-param="CO_FECHHASTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CO_TIPODOCUSOPO" query-param="KEY_CO_TIPODOCUSOPO"/>
			<with-param name="KEY_CO_NUME" query-param="KEY_CO_NUME"/>
			<with-param name="KEY_CO_FECHRESODECR" query-param="KEY_CO_FECHRESODECR"/>
			<with-param name="KEY_CP_CODIGOPERSONA" query-param="KEY_CP_CODIGOPERSONA"/>

		</call-query>
	</resource>

</data>