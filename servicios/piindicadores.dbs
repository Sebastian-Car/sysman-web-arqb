<data name="piindicadores" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPiindicadoresPorCompaniaYVigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PI_INDICADOR.CODIGO COD_INDICADOR, PI_INDICADOR.NOMBRE  FROM PI_INDICADOR WHERE PI_INDICADOR.COMPANIA = :COMPANIA AND PI_INDICADOR.VIGENCIA_INICIAL = :VIGENCIA AND PI_INDICADOR.ID_PLAN = :ID_PLAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_INDICADOR":"$COD_INDICADOR","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piindicadores/porcompaniayvigencia">
		<call-query href="getPiindicadoresPorCompaniaYVigenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>

		</call-query>
	</resource>
	<query id="getPiindicadoresPagPoridplancodynombQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PI_INDICADOR.ID_PLAN,PI_INDICADOR.CODIGO, PI_INDICADOR.NOMBRE  FROM PI_INDICADOR WHERE PI_INDICADOR.COMPANIA = :COMPANIA AND PI_INDICADOR.VIGENCIA_INICIAL = :ANIO AND LENGTH(ID_PLAN) = :DIGMETAPROD) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN":"$ID_PLAN","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="DIGMETAPROD" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piindicadores/poridplancodynomb/pag">
		<call-query href="getPiindicadoresPagPoridplancodynombQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="DIGMETAPROD" query-param="DIGMETAPROD"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPiindicadoresNumPoridplancodynombQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PI_INDICADOR.ID_PLAN,PI_INDICADOR.CODIGO, PI_INDICADOR.NOMBRE  FROM PI_INDICADOR WHERE PI_INDICADOR.COMPANIA = :COMPANIA AND PI_INDICADOR.VIGENCIA_INICIAL = :ANIO AND LENGTH(ID_PLAN) = :DIGMETAPROD) WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="DIGMETAPROD" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piindicadores/poridplancodynomb/num">
		<call-query href="getPiindicadoresNumPoridplancodynombQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="DIGMETAPROD" query-param="DIGMETAPROD"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertPiindicadores" keyColumns="COMPANIA,VIGENCIA_INICIAL,ID_PLAN,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PI_INDICADOR (COMPANIA, VIGENCIA_INICIAL, ID_PLAN, CODIGO, NOMBRE, LB, TIPO_META_INDICADOR, DESCRIPCION_INDICADOR_MEDIDA, UNIDAD_MEDIDA, PARTICIPACION, CREATED_BY, DATE_CREATED, REFERENTE, META_CUATRENIO, DESCRIPCION_META, SECTOR, ODS) VALUES (:COMPANIA, :VIGENCIA_INICIAL, :ID_PLAN, :CODIGO, :NOMBRE, :LB, :TIPO_META_INDICADOR, :DESCRIPCION_INDICADOR_MEDIDA, :UNIDAD_MEDIDA, :PARTICIPACION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :REFERENTE, :META_CUATRENIO, :DESCRIPCION_META, :SECTOR, :ODS)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="LB" sqlType="STRING"/>
		<param name="TIPO_META_INDICADOR" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_INDICADOR_MEDIDA" sqlType="STRING"/>
		<param name="UNIDAD_MEDIDA" sqlType="STRING"/>
		<param defaultValue="0" name="PARTICIPACION" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="REFERENTE" sqlType="STRING"/>
		<param defaultValue="0" name="META_CUATRENIO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_META" sqlType="STRING"/>
		<param defaultValue="" name="SECTOR" sqlType="STRING"/>
		<param defaultValue="" name="ODS" sqlType="STRING"/>

	</query>
	<resource method="POST" path="piindicadores">
		<call-query href="insertPiindicadores">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="LB" query-param="LB"/>
			<with-param name="TIPO_META_INDICADOR" query-param="TIPO_META_INDICADOR"/>
			<with-param name="DESCRIPCION_INDICADOR_MEDIDA" query-param="DESCRIPCION_INDICADOR_MEDIDA"/>
			<with-param name="UNIDAD_MEDIDA" query-param="UNIDAD_MEDIDA"/>
			<with-param name="PARTICIPACION" query-param="PARTICIPACION"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="REFERENTE" query-param="REFERENTE"/>
			<with-param name="META_CUATRENIO" query-param="META_CUATRENIO"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="ODS" query-param="ODS"/>

		</call-query>
	</resource>
	<query id="deletePiindicadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PI_INDICADOR WHERE PI_INDICADOR.COMPANIA= :KEY_COMPANIA AND PI_INDICADOR.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_INDICADOR.ID_PLAN= :KEY_ID_PLAN AND PI_INDICADOR.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="INTEGER"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="piindicadores">
		<call-query href="deletePiindicadores">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getPiindicadoresPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PI_INDICADOR.ID_PLAN, BP_PLAN_INDICATIVO.DESCRIPCION, PI_INDICADOR.CODIGO, PI_INDICADOR.NOMBRE, PI_INDICADOR.LB, PI_INDICADOR.REFERENTE, PI_INDICADOR.META_CUATRENIO, PI_INDICADOR.UNIDAD_MEDIDA, PI_INDICADOR.TIPO_META_INDICADOR, ( CASE WHEN LENGTH(ID_PLAN) = :GETM_PRO THEN 'SubPrograma' ELSE CASE WHEN LENGTH(ID_PLAN) = :GETM_RES THEN 'Programa' ELSE '' END END ) CLASIFICACION, PI_INDICADOR.PARTICIPACION, PI_INDICADOR.DESCRIPCION_META, PI_INDICADOR.SECTOR, PI_INDICADOR.ODS , PI_INDICADOR.COMPANIA, PI_INDICADOR.VIGENCIA_INICIAL FROM PI_INDICADOR INNER JOIN BP_PLAN_INDICATIVO ON PI_INDICADOR.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND PI_INDICADOR.ID_PLAN = BP_PLAN_INDICATIVO.ID WHERE PI_INDICADOR.COMPANIA = :COMPANIA AND PI_INDICADOR.VIGENCIA_INICIAL = :VIGENCIA ORDER BY PI_INDICADOR.ID_PLAN) INI WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END) LIKE UPPER(CONCAT(:ID_PLAN, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN LB IS NULL THEN ' ' ELSE UPPER(LB) END) LIKE UPPER(CONCAT(:LB, '%')) AND (CASE WHEN REFERENTE IS NULL THEN ' ' ELSE UPPER(REFERENTE) END) LIKE UPPER(CONCAT(:REFERENTE, '%')) AND (CASE WHEN META_CUATRENIO IS NULL THEN ' ' ELSE UPPER(META_CUATRENIO) END) LIKE UPPER(CONCAT(:META_CUATRENIO, '%')) AND (CASE WHEN UNIDAD_MEDIDA IS NULL THEN ' ' ELSE UPPER(UNIDAD_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:UNIDAD_MEDIDA), '%')) AND (CASE WHEN TIPO_META_INDICADOR IS NULL THEN ' ' ELSE UPPER(TIPO_META_INDICADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_META_INDICADOR), '%')) AND (CASE WHEN CLASIFICACION IS NULL THEN ' ' ELSE UPPER(CLASIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASIFICACION), '%')) AND (CASE WHEN PARTICIPACION IS NULL THEN ' ' ELSE UPPER(PARTICIPACION) END) LIKE UPPER(CONCAT(:PARTICIPACION, '%')) AND (CASE WHEN DESCRIPCION_META IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_META) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_META), '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(:SECTOR, '%')) AND (CASE WHEN ODS IS NULL THEN ' ' ELSE UPPER(ODS) END) LIKE UPPER(CONCAT(CONCAT('%',:ODS), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PLAN":"$ID_PLAN","DESCRIPCION":"$DESCRIPCION","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","LB":"$LB","REFERENTE":"$REFERENTE","META_CUATRENIO":"$META_CUATRENIO","UNIDAD_MEDIDA":"$UNIDAD_MEDIDA","TIPO_META_INDICADOR":"$TIPO_META_INDICADOR","CLASIFICACION":"$CLASIFICACION","PARTICIPACION":"$PARTICIPACION","DESCRIPCION_META":"$DESCRIPCION_META","SECTOR":"$SECTOR","ODS":"$ODS","COMPANIA":"$COMPANIA","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)"}]}}		</result>
		<param name="GETM_PRO" sqlType="STRING"/>
		<param name="GETM_RES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="LB" sqlType="STRING"/>
		<param name="REFERENTE" sqlType="STRING"/>
		<param name="META_CUATRENIO" sqlType="STRING"/>
		<param name="UNIDAD_MEDIDA" sqlType="STRING"/>
		<param name="TIPO_META_INDICADOR" sqlType="STRING"/>
		<param name="CLASIFICACION" sqlType="STRING"/>
		<param name="PARTICIPACION" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="ODS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piindicadores">
		<call-query href="getPiindicadoresPaginaQuery">
			<with-param name="GETM_PRO" query-param="GETM_PRO"/>
			<with-param name="GETM_RES" query-param="GETM_RES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="LB" query-param="LB"/>
			<with-param name="REFERENTE" query-param="REFERENTE"/>
			<with-param name="META_CUATRENIO" query-param="META_CUATRENIO"/>
			<with-param name="UNIDAD_MEDIDA" query-param="UNIDAD_MEDIDA"/>
			<with-param name="TIPO_META_INDICADOR" query-param="TIPO_META_INDICADOR"/>
			<with-param name="CLASIFICACION" query-param="CLASIFICACION"/>
			<with-param name="PARTICIPACION" query-param="PARTICIPACION"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="ODS" query-param="ODS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPiindicadoresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PI_INDICADOR.ID_PLAN, BP_PLAN_INDICATIVO.DESCRIPCION, PI_INDICADOR.CODIGO, PI_INDICADOR.NOMBRE, PI_INDICADOR.LB, PI_INDICADOR.REFERENTE, PI_INDICADOR.META_CUATRENIO, PI_INDICADOR.UNIDAD_MEDIDA, PI_INDICADOR.TIPO_META_INDICADOR, ( CASE WHEN LENGTH(ID_PLAN) = :GETM_PRO THEN 'SubPrograma' ELSE CASE WHEN LENGTH(ID_PLAN) = :GETM_RES THEN 'Programa' ELSE '' END END ) CLASIFICACION, PI_INDICADOR.PARTICIPACION, PI_INDICADOR.DESCRIPCION_META, PI_INDICADOR.SECTOR, PI_INDICADOR.ODS , PI_INDICADOR.COMPANIA, PI_INDICADOR.VIGENCIA_INICIAL FROM PI_INDICADOR INNER JOIN BP_PLAN_INDICATIVO ON PI_INDICADOR.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND PI_INDICADOR.ID_PLAN = BP_PLAN_INDICATIVO.ID WHERE PI_INDICADOR.COMPANIA = :COMPANIA AND PI_INDICADOR.VIGENCIA_INICIAL = :VIGENCIA ORDER BY PI_INDICADOR.ID_PLAN) INI WHERE (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END) LIKE UPPER(CONCAT(:ID_PLAN, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN LB IS NULL THEN ' ' ELSE UPPER(LB) END) LIKE UPPER(CONCAT(:LB, '%')) AND (CASE WHEN REFERENTE IS NULL THEN ' ' ELSE UPPER(REFERENTE) END) LIKE UPPER(CONCAT(:REFERENTE, '%')) AND (CASE WHEN META_CUATRENIO IS NULL THEN ' ' ELSE UPPER(META_CUATRENIO) END) LIKE UPPER(CONCAT(:META_CUATRENIO, '%')) AND (CASE WHEN UNIDAD_MEDIDA IS NULL THEN ' ' ELSE UPPER(UNIDAD_MEDIDA) END) LIKE UPPER(CONCAT(CONCAT('%',:UNIDAD_MEDIDA), '%')) AND (CASE WHEN TIPO_META_INDICADOR IS NULL THEN ' ' ELSE UPPER(TIPO_META_INDICADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_META_INDICADOR), '%')) AND (CASE WHEN CLASIFICACION IS NULL THEN ' ' ELSE UPPER(CLASIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASIFICACION), '%')) AND (CASE WHEN PARTICIPACION IS NULL THEN ' ' ELSE UPPER(PARTICIPACION) END) LIKE UPPER(CONCAT(:PARTICIPACION, '%')) AND (CASE WHEN DESCRIPCION_META IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_META) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_META), '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(:SECTOR, '%')) AND (CASE WHEN ODS IS NULL THEN ' ' ELSE UPPER(ODS) END) LIKE UPPER(CONCAT(CONCAT('%',:ODS), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="GETM_PRO" sqlType="STRING"/>
		<param name="GETM_RES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="LB" sqlType="STRING"/>
		<param name="REFERENTE" sqlType="STRING"/>
		<param name="META_CUATRENIO" sqlType="STRING"/>
		<param name="UNIDAD_MEDIDA" sqlType="STRING"/>
		<param name="TIPO_META_INDICADOR" sqlType="STRING"/>
		<param name="CLASIFICACION" sqlType="STRING"/>
		<param name="PARTICIPACION" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="ODS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piindicadores/numero">
		<call-query href="getPiindicadoresNumeroQuery">
			<with-param name="GETM_PRO" query-param="GETM_PRO"/>
			<with-param name="GETM_RES" query-param="GETM_RES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="LB" query-param="LB"/>
			<with-param name="REFERENTE" query-param="REFERENTE"/>
			<with-param name="META_CUATRENIO" query-param="META_CUATRENIO"/>
			<with-param name="UNIDAD_MEDIDA" query-param="UNIDAD_MEDIDA"/>
			<with-param name="TIPO_META_INDICADOR" query-param="TIPO_META_INDICADOR"/>
			<with-param name="CLASIFICACION" query-param="CLASIFICACION"/>
			<with-param name="PARTICIPACION" query-param="PARTICIPACION"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="ODS" query-param="ODS"/>

		</call-query>
	</resource>
	<query id="updatePiindicadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_INDICADOR SET ID_PLAN=:ID_PLAN, CODIGO=:CODIGO, NOMBRE=:NOMBRE, LB=:LB, REFERENTE=:REFERENTE, META_CUATRENIO=:META_CUATRENIO, UNIDAD_MEDIDA=:UNIDAD_MEDIDA, TIPO_META_INDICADOR=:TIPO_META_INDICADOR, PARTICIPACION=:PARTICIPACION, DESCRIPCION_META=:DESCRIPCION_META, SECTOR=:SECTOR, ODS=:ODS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_INDICADOR.COMPANIA= :KEY_COMPANIA AND PI_INDICADOR.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_INDICADOR.ID_PLAN= :KEY_ID_PLAN AND PI_INDICADOR.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="LB" sqlType="STRING"/>
		<param name="REFERENTE" sqlType="STRING"/>
		<param name="META_CUATRENIO" sqlType="STRING"/>
		<param name="UNIDAD_MEDIDA" sqlType="STRING"/>
		<param name="TIPO_META_INDICADOR" sqlType="STRING"/>
		<param name="PARTICIPACION" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="ODS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="piindicadores">
		<call-query href="updatePiindicadores">
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="LB" query-param="LB"/>
			<with-param name="REFERENTE" query-param="REFERENTE"/>
			<with-param name="META_CUATRENIO" query-param="META_CUATRENIO"/>
			<with-param name="UNIDAD_MEDIDA" query-param="UNIDAD_MEDIDA"/>
			<with-param name="TIPO_META_INDICADOR" query-param="TIPO_META_INDICADOR"/>
			<with-param name="PARTICIPACION" query-param="PARTICIPACION"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="ODS" query-param="ODS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>