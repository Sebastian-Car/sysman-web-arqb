<data name="sfdetallecuotaabono" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfdetallecuotaabonoTotalesDetallecuoQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(SF_DETALLE_CUOTAABONO.VALOR_BASE) BASE, SUM(SF_DETALLE_CUOTAABONO.VALOR_IVA) IVA, SUM(SF_DETALLE_CUOTAABONO.VALOR_RETE) RETE, SUM(SF_DETALLE_CUOTAABONO.VALOR_DESCUENTO) DESCUENTO, SUM(SF_DETALLE_CUOTAABONO.VALOR_ICA) ICA, SUM( SF_DETALLE_CUOTAABONO.TOTAL_CUOTA) TOTALES FROM SF_DETALLE_CUOTAABONO WHERE COMPANIA = :COMPANIA AND TIPO_ABONO = :TIPO AND CODIGO_ABONO = :CODIGO AND CUOTA = :CUOTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BASE":"$BASE","IVA":"$IVA","RETE":"$RETE","DESCUENTO":"$DESCUENTO","ICA":"$ICA","TOTALES":"$TOTALES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecuotaabono/totalesdetallecuo">
		<call-query href="getSfdetallecuotaabonoTotalesDetallecuoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>

		</call-query>
	</resource>
	<query id="getSfdetallecuotaabonoPagGrillaDetallecuoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CUOTA, ANO, CONCEPTO, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_DESCUENTO, VALOR_ICA, TOTAL_CUOTA  FROM SF_DETALLE_CUOTAABONO WHERE COMPANIA = :COMPANIA AND TIPO_ABONO = :TIPO AND CODIGO_ABONO = :CODIGO AND CUOTA = :CUOTA) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END)  LIKE UPPER(:VALOR_BASE || '%')  AND (CASE WHEN VALOR_IVA IS NULL THEN ' ' ELSE UPPER(VALOR_IVA) END)  LIKE UPPER(:VALOR_IVA || '%')  AND (CASE WHEN VALOR_RETE IS NULL THEN ' ' ELSE UPPER(VALOR_RETE) END)  LIKE UPPER(:VALOR_RETE || '%')  AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END)  LIKE UPPER(:VALOR_DESCUENTO || '%')  AND (CASE WHEN VALOR_ICA IS NULL THEN ' ' ELSE UPPER(VALOR_ICA) END)  LIKE UPPER(:VALOR_ICA || '%')  AND (CASE WHEN TOTAL_CUOTA IS NULL THEN ' ' ELSE UPPER(TOTAL_CUOTA) END)  LIKE UPPER(:TOTAL_CUOTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUOTA":"$CUOTA(type:integer)","ANO":"$ANO(type:integer)","CONCEPTO":"$CONCEPTO","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_ICA":"$VALOR_ICA","TOTAL_CUOTA":"$TOTAL_CUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="TOTAL_CUOTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfdetallecuotaabono/grilladetallecuo/pag">
		<call-query href="getSfdetallecuotaabonoPagGrillaDetallecuoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="VALOR_IVA" query-param="VALOR_IVA"/>
			<with-param name="VALOR_RETE" query-param="VALOR_RETE"/>
			<with-param name="VALOR_DESCUENTO" query-param="VALOR_DESCUENTO"/>
			<with-param name="VALOR_ICA" query-param="VALOR_ICA"/>
			<with-param name="TOTAL_CUOTA" query-param="TOTAL_CUOTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecuotaabonoNumGrillaDetallecuoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CUOTA, ANO, CONCEPTO, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_DESCUENTO, VALOR_ICA, TOTAL_CUOTA  FROM SF_DETALLE_CUOTAABONO WHERE COMPANIA = :COMPANIA AND TIPO_ABONO = :TIPO AND CODIGO_ABONO = :CODIGO AND CUOTA = :CUOTA) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END)  LIKE UPPER(:VALOR_BASE || '%')  AND (CASE WHEN VALOR_IVA IS NULL THEN ' ' ELSE UPPER(VALOR_IVA) END)  LIKE UPPER(:VALOR_IVA || '%')  AND (CASE WHEN VALOR_RETE IS NULL THEN ' ' ELSE UPPER(VALOR_RETE) END)  LIKE UPPER(:VALOR_RETE || '%')  AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END)  LIKE UPPER(:VALOR_DESCUENTO || '%')  AND (CASE WHEN VALOR_ICA IS NULL THEN ' ' ELSE UPPER(VALOR_ICA) END)  LIKE UPPER(:VALOR_ICA || '%')  AND (CASE WHEN TOTAL_CUOTA IS NULL THEN ' ' ELSE UPPER(TOTAL_CUOTA) END)  LIKE UPPER(:TOTAL_CUOTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="TOTAL_CUOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecuotaabono/grilladetallecuo/num">
		<call-query href="getSfdetallecuotaabonoNumGrillaDetallecuoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="VALOR_IVA" query-param="VALOR_IVA"/>
			<with-param name="VALOR_RETE" query-param="VALOR_RETE"/>
			<with-param name="VALOR_DESCUENTO" query-param="VALOR_DESCUENTO"/>
			<with-param name="VALOR_ICA" query-param="VALOR_ICA"/>
			<with-param name="TOTAL_CUOTA" query-param="TOTAL_CUOTA"/>

		</call-query>
	</resource>

</data>