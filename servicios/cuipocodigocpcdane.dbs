	<query id="getCuipocodigocpcdanePagClasificadorhijoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT T.CODIGO, T.NOMBRE FROM TIPOCLASIFICADORESHIJO TH INNER JOIN TIPOCLASIFICADOR T ON TH.COMPANIA = T.COMPANIA AND TH.ANO = T.ANO AND TH.IDHIJO = T.ID WHERE TH.COMPANIA = :COMPANIA AND TH.ANO = :ANO AND TH.IDPADRE = :TIPOCLASIFICADOR) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
