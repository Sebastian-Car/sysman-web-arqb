<data name="diabloqueo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDiabloqueoGetestadomescontableQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(0) ESTADO FROM DIA_BLOQUEO WHERE DIA_BLOQUEO.COMPANIA = :COMPANIA AND DIA_BLOQUEO.ANO = :ANIO AND DIA_BLOQUEO.MES = :MES AND DIA_BLOQUEO.DIA = :DIA AND APLICACION = :APLICACION AND PROCESO = :PROCESO AND DIA_BLOQUEO.ESTADO IN('A')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DIA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="diabloqueo/getestadomescontable">
		<call-query href="getDiabloqueoGetestadomescontableQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DIA" query-param="DIA"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="PROCESO" query-param="PROCESO"/>

		</call-query>
	</resource>
	<query id="getDiabloqueoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DIA_BLOQUEO.COMPANIA, DIA_BLOQUEO.ANO, DIA_BLOQUEO.MES, DIA_BLOQUEO.DIA, DIA_BLOQUEO.APLICACION, DIA_BLOQUEO.PROCESO, DIA_BLOQUEO.ESTADO, CASE WHEN DIA_BLOQUEO.ESTADO = 'A' THEN 'ACTIVO' ELSE 'CERRADO' END NOMBREESTADO  FROM DIA_BLOQUEO WHERE DIA_BLOQUEO.COMPANIA = :COMPANIA AND DIA_BLOQUEO.ANO = :ANO AND DIA_BLOQUEO.MES = :MES AND DIA_BLOQUEO.APLICACION = :APLICACION AND DIA_BLOQUEO.PROCESO = :PROCESO) WHERE (CASE WHEN DIA IS NULL THEN ' ' ELSE UPPER(DIA) END)  LIKE UPPER(:DIA || '%')  AND (CASE WHEN NOMBREESTADO IS NULL THEN ' ' ELSE UPPER(NOMBREESTADO) END)  LIKE UPPER( '%' || :NOMBREESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","DIA":"$DIA(type:integer)","APLICACION":"$APLICACION(type:integer)","PROCESO":"$PROCESO(type:integer)","ESTADO":"$ESTADO","NOMBREESTADO":"$NOMBREESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="DIA" sqlType="STRING"/>
		<param name="NOMBREESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="diabloqueo">
		<call-query href="getDiabloqueoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="DIA" query-param="DIA"/>
			<with-param name="NOMBREESTADO" query-param="NOMBREESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDiabloqueoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DIA_BLOQUEO.COMPANIA, DIA_BLOQUEO.ANO, DIA_BLOQUEO.MES, DIA_BLOQUEO.DIA, DIA_BLOQUEO.APLICACION, DIA_BLOQUEO.PROCESO, DIA_BLOQUEO.ESTADO, CASE WHEN DIA_BLOQUEO.ESTADO = 'A' THEN 'ACTIVO' ELSE 'CERRADO' END NOMBREESTADO  FROM DIA_BLOQUEO WHERE DIA_BLOQUEO.COMPANIA = :COMPANIA AND DIA_BLOQUEO.ANO = :ANO AND DIA_BLOQUEO.MES = :MES AND DIA_BLOQUEO.APLICACION = :APLICACION AND DIA_BLOQUEO.PROCESO = :PROCESO) WHERE (CASE WHEN DIA IS NULL THEN ' ' ELSE UPPER(DIA) END)  LIKE UPPER(:DIA || '%')  AND (CASE WHEN NOMBREESTADO IS NULL THEN ' ' ELSE UPPER(NOMBREESTADO) END)  LIKE UPPER( '%' || :NOMBREESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="DIA" sqlType="STRING"/>
		<param name="NOMBREESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="diabloqueo/numero">
		<call-query href="getDiabloqueoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="DIA" query-param="DIA"/>
			<with-param name="NOMBREESTADO" query-param="NOMBREESTADO"/>

		</call-query>
	</resource>
	<query id="updateDiabloqueo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DIA_BLOQUEO SET ESTADO=:ESTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DIA_BLOQUEO.COMPANIA= :KEY_COMPANIA AND DIA_BLOQUEO.ANO= :KEY_ANO AND DIA_BLOQUEO.MES= :KEY_MES AND DIA_BLOQUEO.DIA= :KEY_DIA AND DIA_BLOQUEO.APLICACION= :KEY_APLICACION AND DIA_BLOQUEO.PROCESO= :KEY_PROCESO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_DIA" sqlType="STRING"/>
		<param name="KEY_APLICACION" sqlType="STRING"/>
		<param name="KEY_PROCESO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="diabloqueo">
		<call-query href="updateDiabloqueo">
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_DIA" query-param="KEY_DIA"/>
			<with-param name="KEY_APLICACION" query-param="KEY_APLICACION"/>
			<with-param name="KEY_PROCESO" query-param="KEY_PROCESO"/>

		</call-query>
	</resource>

</data>