<data name="esitemse" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsitemseTodosPorElValorTotalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_ITEMS_E.VALORTOTAL  FROM ES_ITEMS_E WHERE ES_ITEMS_E.COMPANIA = :COMPANIA AND ES_ITEMS_E.COD_ESTUDIO=:COD_ESTUDIO GROUP BY ES_ITEMS_E.VALORTOTAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORTOTAL":"$VALORTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esitemse/todosporelvalortotal">
		<call-query href="getEsitemseTodosPorElValorTotalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="insertEsitemse" keyColumns="COMPANIA,COD_ITEM,COD_ESTUDIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_ITEMS_E (COMPANIA, COD_ITEM, COD_ESTUDIO, TERCERO, DEPENDENCIA, FECHA, DESCRIPCION, RESPONSABLE, PORCIVAGLOBAL, PORCDESCGLOBAL, SUBTOTAL, VALORIVA, VALORDESCUENTO, VALORTOTAL, VACIA, IMPRESA, SELECCIONADA, VALORESTIMADO, RUBROCOMPRAS, OBSERVACIONES, NSOLICITUDDISPON, PLACA, PERIORICIDAD, UNIDAD_TIEMPO, PLAZO, CREATED_BY, DATE_CREATED, CANTIDAD, A_GLOBAL, I_GLOBAL, U_GLOBAL, SUCURSAL_RESPONSABLE) VALUES (:COMPANIA, :COD_ITEM, :COD_ESTUDIO, :TERCERO, :DEPENDENCIA, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, :RESPONSABLE, :PORCIVAGLOBAL, :PORCDESCGLOBAL, :SUBTOTAL, :VALORIVA, :VALORDESCUENTO, :VALORTOTAL, :VACIA, :IMPRESA, :SELECCIONADA, :VALORESTIMADO, :RUBROCOMPRAS, :OBSERVACIONES, :NSOLICITUDDISPON, :PLACA, :PERIORICIDAD, :UNIDAD_TIEMPO, :PLAZO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CANTIDAD, :A_GLOBAL, :I_GLOBAL, :U_GLOBAL, :SUCURSAL_RESPONSABLE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ITEM":"$COD_ITEM","KEY_COD_ESTUDIO":"$COD_ESTUDIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVAGLOBAL" sqlType="STRING"/>
		<param defaultValue="0" name="PORCDESCGLOBAL" sqlType="STRING"/>
		<param defaultValue="0" name="SUBTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORIVA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORDESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VACIA" sqlType="STRING"/>
		<param defaultValue="0" name="IMPRESA" sqlType="STRING"/>
		<param defaultValue="0" name="SELECCIONADA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORESTIMADO" sqlType="STRING"/>
		<param defaultValue="" name="RUBROCOMPRAS" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="NSOLICITUDDISPON" sqlType="STRING"/>
		<param defaultValue="" name="PLACA" sqlType="STRING"/>
		<param defaultValue="" name="PERIORICIDAD" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD_TIEMPO" sqlType="STRING"/>
		<param defaultValue="" name="PLAZO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="A_GLOBAL" sqlType="STRING"/>
		<param defaultValue="0" name="I_GLOBAL" sqlType="STRING"/>
		<param defaultValue="0" name="U_GLOBAL" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esitemse">
		<call-query href="insertEsitemse">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="PORCIVAGLOBAL" query-param="PORCIVAGLOBAL"/>
			<with-param name="PORCDESCGLOBAL" query-param="PORCDESCGLOBAL"/>
			<with-param name="SUBTOTAL" query-param="SUBTOTAL"/>
			<with-param name="VALORIVA" query-param="VALORIVA"/>
			<with-param name="VALORDESCUENTO" query-param="VALORDESCUENTO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="VACIA" query-param="VACIA"/>
			<with-param name="IMPRESA" query-param="IMPRESA"/>
			<with-param name="SELECCIONADA" query-param="SELECCIONADA"/>
			<with-param name="VALORESTIMADO" query-param="VALORESTIMADO"/>
			<with-param name="RUBROCOMPRAS" query-param="RUBROCOMPRAS"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="NSOLICITUDDISPON" query-param="NSOLICITUDDISPON"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="PERIORICIDAD" query-param="PERIORICIDAD"/>
			<with-param name="UNIDAD_TIEMPO" query-param="UNIDAD_TIEMPO"/>
			<with-param name="PLAZO" query-param="PLAZO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="A_GLOBAL" query-param="A_GLOBAL"/>
			<with-param name="I_GLOBAL" query-param="I_GLOBAL"/>
			<with-param name="U_GLOBAL" query-param="U_GLOBAL"/>
			<with-param name="SUCURSAL_RESPONSABLE" query-param="SUCURSAL_RESPONSABLE"/>

		</call-query>
	</resource>
	<query id="deleteEsitemse" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_ITEMS_E WHERE ES_ITEMS_E.COMPANIA= :KEY_COMPANIA AND ES_ITEMS_E.COD_ITEM= :KEY_COD_ITEM AND ES_ITEMS_E.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ITEM" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="esitemse">
		<call-query href="deleteEsitemse">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ITEM" query-param="KEY_COD_ITEM"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsitemsePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_ITEMS_E.COMPANIA, ES_ITEMS_E.COD_ITEM, ES_ITEMS_E.COD_ESTUDIO, TERCERO.NOMBRE, ES_ITEMS_E.DEPENDENCIA, TO_CHAR(ES_ITEMS_E.FECHA, 'DD/MM/YYYY') FECHA  FROM ES_ITEMS_E LEFT JOIN DEPENDENCIA_RESPONSABLE ON ES_ITEMS_E.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND ES_ITEMS_E.DEPENDENCIA = DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND ES_ITEMS_E.RESPONSABLE = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND ES_ITEMS_E.SUCURSAL_RESPONSABLE = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE ES_ITEMS_E.COMPANIA = :COMPANIA AND ES_ITEMS_E.COD_ESTUDIO = :CODESTUDIO) WHERE (CASE WHEN COD_ITEM IS NULL THEN ' ' ELSE UPPER(COD_ITEM) END)  LIKE UPPER(:COD_ITEM || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ITEM":"$COD_ITEM","COD_ESTUDIO":"$COD_ESTUDIO","NOMBRE":"$NOMBRE","DEPENDENCIA":"$DEPENDENCIA","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esitemse">
		<call-query href="getEsitemsePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsitemseNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_ITEMS_E.COMPANIA, ES_ITEMS_E.COD_ITEM, ES_ITEMS_E.COD_ESTUDIO, TERCERO.NOMBRE, ES_ITEMS_E.DEPENDENCIA, TO_CHAR(ES_ITEMS_E.FECHA, 'DD/MM/YYYY') FECHA  FROM ES_ITEMS_E LEFT JOIN DEPENDENCIA_RESPONSABLE ON ES_ITEMS_E.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND ES_ITEMS_E.DEPENDENCIA = DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND ES_ITEMS_E.RESPONSABLE = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND ES_ITEMS_E.SUCURSAL_RESPONSABLE = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLE.SUCURSAL LEFT JOIN TERCERO ON RESPONSABLE.COMPANIA = TERCERO.COMPANIA AND RESPONSABLE.CEDULA = TERCERO.NIT AND RESPONSABLE.SUCURSAL = TERCERO.SUCURSAL WHERE ES_ITEMS_E.COMPANIA = :COMPANIA AND ES_ITEMS_E.COD_ESTUDIO = :CODESTUDIO) WHERE (CASE WHEN COD_ITEM IS NULL THEN ' ' ELSE UPPER(COD_ITEM) END)  LIKE UPPER(:COD_ITEM || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER(:COD_ESTUDIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODESTUDIO" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esitemse/numero">
		<call-query href="getEsitemseNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODESTUDIO" query-param="CODESTUDIO"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getEsitemseRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_ITEMS_E.COMPANIA, ES_ITEMS_E.COD_ITEM, ES_ITEMS_E.COD_ESTUDIO, ES_ITEMS_E.TERCERO, ES_ITEMS_E.DEPENDENCIA,(TO_CHAR(ES_ITEMS_E.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ES_ITEMS_E.DESCRIPCION, ES_ITEMS_E.RESPONSABLE, ES_ITEMS_E.PORCIVAGLOBAL, ES_ITEMS_E.PORCDESCGLOBAL, ES_ITEMS_E.SUBTOTAL, ES_ITEMS_E.VALORIVA, ES_ITEMS_E.VALORDESCUENTO, ES_ITEMS_E.VALORTOTAL, ES_ITEMS_E.VACIA,(CASE ES_ITEMS_E.IMPRESA WHEN 0 THEN 'false' ELSE 'true' END) IMPRESA,(CASE ES_ITEMS_E.SELECCIONADA WHEN 0 THEN 'false' ELSE 'true' END) SELECCIONADA, ES_ITEMS_E.VALORESTIMADO, ES_ITEMS_E.RUBROCOMPRAS, ES_ITEMS_E.OBSERVACIONES, ES_ITEMS_E.NSOLICITUDDISPON, ES_ITEMS_E.PLACA, ES_ITEMS_E.PERIORICIDAD, ES_ITEMS_E.UNIDAD_TIEMPO, ES_ITEMS_E.PLAZO, ES_ITEMS_E.CREATED_BY, ES_ITEMS_E.MODIFIED_BY,(TO_CHAR(ES_ITEMS_E.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(ES_ITEMS_E.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ES_ITEMS_E.CANTIDAD, ES_ITEMS_E.A_GLOBAL, ES_ITEMS_E.I_GLOBAL, ES_ITEMS_E.U_GLOBAL, ES_ITEMS_E.SUCURSAL_RESPONSABLE  FROM ES_ITEMS_E LEFT JOIN DEPENDENCIA_RESPONSABLE ON ES_ITEMS_E.COMPANIA = DEPENDENCIA_RESPONSABLE.COMPANIA AND ES_ITEMS_E.DEPENDENCIA = DEPENDENCIA_RESPONSABLE.DEPENDENCIA AND ES_ITEMS_E.RESPONSABLE = DEPENDENCIA_RESPONSABLE.RESPONSABLE AND ES_ITEMS_E.SUCURSAL_RESPONSABLE = DEPENDENCIA_RESPONSABLE.SUCURSAL LEFT JOIN DEPENDENCIA ON ES_ITEMS_E.COMPANIA = DEPENDENCIA.COMPANIA AND ES_ITEMS_E.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE ES_ITEMS_E.COMPANIA= :KEY_COMPANIA AND ES_ITEMS_E.COD_ITEM= :KEY_COD_ITEM AND ES_ITEMS_E.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ITEM":"$COD_ITEM","COD_ESTUDIO":"$COD_ESTUDIO","TERCERO":"$TERCERO","DEPENDENCIA":"$DEPENDENCIA","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","RESPONSABLE":"$RESPONSABLE","PORCIVAGLOBAL":"$PORCIVAGLOBAL","PORCDESCGLOBAL":"$PORCDESCGLOBAL","SUBTOTAL":"$SUBTOTAL","VALORIVA":"$VALORIVA","VALORDESCUENTO":"$VALORDESCUENTO","VALORTOTAL":"$VALORTOTAL","VACIA":"$VACIA","IMPRESA":"$IMPRESA(type:boolean)","SELECCIONADA":"$SELECCIONADA(type:boolean)","VALORESTIMADO":"$VALORESTIMADO","RUBROCOMPRAS":"$RUBROCOMPRAS","OBSERVACIONES":"$OBSERVACIONES","NSOLICITUDDISPON":"$NSOLICITUDDISPON","PLACA":"$PLACA","PERIORICIDAD":"$PERIORICIDAD","UNIDAD_TIEMPO":"$UNIDAD_TIEMPO","PLAZO":"$PLAZO","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","CANTIDAD":"$CANTIDAD","A_GLOBAL":"$A_GLOBAL","I_GLOBAL":"$I_GLOBAL","U_GLOBAL":"$U_GLOBAL","SUCURSAL_RESPONSABLE":"$SUCURSAL_RESPONSABLE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ITEM" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esitemse/data">
		<call-query href="getEsitemseRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ITEM" query-param="KEY_COD_ITEM"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="updateEsitemse" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ITEMS_E SET COMPANIA=:COMPANIA, COD_ITEM=:COD_ITEM, COD_ESTUDIO=:COD_ESTUDIO, TERCERO=:TERCERO, DEPENDENCIA=:DEPENDENCIA, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, RESPONSABLE=:RESPONSABLE, PORCIVAGLOBAL=:PORCIVAGLOBAL, PORCDESCGLOBAL=:PORCDESCGLOBAL, SUBTOTAL=:SUBTOTAL, VALORIVA=:VALORIVA, VALORDESCUENTO=:VALORDESCUENTO, VALORTOTAL=:VALORTOTAL, VACIA=:VACIA, IMPRESA=:IMPRESA, SELECCIONADA=:SELECCIONADA, VALORESTIMADO=:VALORESTIMADO, RUBROCOMPRAS=:RUBROCOMPRAS, OBSERVACIONES=:OBSERVACIONES, NSOLICITUDDISPON=:NSOLICITUDDISPON, PLACA=:PLACA, PERIORICIDAD=:PERIORICIDAD, UNIDAD_TIEMPO=:UNIDAD_TIEMPO, PLAZO=:PLAZO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CANTIDAD=:CANTIDAD, A_GLOBAL=:A_GLOBAL, I_GLOBAL=:I_GLOBAL, U_GLOBAL=:U_GLOBAL, SUCURSAL_RESPONSABLE=:SUCURSAL_RESPONSABLE WHERE ES_ITEMS_E.COMPANIA= :KEY_COMPANIA AND ES_ITEMS_E.COD_ITEM= :KEY_COD_ITEM AND ES_ITEMS_E.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ITEM" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="PORCIVAGLOBAL" sqlType="STRING"/>
		<param name="PORCDESCGLOBAL" sqlType="STRING"/>
		<param name="SUBTOTAL" sqlType="STRING"/>
		<param name="VALORIVA" sqlType="STRING"/>
		<param name="VALORDESCUENTO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="VACIA" sqlType="STRING"/>
		<param name="IMPRESA" sqlType="STRING"/>
		<param name="SELECCIONADA" sqlType="STRING"/>
		<param name="VALORESTIMADO" sqlType="STRING"/>
		<param name="RUBROCOMPRAS" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NSOLICITUDDISPON" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="PERIORICIDAD" sqlType="STRING"/>
		<param name="UNIDAD_TIEMPO" sqlType="STRING"/>
		<param name="PLAZO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="A_GLOBAL" sqlType="STRING"/>
		<param name="I_GLOBAL" sqlType="STRING"/>
		<param name="U_GLOBAL" sqlType="STRING"/>
		<param name="SUCURSAL_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ITEM" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esitemse">
		<call-query href="updateEsitemse">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ITEM" query-param="COD_ITEM"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="PORCIVAGLOBAL" query-param="PORCIVAGLOBAL"/>
			<with-param name="PORCDESCGLOBAL" query-param="PORCDESCGLOBAL"/>
			<with-param name="SUBTOTAL" query-param="SUBTOTAL"/>
			<with-param name="VALORIVA" query-param="VALORIVA"/>
