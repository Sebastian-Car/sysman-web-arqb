	<query id="getTercerosPagSinvariosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ( CONCAT( NIT, SUCURSAL ) ) CODIGO, NIT, ( CASE WHEN TRIM(NOMBRE) = '' THEN NULL ELSE TRIM(NOMBRE) END ) NOMBRE, SUCURSAL, COMPANIA,(CASE AUTORETENEDOR WHEN 0 THEN 'false' ELSE 'true' END) AUTORETENEDOR,(CASE AUTORET_IVA WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_IVA,(CASE AUTORET_ICA WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_ICA,(CASE AUTORET_TBRE WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_TBRE,(CASE AUTORET_PRO WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_PRO, REGIMEN, DIRECCION,(CASE LEY1450 WHEN 0 THEN 'false' ELSE 'true' END) LEY1450,(CASE LEY1819 WHEN 0 THEN 'false' ELSE 'true' END) LEY1819 FROM TERCERO WHERE COMPANIA = :COMPANIA AND ESTADO LIKE 'A' AND (NIT NOT IN(PCK_DATOS.FC_CONS_TERCERO) AND SUCURSAL NOT IN(PCK_DATOS.FC_CONS_SUCURSAL)) ORDER BY NOMBRE NULLS LAST) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","COMPANIA":"$COMPANIA","AUTORETENEDOR":"$AUTORETENEDOR(type:boolean)","AUTORET_IVA":"$AUTORET_IVA(type:boolean)","AUTORET_ICA":"$AUTORET_ICA(type:boolean)","AUTORET_TBRE":"$AUTORET_TBRE(type:boolean)","AUTORET_PRO":"$AUTORET_PRO(type:boolean)","REGIMEN":"$REGIMEN","DIRECCION":"$DIRECCION","LEY1450":"$LEY1450(type:boolean)","LEY1819":"$LEY1819(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/sinvarios/pag">
		<call-query href="getTercerosPagSinvariosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
