	<query id="getTercerosTerceroLoteQuery"  useConfig="sysmandsunist">
		<sql>SELECT TERCERO.NIT NUMERODOCUMENTO, UPPER(SUBSTR(PAISES.NOMBRE,0,2) ) PAIS, TERCERO.DEPARTAMENTO CODIGODEPARTAMENTO, DEPARTAMENTO.NOMBRE DEPARTAMENTO, CONCAT(TERCERO.DEPARTAMENTO,TERCERO.CIUDAD) CODIGOCIUDAD, CIUDAD.NOMBRE CIUDAD, TERCERO.NOMBRE NOMBRETERCERO, TERCERO.DIRECCIONEMAIL CORREOELECTRONICO, TERCERO.TELEFONOS TELEFONO, CASE WHEN TERCERO.REGIMEN = 'C' THEN '48' ELSE '49' END TIPOREGIMEN, CASE TERCERO.TIPOID WHEN 'N' THEN '31' WHEN 'C' THEN '13' WHEN 'E' THEN '22' WHEN 'T' THEN '12' ELSE '50' END TIPOIDENTIFICACION, CASE WHEN TERCERO.NATURALEZA = 'N' THEN '2' ELSE '1' END TIPOORGANIZACION, TERCERO.DIRECCION, TERCERO.COMPANIA, TERCERO.DIRECCIONFISCAL DIRECCIONFISCAL, TERCERO.CODIGOPOSTAL CODIGOPOSTAL, TERCERO.DIGITOVERIFICACION DIGITOVERIFICACION FROM TERCERO LEFT JOIN CIUDAD ON TERCERO.PAIS = CIUDAD.PAIS AND TERCERO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND TERCERO.CIUDAD = CIUDAD.CODIGO LEFT JOIN DEPARTAMENTO ON CIUDAD.DEPARTAMENTO = DEPARTAMENTO.CODIGO AND CIUDAD.PAIS = DEPARTAMENTO.PAIS LEFT JOIN PAISES ON DEPARTAMENTO.PAIS = PAISES.PAIS WHERE TERCERO.COMPANIA =:COMPANIA AND TERCERO.NIT =:NIT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERODOCUMENTO":"$NUMERODOCUMENTO","PAIS":"$PAIS","CODIGODEPARTAMENTO":"$CODIGODEPARTAMENTO","DEPARTAMENTO":"$DEPARTAMENTO","CODIGOCIUDAD":"$CODIGOCIUDAD","CIUDAD":"$CIUDAD","NOMBRETERCERO":"$NOMBRETERCERO","CORREOELECTRONICO":"$CORREOELECTRONICO","TELEFONO":"$TELEFONO","TIPOREGIMEN":"$TIPOREGIMEN","TIPOIDENTIFICACION":"$TIPOIDENTIFICACION","TIPOORGANIZACION":"$TIPOORGANIZACION","DIRECCION":"$DIRECCION","COMPANIA":"$COMPANIA","DIRECCIONFISCAL":"$DIRECCIONFISCAL","CODIGOPOSTAL":"$CODIGOPOSTAL","DIGITOVERIFICACION":"$DIGITOVERIFICACION(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/tercerolote">
		<call-query href="getTercerosTerceroLoteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>

		</call-query>
	</resource>
	<query id="getTercerosTodosTercerosQuery"  useConfig="sysmandsunist">
		<sql>SELECT NIT, SUCURSAL, COMPANIA, NOMBRE, DIRECCION, PAIS, DEPARTAMENTO, CIUDAD, TELEFONOS, TIPOID, NIT_CEDULA, NOMBRE1, NOMBRE2, APELLIDO1, APELLIDO2, PROPIETARIO, CLASE, NATURALEZA, TIPO_ASOCIADO, REGIMEN, PORCDESCUENTO, FAX, DIRECCIONEMAIL EMAIL,(CASE AUTORETENEDOR WHEN 0 THEN 'false' ELSE 'true' END) AUTORETENEDOR,(CASE CLASEENTIDADOFICIAL WHEN 0 THEN 'false' ELSE 'true' END) CLASEENTIDADOFICIAL,(CASE APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, EXPEDIDACEDULA, DIGITOVERIFICACION, ORDEN, ESTADO FROM TERCERO WHERE COMPANIA =:COMPANIA AND NIT BETWEEN :TERCEROINI AND :TERCEROFIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","SUCURSAL":"$SUCURSAL","COMPANIA":"$COMPANIA","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","TELEFONOS":"$TELEFONOS","TIPOID":"$TIPOID","NIT_CEDULA":"$NIT_CEDULA","NOMBRE1":"$NOMBRE1","NOMBRE2":"$NOMBRE2","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","PROPIETARIO":"$PROPIETARIO","CLASE":"$CLASE","NATURALEZA":"$NATURALEZA","TIPO_ASOCIADO":"$TIPO_ASOCIADO","REGIMEN":"$REGIMEN","PORCDESCUENTO":"$PORCDESCUENTO","FAX":"$FAX","EMAIL":"$EMAIL","AUTORETENEDOR":"$AUTORETENEDOR(type:boolean)","CLASEENTIDADOFICIAL":"$CLASEENTIDADOFICIAL(type:boolean)","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","EXPEDIDACEDULA":"$EXPEDIDACEDULA","DIGITOVERIFICACION":"$DIGITOVERIFICACION(type:long)","ORDEN":"$ORDEN","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROINI" sqlType="STRING"/>
		<param name="TERCEROFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/todosterceros">
		<call-query href="getTercerosTodosTercerosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCEROINI" query-param="TERCEROINI"/>
			<with-param name="TERCEROFIN" query-param="TERCEROFIN"/>

		</call-query>
	</resource>
	<query id="getTercerosPagTodposConTipoDocumentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NIT, NOMBRE, SUCURSAL,TIPOID FROM TERCERO WHERE COMPANIA = :COMPANIA ORDER BY NIT) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","TIPOID":"$TIPOID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/todposcontipodocumento/pag">
		<call-query href="getTercerosPagTodposConTipoDocumentoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
