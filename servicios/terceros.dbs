	</resource>
	<query id="getTercerosRegistroDeConductoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NIT, VINCULACION, ASIGNACIOCOND, ESTADO, NOMBRE1, APELLIDO1, NOMBRE2, APELLIDO2,(TO_CHAR(FECHANACIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHANACIMIENTO, TIPO_DE_SANGRE,(TO_CHAR(FECHAULTIMOEXAMEN,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMOEXAMEN, CARGO, DIRECCION, TELEFONOS, EXPERIENCIA, SUCURSAL, CATEGORIA_LICENCIA, NROLICENCIA, COMPANIA, REGIMEN, PCK_SYSMAN_UTL.FC_EDAD(FECHANACIMIENTO) EDAD,(CASE CONDUCTOR WHEN 0 THEN 'false' ELSE 'true' END) CONDUCTOR, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM TERCERO WHERE COMPANIA = :KEY_COMPANIA AND NIT = :KEY_NIT AND SUCURSAL = :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","VINCULACION":"$VINCULACION","ASIGNACIOCOND":"$ASIGNACIOCOND","ESTADO":"$ESTADO","NOMBRE1":"$NOMBRE1","APELLIDO1":"$APELLIDO1","NOMBRE2":"$NOMBRE2","APELLIDO2":"$APELLIDO2","FECHANACIMIENTO":"$FECHANACIMIENTO","TIPO_DE_SANGRE":"$TIPO_DE_SANGRE","FECHAULTIMOEXAMEN":"$FECHAULTIMOEXAMEN","CARGO":"$CARGO","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","EXPERIENCIA":"$EXPERIENCIA","SUCURSAL":"$SUCURSAL","CATEGORIA_LICENCIA":"$CATEGORIA_LICENCIA","NROLICENCIA":"$NROLICENCIA","COMPANIA":"$COMPANIA","REGIMEN":"$REGIMEN","EDAD":"$EDAD(type:integer)","CONDUCTOR":"$CONDUCTOR(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/registrodeconductores">
