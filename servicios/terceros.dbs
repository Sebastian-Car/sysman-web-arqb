	<query id="getTercerosPagSolicitanteViaticosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ROWNUM, T.NIT, T.SUCURSAL, T.NOMBRE , DP.CODIGO DEPENDENCIA , DP.NOMBRE NOMBREDEPENDENCIA , DPR.RESPONSABLE , TT.NOMBRE NOMBRE_RESPONSABLE , DPR.SUCURSAL SUCURSAL_RESPONSABLE , (TO_CHAR(P.FECHANCTO,'DD/MM/YYYY HH24:MI:SS')) FECHANACIMIENTO , P.BANCO , B.NOMBREBANCO , P.CUENTA , P.TELEFONOS , P.EMAIL_CORPORATIVO DIRECCIONEMAIL , P.SALARIO_BASE_IBC, T.CIUDAD, T.EXPEDIDACEDULA FROM TERCERO T INNER JOIN PERSONAL P ON T.COMPANIA = P.COMPANIA AND T.NIT = P.NUMERO_DCTO AND T.SUCURSAL = P.SUCURSAL INNER JOIN DEPENDENCIA DP ON P.COMPANIA = DP.COMPANIA AND P.DEPENDENCIA = DP.CODIGO INNER JOIN DEPENDENCIA_RESPONSABLE DPR ON DPR.COMPANIA = DP.COMPANIA AND DPR.DEPENDENCIA = DP.CODIGO INNER JOIN RESPONSABLE R ON R.COMPANIA = DPR.COMPANIA AND R.CEDULA = DPR.RESPONSABLE AND R.SUCURSAL = DPR.SUCURSAL INNER JOIN TERCERO TT ON R.COMPANIA = TT.COMPANIA AND R.CEDULA = TT.NIT AND R.SUCURSAL = TT.SUCURSAL INNER JOIN BANCO B ON B.COMPANIA = P.COMPANIA AND B.BANCO =P.BANCO WHERE T.COMPANIA = :COMPANIA AND P.ESTADO_ACTUAL IN (1) AND DPR.JEFEUNIDAD NOT IN (0) AND R.ACTIVO NOT IN (0) UNION SELECT ROWNUM, T.NIT, T.SUCURSAL, T.NOMBRE, '' DEPENDENCIA, '' NOMBREDEPENDENCIA, '' RESPONSABLE , '' NOMBRE_RESPONSABLE , '' SUCURSAL_RESPONSABLE , (TO_CHAR(T.FECHANACIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHANACIMIENTO , '' BANCO , '' NOMBREBANCO , '' CUENTA , T.TELEFONOS , T.DIRECCIONEMAIL , 0.0 SALARIO_BASE_IBC, T.CIUDAD, T.EXPEDIDACEDULA FROM TERCERO T LEFT JOIN PERSONAL P ON T.COMPANIA = P.COMPANIA AND T.NIT = P.NUMERO_DCTO AND T.SUCURSAL = P.SUCURSAL WHERE T.COMPANIA = :COMPANIA AND P.COMPANIA IS NULL ORDER BY 2) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(:RESPONSABLE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ROWNUM":"$ROWNUM(type:double)","NIT":"$NIT","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","DEPENDENCIA":"$DEPENDENCIA","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","RESPONSABLE":"$RESPONSABLE","NOMBRE_RESPONSABLE":"$NOMBRE_RESPONSABLE","SUCURSAL_RESPONSABLE":"$SUCURSAL_RESPONSABLE","FECHANACIMIENTO":"$FECHANACIMIENTO","BANCO":"$BANCO","NOMBREBANCO":"$NOMBREBANCO","CUENTA":"$CUENTA","TELEFONOS":"$TELEFONOS","DIRECCIONEMAIL":"$DIRECCIONEMAIL","SALARIO_BASE_IBC":"$SALARIO_BASE_IBC(type:double)","CIUDAD":"$CIUDAD","EXPEDIDACEDULA":"$EXPEDIDACEDULA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
