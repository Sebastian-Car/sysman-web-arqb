	<query id="getTercerosPagTodasLosTerNaturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIT, NOMBRE NOMBRE_COMPLETO, APELLIDO1, APELLIDO2, NOMBRE, TIPOID, UPPER(DESCRIPCION) TIPO_DOCU, TERCERO.SUCURSAL  FROM TERCERO LEFT JOIN TIPOS_DOCUMENTOS ON TERCERO.COMPANIA = TIPOS_DOCUMENTOS.COMPANIA AND TERCERO.TIPOID = TIPOS_DOCUMENTOS.DCTO_IDENTIDAD WHERE TERCERO.COMPANIA = :COMPANIA AND TERCERO.NATURALEZA IN('N')) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE_COMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRE_COMPLETO) END)  LIKE UPPER( '%' || :NOMBRE_COMPLETO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE_COMPLETO":"$NOMBRE_COMPLETO","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRE":"$NOMBRE","TIPOID":"$TIPOID","TIPO_DOCU":"$TIPO_DOCU","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE_COMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
