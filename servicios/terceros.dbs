	<query id="getTercerosPagListaDeConductoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, SUCURSAL, NIT , CASE WHEN ESTADO='A' THEN 'Activo' WHEN ESTADO='R' THEN 'Retirado' WHEN ESTADO='I' THEN 'Inactivo' END AS ESTADO, NOMBRE, TO_CHAR(FECHANACIMIENTO,'dd/MM/YYYY') AS FECHA_NACIMIENTO, PCK_SYSMAN_UTL.FC_EDAD(FECHANACIMIENTO) EDAD, TIPO_DE_SANGRE, CATEGORIA_LICENCIA CATEGORIA, NROLICENCIA LICENCIA  FROM TERCERO WHERE COMPANIA = :COMPANIA AND ESTADO IN CASE WHEN :OPCION IS NULL THEN ESTADO ELSE :OPCION END AND CONDUCTOR NOT IN(0)) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FECHA_NACIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHA_NACIMIENTO) END)  LIKE UPPER( '%' || :FECHA_NACIMIENTO || '%')  AND (CASE WHEN EDAD IS NULL THEN ' ' ELSE UPPER(EDAD) END)  LIKE UPPER(:EDAD || '%')  AND (CASE WHEN TIPO_DE_SANGRE IS NULL THEN ' ' ELSE UPPER(TIPO_DE_SANGRE) END)  LIKE UPPER( '%' || :TIPO_DE_SANGRE || '%')  AND (CASE WHEN CATEGORIA IS NULL THEN ' ' ELSE UPPER(CATEGORIA) END)  LIKE UPPER( '%' || :CATEGORIA || '%')  AND (CASE WHEN LICENCIA IS NULL THEN ' ' ELSE UPPER(LICENCIA) END)  LIKE UPPER( '%' || :LICENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NIT":"$NIT","ESTADO":"$ESTADO","NOMBRE":"$NOMBRE","FECHA_NACIMIENTO":"$FECHA_NACIMIENTO","EDAD":"$EDAD(type:integer)","TIPO_DE_SANGRE":"$TIPO_DE_SANGRE","CATEGORIA":"$CATEGORIA","LICENCIA":"$LICENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="OPCION" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHA_NACIMIENTO" sqlType="STRING"/>
		<param name="EDAD" sqlType="STRING"/>
		<param name="TIPO_DE_SANGRE" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="LICENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
