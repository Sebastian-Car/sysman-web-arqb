	<query id="insertTercerosTerceroDeudaPredio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TERCERO ( COMPANIA, SUCURSAL, CIUDAD, NIT, TIPOID, NOMBRE, REGIMEN, CREATED_BY, DATE_CREATED ) SELECT CODIGO, :SUCURSAL, :CIUDAD, :NIT, :TIPOID, :NOMBRE, 'S', :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS') FROM COMPANIA WHERE CODIGO NOT IN (SELECT COMPANIA FROM TERCERO WHERE COMPANIA =:COMPANIA AND NIT =:NIT AND SUCURSAL =:SUCURSAL ) AND CODIGO = :COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="CIUDAD" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param defaultValue="" name="TIPOID" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
