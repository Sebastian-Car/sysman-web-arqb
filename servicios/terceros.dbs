	<query id="getTercerosPagTodosInterventoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TERCERO.NIT CEDULA, TERCERO.NOMBRE, TERCERO.CARGO, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA AND IND_INTERVENTOR NOT IN (0)) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
