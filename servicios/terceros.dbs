	</resource>
	<query id="updateTercerosIndterceroEnExogenas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TERCERO SET IND_REPORTAR_2276  = :IND_REPORTAR_2276 ,   MODIFIED_BY   =:MODIFIED_BY,   DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPANIA = :KEY_COMPANIA AND NIT = :KEY_NIT AND SUCURSAL = :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IND_REPORTAR_2276" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
