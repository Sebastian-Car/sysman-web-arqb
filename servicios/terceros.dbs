	<query id="getTercerosNumDireccionFaxYTelefonoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TERCERO.NIT, TERCERO.NOMBRE, TERCERO.SUCURSAL, TERCERO.DIRECCION, TERCERO.FAX, TERCERO.TELEFONOS  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA ORDER BY NOMBRE) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
