	<query id="getTercerosSupervisorPorClaseNumQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TERCERO.NOMBRE SUPERVISOR  FROM SUPERVISORES INNER JOIN TERCERO ON SUPERVISORES.COMPANIA = TERCERO.COMPANIA AND SUPERVISORES.CEDULA = TERCERO.NIT AND SUPERVISORES.SUCURSAL = TERCERO.SUCURSAL WHERE SUPERVISORES.COMPANIA = :COMPANIA AND SUPERVISORES.CLASEORDEN = :CLASEORDEN AND SUPERVISORES.NUMEROCONTRATO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUPERVISOR":"$SUPERVISOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
