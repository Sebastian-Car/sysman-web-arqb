	<query id="getTercerosPagTercerosEnExogenasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,NIT,SUCURSAL,NOMBRE,(CASE IND_REPORTAR_2276 WHEN 0 THEN 'false' ELSE 'true' END) IND_REPORTAR_2276 FROM TERCERO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_REPORTAR_2276 IS NULL THEN ' ' ELSE UPPER(IND_REPORTAR_2276) END)  LIKE UPPER( '%' || :IND_REPORTAR_2276 || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","IND_REPORTAR_2276":"$IND_REPORTAR_2276(type:boolean)"}]}}		</result>
