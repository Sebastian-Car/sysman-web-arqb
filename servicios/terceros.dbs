	<query id="updateTerceros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TERCERO SET TELEFONOS=:TELEFONOS, NRODOCUMENTO_EMBARGO=:NRODOCUMENTO_EMBARGO, CIUDADDEREGISTRO=:CIUDADDEREGISTRO, TIPO_EMBARGO=:TIPO_EMBARGO, CARGO_CONTACTO=:CARGO_CONTACTO, APELLIDO1=:APELLIDO1, DIAS_PRMD_CARTERA=:DIAS_PRMD_CARTERA, GRADO=:GRADO, APELLIDO2=:APELLIDO2, APORTESARL=:APORTESARL, MODIFIED_BY=:MODIFIED_BY, CEDULAREPRESENTANTE=:CEDULAREPRESENTANTE, FORMADEPAGO=:FORMADEPAGO, FAX=:FAX, APORTESVOLUNTARIOS=:APORTESVOLUNTARIOS, PROFESION=:PROFESION, VENDEDOR=:VENDEDOR, NOMBREVENDEDOR=:NOMBREVENDEDOR, VINCULACION=:VINCULACION, AUTORET_TBRE=:AUTORET_TBRE, PAIS_EXPE=:PAIS_EXPE, DEPARTAMENTO_EXPE=:DEPARTAMENTO_EXPE, CIUDAD_EXPE=:CIUDAD_EXPE, EXPEDIDACEDULA=:EXPEDIDACEDULA, REGIMEN=:REGIMEN, ACTIVO=:ACTIVO, CIUDAD=:CIUDAD, NOAPORTAPENSION=:NOAPORTAPENSION, CODIGORUP=:CODIGORUP, DECLARARENTA=:DECLARARENTA, PORCDESCUENTO=:PORCDESCUENTO, ANTECEDENTES=:ANTECEDENTES, CODIGO_PROPONENTE=:CODIGO_PROPONENTE, MEDPREPAGADA=:MEDPREPAGADA, FECHAULTIMAFACTURA=TO_DATE(:FECHAULTIMAFACTURA,'DD/MM/YYYY HH24:MI:SS'), KCONSTRUCTOR=:KCONSTRUCTOR, VALORULTIMAFACTURA=:VALORULTIMAFACTURA, EXPEDIDAENREPRESENTANTE=:EXPEDIDAENREPRESENTANTE, UNIDAD=:UNIDAD, CONTACTO=:CONTACTO, NITAPODERADO=:NITAPODERADO, PRMD_CARTERA=:PRMD_CARTERA, APLICADESCUENTO=:APLICADESCUENTO, REGISTROMERCANTIL=:REGISTROMERCANTIL, PAGOELECTRONICO=:PAGOELECTRONICO, EMBARGO=:EMBARGO, NATURALEZA=:NATURALEZA, FECHA_EMBARGO=TO_DATE(:FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS'), CARGOREPRESENTANTE=:CARGOREPRESENTANTE, MAX_CREDITO=:MAX_CREDITO, DIRECCIONEMAIL=:DIRECCIONEMAIL, ESTADO=:ESTADO, RETENEDORICA=:RETENEDORICA, CLASEENTIDADOFICIAL=:CLASEENTIDADOFICIAL, KCONSULTORING=:KCONSULTORING, TIPO_ASOCIADO=:TIPO_ASOCIADO, AFC=:AFC, CODIGOSCHIP=:CODIGOSCHIP, SUCURSAL_VEND=:SUCURSAL_VEND, CAMARA_COMERCIO=:CAMARA_COMERCIO, DEDUCIBLE_VIVIENDA=:DEDUCIBLE_VIVIENDA, ORDEN=:ORDEN, TIPOSOCIEDAD=:TIPOSOCIEDAD, NIT_CEDULA=:NIT_CEDULA, CLASE=:CLASE, DEPENDIENTE=:DEPENDIENTE, FUERZA=:FUERZA, KCONSULTOR=:KCONSULTOR, VALOR_EMBARGO=:VALOR_EMBARGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CODIGOEQUIVALENTE=:CODIGOEQUIVALENTE, NOAPORTASALUD=:NOAPORTASALUD, CALIFICACIONCC=:CALIFICACIONCC, INFORMACION_ADICIONAL=:INFORMACION_ADICIONAL, TIPO_CONTRATISTA=:TIPO_CONTRATISTA, ZONA=:ZONA, DEPARTAMENTO=:DEPARTAMENTO, NOMBREREPLEGAL=:NOMBREREPLEGAL, VLRMAXCARTERA=:VLRMAXCARTERA, KPROVEEDOR=:KPROVEEDOR, DIGITOVERIFICACION=:DIGITOVERIFICACION, AUTORETENEDOR=:AUTORETENEDOR, PAIS=:PAIS, LEY1450=:LEY1450, LEY1819=:LEY1819, AUTORET_PRO=:AUTORET_PRO, TIPO_TERCERO=:TIPO_TERCERO, FECHACAMARACOMERCIO=TO_DATE(:FECHACAMARACOMERCIO,'DD/MM/YYYY HH24:MI:SS'), ACTIVIDAD=:ACTIVIDAD, CODIGOICA=:CODIGOICA, AUTORET_IVA=:AUTORET_IVA, NOCAMARACOMERCIO=:NOCAMARACOMERCIO, TIPOID=:TIPOID, IBC=:IBC, DIRECCIONWEB=:DIRECCIONWEB, CARGO=:CARGO, FECHAINSCRIPCIONCC=TO_DATE(:FECHAINSCRIPCIONCC,'DD/MM/YYYY HH24:MI:SS'), DETERIORO=:DETERIORO, AUTORET_ICA=:AUTORET_ICA, CODIGOPOSTAL=:CODIGOPOSTAL, RETENEDORIVA=:RETENEDORIVA, PROPIETARIO=:PROPIETARIO, TARJETAPROFESIONAL=:TARJETAPROFESIONAL, DIRECCION=:DIRECCION, SUCURSALAPODERADO=:SUCURSALAPODERADO, IND_INTERVENTOR=:IND_INTERVENTOR, NOMBRE1=:NOMBRE1, NOMBRE2=:NOMBRE2, IND_PAGO_RETENCION=:IND_PAGO_RETENCION, IND_REPORTAR_2276=:IND_REPORTAR_2276, DIRECCIONFISCAL=:DIRECCIONFISCAL, TIPOENTIDAD=:TIPOENTIDAD, NUMEROLISTA=:NUMEROLISTA, PERIOCIDAD=:PERIOCIDAD, IND_PERSONANIT=:IND_PERSONANIT, GENERO=:GENERO WHERE TERCERO.COMPANIA= :KEY_COMPANIA AND TERCERO.NIT= :KEY_NIT AND TERCERO.SUCURSAL= :KEY_SUCURSAL</sql>
