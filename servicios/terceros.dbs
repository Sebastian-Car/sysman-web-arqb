	<query id="getTercerosPagTodosPorResponsableRadicQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  RES.RESPONSABLE RESPONSABLE_RADIC, RES.CARGO, RES.DEPENDENCIA, TER.NOMBRE, TER.SUCURSAL  FROM (SELECT DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, RESPONSABLE.COMPANIA, RESPONSABLE.CEDULA, RESPONSABLE.SUCURSAL, RESPONSABLE.CARGO, DEPENDENCIA_RESPONSABLE.DEPENDENCIA FROM DEPENDENCIA_RESPONSABLE LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLE.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.ACTIVO_RECEP NOT IN (0) ORDER BY CEDULA) RES INNER JOIN TERCERO TER ON RES.COMPANIA=TER.COMPANIA AND RES.CEDULA=TER.NIT AND RES.SUCURSAL=TER.SUCURSAL ORDER BY RESPONSABLE_RADIC) WHERE (CASE WHEN RESPONSABLE_RADIC IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_RADIC) END)  LIKE UPPER(:RESPONSABLE_RADIC || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE_RADIC":"$RESPONSABLE_RADIC","CARGO":"$CARGO","DEPENDENCIA":"$DEPENDENCIA","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE_RADIC" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/todosporresponsableradic/pag">
		<call-query href="getTercerosPagTodosPorResponsableRadicQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE_RADIC" query-param="RESPONSABLE_RADIC"/>
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTercerosNumTodosPorResponsableRadicQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  RES.RESPONSABLE RESPONSABLE_RADIC, RES.CARGO, RES.DEPENDENCIA, TER.NOMBRE, TER.SUCURSAL  FROM (SELECT DISTINCT DEPENDENCIA_RESPONSABLE.RESPONSABLE, RESPONSABLE.COMPANIA, RESPONSABLE.CEDULA, RESPONSABLE.SUCURSAL, RESPONSABLE.CARGO, DEPENDENCIA_RESPONSABLE.DEPENDENCIA FROM DEPENDENCIA_RESPONSABLE LEFT JOIN RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = RESPONSABLE.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = RESPONSABLE.CEDULA AND DEPENDENCIA_RESPONSABLE.SUCURSAL = RESPONSABLE.SUCURSAL WHERE DEPENDENCIA_RESPONSABLE.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA AND DEPENDENCIA_RESPONSABLE.ACTIVO_RECEP NOT IN (0) ORDER BY CEDULA) RES INNER JOIN TERCERO TER ON RES.COMPANIA=TER.COMPANIA AND RES.CEDULA=TER.NIT AND RES.SUCURSAL=TER.SUCURSAL ORDER BY RESPONSABLE_RADIC) WHERE (CASE WHEN RESPONSABLE_RADIC IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_RADIC) END)  LIKE UPPER(:RESPONSABLE_RADIC || '%')  AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END)  LIKE UPPER( '%' || :CARGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE_RADIC" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
