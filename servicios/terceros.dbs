	<query id="updateTercerosEdicionDeConductores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TERCERO SET NIT=:NIT, VINCULACION=:VINCULACION, ASIGNACIOCOND=:ASIGNACIOCOND, ESTADO=:ESTADO, NOMBRE1=:NOMBRE1, APELLIDO1=:APELLIDO1, NOMBRE2=:NOMBRE2, APELLIDO2=:APELLIDO2, FECHANACIMIENTO=TO_DATE(:FECHANACIMIENTO,'DD/MM/YYYY HH24:MI:SS'), TIPO_DE_SANGRE=:TIPO_DE_SANGRE, FECHAULTIMOEXAMEN=TO_DATE(:FECHAULTIMOEXAMEN,'DD/MM/YYYY HH24:MI:SS'), CARGO=:CARGO, DIRECCION=:DIRECCION, TELEFONOS=:TELEFONOS, EXPERIENCIA=:EXPERIENCIA, SUCURSAL=:SUCURSAL, CATEGORIA_LICENCIA=:CATEGORIA_LICENCIA, NROLICENCIA=:NROLICENCIA, REGIMEN=:REGIMEN, CONDUCTOR=:CONDUCTOR, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE TERCERO.COMPANIA= :KEY_COMPANIA AND TERCERO.NIT= :KEY_NIT AND TERCERO.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NIT" sqlType="STRING"/>
		<param name="VINCULACION" sqlType="STRING"/>
		<param name="ASIGNACIOCOND" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="NOMBRE1" sqlType="STRING"/>
