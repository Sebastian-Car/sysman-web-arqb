	<query id="getTercerosPagPorNitTipopersonaYMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIT, SUCURSAL, NOMBRE  FROM TERCERO WHERE COMPANIA = :COMPANIA AND ( CASE WHEN :TIPO_PERSONA = 'T' AND :CPTO_MOV = 'P' AND :CLASE_MOV = 'E' THEN NIT ELSE :NUMERO END) = :NUMERO AND ( CASE WHEN :TIPO_PERSONA = 'P' THEN CLASE ELSE :TIPO_PERSONA END) = :TIPO_PERSONA ORDER BY NIT, NOMBRE) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_PERSONA" sqlType="STRING"/>
		<param name="CPTO_MOV" sqlType="STRING"/>
		<param name="CLASE_MOV" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

