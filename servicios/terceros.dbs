	<query id="getTercerosPagTerceroJuridicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TERCERO.NIT , TERCERO.NOMBRE, TERCERO.SUCURSAL, TERCERO.NOMBRE1, TERCERO.NOMBRE2, TERCERO.APELLIDO1, TERCERO.APELLIDO2, TERCERO.PROPIETARIO, TERCERO.CLASE, TERCERO.PAIS, TERCERO.DEPARTAMENTO , TERCERO.CIUDAD, TERCERO.DIRECCION, TERCERO.TELEFONOS, TERCERO.FAX, UPPER(PAISES.NOMBRE) PAIS_NOMBRE, UPPER(DEPARTAMENTO.NOMBRE) DEPARTAMENTO_NOMBRE, UPPER(CIUDAD.NOMBRE) MUNICIPIO_NOMBRE  FROM TERCERO LEFT JOIN PAISES ON TERCERO.PAIS = PAISES.PAIS LEFT JOIN DEPARTAMENTO ON TERCERO.PAIS = DEPARTAMENTO.PAIS AND TERCERO.DEPARTAMENTO= DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON TERCERO.PAIS =CIUDAD.PAIS AND TERCERO.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND TERCERO.CIUDAD = CIUDAD.CODIGO WHERE TERCERO.COMPANIA = :COMPANIA AND TERCERO.NATURALEZA IN ('J')) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NOMBRE1 IS NULL THEN ' ' ELSE UPPER(NOMBRE1) END)  LIKE UPPER( '%' || :NOMBRE1 || '%')  AND (CASE WHEN NOMBRE2 IS NULL THEN ' ' ELSE UPPER(NOMBRE2) END)  LIKE UPPER( '%' || :NOMBRE2 || '%')  AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END)  LIKE UPPER( '%' || :APELLIDO1 || '%')  AND (CASE WHEN APELLIDO2 IS NULL THEN ' ' ELSE UPPER(APELLIDO2) END)  LIKE UPPER( '%' || :APELLIDO2 || '%')  AND (CASE WHEN PROPIETARIO IS NULL THEN ' ' ELSE UPPER(PROPIETARIO) END)  LIKE UPPER( '%' || :PROPIETARIO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN PAIS IS NULL THEN ' ' ELSE UPPER(PAIS) END)  LIKE UPPER( '%' || :PAIS || '%')  AND (CASE WHEN DEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(DEPARTAMENTO) END)  LIKE UPPER( '%' || :DEPARTAMENTO || '%')  AND (CASE WHEN CIUDAD IS NULL THEN ' ' ELSE UPPER(CIUDAD) END)  LIKE UPPER( '%' || :CIUDAD || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN TELEFONOS IS NULL THEN ' ' ELSE UPPER(TELEFONOS) END)  LIKE UPPER( '%' || :TELEFONOS || '%')  AND (CASE WHEN FAX IS NULL THEN ' ' ELSE UPPER(FAX) END)  LIKE UPPER( '%' || :FAX || '%')  AND (CASE WHEN PAIS_NOMBRE IS NULL THEN ' ' ELSE UPPER(PAIS_NOMBRE) END)  LIKE UPPER( '%' || :PAIS_NOMBRE || '%')  AND (CASE WHEN DEPARTAMENTO_NOMBRE IS NULL THEN ' ' ELSE UPPER(DEPARTAMENTO_NOMBRE) END)  LIKE UPPER( '%' || :DEPARTAMENTO_NOMBRE || '%')  AND (CASE WHEN MUNICIPIO_NOMBRE IS NULL THEN ' ' ELSE UPPER(MUNICIPIO_NOMBRE) END)  LIKE UPPER( '%' || :MUNICIPIO_NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","NOMBRE1":"$NOMBRE1","NOMBRE2":"$NOMBRE2","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","PROPIETARIO":"$PROPIETARIO","CLASE":"$CLASE","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","FAX":"$FAX","PAIS_NOMBRE":"$PAIS_NOMBRE","DEPARTAMENTO_NOMBRE":"$DEPARTAMENTO_NOMBRE","MUNICIPIO_NOMBRE":"$MUNICIPIO_NOMBRE"}]}}		</result>
