	</resource>
	<query id="insertTercerosInsercionDeConductores" keyColumns="COMPANIA,NIT,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TERCERO (NIT, VINCULACION, ASIGNACIOCOND, ESTADO, NOMBRE1, APELLIDO1, NOMBRE2, APELLIDO2, FECHANACIMIENTO, TIPO_DE_SANGRE, FECHAULTIMOEXAMEN, CARGO, DIRECCION, TELEFONOS, EXPERIENCIA, SUCURSAL, CATEGORIA_LICENCIA, NROLICENCIA, COMPANIA, REGIMEN, CONDUCTOR, CREATED_BY, DATE_CREATED) VALUES (:NIT, :VINCULACION, :ASIGNACIOCOND, :ESTADO, :NOMBRE1, :APELLIDO1, :NOMBRE2, :APELLIDO2, TO_DATE(:FECHANACIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :TIPO_DE_SANGRE, TO_DATE(:FECHAULTIMOEXAMEN,'DD/MM/YYYY HH24:MI:SS'), :CARGO, :DIRECCION, :TELEFONOS, :EXPERIENCIA, :SUCURSAL, :CATEGORIA_LICENCIA, :NROLICENCIA, :COMPANIA, :REGIMEN, :CONDUCTOR, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param defaultValue="" name="VINCULACION" sqlType="STRING"/>
		<param defaultValue="" name="ASIGNACIOCOND" sqlType="STRING"/>
		<param defaultValue="A" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE1" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO1" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE2" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO2" sqlType="STRING"/>
		<param defaultValue="" name="FECHANACIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_DE_SANGRE" sqlType="STRING"/>
		<param defaultValue="" name="FECHAULTIMOEXAMEN" sqlType="STRING"/>
		<param defaultValue="" name="CARGO" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONOS" sqlType="STRING"/>
		<param defaultValue="" name="EXPERIENCIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="CATEGORIA_LICENCIA" sqlType="STRING"/>
		<param defaultValue="" name="NROLICENCIA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param defaultValue="0" name="CONDUCTOR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
