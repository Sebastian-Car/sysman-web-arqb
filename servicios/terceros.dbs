		</call-query>
	</resource>
	<query id="getTercerosNumSinvariosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ( CONCAT( NIT, SUCURSAL ) ) CODIGO, NIT, ( CASE WHEN TRIM(NOMBRE) = '' THEN NULL ELSE TRIM(NOMBRE) END ) NOMBRE, SUCURSAL, COMPANIA,(CASE AUTORETENEDOR WHEN 0 THEN 'false' ELSE 'true' END) AUTORETENEDOR,(CASE AUTORET_IVA WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_IVA,(CASE AUTORET_ICA WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_ICA,(CASE AUTORET_TBRE WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_TBRE,(CASE AUTORET_PRO WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_PRO, REGIMEN, DIRECCION,(CASE LEY1450 WHEN 0 THEN 'false' ELSE 'true' END) LEY1450,(CASE LEY1819 WHEN 0 THEN 'false' ELSE 'true' END) LEY1819 FROM TERCERO WHERE COMPANIA = :COMPANIA AND ESTADO LIKE 'A' AND (NIT NOT IN(PCK_DATOS.FC_CONS_TERCERO) AND SUCURSAL NOT IN(PCK_DATOS.FC_CONS_SUCURSAL)) ORDER BY NOMBRE NULLS LAST) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
