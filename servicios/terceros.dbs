	<query id="getTercerosPagListadoGeneralQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NIT CODIGO, CONCAT(APELLIDO1 ,CONCAT(' ',CONCAT(APELLIDO2 ,CONCAT(' ',CONCAT(NOMBRE1,CONCAT(' ', NOMBRE2)))))) NOMBRE, SUCURSAL EXPRESION1 FROM TERCERO WHERE COMPANIA =:COMPANIA ORDER BY CODIGO, NOMBRE) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN EXPRESION1 IS NULL THEN ' ' ELSE UPPER(EXPRESION1) END) LIKE UPPER(CONCAT(CONCAT('%',:EXPRESION1), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","EXPRESION1":"$EXPRESION1"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="EXPRESION1" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

