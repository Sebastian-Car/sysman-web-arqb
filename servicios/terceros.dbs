<data name="terceros" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTercerosPagTodospornitQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NIT, NOMBRE, SUCURSAL  FROM TERCERO WHERE COMPANIA = :COMPANIA ORDER BY NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/todospornit/pag">
		<call-query href="getTercerosPagTodospornitQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTercerosNumTodospornitQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NIT, NOMBRE, SUCURSAL  FROM TERCERO WHERE COMPANIA = :COMPANIA ORDER BY NIT) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/todospornit/num">
		<call-query href="getTercerosNumTodospornitQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getTercerosTodosPorCompaniaNitSucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CANT  FROM TERCERO WHERE COMPANIA = :COMPANIA AND NIT = :NIT AND SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANT":"$CANT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/todosporcompanianitsucursal">
		<call-query href="getTercerosTodosPorCompaniaNitSucursalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getTercerosPagTodosInicialPorNombreOrdenadosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TRIM(UPPER(TERCERO.NOMBRE))NOMBRE , TERCERO.NIT, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA ORDER BY TERCERO.COMPANIA, TERCERO.NIT, TERCERO.SUCURSAL) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","NIT":"$NIT","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/todosinicialpornombreordenadosporcodigo/pag">
		<call-query href="getTercerosPagTodosInicialPorNombreOrdenadosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTercerosNumTodosInicialPorNombreOrdenadosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TRIM(UPPER(TERCERO.NOMBRE))NOMBRE , TERCERO.NIT, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA ORDER BY TERCERO.COMPANIA, TERCERO.NIT, TERCERO.SUCURSAL) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/todosinicialpornombreordenadosporcodigo/num">
		<call-query href="getTercerosNumTodosInicialPorNombreOrdenadosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getTercerosPagTodosInicialPorNombreOrdenadosPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TRIM(UPPER(TERCERO.NOMBRE))NOMBRE , TERCERO.NIT, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA AND TRIM(UPPER(TERCERO.NOMBRE)) IS NOT NULL ORDER BY TERCERO.COMPANIA, TRIM(UPPER(TERCERO.NOMBRE))) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","NIT":"$NIT","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/todosinicialpornombreordenadospornombre/pag">
		<call-query href="getTercerosPagTodosInicialPorNombreOrdenadosPorNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTercerosNumTodosInicialPorNombreOrdenadosPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TRIM(UPPER(TERCERO.NOMBRE))NOMBRE , TERCERO.NIT, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA AND TRIM(UPPER(TERCERO.NOMBRE)) IS NOT NULL ORDER BY TERCERO.COMPANIA, TRIM(UPPER(TERCERO.NOMBRE))) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/todosinicialpornombreordenadospornombre/num">
		<call-query href="getTercerosNumTodosInicialPorNombreOrdenadosPorNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="insertTerceros" keyColumns="COMPANIA,NIT,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TERCERO (NRODOCUMENTO_EMBARGO, TELEFONOS, AFC, SUCURSAL, SUCURSAL_VEND, CIUDADDEREGISTRO, TIPO_EMBARGO, CAMARA_COMERCIO, DEDUCIBLE_VIVIENDA, ORDEN, CARGO_CONTACTO, TIPOSOCIEDAD, NIT_CEDULA, CLASE, APELLIDO1, FUERZA, DIAS_PRMD_CARTERA, KCONSULTOR, VALOR_EMBARGO, GRADO, APELLIDO2, APORTESARL, CEDULAREPRESENTANTE, FORMADEPAGO, FAX, APORTESVOLUNTARIOS, PROFESION, NOAPORTASALUD, CALIFICACIONCC, PAIS_EXPE, DEPARTAMENTO_EXPE, CIUDAD_EXPE, EXPEDIDACEDULA, REGIMEN, ZONA, TIPO_CONTRATISTA, DEPARTAMENTO, VLRMAXCARTERA, KPROVEEDOR, CIUDAD, NOAPORTAPENSION, CODIGORUP, AUTORETENEDOR, LEY1450, LEY1819, PAIS, PORCDESCUENTO, ACTIVIDAD, CODIGOICA, MEDPREPAGADA, FECHAULTIMAFACTURA, CODIGO_PROPONENTE, KCONSTRUCTOR, TIPOID, IBC, DIRECCIONWEB, VALORULTIMAFACTURA, EXPEDIDAENREPRESENTANTE, UNIDAD, CONTACTO, CARGO, NITAPODERADO, DETERIORO, PRMD_CARTERA, APLICADESCUENTO, REGISTROMERCANTIL, PAGOELECTRONICO, PROPIETARIO, TARJETAPROFESIONAL, EMBARGO, FECHA_EMBARGO, NATURALEZA, NIT, MAX_CREDITO, CARGOREPRESENTANTE, DIRECCIONEMAIL, DIRECCION, ESTADO, COMPANIA, SUCURSALAPODERADO, IND_INTERVENTOR, NOMBRE1, CLASEENTIDADOFICIAL, KCONSULTORING, NOMBRE2, DATE_CREATED, CREATED_BY, IND_PAGO_RETENCION, IND_REPORTAR_2276, CODIGOPOSTAL, DIRECCIONFISCAL, TIPOENTIDAD, NUMEROLISTA, PERIOCIDAD, IND_PERSONANIT, GENERO) VALUES (:NRODOCUMENTO_EMBARGO, :TELEFONOS, :AFC, :SUCURSAL, :SUCURSAL_VEND, :CIUDADDEREGISTRO, :TIPO_EMBARGO, :CAMARA_COMERCIO, :DEDUCIBLE_VIVIENDA, :ORDEN, :CARGO_CONTACTO, :TIPOSOCIEDAD, :NIT_CEDULA, :CLASE, :APELLIDO1, :FUERZA, :DIAS_PRMD_CARTERA, :KCONSULTOR, :VALOR_EMBARGO, :GRADO, :APELLIDO2, :APORTESARL, :CEDULAREPRESENTANTE, :FORMADEPAGO, :FAX, :APORTESVOLUNTARIOS, :PROFESION, :NOAPORTASALUD, :CALIFICACIONCC, :PAIS_EXPE, :DEPARTAMENTO_EXPE, :CIUDAD_EXPE, :EXPEDIDACEDULA, :REGIMEN, :ZONA, :TIPO_CONTRATISTA, :DEPARTAMENTO, :VLRMAXCARTERA, :KPROVEEDOR, :CIUDAD, :NOAPORTAPENSION, :CODIGORUP, :AUTORETENEDOR, :LEY1450, :LEY1819, :PAIS, :PORCDESCUENTO, :ACTIVIDAD, :CODIGOICA, :MEDPREPAGADA, TO_DATE(:FECHAULTIMAFACTURA,'DD/MM/YYYY HH24:MI:SS'), :CODIGO_PROPONENTE, :KCONSTRUCTOR, :TIPOID, :IBC, :DIRECCIONWEB, :VALORULTIMAFACTURA, :EXPEDIDAENREPRESENTANTE, :UNIDAD, :CONTACTO, :CARGO, :NITAPODERADO, :DETERIORO, :PRMD_CARTERA, :APLICADESCUENTO, :REGISTROMERCANTIL, :PAGOELECTRONICO, :PROPIETARIO, :TARJETAPROFESIONAL, :EMBARGO, TO_DATE(:FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS'), :NATURALEZA, :NIT, :MAX_CREDITO, :CARGOREPRESENTANTE, :DIRECCIONEMAIL, :DIRECCION, :ESTADO, :COMPANIA, :SUCURSALAPODERADO, :IND_INTERVENTOR, :NOMBRE1, :CLASEENTIDADOFICIAL, :KCONSULTORING, :NOMBRE2, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, :IND_PAGO_RETENCION, :IND_REPORTAR_2276, :CODIGOPOSTAL, :DIRECCIONFISCAL, :TIPOENTIDAD, :NUMEROLISTA, :PERIOCIDAD, :IND_PERSONANIT, :GENERO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param defaultValue="" name="NRODOCUMENTO_EMBARGO" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONOS" sqlType="STRING"/>
		<param defaultValue="0" name="AFC" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="SUCURSAL_VEND" sqlType="STRING"/>
		<param defaultValue="" name="CIUDADDEREGISTRO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_EMBARGO" sqlType="STRING"/>
		<param defaultValue="" name="CAMARA_COMERCIO" sqlType="STRING"/>
		<param defaultValue="0" name="DEDUCIBLE_VIVIENDA" sqlType="STRING"/>
		<param defaultValue="" name="ORDEN" sqlType="STRING"/>
