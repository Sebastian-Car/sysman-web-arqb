	<query id="getTercerosNumTodosTerceroInicialPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TERCERO.NOMBRE, TERCERO.NIT, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA AND TERCERO.NIT &gt;= :TERCEROINICIAL ORDER BY TERCERO.NOMBRE, TERCERO.COMPANIA) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
