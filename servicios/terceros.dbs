	<query id="getTercerosPagDatosTerceroCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NIT, NOMBRE, DIRECCION, TELEFONOS, DIRECCIONEMAIL, NOMBRE1, NOMBRE2, APELLIDO1, APELLIDO2,SUCURSAL FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","DIRECCIONEMAIL":"$DIRECCIONEMAIL","NOMBRE1":"$NOMBRE1","NOMBRE2":"$NOMBRE2","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
