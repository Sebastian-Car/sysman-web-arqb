	<resource method="POST" path="terceros">
		<call-query href="insertTerceros">
			<with-param name="NRODOCUMENTO_EMBARGO" query-param="NRODOCUMENTO_EMBARGO"/>
			<with-param name="TELEFONOS" query-param="TELEFONOS"/>
			<with-param name="AFC" query-param="AFC"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="SUCURSAL_VEND" query-param="SUCURSAL_VEND"/>
			<with-param name="CIUDADDEREGISTRO" query-param="CIUDADDEREGISTRO"/>
			<with-param name="TIPO_EMBARGO" query-param="TIPO_EMBARGO"/>
			<with-param name="CAMARA_COMERCIO" query-param="CAMARA_COMERCIO"/>
			<with-param name="DEDUCIBLE_VIVIENDA" query-param="DEDUCIBLE_VIVIENDA"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="CARGO_CONTACTO" query-param="CARGO_CONTACTO"/>
			<with-param name="TIPOSOCIEDAD" query-param="TIPOSOCIEDAD"/>
			<with-param name="NIT_CEDULA" query-param="NIT_CEDULA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="APELLIDO1" query-param="APELLIDO1"/>
			<with-param name="FUERZA" query-param="FUERZA"/>
			<with-param name="DIAS_PRMD_CARTERA" query-param="DIAS_PRMD_CARTERA"/>
			<with-param name="KCONSULTOR" query-param="KCONSULTOR"/>
