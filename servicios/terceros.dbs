	<query id="getTercerosPagTodosFinalPorNombreOrdenadosPorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TRIM(UPPER(TERCERO.NOMBRE))NOMBRE, TERCERO.NIT, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA AND TERCERO.NIT &gt;= :TERCEROINICIAL ORDER BY TERCERO.COMPANIA, TERCERO.NIT, TERCERO.SUCURSAL) WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","NIT":"$NIT","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROINICIAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/todosfinalpornombreordenadosporcodigo/pag">
		<call-query href="getTercerosPagTodosFinalPorNombreOrdenadosPorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCEROINICIAL" query-param="TERCEROINICIAL"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
