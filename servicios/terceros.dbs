	<query id="updateTercerosCambioDeNombreATerceros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TERCERO SET NOMBRE1 = :NOMBRENUEVO, NOMBRE2 = NULL, APELLIDO1=NULL, APELLIDO2=NULL,DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),MODIFIED_BY=:MODIFIED_BY WHERE TERCERO.COMPANIA= :KEY_COMPANIA AND TERCERO.NIT= :KEY_NITANTERIOR AND TERCERO.SUCURSAL= :KEY_SUCURSALANTERIOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRENUEVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NITANTERIOR" sqlType="STRING"/>
		<param name="KEY_SUCURSALANTERIOR" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="terceros/cambiodenombreaterceros">
		<call-query href="updateTercerosCambioDeNombreATerceros">
