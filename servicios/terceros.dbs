	<query id="deleteTerceros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TERCERO WHERE TERCERO.COMPANIA= :KEY_COMPANIA AND TERCERO.NIT= :KEY_NIT AND TERCERO.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="terceros">
		<call-query href="deleteTerceros">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getTercerosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TERCERO.COMPANIA, TERCERO.NIT, TERCERO.NOMBRE, TERCERO.DIRECCION, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA ORDER BY TERCERO.NIT, TERCERO.SUCURSAL, TERCERO.COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros">
		<call-query href="getTercerosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTercerosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TERCERO.COMPANIA, TERCERO.NIT, TERCERO.NOMBRE, TERCERO.DIRECCION, TERCERO.SUCURSAL  FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA ORDER BY TERCERO.NIT, TERCERO.SUCURSAL, TERCERO.COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/numero">
		<call-query href="getTercerosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>

		</call-query>
	</resource>
	<query id="getTercerosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, NIT, SUCURSAL, NIT_CEDULA, PROPIETARIO, PAIS, DEPARTAMENTO, CIUDAD, DIRECCION, REGIMEN,(CASE AUTORETENEDOR WHEN 0 THEN 'false' ELSE 'true' END) AUTORETENEDOR,(CASE AUTORET_IVA WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_IVA,(CASE AUTORET_ICA WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_ICA,(CASE AUTORET_TBRE WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_TBRE,(CASE AUTORET_PRO WHEN 0 THEN 'false' ELSE 'true' END) AUTORET_PRO, KCONSTRUCTOR, KCONSULTORING, KCONSULTOR, KPROVEEDOR, TELEFONOS, FAX, CONTACTO, CARGO_CONTACTO, CLASE, TIPO_ASOCIADO, ZONA, MAX_CREDITO, PRMD_CARTERA, DIAS_PRMD_CARTERA, VLRMAXCARTERA, VENDEDOR, SUCURSAL_VEND, FORMADEPAGO,(TO_CHAR(FECHAULTIMAFACTURA,'DD/MM/YYYY HH24:MI:SS')) FECHAULTIMAFACTURA, VALORULTIMAFACTURA, CODIGOEQUIVALENTE, PORCDESCUENTO,(CASE CLASEENTIDADOFICIAL WHEN 0 THEN 'false' ELSE 'true' END) CLASEENTIDADOFICIAL, CODIGOICA, CALIFICACIONCC,(TO_CHAR(FECHAINSCRIPCIONCC,'DD/MM/YYYY HH24:MI:SS')) FECHAINSCRIPCIONCC, NOMBREREPLEGAL, NOMBREVENDEDOR, DIRECCIONEMAIL, DIRECCIONWEB, NOCAMARACOMERCIO,(TO_CHAR(FECHACAMARACOMERCIO,'DD/MM/YYYY HH24:MI:SS')) FECHACAMARACOMERCIO, CEDULAREPRESENTANTE, EXPEDIDAENREPRESENTANTE, CARGOREPRESENTANTE, TARJETAPROFESIONAL, REGISTROMERCANTIL, CIUDADDEREGISTRO, ACTIVIDAD, NATURALEZA, TIPOID, TIPOSOCIEDAD, NITAPODERADO, SUCURSALAPODERADO, TRIM(NOMBRE1) NOMBRE1, NOMBRE2, APELLIDO1, APELLIDO2, PAIS_EXPE, DEPARTAMENTO_EXPE, CIUDAD_EXPE,EXPEDIDACEDULA,(CASE ANTECEDENTES WHEN 0 THEN 'false' ELSE 'true' END) ANTECEDENTES, TIPO_TERCERO,(CASE APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO, CODIGOSCHIP,(CASE EMBARGO WHEN 0 THEN 'false' ELSE 'true' END) EMBARGO,(CASE PAGOELECTRONICO WHEN 0 THEN 'false' ELSE 'true' END) PAGOELECTRONICO,(CASE LEY1450 WHEN 0 THEN 'false' ELSE 'true' END) LEY1450,(CASE LEY1819 WHEN 0 THEN 'false' ELSE 'true' END) LEY1819, IBC, APORTESVOLUNTARIOS, TIPO_CONTRATISTA,(CASE IND_INTERVENTOR WHEN 0 THEN 'false' ELSE 'true' END) IND_INTERVENTOR, CODIGO_PROPONENTE, CAMARA_COMERCIO,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO, TIPO_EMBARGO, AFC, UNIDAD, GRADO, FUERZA,(TO_CHAR(FECHA_EMBARGO,'DD/MM/YYYY HH24:MI:SS')) FECHA_EMBARGO, VALOR_EMBARGO, NRODOCUMENTO_EMBARGO,(CASE RETENEDORIVA WHEN 0 THEN 'false' ELSE 'true' END) RETENEDORIVA,(CASE RETENEDORICA WHEN 0 THEN 'false' ELSE 'true' END) RETENEDORICA, CODIGORUP,(CASE DECLARARENTA WHEN 0 THEN 'false' ELSE 'true' END) DECLARARENTA,(CASE DEPENDIENTE WHEN 0 THEN 'false' ELSE 'true' END) DEPENDIENTE, DEDUCIBLE_VIVIENDA, MEDPREPAGADA, CODIGOPOSTAL, INFORMACION_ADICIONAL, APORTESARL,(CASE NOAPORTASALUD WHEN 0 THEN 'false' ELSE 'true' END) NOAPORTASALUD,(CASE NOAPORTAPENSION WHEN 0 THEN 'false' ELSE 'true' END) NOAPORTAPENSION, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, VINCULACION, NOMBRE, ESTADO, ORDEN, DIGITOVERIFICACION,(CASE DETERIORO WHEN 0 THEN 'false' ELSE 'true' END) DETERIORO,(CASE IND_PAGO_RETENCION WHEN 0 THEN 'false' ELSE 'true' END) IND_PAGO_RETENCION,(CASE IND_REPORTAR_2276 WHEN 0 THEN 'false' ELSE 'true' END) IND_REPORTAR_2276, DIRECCIONFISCAL,TIPOENTIDAD,NUMEROLISTA,PERIOCIDAD,CARGO,(CASE IND_PERSONANIT WHEN 0 THEN 'false' ELSE 'true' END) IND_PERSONANIT, GENERO FROM TERCERO WHERE TERCERO.COMPANIA= :KEY_COMPANIA AND TERCERO.NIT= :KEY_NIT AND TERCERO.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","SUCURSAL":"$SUCURSAL","NIT_CEDULA":"$NIT_CEDULA","PROPIETARIO":"$PROPIETARIO","PAIS":"$PAIS","DEPARTAMENTO":"$DEPARTAMENTO","CIUDAD":"$CIUDAD","DIRECCION":"$DIRECCION","REGIMEN":"$REGIMEN","AUTORETENEDOR":"$AUTORETENEDOR(type:boolean)","AUTORET_IVA":"$AUTORET_IVA(type:boolean)","AUTORET_ICA":"$AUTORET_ICA(type:boolean)","AUTORET_TBRE":"$AUTORET_TBRE(type:boolean)","AUTORET_PRO":"$AUTORET_PRO(type:boolean)","KCONSTRUCTOR":"$KCONSTRUCTOR","KCONSULTORING":"$KCONSULTORING","KCONSULTOR":"$KCONSULTOR","KPROVEEDOR":"$KPROVEEDOR","TELEFONOS":"$TELEFONOS","FAX":"$FAX","CONTACTO":"$CONTACTO","CARGO_CONTACTO":"$CARGO_CONTACTO","CLASE":"$CLASE","TIPO_ASOCIADO":"$TIPO_ASOCIADO","ZONA":"$ZONA","MAX_CREDITO":"$MAX_CREDITO","PRMD_CARTERA":"$PRMD_CARTERA","DIAS_PRMD_CARTERA":"$DIAS_PRMD_CARTERA","VLRMAXCARTERA":"$VLRMAXCARTERA","VENDEDOR":"$VENDEDOR","SUCURSAL_VEND":"$SUCURSAL_VEND","FORMADEPAGO":"$FORMADEPAGO","FECHAULTIMAFACTURA":"$FECHAULTIMAFACTURA","VALORULTIMAFACTURA":"$VALORULTIMAFACTURA","CODIGOEQUIVALENTE":"$CODIGOEQUIVALENTE","PORCDESCUENTO":"$PORCDESCUENTO","CLASEENTIDADOFICIAL":"$CLASEENTIDADOFICIAL(type:boolean)","CODIGOICA":"$CODIGOICA","CALIFICACIONCC":"$CALIFICACIONCC","FECHAINSCRIPCIONCC":"$FECHAINSCRIPCIONCC","NOMBREREPLEGAL":"$NOMBREREPLEGAL","NOMBREVENDEDOR":"$NOMBREVENDEDOR","DIRECCIONEMAIL":"$DIRECCIONEMAIL","DIRECCIONWEB":"$DIRECCIONWEB","NOCAMARACOMERCIO":"$NOCAMARACOMERCIO","FECHACAMARACOMERCIO":"$FECHACAMARACOMERCIO","CEDULAREPRESENTANTE":"$CEDULAREPRESENTANTE","EXPEDIDAENREPRESENTANTE":"$EXPEDIDAENREPRESENTANTE","CARGOREPRESENTANTE":"$CARGOREPRESENTANTE","TARJETAPROFESIONAL":"$TARJETAPROFESIONAL","REGISTROMERCANTIL":"$REGISTROMERCANTIL","CIUDADDEREGISTRO":"$CIUDADDEREGISTRO","ACTIVIDAD":"$ACTIVIDAD","NATURALEZA":"$NATURALEZA","TIPOID":"$TIPOID","TIPOSOCIEDAD":"$TIPOSOCIEDAD","NITAPODERADO":"$NITAPODERADO","SUCURSALAPODERADO":"$SUCURSALAPODERADO","NOMBRE1":"$NOMBRE1","NOMBRE2":"$NOMBRE2","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","PAIS_EXPE":"$PAIS_EXPE","DEPARTAMENTO_EXPE":"$DEPARTAMENTO_EXPE","CIUDAD_EXPE":"$CIUDAD_EXPE","EXPEDIDACEDULA":"$EXPEDIDACEDULA","ANTECEDENTES":"$ANTECEDENTES(type:boolean)","TIPO_TERCERO":"$TIPO_TERCERO","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","CODIGOSCHIP":"$CODIGOSCHIP","EMBARGO":"$EMBARGO(type:boolean)","PAGOELECTRONICO":"$PAGOELECTRONICO(type:boolean)","LEY1450":"$LEY1450(type:boolean)","LEY1819":"$LEY1819(type:boolean)","IBC":"$IBC","APORTESVOLUNTARIOS":"$APORTESVOLUNTARIOS","TIPO_CONTRATISTA":"$TIPO_CONTRATISTA(type:integer)","IND_INTERVENTOR":"$IND_INTERVENTOR(type:boolean)","CODIGO_PROPONENTE":"$CODIGO_PROPONENTE","CAMARA_COMERCIO":"$CAMARA_COMERCIO","ACTIVO":"$ACTIVO(type:boolean)","TIPO_EMBARGO":"$TIPO_EMBARGO","AFC":"$AFC","UNIDAD":"$UNIDAD(type:integer)","GRADO":"$GRADO","FUERZA":"$FUERZA","FECHA_EMBARGO":"$FECHA_EMBARGO","VALOR_EMBARGO":"$VALOR_EMBARGO","NRODOCUMENTO_EMBARGO":"$NRODOCUMENTO_EMBARGO","RETENEDORIVA":"$RETENEDORIVA(type:boolean)","RETENEDORICA":"$RETENEDORICA(type:boolean)","CODIGORUP":"$CODIGORUP","DECLARARENTA":"$DECLARARENTA(type:boolean)","DEPENDIENTE":"$DEPENDIENTE(type:boolean)","DEDUCIBLE_VIVIENDA":"$DEDUCIBLE_VIVIENDA","MEDPREPAGADA":"$MEDPREPAGADA","CODIGOPOSTAL":"$CODIGOPOSTAL","INFORMACION_ADICIONAL":"$INFORMACION_ADICIONAL","APORTESARL":"$APORTESARL","NOAPORTASALUD":"$NOAPORTASALUD(type:boolean)","NOAPORTAPENSION":"$NOAPORTAPENSION(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","VINCULACION":"$VINCULACION","NOMBRE":"$NOMBRE","ESTADO":"$ESTADO","ORDEN":"$ORDEN","DIGITOVERIFICACION":"$DIGITOVERIFICACION(type:long)","DETERIORO":"$DETERIORO(type:boolean)","IND_PAGO_RETENCION":"$IND_PAGO_RETENCION(type:boolean)","IND_REPORTAR_2276":"$IND_REPORTAR_2276(type:boolean)","DIRECCIONFISCAL":"$DIRECCIONFISCAL","TIPOENTIDAD":"$TIPOENTIDAD","NUMEROLISTA":"$NUMEROLISTA","PERIOCIDAD":"$PERIOCIDAD(type:integer)","CARGO":"$CARGO","IND_PERSONANIT":"$IND_PERSONANIT(type:boolean)","GENERO":"$GENERO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
