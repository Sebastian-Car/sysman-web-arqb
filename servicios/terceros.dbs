	<query id="getTercerosPagNombresDeConductoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NIT, (CONCAT(NOMBRE1,CONCAT(' ', NOMBRE2)) ) NOMBRES, (CONCAT(APELLIDO1 ,CONCAT(' ' , APELLIDO2)) ) APELLIDOS, NOMBRE1, NOMBRE2, APELLIDO1, APELLIDO2 FROM TERCERO WHERE COMPANIA =:COMPANIA AND ESTADO IN CASE WHEN :OPCION IS NULL THEN ESTADO ELSE :OPCION END AND CONDUCTOR IN ( 0 ) ORDER BY 1) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN APELLIDOS IS NULL THEN ' ' ELSE UPPER(APELLIDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDOS), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRES":"$NOMBRES","APELLIDOS":"$APELLIDOS","NOMBRE1":"$NOMBRE1","NOMBRE2":"$NOMBRE2","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="OPCION" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="APELLIDOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="terceros/nombresdeconductores/pag">
		<call-query href="getTercerosPagNombresDeConductoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="OPCION" query-param="OPCION"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="APELLIDOS" query-param="APELLIDOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTercerosNumNombresDeConductoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NIT, (CONCAT(NOMBRE1,CONCAT(' ', NOMBRE2)) ) NOMBRES, (CONCAT(APELLIDO1 ,CONCAT(' ' , APELLIDO2)) ) APELLIDOS, NOMBRE1, NOMBRE2, APELLIDO1, APELLIDO2 FROM TERCERO WHERE COMPANIA =:COMPANIA AND ESTADO IN CASE WHEN :OPCION IS NULL THEN ESTADO ELSE :OPCION END AND CONDUCTOR IN ( 0 ) ORDER BY 1) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN APELLIDOS IS NULL THEN ' ' ELSE UPPER(APELLIDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDOS), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="OPCION" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="APELLIDOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="terceros/nombresdeconductores/num">
