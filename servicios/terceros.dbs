	<query id="getTercerosPagTodosLosDatosPersonalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TERCERO.NIT, TERCERO.NOMBRE, TERCERO.SUCURSAL, TERCERO.DIRECCION, TERCERO.CODIGOPOSTAL, TERCERO.TELEFONOS, TERCERO.DIRECCIONEMAIL FROM TERCERO WHERE TERCERO.COMPANIA = :COMPANIA ORDER BY TERCERO.NIT) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) AND (CASE WHEN CODIGOPOSTAL IS NULL THEN ' ' ELSE UPPER(CODIGOPOSTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPOSTAL), '%')) AND (CASE WHEN TELEFONOS IS NULL THEN ' ' ELSE UPPER(TELEFONOS) END) LIKE UPPER(CONCAT(CONCAT('%',:TELEFONOS), '%')) AND (CASE WHEN DIRECCIONEMAIL IS NULL THEN ' ' ELSE UPPER(DIRECCIONEMAIL) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCIONEMAIL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL","DIRECCION":"$DIRECCION","CODIGOPOSTAL":"$CODIGOPOSTAL","TELEFONOS":"$TELEFONOS","DIRECCIONEMAIL":"$DIRECCIONEMAIL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="CODIGOPOSTAL" sqlType="STRING"/>
		<param name="TELEFONOS" sqlType="STRING"/>
		<param name="DIRECCIONEMAIL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
