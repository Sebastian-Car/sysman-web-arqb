	<query id="getTercerosPagTodosTerceroSucursalActivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TERCEROPAGOS.BANCO, TERCEROPAGOS.CUENTA, BANCO.NOMBREBANCO, TO_CHAR(TERCEROPAGOS.FECHAAUTORIZACION, 'DD/MM/YYYY') FECHAAUTORIZACION, TRIM(TERCERO_1.NOMBRE) NOMBRE,TERCEROPAGOS.COMPANIA,TERCEROPAGOS.NIT, TERCEROPAGOS.SUCURSAL  FROM (TERCERO LEFT JOIN ( TERCEROPAGOS LEFT JOIN BANCO ON TERCEROPAGOS.BANCO = BANCO.BANCO AND TERCEROPAGOS.COMPANIA = BANCO.COMPANIA) ON TERCERO.NITAPODERADO = TERCEROPAGOS.NIT AND TERCERO.SUCURSALAPODERADO = TERCEROPAGOS.SUCURSAL AND TERCERO.COMPANIA = TERCEROPAGOS.COMPANIA) LEFT JOIN TERCERO TERCERO_1 ON TERCEROPAGOS.COMPANIA = TERCERO_1.COMPANIA AND TERCEROPAGOS.NIT = TERCERO_1.NIT AND TERCEROPAGOS.SUCURSAL = TERCERO_1.SUCURSAL WHERE TERCERO.COMPANIA = :COMPANIA AND TERCERO.NIT = :TERCERO AND TERCERO.SUCURSAL = :SUCURSAL AND TERCEROPAGOS.ACTIVA &lt;&gt;0 ORDER BY TERCERO.COMPANIA, TERCERO.NIT, TERCERO.SUCURSAL, TERCEROPAGOS.FECHAAUTORIZACION DESC) WHERE (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END)  LIKE UPPER(:BANCO || '%')  AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END)  LIKE UPPER(:CUENTA || '%')  AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END)  LIKE UPPER( '%' || :NOMBREBANCO || '%')  AND (CASE WHEN FECHAAUTORIZACION IS NULL THEN ' ' ELSE UPPER(FECHAAUTORIZACION) END)  LIKE UPPER(:FECHAAUTORIZACION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BANCO":"$BANCO","CUENTA":"$CUENTA","NOMBREBANCO":"$NOMBREBANCO","FECHAAUTORIZACION":"$FECHAAUTORIZACION","NOMBRE":"$NOMBRE","COMPANIA":"$COMPANIA","NIT":"$NIT","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="FECHAAUTORIZACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
