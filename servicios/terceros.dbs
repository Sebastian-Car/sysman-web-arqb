	<query id="getTercerosTerceroporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TERCERO.NIT, TERCERO.NOMBRE, TERCERO.SUCURSAL  FROM TERCERO WHERE (((TERCERO.COMPANIA)=:COMPANIA)) ORDER BY TERCERO.NIT, TERCERO.SUCURSAL, TERCERO.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
