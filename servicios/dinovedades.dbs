<data name="dinovedades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDinovedades" keyColumns="COMPANIA,CLASEORDEN,NUMERO,ORDENDECOMPRA,NOVEDAD,CLASET,TIPOT" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DI_NOVEDADES (COMPANIA, CLASEORDEN, NUMERO, ORDENDECOMPRA, NOVEDAD, CLASET, TIPOT, ANO, CONSECUTIVO, ARCHIVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :NUMERO, :ORDENDECOMPRA, :NOVEDAD, :CLASET, :TIPOT, :ANO, :CONSECUTIVO, :ARCHIVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_NUMERO":"$NUMERO","KEY_ORDENDECOMPRA":"$ORDENDECOMPRA","KEY_NOVEDAD":"$NOVEDAD","KEY_CLASET":"$CLASET","KEY_TIPOT":"$TIPOT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="ORDENDECOMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="NOVEDAD" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ARCHIVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dinovedades">
		<call-query href="insertDinovedades">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDinovedades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DI_NOVEDADES WHERE DI_NOVEDADES.COMPANIA= :KEY_COMPANIA AND DI_NOVEDADES.CLASEORDEN= :KEY_CLASEORDEN AND DI_NOVEDADES.NUMERO= :KEY_NUMERO AND DI_NOVEDADES.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND DI_NOVEDADES.NOVEDAD= :KEY_NOVEDAD AND DI_NOVEDADES.CLASET= :KEY_CLASET AND DI_NOVEDADES.TIPOT= :KEY_TIPOT AND DI_NOVEDADES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>
		<param name="KEY_CLASET" sqlType="STRING"/>
		<param name="KEY_TIPOT" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dinovedades">
		<call-query href="deleteDinovedades">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ORDENDECOMPRA" query-param="KEY_ORDENDECOMPRA"/>
			<with-param name="KEY_NOVEDAD" query-param="KEY_NOVEDAD"/>
			<with-param name="KEY_CLASET" query-param="KEY_CLASET"/>
			<with-param name="KEY_TIPOT" query-param="KEY_TIPOT"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDinovedadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CLASEORDEN, NUMERO, ORDENDECOMPRA, NOVEDAD, CLASET, TIPOT, ANO, CONSECUTIVO, ARCHIVO FROM DI_NOVEDADES WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND NUMERO = :NUMERO AND ORDENDECOMPRA = :ORDENDECOMPRA AND NOVEDAD = :NOVEDAD AND CLASET = :CLASET AND TIPOT = :TIPOT ORDER BY ARCHIVO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASEORDEN), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN ORDENDECOMPRA IS NULL THEN ' ' ELSE UPPER(ORDENDECOMPRA) END) LIKE UPPER(CONCAT(CONCAT('%',:ORDENDECOMPRA), '%')) AND (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOVEDAD), '%')) AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASET), '%')) AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOT), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO), '%')) AND (CASE WHEN ARCHIVO IS NULL THEN ' ' ELSE UPPER(ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:ARCHIVO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","NUMERO":"$NUMERO","ORDENDECOMPRA":"$ORDENDECOMPRA","NOVEDAD":"$NOVEDAD","CLASET":"$CLASET","TIPOT":"$TIPOT","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO","ARCHIVO":"$ARCHIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ARCHIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dinovedades">
		<call-query href="getDinovedadesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDinovedadesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CLASEORDEN, NUMERO, ORDENDECOMPRA, NOVEDAD, CLASET, TIPOT, ANO, CONSECUTIVO, ARCHIVO FROM DI_NOVEDADES WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND NUMERO = :NUMERO AND ORDENDECOMPRA = :ORDENDECOMPRA AND NOVEDAD = :NOVEDAD AND CLASET = :CLASET AND TIPOT = :TIPOT ORDER BY ARCHIVO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASEORDEN), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN ORDENDECOMPRA IS NULL THEN ' ' ELSE UPPER(ORDENDECOMPRA) END) LIKE UPPER(CONCAT(CONCAT('%',:ORDENDECOMPRA), '%')) AND (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOVEDAD), '%')) AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASET), '%')) AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOT), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO), '%')) AND (CASE WHEN ARCHIVO IS NULL THEN ' ' ELSE UPPER(ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:ARCHIVO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ARCHIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dinovedades/numero">
		<call-query href="getDinovedadesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ARCHIVO" query-param="ARCHIVO"/>

		</call-query>
	</resource>

</data>