VALOR ELSE 0 END) NIE193, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE194' THEN H.VALOR ELSE 0 END) NIE194, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE195' THEN H.VALOR ELSE 0 END) NIE195, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE196' THEN H.VALOR ELSE 0 END) NIE196, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE197' THEN H.VALOR ELSE 0 END) NIE197, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE198' THEN H.VALOR ELSE 0 END) NIE198, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE201' THEN H.VALOR ELSE 0 END) NIE201 FROM HISTORICOS H INNER JOIN CONCEPTOS C ON H.ID_DE_CONCEPTO = C.ID_DE_CONCEPTO AND H.COMPANIA = C.COMPANIA INNER JOIN PERSONAL PER ON H.ID_DE_EMPLEADO = PER.ID_DE_EMPLEADO AND H.COMPANIA = PER.COMPANIA INNER JOIN PERIODOS P ON H.PERIODO = P.PERIODO AND H.MES = P.MES AND H.ANO = P.ANO AND H.ID_DE_PROCESO = P.ID_DE_PROCESO AND H.COMPANIA = P.COMPANIA INNER JOIN COMPANIA ON H.COMPANIA = COMPANIA.CODIGO WHERE H.COMPANIA = :UN_COMPANIA AND H.ANO = :UN_ANO AND H.MES = :UN_MES AND C.CONCEPTO_CUNE IS NOT NULL AND P.ACUMULADO NOT IN (0) AND H.ID_DE_PROCESO &lt;&gt; '99' AND PER.GENERACUNE NOT IN (0) AND COMPANIA.GENERA_CUNE NOT IN (0) GROUP BY PER.NOMBRECOMPLETO, H.ANO, H.MES, PER.NUMERO_DCTO, H.COMPANIA ORDER BY PER.NOMBRECOMPLETO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANOMBRES":"$ANOMBRES","BANO":"$BANO(type:integer)","CMES":"$CMES(type:integer)","DNUMERO_DCTO":"$DNUMERO_DCTO","CTOTALDIAS":"$CTOTALDIAS(type:integer)","NIE009":"$NIE009(type:integer)","NIE062":"$NIE062(type:double)","NIE069":"$NIE069(type:integer)","NIE070":"$NIE070(type:integer)","NIE071":"$NIE071(type:integer)","NIE072":"$NIE072(type:integer)","NIE073":"$NIE073(type:integer)","NIE076":"$NIE076(type:double)","NIE078":"$NIE078(type:integer)","NIE081":"$NIE081(type:double)","NIE083":"$NIE083(type:integer)","NIE086":"$NIE086(type:double)","NIE088":"$NIE088(type:integer)","NIE091":"$NIE091(type:double)","NIE093":"$NIE093(type:integer)","NIE096":"$NIE096(type:double)","NIE098":"$NIE098(type:integer)","NIE101":"$NIE101(type:double)","NIE103":"$NIE103(type:integer)","NIE106":"$NIE106(type:double)","NIE108":"$NIE108(type:integer)","NIE111":"$NIE111(type:double)","NIE112":"$NIE112(type:integer)","NIE115":"$NIE115(type:double)","NIE116":"$NIE116(type:integer)","NIE117":"$NIE117(type:integer)","NIE118":"$NIE118(type:integer)","NIE119":"$NIE119(type:integer)","NIE120":"$NIE120(type:integer)","NIE122":"$NIE122(type:integer)","NIE125":"$NIE125(type:integer)","NIE127":"$NIE127(type:integer)","NIE130":"$NIE130(type:integer)","NIE131":"$NIE131(type:integer)","NIE134":"$NIE134(type:integer)","NIE135":"$NIE135(type:integer)","NIE138":"$NIE138(type:integer)","NIE139":"$NIE139(type:integer)","NIE140":"$NIE140(type:integer)","NIE141":"$NIE141(type:integer)","NIE142":"$NIE142(type:integer)","NIE145":"$NIE145(type:integer)","NIE147":"$NIE147(type:integer)","NIE148":"$NIE148(type:integer)","NIE149":"$NIE149(type:integer)","NIE150":"$NIE150(type:integer)","NIE151":"$NIE151(type:integer)","NIE152":"$NIE152(type:integer)","NIE153":"$NIE153(type:integer)","NIE154":"$NIE154(type:integer)","NIE155":"$NIE155(type:integer)","NIE156":"$NIE156(type:integer)","NIE157":"$NIE157(type:integer)","NIE158":"$NIE158(type:integer)","NIE159":"$NIE159(ty