<data name="historicos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="deleteHistoricosBorrarHistoricosPorEmpleado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM HISTORICOS WHERE HISTORICOS.COMPANIA    = :COMPANIA AND HISTORICOS.ID_DE_PROCESO = :PROCESO AND HISTORICOS.ANO           = :ANO AND HISTORICOS.MES           = :MES AND HISTORICOS.PERIODO       = :PERIODO AND HISTORICOS.ID_DE_EMPLEADO= :ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="historicos/borrarhistoricosporempleado">
		<call-query href="deleteHistoricosBorrarHistoricosPorEmpleado">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="deleteHistoricosTodosOprCompaniaIdProcesoEmpleado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM HISTORICOS WHERE HISTORICOS.COMPANIA              = :COMPANIA AND HISTORICOS.ID_DE_PROCESO          = :ID_DE_PROCESO AND HISTORICOS.ANO=:ANO AND HISTORICOS.MES=:MES AND HISTORICOS.PERIODO=:PERIODO AND HISTORICOS.ID_DE_EMPLEADO=:ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="historicos/todosoprcompaniaidprocesoempleado">
		<call-query href="deleteHistoricosTodosOprCompaniaIdProcesoEmpleado">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getHistoricosSumavalorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT Sum(Historicos.Valor) AS SumaConcepto_  FROM Historicos LEFT JOIN periodos ON (Historicos.COMPANIA = periodos.COMPANIA) AND (Historicos.ID_DE_PROCESO = periodos.ID_DE_PROCESO) AND (Historicos.ANO = periodos.ANO) AND (Historicos.MES = periodos.MES) AND (Historicos.PERIODO = periodos.PERIODO) WHERE Historicos.COMPANIA = :COMPANIA AND periodos.ACUMULADO = -1 AND Historicos.ID_DE_EMPLEADO= :CODIGO AND HISTORICOS.ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND HISTORICOS.MES BETWEEN :MESINICIAL AND :MESFINAL AND HISTORICOS.PERIODO BETWEEN :PERIODOINICIAL AND :PERIODOFINAL AND Historicos.ID_DE_CONCEPTO= :CONCEPTO AND Historicos.VALOR &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMACONCEPTO_":"$SUMACONCEPTO_(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="PERIODOINICIAL" sqlType="STRING"/>
		<param name="PERIODOFINAL" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historicos/sumavalor">
		<call-query href="getHistoricosSumavalorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="MESINICIAL" query-param="MESINICIAL"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>
			<with-param name="PERIODOINICIAL" query-param="PERIODOINICIAL"/>
			<with-param name="PERIODOFINAL" query-param="PERIODOFINAL"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getHistoricosSumavalorpornoceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(HISTORICOS.VALOR) AS SUMACONCEPTO  FROM HISTORICOS INNER JOIN PERIODOS ON (HISTORICOS.COMPANIA=PERIODOS.COMPANIA) AND (HISTORICOS.ID_DE_PROCESO = PERIODOS.ID_DE_PROCESO) AND (HISTORICOS.ANO = PERIODOS.ANO) AND (HISTORICOS.MES = PERIODOS.MES) AND PERIODOS.ANO = HISTORICOS.ANO AND PERIODOS.MES = HISTORICOS.MES AND PERIODOS.PERIODO = HISTORICOS.PERIODO WHERE HISTORICOS.COMPANIA = :COMPANIA AND HISTORICOS.ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND HISTORICOS.MES BETWEEN :MESINICIAL AND :MESFINAL AND HISTORICOS.PERIODO BETWEEN :PERIODOINICIAL AND :PERIODOFINAL AND HISTORICOS.ID_DE_EMPLEADO = :CODIGO AND HISTORICOS.ID_DE_CONCEPTO= :CONCEPTO AND PERIODOS.ACUMULADO NOT IN (0) AND HISTORICOS.VALOR NOT IN (0) GROUP BY HISTORICOS.ANO,HISTORICOS.MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMACONCEPTO":"$SUMACONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="PERIODOINICIAL" sqlType="STRING"/>
		<param name="PERIODOFINAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historicos/sumavalorpornocero">
		<call-query href="getHistoricosSumavalorpornoceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="MESINICIAL" query-param="MESINICIAL"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>
			<with-param name="PERIODOINICIAL" query-param="PERIODOINICIAL"/>
			<with-param name="PERIODOFINAL" query-param="PERIODOFINAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="deleteHistoricosTodosporempleadocalculo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE  FROM HISTORICOS WHERE HISTORICOS.COMPANIA          = :COMPANIA AND HISTORICOS.ID_DE_PROCESO       =:PROCESO AND HISTORICOS.ANO                 =:ANO AND HISTORICOS.MES                 =:MES AND HISTORICOS.PERIODO             =:PERIODO AND HISTORICOS.ID_DE_EMPLEADO IN  (       SELECT DISTINCT PERSONAL.ID_DE_EMPLEADO       FROM   PERSONAL, PERIODOS       WHERE PERSONAL.COMPANIA = :COMPANIA       AND PERSONAL.ID_DE_EMPLEADO BETWEEN :EMPINICIAL AND :EMPFINAL       AND PERSONAL.DEPENDENCIA BETWEEN :DEPENDENCIAINI AND :DEPENDENCIAFIN       AND PERSONAL.ID_DE_TIPO BETWEEN :TIPOINI AND :TIPOFIN       AND PERSONAL.ID_CENTRO_DE_COSTO BETWEEN :CENTROINI  AND :CENTROFIN       AND PERIODOS.COMPANIA            =:COMPANIA       AND PERIODOS.ID_DE_PROCESO       =:PROCESO       AND PERIODOS.ANO                 =:ANO       AND PERIODOS.MES                 =:MES       AND PERIODOS.PERIODO             =:PERIODO       AND ( PERSONAL.FECHA_DE_INGRESO &lt;= PERIODOS.FECHAFINAL       AND PERSONAL.ESTADO_ACTUAL      &lt;&gt; 3        OR PERSONAL.FECHA_DE_RETIRO     &gt;=PERIODOS.FECHAFINAL       AND PERSONAL.FECHA_DE_INGRESO   &lt;=PERIODOS.FECHAINICIO       AND PERSONAL.ESTADO_ACTUAL       = 3 ) )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="EMPINICIAL" sqlType="STRING"/>
		<param name="EMPFINAL" sqlType="STRING"/>
		<param name="DEPENDENCIAINI" sqlType="STRING"/>
		<param name="DEPENDENCIAFIN" sqlType="STRING"/>
		<param name="TIPOINI" sqlType="STRING"/>
		<param name="TIPOFIN" sqlType="STRING"/>
		<param name="CENTROINI" sqlType="STRING"/>
		<param name="CENTROFIN" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="historicos/todosporempleadocalculo">
		<call-query href="deleteHistoricosTodosporempleadocalculo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="EMPINICIAL" query-param="EMPINICIAL"/>
			<with-param name="EMPFINAL" query-param="EMPFINAL"/>
			<with-param name="DEPENDENCIAINI" query-param="DEPENDENCIAINI"/>
			<with-param name="DEPENDENCIAFIN" query-param="DEPENDENCIAFIN"/>
			<with-param name="TIPOINI" query-param="TIPOINI"/>
			<with-param name="TIPOFIN" query-param="TIPOFIN"/>
			<with-param name="CENTROINI" query-param="CENTROINI"/>
			<with-param name="CENTROFIN" query-param="CENTROFIN"/>

		</call-query>
	</resource>
	<query id="insertHistoricosEmpleadocalculo" keyColumns="COMPANIA,ID_DE_PROCESO,ANO,MES,PERIODO,ID_DE_EMPLEADO,ID_DE_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO HISTORICOS (COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO, VALOR, FECHA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_PROCESO, :ANO, :MES, :PERIODO, :ID_DE_EMPLEADO, :ID_DE_CONCEPTO, :VALOR, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_PERIODO":"$PERIODO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="historicos/empleadocalculo">
		<call-query href="insertHistoricosEmpleadocalculo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getHistoricosAcumconceptocalcnominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(HISTORICOS.VALOR) SUMACONCEPTO, COUNT(HISTORICOS.VALOR) CUENTACONCEPTO FROM HISTORICOS LEFT JOIN PERIODOS ON ( HISTORICOS.COMPANIA = PERIODOS.COMPANIA ) AND ( HISTORICOS.ID_DE_PROCESO = PERIODOS.ID_DE_PROCESO ) AND ( HISTORICOS.ANO = PERIODOS.ANO ) AND ( HISTORICOS.MES = PERIODOS.MES ) AND ( HISTORICOS.PERIODO = PERIODOS.PERIODO ) WHERE HISTORICOS.COMPANIA =:COMPANIA AND PERIODOS.ACUMULADO &lt;&gt; 0 AND HISTORICOS.ID_DE_EMPLEADO =:EMPLEADO AND CONCAT( HISTORICOS.ANO , CONCAT( '-' ,CONCAT( HISTORICOS.MES ,CONCAT( '-', HISTORICOS.PERIODO )))) BETWEEN :PERIODOIN AND :PERIODOFIN AND HISTORICOS.ID_DE_CONCEPTO =:CONCEPTO AND HISTORICOS.VALOR &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMACONCEPTO":"$SUMACONCEPTO(type:double)","CUENTACONCEPTO":"$CUENTACONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPLEADO" sqlType="STRING"/>
		<param name="PERIODOIN" sqlType="STRING"/>
		<param name="PERIODOFIN" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historicos/acumconceptocalcnomina">
		<call-query href="getHistoricosAcumconceptocalcnominaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPLEADO" query-param="EMPLEADO"/>
			<with-param name="PERIODOIN" query-param="PERIODOIN"/>
			<with-param name="PERIODOFIN" query-param="PERIODOFIN"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getHistoricosAcumcalcnominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(HISTORICOS.VALOR) SUMACONCEPTO, ID_DE_CONCEPTO FROM HISTORICOS LEFT JOIN PERIODOS ON ( HISTORICOS.COMPANIA = PERIODOS.COMPANIA ) AND ( HISTORICOS.ID_DE_PROCESO = PERIODOS.ID_DE_PROCESO ) AND ( HISTORICOS.ANO = PERIODOS.ANO ) AND ( HISTORICOS.MES = PERIODOS.MES ) AND ( HISTORICOS.PERIODO = PERIODOS.PERIODO ) WHERE HISTORICOS.COMPANIA =:COMPANIA AND PERIODOS.ACUMULADO &lt;&gt; 0 AND HISTORICOS.ID_DE_EMPLEADO =:EMPLEADO AND CONCAT( HISTORICOS.ANO , CONCAT( '-' ,CONCAT( HISTORICOS.MES , CONCAT( '-' , HISTORICOS.PERIODO )))) BETWEEN :PERIODOIN AND :PERIODOFIN GROUP BY ID_DE_CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMACONCEPTO":"$SUMACONCEPTO(type:double)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPLEADO" sqlType="STRING"/>
		<param name="PERIODOIN" sqlType="STRING"/>
		<param name="PERIODOFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historicos/acumcalcnomina">
		<call-query href="getHistoricosAcumcalcnominaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPLEADO" query-param="EMPLEADO"/>
			<with-param name="PERIODOIN" query-param="PERIODOIN"/>
			<with-param name="PERIODOFIN" query-param="PERIODOFIN"/>

		</call-query>
	</resource>
	<query id="getHistoricosPagFondoDeRiesgosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERSONAL.COMPANIA, PERSONAL.ID_DE_EMPLEADO, PERSONAL.DCTO_IDENTIDAD, PERSONAL.NUMERO_DCTO, PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '035' THEN HISTORICOS.VALOR ELSE 0 END) DIASVAC, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '350' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '351' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '352' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '353' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '354' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '355' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '358' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '367' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '368' THEN HISTORICOS.VALOR ELSE 0 END)DIASINCAPACIDAD, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '009' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '011' THEN HISTORICOS.VALOR ELSE 0 END) TOTALDIAS, SUM(SUELDOBASICO.VALOR) SUELDO, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '112' THEN HISTORICOS.VALOR ELSE 0 END) IBC, PATRONALES.FACTOR FACTOR, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '111' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '' THEN HISTORICOS.VALOR ELSE 0 END) COTRIESGOS  FROM HISTORICOS INNER JOIN PERSONAL ON HISTORICOS.COMPANIA = PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN PERSONAL_HISTORICO ON HISTORICOS.ID_DE_EMPLEADO = PERSONAL_HISTORICO.ID_DE_EMPLEADO AND HISTORICOS.MES = PERSONAL_HISTORICO.MES AND HISTORICOS.ANO = PERSONAL_HISTORICO.ANO AND HISTORICOS.ID_DE_PROCESO = PERSONAL_HISTORICO.ID_DE_PROCESO AND HISTORICOS.COMPANIA = PERSONAL_HISTORICO.COMPANIA AND HISTORICOS.PERIODO = PERSONAL_HISTORICO.PERIODO INNER JOIN PATRONALES ON PERSONAL.NUMEROPATRONAL = PATRONALES.SUCURSAL AND PERSONAL.COMPANIA = PATRONALES.COMPANIA LEFT JOIN (SELECT HISTORICOS.COMPANIA, HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO, HISTORICOS.ID_DE_CONCEPTO, HISTORICOS.VALOR FROM HISTORICOS WHERE HISTORICOS.COMPANIA = :COMPANIA AND HISTORICOS.ID_DE_PROCESO = :ID_DE_PROCESO AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND HISTORICOS.PERIODO = :PERIODO AND HISTORICOS.ID_DE_CONCEPTO = 1 )SUELDOBASICO ON HISTORICOS.COMPANIA = SUELDOBASICO.COMPANIA AND HISTORICOS.ID_DE_PROCESO = SUELDOBASICO.ID_DE_PROCESO AND HISTORICOS.ANO = SUELDOBASICO.ANO AND HISTORICOS.MES = SUELDOBASICO.MES AND HISTORICOS.PERIODO = SUELDOBASICO.PERIODO AND HISTORICOS.ID_DE_EMPLEADO = SUELDOBASICO.ID_DE_EMPLEADO AND HISTORICOS.ID_DE_CONCEPTO = SUELDOBASICO.ID_DE_CONCEPTO WHERE HISTORICOS.COMPANIA = :COMPANIA AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND PERSONAL_HISTORICO.FONDO_RIESGOS = :FONDORIESGOS GROUP BY PERSONAL.DCTO_IDENTIDAD, PERSONAL.NUMERO_DCTO, PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES, PATRONALES.FACTOR, PERSONAL_HISTORICO.FONDO_RIESGOS, HISTORICOS.ID_DE_EMPLEADO, PERSONAL.COMPANIA, PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN DCTO_IDENTIDAD IS NULL THEN ' ' ELSE UPPER(DCTO_IDENTIDAD) END)  LIKE UPPER( '%' || :DCTO_IDENTIDAD || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END)  LIKE UPPER( '%' || :APELLIDO1 || '%')  AND (CASE WHEN APELLIDO2 IS NULL THEN ' ' ELSE UPPER(APELLIDO2) END)  LIKE UPPER( '%' || :APELLIDO2 || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN DIASVAC IS NULL THEN ' ' ELSE UPPER(DIASVAC) END)  LIKE UPPER(:DIASVAC || '%')  AND (CASE WHEN DIASINCAPACIDAD IS NULL THEN ' ' ELSE UPPER(DIASINCAPACIDAD) END)  LIKE UPPER(:DIASINCAPACIDAD || '%')  AND (CASE WHEN TOTALDIAS IS NULL THEN ' ' ELSE UPPER(TOTALDIAS) END)  LIKE UPPER(:TOTALDIAS || '%')  AND (CASE WHEN SUELDO IS NULL THEN ' ' ELSE UPPER(SUELDO) END)  LIKE UPPER(:SUELDO || '%')  AND (CASE WHEN IBC IS NULL THEN ' ' ELSE UPPER(IBC) END)  LIKE UPPER(:IBC || '%')  AND (CASE WHEN FACTOR IS NULL THEN ' ' ELSE UPPER(FACTOR) END)  LIKE UPPER(:FACTOR || '%')  AND (CASE WHEN COTRIESGOS IS NULL THEN ' ' ELSE UPPER(COTRIESGOS) END)  LIKE UPPER(:COTRIESGOS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","NUMERO_DCTO":"$NUMERO_DCTO","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRES":"$NOMBRES","DIASVAC":"$DIASVAC(type:integer)","DIASINCAPACIDAD":"$DIASINCAPACIDAD(type:integer)","TOTALDIAS":"$TOTALDIAS(type:integer)","SUELDO":"$SUELDO(type:integer)","IBC":"$IBC(type:integer)","FACTOR":"$FACTOR","COTRIESGOS":"$COTRIESGOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FONDORIESGOS" sqlType="STRING"/>
		<param name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="APELLIDO1" sqlType="STRING"/>
		<param name="APELLIDO2" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="DIASVAC" sqlType="STRING"/>
		<param name="DIASINCAPACIDAD" sqlType="STRING"/>
		<param name="TOTALDIAS" sqlType="STRING"/>
		<param name="SUELDO" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="FACTOR" sqlType="STRING"/>
		<param name="COTRIESGOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
