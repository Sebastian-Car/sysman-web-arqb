	<query id="getHistoricosGetkardexcuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT PER.NOMBRECOMPLETO ANOMBRES, H.ANO BANO, H.MES CMES, PER.NUMERO_DCTO DNUMERO_DCTO, SUM( (CASE WHEN C.CONCEPTO_CUNE = 'NIE111' THEN H.VALOR ELSE 0 END)+ (CASE WHEN C.CONCEPTO_CUNE = 'NIE069' THEN H.VALOR ELSE 0 END) + (CASE WHEN C.CONCEPTO_CUNE = 'NIE130' THEN H.VALOR ELSE 0 END) + (CASE WHEN C.CONCEPTO_CUNE = 'NIE134' THEN H.VALOR ELSE 0 END) + (CASE WHEN C.CONCEPTO_CUNE = 'NIE138' THEN H.VALOR ELSE 0 END) ) AS CTOTALDIAS, MAX(PER.ID_DE_EMPLEADO) AS NIE009, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE062' THEN H.VALOR ELSE 0 END) NIE062, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE069' THEN H.VALOR ELSE 0 END) NIE069, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE070' THEN H.VALOR ELSE 0 END) NIE070, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE071' THEN H.VALOR ELSE 0 END) NIE071, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE072' THEN H.VALOR ELSE 0 END) NIE072, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE073' THEN H.VALOR ELSE 0 END) NIE073, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE076' THEN H.VALOR ELSE 0 END) NIE076, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE078' THEN H.VALOR ELSE 0 END) NIE078, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE081' THEN H.VALOR ELSE 0 END) NIE081, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE083' THEN H.VALOR ELSE 0 END) NIE083, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE086' THEN H.VALOR ELSE 0 END) NIE086, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE088' THEN H.VALOR ELSE 0 END) NIE088, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE091' THEN H.VALOR ELSE 0 END) NIE091, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE093' THEN H.VALOR ELSE 0 END) NIE093, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE096' THEN H.VALOR ELSE 0 END) NIE096, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE098' THEN H.VALOR ELSE 0 END) NIE098, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE101' THEN H.VALOR ELSE 0 END) NIE101, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE103' THEN H.VALOR ELSE 0 END) NIE103, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE106' THEN H.VALOR ELSE 0 END) NIE106, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE108' THEN H.VALOR ELSE 0 END) NIE108, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE111' THEN H.VALOR ELSE 0 END) NIE111, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE112' THEN H.VALOR ELSE 0 END) NIE112, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE115' THEN H.VALOR ELSE 0 END) NIE115, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE116' THEN H.VALOR ELSE 0 END) NIE116, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE117' THEN H.VALOR ELSE 0 END) NIE117, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE118' THEN H.VALOR ELSE 0 END) NIE118, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE119' THEN H.VALOR ELSE 0 END) NIE119, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE120' THEN H.VALOR ELSE 0 END) NIE120, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE122' THEN H.VALOR ELSE 0 END) NIE122, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE125' THEN H.VALOR ELSE 0 END) NIE125, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE127' THEN H.VALOR ELSE 0 END) NIE127, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE130' THEN H.VALOR ELSE 0 END) NIE130, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE131' THEN H.VALOR ELSE 0 END) NIE131, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE134' THEN H.VALOR ELSE 0 END) NIE134, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE135' THEN H.VALOR ELSE 0 END) NIE135, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE138' THEN H.VALOR ELSE 0 END) NIE138, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE139' THEN H.VALOR ELSE 0 END) NIE139, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE140' THEN H.VALOR ELSE 0 END) NIE140, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE141' THEN H.VALOR ELSE 0 END) NIE141, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE142' THEN H.VALOR ELSE 0 END) NIE142, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE145' THEN H.VALOR ELSE 0 END) NIE145, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE147' THEN H.VALOR ELSE 0 END) NIE147, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE148' THEN H.VALOR ELSE 0 END) NIE148, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE149' THEN H.VALOR ELSE 0 END) NIE149, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE150' THEN H.VALOR ELSE 0 END) NIE150, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE151' THEN H.VALOR ELSE 0 END) NIE151, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE152' THEN H.VALOR ELSE 0 END) NIE152, SUM(CASE WHEN C.CONCEPTO_CUNE = 'NIE153' THEN 