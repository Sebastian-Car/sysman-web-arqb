	</resource>
	<query id="updateHistoricos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE HISTORICOS SET ID_DE_PROCESO=:ID_DE_PROCESO, ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, VALOR=:VALOR, OBSERVACIONES=:OBSERVACIONES, MANUAL=:MANUAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE HISTORICOS.COMPANIA= :KEY_COMPANIA AND HISTORICOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND HISTORICOS.ANO= :KEY_ANO AND HISTORICOS.MES= :KEY_MES AND HISTORICOS.PERIODO= :KEY_PERIODO AND HISTORICOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND HISTORICOS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="MANUAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="historicos">
		<call-query href="updateHistoricos">
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="MANUAL" query-param="MANUAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getHistoricosNumFondoDeRiesgosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PERSONAL.COMPANIA, PERSONAL.ID_DE_EMPLEADO, PERSONAL.DCTO_IDENTIDAD, PERSONAL.NUMERO_DCTO, PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '035' THEN HISTORICOS.VALOR ELSE 0 END) DIASVAC, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '350' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '351' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '352' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '353' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '354' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '355' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '358' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '367' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '368' THEN HISTORICOS.VALOR ELSE 0 END)DIASINCAPACIDAD, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '009' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '011' THEN HISTORICOS.VALOR ELSE 0 END) TOTALDIAS, SUM(SUELDOBASICO.VALOR) SUELDO, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '112' THEN HISTORICOS.VALOR ELSE 0 END) IBC, PATRONALES.FACTOR FACTOR, SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '111' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '' THEN HISTORICOS.VALOR ELSE 0 END) COTRIESGOS  FROM HISTORICOS INNER JOIN PERSONAL ON HISTORICOS.COMPANIA = PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN PERSONAL_HISTORICO ON HISTORICOS.ID_DE_EMPLEADO = PERSONAL_HISTORICO.ID_DE_EMPLEADO AND HISTORICOS.MES = PERSONAL_HISTORICO.MES AND HISTORICOS.ANO = PERSONAL_HISTORICO.ANO AND HISTORICOS.ID_DE_PROCESO = PERSONAL_HISTORICO.ID_DE_PROCESO AND HISTORICOS.COMPANIA = PERSONAL_HISTORICO.COMPANIA AND HISTORICOS.PERIODO = PERSONAL_HISTORICO.PERIODO INNER JOIN PATRONALES ON PERSONAL.NUMEROPATRONAL = PATRONALES.SUCURSAL AND PERSONAL.COMPANIA = PATRONALES.COMPANIA LEFT JOIN (SELECT HISTORICOS.COMPANIA, HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO, HISTORICOS.ID_DE_CONCEPTO, HISTORICOS.VALOR FROM HISTORICOS WHERE HISTORICOS.COMPANIA = :COMPANIA AND HISTORICOS.ID_DE_PROCESO = :ID_DE_PROCESO AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND HISTORICOS.PERIODO = :PERIODO AND HISTORICOS.ID_DE_CONCEPTO = 1 )SUELDOBASICO ON HISTORICOS.COMPANIA = SUELDOBASICO.COMPANIA AND HISTORICOS.ID_DE_PROCESO = SUELDOBASICO.ID_DE_PROCESO AND HISTORICOS.ANO = SUELDOBASICO.ANO AND HISTORICOS.MES = SUELDOBASICO.MES AND HISTORICOS.PERIODO = SUELDOBASICO.PERIODO AND HISTORICOS.ID_DE_EMPLEADO = SUELDOBASICO.ID_DE_EMPLEADO AND HISTORICOS.ID_DE_CONCEPTO = SUELDOBASICO.ID_DE_CONCEPTO WHERE HISTORICOS.COMPANIA = :COMPANIA AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND PERSONAL_HISTORICO.FONDO_RIESGOS = :FONDORIESGOS GROUP BY PERSONAL.DCTO_IDENTIDAD, PERSONAL.NUMERO_DCTO, PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES, PATRONALES.FACTOR, PERSONAL_HISTORICO.FONDO_RIESGOS, HISTORICOS.ID_DE_EMPLEADO, PERSONAL.COMPANIA, PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN DCTO_IDENTIDAD IS NULL THEN ' ' ELSE UPPER(DCTO_IDENTIDAD) END)  LIKE UPPER( '%' || :DCTO_IDENTIDAD || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END)  LIKE UPPER( '%' || :APELLIDO1 || '%')  AND (CASE WHEN APELLIDO2 IS NULL THEN ' ' ELSE UPPER(APELLIDO2) END)  LIKE UPPER( '%' || :APELLIDO2 || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN DIASVAC IS NULL THEN ' ' ELSE UPPER(DIASVAC) END)  LIKE UPPER(:DIASVAC || '%')  AND (CASE WHEN DIASINCAPACIDAD IS NULL THEN ' ' ELSE UPPER(DIASINCAPACIDAD) END)  LIKE UPPER(:DIASINCAPACIDAD || '%')  AND (CASE WHEN TOTALDIAS IS NULL THEN ' ' ELSE UPPER(TOTALDIAS) END)  LIKE UPPER(:TOTALDIAS || '%')  AND (CASE WHEN SUELDO IS NULL THEN ' ' ELSE UPPER(SUELDO) END)  LIKE UPPER(:SUELDO || '%')  AND (CASE WHEN IBC IS NULL THEN ' ' ELSE UPPER(IBC) END)  LIKE UPPER(:IBC || '%')  AND (CASE WHEN FACTOR IS NULL THEN ' ' ELSE UPPER(FACTOR) END)  LIKE UPPER(:FACTOR || '%')  AND (CASE WHEN COTRIESGOS IS NULL THEN ' ' ELSE UPPER(COTRIESGOS) END)  LIKE UPPER(:COTRIESGOS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FONDORIESGOS" sqlType="STRING"/>
		<param name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="APELLIDO1" sqlType="STRING"/>
		<param name="APELLIDO2" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="DIASVAC" sqlType="STRING"/>
		<param name="DIASINCAPACIDAD" sqlType="STRING"/>
		<param name="TOTALDIAS" sqlType="STRING"/>
		<param name="SUELDO" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="FACTOR" sqlType="STRING"/>
		<param name="COTRIESGOS" sqlType="STRING"/>

	</query>
