	<query id="getHistoricosPivotNombreConceptosMaestraQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT CONCAT(CONCEPTOS.CLASE,CONCAT('_',CONCAT(LPAD(HISTORICOS.ID_DE_CONCEPTO,3,0),CONCAT('_',CONCEPTOS.NOMBRE_CONCEPTO) ) ) ) NOMBRECONCEPTO FROM HISTORICOS INNER JOIN CONCEPTOS ON HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA AND HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO INNER JOIN PERIODOS ON HISTORICOS.COMPANIA = PERIODOS.COMPANIA AND HISTORICOS.ID_DE_PROCESO = PERIODOS.ID_DE_PROCESO AND HISTORICOS.ANO = PERIODOS.ANO AND HISTORICOS.MES = PERIODOS.MES AND HISTORICOS.PERIODO = PERIODOS.PERIODO INNER JOIN PERSONAL ON HISTORICOS.COMPANIA = PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN ESTABLECIMIENTOS_DOCENTES ON PERSONAL.COMPANIA = ESTABLECIMIENTOS_DOCENTES.COMPANIA AND PERSONAL.CODIGO_ESTABLECIMIENTO = ESTABLECIMIENTOS_DOCENTES.CODIGO INNER JOIN DEPENDENCIA ON PERSONAL.COMPANIA = DEPENDENCIA.COMPANIA AND PERSONAL.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN CENTRO_COSTO ON PERSONAL.COMPANIA = CENTRO_COSTO.COMPANIA AND PERSONAL.ID_CENTRO_DE_COSTO = CENTRO_COSTO.CODIGO AND HISTORICOS.ANO = CENTRO_COSTO.ANO WHERE HISTORICOS.COMPANIA =:COMPANIA AND HISTORICOS.ID_DE_PROCESO =:ID_DE_PROCESO AND HISTORICOS.ANO =:ANO AND HISTORICOS.MES =:MES AND HISTORICOS.PERIODO =:PERIODO AND PERIODOS.ACUMULADO NOT IN (0) AND CONCEPTOS.CLASE BETWEEN 1 AND 8 AND HISTORICOS.ID_DE_CONCEPTO &lt; 900 ORDER BY CONCAT(CONCEPTOS.CLASE,CONCAT('_',CONCAT(LPAD(HISTORICOS.ID_DE_CONCEPTO,3,0),CONCAT('_',CONCEPTOS.NOMBRE_CONCEPTO) ) ) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRECONCEPTO":"$NOMBRECONCEPTO"}]}}		</result>
