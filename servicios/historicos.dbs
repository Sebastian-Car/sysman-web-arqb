<query id="getHistoricosPagGethistoricosnumcptoqueryqueryQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT HISTORICOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO NOMBRE_CONCEPTO FROM HISTORICOS LEFT JOIN CONCEPTOS ON (HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA) AND (HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO) WHERE (((HISTORICOS.COMPANIA) = :COMPANIA) AND ((HISTORICOS.ID_DE_PROCESO) = :ID_DE_PROCESO) AND ((HISTORICOS.PERIODO) = :PERIODO) AND ((HISTORICOS.ANO) = :ANO) AND ((HISTORICOS.MES) = :MES) AND (CONCEPTOS.CLASE in (3,4,5,6) ) AND (CONCEPTOS.ID_DE_CONCEPTO not in (97,140,144) ) ) ORDER BY HISTORICOS.ID_DE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="historicos/gethistoricosnumcptoqueryquery/pag">
		<call-query href="getHistoricosPagGethistoricosnumcptoqueryqueryQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getHistoricosNumGethistoricosnumcptoqueryqueryQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT HISTORICOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO NOMBRE_CONCEPTO FROM HISTORICOS LEFT JOIN CONCEPTOS ON (HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA) AND (HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO) WHERE (((HISTORICOS.COMPANIA) = :COMPANIA) AND ((HISTORICOS.ID_DE_PROCESO) = :ID_DE_PROCESO) AND ((HISTORICOS.PERIODO) = :PERIODO) AND ((HISTORICOS.ANO) = :ANO) AND ((HISTORICOS.MES) = :MES) AND (CONCEPTOS.CLASE in (3,4,5,6) ) AND (CONCEPTOS.ID_DE_CONCEPTO not in (97,140,144) ) ) ORDER BY HISTORICOS.ID_DE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historicos/gethistoricosnumcptoqueryquery/num">
		<call-query href="getHistoricosNumGethistoricosnumcptoqueryqueryQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getHistoricosInfperiodosdicQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(*) REG FROM HISTORICOS WHERE COMPANIA = :COMPANIA AND ID_DE_PROCESO = :ID_DE_PROCESO AND ANO = :ANIO AND MES = :MES AND PERIODO IN(4,8)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"REG":"$REG(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historicos/infperiodosdic">
		<call-query href="getHistoricosInfperiodosdicQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	
