			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FONDORIESGOS" query-param="FONDORIESGOS"/>

		</call-query>
	</resource>
	<query id="getHistoricosReportesFinancierosSiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT HISTORICOS.COMPANIA, CONCEPTOS.CLASE CLASE, SUM(HISTORICOS.VALOR) TOTAL, CASE WHEN NVL(CONCEPTOS.SIIF_ATRIBUTOEMPLEADO,' ') &lt;&gt; ' ' OR ( NVL(CONCEPTOS.SIIF_ATRIBUTOEMPLEADO,' ') = ' ' AND V_FONDOS.PUBLICO NOT IN ( 0 ) ) THEN 'Privado' ELSE 'Público' END TPUBLICO, CASE WHEN V_FONDOS.COMPANIA IS NULL THEN CONCEPTOS.NITCONCEPTO ELSE V_FONDOS.NOMBRE_FONDO END NOMBREFONDO, CASE WHEN NVL(CONCEPTOS.SIIF_ATRIBUTOEMPLEADO,' ') &lt;&gt; ' ' THEN CONCEPTOS.SIIF_ATRIBUTOEMPLEADO ELSE V_FONDOS.RUBRO_SIIF_EMPLEADO END RUBROS_SIIF, CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 130 ) THEN 1 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 131 ) THEN 2 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 132 ) THEN 3 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 124 ) THEN 6 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 127 ) THEN 5 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 100, 200, 205 ) THEN 7 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 125 ) THEN 8 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 120 ) THEN 3 ELSE 8 END END END END END END END END ORDEN, CASE WHEN V_FONDOS.COMPANIA IS NULL THEN CONCEPTOS.NITCONCEPTO ELSE V_FONDOS.NIT END NIT FROM HISTORICOS INNER JOIN PERIODOS ON HISTORICOS.COMPANIA = PERIODOS.COMPANIA AND HISTORICOS.ID_DE_PROCESO = PERIODOS.ID_DE_PROCESO AND HISTORICOS.ANO = PERIODOS.ANO AND HISTORICOS.MES = PERIODOS.MES AND HISTORICOS.PERIODO = PERIODOS.PERIODO INNER JOIN CONCEPTOS ON HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA AND HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO INNER JOIN PERSONAL ON HISTORICOS.COMPANIA = PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN V_FONDOS ON PERSONAL.COMPANIA = V_FONDOS.COMPANIA AND CASE WHEN CONCEPTOS.ID_DE_CONCEPTO IN (113,130,123) THEN PERSONAL.FONDO_SALUD ELSE CASE WHEN CONCEPTOS.ID_DE_CONCEPTO IN ( 120, 131, 132 ) THEN PERSONAL.ID_DEL_FONDO ELSE CASE WHEN CONCEPTOS.ID_DE_CONCEPTO IN ( 124 ) THEN PERSONAL.FONDO_PENSION_VOL ELSE CASE WHEN CONCEPTOS.ID_DE_CONCEPTO IN ( 127 ) THEN PERSONAL.FONDO_AFC ELSE CASE WHEN CONCEPTOS.ID_DE_CONCEPTO IN ( 100, 200, 205 ) THEN PERSONAL.MEDICINA_PREPAGADA ELSE ' ' END END END END END = V_FONDOS.COD_FONDO WHERE HISTORICOS.COMPANIA =:COMPANIA AND CONCAT(HISTORICOS.ID_DE_PROCESO,CONCAT(HISTORICOS.ANO,CONCAT(HISTORICOS.MES,HISTORICOS.PERIODO) ) ) = CONCAT(:PROCESO,CONCAT (:ANO,CONCAT(:MES,:PERIODO) ) ) AND CONCEPTOS.CLASE IN (5) AND PERIODOS.ACUMULADO NOT IN (0) GROUP BY HISTORICOS.COMPANIA, CONCEPTOS.CLASE, CASE WHEN NVL(CONCEPTOS.SIIF_ATRIBUTOEMPLEADO,' ') &lt;&gt; ' ' OR ( NVL(CONCEPTOS.SIIF_ATRIBUTOEMPLEADO,' ') = ' ' AND V_FONDOS.PUBLICO NOT IN ( 0 ) ) THEN 'Privado' ELSE 'Público' END, CASE WHEN V_FONDOS.COMPANIA IS NULL THEN CONCEPTOS.NITCONCEPTO ELSE V_FONDOS.NOMBRE_FONDO END, CASE WHEN NVL(CONCEPTOS.SIIF_ATRIBUTOEMPLEADO,' ') &lt;&gt; ' ' THEN CONCEPTOS.SIIF_ATRIBUTOEMPLEADO ELSE V_FONDOS.RUBRO_SIIF_EMPLEADO END, CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 130 ) THEN 1 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 131 ) THEN 2 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 132 ) THEN 3 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 124 ) THEN 6 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 127 ) THEN 5 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 100, 200, 205 ) THEN 7 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 125 ) THEN 8 ELSE CASE WHEN HISTORICOS.ID_DE_CONCEPTO IN ( 120 ) THEN 3 ELSE 8 END END END END END END END END, CASE WHEN V_FONDOS.COMPANIA IS NULL THEN CONCEPTOS.NITCONCEPTO ELSE V_FONDOS.NIT END ORDER BY CASE WHEN NVL(CONCEPTOS.SIIF_ATRIBUTOEMPLEADO,' ') &lt;&gt; ' ' THEN CONCEPTOS.SIIF_ATRIBUTOEMPLEADO ELSE V_FONDOS.RUBRO_SIIF_EMPLEADO END, CASE WHEN V_FONDOS.COMPANIA IS NULL THEN CONCEPTOS.NITCONCEPTO ELSE V_FONDOS.NIT END ASC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASE":"$CLASE","TOTAL":"$TOTAL(type:integer)","TPUBLICO":"$TPUBLICO","NOMBREFONDO":"$NOMBREFONDO","RUBROS_SIIF":"$RUBROS_SIIF","ORDEN":"$ORDEN(type:integer)","NIT":"$NIT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historicos/reportesfinancierossiif">
		<call-query href="getHistoricosReportesFinancierosSiifQuery">
