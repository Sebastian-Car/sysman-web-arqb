			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getHistoricosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT HISTORICOS.COMPANIA, HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO, HISTORICOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, HISTORICOS.VALOR, HISTORICOS.OBSERVACIONES,(CASE HISTORICOS.MANUAL WHEN 0 THEN 'false' ELSE 'true' END) MANUAL, CONCEPTOS.RANGO1, CONCEPTOS.RANGO2 FROM HISTORICOS LEFT JOIN CONCEPTOS ON (HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA) AND (HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO) WHERE HISTORICOS.COMPANIA =CONCEPTOS.COMPANIA AND CONCEPTOS.COMPANIA = :COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = :EMPLEADO AND HISTORICOS.ID_DE_PROCESO = :PROCESO AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND HISTORICOS.PERIODO = :PERIODO ORDER BY HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO, HISTORICOS.ID_DE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_CONCEPTO), '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) AND (CASE WHEN MANUAL IS NULL THEN ' ' ELSE UPPER(MANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:MANUAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","VALOR":"$VALOR","OBSERVACIONES":"$OBSERVACIONES","MANUAL":"$MANUAL(type:boolean)","RANGO1":"$RANGO1","RANGO2":"$RANGO2"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPLEADO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="MANUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="historicos">
		<call-query href="getHistoricosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPLEADO" query-param="EMPLEADO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="MANUAL" query-param="MANUAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getHistoricosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT HISTORICOS.COMPANIA, HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO, HISTORICOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, HISTORICOS.VALOR, HISTORICOS.OBSERVACIONES,(CASE HISTORICOS.MANUAL WHEN 0 THEN 'false' ELSE 'true' END) MANUAL, CONCEPTOS.RANGO1, CONCEPTOS.RANGO2 FROM HISTORICOS LEFT JOIN CONCEPTOS ON (HISTORICOS.COMPANIA = CONCEPTOS.COMPANIA) AND (HISTORICOS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO) WHERE HISTORICOS.COMPANIA =CONCEPTOS.COMPANIA AND CONCEPTOS.COMPANIA = :COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = :EMPLEADO AND HISTORICOS.ID_DE_PROCESO = :PROCESO AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND HISTORICOS.PERIODO = :PERIODO ORDER BY HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO, HISTORICOS.ID_DE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_CONCEPTO), '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) AND (CASE WHEN MANUAL IS NULL THEN ' ' ELSE UPPER(MANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:MANUAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPLEADO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="MANUAL" sqlType="STRING"/>

	</query>
