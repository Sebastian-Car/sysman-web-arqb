	<query id="getHistoricosTotalesDeAutoliquidacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '035' THEN HISTORICOS.VALOR ELSE 0 END),0) DIASVAC, NVL(SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '350' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '351' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '352' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '353' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '354' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '355' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '358' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '367' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '368' THEN HISTORICOS.VALOR ELSE 0 END),0)DIASINCAPACIDAD, NVL(SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '009' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '011' THEN HISTORICOS.VALOR ELSE 0 END),0) TOTALDIAS, NVL(SUM(SUELDOBASICO.VALOR),0) SUELDO, NVL(SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '112' THEN HISTORICOS.VALOR ELSE 0 END),0) IBC, NVL(SUM( CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '111' THEN HISTORICOS.VALOR ELSE 0 END + CASE WHEN HISTORICOS.ID_DE_CONCEPTO = '' THEN HISTORICOS.VALOR ELSE 0 END),0) COTRIESGOS  FROM HISTORICOS INNER JOIN PERSONAL ON HISTORICOS.COMPANIA = PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN PERSONAL_HISTORICO ON HISTORICOS.ID_DE_EMPLEADO = PERSONAL_HISTORICO.ID_DE_EMPLEADO AND HISTORICOS.MES = PERSONAL_HISTORICO.MES AND HISTORICOS.ANO = PERSONAL_HISTORICO.ANO AND HISTORICOS.ID_DE_PROCESO = PERSONAL_HISTORICO.ID_DE_PROCESO AND HISTORICOS.COMPANIA = PERSONAL_HISTORICO.COMPANIA AND HISTORICOS.PERIODO = PERSONAL_HISTORICO.PERIODO LEFT JOIN (SELECT HISTORICOS.COMPANIA, HISTORICOS.ID_DE_PROCESO, HISTORICOS.ANO, HISTORICOS.MES, HISTORICOS.PERIODO, HISTORICOS.ID_DE_EMPLEADO, HISTORICOS.ID_DE_CONCEPTO, HISTORICOS.VALOR FROM HISTORICOS WHERE HISTORICOS.COMPANIA = :COMPANIA AND HISTORICOS.ID_DE_PROCESO = :ID_DE_PROCESO AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND HISTORICOS.PERIODO = :PERIODO AND HISTORICOS.ID_DE_CONCEPTO = 1 )SUELDOBASICO ON HISTORICOS.COMPANIA = SUELDOBASICO.COMPANIA AND HISTORICOS.ID_DE_PROCESO = SUELDOBASICO.ID_DE_PROCESO AND HISTORICOS.ANO = SUELDOBASICO.ANO AND HISTORICOS.MES = SUELDOBASICO.MES AND HISTORICOS.PERIODO = SUELDOBASICO.PERIODO AND HISTORICOS.ID_DE_EMPLEADO = SUELDOBASICO.ID_DE_EMPLEADO AND HISTORICOS.ID_DE_CONCEPTO = SUELDOBASICO.ID_DE_CONCEPTO WHERE HISTORICOS.COMPANIA = :COMPANIA AND HISTORICOS.ANO = :ANO AND HISTORICOS.MES = :MES AND PERSONAL_HISTORICO.FONDO_RIESGOS = :FONDORIESGOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIASVAC":"$DIASVAC(type:integer)","DIASINCAPACIDAD":"$DIASINCAPACIDAD(type:integer)","TOTALDIAS":"$TOTALDIAS(type:integer)","SUELDO":"$SUELDO(type:integer)","IBC":"$IBC(type:integer)","COTRIESGOS":"$COTRIESGOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FONDORIESGOS" sqlType="STRING"/>

	</query>
