<data name="esriesestpr" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsriesestprCanttipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) CANT  FROM ES_RIES_ESTPR WHERE COMPANIA = :COMPANIA AND COD_ESTUDIO = :COD_ESTUDIO AND COD_RIESGO = :COD_RIESGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANT":"$CANT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_RIESGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esriesestpr/canttipo">
		<call-query href="getEsriesestprCanttipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_RIESGO" query-param="COD_RIESGO"/>

		</call-query>
	</resource>
	<query id="insertEsriesestpr" keyColumns="COMPANIA,COD_T_RIESGO,COD_RIESGO,COD_ESTUDIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_RIES_ESTPR (COMPANIA, COD_T_RIESGO, COD_RIESGO, COD_ESTUDIO, DOC_RESPALDO, RESP_ENTREGA, RESP_RECIBIDO, SUCURSAL_RESP_RECIBIDO, ANALIZADO, VERIFICADO, OBSERVACIONES, DETALLE, ESTIMACION, FECHA_RECIBIDO, FECHA_ENTREGA, FUENTE, ETAPA, TIPO, CONSECUENCIA_OCURRENCIA, PROBABILIDAD, IMPACTO, VALORACION, CATEGORIA, TRATAMIENTO, PROBABILIDAD_DESPUES, IMPACTO_DESPUES, VALORACION_DESPUES, CATEGORIA_DESPUES, AFECTA_EJECUCION_CONTRATO, RESPONBABLE_IMPLEMENTACION, F_INICIO_TRATAMIENTO, F_FIN_TRATAMIENTO, REALIZACION_MONITOREO, PERIODICIDAD, TIPO_OPCION_ETAPA, TIPO_OPCION_FUENTE, TIPO_OPCION_IMPACTO, TIPO_OPCION_IMPACTO_DES, TIPO_OPCION_PROBABILIDAD, TIPO_OPCION_PROBABILIDAD_DES, TIPO_OPCION_TIPO, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_T_RIESGO, :COD_RIESGO, :COD_ESTUDIO, :DOC_RESPALDO, :RESP_ENTREGA, :RESP_RECIBIDO, :SUCURSAL_RESP_RECIBIDO, :ANALIZADO, :VERIFICADO, :OBSERVACIONES, :DETALLE, :ESTIMACION, TO_DATE(:FECHA_RECIBIDO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS'), :FUENTE, :ETAPA, :TIPO, :CONSECUENCIA_OCURRENCIA, :PROBABILIDAD, :IMPACTO, :VALORACION, :CATEGORIA, :TRATAMIENTO, :PROBABILIDAD_DESPUES, :IMPACTO_DESPUES, :VALORACION_DESPUES, :CATEGORIA_DESPUES, :AFECTA_EJECUCION_CONTRATO, :RESPONBABLE_IMPLEMENTACION, :F_INICIO_TRATAMIENTO, :F_FIN_TRATAMIENTO, :REALIZACION_MONITOREO, :PERIODICIDAD, :TIPO_OPCION_ETAPA, :TIPO_OPCION_FUENTE, :TIPO_OPCION_IMPACTO, :TIPO_OPCION_IMPACTO_DES, :TIPO_OPCION_PROBABILIDAD, :TIPO_OPCION_PROBABILIDAD_DES, :TIPO_OPCION_TIPO, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_T_RIESGO":"$COD_T_RIESGO(type:integer)","KEY_COD_RIESGO":"$COD_RIESGO(type:integer)","KEY_COD_ESTUDIO":"$COD_ESTUDIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_RIESGO" sqlType="STRING"/>
		<param name="COD_RIESGO" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param defaultValue="" name="DOC_RESPALDO" sqlType="STRING"/>
		<param name="RESP_ENTREGA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESP_RECIBIDO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_RESP_RECIBIDO" sqlType="STRING"/>
		<param defaultValue="0" name="ANALIZADO" sqlType="STRING"/>
		<param defaultValue="0" name="VERIFICADO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="DETALLE" sqlType="STRING"/>
		<param defaultValue="" name="ESTIMACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_RECIBIDO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ENTREGA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ETAPA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CONSECUENCIA_OCURRENCIA" sqlType="STRING"/>
		<param name="PROBABILIDAD" sqlType="STRING"/>
		<param name="IMPACTO" sqlType="STRING"/>
		<param name="VALORACION" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="TRATAMIENTO" sqlType="STRING"/>
		<param name="PROBABILIDAD_DESPUES" sqlType="STRING"/>
		<param name="IMPACTO_DESPUES" sqlType="STRING"/>
		<param name="VALORACION_DESPUES" sqlType="STRING"/>
		<param name="CATEGORIA_DESPUES" sqlType="STRING"/>
		<param defaultValue="0" name="AFECTA_EJECUCION_CONTRATO" sqlType="STRING"/>
		<param name="RESPONBABLE_IMPLEMENTACION" sqlType="STRING"/>
		<param defaultValue="" name="F_INICIO_TRATAMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="F_FIN_TRATAMIENTO" sqlType="STRING"/>
		<param name="REALIZACION_MONITOREO" sqlType="STRING"/>
		<param name="PERIODICIDAD" sqlType="STRING"/>
		<param name="TIPO_OPCION_ETAPA" sqlType="STRING"/>
		<param name="TIPO_OPCION_FUENTE" sqlType="STRING"/>
		<param name="TIPO_OPCION_IMPACTO" sqlType="STRING"/>
		<param name="TIPO_OPCION_IMPACTO_DES" sqlType="STRING"/>
		<param name="TIPO_OPCION_PROBABILIDAD" sqlType="STRING"/>
		<param name="TIPO_OPCION_PROBABILIDAD_DES" sqlType="STRING"/>
		<param name="TIPO_OPCION_TIPO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esriesestpr">
		<call-query href="insertEsriesestpr">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_RIESGO" query-param="COD_T_RIESGO"/>
			<with-param name="COD_RIESGO" query-param="COD_RIESGO"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="DOC_RESPALDO" query-param="DOC_RESPALDO"/>
			<with-param name="RESP_ENTREGA" query-param="RESP_ENTREGA"/>
			<with-param name="RESP_RECIBIDO" query-param="RESP_RECIBIDO"/>
			<with-param name="SUCURSAL_RESP_RECIBIDO" query-param="SUCURSAL_RESP_RECIBIDO"/>
			<with-param name="ANALIZADO" query-param="ANALIZADO"/>
