	<query id="deleteEsriesestpr" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_RIES_ESTPR WHERE ES_RIES_ESTPR.COMPANIA= :KEY_COMPANIA AND ES_RIES_ESTPR.COD_T_RIESGO= :KEY_COD_T_RIESGO AND ES_RIES_ESTPR.COD_RIESGO= :KEY_COD_RIESGO AND ES_RIES_ESTPR.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_T_RIESGO" sqlType="INTEGER"/>
		<param name="KEY_COD_RIESGO" sqlType="INTEGER"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="esriesestpr">
		<call-query href="deleteEsriesestpr">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_T_RIESGO" query-param="KEY_COD_T_RIESGO"/>
			<with-param name="KEY_COD_RIESGO" query-param="KEY_COD_RIESGO"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="getEsriesestprPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_RIES_ESTPR.COMPANIA, ES_RIES_ESTPR.COD_T_RIESGO, FUENTE.NOMBRE NOMBRE_FUENTE, ETAPA.NOMBRE NOMBRE_ETAPA, TIPO.NOMBRE NOMBRE_TIPO, ES_RIES_ESTPR.COD_RIESGO, ES_RIES_ESTPR.COD_ESTUDIO, ES_RIES_ESTPR.DOC_RESPALDO, ES_RIES_ESTPR.RESP_ENTREGA, ES_RIES_ESTPR.RESP_RECIBIDO, ES_RIES_ESTPR.SUCURSAL_RESP_RECIBIDO,(CASE ES_RIES_ESTPR.ANALIZADO WHEN 0 THEN 'false' ELSE 'true' END) ANALIZADO,(CASE ES_RIES_ESTPR.VERIFICADO WHEN 0 THEN 'false' ELSE 'true' END) VERIFICADO, ES_RIES_ESTPR.OBSERVACIONES, ES_RIES_ESTPR.DETALLE, ES_RIES_ESTPR.ESTIMACION,(TO_CHAR(ES_RIES_ESTPR.FECHA_RECIBIDO,'DD/MM/YYYY HH24:MI:SS')) FECHA_RECIBIDO,(TO_CHAR(ES_RIES_ESTPR.FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENTREGA, ES_RIES_ESTPR.FUENTE, ES_RIES_ESTPR.ETAPA, ES_RIES_ESTPR.TIPO, ES_RIES_ESTPR.CONSECUENCIA_OCURRENCIA, ES_RIES_ESTPR.PROBABILIDAD, ES_RIES_ESTPR.IMPACTO, ES_RIES_ESTPR.VALORACION, ES_RIES_ESTPR.CATEGORIA, ES_RIES_ESTPR.TRATAMIENTO, ES_RIES_ESTPR.PROBABILIDAD_DESPUES, ES_RIES_ESTPR.IMPACTO_DESPUES, ES_RIES_ESTPR.VALORACION_DESPUES, ES_RIES_ESTPR.CATEGORIA_DESPUES,(CASE ES_RIES_ESTPR.AFECTA_EJECUCION_CONTRATO WHEN 0 THEN 'false' ELSE 'true' END) AFECTA_EJECUCION_CONTRATO, ES_RIES_ESTPR.RESPONBABLE_IMPLEMENTACION, ES_RIES_ESTPR.F_INICIO_TRATAMIENTO, ES_RIES_ESTPR.F_FIN_TRATAMIENTO, ES_RIES_ESTPR.REALIZACION_MONITOREO, ES_RIES_ESTPR.PERIODICIDAD, ES_RIES_ESTPR.TIPO_OPCION_ETAPA, ES_RIES_ESTPR.TIPO_OPCION_FUENTE, ES_RIES_ESTPR.TIPO_OPCION_IMPACTO, ES_RIES_ESTPR.TIPO_OPCION_IMPACTO_DES, ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD, ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD_DES, ES_RIES_ESTPR.TIPO_OPCION_TIPO  FROM ES_RIES_ESTPR INNER JOIN ES_FUENTE_ETAPA_TIPO FUENTE ON ES_RIES_ESTPR.COMPANIA = FUENTE.COMPANIA AND ES_RIES_ESTPR.FUENTE = FUENTE.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_FUENTE = FUENTE.TIPO_OPCION INNER JOIN ES_FUENTE_ETAPA_TIPO ETAPA ON ES_RIES_ESTPR.COMPANIA = ETAPA.COMPANIA AND ES_RIES_ESTPR.ETAPA = ETAPA.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_ETAPA = ETAPA.TIPO_OPCION INNER JOIN ES_FUENTE_ETAPA_TIPO TIPO ON ES_RIES_ESTPR.COMPANIA = TIPO.COMPANIA AND ES_RIES_ESTPR.TIPO = TIPO.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_TIPO = TIPO.TIPO_OPCION WHERE ES_RIES_ESTPR.COMPANIA = :COMPANIA AND ES_RIES_ESTPR.COD_ESTUDIO = :COD_ESTUDIO) WHERE (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END)  LIKE UPPER(:NOMBRE_FUENTE || '%')  AND (CASE WHEN NOMBRE_ETAPA IS NULL THEN ' ' ELSE UPPER(NOMBRE_ETAPA) END)  LIKE UPPER( '%' || :NOMBRE_ETAPA || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%')  AND (CASE WHEN COD_RIESGO IS NULL THEN ' ' ELSE UPPER(COD_RIESGO) END)  LIKE UPPER( '%' || :COD_RIESGO || '%')  AND (CASE WHEN DOC_RESPALDO IS NULL THEN ' ' ELSE UPPER(DOC_RESPALDO) END)  LIKE UPPER( '%' || :DOC_RESPALDO || '%')  AND (CASE WHEN SUCURSAL_RESP_RECIBIDO IS NULL THEN ' ' ELSE UPPER(SUCURSAL_RESP_RECIBIDO) END)  LIKE UPPER( '%' || :SUCURSAL_RESP_RECIBIDO || '%')  AND (CASE WHEN ANALIZADO IS NULL THEN ' ' ELSE UPPER(ANALIZADO) END)  LIKE UPPER( '%' || :ANALIZADO || '%')  AND (CASE WHEN VERIFICADO IS NULL THEN ' ' ELSE UPPER(VERIFICADO) END)  LIKE UPPER( '%' || :VERIFICADO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN DETALLE IS NULL THEN ' ' ELSE UPPER(DETALLE) END)  LIKE UPPER( '%' || :DETALLE || '%')  AND (CASE WHEN ESTIMACION IS NULL THEN ' ' ELSE UPPER(ESTIMACION) END)  LIKE UPPER( '%' || :ESTIMACION || '%')  AND (CASE WHEN FECHA_RECIBIDO IS NULL THEN ' ' ELSE UPPER(FECHA_RECIBIDO) END)  LIKE UPPER( '%' || :FECHA_RECIBIDO || '%')  AND (CASE WHEN FECHA_ENTREGA IS NULL THEN ' ' ELSE UPPER(FECHA_ENTREGA) END)  LIKE UPPER( '%' || :FECHA_ENTREGA || '%')  AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER( '%' || :FUENTE || '%')  AND (CASE WHEN ETAPA IS NULL THEN ' ' ELSE UPPER(ETAPA) END)  LIKE UPPER( '%' || :ETAPA || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN CONSECUENCIA_OCURRENCIA IS NULL THEN ' ' ELSE UPPER(CONSECUENCIA_OCURRENCIA) END)  LIKE UPPER( '%' || :CONSECUENCIA_OCURRENCIA || '%')  AND (CASE WHEN PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(PROBABILIDAD) END)  LIKE UPPER( '%' || :PROBABILIDAD || '%')  AND (CASE WHEN IMPACTO IS NULL THEN ' ' ELSE UPPER(IMPACTO) END)  LIKE UPPER( '%' || :IMPACTO || '%')  AND (CASE WHEN VALORACION IS NULL THEN ' ' ELSE UPPER(VALORACION) END)  LIKE UPPER( '%' || :VALORACION || '%')  AND (CASE WHEN CATEGORIA IS NULL THEN ' ' ELSE UPPER(CATEGORIA) END)  LIKE UPPER( '%' || :CATEGORIA || '%')  AND (CASE WHEN TRATAMIENTO IS NULL THEN ' ' ELSE UPPER(TRATAMIENTO) END)  LIKE UPPER( '%' || :TRATAMIENTO || '%')  AND (CASE WHEN PROBABILIDAD_DESPUES IS NULL THEN ' ' ELSE UPPER(PROBABILIDAD_DESPUES) END)  LIKE UPPER( '%' || :PROBABILIDAD_DESPUES || '%')  AND (CASE WHEN IMPACTO_DESPUES IS NULL THEN ' ' ELSE UPPER(IMPACTO_DESPUES) END)  LIKE UPPER( '%' || :IMPACTO_DESPUES || '%')  AND (CASE WHEN VALORACION_DESPUES IS NULL THEN ' ' ELSE UPPER(VALORACION_DESPUES) END)  LIKE UPPER( '%' || :VALORACION_DESPUES || '%')  AND (CASE WHEN CATEGORIA_DESPUES IS NULL THEN ' ' ELSE UPPER(CATEGORIA_DESPUES) END)  LIKE UPPER( '%' || :CATEGORIA_DESPUES || '%')  AND (CASE WHEN AFECTA_EJECUCION_CONTRATO IS NULL THEN ' ' ELSE UPPER(AFECTA_EJECUCION_CONTRATO) END)  LIKE UPPER( '%' || :AFECTA_EJECUCION_CONTRATO || '%')  AND (CASE WHEN RESPONBABLE_IMPLEMENTACION IS NULL THEN ' ' ELSE UPPER(RESPONBABLE_IMPLEMENTACION) END)  LIKE UPPER( '%' || :RESPONBABLE_IMPLEMENTACION || '%')  AND (CASE WHEN F_INICIO_TRATAMIENTO IS NULL THEN ' ' ELSE UPPER(F_INICIO_TRATAMIENTO) END)  LIKE UPPER( '%' || :F_INICIO_TRATAMIENTO || '%')  AND (CASE WHEN F_FIN_TRATAMIENTO IS NULL THEN ' ' ELSE UPPER(F_FIN_TRATAMIENTO) END)  LIKE UPPER( '%' || :F_FIN_TRATAMIENTO || '%')  AND (CASE WHEN REALIZACION_MONITOREO IS NULL THEN ' ' ELSE UPPER(REALIZACION_MONITOREO) END)  LIKE UPPER( '%' || :REALIZACION_MONITOREO || '%')  AND (CASE WHEN PERIODICIDAD IS NULL THEN ' ' ELSE UPPER(PERIODICIDAD) END)  LIKE UPPER( '%' || :PERIODICIDAD || '%')  AND (CASE WHEN TIPO_OPCION_ETAPA IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_ETAPA) END)  LIKE UPPER( '%' || :TIPO_OPCION_ETAPA || '%')  AND (CASE WHEN TIPO_OPCION_FUENTE IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_FUENTE) END)  LIKE UPPER( '%' || :TIPO_OPCION_FUENTE || '%')  AND (CASE WHEN TIPO_OPCION_IMPACTO IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_IMPACTO) END)  LIKE UPPER( '%' || :TIPO_OPCION_IMPACTO || '%')  AND (CASE WHEN TIPO_OPCION_IMPACTO_DES IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_IMPACTO_DES) END)  LIKE UPPER( '%' || :TIPO_OPCION_IMPACTO_DES || '%')  AND (CASE WHEN TIPO_OPCION_PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_PROBABILIDAD) END)  LIKE UPPER( '%' || :TIPO_OPCION_PROBABILIDAD || '%')  AND (CASE WHEN TIPO_OPCION_PROBABILIDAD_DES IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_PROBABILIDAD_DES) END)  LIKE UPPER( '%' || :TIPO_OPCION_PROBABILIDAD_DES || '%')  AND (CASE WHEN TIPO_OPCION_TIPO IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_TIPO) END)  LIKE UPPER( '%' || :TIPO_OPCION_TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_T_RIESGO":"$COD_T_RIESGO(type:integer)","NOMBRE_FUENTE":"$NOMBRE_FUENTE","NOMBRE_ETAPA":"$NOMBRE_ETAPA","NOMBRE_TIPO":"$NOMBRE_TIPO","COD_RIESGO":"$COD_RIESGO(type:integer)","COD_ESTUDIO":"$COD_ESTUDIO","DOC_RESPALDO":"$DOC_RESPALDO","RESP_ENTREGA":"$RESP_ENTREGA","RESP_RECIBIDO":"$RESP_RECIBIDO","SUCURSAL_RESP_RECIBIDO":"$SUCURSAL_RESP_RECIBIDO","ANALIZADO":"$ANALIZADO(type:boolean)","VERIFICADO":"$VERIFICADO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","DETALLE":"$DETALLE(type:integer)","ESTIMACION":"$ESTIMACION","FECHA_RECIBIDO":"$FECHA_RECIBIDO","FECHA_ENTREGA":"$FECHA_ENTREGA","FUENTE":"$FUENTE","ETAPA":"$ETAPA","TIPO":"$TIPO","CONSECUENCIA_OCURRENCIA":"$CONSECUENCIA_OCURRENCIA","PROBABILIDAD":"$PROBABILIDAD","IMPACTO":"$IMPACTO","VALORACION":"$VALORACION(type:integer)","CATEGORIA":"$CATEGORIA","TRATAMIENTO":"$TRATAMIENTO","PROBABILIDAD_DESPUES":"$PROBABILIDAD_DESPUES","IMPACTO_DESPUES":"$IMPACTO_DESPUES","VALORACION_DESPUES":"$VALORACION_DESPUES(type:integer)","CATEGORIA_DESPUES":"$CATEGORIA_DESPUES","AFECTA_EJECUCION_CONTRATO":"$AFECTA_EJECUCION_CONTRATO(type:boolean)","RESPONBABLE_IMPLEMENTACION":"$RESPONBABLE_IMPLEMENTACION","F_INICIO_TRATAMIENTO":"$F_INICIO_TRATAMIENTO","F_FIN_TRATAMIENTO":"$F_FIN_TRATAMIENTO","REALIZACION_MONITOREO":"$REALIZACION_MONITOREO","PERIODICIDAD":"$PERIODICIDAD","TIPO_OPCION_ETAPA":"$TIPO_OPCION_ETAPA(type:integer)","TIPO_OPCION_FUENTE":"$TIPO_OPCION_FUENTE(type:integer)","TIPO_OPCION_IMPACTO":"$TIPO_OPCION_IMPACTO(type:integer)","TIPO_OPCION_IMPACTO_DES":"$TIPO_OPCION_IMPACTO_DES(type:integer)","TIPO_OPCION_PROBABILIDAD":"$TIPO_OPCION_PROBABILIDAD(type:integer)","TIPO_OPCION_PROBABILIDAD_DES":"$TIPO_OPCION_PROBABILIDAD_DES(type:integer)","TIPO_OPCION_TIPO":"$TIPO_OPCION_TIPO(type:integer)"}]}}		</result>
