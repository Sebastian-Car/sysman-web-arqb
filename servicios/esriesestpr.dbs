	<resource method="PUT" path="esriesestpr">
		<call-query href="updateEsriesestpr">
			<with-param name="COD_T_RIESGO" query-param="COD_T_RIESGO"/>
			<with-param name="COD_RIESGO" query-param="COD_RIESGO"/>
			<with-param name="DOC_RESPALDO" query-param="DOC_RESPALDO"/>
			<with-param name="RESP_ENTREGA" query-param="RESP_ENTREGA"/>
			<with-param name="RESP_RECIBIDO" query-param="RESP_RECIBIDO"/>
			<with-param name="SUCURSAL_RESP_RECIBIDO" query-param="SUCURSAL_RESP_RECIBIDO"/>
			<with-param name="ANALIZADO" query-param="ANALIZADO"/>
			<with-param name="VERIFICADO" query-param="VERIFICADO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DETALLE" query-param="DETALLE"/>
			<with-param name="ESTIMACION" query-param="ESTIMACION"/>
			<with-param name="FECHA_RECIBIDO" query-param="FECHA_RECIBIDO"/>
			<with-param name="FECHA_ENTREGA" query-param="FECHA_ENTREGA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="ETAPA" query-param="ETAPA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONSECUENCIA_OCURRENCIA" query-param="CONSECUENCIA_OCURRENCIA"/>
			<with-param name="PROBABILIDAD" query-param="PROBABILIDAD"/>
			<with-param name="IMPACTO" query-param="IMPACTO"/>
			<with-param name="VALORACION" query-param="VALORACION"/>
			<with-param name="CATEGORIA" query-param="CATEGORIA"/>
			<with-param name="TRATAMIENTO" query-param="TRATAMIENTO"/>
			<with-param name="PROBABILIDAD_DESPUES" query-param="PROBABILIDAD_DESPUES"/>
			<with-param name="IMPACTO_DESPUES" query-param="IMPACTO_DESPUES"/>
