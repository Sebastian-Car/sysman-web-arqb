	<query id="getEsriesestprRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_RIES_ESTPR.COMPANIA, ES_RIES_ESTPR.COD_T_RIESGO, FUENTE.NOMBRE NOMBRE_FUENTE, ETAPA.NOMBRE NOMBRE_ETAPA, TIPO.NOMBRE NOMBRE_TIPO, PROBABILIDAD.CATEGORIA NOMBRE_PROBABILIDAD, PROBABILIDAD_DES.CATEGORIA NOMBRE_PROBABILIDAD_DESPUES, IMPACTO.CATEGORIA NOMBRE_IMPACTO, IMPACTO_DES.CATEGORIA NOMBRE_IMPACTO_DESPUES, ES_RIES_ESTPR.COD_RIESGO, ES_RIES_ESTPR.COD_ESTUDIO, ES_RIES_ESTPR.DOC_RESPALDO, ES_RIES_ESTPR.RESP_ENTREGA, ES_RIES_ESTPR.RESP_RECIBIDO, ES_RIES_ESTPR.SUCURSAL_RESP_RECIBIDO,(CASE ES_RIES_ESTPR.ANALIZADO WHEN 0 THEN 'false' ELSE 'true' END) ANALIZADO,(CASE ES_RIES_ESTPR.VERIFICADO WHEN 0 THEN 'false' ELSE 'true' END) VERIFICADO, ES_RIES_ESTPR.OBSERVACIONES, ES_RIES_ESTPR.DETALLE, ES_RIES_ESTPR.ESTIMACION,(TO_CHAR(ES_RIES_ESTPR.FECHA_RECIBIDO,'DD/MM/YYYY HH24:MI:SS')) FECHA_RECIBIDO,(TO_CHAR(ES_RIES_ESTPR.FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENTREGA, ES_RIES_ESTPR.FUENTE, ES_RIES_ESTPR.ETAPA, ES_RIES_ESTPR.TIPO, ES_RIES_ESTPR.CONSECUENCIA_OCURRENCIA, ES_RIES_ESTPR.PROBABILIDAD, ES_RIES_ESTPR.IMPACTO, ES_RIES_ESTPR.VALORACION, ES_RIES_ESTPR.CATEGORIA, ES_RIES_ESTPR.TRATAMIENTO, ES_RIES_ESTPR.PROBABILIDAD_DESPUES, ES_RIES_ESTPR.IMPACTO_DESPUES, ES_RIES_ESTPR.VALORACION_DESPUES, ES_RIES_ESTPR.CATEGORIA_DESPUES,(CASE ES_RIES_ESTPR.AFECTA_EJECUCION_CONTRATO WHEN 0 THEN 'false' ELSE 'true' END) AFECTA_EJECUCION_CONTRATO, ES_RIES_ESTPR.RESPONBABLE_IMPLEMENTACION, ES_RIES_ESTPR.F_INICIO_TRATAMIENTO, ES_RIES_ESTPR.F_FIN_TRATAMIENTO, ES_RIES_ESTPR.REALIZACION_MONITOREO, ES_RIES_ESTPR.PERIODICIDAD, ES_RIES_ESTPR.TIPO_OPCION_ETAPA, ES_RIES_ESTPR.TIPO_OPCION_FUENTE, ES_RIES_ESTPR.TIPO_OPCION_IMPACTO, ES_RIES_ESTPR.TIPO_OPCION_IMPACTO_DES, ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD, ES_RIES_ESTPR.DESCRIPCION, ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD_DES, ES_RIES_ESTPR.TIPO_OPCION_TIPO  FROM ES_RIES_ESTPR INNER JOIN ES_FUENTE_ETAPA_TIPO FUENTE ON ES_RIES_ESTPR.COMPANIA = FUENTE.COMPANIA AND ES_RIES_ESTPR.FUENTE = FUENTE.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_FUENTE = FUENTE.TIPO_OPCION INNER JOIN ES_FUENTE_ETAPA_TIPO ETAPA ON ES_RIES_ESTPR.COMPANIA = ETAPA.COMPANIA AND ES_RIES_ESTPR.ETAPA = ETAPA.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_ETAPA = ETAPA.TIPO_OPCION INNER JOIN ES_FUENTE_ETAPA_TIPO TIPO ON ES_RIES_ESTPR.COMPANIA = TIPO.COMPANIA AND ES_RIES_ESTPR.TIPO = TIPO.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_TIPO = TIPO.TIPO_OPCION INNER JOIN ES_PROBABILIDAD_VALORACION PROBABILIDAD ON ES_RIES_ESTPR.COMPANIA = PROBABILIDAD.COMPANIA AND ES_RIES_ESTPR.PROBABILIDAD = PROBABILIDAD.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD = PROBABILIDAD.TIPO_OPCION INNER JOIN ES_PROBABILIDAD_VALORACION PROBABILIDAD_DES ON ES_RIES_ESTPR.COMPANIA = PROBABILIDAD_DES.COMPANIA AND ES_RIES_ESTPR.PROBABILIDAD_DESPUES = PROBABILIDAD_DES.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD_DES = PROBABILIDAD_DES.TIPO_OPCION INNER JOIN ES_IMPACTO IMPACTO ON ES_RIES_ESTPR.COMPANIA = IMPACTO.COMPANIA AND ES_RIES_ESTPR.IMPACTO = IMPACTO.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_IMPACTO = IMPACTO.TIPO_OPCION INNER JOIN ES_IMPACTO IMPACTO_DES ON ES_RIES_ESTPR.COMPANIA = IMPACTO_DES.COMPANIA AND ES_RIES_ESTPR.IMPACTO_DESPUES = IMPACTO_DES.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_IMPACTO_DES = IMPACTO_DES.TIPO_OPCION WHERE ES_RIES_ESTPR.COMPANIA= :KEY_COMPANIA AND ES_RIES_ESTPR.COD_T_RIESGO= :KEY_COD_T_RIESGO AND ES_RIES_ESTPR.COD_RIESGO= :KEY_COD_RIESGO AND ES_RIES_ESTPR.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_T_RIESGO":"$COD_T_RIESGO(type:integer)","NOMBRE_FUENTE":"$NOMBRE_FUENTE","NOMBRE_ETAPA":"$NOMBRE_ETAPA","NOMBRE_TIPO":"$NOMBRE_TIPO","NOMBRE_PROBABILIDAD":"$NOMBRE_PROBABILIDAD","NOMBRE_PROBABILIDAD_DESPUES":"$NOMBRE_PROBABILIDAD_DESPUES","NOMBRE_IMPACTO":"$NOMBRE_IMPACTO","NOMBRE_IMPACTO_DESPUES":"$NOMBRE_IMPACTO_DESPUES","COD_RIESGO":"$COD_RIESGO(type:integer)","COD_ESTUDIO":"$COD_ESTUDIO","DOC_RESPALDO":"$DOC_RESPALDO","RESP_ENTREGA":"$RESP_ENTREGA","RESP_RECIBIDO":"$RESP_RECIBIDO","SUCURSAL_RESP_RECIBIDO":"$SUCURSAL_RESP_RECIBIDO","ANALIZADO":"$ANALIZADO(type:boolean)","VERIFICADO":"$VERIFICADO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","DETALLE":"$DETALLE(type:integer)","ESTIMACION":"$ESTIMACION","FECHA_RECIBIDO":"$FECHA_RECIBIDO","FECHA_ENTREGA":"$FECHA_ENTREGA","FUENTE":"$FUENTE","ETAPA":"$ETAPA","TIPO":"$TIPO","CONSECUENCIA_OCURRENCIA":"$CONSECUENCIA_OCURRENCIA","PROBABILIDAD":"$PROBABILIDAD","IMPACTO":"$IMPACTO","VALORACION":"$VALORACION(type:integer)","CATEGORIA":"$CATEGORIA","TRATAMIENTO":"$TRATAMIENTO","PROBABILIDAD_DESPUES":"$PROBABILIDAD_DESPUES","IMPACTO_DESPUES":"$IMPACTO_DESPUES","VALORACION_DESPUES":"$VALORACION_DESPUES(type:integer)","CATEGORIA_DESPUES":"$CATEGORIA_DESPUES","AFECTA_EJECUCION_CONTRATO":"$AFECTA_EJECUCION_CONTRATO(type:boolean)","RESPONBABLE_IMPLEMENTACION":"$RESPONBABLE_IMPLEMENTACION","F_INICIO_TRATAMIENTO":"$F_INICIO_TRATAMIENTO","F_FIN_TRATAMIENTO":"$F_FIN_TRATAMIENTO","REALIZACION_MONITOREO":"$REALIZACION_MONITOREO","PERIODICIDAD":"$PERIODICIDAD","TIPO_OPCION_ETAPA":"$TIPO_OPCION_ETAPA(type:integer)","TIPO_OPCION_FUENTE":"$TIPO_OPCION_FUENTE(type:integer)","TIPO_OPCION_IMPACTO":"$TIPO_OPCION_IMPACTO(type:integer)","TIPO_OPCION_IMPACTO_DES":"$TIPO_OPCION_IMPACTO_DES(type:integer)","TIPO_OPCION_PROBABILIDAD":"$TIPO_OPCION_PROBABILIDAD(type:integer)","DESCRIPCION":"$DESCRIPCION","TIPO_OPCION_PROBABILIDAD_DES":"$TIPO_OPCION_PROBABILIDAD_DES(type:integer)","TIPO_OPCION_TIPO":"$TIPO_OPCION_TIPO(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_T_RIESGO" sqlType="STRING"/>
		<param name="KEY_COD_RIESGO" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esriesestpr/data">
