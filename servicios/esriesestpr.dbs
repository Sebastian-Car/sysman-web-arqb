	<query id="getEsriesestprNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_RIES_ESTPR.COMPANIA, ES_RIES_ESTPR.COD_T_RIESGO, FUENTE.NOMBRE NOMBRE_FUENTE, ETAPA.NOMBRE NOMBRE_ETAPA, TIPO.NOMBRE NOMBRE_TIPO, ES_RIES_ESTPR.COD_RIESGO, ES_RIES_ESTPR.COD_ESTUDIO, ES_RIES_ESTPR.DOC_RESPALDO, ES_RIES_ESTPR.RESP_ENTREGA, ES_RIES_ESTPR.RESP_RECIBIDO, ES_RIES_ESTPR.SUCURSAL_RESP_RECIBIDO,(CASE ES_RIES_ESTPR.ANALIZADO WHEN 0 THEN 'false' ELSE 'true' END) ANALIZADO,(CASE ES_RIES_ESTPR.VERIFICADO WHEN 0 THEN 'false' ELSE 'true' END) VERIFICADO, ES_RIES_ESTPR.OBSERVACIONES, ES_RIES_ESTPR.DETALLE, ES_RIES_ESTPR.ESTIMACION,(TO_CHAR(ES_RIES_ESTPR.FECHA_RECIBIDO,'DD/MM/YYYY HH24:MI:SS')) FECHA_RECIBIDO,(TO_CHAR(ES_RIES_ESTPR.FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENTREGA, ES_RIES_ESTPR.FUENTE, ES_RIES_ESTPR.ETAPA, ES_RIES_ESTPR.TIPO, ES_RIES_ESTPR.CONSECUENCIA_OCURRENCIA, ES_RIES_ESTPR.PROBABILIDAD, ES_RIES_ESTPR.IMPACTO, ES_RIES_ESTPR.VALORACION, ES_RIES_ESTPR.CATEGORIA, ES_RIES_ESTPR.TRATAMIENTO, ES_RIES_ESTPR.PROBABILIDAD_DESPUES, ES_RIES_ESTPR.IMPACTO_DESPUES, ES_RIES_ESTPR.VALORACION_DESPUES, ES_RIES_ESTPR.CATEGORIA_DESPUES,(CASE ES_RIES_ESTPR.AFECTA_EJECUCION_CONTRATO WHEN 0 THEN 'false' ELSE 'true' END) AFECTA_EJECUCION_CONTRATO, ES_RIES_ESTPR.RESPONBABLE_IMPLEMENTACION, ES_RIES_ESTPR.F_INICIO_TRATAMIENTO, ES_RIES_ESTPR.F_FIN_TRATAMIENTO, ES_RIES_ESTPR.REALIZACION_MONITOREO, ES_RIES_ESTPR.PERIODICIDAD, ES_RIES_ESTPR.TIPO_OPCION_ETAPA, ES_RIES_ESTPR.TIPO_OPCION_FUENTE, ES_RIES_ESTPR.TIPO_OPCION_IMPACTO, ES_RIES_ESTPR.TIPO_OPCION_IMPACTO_DES, ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD, ES_RIES_ESTPR.TIPO_OPCION_PROBABILIDAD_DES, ES_RIES_ESTPR.TIPO_OPCION_TIPO  FROM ES_RIES_ESTPR INNER JOIN ES_FUENTE_ETAPA_TIPO FUENTE ON ES_RIES_ESTPR.COMPANIA = FUENTE.COMPANIA AND ES_RIES_ESTPR.FUENTE = FUENTE.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_FUENTE = FUENTE.TIPO_OPCION INNER JOIN ES_FUENTE_ETAPA_TIPO ETAPA ON ES_RIES_ESTPR.COMPANIA = ETAPA.COMPANIA AND ES_RIES_ESTPR.ETAPA = ETAPA.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_ETAPA = ETAPA.TIPO_OPCION INNER JOIN ES_FUENTE_ETAPA_TIPO TIPO ON ES_RIES_ESTPR.COMPANIA = TIPO.COMPANIA AND ES_RIES_ESTPR.TIPO = TIPO.CODIGO AND ES_RIES_ESTPR.TIPO_OPCION_TIPO = TIPO.TIPO_OPCION WHERE ES_RIES_ESTPR.COMPANIA = :COMPANIA AND ES_RIES_ESTPR.COD_ESTUDIO = :COD_ESTUDIO) WHERE (CASE WHEN NOMBRE_FUENTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUENTE) END)  LIKE UPPER(:NOMBRE_FUENTE || '%')  AND (CASE WHEN NOMBRE_ETAPA IS NULL THEN ' ' ELSE UPPER(NOMBRE_ETAPA) END)  LIKE UPPER( '%' || :NOMBRE_ETAPA || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%')  AND (CASE WHEN COD_RIESGO IS NULL THEN ' ' ELSE UPPER(COD_RIESGO) END)  LIKE UPPER( '%' || :COD_RIESGO || '%')  AND (CASE WHEN DOC_RESPALDO IS NULL THEN ' ' ELSE UPPER(DOC_RESPALDO) END)  LIKE UPPER( '%' || :DOC_RESPALDO || '%')  AND (CASE WHEN SUCURSAL_RESP_RECIBIDO IS NULL THEN ' ' ELSE UPPER(SUCURSAL_RESP_RECIBIDO) END)  LIKE UPPER( '%' || :SUCURSAL_RESP_RECIBIDO || '%')  AND (CASE WHEN ANALIZADO IS NULL THEN ' ' ELSE UPPER(ANALIZADO) END)  LIKE UPPER( '%' || :ANALIZADO || '%')  AND (CASE WHEN VERIFICADO IS NULL THEN ' ' ELSE UPPER(VERIFICADO) END)  LIKE UPPER( '%' || :VERIFICADO || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN DETALLE IS NULL THEN ' ' ELSE UPPER(DETALLE) END)  LIKE UPPER( '%' || :DETALLE || '%')  AND (CASE WHEN ESTIMACION IS NULL THEN ' ' ELSE UPPER(ESTIMACION) END)  LIKE UPPER( '%' || :ESTIMACION || '%')  AND (CASE WHEN FECHA_RECIBIDO IS NULL THEN ' ' ELSE UPPER(FECHA_RECIBIDO) END)  LIKE UPPER( '%' || :FECHA_RECIBIDO || '%')  AND (CASE WHEN FECHA_ENTREGA IS NULL THEN ' ' ELSE UPPER(FECHA_ENTREGA) END)  LIKE UPPER( '%' || :FECHA_ENTREGA || '%')  AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER( '%' || :FUENTE || '%')  AND (CASE WHEN ETAPA IS NULL THEN ' ' ELSE UPPER(ETAPA) END)  LIKE UPPER( '%' || :ETAPA || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN CONSECUENCIA_OCURRENCIA IS NULL THEN ' ' ELSE UPPER(CONSECUENCIA_OCURRENCIA) END)  LIKE UPPER( '%' || :CONSECUENCIA_OCURRENCIA || '%')  AND (CASE WHEN PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(PROBABILIDAD) END)  LIKE UPPER( '%' || :PROBABILIDAD || '%')  AND (CASE WHEN IMPACTO IS NULL THEN ' ' ELSE UPPER(IMPACTO) END)  LIKE UPPER( '%' || :IMPACTO || '%')  AND (CASE WHEN VALORACION IS NULL THEN ' ' ELSE UPPER(VALORACION) END)  LIKE UPPER( '%' || :VALORACION || '%')  AND (CASE WHEN CATEGORIA IS NULL THEN ' ' ELSE UPPER(CATEGORIA) END)  LIKE UPPER( '%' || :CATEGORIA || '%')  AND (CASE WHEN TRATAMIENTO IS NULL THEN ' ' ELSE UPPER(TRATAMIENTO) END)  LIKE UPPER( '%' || :TRATAMIENTO || '%')  AND (CASE WHEN PROBABILIDAD_DESPUES IS NULL THEN ' ' ELSE UPPER(PROBABILIDAD_DESPUES) END)  LIKE UPPER( '%' || :PROBABILIDAD_DESPUES || '%')  AND (CASE WHEN IMPACTO_DESPUES IS NULL THEN ' ' ELSE UPPER(IMPACTO_DESPUES) END)  LIKE UPPER( '%' || :IMPACTO_DESPUES || '%')  AND (CASE WHEN VALORACION_DESPUES IS NULL THEN ' ' ELSE UPPER(VALORACION_DESPUES) END)  LIKE UPPER( '%' || :VALORACION_DESPUES || '%')  AND (CASE WHEN CATEGORIA_DESPUES IS NULL THEN ' ' ELSE UPPER(CATEGORIA_DESPUES) END)  LIKE UPPER( '%' || :CATEGORIA_DESPUES || '%')  AND (CASE WHEN AFECTA_EJECUCION_CONTRATO IS NULL THEN ' ' ELSE UPPER(AFECTA_EJECUCION_CONTRATO) END)  LIKE UPPER( '%' || :AFECTA_EJECUCION_CONTRATO || '%')  AND (CASE WHEN RESPONBABLE_IMPLEMENTACION IS NULL THEN ' ' ELSE UPPER(RESPONBABLE_IMPLEMENTACION) END)  LIKE UPPER( '%' || :RESPONBABLE_IMPLEMENTACION || '%')  AND (CASE WHEN F_INICIO_TRATAMIENTO IS NULL THEN ' ' ELSE UPPER(F_INICIO_TRATAMIENTO) END)  LIKE UPPER( '%' || :F_INICIO_TRATAMIENTO || '%')  AND (CASE WHEN F_FIN_TRATAMIENTO IS NULL THEN ' ' ELSE UPPER(F_FIN_TRATAMIENTO) END)  LIKE UPPER( '%' || :F_FIN_TRATAMIENTO || '%')  AND (CASE WHEN REALIZACION_MONITOREO IS NULL THEN ' ' ELSE UPPER(REALIZACION_MONITOREO) END)  LIKE UPPER( '%' || :REALIZACION_MONITOREO || '%')  AND (CASE WHEN PERIODICIDAD IS NULL THEN ' ' ELSE UPPER(PERIODICIDAD) END)  LIKE UPPER( '%' || :PERIODICIDAD || '%')  AND (CASE WHEN TIPO_OPCION_ETAPA IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_ETAPA) END)  LIKE UPPER( '%' || :TIPO_OPCION_ETAPA || '%')  AND (CASE WHEN TIPO_OPCION_FUENTE IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_FUENTE) END)  LIKE UPPER( '%' || :TIPO_OPCION_FUENTE || '%')  AND (CASE WHEN TIPO_OPCION_IMPACTO IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_IMPACTO) END)  LIKE UPPER( '%' || :TIPO_OPCION_IMPACTO || '%')  AND (CASE WHEN TIPO_OPCION_IMPACTO_DES IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_IMPACTO_DES) END)  LIKE UPPER( '%' || :TIPO_OPCION_IMPACTO_DES || '%')  AND (CASE WHEN TIPO_OPCION_PROBABILIDAD IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_PROBABILIDAD) END)  LIKE UPPER( '%' || :TIPO_OPCION_PROBABILIDAD || '%')  AND (CASE WHEN TIPO_OPCION_PROBABILIDAD_DES IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_PROBABILIDAD_DES) END)  LIKE UPPER( '%' || :TIPO_OPCION_PROBABILIDAD_DES || '%')  AND (CASE WHEN TIPO_OPCION_TIPO IS NULL THEN ' ' ELSE UPPER(TIPO_OPCION_TIPO) END)  LIKE UPPER( '%' || :TIPO_OPCION_TIPO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
