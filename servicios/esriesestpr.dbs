	<query id="updateEsriesestpr" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_RIES_ESTPR SET COD_T_RIESGO=:COD_T_RIESGO, COD_RIESGO=:COD_RIESGO, DOC_RESPALDO=:DOC_RESPALDO, RESP_ENTREGA=:RESP_ENTREGA, RESP_RECIBIDO=:RESP_RECIBIDO, SUCURSAL_RESP_RECIBIDO=:SUCURSAL_RESP_RECIBIDO, ANALIZADO=:ANALIZADO, VERIFICADO=:VERIFICADO, OBSERVACIONES=:OBSERVACIONES, DETALLE=:DETALLE, ESTIMACION=:ESTIMACION, FECHA_RECIBIDO=TO_DATE(:FECHA_RECIBIDO,'DD/MM/YYYY HH24:MI:SS'), FECHA_ENTREGA=TO_DATE(:FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS'), FUENTE=:FUENTE, ETAPA=:ETAPA, TIPO=:TIPO, CONSECUENCIA_OCURRENCIA=:CONSECUENCIA_OCURRENCIA, PROBABILIDAD=:PROBABILIDAD, IMPACTO=:IMPACTO, VALORACION=:VALORACION, CATEGORIA=:CATEGORIA, TRATAMIENTO=:TRATAMIENTO, PROBABILIDAD_DESPUES=:PROBABILIDAD_DESPUES, IMPACTO_DESPUES=:IMPACTO_DESPUES, VALORACION_DESPUES=:VALORACION_DESPUES, CATEGORIA_DESPUES=:CATEGORIA_DESPUES, AFECTA_EJECUCION_CONTRATO=:AFECTA_EJECUCION_CONTRATO, RESPONBABLE_IMPLEMENTACION=:RESPONBABLE_IMPLEMENTACION, F_INICIO_TRATAMIENTO=:F_INICIO_TRATAMIENTO, F_FIN_TRATAMIENTO=:F_FIN_TRATAMIENTO, REALIZACION_MONITOREO=:REALIZACION_MONITOREO, PERIODICIDAD=:PERIODICIDAD, TIPO_OPCION_ETAPA=:TIPO_OPCION_ETAPA, TIPO_OPCION_FUENTE=:TIPO_OPCION_FUENTE, TIPO_OPCION_IMPACTO=:TIPO_OPCION_IMPACTO, TIPO_OPCION_IMPACTO_DES=:TIPO_OPCION_IMPACTO_DES, TIPO_OPCION_PROBABILIDAD=:TIPO_OPCION_PROBABILIDAD, DESCRIPCION=:DESCRIPCION, TIPO_OPCION_PROBABILIDAD_DES=:TIPO_OPCION_PROBABILIDAD_DES, TIPO_OPCION_TIPO=:TIPO_OPCION_TIPO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_RIES_ESTPR.COMPANIA= :KEY_COMPANIA AND ES_RIES_ESTPR.COD_T_RIESGO= :KEY_COD_T_RIESGO AND ES_RIES_ESTPR.COD_RIESGO= :KEY_COD_RIESGO AND ES_RIES_ESTPR.COD_ESTUDIO= :KEY_COD_ESTUDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

