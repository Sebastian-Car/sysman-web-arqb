<data name="interrupcionvacaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertInterrupcionvacaciones" keyColumns="COMPANIA,ID_DE_PROCESO,ANO,MES,PERIODO,ID_DE_EMPLEADO,ID_DE_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INTERRUPCION_VACACIONES (COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO, FECHA_INICIO, FECHA_FINAL, INICIO_DISFRUTE, FINAL_DISFRUTE, DIAS, ENDINERO, FECHAINTERRUPCION, DIASINTERRUPCION, INTERRUPCION_ENDINERO, NUMACTO, FECHAACTO, FECHAPAGOINTERRUPCION, OBSERVACION_INT, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_PROCESO, :ANO, :MES, :PERIODO, :ID_DE_EMPLEADO, :ID_DE_CONCEPTO, TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), :DIAS, :ENDINERO, TO_DATE(:FECHAINTERRUPCION,'DD/MM/YYYY HH24:MI:SS'), :DIASINTERRUPCION, :INTERRUPCION_ENDINERO, :NUMACTO, TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAPAGOINTERRUPCION,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACION_INT, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_PERIODO":"$PERIODO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="1" name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param defaultValue="1" name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param defaultValue="" name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="0" name="ENDINERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINTERRUPCION" sqlType="STRING"/>
		<param defaultValue="0" name="DIASINTERRUPCION" sqlType="STRING"/>
		<param defaultValue="0" name="INTERRUPCION_ENDINERO" sqlType="STRING"/>
		<param defaultValue="" name="NUMACTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAACTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAPAGOINTERRUPCION" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION_INT" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="interrupcionvacaciones">
		<call-query href="insertInterrupcionvacaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="INICIO_DISFRUTE" query-param="INICIO_DISFRUTE"/>
			<with-param name="FINAL_DISFRUTE" query-param="FINAL_DISFRUTE"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="ENDINERO" query-param="ENDINERO"/>
			<with-param name="FECHAINTERRUPCION" query-param="FECHAINTERRUPCION"/>
			<with-param name="DIASINTERRUPCION" query-param="DIASINTERRUPCION"/>
			<with-param name="INTERRUPCION_ENDINERO" query-param="INTERRUPCION_ENDINERO"/>
			<with-param name="NUMACTO" query-param="NUMACTO"/>
			<with-param name="FECHAACTO" query-param="FECHAACTO"/>
			<with-param name="FECHAPAGOINTERRUPCION" query-param="FECHAPAGOINTERRUPCION"/>
			<with-param name="OBSERVACION_INT" query-param="OBSERVACION_INT"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteInterrupcionvacaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM INTERRUPCION_VACACIONES WHERE INTERRUPCION_VACACIONES.COMPANIA= :KEY_COMPANIA AND INTERRUPCION_VACACIONES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND INTERRUPCION_VACACIONES.ANO= :KEY_ANO AND INTERRUPCION_VACACIONES.MES= :KEY_MES AND INTERRUPCION_VACACIONES.PERIODO= :KEY_PERIODO AND INTERRUPCION_VACACIONES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND INTERRUPCION_VACACIONES.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="interrupcionvacaciones">
		<call-query href="deleteInterrupcionvacaciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getInterrupcionvacacionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO,(TO_CHAR(INTERRUPCION_VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(INTERRUPCION_VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(INTERRUPCION_VACACIONES.FECHAPAGOINTERRUPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOINTERRUPCION,(TO_CHAR(INTERRUPCION_VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(INTERRUPCION_VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE,(TO_CHAR(FECHAINTERRUPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAINTERRUPCION,(CASE INTERRUPCION_ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) INTERRUPCION_ENDINERO, DIASINTERRUPCION  FROM INTERRUPCION_VACACIONES WHERE COMPANIA = :COMPANIA AND ID_DE_EMPLEADO= :ID_EMPLEADO ORDER BY ID_DE_EMPLEADO, FECHA_FINAL DESC, FECHA_INICIO DESC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN FECHAPAGOINTERRUPCION IS NULL THEN ' ' ELSE UPPER(FECHAPAGOINTERRUPCION) END)  LIKE UPPER( '%' || :FECHAPAGOINTERRUPCION || '%')  AND (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :INICIO_DISFRUTE || '%')  AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END)  LIKE UPPER( '%' || :FINAL_DISFRUTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","FECHAPAGOINTERRUPCION":"$FECHAPAGOINTERRUPCION","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","FECHAINTERRUPCION":"$FECHAINTERRUPCION","INTERRUPCION_ENDINERO":"$INTERRUPCION_ENDINERO(type:boolean)","DIASINTERRUPCION":"$DIASINTERRUPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="FECHAPAGOINTERRUPCION" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="interrupcionvacaciones">
		<call-query href="getInterrupcionvacacionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="FECHAPAGOINTERRUPCION" query-param="FECHAPAGOINTERRUPCION"/>
			<with-param name="INICIO_DISFRUTE" query-param="INICIO_DISFRUTE"/>
			<with-param name="FINAL_DISFRUTE" query-param="FINAL_DISFRUTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInterrupcionvacacionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO,(TO_CHAR(INTERRUPCION_VACACIONES.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(INTERRUPCION_VACACIONES.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(INTERRUPCION_VACACIONES.FECHAPAGOINTERRUPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOINTERRUPCION,(TO_CHAR(INTERRUPCION_VACACIONES.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(INTERRUPCION_VACACIONES.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE,(TO_CHAR(FECHAINTERRUPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAINTERRUPCION,(CASE INTERRUPCION_ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) INTERRUPCION_ENDINERO, DIASINTERRUPCION  FROM INTERRUPCION_VACACIONES WHERE COMPANIA = :COMPANIA AND ID_DE_EMPLEADO= :ID_EMPLEADO ORDER BY ID_DE_EMPLEADO, FECHA_FINAL DESC, FECHA_INICIO DESC) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN FECHA_INICIO IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO) END)  LIKE UPPER( '%' || :FECHA_INICIO || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN FECHAPAGOINTERRUPCION IS NULL THEN ' ' ELSE UPPER(FECHAPAGOINTERRUPCION) END)  LIKE UPPER( '%' || :FECHAPAGOINTERRUPCION || '%')  AND (CASE WHEN INICIO_DISFRUTE IS NULL THEN ' ' ELSE UPPER(INICIO_DISFRUTE) END)  LIKE UPPER( '%' || :INICIO_DISFRUTE || '%')  AND (CASE WHEN FINAL_DISFRUTE IS NULL THEN ' ' ELSE UPPER(FINAL_DISFRUTE) END)  LIKE UPPER( '%' || :FINAL_DISFRUTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="FECHAPAGOINTERRUPCION" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="interrupcionvacaciones/numero">
		<call-query href="getInterrupcionvacacionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_INICIO" query-param="FECHA_INICIO"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="FECHAPAGOINTERRUPCION" query-param="FECHAPAGOINTERRUPCION"/>
			<with-param name="INICIO_DISFRUTE" query-param="INICIO_DISFRUTE"/>
			<with-param name="FINAL_DISFRUTE" query-param="FINAL_DISFRUTE"/>

		</call-query>
	</resource>
	<query id="getInterrupcionvacacionesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO,(TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, DIAS,(CASE ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) ENDINERO,(TO_CHAR(FECHAINTERRUPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAINTERRUPCION, DIASINTERRUPCION,(CASE INTERRUPCION_ENDINERO WHEN 0 THEN 'false' ELSE 'true' END) INTERRUPCION_ENDINERO, NUMACTO,(TO_CHAR(FECHAACTO,'DD/MM/YYYY HH24:MI:SS')) FECHAACTO, TO_CHAR(FECHAPAGOINTERRUPCION,'DD/MM/YYYY') FECHAPAGOINTERRUPCION, OBSERVACION_INT,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM INTERRUPCION_VACACIONES WHERE INTERRUPCION_VACACIONES.COMPANIA= :KEY_COMPANIA AND INTERRUPCION_VACACIONES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND INTERRUPCION_VACACIONES.ANO= :KEY_ANO AND INTERRUPCION_VACACIONES.MES= :KEY_MES AND INTERRUPCION_VACACIONES.PERIODO= :KEY_PERIODO AND INTERRUPCION_VACACIONES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND INTERRUPCION_VACACIONES.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","DIAS":"$DIAS","ENDINERO":"$ENDINERO(type:boolean)","FECHAINTERRUPCION":"$FECHAINTERRUPCION","DIASINTERRUPCION":"$DIASINTERRUPCION","INTERRUPCION_ENDINERO":"$INTERRUPCION_ENDINERO(type:boolean)","NUMACTO":"$NUMACTO","FECHAACTO":"$FECHAACTO","FECHAPAGOINTERRUPCION":"$FECHAPAGOINTERRUPCION","OBSERVACION_INT":"$OBSERVACION_INT","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="interrupcionvacaciones/data">
		<call-query href="getInterrupcionvacacionesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateInterrupcionvacaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INTERRUPCION_VACACIONES SET COMPANIA=:COMPANIA, ID_DE_PROCESO=:ID_DE_PROCESO, ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, FECHA_INICIO=TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), INICIO_DISFRUTE=TO_DATE(:INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), FINAL_DISFRUTE=TO_DATE(:FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'), DIAS=:DIAS, ENDINERO=:ENDINERO, FECHAINTERRUPCION=TO_DATE(:FECHAINTERRUPCION,'DD/MM/YYYY HH24:MI:SS'), DIASINTERRUPCION=:DIASINTERRUPCION, INTERRUPCION_ENDINERO=:INTERRUPCION_ENDINERO, NUMACTO=:NUMACTO, FECHAACTO=TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), FECHAPAGOINTERRUPCION=TO_DATE(:FECHAPAGOINTERRUPCION,'DD/MM/YYYY HH24:MI:SS'), OBSERVACION_INT=:OBSERVACION_INT, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE INTERRUPCION_VACACIONES.COMPANIA= :KEY_COMPANIA AND INTERRUPCION_VACACIONES.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND INTERRUPCION_VACACIONES.ANO= :KEY_ANO AND INTERRUPCION_VACACIONES.MES= :KEY_MES AND INTERRUPCION_VACACIONES.PERIODO= :KEY_PERIODO AND INTERRUPCION_VACACIONES.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND INTERRUPCION_VACACIONES.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ENDINERO" sqlType="STRING"/>
		<param name="FECHAINTERRUPCION" sqlType="STRING"/>
		<param name="DIASINTERRUPCION" sqlType="STRING"/>
		<param name="INTERRUPCION_ENDINERO" sqlType="STRING"/>
		<param name="NUMACTO" sqlType="STRING"/>
		<param name="FECHAACTO" sqlType="STRING"/>
		<param name="FECHAPAGOINTERRUPCION" sqlType="STRING"/>
		<param name="OBSERVACION_INT" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="interrupcionvacaciones">
		<call-query href="updateInterrupcionvacaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
