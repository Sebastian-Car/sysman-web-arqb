	<query id="getComprobantespptalPagTodosPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.DESCRIPCION REGISTRO  FROM COMPROBANTE_PPTAL WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.TIPO = :TIPOREGISTRO ORDER BY COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN REGISTRO IS NULL THEN ' ' ELSE UPPER(REGISTRO) END)  LIKE UPPER( '%' || :REGISTRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","REGISTRO":"$REGISTRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOREGISTRO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="REGISTRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantespptal/todosportipo/pag">
		<call-query href="getComprobantespptalPagTodosPorTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOREGISTRO" query-param="TIPOREGISTRO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="REGISTRO" query-param="REGISTRO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalNumTodosPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.DESCRIPCION REGISTRO  FROM COMPROBANTE_PPTAL WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.TIPO = :TIPOREGISTRO ORDER BY COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN REGISTRO IS NULL THEN ' ' ELSE UPPER(REGISTRO) END)  LIKE UPPER( '%' || :REGISTRO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOREGISTRO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="REGISTRO" sqlType="STRING"/>

	</query>
