	<query id="getComprobantespptalTipopornumerofechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  C.TIPO TIPO, C.NUMERO NUMERO,(TO_CHAR(C.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM COMPROBANTE_PPTAL C INNER JOIN TIPO_COMPROBPP T ON (C.TIPO = T.CODIGO) AND (C.COMPANIA = T.COMPANIA) WHERE C.COMPANIA =:COMPANIA AND TRUNC(C.FECHA) &gt; :FECHACOMP AND C.TIPO = :TIPOAF AND C.NUMERO = :NUMEROAFE AND T.CLASE IN ('ADD','DMD','TRA')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACOMP" sqlType="STRING"/>
		<param name="TIPOAF" sqlType="STRING"/>
		<param name="NUMEROAFE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantespptal/tipopornumerofecha">
		<call-query href="getComprobantespptalTipopornumerofechaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACOMP" query-param="FECHACOMP"/>
			<with-param name="TIPOAF" query-param="TIPOAF"/>
			<with-param name="NUMEROAFE" query-param="NUMEROAFE"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalPagConsultalistacptafectarpptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.DESCRIPCION,(TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPO, SUM( CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO - DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) - (DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO - DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO) + (DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO - DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO) ELSE (DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO - DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO) - (DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO - DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO) + (DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO - DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO) END) SALDO, PROYECTOS_PPTAL.NOMBRE NOMBRE_PROYECTO FROM COMPROBANTE_PPTAL INNER JOIN DETALLE_COMPROBANTE_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND COMPROBANTE_PPTAL.TIPO = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND COMPROBANTE_PPTAL.NUMERO = DETALLE_COMPROBANTE_PPTAL.COMPROBANTE INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPO_COMPROBPP ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COMPROBANTE_PPTAL.TIPO = TIPO_COMPROBPP.CODIGO INNER JOIN TIPO_COMPROBPP TCAFET ON COMPROBANTE_PPTAL.COMPANIA = TCAFET.COMPANIA AND TCAFET.CODIGO = :COMPROBANTE_AFECT LEFT JOIN PROYECTOS_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = PROYECTOS_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.ANO = PROYECTOS_PPTAL.ANO AND COMPROBANTE_PPTAL.COD_PROYECTO_PPTAL = PROYECTOS_PPTAL.CODIGO WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.ANO = :ANO AND TIPO_COMPROBPP.CLASE = :CLASEAFECTAR AND TIPO_COMPROBPP.SOLO_AFECT_PPTAL IN (0) AND PLAN_PRESUPUESTAL.VIGENCIA &lt;= CASE WHEN 'NO' LIKE :CADENA THEN PLAN_PRESUPUESTAL.VIGENCIA ELSE TO_NUMBER(:ANO) END AND COMPROBANTE_PPTAL.FECHA &lt;= TO_DATE(:FECHARES,'DD/MM/YYYY') AND ((TCAFET.TECEROIGUAL &lt;&gt; 0 AND COMPROBANTE_PPTAL.TERCERO =:TERCEROCOMPROBANTE ) OR (TCAFET.TECEROIGUAL = 0)) AND COMPROBANTE_PPTAL.SUCURSAL = :SUCURSALCOMPROBANTE AND ( (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO - DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) - (DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO - DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO) + (DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO - DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO)) NOT IN(0) GROUP BY COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.DESCRIPCION, COMPROBANTE_PPTAL.FECHA, COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPO, PROYECTOS_PPTAL.NOMBRE) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN NOMBRE_PROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_PROYECTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","SALDO":"$SALDO","NOMBRE_PROYECTO":"$NOMBRE_PROYECTO"}]}}		</result>
		<param name="COMPROBANTE_AFECT" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASEAFECTAR" sqlType="STRING"/>
		<param name="CADENA" sqlType="STRING"/>
		<param name="FECHARES" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="NOMBRE_PROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantespptal/consultalistacptafectarpptal/pag">
