			<with-param name="NUMEROFINAL" query-param="NUMEROFINAL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalPagUsuariofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  *  FROM (SELECT USUARIO FROM ( SELECT DISTINCT CREATED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND CREATED_BY IS NOT NULL UNION SELECT DISTINCT MODIFIED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND MODIFIED_BY IS NOT NULL) ORDER BY USUARIO) WHERE USUARIO &gt;= :USUARIOINICIAL) WHERE (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"USUARIO":"$USUARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="NUMEROFINAL" sqlType="STRING"/>
		<param name="USUARIOINICIAL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
