	<query id="getComprobantespptalTodosPorCompaniaAnoTipoComprobanteFechaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT('X') CONTEO  FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :STRTIPOCOMPROBANTE AND NUMERO NOT IN (:NUMERO) AND FECHA &gt; :FECHA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONTEO":"$CONTEO(type:integer)"}]}}		</result>
