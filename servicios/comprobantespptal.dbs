			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="VLR_DOCUMENTO" query-param="VLR_DOCUMENTO"/>

		</call-query>
	</resource>

		<query id="getComprobantespptalRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPROBANTE_PPTAL.COMPANIA, COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPO, COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, COMPROBANTE_PPTAL.SUCURSAL, COMPROBANTE_PPTAL.CENTRO_COSTO, COMPROBANTE_PPTAL.AUXILIAR, COMPROBANTE_PPTAL.REFERENCIA, COMPROBANTE_PPTAL.FUENTE_RECURSO,(TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, COMPROBANTE_PPTAL.MES, COMPROBANTE_PPTAL.DIA,(TO_CHAR(COMPROBANTE_PPTAL.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, COMPROBANTE_PPTAL.DESCRIPCION , COMPROBANTE_PPTAL.TEXTO, COMPROBANTE_PPTAL.NRO_DOCUMENTO,(TO_CHAR(COMPROBANTE_PPTAL.FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS')) FECHA_VCN_DOC, COMPROBANTE_PPTAL.VLR_DOCUMENTO, COMPROBANTE_PPTAL.DEBITO, COMPROBANTE_PPTAL.CREDITO, COMPROBANTE_PPTAL.DEBITO_AFECTADO, COMPROBANTE_PPTAL.CREDITO_AFECTADO, COMPROBANTE_PPTAL.DEBITO_AFECTADOCNT, COMPROBANTE_PPTAL.CREDITO_AFECTADOCNT, COMPROBANTE_PPTAL.MODIFICACION_DEBITO, COMPROBANTE_PPTAL.MODIFICACION_CREDITO, COMPROBANTE_PPTAL.ABONADO,(CASE COMPROBANTE_PPTAL.ENTREGADO WHEN 0 THEN 'false' ELSE 'true' END) ENTREGADO,(CASE COMPROBANTE_PPTAL.PAGADOBANCO WHEN 0 THEN 'false' ELSE 'true' END) PAGADOBANCO,(CASE COMPROBANTE_PPTAL.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO,(CASE COMPROBANTE_PPTAL.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO,(CASE COMPROBANTE_PPTAL.CONTRACTUAL WHEN 0 THEN 'false' ELSE 'true' END) CONTRACTUAL, COMPROBANTE_PPTAL.DESTINO,(CASE COMPROBANTE_PPTAL.REGISTROAUTOMATICO WHEN 0 THEN 'false' ELSE 'true' END) REGISTROAUTOMATICO, COMPROBANTE_PPTAL.CARGO, COMPROBANTE_PPTAL.DEPENDENCIA, COMPROBANTE_PPTAL.CODSOLICITANTE, COMPROBANTE_PPTAL.SUCSOLICITANTE,(CASE COMPROBANTE_PPTAL.PAPELES WHEN 0 THEN 'false' ELSE 'true' END) PAPELES, COMPROBANTE_PPTAL.TIPOCONTRATO, COMPROBANTE_PPTAL.NUMEROCONTRATO,(CASE COMPROBANTE_PPTAL.SITUACIONFONDOS WHEN 0 THEN 'false' ELSE 'true' END) SITUACIONFONDOS, COMPROBANTE_PPTAL.TIPO_DOCUMENTO, COMPROBANTE_PPTAL.ANO_GENERA, COMPROBANTE_PPTAL.TIPO_GENERA, COMPROBANTE_PPTAL.NRO_GENERA,(TO_CHAR(COMPROBANTE_PPTAL.FECHA_APROB_VF,'DD/MM/YYYY HH24:MI:SS')) FECHA_APROB_VF, COMPROBANTE_PPTAL.TIPO_VF, COMPROBANTE_PPTAL.TIPO_AUTORIZACION_VF, COMPROBANTE_PPTAL.NRO_AUTORIZACION_VF,(TO_CHAR(COMPROBANTE_PPTAL.FECHA_AUTO_VF,'DD/MM/YYYY HH24:MI:SS')) FECHA_AUTO_VF, COMPROBANTE_PPTAL.COD_PROYECTO_PPTAL, COMPROBANTE_PPTAL.LUGAR, COMPROBANTE_PPTAL.FUENTE_FINANCIACION, COMPROBANTE_PPTAL.ASIGNACION,(CASE COMPROBANTE_PPTAL.DANE WHEN 0 THEN 'false' ELSE 'true' END) DANE, COMPROBANTE_PPTAL.CMPTE_AFECTADO, COMPROBANTE_PPTAL.TIPO_CPTE_AFECT,(CASE COMPROBANTE_PPTAL.NOLIBERAR WHEN 0 THEN 'false' ELSE 'true' END) NOLIBERAR, COMPROBANTE_PPTAL.FICHA, COMPROBANTE_PPTAL.IDCONTRATOSECOP, COMPROBANTE_PPTAL.IDCONTRATOENTIDAD, COMPROBANTE_PPTAL.CREATED_BY, COMPROBANTE_PPTAL.ANOPROYECTO,(TO_CHAR(COMPROBANTE_PPTAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, COMPROBANTE_PPTAL.MODIFIED_BY,(TO_CHAR(COMPROBANTE_PPTAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TIPO_COMPROBPP.CLASE, SOLICITANTE.NOMBRE NOMBRESOLICITANTE, PROYECTOS_PPTAL.NOMBRE NOMBRE_PROYECTO_PPTAL,(CASE COMPROBANTE_PPTAL.MEN_VIATICOS WHEN 0 THEN 'false' ELSE 'true' END) MEN_VIATICOS,(CASE COMPROBANTE_PPTAL.INF_MEN WHEN 0 THEN 'false' ELSE 'true' END) INF_MEN,(CASE TIPO_COMPROBPP.OBLIGAAFECTACION WHEN 0 THEN 'false' ELSE 'true' END) OBLIGAAFECTACION, COMPROBANTE_PPTAL.CERTIFICADO_PAA, COMPROBANTE_PPTAL.TIPO_COMPROMISO, TIPO_COMPROMISOPPTAL.NOMBRE AS NOMBRE_COMPROMISO FROM COMPROBANTE_PPTAL INNER JOIN TIPO_COMPROBPP ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COMPROBANTE_PPTAL.TIPO = TIPO_COMPROBPP.CODIGO INNER JOIN TERCERO ON COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN TERCERO SOLICITANTE ON COMPROBANTE_PPTAL.COMPANIA = SOLICITANTE.COMPANIA AND COMPROBANTE_PPTAL.CODSOLICITANTE = SOLICITANTE.NIT AND COMPROBANTE_PPTAL.SUCSOLICITANTE = SOLICITANTE.SUCURSAL LEFT JOIN PROYECTOS_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = PROYECTOS_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.ANO = PROYECTOS_PPTAL.ANO AND COMPROBANTE_PPTAL.COD_PROYECTO_PPTAL = PROYECTOS_PPTAL.CODIGO LEFT JOIN TIPO_COMPROMISOPPTAL ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROMISOPPTAL.COMPANIA AND COMPROBANTE_PPTAL.TIPO_COMPROMISO = TIPO_COMPROMISOPPTAL.CODIGO WHERE COMPROBANTE_PPTAL.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_PPTAL.ANO= :KEY_ANO AND COMPROBANTE_PPTAL.TIPO= :KEY_TIPO AND COMPROBANTE_PPTAL.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO","FECHA":"$FECHA","MES":"$MES(type:long)","DIA":"$DIA(type:long)","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","DESCRIPCION":"$DESCRIPCION","TEXTO":"$TEXTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","FECHA_VCN_DOC":"$FECHA_VCN_DOC","VLR_DOCUMENTO":"$VLR_DOCUMENTO","DEBITO":"$DEBITO","CREDITO":"$CREDITO","DEBITO_AFECTADO":"$DEBITO_AFECTADO","CREDITO_AFECTADO":"$CREDITO_AFECTADO","DEBITO_AFECTADOCNT":"$DEBITO_AFECTADOCNT","CREDITO_AFECTADOCNT":"$CREDITO_AFECTADOCNT","MODIFICACION_DEBITO":"$MODIFICACION_DEBITO","MODIFICACION_CREDITO":"$MODIFICACION_CREDITO","ABONADO":"$ABONADO","ENTREGADO":"$ENTREGADO(type:boolean)","PAGADOBANCO":"$PAGADOBANCO(type:boolean)","IMPRESO":"$IMPRESO(type:boolean)","ANULADO":"$ANULADO(type:boolean)","CONTRACTUAL":"$CONTRACTUAL(type:boolean)","DESTINO":"$DESTINO","REGISTROAUTOMATICO":"$REGISTROAUTOMATICO(type:boolean)","CARGO":"$CARGO","DEPENDENCIA":"$DEPENDENCIA","CODSOLICITANTE":"$CODSOLICITANTE","SUCSOLICITANTE":"$SUCSOLICITANTE","PAPELES":"$PAPELES(type:boolean)","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO(type:long)","SITUACIONFONDOS":"$SITUACIONFONDOS(type:boolean)","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","ANO_GENERA":"$ANO_GENERA(type:integer)","TIPO_GENERA":"$TIPO_GENERA","NRO_GENERA":"$NRO_GENERA(type:long)","FECHA_APROB_VF":"$FECHA_APROB_VF","TIPO_VF":"$TIPO_VF","TIPO_AUTORIZACION_VF":"$TIPO_AUTORIZACION_VF","NRO_AUTORIZACION_VF":"$NRO_AUTORIZACION_VF","FECHA_AUTO_VF":"$FECHA_AUTO_VF","COD_PROYECTO_PPTAL":"$COD_PROYECTO_PPTAL","LUGAR":"$LUGAR","FUENTE_FINANCIACION":"$FUENTE_FINANCIACION","ASIGNACION":"$ASIGNACION","DANE":"$DANE(type:boolean)","CMPTE_AFECTADO":"$CMPTE_AFECTADO(type:long)","TIPO_CPTE_AFECT":"$TIPO_CPTE_AFECT","NOLIBERAR":"$NOLIBERAR(type:boolean)","FICHA":"$FICHA","IDCONTRATOSECOP":"$IDCONTRATOSECOP","IDCONTRATOENTIDAD":"$IDCONTRATOENTIDAD","CREATED_BY":"$CREATED_BY","ANOPROYECTO":"$ANOPROYECTO(type:integer)","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CLASE":"$CLASE","NOMBRESOLICITANTE":"$NOMBRESOLICITANTE","NOMBRE_PROYECTO_PPTAL":"$NOMBRE_PROYECTO_PPTAL","MEN_VIATICOS":"$MEN_VIATICOS(type:boolean)","INF_MEN":"$INF_MEN(type:boolean)","OBLIGAAFECTACION":"$OBLIGAAFECTACION(type:boolean)","CERTIFICADO_PAA":"$CERTIFICADO_PAA","TIPO_COMPROMISO":"$TIPO_COMPROMISO","NOMBRE_COMPROMISO":"$NOMBRE_COMPROMISO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantespptal/data">
		<call-query href="getComprobantespptalRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>

		<query id="updateComprobantespptal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPROBANTE_PPTAL SET CREDITO_AFECTADO=:CREDITO_AFECTADO, ABONADO=:ABONADO, TIPO_VF=:TIPO_VF, SUCURSAL=:SUCURSAL, FUENTE_RECURSO=:FUENTE_RECURSO, NUMERO=:NUMERO, NRO_AUTORIZACION_VF=:NRO_AUTORIZACION_VF, TEXTO=:TEXTO, ASIGNACION=:ASIGNACION, FECHA_VCN_DOC=TO_DATE(:FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS'), LUGAR=:LUGAR, DESTINO=:DESTINO, FECHA_AUTO_VF=TO_DATE(:FECHA_AUTO_VF,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, FUENTE_FINANCIACION=:FUENTE_FINANCIACION, DEBITO_AFECTADO=:DEBITO_AFECTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), NRO_GENERA=:NRO_GENERA, INF_MEN=:INF_MEN, CREDITO_AFECTADOCNT=:CREDITO_AFECTADOCNT, REGISTROAUTOMATICO=:REGISTROAUTOMATICO, DEBITO_AFECTADOCNT=:DEBITO_AFECTADOCNT, MEN_VIATICOS=:MEN_VIATICOS, COD_PROYECTO_PPTAL=:COD_PROYECTO_PPTAL, DANE=:DANE, FECHA_VENCIMIENTO=TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), NUMEROCONTRATO=:NUMEROCONTRATO, DEPENDENCIA=:DEPENDENCIA, CREDITO=:CREDITO, PAGADOBANCO=:PAGADOBANCO, MODIFICACION_DEBITO=:MODIFICACION_DEBITO, FECHA_APROB_VF=TO_DATE(:FECHA_APROB_VF,'DD/MM/YYYY HH24:MI:SS'), CONTRACTUAL=:CONTRACTUAL, TIPO=:TIPO, DESCRIPCION=:DESCRIPCION, VLR_DOCUMENTO=:VLR_DOCUMENTO, ANO_GENERA=:ANO_GENERA, TERCERO=:TERCERO, ENTREGADO=:ENTREGADO, PAPELES=:PAPELES, REFERENCIA=:REFERENCIA, MODIFICACION_CREDITO=:MODIFICACION_CREDITO, DIA=:DIA, CENTRO_COSTO=:CENTRO_COSTO, CARGO=:CARGO, TIPOCONTRATO=:TIPOCONTRATO, MES=:MES, TIPO_GENERA=:TIPO_GENERA, AUXILIAR=:AUXILIAR, TIPO_DOCUMENTO=:TIPO_DOCUMENTO, ANO=:ANO, DEBITO=:DEBITO, SITUACIONFONDOS=:SITUACIONFONDOS, CODSOLICITANTE=:CODSOLICITANTE, ANULADO=:ANULADO, SUCSOLICITANTE=:SUCSOLICITANTE, NRO_DOCUMENTO=:NRO_DOCUMENTO, TIPO_AUTORIZACION_VF=:TIPO_AUTORIZACION_VF, IMPRESO=:IMPRESO, ANOPROYECTO=:ANOPROYECTO, CMPTE_AFECTADO=:CMPTE_AFECTADO, TIPO_CPTE_AFECT=:TIPO_CPTE_AFECT, NOLIBERAR=:NOLIBERAR, FICHA=:FICHA, IDCONTRATOSECOP=:IDCONTRATOSECOP, IDCONTRATOENTIDAD=:IDCONTRATOENTIDAD, CERTIFICADO_PAA=:CERTIFICADO_PAA, TIPO_COMPROMISO=:TIPO_COMPROMISO WHERE COMPROBANTE_PPTAL.COMPANIA= :KEY_COMPANIA AND COMPROBANTE_PPTAL.ANO= :KEY_ANO AND COMPROBANTE_PPTAL.TIPO= :KEY_TIPO AND COMPROBANTE_PPTAL.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

