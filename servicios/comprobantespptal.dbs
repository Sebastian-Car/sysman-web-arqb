			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="REGISTRO" query-param="REGISTRO"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalConteoPorTipoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPO AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
