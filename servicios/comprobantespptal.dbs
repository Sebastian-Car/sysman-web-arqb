	<query id="insertComprobantespptal" keyColumns="COMPANIA,ANO,TIPO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPROBANTE_PPTAL (FECHA_APROB_VF, TIPO_VF, CONTRACTUAL, SUCURSAL, FUENTE_RECURSO, TIPO, NRO_AUTORIZACION_VF, DESCRIPCION, NUMERO, TEXTO, VLR_DOCUMENTO, TERCERO, ASIGNACION, FECHA_VCN_DOC, LUGAR, PAPELES, REFERENCIA, DESTINO, FECHA_AUTO_VF, CENTRO_COSTO, FUENTE_FINANCIACION, TIPOCONTRATO, AUXILIAR, FECHA, TIPO_DOCUMENTO, INF_MEN, ANO, SITUACIONFONDOS, REGISTROAUTOMATICO, NRO_DOCUMENTO, TIPO_AUTORIZACION_VF, COD_PROYECTO_PPTAL, MEN_VIATICOS, COMPANIA, DANE, NUMEROCONTRATO, DEPENDENCIA, CREATED_BY, DATE_CREATED, ANOPROYECTO, CMPTE_AFECTADO, TIPO_CPTE_AFECT, NOLIBERAR, FICHA, IDCONTRATOSECOP, IDCONTRATOENTIDAD, CERTIFICADO_PAA, TIPO_COMPROMISO) VALUES (TO_DATE(:FECHA_APROB_VF,'DD/MM/YYYY HH24:MI:SS'), :TIPO_VF, :CONTRACTUAL, :SUCURSAL, :FUENTE_RECURSO, :TIPO, :NRO_AUTORIZACION_VF, :DESCRIPCION, :NUMERO, :TEXTO, :VLR_DOCUMENTO, :TERCERO, :ASIGNACION, TO_DATE(:FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS'), :LUGAR, :PAPELES, :REFERENCIA, :DESTINO, TO_DATE(:FECHA_AUTO_VF,'DD/MM/YYYY HH24:MI:SS'), :CENTRO_COSTO, :FUENTE_FINANCIACION, :TIPOCONTRATO, :AUXILIAR, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :TIPO_DOCUMENTO, :INF_MEN, :ANO, :SITUACIONFONDOS, :REGISTROAUTOMATICO, :NRO_DOCUMENTO, :TIPO_AUTORIZACION_VF, :COD_PROYECTO_PPTAL, :MEN_VIATICOS, :COMPANIA, :DANE, :NUMEROCONTRATO, :DEPENDENCIA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :ANOPROYECTO, :CMPTE_AFECTADO, :TIPO_CPTE_AFECT, :NOLIBERAR, :FICHA, :IDCONTRATOSECOP, :IDCONTRATOENTIDAD, :CERTIFICADO_PAA, :TIPO_COMPROMISO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
