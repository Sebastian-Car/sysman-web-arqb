	<query id="getComprobantespptalPagTodosPorCompaniaNumeroMesFechaTipoComprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.TIPO, TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY') FECHA, COMPROBANTE_PPTAL.DESCRIPCION, COMPROBANTE_PPTAL.ANO, (CONCAT(NVL(COMPROBANTE_PPTAL.TEXTO,' '), '.') ) TEXTO, COMPROBANTE_PPTAL.NRO_DOCUMENTO, COMPROBANTE_PPTAL.VLR_DOCUMENTO, COMPROBANTE_PPTAL.TERCERO, COMPROBANTE_PPTAL.SUCURSAL, COMPROBANTE_PPTAL.REFERENCIA, COMPROBANTE_PPTAL.TIPOCONTRATO, COMPROBANTE_PPTAL.NUMEROCONTRATO, COMPROBANTE_PPTAL.TIPO_DOCUMENTO,(TO_CHAR(COMPROBANTE_PPTAL.FECHA_VCN_DOC,'DD/MM/YYYY HH24:MI:SS')) FECHA_VCN_DOC, COMPROBANTE_PPTAL.DESTINO, COMPROBANTE_PPTAL.DEPENDENCIA, COMPROBANTE_PPTAL.CARGO FROM COMPROBANTE_PPTAL WHERE COMPROBANTE_PPTAL.COMPANIA =:COMPANIA AND COMPROBANTE_PPTAL.ANO =:ANIO AND COMPROBANTE_PPTAL.TIPO =:STRTIPOCOMPROBANTE AND COMPROBANTE_PPTAL.NUMERO &lt;&gt;:NUMEROS AND COMPROBANTE_PPTAL.FECHA &lt;= TO_DATE(:FECHAS,'DD/MM/YYYY HH24:MI:SS') ORDER BY COMPROBANTE_PPTAL.COMPANIA, COMPROBANTE_PPTAL.TIPO, COMPROBANTE_PPTAL.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TEXTO IS NULL THEN ' ' ELSE UPPER(TEXTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TEXTO), '%')) AND (CASE WHEN NRO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(NRO_DOCUMENTO) END) LIKE UPPER(CONCAT(:NRO_DOCUMENTO, '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN TIPOCONTRATO IS NULL THEN ' ' ELSE UPPER(TIPOCONTRATO) END) LIKE UPPER(CONCAT(:TIPOCONTRATO, '%')) AND (CASE WHEN NUMEROCONTRATO IS NULL THEN ' ' ELSE UPPER(NUMEROCONTRATO) END) LIKE UPPER(CONCAT(:NUMEROCONTRATO, '%')) AND (CASE WHEN TIPO_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(TIPO_DOCUMENTO) END) LIKE UPPER(CONCAT(:TIPO_DOCUMENTO, '%')) AND (CASE WHEN FECHA_VCN_DOC IS NULL THEN ' ' ELSE UPPER(FECHA_VCN_DOC) END) LIKE UPPER(CONCAT(:FECHA_VCN_DOC, '%')) AND (CASE WHEN DESTINO IS NULL THEN ' ' ELSE UPPER(DESTINO) END) LIKE UPPER(CONCAT(:DESTINO, '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END) LIKE UPPER(CONCAT(:CARGO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","TIPO":"$TIPO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","ANO":"$ANO(type:integer)","TEXTO":"$TEXTO","NRO_DOCUMENTO":"$NRO_DOCUMENTO","VLR_DOCUMENTO":"$VLR_DOCUMENTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","REFERENCIA":"$REFERENCIA","TIPOCONTRATO":"$TIPOCONTRATO","NUMEROCONTRATO":"$NUMEROCONTRATO","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","FECHA_VCN_DOC":"$FECHA_VCN_DOC","DESTINO":"$DESTINO","DEPENDENCIA":"$DEPENDENCIA","CARGO":"$CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMEROS" sqlType="STRING"/>
		<param name="FECHAS" sqlType="STRING"/>
