	<query id="getComprobantespptalCuentaporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT DETALLE_COMPROBANTE_PPTAL.CUENTA  FROM COMPROBANTE_PPTAL INNER JOIN DETALLE_COMPROBANTE_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND COMPROBANTE_PPTAL.TIPO = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND COMPROBANTE_PPTAL.NUMERO = DETALLE_COMPROBANTE_PPTAL.COMPROBANTE WHERE COMPROBANTE_PPTAL.COMPANIA =:COMPANIA AND COMPROBANTE_PPTAL.ANO =:ANO AND COMPROBANTE_PPTAL.TIPO =:TIPO AND COMPROBANTE_PPTAL.NUMERO =:NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA"}]}}		</result>
