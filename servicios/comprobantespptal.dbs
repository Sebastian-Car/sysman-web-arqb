	<query id="getComprobantespptalPagUsuarioinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  USUARIO  FROM ( SELECT DISTINCT CREATED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND CREATED_BY IS NOT NULL UNION SELECT DISTINCT MODIFIED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND MODIFIED_BY IS NOT NULL) ORDER BY USUARIO) WHERE (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"USUARIO":"$USUARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="NUMEROFINAL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantespptal/usuarioinicial/pag">
		<call-query href="getComprobantespptalPagUsuarioinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="NUMEROINICIAL" query-param="NUMEROINICIAL"/>
			<with-param name="NUMEROFINAL" query-param="NUMEROFINAL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalNumUsuarioinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  USUARIO  FROM ( SELECT DISTINCT CREATED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND CREATED_BY IS NOT NULL UNION SELECT DISTINCT MODIFIED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND MODIFIED_BY IS NOT NULL) ORDER BY USUARIO) WHERE (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="ANOFINAL" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="NUMEROINICIAL" sqlType="STRING"/>
		<param name="NUMEROFINAL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantespptal/usuarioinicial/num">
		<call-query href="getComprobantespptalNumUsuarioinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
