	<query id="getComprobantespptalPagListacntpptosafectarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(COMPROBANTE_PPTAL.COMPANIA,'-'), COMPROBANTE_PPTAL.TIPO),'-'), COMPROBANTE_PPTAL.NUMERO),'-'), DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO) INDICE, DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, SUBSTR(COMPROBANTE_PPTAL.DESCRIPCION,1,100) DESCRIPCION,(TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, DETALLE_COMPROBANTE_PPTAL.CUENTA, ( CASE WHEN PLAN_PRESUPUESTAL.NATURALEZA = 'D' THEN ( DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO - DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO ) - ( DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO - DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO ) + ( DETALLE_COMPROBANTE_PPTAL .MODIFICACION_DEBITO - DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO ) ELSE ( DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO - DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO ) - ( DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO - DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO ) + ( DETALLE_COMPROBANTE_PPTAL.MODIFICACION_CREDITO - DETALLE_COMPROBANTE_PPTAL .MODIFICACION_DEBITO ) END ) SALDO, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO = '99999999999999999999' THEN CENTRO_COSTO.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO, ' - '), CENTRO_COSTO.NOMBRE) END CENTRO_COSTO_NOM, CASE WHEN DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO = '99999999999999999999' THEN FUENTE_RECURSOS.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO, ' - '), FUENTE_RECURSOS.NOMBRE) END FUENTE_RECURSOS_NOM, CASE WHEN DETALLE_COMPROBANTE_PPTAL.AUXILIAR = '99999999999999999999' THEN AUXILIAR.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.AUXILIAR, ' - '), AUXILIAR.NOMBRE) END AUXILIAR_NOM, CASE WHEN DETALLE_COMPROBANTE_PPTAL.REFERENCIA = '99999999999999999999' THEN REFERENCIA.NOMBRE ELSE CONCAT(CONCAT(DETALLE_COMPROBANTE_PPTAL.REFERENCIA, ' - '), REFERENCIA.NOMBRE) END REFERENCIA_NOM, DETALLE_COMPROBANTE_PPTAL.ANO FROM COMPROBANTE_PPTAL INNER JOIN DETALLE_COMPROBANTE_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND COMPROBANTE_PPTAL.TIPO = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND COMPROBANTE_PPTAL.NUMERO = DETALLE_COMPROBANTE_PPTAL.COMPROBANTE INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA = PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPO_COMPROBPP ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COMPROBANTE_PPTAL.TIPO = TIPO_COMPROBPP.CODIGO INNER JOIN CENTRO_COSTO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = CENTRO_COSTO.ANO AND DETALLE_COMPROBANTE_PPTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO INNER JOIN AUXILIAR ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = AUXILIAR.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = AUXILIAR.ANO AND DETALLE_COMPROBANTE_PPTAL.AUXILIAR = AUXILIAR.CODIGO INNER JOIN REFERENCIA ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = REFERENCIA.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = REFERENCIA.ANO AND DETALLE_COMPROBANTE_PPTAL.REFERENCIA = REFERENCIA.CODIGO INNER JOIN FUENTE_RECURSOS ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = FUENTE_RECURSOS.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = FUENTE_RECURSOS.ANO AND DETALLE_COMPROBANTE_PPTAL.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO WHERE COMPROBANTE_PPTAL.COMPANIA = :KEY_COMPANIA AND COMPROBANTE_PPTAL.ANO = :KEY_ANO AND TIPO_COMPROBPP.CLASE = :CLASEAFECTAR AND PLAN_PRESUPUESTAL.ANO = PLAN_PRESUPUESTAL.VIGENCIA AND COMPROBANTE_PPTAL.FECHA &lt;= TO_DATE(:FECHARES, 'DD/MM/YYYY') AND DETALLE_COMPROBANTE_PPTAL.TERCERO = :TERCERO AND DETALLE_COMPROBANTE_PPTAL.SUCURSAL = :SUCURSAL AND ( ( DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO - DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO ) - ( DETALLE_COMPROBANTE_PPTAL.DEBITO_AFECTADO - DETALLE_COMPROBANTE_PPTAL.CREDITO_AFECTADO ) + ( DETALLE_COMPROBANTE_PPTAL.MODIFICACION_DEBITO - DETALLE_COMPROBANTE_PPTAL. MODIFICACION_CREDITO ) ) &gt; 0 ORDER BY FECHA DESC) INI WHERE (CASE WHEN TIPO_CPTE IS NULL THEN ' ' ELSE UPPER(TIPO_CPTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_CPTE), '%')) AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBANTE), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVO), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN CENTRO_COSTO_NOM IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO_NOM), '%')) AND (CASE WHEN FUENTE_RECURSOS_NOM IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSOS_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSOS_NOM), '%')) AND (CASE WHEN AUXILIAR_NOM IS NULL THEN ' ' ELSE UPPER(AUXILIAR_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR_NOM), '%')) AND (CASE WHEN REFERENCIA_NOM IS NULL THEN ' ' ELSE UPPER(REFERENCIA_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA_NOM), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"INDICE":"$INDICE","COMPANIA":"$COMPANIA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CUENTA":"$CUENTA","SALDO":"$SALDO(type:integer)","CENTRO_COSTO_NOM":"$CENTRO_COSTO_NOM","FUENTE_RECURSOS_NOM":"$FUENTE_RECURSOS_NOM","AUXILIAR_NOM":"$AUXILIAR_NOM","REFERENCIA_NOM":"$REFERENCIA_NOM","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="CLASEAFECTAR" sqlType="STRING"/>
		<param name="FECHARES" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="CENTRO_COSTO_NOM" sqlType="STRING"/>
		<param name="FUENTE_RECURSOS_NOM" sqlType="STRING"/>
		<param name="AUXILIAR_NOM" sqlType="STRING"/>
		<param name="REFERENCIA_NOM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
