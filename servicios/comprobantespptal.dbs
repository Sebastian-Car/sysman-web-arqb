	<query id="getComprobantespptalPagTodosPorTipoYCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY') FECHA, ((DEBITO-CREDITO)-(DEBITO_AFECTADO-CREDITO_AFECTADO)+(MODIFICACION_DEBITO-MODIFICACION_CREDITO)) TOTALNETO, COMPROBANTE_PPTAL.DESCRIPCION  FROM COMPROBANTE_PPTAL WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.TIPO = :TIPO ORDER BY COMPROBANTE_PPTAL.COMPANIA, COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPO, COMPROBANTE_PPTAL.NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN TOTALNETO IS NULL THEN ' ' ELSE UPPER(TOTALNETO) END)  LIKE UPPER(:TOTALNETO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","TOTALNETO":"$TOTALNETO(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="TOTALNETO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
