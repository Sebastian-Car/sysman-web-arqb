			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalNumPorAnioTipoMayoresANumeroQuery"  useConfig="sysmandsunist">
