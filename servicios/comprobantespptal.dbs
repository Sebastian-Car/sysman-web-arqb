	<query id="getComprobantespptalNumUsuariofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  *  FROM (SELECT USUARIO FROM ( SELECT DISTINCT CREATED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND CREATED_BY IS NOT NULL UNION SELECT DISTINCT MODIFIED_BY USUARIO FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND NUMERO BETWEEN :NUMEROINICIAL AND :NUMEROFINAL AND MODIFIED_BY IS NOT NULL) ORDER BY USUARIO) WHERE USUARIO &gt;= :USUARIOINICIAL) WHERE (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
