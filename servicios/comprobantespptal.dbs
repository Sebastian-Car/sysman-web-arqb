	<query id="getComprobantespptalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (CASE WHEN PCK_SYSMAN_UTL.FC_VERIFICAR_ESTADODIA ( COMPROBANTE_PPTAL.COMPANIA, COMPROBANTE_PPTAL.ANO , COMPROBANTE_PPTAL.MES , COMPROBANTE_PPTAL.DIA , :MODULO, :PROCESO ) ='A' THEN 'true' else 'false' END) ABIERTO, COMPROBANTE_PPTAL.COMPANIA, COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPO, COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY') FECHA, COMPROBANTE_PPTAL.DESCRIPCION, COMPROBANTE_PPTAL.VLR_DOCUMENTO FROM COMPROBANTE_PPTAL INNER JOIN TIPO_COMPROBPP ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COMPROBANTE_PPTAL.TIPO = TIPO_COMPROBPP.CODIGO INNER JOIN TERCERO ON COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.ANO = :ANIO AND COMPROBANTE_PPTAL.TIPO = :STRTIPOCOMPROBANTE AND TO_NUMBER(TO_CHAR(COMPROBANTE_PPTAL.FECHA, 'MM')) = :MES ORDER BY COMPROBANTE_PPTAL.FECHA DESC, COMPROBANTE_PPTAL.NUMERO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantespptal/numero">
		<call-query href="getComprobantespptalNumeroQuery">
			<with-param name="MODULO" query-param="MODULO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
