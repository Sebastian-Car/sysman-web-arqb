	<query id="getComprobantespptalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (CASE WHEN PCK_SYSMAN_UTL.FC_VERIFICAR_ESTADODIA ( COMPROBANTE_PPTAL.COMPANIA, COMPROBANTE_PPTAL.ANO , COMPROBANTE_PPTAL.MES , COMPROBANTE_PPTAL.DIA , :MODULO, :PROCESO ) ='A' THEN 'true' else 'false' END) ABIERTO, COMPROBANTE_PPTAL.COMPANIA, COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.TIPO, COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.TERCERO, TERCERO.NOMBRE NOMBRETERCERO, TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY') FECHA, COMPROBANTE_PPTAL.DESCRIPCION, COMPROBANTE_PPTAL.VLR_DOCUMENTO FROM COMPROBANTE_PPTAL INNER JOIN TIPO_COMPROBPP ON COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND COMPROBANTE_PPTAL.TIPO = TIPO_COMPROBPP.CODIGO INNER JOIN TERCERO ON COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.ANO = :ANIO AND COMPROBANTE_PPTAL.TIPO = :STRTIPOCOMPROBANTE AND TO_NUMBER(TO_CHAR(COMPROBANTE_PPTAL.FECHA, 'MM')) = :MES ORDER BY COMPROBANTE_PPTAL.FECHA DESC, COMPROBANTE_PPTAL.NUMERO DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN VLR_DOCUMENTO IS NULL THEN ' ' ELSE UPPER(VLR_DOCUMENTO) END) LIKE UPPER(CONCAT(:VLR_DOCUMENTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ABIERTO":"$ABIERTO(type:boolean)","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","FECHA":"$FECHA","DESCRIPCION":"$DESCRIPCION","VLR_DOCUMENTO":"$VLR_DOCUMENTO"}]}}		</result>
		<param name="MODULO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="STRTIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="VLR_DOCUMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="comprobantespptal">
