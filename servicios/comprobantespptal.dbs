	<query id="getComprobantespptalPagPorordencompraQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, COMPROBANTE_PPTAL.DESCRIPCION REGISTRO  FROM COMPROBANTE_PPTAL INNER JOIN ORDENDECOMPRAPPTO ON COMPROBANTE_PPTAL.COMPANIA = ORDENDECOMPRAPPTO.COMPANIA AND COMPROBANTE_PPTAL.TIPO = ORDENDECOMPRAPPTO.TIPOPPTO AND COMPROBANTE_PPTAL.NUMERO = ORDENDECOMPRAPPTO.NUMEROPPTO WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND ORDENDECOMPRAPPTO.TIPOPPTO = :TIPOREGISTRO AND ORDENDECOMPRAPPTO.NUMERO = :NUMEROCOM ORDER BY COMPROBANTE_PPTAL.ANO, COMPROBANTE_PPTAL.NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN REGISTRO IS NULL THEN ' ' ELSE UPPER(REGISTRO) END)  LIKE UPPER( '%' || :REGISTRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","REGISTRO":"$REGISTRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOREGISTRO" sqlType="STRING"/>
		<param name="NUMEROCOM" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="REGISTRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
