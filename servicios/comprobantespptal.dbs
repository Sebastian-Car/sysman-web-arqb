	<query id="getComprobantespptalPagNumerocondportercerosucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, SUBSTR(COMPROBANTE_PPTAL.DESCRIPCION,1,100) DESCRIPCION, TO_CHAR(COMPROBANTE_PPTAL.FECHA, 'DD/MM/YYYY') FECHA, COMPROBANTE_PPTAL.ANO  FROM COMPROBANTE_PPTAL WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.ANO = :ANO AND COMPROBANTE_PPTAL.TIPO = :TIPO AND TRUNC(COMPROBANTE_PPTAL.FECHA) &lt;= TO_DATE(:FECHACOMP,'DD/MM/YYYY HH24:MI:SS') AND COMPROBANTE_PPTAL.TERCERO = ( CASE WHEN :PIDETERCERO IN (0) THEN COMPROBANTE_PPTAL.TERCERO ELSE :TERCERO END) AND COMPROBANTE_PPTAL.SUCURSAL = ( CASE WHEN :PIDETERCERO IN (0) THEN COMPROBANTE_PPTAL.SUCURSAL ELSE :SUCURSAL END) AND ( ( CASE WHEN :INDAFECTACION IN (0) THEN (CREDITO - DEBITO - (CREDITO_AFECTADO - DEBITO_AFECTADO)+( MODIFICACION_CREDITO - MODIFICACION_DEBITO)) WHEN :INDAFECTACION IN(1) THEN (DEBITO - CREDITO - (DEBITO_AFECTADO - CREDITO_AFECTADO) +(MODIFICACION_DEBITO - MODIFICACION_CREDITO)) ELSE 1 END ) &gt;0 )) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FECHACOMP" sqlType="STRING"/>
		<param name="PIDETERCERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="INDAFECTACION" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
