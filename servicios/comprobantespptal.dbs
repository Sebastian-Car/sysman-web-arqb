			<with-param name="NUMEROCOM" query-param="NUMEROCOM"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="REGISTRO" query-param="REGISTRO"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalPagPorAnioTipoMayoresANumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUMERO, DESCRIPCION  FROM COMPROBANTE_PPTAL WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND TIPO = :TIPO AND NUMERO &gt;= :NUMEROINI ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMEROINI" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
