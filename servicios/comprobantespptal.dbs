		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="comprobantespptal/porcomprobanteinicial/num">
		<call-query href="getComprobantespptalNumPorcomprobanteinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="ANOFINAL" query-param="ANOFINAL"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getComprobantespptalPagPorcomprobantefinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPROBANTE_PPTAL.NUMERO, TO_CHAR(COMPROBANTE_PPTAL.FECHA,'DD/MM/YYYY')FECHA, COMPROBANTE_PPTAL.DESCRIPCION  FROM COMPROBANTE_PPTAL WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.ANO BETWEEN :ANOINICIAL AND :ANOFINAL AND COMPROBANTE_PPTAL.TIPO BETWEEN :TIPOINICIAL AND :TIPOFINAL AND COMPROBANTE_PPTAL.NUMERO &gt;= :NUMEROINICIAL) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
