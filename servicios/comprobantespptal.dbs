	<query id="getComprobantespptalNumTodosPorDetalleComprobantePresupuestalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, NVL(DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE,0) AS TIPO, NVL(DETALLE_COMPROBANTE_PPTAL.CUENTA,0) AS RUBROS, NVL(PLAN_PRESUPUESTAL.NOMBRE,'ND') AS DRUBROS, NVL(DETALLE_COMPROBANTE_PPTAL.COMPROBANTE,0) AS COMPROBANTE, NVL(DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO,0) AS VALOR_D, '0.00' AS EDITABLE  FROM COMPROBANTE_PPTAL INNER JOIN DETALLE_COMPROBANTE_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = DETALLE_COMPROBANTE_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.TIPO = DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE AND COMPROBANTE_PPTAL.ANO = DETALLE_COMPROBANTE_PPTAL.ANO AND COMPROBANTE_PPTAL.NUMERO = DETALLE_COMPROBANTE_PPTAL.COMPROBANTE INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.CUENTA = PLAN_PRESUPUESTAL.CODIGO AND DETALLE_COMPROBANTE_PPTAL.ANO = PLAN_PRESUPUESTAL.ANO WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND COMPROBANTE_PPTAL.TIPO = :TIPOPPTO AND COMPROBANTE_PPTAL.NUMERO = :NUMEROPPTO ORDER BY DETALLE_COMPROBANTE_PPTAL.COMPROBANTE) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN RUBROS IS NULL THEN ' ' ELSE UPPER(RUBROS) END)  LIKE UPPER( '%' || :RUBROS || '%')  AND (CASE WHEN DRUBROS IS NULL THEN ' ' ELSE UPPER(DRUBROS) END)  LIKE UPPER( '%' || :DRUBROS || '%')  AND (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END)  LIKE UPPER( '%' || :COMPROBANTE || '%')  AND (CASE WHEN VALOR_D IS NULL THEN ' ' ELSE UPPER(VALOR_D) END)  LIKE UPPER( '%' || :VALOR_D || '%')  AND (CASE WHEN EDITABLE IS NULL THEN ' ' ELSE UPPER(EDITABLE) END)  LIKE UPPER( '%' || :EDITABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
