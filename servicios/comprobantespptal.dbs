		<param name="DRUBROS" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="VALOR_D" sqlType="STRING"/>
		<param name="EDITABLE" sqlType="STRING"/>

	</query>
