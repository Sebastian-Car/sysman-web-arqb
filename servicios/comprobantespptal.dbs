	<query id="getComprobantespptalAfectanProyectosPptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 1 EXISTE  FROM COMPROBANTE_PPTAL INNER JOIN PROYECTOS_PPTAL ON COMPROBANTE_PPTAL.COMPANIA = PROYECTOS_PPTAL.COMPANIA AND COMPROBANTE_PPTAL.ANO = PROYECTOS_PPTAL.ANO AND COMPROBANTE_PPTAL.COD_PROYECTO_PPTAL = PROYECTOS_PPTAL.CODIGO WHERE COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND PROYECTOS_PPTAL.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
