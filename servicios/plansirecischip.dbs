<data name="plansirecischip" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPlansirecischipPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_SIRECI_SCHIP.CODIGO, PLAN_SIRECI_SCHIP.NOMBRE,(CASE PLAN_SIRECI_SCHIP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_SIRECI_SCHIP WHERE PLAN_SIRECI_SCHIP.COMPANIA = :COMPANIA AND PLAN_SIRECI_SCHIP.ANO = :ANO AND PLAN_SIRECI_SCHIP.NATURALEZA = :NATURALEZA AND PLAN_SIRECI_SCHIP.MOVIMIENTO NOT IN (0) ORDER BY PLAN_SIRECI_SCHIP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="plansirecischip/todosporcompania/pag">
		<call-query href="getPlansirecischipPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlansirecischipNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_SIRECI_SCHIP.CODIGO, PLAN_SIRECI_SCHIP.NOMBRE,(CASE PLAN_SIRECI_SCHIP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_SIRECI_SCHIP WHERE PLAN_SIRECI_SCHIP.COMPANIA = :COMPANIA AND PLAN_SIRECI_SCHIP.ANO = :ANO AND PLAN_SIRECI_SCHIP.NATURALEZA = :NATURALEZA AND PLAN_SIRECI_SCHIP.MOVIMIENTO NOT IN (0) ORDER BY PLAN_SIRECI_SCHIP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="plansirecischip/todosporcompania/num">
		<call-query href="getPlansirecischipNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPlansirecischipPorcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PLAN_SIRECI_SCHIP.CODIGO, PLAN_SIRECI_SCHIP.NOMBRE,(CASE PLAN_SIRECI_SCHIP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_SIRECI_SCHIP WHERE PLAN_SIRECI_SCHIP.COMPANIA = :COMPANIA AND PLAN_SIRECI_SCHIP.ANO = :ANO AND PLAN_SIRECI_SCHIP.NATURALEZA = :NATURALEZA AND PLAN_SIRECI_SCHIP.MOVIMIENTO NOT IN (0) ORDER BY PLAN_SIRECI_SCHIP.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="plansirecischip/porcodigo">
		<call-query href="getPlansirecischipPorcodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>

		</call-query>
	</resource>

</data>