	<query id="updateEvreclamacionobjecion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_RECLAMACIONOBJECION SET COMPANIA=:COMPANIA, NUMERO_RADICADO=:NUMERO_RADICADO, NUMERO_EVALUACION=:NUMERO_EVALUACION, CLASE_EVALUACION=:CLASE_EVALUACION, TIPO_EVALUACION=:TIPO_EVALUACION, CEDULA_EVALUADO=:CEDULA_EVALUADO, SUCURSAL_EVALUADO=:SUCURSAL_EVALUADO, CEDULA_EVALUADOR=:CEDULA_EVALUADOR, SUCURSAL_EVALUADOR=:SUCURSAL_EVALUADOR, DECISION=:DECISION, FECHA_RECLAMACION=TO_DATE(:FECHA_RECLAMACION,'DD/MM/YYYY HH24:MI:SS'), MOTIVACION=:MOTIVACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_RECLAMACIONOBJECION.COMPANIA= :KEY_COMPANIA AND EV_RECLAMACIONOBJECION.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_RECLAMACIONOBJECION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_RECLAMACIONOBJECION.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_RECLAMACIONOBJECION.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_RECLAMACIONOBJECION.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND EV_RECLAMACIONOBJECION.NUMERO_RADICADO= :KEY_NUMERO_RADICADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

