			<with-param name="FECHA_RECLAMACION" query-param="FECHA_RECLAMACION"/>
			<with-param name="MOTIVACION" query-param="MOTIVACION"/>
			<with-param name="DECISION" query-param="DECISION"/>

		</call-query>
	</resource>
	<query id="getEvreclamacionobjecionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, NUMERO_RADICADO, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, DECISION,(TO_CHAR(FECHA_RECLAMACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RECLAMACION, MOTIVACION  FROM EV_RECLAMACIONOBJECION WHERE EV_RECLAMACIONOBJECION.COMPANIA= :KEY_COMPANIA AND EV_RECLAMACIONOBJECION.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_RECLAMACIONOBJECION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_RECLAMACIONOBJECION.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_RECLAMACIONOBJECION.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_RECLAMACIONOBJECION.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND EV_RECLAMACIONOBJECION.NUMERO_RADICADO= :KEY_NUMERO_RADICADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_RADICADO":"$NUMERO_RADICADO(type:long)","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR","DECISION":"$DECISION","FECHA_RECLAMACION":"$FECHA_RECLAMACION","MOTIVACION":"$MOTIVACION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_RADICADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evreclamacionobjecion/data">
