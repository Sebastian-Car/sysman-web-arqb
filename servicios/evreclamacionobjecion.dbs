<data name="evreclamacionobjecion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEvreclamacionobjecion" keyColumns="COMPANIA,NUMERO_EVALUACION,CLASE_EVALUACION,TIPO_EVALUACION,CEDULA_EVALUADO,SUCURSAL_EVALUADO,NUMERO_RADICADO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_RECLAMACIONOBJECION (COMPANIA, NUMERO_RADICADO, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, DECISION, FECHA_RECLAMACION, MOTIVACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_RADICADO, :NUMERO_EVALUACION, :CLASE_EVALUACION, :TIPO_EVALUACION, :CEDULA_EVALUADO, :SUCURSAL_EVALUADO, :CEDULA_EVALUADOR, :SUCURSAL_EVALUADOR, :DECISION, TO_DATE(:FECHA_RECLAMACION,'DD/MM/YYYY HH24:MI:SS'), :MOTIVACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","KEY_TIPO_EVALUACION":"$TIPO_EVALUACION","KEY_CEDULA_EVALUADO":"$CEDULA_EVALUADO","KEY_SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","KEY_NUMERO_RADICADO":"$NUMERO_RADICADO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_RADICADO" sqlType="STRING"/>
		<param name="NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADOR" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADOR" sqlType="STRING"/>
		<param name="DECISION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_RECLAMACION" sqlType="STRING"/>
		<param name="MOTIVACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evreclamacionobjecion">
		<call-query href="insertEvreclamacionobjecion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_RADICADO" query-param="NUMERO_RADICADO"/>
			<with-param name="NUMERO_EVALUACION" query-param="NUMERO_EVALUACION"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CEDULA_EVALUADOR" query-param="CEDULA_EVALUADOR"/>
			<with-param name="SUCURSAL_EVALUADOR" query-param="SUCURSAL_EVALUADOR"/>
			<with-param name="DECISION" query-param="DECISION"/>
			<with-param name="FECHA_RECLAMACION" query-param="FECHA_RECLAMACION"/>
			<with-param name="MOTIVACION" query-param="MOTIVACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEvreclamacionobjecion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_RECLAMACIONOBJECION WHERE EV_RECLAMACIONOBJECION.COMPANIA= :KEY_COMPANIA AND EV_RECLAMACIONOBJECION.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_RECLAMACIONOBJECION.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_RECLAMACIONOBJECION.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_RECLAMACIONOBJECION.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_RECLAMACIONOBJECION.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND EV_RECLAMACIONOBJECION.NUMERO_RADICADO= :KEY_NUMERO_RADICADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="INTEGER"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_NUMERO_RADICADO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="evreclamacionobjecion">
		<call-query href="deleteEvreclamacionobjecion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_EVALUACION" query-param="KEY_NUMERO_EVALUACION"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_NUMERO_RADICADO" query-param="KEY_NUMERO_RADICADO"/>

		</call-query>
	</resource>
	<query id="getEvreclamacionobjecionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NUMERO_RADICADO, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO,(TO_CHAR(FECHA_RECLAMACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RECLAMACION, MOTIVACION, DECISION  FROM EV_RECLAMACIONOBJECION WHERE COMPANIA = :COMPANIA AND NUMERO_EVALUACION = :EVALUACION AND CLASE_EVALUACION = :CLASE AND TIPO_EVALUACION = :TIPO AND CEDULA_EVALUADO = :CEDULA_EVALUADO AND SUCURSAL_EVALUADO = :SUCURSAL_EVALUADO) WHERE (CASE WHEN NUMERO_RADICADO IS NULL THEN ' ' ELSE UPPER(NUMERO_RADICADO) END)  LIKE UPPER(:NUMERO_RADICADO || '%')  AND (CASE WHEN FECHA_RECLAMACION IS NULL THEN ' ' ELSE UPPER(FECHA_RECLAMACION) END)  LIKE UPPER( '%' || :FECHA_RECLAMACION || '%')  AND (CASE WHEN MOTIVACION IS NULL THEN ' ' ELSE UPPER(MOTIVACION) END)  LIKE UPPER( '%' || :MOTIVACION || '%')  AND (CASE WHEN DECISION IS NULL THEN ' ' ELSE UPPER(DECISION) END)  LIKE UPPER( '%' || :DECISION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_RADICADO":"$NUMERO_RADICADO(type:long)","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","FECHA_RECLAMACION":"$FECHA_RECLAMACION","MOTIVACION":"$MOTIVACION","DECISION":"$DECISION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="NUMERO_RADICADO" sqlType="STRING"/>
		<param name="FECHA_RECLAMACION" sqlType="STRING"/>
		<param name="MOTIVACION" sqlType="STRING"/>
		<param name="DECISION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evreclamacionobjecion">
		<call-query href="getEvreclamacionobjecionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="NUMERO_RADICADO" query-param="NUMERO_RADICADO"/>
			<with-param name="FECHA_RECLAMACION" query-param="FECHA_RECLAMACION"/>
			<with-param name="MOTIVACION" query-param="MOTIVACION"/>
			<with-param name="DECISION" query-param="DECISION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvreclamacionobjecionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NUMERO_RADICADO, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO,(TO_CHAR(FECHA_RECLAMACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RECLAMACION, MOTIVACION, DECISION  FROM EV_RECLAMACIONOBJECION WHERE COMPANIA = :COMPANIA AND NUMERO_EVALUACION = :EVALUACION AND CLASE_EVALUACION = :CLASE AND TIPO_EVALUACION = :TIPO AND CEDULA_EVALUADO = :CEDULA_EVALUADO AND SUCURSAL_EVALUADO = :SUCURSAL_EVALUADO) WHERE (CASE WHEN NUMERO_RADICADO IS NULL THEN ' ' ELSE UPPER(NUMERO_RADICADO) END)  LIKE UPPER(:NUMERO_RADICADO || '%')  AND (CASE WHEN FECHA_RECLAMACION IS NULL THEN ' ' ELSE UPPER(FECHA_RECLAMACION) END)  LIKE UPPER( '%' || :FECHA_RECLAMACION || '%')  AND (CASE WHEN MOTIVACION IS NULL THEN ' ' ELSE UPPER(MOTIVACION) END)  LIKE UPPER( '%' || :MOTIVACION || '%')  AND (CASE WHEN DECISION IS NULL THEN ' ' ELSE UPPER(DECISION) END)  LIKE UPPER( '%' || :DECISION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EVALUACION" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="NUMERO_RADICADO" sqlType="STRING"/>
		<param name="FECHA_RECLAMACION" sqlType="STRING"/>
		<param name="MOTIVACION" sqlType="STRING"/>
		<param name="DECISION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evreclamacionobjecion/numero">
		<call-query href="getEvreclamacionobjecionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EVALUACION" query-param="EVALUACION"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="TIPO" query-param="TIPO"/>
