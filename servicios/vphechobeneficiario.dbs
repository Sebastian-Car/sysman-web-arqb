<data name="vphechobeneficiario" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertVphechobeneficiario" keyColumns="ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VP_HECHOS_BENEFICIARIOS (COMPANIA, ID_BENEFICIARIOS, ID_HECHOS_PROYECTOS, ID_PROYECTOS, CODIGO_HECHO, CODIGO_PROYECTO, CLASE, IP_CODIGO, IP_NUMERO_ORDEN, NOMBRE, BASE_CONTRIBUCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_BENEFICIARIOS, :ID_HECHOS_PROYECTOS, :ID_PROYECTOS, :CODIGO_HECHO, :CODIGO_PROYECTO, :CLASE, :IP_CODIGO, :IP_NUMERO_ORDEN, :NOMBRE, :BASE_CONTRIBUCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ID":"$ID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_BENEFICIARIOS" sqlType="STRING"/>
		<param name="ID_HECHOS_PROYECTOS" sqlType="STRING"/>
		<param name="ID_PROYECTOS" sqlType="STRING"/>
		<param name="CODIGO_HECHO" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="IP_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="BASE_CONTRIBUCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vphechobeneficiario">
		<call-query href="insertVphechobeneficiario">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_BENEFICIARIOS" query-param="ID_BENEFICIARIOS"/>
			<with-param name="ID_HECHOS_PROYECTOS" query-param="ID_HECHOS_PROYECTOS"/>
			<with-param name="ID_PROYECTOS" query-param="ID_PROYECTOS"/>
			<with-param name="CODIGO_HECHO" query-param="CODIGO_HECHO"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="IP_NUMERO_ORDEN" query-param="IP_NUMERO_ORDEN"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="BASE_CONTRIBUCION" query-param="BASE_CONTRIBUCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVphechobeneficiario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VP_HECHOS_BENEFICIARIOS WHERE VP_HECHOS_BENEFICIARIOS.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vphechobeneficiario">
		<call-query href="deleteVphechobeneficiario">
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getVphechobeneficiarioPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT VPHB.ID, VPHB.COMPANIA, VPHB.CODIGO_HECHO, VPHP.NOMBRE, VPHP.TARIFA, VPHP.BASE_PLUSVALIA, VPHB.BASE_CONTRIBUCION FROM VP_HECHOS_BENEFICIARIOS VPHB INNER JOIN VP_HECHOS_PROYECTOS VPHP ON VPHB.ID_HECHOS_PROYECTOS = VPHP.ID WHERE VPHB.COMPANIA = :COMPANIA AND VPHB.ID_PROYECTOS = :PROYECTO AND VPHB.ID_BENEFICIARIOS = :BENEFICIARIO ORDER BY VPHB.CODIGO_HECHO) INI WHERE (CASE WHEN CODIGO_HECHO IS NULL THEN ' ' ELSE UPPER(CODIGO_HECHO) END) LIKE UPPER(CONCAT(:CODIGO_HECHO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END) LIKE UPPER(CONCAT(:TARIFA, '%')) AND (CASE WHEN BASE_PLUSVALIA IS NULL THEN ' ' ELSE UPPER(BASE_PLUSVALIA) END) LIKE UPPER(CONCAT(:BASE_PLUSVALIA, '%')) AND (CASE WHEN BASE_CONTRIBUCION IS NULL THEN ' ' ELSE UPPER(BASE_CONTRIBUCION) END) LIKE UPPER(CONCAT(:BASE_CONTRIBUCION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CODIGO_HECHO":"$CODIGO_HECHO","NOMBRE":"$NOMBRE","TARIFA":"$TARIFA(type:long)","BASE_PLUSVALIA":"$BASE_PLUSVALIA","BASE_CONTRIBUCION":"$BASE_CONTRIBUCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CODIGO_HECHO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="BASE_PLUSVALIA" sqlType="STRING"/>
		<param name="BASE_CONTRIBUCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vphechobeneficiario">
		<call-query href="getVphechobeneficiarioPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CODIGO_HECHO" query-param="CODIGO_HECHO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="BASE_PLUSVALIA" query-param="BASE_PLUSVALIA"/>
			<with-param name="BASE_CONTRIBUCION" query-param="BASE_CONTRIBUCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVphechobeneficiarioNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT VPHB.ID, VPHB.COMPANIA, VPHB.CODIGO_HECHO, VPHP.NOMBRE, VPHP.TARIFA, VPHP.BASE_PLUSVALIA, VPHB.BASE_CONTRIBUCION FROM VP_HECHOS_BENEFICIARIOS VPHB INNER JOIN VP_HECHOS_PROYECTOS VPHP ON VPHB.ID_HECHOS_PROYECTOS = VPHP.ID WHERE VPHB.COMPANIA = :COMPANIA AND VPHB.ID_PROYECTOS = :PROYECTO AND VPHB.ID_BENEFICIARIOS = :BENEFICIARIO ORDER BY VPHB.CODIGO_HECHO) INI WHERE (CASE WHEN CODIGO_HECHO IS NULL THEN ' ' ELSE UPPER(CODIGO_HECHO) END) LIKE UPPER(CONCAT(:CODIGO_HECHO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(:NOMBRE, '%')) AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END) LIKE UPPER(CONCAT(:TARIFA, '%')) AND (CASE WHEN BASE_PLUSVALIA IS NULL THEN ' ' ELSE UPPER(BASE_PLUSVALIA) END) LIKE UPPER(CONCAT(:BASE_PLUSVALIA, '%')) AND (CASE WHEN BASE_CONTRIBUCION IS NULL THEN ' ' ELSE UPPER(BASE_CONTRIBUCION) END) LIKE UPPER(CONCAT(:BASE_CONTRIBUCION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CODIGO_HECHO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="BASE_PLUSVALIA" sqlType="STRING"/>
		<param name="BASE_CONTRIBUCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vphechobeneficiario/numero">
		<call-query href="getVphechobeneficiarioNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CODIGO_HECHO" query-param="CODIGO_HECHO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="BASE_PLUSVALIA" query-param="BASE_PLUSVALIA"/>
			<with-param name="BASE_CONTRIBUCION" query-param="BASE_CONTRIBUCION"/>

		</call-query>
	</resource>
	<query id="getVphechobeneficiarioRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT VP_HECHOS_BENEFICIARIOS.ID, VP_HECHOS_BENEFICIARIOS.COMPANIA, VP_HECHOS_BENEFICIARIOS.CODIGO_HECHO, VP_HECHOS_PROYECTOS.NOMBRE, VP_HECHOS_PROYECTOS.TARIFA, VP_HECHOS_PROYECTOS.BASE_PLUSVALIA,VP_HECHOS_BENEFICIARIOS.BASE_CONTRIBUCION,(CASE VP_HECHOS_PROYECTOS.DIVIDE_ACUERDO WHEN 0 THEN 'false' ELSE 'true' END) DIVIDE_ACUERDO, VP_HECHOS_BENEFICIARIOS.ID_HECHOS_PROYECTOS,VP_HECHOS_BENEFICIARIOS.ACUERDO_INICIAL,VP_HECHOS_BENEFICIARIOS.ACUERDO_FINAL,VP_HECHOS_BENEFICIARIOS.CAMPO1 ,VP_HECHOS_BENEFICIARIOS.CAMPO2, VP_HECHOS_BENEFICIARIOS.CAMPO2 - VP_HECHOS_BENEFICIARIOS.CAMPO1 as "BASE_LIQUIDACION" FROM VP_HECHOS_BENEFICIARIOS INNER JOIN VP_HECHOS_PROYECTOS ON VP_HECHOS_BENEFICIARIOS.ID_HECHOS_PROYECTOS = VP_HECHOS_PROYECTOS.ID WHERE VP_HECHOS_BENEFICIARIOS.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CODIGO_HECHO":"$CODIGO_HECHO","NOMBRE":"$NOMBRE","TARIFA":"$TARIFA(type:long)","BASE_PLUSVALIA":"$BASE_PLUSVALIA","BASE_CONTRIBUCION":"$BASE_CONTRIBUCION","DIVIDE_ACUERDO":"$DIVIDE_ACUERDO(type:boolean)","ID_HECHOS_PROYECTOS":"$ID_HECHOS_PROYECTOS","ACUERDO_INICIAL":"$ACUERDO_INICIAL(type:long)","ACUERDO_FINAL":"$ACUERDO_FINAL(type:long)","CAMPO1":"$CAMPO1","CAMPO2":"$CAMPO2","BASE_LIQUIDACION":"$BASE_LIQUIDACION(type:double)"}]}}		</result>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vphechobeneficiario/data">
		<call-query href="getVphechobeneficiarioRegistroQuery">
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateVphechobeneficiario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VP_HECHOS_BENEFICIARIOS SET COMPANIA=:COMPANIA, ID_BENEFICIARIOS=:ID_BENEFICIARIOS, ID_HECHOS_PROYECTOS=:ID_HECHOS_PROYECTOS, ID_PROYECTOS=:ID_PROYECTOS, CODIGO_HECHO=:CODIGO_HECHO, CODIGO_PROYECTO=:CODIGO_PROYECTO, CLASE=:CLASE, IP_CODIGO=:IP_CODIGO, IP_NUMERO_ORDEN=:IP_NUMERO_ORDEN, NOMBRE=:NOMBRE, ACUERDO_INICIAL=:ACUERDO_INICIAL, ACUERDO_FINAL=:ACUERDO_FINAL, CAMPO1=:CAMPO1, CAMPO2=:CAMPO2, BASE_CONTRIBUCION=:BASE_CONTRIBUCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VP_HECHOS_BENEFICIARIOS.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_BENEFICIARIOS" sqlType="STRING"/>
		<param name="ID_HECHOS_PROYECTOS" sqlType="STRING"/>
		<param name="ID_PROYECTOS" sqlType="STRING"/>
		<param name="CODIGO_HECHO" sqlType="STRING"/>
		<param name="CODIGO_PROYECTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="IP_CODIGO" sqlType="STRING"/>
		<param name="IP_NUMERO_ORDEN" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ACUERDO_INICIAL" sqlType="STRING"/>
		<param name="ACUERDO_FINAL" sqlType="STRING"/>
		<param name="CAMPO1" sqlType="STRING"/>
		<param name="CAMPO2" sqlType="STRING"/>
		<param name="BASE_CONTRIBUCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vphechobeneficiario">
		<call-query href="updateVphechobeneficiario">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_BENEFICIARIOS" query-param="ID_BENEFICIARIOS"/>
			<with-param name="ID_HECHOS_PROYECTOS" query-param="ID_HECHOS_PROYECTOS"/>
			<with-param name="ID_PROYECTOS" query-param="ID_PROYECTOS"/>
			<with-param name="CODIGO_HECHO" query-param="CODIGO_HECHO"/>
			<with-param name="CODIGO_PROYECTO" query-param="CODIGO_PROYECTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="IP_CODIGO" query-param="IP_CODIGO"/>
			<with-param name="IP_NUMERO_ORDEN" query-param="IP_NUMERO_ORDEN"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ACUERDO_INICIAL" query-param="ACUERDO_INICIAL"/>
			<with-param name="ACUERDO_FINAL" query-param="ACUERDO_FINAL"/>
			<with-param name="CAMPO1" query-param="CAMPO1"/>
			<with-param name="CAMPO2" query-param="CAMPO2"/>
			<with-param name="BASE_CONTRIBUCION" query-param="BASE_CONTRIBUCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>

</data>