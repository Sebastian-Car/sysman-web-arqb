<data name="ipacuerdos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpacuerdosPagAcuerdosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREANOI, IP_ACUERDOS.PREANO, IP_ACUERDOS.RESOLUCION, CASE IP_ACUERDOS.CANCELADO WHEN 0 THEN 'No' ELSE 'Si' END CANCELADO, CASE IP_ACUERDOS.ANULADO WHEN 0 THEN 'No' ELSE 'Si' END ANULADO, IP_ACUERDOS.PREDIO,(CASE IP_ACUERDOS.APLICA_DSCESP WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DSCESP FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA AND IP_ACUERDOS.PREDIO = :PREDIO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN PREANOI IS NULL THEN ' ' ELSE UPPER(PREANOI) END)  LIKE UPPER( '%' || :PREANOI || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN CANCELADO IS NULL THEN ' ' ELSE UPPER(CANCELADO) END)  LIKE UPPER(:CANCELADO || '%')  AND (CASE WHEN ANULADO IS NULL THEN ' ' ELSE UPPER(ANULADO) END)  LIKE UPPER(:ANULADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACUERDO":"$CODIGOACUERDO","PREANOI":"$PREANOI(type:integer)","PREANO":"$PREANO(type:integer)","RESOLUCION":"$RESOLUCION","CANCELADO":"$CANCELADO","ANULADO":"$ANULADO","PREDIO":"$PREDIO","APLICA_DSCESP":"$APLICA_DSCESP(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREANOI" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="CANCELADO" sqlType="STRING"/>
		<param name="ANULADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipacuerdos/acuerdosporpredio/pag">
		<call-query href="getIpacuerdosPagAcuerdosPorPredioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREANOI" query-param="PREANOI"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="CANCELADO" query-param="CANCELADO"/>
			<with-param name="ANULADO" query-param="ANULADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosNumAcuerdosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREANOI, IP_ACUERDOS.PREANO, IP_ACUERDOS.RESOLUCION, CASE IP_ACUERDOS.CANCELADO WHEN 0 THEN 'No' ELSE 'Si' END CANCELADO, CASE IP_ACUERDOS.ANULADO WHEN 0 THEN 'No' ELSE 'Si' END ANULADO, IP_ACUERDOS.PREDIO,(CASE IP_ACUERDOS.APLICA_DSCESP WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DSCESP FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA AND IP_ACUERDOS.PREDIO = :PREDIO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN PREANOI IS NULL THEN ' ' ELSE UPPER(PREANOI) END)  LIKE UPPER( '%' || :PREANOI || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN CANCELADO IS NULL THEN ' ' ELSE UPPER(CANCELADO) END)  LIKE UPPER( '%' || :CANCELADO || '%')  AND (CASE WHEN ANULADO IS NULL THEN ' ' ELSE UPPER(ANULADO) END)  LIKE UPPER( '%' || :ANULADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREANOI" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="CANCELADO" sqlType="STRING"/>
		<param name="ANULADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipacuerdos/acuerdosporpredio/num">
		<call-query href="getIpacuerdosNumAcuerdosPorPredioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREANOI" query-param="PREANOI"/>
			<with-param name="PREANO" query-param="PREANO"/>
			<with-param name="CANCELADO" query-param="CANCELADO"/>
			<with-param name="ANULADO" query-param="ANULADO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosPagAcuerdosAnulacionCanceladoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGOACUERDO, PREDIO, CASE IP_ACUERDOS.CANCELADO WHEN 0 THEN 'No' ELSE 'Si' END PAGO, CASE IP_ACUERDOS.ANULADO WHEN 0 THEN 'No' ELSE 'Si' END ANULADO , RESOLUCION, PREANOI, PREANO,(CASE APLICA_DSCESP WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DSCESP FROM IP_ACUERDOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER( '%' || :CODIGOACUERDO || '%')  AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END)  LIKE UPPER( '%' || :PREDIO || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER(:PAGO || '%')  AND (CASE WHEN ANULADO IS NULL THEN ' ' ELSE UPPER(ANULADO) END)  LIKE UPPER(:ANULADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACUERDO":"$CODIGOACUERDO","PREDIO":"$PREDIO","PAGO":"$PAGO","ANULADO":"$ANULADO","RESOLUCION":"$RESOLUCION","PREANOI":"$PREANOI(type:integer)","PREANO":"$PREANO(type:integer)","APLICA_DSCESP":"$APLICA_DSCESP(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="ANULADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipacuerdos/acuerdosanulacioncancelado/pag">
		<call-query href="getIpacuerdosPagAcuerdosAnulacionCanceladoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="ANULADO" query-param="ANULADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosNumAcuerdosAnulacionCanceladoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGOACUERDO, PREDIO, CASE IP_ACUERDOS.CANCELADO WHEN 0 THEN 'No' ELSE 'Si' END PAGO, CASE IP_ACUERDOS.ANULADO WHEN 0 THEN 'No' ELSE 'Si' END ANULADO , RESOLUCION, PREANOI, PREANO,(CASE APLICA_DSCESP WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DSCESP FROM IP_ACUERDOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER( '%' || :CODIGOACUERDO || '%')  AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END)  LIKE UPPER( '%' || :PREDIO || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER( '%' || :PAGO || '%')  AND (CASE WHEN ANULADO IS NULL THEN ' ' ELSE UPPER(ANULADO) END)  LIKE UPPER( '%' || :ANULADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="ANULADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipacuerdos/acuerdosanulacioncancelado/num">
		<call-query href="getIpacuerdosNumAcuerdosAnulacionCanceladoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="PAGO" query-param="PAGO"/>
			<with-param name="ANULADO" query-param="ANULADO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosCodigoUltimoAcueroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(TO_NUMBER(CODIGOACUERDO)) ULTIMOACUERDO  FROM IP_ACUERDOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ULTIMOACUERDO":"$ULTIMOACUERDO(type:integer)"}]}}		</result>
 
	</query>
	<resource method="GET" path="ipacuerdos/codigoultimoacuero">
		<call-query href="getIpacuerdosCodigoUltimoAcueroQuery">
 
		</call-query>
	</resource>
	<query id="getIpacuerdosPagTodosPorPredioYCodigoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREDIO  FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA ORDER BY IP_ACUERDOS.CODIGOACUERDO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END)  LIKE UPPER( '%' || :PREDIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACUERDO":"$CODIGOACUERDO","PREDIO":"$PREDIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipacuerdos/todosporpredioycodigoinicial/pag">
