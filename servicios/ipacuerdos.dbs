	<query id="getIpacuerdosNumTodosPorPredioYCodigoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREDIO  FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA AND IP_ACUERDOS.CODIGOACUERDO &gt;= :ACUERDOINICIAL ORDER BY IP_ACUERDOS.CODIGOACUERDO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END)  LIKE UPPER( '%' || :PREDIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACUERDOINICIAL" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipacuerdos/todosporpredioycodigofinal/num">
		<call-query href="getIpacuerdosNumTodosPorPredioYCodigoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACUERDOINICIAL" query-param="ACUERDOINICIAL"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosPagNombreResponsableYCodigoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREDIO, IP_ACUERDOS.NOMBRE_RESP  FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA AND IP_ACUERDOS.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_ACUERDOS.CODIGOACUERDO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN NOMBRE_RESP IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESP) END)  LIKE UPPER( '%' || :NOMBRE_RESP || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACUERDO":"$CODIGOACUERDO","PREDIO":"$PREDIO","NOMBRE_RESP":"$NOMBRE_RESP"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="NOMBRE_RESP" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
