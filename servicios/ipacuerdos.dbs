	</resource>
	<query id="getIpacuerdosPagNombreResponsableYCodigoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREDIO, IP_ACUERDOS.NOMBRE_RESP  FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA AND IP_ACUERDOS.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_ACUERDOS.CODIGOACUERDO &gt;= :CODIGOINICIAL ORDER BY IP_ACUERDOS.CODIGOACUERDO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN NOMBRE_RESP IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESP) END)  LIKE UPPER( '%' || :NOMBRE_RESP || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACUERDO":"$CODIGOACUERDO","PREDIO":"$PREDIO","NOMBRE_RESP":"$NOMBRE_RESP"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="NOMBRE_RESP" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipacuerdos/nombreresponsableycodigofinal/pag">
		<call-query href="getIpacuerdosPagNombreResponsableYCodigoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="NOMBRE_RESP" query-param="NOMBRE_RESP"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosNumNombreResponsableYCodigoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREDIO, IP_ACUERDOS.NOMBRE_RESP  FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA AND IP_ACUERDOS.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_ACUERDOS.CODIGOACUERDO &gt;= :CODIGOINICIAL ORDER BY IP_ACUERDOS.CODIGOACUERDO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN NOMBRE_RESP IS NULL THEN ' ' ELSE UPPER(NOMBRE_RESP) END)  LIKE UPPER( '%' || :NOMBRE_RESP || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="NOMBRE_RESP" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipacuerdos/nombreresponsableycodigofinal/num">
		<call-query href="getIpacuerdosNumNombreResponsableYCodigoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="NOMBRE_RESP" query-param="NOMBRE_RESP"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosPreanoiPreanoPorNumCodQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PREANOI, PREANO, CODIGOACUERDO  FROM IP_ACUERDOS WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO AND PREDIO = :CODIGO AND CANCELADO = 0 AND ANULADO = 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREANOI":"$PREANOI(type:integer)","PREANO":"$PREANO(type:integer)","CODIGOACUERDO":"$CODIGOACUERDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipacuerdos/preanoipreanopornumcod">
		<call-query href="getIpacuerdosPreanoiPreanoPorNumCodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosNumeroAcuerdosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM IP_ACUERDOS A INNER JOIN IP_FACTURADOSACUERDOS FA ON A.COMPANIA = FA.COMPANIA AND A.PREDIO = FA.PREDIO AND A.CODIGOACUERDO = FA.CODIGOACUERDO WHERE A.CANCELADO IN (0) AND A.ANULADO IN (0) AND FA.PAGADO IN (0) AND FA.PREDIO = :PREDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipacuerdos/numeroacuerdosporpredio">
		<call-query href="getIpacuerdosNumeroAcuerdosPorPredioQuery">
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>

</data>