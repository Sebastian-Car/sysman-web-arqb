			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosNumTodosPorPredioYCodigoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREDIO  FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA ORDER BY IP_ACUERDOS.CODIGOACUERDO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END)  LIKE UPPER( '%' || :PREDIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipacuerdos/todosporpredioycodigoinicial/num">
		<call-query href="getIpacuerdosNumTodosPorPredioYCodigoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>
	<query id="getIpacuerdosPagTodosPorPredioYCodigoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_ACUERDOS.CODIGOACUERDO, IP_ACUERDOS.PREDIO  FROM IP_ACUERDOS WHERE IP_ACUERDOS.COMPANIA = :COMPANIA AND IP_ACUERDOS.CODIGOACUERDO &gt;= :ACUERDOINICIAL ORDER BY IP_ACUERDOS.CODIGOACUERDO) WHERE (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER(:CODIGOACUERDO || '%')  AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END)  LIKE UPPER( '%' || :PREDIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACUERDO":"$CODIGOACUERDO","PREDIO":"$PREDIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACUERDOINICIAL" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipacuerdos/todosporpredioycodigofinal/pag">
		<call-query href="getIpacuerdosPagTodosPorPredioYCodigoFinalQuery">
