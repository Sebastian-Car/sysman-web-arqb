<data name="cuipovalidacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCuipovalidacionValidacionprogramaciongastosaproQuery"  useConfig="sysmandsunist">
		<sql>SELECT APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET, TIPOVIGENCIA.EQUIVALENTE_CUIPO, APROPIACIONESINICIALES.CODIGOUNIDADEJE SECCION_PPTAL, APROPIACIONESINICIALES.PROGRAMA, APROPIACIONESINICIALES.CODIGOBPIN, APROPIACIONESINICIALES.DETALLESECTORIAL DETALLE_SECTORIAL, SUM(APROPIACIONESINICIALES.DEBITO) APROPIACIONINICIAL, 0 MODIFICACION, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (APROPIACIONESINICIALES.CODIGO_CCPET LIKE '2.3%' AND APROPIACIONESINICIALES.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN APROPIACIONESINICIALES.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END OBSERVACION FROM APROPIACIONESINICIALES INNER JOIN PLAN_PRESUPUESTAL ON APROPIACIONESINICIALES.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND APROPIACIONESINICIALES.ANO=PLAN_PRESUPUESTAL.ANO AND APROPIACIONESINICIALES.CODIGO=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE APROPIACIONESINICIALES.COMPANIA=:COMPANIA and APROPIACIONESINICIALES.ANO=:ANIO AND PLAN_PRESUPUESTAL.NATURALEZA='D' AND PLAN_PRESUPUESTAL.REGALIAS IN (0) AND (APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') OR (APROPIACIONESINICIALES.CODIGO_CCPET LIKE '2.3%' AND APROPIACIONESINICIALES.PROGRAMA IN (0)) OR APROPIACIONESINICIALES.CODIGOUNIDADEJE IN ('0')) GROUP BY APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET , TIPOVIGENCIA.EQUIVALENTE_CUIPO, APROPIACIONESINICIALES.CODIGOUNIDADEJE , APROPIACIONESINICIALES.PROGRAMA, APROPIACIONESINICIALES.CODIGOBPIN, APROPIACIONESINICIALES.DETALLESECTORIAL, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (APROPIACIONESINICIALES.CODIGO_CCPET LIKE '2.3%' AND APROPIACIONESINICIALES.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN APROPIACIONESINICIALES.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END ORDER BY APROPIACIONESINICIALES.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CODIGO_CCPET":"$CODIGO_CCPET","EQUIVALENTE_CUIPO":"$EQUIVALENTE_CUIPO","SECCION_PPTAL":"$SECCION_PPTAL","PROGRAMA":"$PROGRAMA","CODIGOBPIN":"$CODIGOBPIN","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprogramaciongastosapro">
		<call-query href="getCuipovalidacionValidacionprogramaciongastosaproQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionprogramaciongastosdetQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET, TIPOVIGENCIA.EQUIVALENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE SECCION_PPTAL, DETALLE_COMPROBANTE_PPTAL.PROGRAMA, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN CODIGOBPIN, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, 0 APROPIACIONINICIAL, SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO -VALOR_CREDITO) MODIFICACION, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN IN (0)) THEN 'El BPIN no puede ser 0 para este CCPET' WHEN DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END OBSERVACION FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE=TIPO_COMPROBPP.CODIGO INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO=PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA=:COMPANIA AND PLAN_PRESUPUESTAL.ANO=:ANIO AND DETALLE_COMPROBANTE_PPTAL.MES&lt;=:MESFINAL AND PLAN_PRESUPUESTAL.NATURALEZA='D' AND PLAN_PRESUPUESTAL.REGALIAS IN (0) AND TIPO_COMPROBPP.CLASE IN('ADC','RED','TRA') AND (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') OR (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.PROGRAMA IN (0)) OR (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN IN (0)) OR DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0')) GROUP BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET , TIPOVIGENCIA.EQUIVALENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE , DETALLE_COMPROBANTE_PPTAL.PROGRAMA, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN IN (0)) THEN 'El BPIN no puede ser 0 para este CCPET' WHEN DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END ORDER BY DETALLE_COMPROBANTE_PPTAL.CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CODIGO_CCPET":"$CODIGO_CCPET","EQUIVALENTE_CUIPO":"$EQUIVALENTE_CUIPO","SECCION_PPTAL":"$SECCION_PPTAL","PROGRAMA":"$PROGRAMA","CODIGOBPIN":"$CODIGOBPIN","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprogramaciongastosdet">
		<call-query href="getCuipovalidacionValidacionprogramaciongastosdetQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionejecuciongastosQuery"  useConfig="sysmandsunist">
		<sql>SELECT CUENTA, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CODIGO_CCPET, VIGENCIA, SECCION_PPTAL_CUIPO, SECTOR_CUIPO, CPC, DETALLE_SECTORIAL, FUENTE_FINANCIACION, TIPO_NORMA, NUMERO_NORMA, FECHA_NORMA, PROGRAMATICO, BPIN, SITUACION_FONDOS, POLITICA_PUBLICA, TERCERO, SUM(VAL_COMPROMISOS) AS COMPROMISOS, OBSERVACION FROM (SELECT D.CUENTA, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, NVL(CC.CODIGO,0) AS CODIGO_CCPET, TV.EQUIVALENTE_CUIPO AS VIGENCIA, SEC.CODIGO AS SECCION_PPTAL_CUIPO, SECT.CODIGO AS SECTOR_CUIPO, NVL(CPC.CODIGO,'0') AS CPC, NVL(D.DETALLE_SECTORIAL,0) AS DETALLE_SECTORIAL, F.CODIGO AS FUENTE_FINANCIACION, CASE WHEN P.APLICA_DEST_ESPECIFICA &lt;&gt; 0 THEN P.TIPO_NORMA ELSE '0' END AS TIPO_NORMA, CASE WHEN P.APLICA_DEST_ESPECIFICA &lt;&gt; 0 THEN P.NUMERO_NORMA ELSE '0' END AS NUMERO_NORMA, CASE WHEN P.APLICA_DEST_ESPECIFICA &lt;&gt; 0 THEN TO_CHAR(P.FECHA_NORMA,'DD/MM/YYYY') ELSE '01/01/1900' END AS FECHA_NORMA, PROD.CODIGO AS PROGRAMATICO, D.CODIGO_BPIN AS BPIN, CASE WHEN P.CONSITUACIONFONDOS = 0 THEN 'C' ELSE 'S' END AS SITUACION_FONDOS, NVL(P.POLITCA_PUBLICA_CUIPO,'0') AS POLITICA_PUBLICA, CASE WHEN P.TRANSFERENCIA &lt;&gt; 0 THEN T.NIT_CEDULA ELSE '1' END AS TERCERO, CASE WHEN (CC.CODIGO IS NULL OR CC.CODIGO = '0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (D.CODIGOUNIDADEJE = '0' OR D.CODIGOUNIDADEJE IS NULL) THEN 'Falta configuración de la sección presupuestal' WHEN (TV.EQUIVALENTE_CUIPO = '0' OR TV.EQUIVALENTE_CUIPO IS NULL) THEN 'Falta configuración de la sección presupuestal' WHEN (CC.OBLIGACPCDANE = -1 AND (CPC.CODIGO IS NULL OR CPC.CODIGO IN ('0'))) THEN 'Es obligatorio el CPC para este CCPET' WHEN (CC.CODIGO LIKE '2.3%' AND (SECT.CODIGO IS NULL OR SECT.CODIGO IN ('0'))) THEN 'Falta configuración del sector para este CCPET' WHEN (CC.CODIGO LIKE '2.3%' AND (F.CODIGO IS NULL OR F.CODIGO IN ('0'))) THEN 'Falta configuración de la fuente para este CCPET' ELSE '' END AS OBSERVACION, CASE WHEN TC.CLASE IN ('RES','ADR','DMR') THEN (D.VALOR_DEBITO - D.VALOR_CREDITO) ELSE 0 END AS VAL_COMPROMISOS, CASE WHEN TC.CLASE IN ('REO','ARO','DRO') THEN (D.VALOR_DEBITO - D.VALOR_CREDITO) ELSE 0 END AS VAL_OBLIGACIONES, CASE WHEN TC.CLASE IN ('EGR','ADG','DEG') THEN (D.VALOR_DEBITO - D.VALOR_CREDITO) ELSE 0 END AS VAL_PAGOS FROM DETALLE_COMPROBANTE_PPTAL D INNER JOIN PLAN_PRESUPUESTAL P ON D.COMPANIA = P.COMPANIA AND D.ANO = P.ANO AND D.CUENTA = P.CODIGO LEFT JOIN TIPOCLASIFICADOR CC ON D.COMPANIA = CC.COMPANIA AND D.ANO = CC.ANO AND CC.CLASECLASIFICADOR = '006' AND D.CODIGO_CCPET = CC.CODIGO LEFT JOIN TIPOCLASIFICADOR F ON D.COMPANIA = F.COMPANIA AND D.ANO = F.ANO AND F.CLASECLASIFICADOR = '009' AND D.FUENTE_CUIPO = F.CODIGO LEFT JOIN TIPOCLASIFICADOR CPC ON D.COMPANIA = CPC.COMPANIA AND D.ANO = CPC.ANO AND CPC.CLASECLASIFICADOR = '007' AND D.CODIGO_CPC = CPC.CODIGO LEFT JOIN TIPOCLASIFICADOR SEC ON D.COMPANIA = SEC.COMPANIA AND D.ANO = SEC.ANO AND SEC.CLASECLASIFICADOR = '008' AND D.CODIGOUNIDADEJE = SEC.CODIGO LEFT JOIN TIPOCLASIFICADOR PROD ON D.COMPANIA = PROD.COMPANIA AND D.ANO = PROD.ANO AND PROD.CLASECLASIFICADOR = '004' AND D.COD_PROD_CUIPO = PROD.CODIGO LEFT JOIN TIPOCLASIFICADOR SECT ON D.COMPANIA = SECT.COMPANIA AND D.ANO = SECT.ANO AND SECT.CLASECLASIFICADOR = '001' AND D.SECTOR = SECT.CODIGO LEFT JOIN TIPOVIGENCIA TV ON TV.CODIGO = P.TIPOVIGENCIA INNER JOIN TIPO_COMPROBPP TC ON D.COMPANIA = TC.COMPANIA AND D.TIPO_CPTE = TC.CODIGO INNER JOIN TERCERO T ON D.COMPANIA = T.COMPANIA AND D.TERCERO = T.NIT AND D.SUCURSAL = T.SUCURSAL WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANIO AND D.MES &lt;= :MESFINAL AND P.NATURALEZA = 'D' AND P.REGALIAS = 0 AND TC.CLASE = 'RES' AND ((CC.CODIGO IS NULL OR CC.CODIGO = '0') OR (D.CODIGOUNIDADEJE = '0' OR D.CODIGOUNIDADEJE IS NULL) OR (CC.OBLIGACPCDANE = -1 AND (CPC.CODIGO IS NULL OR CPC.CODIGO IN ('0'))) OR (TV.EQUIVALENTE_CUIPO = '0' OR TV.EQUIVALENTE_CUIPO IS NULL) OR (CC.CODIGO LIKE '2.3%' AND (SECT.CODIGO IS NULL OR SECT.CODIGO IN ('0'))) OR (CC.CODIGO LIKE '2.3%' AND (F.CODIGO IS NULL OR F.CODIGO IN ('0'))) ) ) BASE GROUP BY CUENTA, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CODIGO_CCPET, VIGENCIA, SECCION_PPTAL_CUIPO, SECTOR_CUIPO, CPC, DETALLE_SECTORIAL, FUENTE_FINANCIACION, TIPO_NORMA, NUMERO_NORMA, FECHA_NORMA, PROGRAMATICO, BPIN, SITUACION_FONDOS, POLITICA_PUBLICA, TERCERO, OBSERVACION ORDER BY CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CODIGO_CCPET":"$CODIGO_CCPET","VIGENCIA":"$VIGENCIA","SECCION_PPTAL_CUIPO":"$SECCION_PPTAL_CUIPO","SECTOR_CUIPO":"$SECTOR_CUIPO","CPC":"$CPC","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","FUENTE_FINANCIACION":"$FUENTE_FINANCIACION","TIPO_NORMA":"$TIPO_NORMA","NUMERO_NORMA":"$NUMERO_NORMA","FECHA_NORMA":"$FECHA_NORMA","PROGRAMATICO":"$PROGRAMATICO","BPIN":"$BPIN","SITUACION_FONDOS":"$SITUACION_FONDOS","POLITICA_PUBLICA":"$POLITICA_PUBLICA","TERCERO":"$TERCERO","COMPROMISOS":"$COMPROMISOS(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionejecuciongastos">
		<call-query href="getCuipovalidacionValidacionejecuciongastosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionprograingresosaproQuery"  useConfig="sysmandsunist">
		<sql>SELECT APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET CODIGO_CCPET, APROPIACIONESINICIALES.DETALLESECTORIAL DETALLE_SECTORIAL, SUM(APROPIACIONESINICIALES.CREDITO) APROPIACIONINICIAL, 0 MODIFICACION, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END OBSERVACION FROM APROPIACIONESINICIALES INNER JOIN PLAN_PRESUPUESTAL ON APROPIACIONESINICIALES.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND APROPIACIONESINICIALES.ANO=PLAN_PRESUPUESTAL.ANO AND APROPIACIONESINICIALES.CODIGO=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE APROPIACIONESINICIALES.COMPANIA=:COMPANIA and APROPIACIONESINICIALES.ANO=:ANIO AND PLAN_PRESUPUESTAL.NATURALEZA='C' AND PLAN_PRESUPUESTAL.REGALIAS IN (0) AND APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') GROUP BY APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET , APROPIACIONESINICIALES.DETALLESECTORIAL, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CODIGO_CCPET":"$CODIGO_CCPET","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprograingresosapro">
		<call-query href="getCuipovalidacionValidacionprograingresosaproQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionprograingresosdetQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET CODIGO_CCPET, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, 0 APROPIACIONINICIAL, SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO -VALOR_DEBITO) MODIFICACION, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END OBSERVACION FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE=TIPO_COMPROBPP.CODIGO INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO=PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA=:COMPANIA AND PLAN_PRESUPUESTAL.ANO=:ANIO and DETALLE_COMPROBANTE_PPTAL.MES&lt;=:MESFINAL AND PLAN_PRESUPUESTAL.NATURALEZA='C' AND PLAN_PRESUPUESTAL.REGALIAS IN (0) AND TIPO_COMPROBPP.CLASE IN('ADC','RED','TRA') AND DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') GROUP BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET , DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CODIGO_CCPET":"$CODIGO_CCPET","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprograingresosdet">
		<call-query href="getCuipovalidacionValidacionprograingresosdetQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionejecucioningresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT CUENTA, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CODIGO_CCPET, CPC, DETALLE_SECTORIAL, FUENTE_FINANCIACION, TERCERO, POLITICA_PUBLICA, SUM(DIFERENCIA) AS TOTAL, OBSERVACION FROM (SELECT D.CUENTA, D.TIPO_CPTE, D.COMPROBANTE, D.CONSECUTIVO, NVL(CC.CODIGO, 0) CODIGO_CCPET, NVL(CPC.CODIGO, '0') CPC, NVL(D.DETALLE_SECTORIAL, 0) DETALLE_SECTORIAL, NVL(F.CODIGO, '0') FUENTE_FINANCIACION, P.APLICA_DEST_ESPECIFICA P_APLICA, CASE WHEN P.TRANSFERENCIA NOT IN (0) THEN T.NIT_CEDULA ELSE '1' END AS TERCERO, NVL(P.POLITCA_PUBLICA_CUIPO, '0') POLITICA_PUBLICA, (D.VALOR_CREDITO - D.VALOR_DEBITO) AS DIFERENCIA, CASE WHEN (CC.CODIGO IS NULL OR CC.CODIGO IN ('0')) THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (D.FUENTE_CUIPO IS NULL OR D.FUENTE_CUIPO IN ('0')) THEN 'Falta configuración de la fuente' WHEN (CC.OBLIGACPCDANE = -1 AND (CPC.CODIGO IS NULL OR CPC.CODIGO IN ('0'))) THEN 'Es obligatorio el CPC para este CCPET' ELSE '' END OBSERVACION FROM DETALLE_COMPROBANTE_PPTAL D INNER JOIN PLAN_PRESUPUESTAL P ON D.COMPANIA = P.COMPANIA AND D.ANO = P.ANO AND D.CUENTA = P.CODIGO LEFT JOIN TIPOCLASIFICADOR CC ON D.COMPANIA = CC.COMPANIA AND D.ANO = CC.ANO AND '006' = CC.CLASECLASIFICADOR AND D.CODIGO_CCPET = CC.CODIGO LEFT JOIN TIPOCLASIFICADOR F ON D.COMPANIA = F.COMPANIA AND D.ANO = F.ANO AND '009' = F.CLASECLASIFICADOR AND D.FUENTE_CUIPO = F.CODIGO LEFT JOIN TIPOCLASIFICADOR CPC ON D.COMPANIA = CPC.COMPANIA AND D.ANO = CPC.ANO AND '007' = CPC.CLASECLASIFICADOR AND D.CODIGO_CPC = CPC.CODIGO INNER JOIN TIPO_COMPROBPP TC ON D.COMPANIA = TC.COMPANIA AND D.TIPO_CPTE = TC.CODIGO INNER JOIN TERCERO T ON D.COMPANIA = T.COMPANIA AND D.TERCERO = T.NIT AND D.SUCURSAL = T.SUCURSAL WHERE D.COMPANIA = :COMPANIA AND D.ANO = :ANIO AND D.MES &lt;= :MESFINAL AND D.NATURALEZA = 'C' AND P.REGALIAS IN (0) AND TC.CLASE IN ('ING','DIN','AIN') AND ((CC.CODIGO IS NULL OR CC.CODIGO IN ('0')) OR (D.FUENTE_CUIPO IS NULL OR D.FUENTE_CUIPO IN ('0')) OR (CC.OBLIGACPCDANE = -1 AND (CPC.CODIGO IS NULL OR CPC.CODIGO IN ('0'))) )) BASE GROUP BY CUENTA, TIPO_CPTE, COMPROBANTE, CONSECUTIVO, CODIGO_CCPET, CPC, DETALLE_SECTORIAL, FUENTE_FINANCIACION, TERCERO, POLITICA_PUBLICA, OBSERVACION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CODIGO_CCPET":"$CODIGO_CCPET","CPC":"$CPC","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","FUENTE_FINANCIACION":"$FUENTE_FINANCIACION","TERCERO":"$TERCERO","POLITICA_PUBLICA":"$POLITICA_PUBLICA","TOTAL":"$TOTAL(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionejecucioningresos">
		<call-query href="getCuipovalidacionValidacionejecucioningresosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionprogragastosaprosgrQuery"  useConfig="sysmandsunist">
		<sql>SELECT APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET, TIPOVIGENCIA.EQUIVALENTE_CUIPO, APROPIACIONESINICIALES.CODIGOUNIDADEJE SECCION_PPTAL, APROPIACIONESINICIALES.PROGRAMA, APROPIACIONESINICIALES.CODIGOBPIN, APROPIACIONESINICIALES.DETALLESECTORIAL DETALLE_SECTORIAL, SUM(APROPIACIONESINICIALES.DEBITO) APROPIACIONINICIAL, 0 MODIFICACION, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (APROPIACIONESINICIALES.CODIGO_CCPET LIKE '2.3%' AND APROPIACIONESINICIALES.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN APROPIACIONESINICIALES.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END OBSERVACION FROM APROPIACIONESINICIALES INNER JOIN PLAN_PRESUPUESTAL ON APROPIACIONESINICIALES.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND APROPIACIONESINICIALES.ANO=PLAN_PRESUPUESTAL.ANO AND APROPIACIONESINICIALES.CODIGO=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE APROPIACIONESINICIALES.COMPANIA=:COMPANIA and APROPIACIONESINICIALES.ANO=:ANIO AND PLAN_PRESUPUESTAL.NATURALEZA='D' AND PLAN_PRESUPUESTAL.REGALIAS NOT IN (0) AND (APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') OR (APROPIACIONESINICIALES.CODIGO_CCPET LIKE '2.3%' AND APROPIACIONESINICIALES.PROGRAMA IN (0)) OR APROPIACIONESINICIALES.CODIGOUNIDADEJE IN ('0')) GROUP BY APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET , TIPOVIGENCIA.EQUIVALENTE_CUIPO, APROPIACIONESINICIALES.CODIGOUNIDADEJE , APROPIACIONESINICIALES.PROGRAMA, APROPIACIONESINICIALES.CODIGOBPIN, APROPIACIONESINICIALES.DETALLESECTORIAL, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (APROPIACIONESINICIALES.CODIGO_CCPET LIKE '2.3%' AND APROPIACIONESINICIALES.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN APROPIACIONESINICIALES.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END ORDER BY APROPIACIONESINICIALES.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CODIGO_CCPET":"$CODIGO_CCPET","EQUIVALENTE_CUIPO":"$EQUIVALENTE_CUIPO","SECCION_PPTAL":"$SECCION_PPTAL","PROGRAMA":"$PROGRAMA","CODIGOBPIN":"$CODIGOBPIN","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprogragastosaprosgr">
		<call-query href="getCuipovalidacionValidacionprogragastosaprosgrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionprogragastosdetsgrQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET, TIPOVIGENCIA.EQUIVALENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE SECCION_PPTAL, DETALLE_COMPROBANTE_PPTAL.PROGRAMA, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN CODIGOBPIN, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, 0 APROPIACIONINICIAL, SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO -VALOR_CREDITO) MODIFICACION, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN IN (0)) THEN 'El BPIN no puede ser 0 para este CCPET' WHEN DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END OBSERVACION FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE=TIPO_COMPROBPP.CODIGO INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO=PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA=:COMPANIA AND PLAN_PRESUPUESTAL.ANO=:ANIO AND DETALLE_COMPROBANTE_PPTAL.MES&lt;=:MESFINAL AND PLAN_PRESUPUESTAL.NATURALEZA='D' AND PLAN_PRESUPUESTAL.REGALIAS NOT IN (0) AND TIPO_COMPROBPP.CLASE IN('ADC','RED','TRA') AND (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') OR (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.PROGRAMA IN (0)) OR (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN IN (0)) OR DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0')) GROUP BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET , TIPOVIGENCIA.EQUIVALENTE_CUIPO, DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE , DETALLE_COMPROBANTE_PPTAL.PROGRAMA, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.PROGRAMA IN (0)) THEN 'El programa no puede ser 0 para este CCPET' WHEN (DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET LIKE '2.3%' AND DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN IN (0)) THEN 'El BPIN no puede ser 0 para este CCPET' WHEN DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END ORDER BY DETALLE_COMPROBANTE_PPTAL.CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CODIGO_CCPET":"$CODIGO_CCPET","EQUIVALENTE_CUIPO":"$EQUIVALENTE_CUIPO","SECCION_PPTAL":"$SECCION_PPTAL","PROGRAMA":"$PROGRAMA","CODIGOBPIN":"$CODIGOBPIN","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprogragastosdetsgr">
		<call-query href="getCuipovalidacionValidacionprogragastosdetsgrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionejecuciongastossgrQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, NVL(CODIGO_CCEPT.CODIGO,0) CODIGO_CCPET, (SELECT EQUIVALENTE_CUIPO FROM TIPOVIGENCIA WHERE CODIGO = P.TIPOVIGENCIA AND EQUIVALENTE_CUIPO IS NOT NULL) VIGENCIA, SECCION_PPTAL_CUIPO.CODIGO SECCION_PPTAL_CUIPO, SECTOR_CUIPO.CODIGO SECTOR_CUIPO, NVL(COD_CPC_CUIPO.CODIGO,'0') CPC, NVL(DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL,0) DETALLE_SECTORIAL, FUENTE_CUIPO.CODIGO FUENTE_FINANCIACION, CASE WHEN P.APLICA_DEST_ESPECIFICA NOT IN (0) THEN P.TIPO_NORMA ELSE '0' END TIPO_NORMA, CASE WHEN P.APLICA_DEST_ESPECIFICA NOT IN (0) THEN P.NUMERO_NORMA ELSE '0' END NUMERO_NORMA, CASE WHEN P.APLICA_DEST_ESPECIFICA NOT IN (0) THEN TO_CHAR(P.FECHA_NORMA,'DD/MM/YYYY') ELSE '01/01/1900' END FECHA_NORMA, COD_PRODUCTO_CUIPO.CODIGO PROGRAMATICO, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN BPIN, CASE WHEN P.CONSITUACIONFONDOS IN (0) THEN 'C' ELSE 'S' END SITUACION_FONDOS, NVL(P.POLITCA_PUBLICA_CUIPO,'0') POLITICA_PUBLICA, CASE WHEN P.TRANSFERENCIA NOT IN (0) THEN TERCERO.NIT_CEDULA ELSE '1' END TERCERO, SUM(CASE WHEN TIPO_COMPROBPP.CLASE IN ('RES','ADR','DMR') THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO - DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) ELSE 0 END) AS COMPROMISOS, SUM(CASE WHEN TIPO_COMPROBPP.CLASE IN ('REO','ARO','DRO') THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO - DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) ELSE 0 END) AS OBLIGACIONES, SUM(CASE WHEN TIPO_COMPROBPP.CLASE IN ('EGR','ADG','DEG') THEN (DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO - DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO) ELSE 0 END) AS PAGOS, CASE WHEN (CODIGO_CCEPT.CODIGO IS NULL OR CODIGO_CCEPT.CODIGO IN ('0')) THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END OBSERVACION FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN PLAN_PRESUPUESTAL P ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = P.COMPANIA AND DETALLE_COMPROBANTE_PPTAL .ANO = P.ANO AND DETALLE_COMPROBANTE_PPTAL .CUENTA = P.CODIGO LEFT JOIN TIPOCLASIFICADOR CODIGO_CCEPT ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = CODIGO_CCEPT.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = CODIGO_CCEPT.ANO AND '006'=CODIGO_CCEPT.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET=CODIGO_CCEPT.CODIGO LEFT JOIN TIPOCLASIFICADOR FUENTE_CUIPO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = FUENTE_CUIPO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = FUENTE_CUIPO.ANO AND '009'=FUENTE_CUIPO.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO = FUENTE_CUIPO.CODIGO LEFT JOIN TIPOCLASIFICADOR COD_CPC_CUIPO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COD_CPC_CUIPO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COD_CPC_CUIPO.ANO AND '007'=COD_CPC_CUIPO.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.CODIGO_CPC = COD_CPC_CUIPO.CODIGO LEFT JOIN TIPOCLASIFICADOR SECCION_PPTAL_CUIPO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = SECCION_PPTAL_CUIPO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = SECCION_PPTAL_CUIPO.ANO AND '008'= SECCION_PPTAL_CUIPO.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE = SECCION_PPTAL_CUIPO.CODIGO LEFT JOIN TIPOCLASIFICADOR COD_PRODUCTO_CUIPO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COD_PRODUCTO_CUIPO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COD_PRODUCTO_CUIPO.ANO AND '004'=COD_PRODUCTO_CUIPO.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.COD_PROD_CUIPO = COD_PRODUCTO_CUIPO.CODIGO LEFT JOIN TIPOCLASIFICADOR SECTOR_CUIPO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = SECTOR_CUIPO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = SECTOR_CUIPO.ANO AND '001'= SECTOR_CUIPO.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.SECTOR = SECTOR_CUIPO.CODIGO INNER JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = TIPO_COMPROBPP.CODIGO INNER JOIN TERCERO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANIO AND DETALLE_COMPROBANTE_PPTAL.MES &lt;= :MESFINAL AND P.NATURALEZA ='D' AND P.REGALIAS NOT IN (0) AND TIPO_COMPROBPP.CLASE = 'RES' AND (CODIGO_CCEPT.CODIGO IS NULL OR CODIGO_CCEPT.CODIGO IN ('0')) GROUP BY NVL(CODIGO_CCEPT.CODIGO,0), DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, P.TIPOVIGENCIA, SECCION_PPTAL_CUIPO.CODIGO, SECTOR_CUIPO.CODIGO, NVL(COD_CPC_CUIPO.CODIGO,'0'), NVL(DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL,0), FUENTE_CUIPO.CODIGO, CASE WHEN P.APLICA_DEST_ESPECIFICA NOT IN (0) THEN P.TIPO_NORMA ELSE '0' END, CASE WHEN P.APLICA_DEST_ESPECIFICA NOT IN (0) THEN P.NUMERO_NORMA ELSE '0' END, CASE WHEN P.APLICA_DEST_ESPECIFICA NOT IN (0) THEN TO_CHAR(P.FECHA_NORMA,'DD/MM/YYYY') ELSE '01/01/1900' END, CASE WHEN P.CONSITUACIONFONDOS IN (0) THEN 'C' ELSE 'S' END, NVL(P.POLITCA_PUBLICA_CUIPO,'0'), CASE WHEN P.TRANSFERENCIA NOT IN (0) THEN TERCERO.NIT_CEDULA ELSE '1' END, COD_PRODUCTO_CUIPO.CODIGO, DETALLE_COMPROBANTE_PPTAL.CODIGO_BPIN, CASE WHEN (CODIGO_CCEPT.CODIGO IS NULL OR CODIGO_CCEPT.CODIGO IN ('0')) THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN DETALLE_COMPROBANTE_PPTAL.CODIGOUNIDADEJE IN ('0') THEN 'Falta configuración de la unidad ejecutora' ELSE '' END ORDER BY DETALLE_COMPROBANTE_PPTAL.CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CODIGO_CCPET":"$CODIGO_CCPET","VIGENCIA":"$VIGENCIA","SECCION_PPTAL_CUIPO":"$SECCION_PPTAL_CUIPO","SECTOR_CUIPO":"$SECTOR_CUIPO","CPC":"$CPC","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","FUENTE_FINANCIACION":"$FUENTE_FINANCIACION","TIPO_NORMA":"$TIPO_NORMA","NUMERO_NORMA":"$NUMERO_NORMA","FECHA_NORMA":"$FECHA_NORMA","PROGRAMATICO":"$PROGRAMATICO","BPIN":"$BPIN","SITUACION_FONDOS":"$SITUACION_FONDOS","POLITICA_PUBLICA":"$POLITICA_PUBLICA","TERCERO":"$TERCERO","COMPROMISOS":"$COMPROMISOS(type:double)","OBLIGACIONES":"$OBLIGACIONES(type:double)","PAGOS":"$PAGOS(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionejecuciongastossgr">
		<call-query href="getCuipovalidacionValidacionejecuciongastossgrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionprograingresosaprosgrQuery"  useConfig="sysmandsunist">
		<sql>SELECT APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET CODIGO_CCPET, APROPIACIONESINICIALES.DETALLESECTORIAL DETALLE_SECTORIAL, SUM(APROPIACIONESINICIALES.CREDITO) APROPIACIONINICIAL, 0 MODIFICACION, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END OBSERVACION FROM APROPIACIONESINICIALES INNER JOIN PLAN_PRESUPUESTAL ON APROPIACIONESINICIALES.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND APROPIACIONESINICIALES.ANO=PLAN_PRESUPUESTAL.ANO AND APROPIACIONESINICIALES.CODIGO=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE APROPIACIONESINICIALES.COMPANIA=:COMPANIA and APROPIACIONESINICIALES.ANO=:ANIO AND PLAN_PRESUPUESTAL.NATURALEZA='C' AND PLAN_PRESUPUESTAL.REGALIAS NOT IN (0) AND APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') GROUP BY APROPIACIONESINICIALES.COMPANIA, APROPIACIONESINICIALES.ANO, APROPIACIONESINICIALES.CODIGO, APROPIACIONESINICIALES.CODIGO_CCPET , APROPIACIONESINICIALES.DETALLESECTORIAL, CASE WHEN APROPIACIONESINICIALES.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CODIGO_CCPET":"$CODIGO_CCPET","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprograingresosaprosgr">
		<call-query href="getCuipovalidacionValidacionprograingresosaprosgrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionprograingresosdetsgrQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET CODIGO_CCPET, DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, 0 APROPIACIONINICIAL, SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO -VALOR_DEBITO) MODIFICACION, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END OBSERVACION FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE=TIPO_COMPROBPP.CODIGO INNER JOIN PLAN_PRESUPUESTAL ON DETALLE_COMPROBANTE_PPTAL.COMPANIA=PLAN_PRESUPUESTAL.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO=PLAN_PRESUPUESTAL.ANO AND DETALLE_COMPROBANTE_PPTAL.CUENTA=PLAN_PRESUPUESTAL.CODIGO INNER JOIN TIPOVIGENCIA ON PLAN_PRESUPUESTAL.TIPOVIGENCIA=TIPOVIGENCIA.CODIGO WHERE PLAN_PRESUPUESTAL.COMPANIA=:COMPANIA AND PLAN_PRESUPUESTAL.ANO=:ANIO and DETALLE_COMPROBANTE_PPTAL.MES&lt;=:MESFINAL AND PLAN_PRESUPUESTAL.NATURALEZA='C' AND PLAN_PRESUPUESTAL.REGALIAS NOT IN (0) AND TIPO_COMPROBPP.CLASE IN('ADC','RED','TRA') AND DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') GROUP BY DETALLE_COMPROBANTE_PPTAL.COMPANIA, DETALLE_COMPROBANTE_PPTAL.ANO, DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET , DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL, CASE WHEN DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET IN ('0') THEN 'Falta configuración del codigo CCPET, Valor no reportado' ELSE '' END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CODIGO_CCPET":"$CODIGO_CCPET","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL(type:double)","MODIFICACION":"$MODIFICACION(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionprograingresosdetsgr">
		<call-query href="getCuipovalidacionValidacionprograingresosdetsgrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getCuipovalidacionValidacionejecucioningresossgrQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, NVL(CODIGO_CCEPT.CODIGO,0) CODIGO_CCPET, NVL(COD_CPC_CUIPO.CODIGO,'0') CPC, NVL(DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL,0) DETALLE_SECTORIAL, NVL(FUENTE_CUIPO.CODIGO, '0') FUENTE_FINANCIACION, SUM(CASE WHEN P.APLICA_DEST_ESPECIFICA NOT IN (0) THEN DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO-DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO ELSE 0 END )VALOR_DESTINACION, CASE WHEN P.TRANSFERENCIA NOT IN (0) THEN TERCERO.NIT_CEDULA ELSE '1' END TERCERO, NVL(P.POLITCA_PUBLICA_CUIPO,'0') POLITICA_PUBLICA, SUM(DETALLE_COMPROBANTE_PPTAL.VALOR_CREDITO - DETALLE_COMPROBANTE_PPTAL.VALOR_DEBITO) AS TOTAL, CASE WHEN (CODIGO_CCEPT.CODIGO IS NULL OR CODIGO_CCEPT.CODIGO IN ('0')) THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO IS NULL OR DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO IN ('0')) THEN 'Falta configuración de la fuente' ELSE '' END OBSERVACION FROM DETALLE_COMPROBANTE_PPTAL INNER JOIN PLAN_PRESUPUESTAL P ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = P.COMPANIA AND DETALLE_COMPROBANTE_PPTAL .ANO = P.ANO AND DETALLE_COMPROBANTE_PPTAL .CUENTA = P.CODIGO LEFT JOIN TIPOCLASIFICADOR CODIGO_CCEPT ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = CODIGO_CCEPT.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = CODIGO_CCEPT.ANO AND '006'=CODIGO_CCEPT.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.CODIGO_CCPET=CODIGO_CCEPT.CODIGO LEFT JOIN TIPOCLASIFICADOR FUENTE_CUIPO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = FUENTE_CUIPO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = FUENTE_CUIPO.ANO AND '009'=FUENTE_CUIPO.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO = FUENTE_CUIPO.CODIGO LEFT JOIN TIPOCLASIFICADOR COD_CPC_CUIPO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = COD_CPC_CUIPO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = COD_CPC_CUIPO.ANO AND '007'=COD_CPC_CUIPO.CLASECLASIFICADOR AND DETALLE_COMPROBANTE_PPTAL.CODIGO_CPC = COD_CPC_CUIPO.CODIGO INNER JOIN TIPO_COMPROBPP ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TIPO_COMPROBPP.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE = TIPO_COMPROBPP.CODIGO INNER JOIN TERCERO ON DETALLE_COMPROBANTE_PPTAL.COMPANIA = TERCERO.COMPANIA AND DETALLE_COMPROBANTE_PPTAL.TERCERO = TERCERO.NIT AND DETALLE_COMPROBANTE_PPTAL.SUCURSAL = TERCERO.SUCURSAL WHERE DETALLE_COMPROBANTE_PPTAL.COMPANIA = :COMPANIA AND DETALLE_COMPROBANTE_PPTAL.ANO = :ANIO AND DETALLE_COMPROBANTE_PPTAL.MES &lt;= :MESFINAL AND DETALLE_COMPROBANTE_PPTAL.NATURALEZA ='C' AND P.REGALIAS NOT IN (0) AND TIPO_COMPROBPP.CLASE IN ('ING','DIN','AIN') AND ((CODIGO_CCEPT.CODIGO IS NULL OR CODIGO_CCEPT.CODIGO IN ('0')) OR (DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO IS NULL OR DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO IN ('0'))) GROUP BY DETALLE_COMPROBANTE_PPTAL.CUENTA, DETALLE_COMPROBANTE_PPTAL.TIPO_CPTE, DETALLE_COMPROBANTE_PPTAL.COMPROBANTE, DETALLE_COMPROBANTE_PPTAL.CONSECUTIVO, NVL(CODIGO_CCEPT.CODIGO,0), NVL(COD_CPC_CUIPO.CODIGO,'0'), NVL(DETALLE_COMPROBANTE_PPTAL.DETALLE_SECTORIAL,0), FUENTE_CUIPO.CODIGO , CASE WHEN P.TRANSFERENCIA NOT IN (0) THEN TERCERO.NIT_CEDULA ELSE '1' END, NVL(P.POLITCA_PUBLICA_CUIPO,'0'), CASE WHEN (CODIGO_CCEPT.CODIGO IS NULL OR CODIGO_CCEPT.CODIGO IN ('0')) THEN 'Falta configuración del codigo CCPET, Valor no reportado' WHEN (DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO IS NULL OR DETALLE_COMPROBANTE_PPTAL.FUENTE_CUIPO IN ('0')) THEN 'Falta configuración de la fuente' ELSE '' END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","TIPO_CPTE":"$TIPO_CPTE","COMPROBANTE":"$COMPROBANTE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CODIGO_CCPET":"$CODIGO_CCPET","CPC":"$CPC","DETALLE_SECTORIAL":"$DETALLE_SECTORIAL","FUENTE_FINANCIACION":"$FUENTE_FINANCIACION","VALOR_DESTINACION":"$VALOR_DESTINACION(type:integer)","TERCERO":"$TERCERO","POLITICA_PUBLICA":"$POLITICA_PUBLICA","TOTAL":"$TOTAL(type:double)","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cuipovalidacion/validacionejecucioningresossgr">
		<call-query href="getCuipovalidacionValidacionejecucioningresossgrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>

</data>