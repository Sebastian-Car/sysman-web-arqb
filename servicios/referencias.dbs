	<query id="getReferenciasPagConplanpptalporcuentaanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT REFERENCIA.CODIGO, REFERENCIA.NOMBRE  FROM REFERENCIA INNER JOIN V_PLAN_PRESUPUESTAL ON REFERENCIA.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND REFERENCIA.CODIGO = V_PLAN_PRESUPUESTAL.REFERENCIA AND REFERENCIA.ANO = V_PLAN_PRESUPUESTAL.ANO WHERE REFERENCIA.COMPANIA = :COMPANIA AND REFERENCIA.MOVIMIENTO NOT IN ( 0 ) AND REFERENCIA.ANO = :ANO AND V_PLAN_PRESUPUESTAL.CODIGO = :CODCUENTA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
