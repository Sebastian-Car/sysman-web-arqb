	<query id="getReferenciasPoraniopaginadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT t.*, ROWNUM rn FROM ( SELECT COMPANIA,ANO,CODIGO, NOMBRE FROM REFERENCIA WHERE COMPANIA = :COMPANIA AND ANO = :ANIO ORDER BY CODIGO ) t WHERE ROWNUM &lt;= :PAGINICIO + :PAGTAMANIO ) WHERE rn &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","RN":"$RN(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="referencias/poraniopaginado">
