	</resource>
		<query id="getReferenciasReferenciaequivalentesiganoQuery"  useConfig="sysmandsunist">
		<sql>SELECT REFERENCIA.CODIGO FROM REFERENCIA WHERE REFERENCIA.COMPANIA = :COMPANIA AND REFERENCIA.ANO = :ANO ORDER BY CODIGO ASC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
