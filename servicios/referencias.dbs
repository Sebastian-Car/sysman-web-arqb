	<query id="getReferenciasPagGetreferenciapocompaniaanioyrubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_PPTAL.REFERENCIA CODIGO, REFERENCIA.NOMBRE NOMBRE FROM DETALLE_COMPROBANTE_PPTAL LEFT JOIN REFERENCIA ON REFERENCIA.COMPANIA = DETALLE_COMPROBANTE_PPTAL.compania AND REFERENCIA.ANO = DETALLE_COMPROBANTE_PPTAL.ano AND REFERENCIA.CODIGO = DETALLE_COMPROBANTE_PPTAL.REFERENCIA WHERE DETALLE_COMPROBANTE_PPTAL.compania = :COMPANIA and DETALLE_COMPROBANTE_PPTAL.ano = :ANO and DETALLE_COMPROBANTE_PPTAL.cuenta = :RUBRO group by REFERENCIA.NOMBRE, DETALLE_COMPROBANTE_PPTAL.REFERENCIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
