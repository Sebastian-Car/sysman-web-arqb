	<query id="getReferenciasTodosporanoactualQuery"  useConfig="sysmandsunist">
		<sql>SELECT REFERENCIA.CODIGO, REFERENCIA.NOMBRE FROM REFERENCIA WHERE REFERENCIA.COMPANIA = :COMPANIA AND REFERENCIA.ANO = TO_CHAR(SYSDATE, 'YYYY') ORDER BY REFERENCIA.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
