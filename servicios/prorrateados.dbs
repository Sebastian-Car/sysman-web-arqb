<data name="prorrateados" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getProrrateadosListaprorrateadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPO, ANO, CODIGO, CUENTA_CREDITO, PCT_APLICAR FROM PRORRATEADOS WHERE PRORRATEADOS.COMPANIA = :COMPANIA AND PRORRATEADOS.TIPO = :TIPO AND PRORRATEADOS.ANO = :ANO AND PRORRATEADOS.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CUENTA_CREDITO":"$CUENTA_CREDITO","PCT_APLICAR":"$PCT_APLICAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="prorrateados/listaprorrateados">
		<call-query href="getProrrateadosListaprorrateadosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getProrrateadosValidarporcentajeQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(PCT_APLICAR) VALOR FROM PRORRATEADOS WHERE PRORRATEADOS.COMPANIA = :COMPANIA AND PRORRATEADOS.TIPO = :TIPO AND PRORRATEADOS.ANO = :ANO AND PRORRATEADOS.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="prorrateados/validarporcentaje">
		<call-query href="getProrrateadosValidarporcentajeQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertProrrateados" keyColumns="COMPANIA,TIPO,ANO,CODIGO,CUENTA_CREDITO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PRORRATEADOS (COMPANIA, TIPO, ANO, CODIGO, CUENTA_CREDITO, PCT_APLICAR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :ANO, :CODIGO, :CUENTA_CREDITO, :PCT_APLICAR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO","KEY_CUENTA_CREDITO":"$CUENTA_CREDITO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param defaultValue="0" name="PCT_APLICAR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="prorrateados">
		<call-query href="insertProrrateados">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="PCT_APLICAR" query-param="PCT_APLICAR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteProrrateados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PRORRATEADOS WHERE PRORRATEADOS.COMPANIA= :KEY_COMPANIA AND PRORRATEADOS.TIPO= :KEY_TIPO AND PRORRATEADOS.ANO= :KEY_ANO AND PRORRATEADOS.CODIGO= :KEY_CODIGO AND PRORRATEADOS.CUENTA_CREDITO= :KEY_CUENTA_CREDITO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CUENTA_CREDITO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="prorrateados">
		<call-query href="deleteProrrateados">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CUENTA_CREDITO" query-param="KEY_CUENTA_CREDITO"/>

		</call-query>
	</resource>
	<query id="getProrrateadosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPO, ANO, CODIGO, CUENTA_CREDITO, PCT_APLICAR FROM PRORRATEADOS WHERE PRORRATEADOS.COMPANIA= :KEY_COMPANIA AND PRORRATEADOS.TIPO= :KEY_TIPO AND PRORRATEADOS.ANO= :KEY_ANO AND PRORRATEADOS.CODIGO= :KEY_CODIGO AND PRORRATEADOS.CUENTA_CREDITO= :KEY_CUENTA_CREDITO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","CUENTA_CREDITO":"$CUENTA_CREDITO","PCT_APLICAR":"$PCT_APLICAR"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CUENTA_CREDITO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="prorrateados/data">
		<call-query href="getProrrateadosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CUENTA_CREDITO" query-param="KEY_CUENTA_CREDITO"/>

		</call-query>
	</resource>
	<query id="updateProrrateados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PRORRATEADOS SET COMPANIA=:COMPANIA, TIPO=:TIPO, ANO=:ANO, CODIGO=:CODIGO, CUENTA_CREDITO=:CUENTA_CREDITO, PCT_APLICAR=:PCT_APLICAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PRORRATEADOS.COMPANIA= :KEY_COMPANIA AND PRORRATEADOS.TIPO= :KEY_TIPO AND PRORRATEADOS.ANO= :KEY_ANO AND PRORRATEADOS.CODIGO= :KEY_CODIGO AND PRORRATEADOS.CUENTA_CREDITO= :KEY_CUENTA_CREDITO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="PCT_APLICAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_CUENTA_CREDITO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="prorrateados">
		<call-query href="updateProrrateados">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="PCT_APLICAR" query-param="PCT_APLICAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_CUENTA_CREDITO" query-param="KEY_CUENTA_CREDITO"/>

		</call-query>
	</resource>

</data>