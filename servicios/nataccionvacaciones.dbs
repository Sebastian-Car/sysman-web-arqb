<data name="nataccionvacaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNataccionvacacionesAccionpornombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO CODIGOACCION, NOMBREACCION  FROM NAT_ACCION_VACACIONES ORDER BY NOMBREACCION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACCION":"$CODIGOACCION","NOMBREACCION":"$NOMBREACCION"}]}}		</result>
 
	</query>
	<resource method="GET" path="nataccionvacaciones/accionpornombre">
		<call-query href="getNataccionvacacionesAccionpornombreQuery">
 
		</call-query>
	</resource>

</data>