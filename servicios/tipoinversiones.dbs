<data name="tipoinversiones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoinversionesDeRentaFijaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO,NOMBRE  FROM TIPO_INVERSION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="tipoinversiones/derentafija">
		<call-query href="getTipoinversionesDeRentaFijaQuery">
 
		</call-query>
	</resource>

</data>