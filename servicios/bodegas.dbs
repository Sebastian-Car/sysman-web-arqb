	<query id="getBodegasAuxiliaresbodegaQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE FUENTERECURSO WHEN 0 THEN 'false' ELSE 'true' END) FUENTERECURSO,(CASE REFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) REFERENCIA,(CASE AUXILIAR WHEN 0 THEN 'false' ELSE 'true' END) AUXILIAR,(CASE PROYECTO WHEN 0 THEN 'false' ELSE 'true' END) PROYECTO,(CASE CENTROCOSTO WHEN 0 THEN 'false' ELSE 'true' END) CENTROCOSTO,(CASE LOTE WHEN 0 THEN 'false' ELSE 'true' END) LOTE FROM BODEGA WHERE COMPANIA = :COMPANIA AND CODIGO = :BODEGA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FUENTERECURSO":"$FUENTERECURSO(type:boolean)","REFERENCIA":"$REFERENCIA(type:boolean)","AUXILIAR":"$AUXILIAR(type:boolean)","PROYECTO":"$PROYECTO(type:boolean)","CENTROCOSTO":"$CENTROCOSTO(type:boolean)","LOTE":"$LOTE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/auxiliaresbodega">
		<call-query href="getBodegasAuxiliaresbodegaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="BODEGA" query-param="BODEGA"/>

		</call-query>
	</resource>
	<query id="getBodegasCargabodegaveineteQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,NOMBRE FROM BODEGA WHERE COMPANIA = :COMPANIA AND CLASE_BODEGA = '20' ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/cargabodegaveinete">
