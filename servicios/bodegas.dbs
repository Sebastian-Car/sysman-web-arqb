<data name="bodegas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBodegasPagPorTipoMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BODEGA.CODIGO, BODEGA.NOMBRE, BODEGA.CLASE_BODEGA  FROM BODEGA INNER JOIN TIPOMOVIMIENTO ON BODEGA.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND BODEGA.CLASE_BODEGA = TIPOMOVIMIENTO.CLASE_BODEGA_ORIGEN WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CODIGO = :TIPOMOVIMIENTO ORDER BY BODEGA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE_BODEGA IS NULL THEN ' ' ELSE UPPER(CLASE_BODEGA) END)  LIKE UPPER(:CLASE_BODEGA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE_BODEGA":"$CLASE_BODEGA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bodegas/portipomovimiento/pag">
		<call-query href="getBodegasPagPorTipoMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBodegasNumPorTipoMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BODEGA.CODIGO, BODEGA.NOMBRE, BODEGA.CLASE_BODEGA  FROM BODEGA INNER JOIN TIPOMOVIMIENTO ON BODEGA.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND BODEGA.CLASE_BODEGA = TIPOMOVIMIENTO.CLASE_BODEGA_ORIGEN WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CODIGO = :TIPOMOVIMIENTO ORDER BY BODEGA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE_BODEGA IS NULL THEN ' ' ELSE UPPER(CLASE_BODEGA) END)  LIKE UPPER( '%' || :CLASE_BODEGA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/portipomovimiento/num">
		<call-query href="getBodegasNumPorTipoMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>

		</call-query>
	</resource>
	<query id="getBodegasPagDestinoPorTipoMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BODEGA.CODIGO, BODEGA.NOMBRE, BODEGA.CLASE_BODEGA  FROM BODEGA INNER JOIN TIPOMOVIMIENTO ON BODEGA.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND BODEGA.CLASE_BODEGA = TIPOMOVIMIENTO.CLASE_BODEGA_DESTINO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CODIGO = :TIPOMOVIMIENTO ORDER BY BODEGA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE_BODEGA IS NULL THEN ' ' ELSE UPPER(CLASE_BODEGA) END)  LIKE UPPER(:CLASE_BODEGA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE_BODEGA":"$CLASE_BODEGA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bodegas/destinoportipomovimiento/pag">
		<call-query href="getBodegasPagDestinoPorTipoMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBodegasNumDestinoPorTipoMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BODEGA.CODIGO, BODEGA.NOMBRE, BODEGA.CLASE_BODEGA  FROM BODEGA INNER JOIN TIPOMOVIMIENTO ON BODEGA.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND BODEGA.CLASE_BODEGA = TIPOMOVIMIENTO.CLASE_BODEGA_DESTINO WHERE TIPOMOVIMIENTO.COMPANIA = :COMPANIA AND TIPOMOVIMIENTO.CODIGO = :TIPOMOVIMIENTO ORDER BY BODEGA.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE_BODEGA IS NULL THEN ' ' ELSE UPPER(CLASE_BODEGA) END)  LIKE UPPER( '%' || :CLASE_BODEGA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/destinoportipomovimiento/num">
		<call-query href="getBodegasNumDestinoPorTipoMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>

		</call-query>
	</resource>
	<query id="getBodegasPagListabodegaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  B.CODIGO, B.NOMBRE  FROM BODEGA B INNER JOIN CLASE_BODEGA C ON B.CODIGO = C.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bodegas/listabodega/pag">
		<call-query href="getBodegasPagListabodegaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBodegasNumListabodegaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  B.CODIGO, B.NOMBRE  FROM BODEGA B INNER JOIN CLASE_BODEGA C ON B.CODIGO = C.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/listabodega/num">
		<call-query href="getBodegasNumListabodegaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBodegasPagPorcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BODEGA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bodegas/porcompania/pag">
		<call-query href="getBodegasPagPorcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBodegasNumPorcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE  FROM BODEGA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/porcompania/num">
		<call-query href="getBodegasNumPorcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBodegasPagBodegasclase20Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE FROM BODEGA WHERE COMPANIA = :COMPANIA AND CLASE_BODEGA = :CLASE_BODEGA ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bodegas/bodegasclase20/pag">
		<call-query href="getBodegasPagBodegasclase20Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertBodegas" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BODEGA (COMPANIA, CODIGO, NOMBRE, CLASE_BODEGA, CREATED_BY, DATE_CREATED, MOSTRAR, MANTENIMIENTO, NO_EXPLOTADOS, FUENTERECURSO, REFERENCIA, AUXILIAR, PROYECTO, CENTROCOSTO, LOTE) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :CLASE_BODEGA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :MOSTRAR, :MANTENIMIENTO, :NO_EXPLOTADOS, :FUENTERECURSO, :REFERENCIA, :AUXILIAR, :PROYECTO, :CENTROCOSTO, :LOTE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="-1" name="MOSTRAR" sqlType="STRING"/>
		<param defaultValue="0" name="MANTENIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="NO_EXPLOTADOS" sqlType="STRING"/>
		<param defaultValue="0" name="FUENTERECURSO" sqlType="STRING"/>
		<param defaultValue="0" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="0" name="PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="CENTROCOSTO" sqlType="STRING"/>												   
		<param defaultValue="0" name="LOTE" sqlType="STRING"/>												

	</query>
	<resource method="POST" path="bodegas">
		<call-query href="insertBodegas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="MOSTRAR" query-param="MOSTRAR"/>
			<with-param name="MANTENIMIENTO" query-param="MANTENIMIENTO"/>
			<with-param name="NO_EXPLOTADOS" query-param="NO_EXPLOTADOS"/>
			<with-param name="FUENTERECURSO" query-param="FUENTERECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>											 
			<with-param name="LOTE" query-param="LOTE"/>								   

		</call-query>
	</resource>
	<query id="deleteBodegas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BODEGA WHERE BODEGA.COMPANIA= :KEY_COMPANIA AND BODEGA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bodegas">
		<call-query href="deleteBodegas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getBodegasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BODEGA.COMPANIA, BODEGA.CODIGO, BODEGA.NOMBRE, BODEGA.CLASE_BODEGA, CLASE_BODEGA.NOMBRE NOMBODEGA, BODEGA.CREATED_BY,(TO_CHAR(BODEGA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(CASE BODEGA.MOSTRAR WHEN 0 THEN 'false' ELSE 'true' END) MOSTRAR,(CASE BODEGA.MANTENIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MANTENIMIENTO,(CASE BODEGA.NO_EXPLOTADOS WHEN 0 THEN 'false' ELSE 'true' END) NO_EXPLOTADOS,(CASE BODEGA.FUENTERECURSO WHEN 0 THEN 'false' ELSE 'true' END) FUENTERECURSO,(CASE BODEGA.REFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) REFERENCIA,(CASE BODEGA.AUXILIAR WHEN 0 THEN 'false' ELSE 'true' END) AUXILIAR,(CASE BODEGA.PROYECTO WHEN 0 THEN 'false' ELSE 'true' END) PROYECTO,(CASE BODEGA.CENTROCOSTO WHEN 0 THEN 'false' ELSE 'true' END) CENTROCOSTO,(CASE BODEGA.LOTE WHEN 0 THEN 'false' ELSE 'true' END) LOTE FROM BODEGA INNER JOIN CLASE_BODEGA ON BODEGA.CLASE_BODEGA = CLASE_BODEGA.CODIGO WHERE BODEGA.COMPANIA = :COMPANIA ORDER BY BODEGA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASE_BODEGA IS NULL THEN ' ' ELSE UPPER(CLASE_BODEGA) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_BODEGA), '%')) AND (CASE WHEN NOMBODEGA IS NULL THEN ' ' ELSE UPPER(NOMBODEGA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBODEGA), '%')) AND (CASE WHEN MOSTRAR IS NULL THEN ' ' ELSE UPPER(MOSTRAR) END) LIKE UPPER(CONCAT(CONCAT('%',:MOSTRAR), '%')) AND (CASE WHEN MANTENIMIENTO IS NULL THEN ' ' ELSE UPPER(MANTENIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MANTENIMIENTO), '%')) AND (CASE WHEN NO_EXPLOTADOS IS NULL THEN ' ' ELSE UPPER(NO_EXPLOTADOS) END) LIKE UPPER(CONCAT(CONCAT('%',:NO_EXPLOTADOS), '%')) AND (CASE WHEN FUENTERECURSO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTERECURSO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:PROYECTO), '%')) AND (CASE WHEN CENTROCOSTO IS NULL THEN ' ' ELSE UPPER(CENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTROCOSTO), '%')) AND (CASE WHEN LOTE IS NULL THEN ' ' ELSE UPPER(LOTE) END) LIKE UPPER(CONCAT(CONCAT('%',:LOTE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASE_BODEGA":"$CLASE_BODEGA","NOMBODEGA":"$NOMBODEGA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MOSTRAR":"$MOSTRAR(type:boolean)","MANTENIMIENTO":"$MANTENIMIENTO(type:boolean)","NO_EXPLOTADOS":"$NO_EXPLOTADOS(type:boolean)","FUENTERECURSO":"$FUENTERECURSO(type:boolean)","REFERENCIA":"$REFERENCIA(type:boolean)","AUXILIAR":"$AUXILIAR(type:boolean)","PROYECTO":"$PROYECTO(type:boolean)","CENTROCOSTO":"$CENTROCOSTO(type:boolean)","LOTE":"$LOTE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="NOMBODEGA" sqlType="STRING"/>
		<param name="MOSTRAR" sqlType="STRING"/>
		<param name="MANTENIMIENTO" sqlType="STRING"/>
		<param name="NO_EXPLOTADOS" sqlType="STRING"/>
		<param name="FUENTERECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>								  
		<param name="LOTE" sqlType="STRING"/>							   
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bodegas">
