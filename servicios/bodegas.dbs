			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="NOMBODEGA" query-param="NOMBODEGA"/>
			<with-param name="MOSTRAR" query-param="MOSTRAR"/>
			<with-param name="MANTENIMIENTO" query-param="MANTENIMIENTO"/>
			<with-param name="NO_EXPLOTADOS" query-param="NO_EXPLOTADOS"/>
			<with-param name="FUENTERECURSO" query-param="FUENTERECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>											 
			<with-param name="LOTE" query-param="LOTE"/>								   
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBodegasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BODEGA.COMPANIA, BODEGA.CODIGO, BODEGA.NOMBRE, BODEGA.CLASE_BODEGA, CLASE_BODEGA.NOMBRE NOMBODEGA, BODEGA.CREATED_BY,(TO_CHAR(BODEGA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(CASE BODEGA.MOSTRAR WHEN 0 THEN 'false' ELSE 'true' END) MOSTRAR,(CASE BODEGA.MANTENIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MANTENIMIENTO,(CASE BODEGA.NO_EXPLOTADOS WHEN 0 THEN 'false' ELSE 'true' END) NO_EXPLOTADOS,(CASE BODEGA.FUENTERECURSO WHEN 0 THEN 'false' ELSE 'true' END) FUENTERECURSO,(CASE BODEGA.REFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) REFERENCIA,(CASE BODEGA.AUXILIAR WHEN 0 THEN 'false' ELSE 'true' END) AUXILIAR,(CASE BODEGA.PROYECTO WHEN 0 THEN 'false' ELSE 'true' END) PROYECTO,(CASE BODEGA.CENTROCOSTO WHEN 0 THEN 'false' ELSE 'true' END) CENTROCOSTO,(CASE BODEGA.LOTE WHEN 0 THEN 'false' ELSE 'true' END) LOTE FROM BODEGA INNER JOIN CLASE_BODEGA ON BODEGA.CLASE_BODEGA = CLASE_BODEGA.CODIGO WHERE BODEGA.COMPANIA = :COMPANIA ORDER BY BODEGA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASE_BODEGA IS NULL THEN ' ' ELSE UPPER(CLASE_BODEGA) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_BODEGA), '%')) AND (CASE WHEN NOMBODEGA IS NULL THEN ' ' ELSE UPPER(NOMBODEGA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBODEGA), '%')) AND (CASE WHEN MOSTRAR IS NULL THEN ' ' ELSE UPPER(MOSTRAR) END) LIKE UPPER(CONCAT(CONCAT('%',:MOSTRAR), '%')) AND (CASE WHEN MANTENIMIENTO IS NULL THEN ' ' ELSE UPPER(MANTENIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MANTENIMIENTO), '%')) AND (CASE WHEN NO_EXPLOTADOS IS NULL THEN ' ' ELSE UPPER(NO_EXPLOTADOS) END) LIKE UPPER(CONCAT(CONCAT('%',:NO_EXPLOTADOS), '%')) AND (CASE WHEN FUENTERECURSO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTERECURSO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:PROYECTO), '%')) AND (CASE WHEN CENTROCOSTO IS NULL THEN ' ' ELSE UPPER(CENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTROCOSTO), '%')) AND (CASE WHEN LOTE IS NULL THEN ' ' ELSE UPPER(LOTE) END) LIKE UPPER(CONCAT(CONCAT('%',:LOTE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="NOMBODEGA" sqlType="STRING"/>
		<param name="MOSTRAR" sqlType="STRING"/>
		<param name="MANTENIMIENTO" sqlType="STRING"/>
		<param name="NO_EXPLOTADOS" sqlType="STRING"/>
		<param name="FUENTERECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>
		<param name="LOTE" sqlType="STRING"/>
	</query>
	<resource method="GET" path="bodegas/numero">
