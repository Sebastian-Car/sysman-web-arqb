		</call-query>
	</resource>
	<query id="updateBodegas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BODEGA SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, CLASE_BODEGA=:CLASE_BODEGA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, MOSTRAR=:MOSTRAR, MANTENIMIENTO=:MANTENIMIENTO, NO_EXPLOTADOS=:NO_EXPLOTADOS, FUENTERECURSO=:FUENTERECURSO, REFERENCIA=:REFERENCIA, AUXILIAR=:AUXILIAR, PROYECTO=:PROYECTO, CENTROCOSTO=:CENTROCOSTO, LOTE=:LOTE WHERE BODEGA.COMPANIA= :KEY_COMPANIA AND BODEGA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="MOSTRAR" sqlType="STRING"/>
		<param name="MANTENIMIENTO" sqlType="STRING"/>
		<param name="NO_EXPLOTADOS" sqlType="STRING"/>
		<param name="FUENTERECURSO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>									  
		<param name="LOTE" sqlType="STRING"/>							   
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bodegas">
		<call-query href="updateBodegas">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="MOSTRAR" query-param="MOSTRAR"/>
			<with-param name="MANTENIMIENTO" query-param="MANTENIMIENTO"/>
			<with-param name="NO_EXPLOTADOS" query-param="NO_EXPLOTADOS"/>
			<with-param name="FUENTERECURSO" query-param="FUENTERECURSO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>												 
			<with-param name="LOTE" query-param="LOTE"/>								   
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getBodegasNumBodegasclase20Query"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE FROM BODEGA WHERE COMPANIA = :COMPANIA AND CLASE_BODEGA = :CLASE_BODEGA ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/bodegasclase20/num">
		<call-query href="getBodegasNumBodegasclase20Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBodegasPagBodegasclase20finQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE FROM BODEGA WHERE COMPANIA = :COMPANIA AND CLASE_BODEGA = :CLASE_BODEGA AND CODIGO &gt;= :CODIGOINI ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="CODIGOINI" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bodegas/bodegasclase20fin/pag">
		<call-query href="getBodegasPagBodegasclase20finQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_BODEGA" query-param="CLASE_BODEGA"/>
			<with-param name="CODIGOINI" query-param="CODIGOINI"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBodegasNumBodegasclase20finQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE FROM BODEGA WHERE COMPANIA = :COMPANIA AND CLASE_BODEGA = :CLASE_BODEGA AND CODIGO &gt;= :CODIGOINI ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_BODEGA" sqlType="STRING"/>
		<param name="CODIGOINI" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bodegas/bodegasclase20fin/num">
