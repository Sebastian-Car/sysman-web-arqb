<data name="natmodalidadestudiosuperior" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatmodalidadestudiosuperiorTodosPorCodigoYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MO_CODIGO, MO_NOMBRE  FROM NAT_MODALIDAD_ESTUDIOSUPERIOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MO_CODIGO":"$MO_CODIGO","MO_NOMBRE":"$MO_NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="natmodalidadestudiosuperior/todosporcodigoynombre">
		<call-query href="getNatmodalidadestudiosuperiorTodosPorCodigoYNombreQuery">
 
		</call-query>
	</resource>
	<query id="getNatmodalidadestudiosuperiorPagNatmodalidadestudiosuperiorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  MO_CODIGO, MO_NOMBRE  FROM NAT_MODALIDAD_ESTUDIOSUPERIOR) WHERE (CASE WHEN MO_CODIGO IS NULL THEN ' ' ELSE UPPER(MO_CODIGO) END)  LIKE UPPER(:MO_CODIGO || '%')  AND (CASE WHEN MO_NOMBRE IS NULL THEN ' ' ELSE UPPER(MO_NOMBRE) END)  LIKE UPPER(:MO_NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MO_CODIGO":"$MO_CODIGO","MO_NOMBRE":"$MO_NOMBRE"}]}}		</result>
		<param name="MO_CODIGO" sqlType="STRING"/>
		<param name="MO_NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natmodalidadestudiosuperior/natmodalidadestudiosuperior/pag">
		<call-query href="getNatmodalidadestudiosuperiorPagNatmodalidadestudiosuperiorQuery">
			<with-param name="MO_CODIGO" query-param="MO_CODIGO"/>
			<with-param name="MO_NOMBRE" query-param="MO_NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatmodalidadestudiosuperiorNumNatmodalidadestudiosuperiorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  MO_CODIGO, MO_NOMBRE  FROM NAT_MODALIDAD_ESTUDIOSUPERIOR) WHERE (CASE WHEN MO_CODIGO IS NULL THEN ' ' ELSE UPPER(MO_CODIGO) END)  LIKE UPPER(:MO_CODIGO || '%')  AND (CASE WHEN MO_NOMBRE IS NULL THEN ' ' ELSE UPPER(MO_NOMBRE) END)  LIKE UPPER(:MO_NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="MO_CODIGO" sqlType="STRING"/>
		<param name="MO_NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natmodalidadestudiosuperior/natmodalidadestudiosuperior/num">
		<call-query href="getNatmodalidadestudiosuperiorNumNatmodalidadestudiosuperiorQuery">
			<with-param name="MO_CODIGO" query-param="MO_CODIGO"/>
			<with-param name="MO_NOMBRE" query-param="MO_NOMBRE"/>

		</call-query>
	</resource>

</data>