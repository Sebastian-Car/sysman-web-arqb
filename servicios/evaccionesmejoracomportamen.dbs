	<query id="getEvaccionesmejoracomportamenRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  EV_ACCIONES_MEJORA_COMPORTAMEN.COMPANIA , EV_ACCIONES_MEJORA_COMPORTAMEN.NUMERO_EVALUACION , EV_ACCIONES_MEJORA_COMPORTAMEN.CLASE_EVALUACION , EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO_EVALUACION , EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADO , EV_ACCIONES_MEJORA_COMPORTAMEN.SUCURSAL_EVALUADO , EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADOR , EV_ACCIONES_MEJORA_COMPORTAMEN.SUCURSAL_EVALUADOR , EV_ACCIONES_MEJORA_COMPORTAMEN.COMPONENTE , EV_ACCIONES_MEJORA_COMPORTAMEN.ASPECTO_A_CORREGIR , EV_ACCIONES_MEJORA_COMPORTAMEN.ACCION , EV_ACCIONES_MEJORA_COMPORTAMEN.MOTIVO , EV_ACCIONES_MEJORA_COMPORTAMEN.OBSERVACIONES, EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO, EV_ACCIONES_MEJORA_COMPORTAMEN.CONSECUTIVO, EV_TIPO_DE_EVALUACION.NOMBRE  FROM EV_ACCIONES_MEJORA_COMPORTAMEN INNER JOIN EV_TIPO_DE_EVALUACION ON EV_TIPO_DE_EVALUACION.COMPANIA = EV_ACCIONES_MEJORA_COMPORTAMEN.COMPANIA AND EV_TIPO_DE_EVALUACION.CLASE_EVALUACION = EV_ACCIONES_MEJORA_COMPORTAMEN.CLASE_EVALUACION AND EV_TIPO_DE_EVALUACION.CODIGO = EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO_EVALUACION WHERE EV_ACCIONES_MEJORA_COMPORTAMEN.COMPANIA= :KEY_COMPANIA AND EV_ACCIONES_MEJORA_COMPORTAMEN.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO= :KEY_TIPO AND EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND EV_ACCIONES_MEJORA_COMPORTAMEN.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
