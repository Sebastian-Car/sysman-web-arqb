	<query id="getEvaccionesmejoracomportamenPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_ACCIONES_MEJORA_COMPORTAMEN.COMPANIA, EV_ACCIONES_MEJORA_COMPORTAMEN.CONSECUTIVO, EV_ACCIONES_MEJORA_COMPORTAMEN.COMPONENTE, EV_ACCIONES_MEJORA_COMPORTAMEN.MOTIVO, EV_ACCIONES_MEJORA_COMPORTAMEN.ASPECTO_A_CORREGIR, EV_ACCIONES_MEJORA_COMPORTAMEN.NUMERO_EVALUACION , EV_ACCIONES_MEJORA_COMPORTAMEN.CLASE_EVALUACION , EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO_EVALUACION , EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADO , EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADOR, EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO, EV_TIPO_DE_EVALUACION.NOMBRE  FROM EV_ACCIONES_MEJORA_COMPORTAMEN INNER JOIN EV_TIPO_DE_EVALUACION ON EV_TIPO_DE_EVALUACION.COMPANIA = EV_ACCIONES_MEJORA_COMPORTAMEN.COMPANIA AND EV_TIPO_DE_EVALUACION.CLASE_EVALUACION = EV_ACCIONES_MEJORA_COMPORTAMEN.CLASE_EVALUACION AND EV_TIPO_DE_EVALUACION.CODIGO = EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO_EVALUACION WHERE EV_ACCIONES_MEJORA_COMPORTAMEN.COMPANIA = :COMPANIA AND EV_ACCIONES_MEJORA_COMPORTAMEN.NUMERO_EVALUACION = :NUMEROEVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.CLASE_EVALUACION = :CLASEEVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO_EVALUACION = :TIPOEVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADO = :CEDULAEVALUADO AND EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADOR = :CEDULAEVALUADOR) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER( '%' || :COMPONENTE || '%')  AND (CASE WHEN ASPECTO_A_CORREGIR IS NULL THEN ' ' ELSE UPPER(ASPECTO_A_CORREGIR) END)  LIKE UPPER( '%' || :ASPECTO_A_CORREGIR || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","COMPONENTE":"$COMPONENTE","MOTIVO":"$MOTIVO","ASPECTO_A_CORREGIR":"$ASPECTO_A_CORREGIR","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","TIPO_EVALUACION":"$TIPO_EVALUACION","CEDULA_EVALUADO":"$CEDULA_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","TIPO":"$TIPO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROEVALUACION" sqlType="STRING"/>
		<param name="CLASEEVALUACION" sqlType="STRING"/>
		<param name="TIPOEVALUACION" sqlType="STRING"/>
		<param name="CEDULAEVALUADO" sqlType="STRING"/>
		<param name="CEDULAEVALUADOR" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ASPECTO_A_CORREGIR" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
