	<query id="updateEvaccionesmejoracomportamen" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_ACCIONES_MEJORA_COMPORTAMEN SET TIPO_EVALUACION=:TIPO_EVALUACION, CEDULA_EVALUADO=:CEDULA_EVALUADO, SUCURSAL_EVALUADO=:SUCURSAL_EVALUADO, CEDULA_EVALUADOR=:CEDULA_EVALUADOR, SUCURSAL_EVALUADOR=:SUCURSAL_EVALUADOR, COMPONENTE=:COMPONENTE, ASPECTO_A_CORREGIR=:ASPECTO_A_CORREGIR, ACCION=:ACCION, MOTIVO=:MOTIVO, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_ACCIONES_MEJORA_COMPORTAMEN.COMPANIA= :KEY_COMPANIA AND EV_ACCIONES_MEJORA_COMPORTAMEN.NUMERO_EVALUACION= :KEY_NUMERO_EVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_ACCIONES_MEJORA_COMPORTAMEN.TIPO= :KEY_TIPO AND EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_ACCIONES_MEJORA_COMPORTAMEN.CEDULA_EVALUADOR= :KEY_CEDULA_EVALUADOR AND EV_ACCIONES_MEJORA_COMPORTAMEN.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
