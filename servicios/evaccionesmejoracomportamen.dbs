	<query id="insertEvaccionesmejoracomportamen" keyColumns="COMPANIA,NUMERO_EVALUACION,CLASE_EVALUACION,TIPO_EVALUACION,TIPO,CEDULA_EVALUADO,CEDULA_EVALUADOR,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_ACCIONES_MEJORA_COMPORTAMEN (COMPANIA, NUMERO_EVALUACION, CLASE_EVALUACION, TIPO_EVALUACION, CEDULA_EVALUADO, SUCURSAL_EVALUADO, CEDULA_EVALUADOR, SUCURSAL_EVALUADOR, CONSECUTIVO, COMPONENTE, ASPECTO_A_CORREGIR, ACCION, MOTIVO, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_EVALUACION, :CLASE_EVALUACION, :TIPO_EVALUACION, :CEDULA_EVALUADO, :SUCURSAL_EVALUADO, :CEDULA_EVALUADOR, :SUCURSAL_EVALUADOR, :CONSECUTIVO, :COMPONENTE, :ASPECTO_A_CORREGIR, :ACCION, :MOTIVO, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","KEY_CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","KEY_TIPO_EVALUACION":"$TIPO_EVALUACION","KEY_TIPO":"$TIPO","KEY_CEDULA_EVALUADO":"$CEDULA_EVALUADO","KEY_CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
