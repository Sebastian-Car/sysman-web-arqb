			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroPagTodosporcodcobroterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_OBJETO_COBRO.CODIGO_COBRO AS NUMERO_FACTURA, SF_OBJETO_COBRO.TIPOCOBRO AS TIPO_FACTURA, SF_OBJETO_COBRO.TERCERO, SF_OBJETO_COBRO.SUCURSAL, SF_OBJETO_COBRO.CENTRO_COSTO, SF_OBJETO_COBRO.AUXILIAR, SF_OBJETO_COBRO.VALOR_TOTAL,(CASE SF_OBJETO_COBRO.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA, SF_OBJETO_COBRO.TIPO_ABONO, SF_OBJETO_COBRO.NRO_ABONO, SF_OBJETO_COBRO.TASA_INTERES, SF_OBJETO_COBRO.VLR_EFECTIVO, SF_OBJETO_COBRO.VLR_CREDITO, SF_OBJETO_COBRO.CUOTAS_DIFERIDAS, SF_OBJETO_COBRO.VLR_PROM_CUOTA, SF_OBJETO_COBRO.FECHA_SOLICITUD AS FECHA_EXPEDICION, TO_CHAR(CONCAT(CONCAT(CONCAT(CONCAT(SF_OBJETO_COBRO.TIPOCOBRO,' - '), SF_OBJETO_COBRO.CODIGO_COBRO),' - '),SF_OBJETO_COBRO.OBSERVACIONES)) AS OBSERVACIONES FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = :TIPOFACTURA AND NRO_ACUERDO IS NULL AND SF_OBJETO_COBRO.INDPAGO IN (0) AND SF_OBJETO_COBRO.ANO = :ANOCOBRO ORDER BY SF_OBJETO_COBRO.CODIGO_COBRO DESC) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN TIPO_FACTURA IS NULL THEN ' ' ELSE UPPER(TIPO_FACTURA) END) LIKE UPPER(CONCAT(:TIPO_FACTURA, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN DIFERIDA IS NULL THEN ' ' ELSE UPPER(DIFERIDA) END) LIKE UPPER(CONCAT(:DIFERIDA, '%')) AND (CASE WHEN TIPO_ABONO IS NULL THEN ' ' ELSE UPPER(TIPO_ABONO) END) LIKE UPPER(CONCAT(:TIPO_ABONO, '%')) AND (CASE WHEN NRO_ABONO IS NULL THEN ' ' ELSE UPPER(NRO_ABONO) END) LIKE UPPER(CONCAT(:NRO_ABONO, '%')) AND (CASE WHEN TASA_INTERES IS NULL THEN ' ' ELSE UPPER(TASA_INTERES) END) LIKE UPPER(CONCAT(:TASA_INTERES, '%')) AND (CASE WHEN VLR_EFECTIVO IS NULL THEN ' ' ELSE UPPER(VLR_EFECTIVO) END) LIKE UPPER(CONCAT(:VLR_EFECTIVO, '%')) AND (CASE WHEN VLR_CREDITO IS NULL THEN ' ' ELSE UPPER(VLR_CREDITO) END) LIKE UPPER(CONCAT(:VLR_CREDITO, '%')) AND (CASE WHEN CUOTAS_DIFERIDAS IS NULL THEN ' ' ELSE UPPER(CUOTAS_DIFERIDAS) END) LIKE UPPER(CONCAT(:CUOTAS_DIFERIDAS, '%')) AND (CASE WHEN VLR_PROM_CUOTA IS NULL THEN ' ' ELSE UPPER(VLR_PROM_CUOTA) END) LIKE UPPER(CONCAT(:VLR_PROM_CUOTA, '%')) AND (CASE WHEN FECHA_EXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHA_EXPEDICION) END) LIKE UPPER(CONCAT(:FECHA_EXPEDICION, '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","TIPO_FACTURA":"$TIPO_FACTURA","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VALOR_TOTAL":"$VALOR_TOTAL","DIFERIDA":"$DIFERIDA(type:boolean)","TIPO_ABONO":"$TIPO_ABONO","NRO_ABONO":"$NRO_ABONO(type:long)","TASA_INTERES":"$TASA_INTERES","VLR_EFECTIVO":"$VLR_EFECTIVO","VLR_CREDITO":"$VLR_CREDITO","CUOTAS_DIFERIDAS":"$CUOTAS_DIFERIDAS","VLR_PROM_CUOTA":"$VLR_PROM_CUOTA","FECHA_EXPEDICION":"$FECHA_EXPEDICION","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="TIPO_FACTURA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="DIFERIDA" sqlType="STRING"/>
		<param name="TIPO_ABONO" sqlType="STRING"/>
		<param name="NRO_ABONO" sqlType="STRING"/>
		<param name="TASA_INTERES" sqlType="STRING"/>
		<param name="VLR_EFECTIVO" sqlType="STRING"/>
		<param name="VLR_CREDITO" sqlType="STRING"/>
		<param name="CUOTAS_DIFERIDAS" sqlType="STRING"/>
		<param name="VLR_PROM_CUOTA" sqlType="STRING"/>
		<param name="FECHA_EXPEDICION" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
