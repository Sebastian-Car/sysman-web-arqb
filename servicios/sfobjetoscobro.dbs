		</call-query>
	</resource>
	<query id="getSfobjetoscobroNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, TIPOCOBRO, NRO_FACTURA, CODIGO_COBRO,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, ANO, TERCERO,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD,(TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, VALOR_TOTAL FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = :TIPO_COBRO AND EXTRACT ( YEAR FROM FECHA_SOLICITUD) = :ANIO ORDER BY SF_OBJETO_COBRO.CODIGO_COBRO DESC) INI WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END) LIKE UPPER(CONCAT(:NRO_FACTURA, '%')) AND (CASE WHEN CODIGO_COBRO IS NULL THEN ' ' ELSE UPPER(CODIGO_COBRO) END) LIKE UPPER(CONCAT(:CODIGO_COBRO, '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(:IMPRESO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN FECHA_SOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHA_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_SOLICITUD), '%')) AND (CASE WHEN FECHA_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHA_VENCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_VENCIMIENTO), '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_COBRO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="CODIGO_COBRO" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param name="FECHA_VENCIMIENTO" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/numero">
		<call-query href="getSfobjetoscobroNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_COBRO" query-param="TIPO_COBRO"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="NRO_FACTURA" query-param="NRO_FACTURA"/>
			<with-param name="CODIGO_COBRO" query-param="CODIGO_COBRO"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="FECHA_SOLICITUD" query-param="FECHA_SOLICITUD"/>
			<with-param name="FECHA_VENCIMIENTO" query-param="FECHA_VENCIMIENTO"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_OBJETO_COBRO.COMPANIA, SF_OBJETO_COBRO.ANO, SF_OBJETO_COBRO.TIPOCOBRO, SF_OBJETO_COBRO.CODIGO_COBRO, SF_OBJETO_COBRO.TERCERO, SF_OBJETO_COBRO.SUCURSAL, SF_OBJETO_COBRO.CENTRO_COSTO, SF_OBJETO_COBRO.AUXILIAR, ( TO_CHAR( SF_OBJETO_COBRO.FECHA_SOLICITUD, 'DD/MM/YYYY HH24:MI:SS' ) ) FECHA_SOLICITUD, ( TO_CHAR( SF_OBJETO_COBRO.FECHA_REGISTRO, 'DD/MM/YYYY HH24:MI:SS' ) ) FECHA_REGISTRO, SF_OBJETO_COBRO.NIT_ANUNCIANTE, SF_OBJETO_COBRO.SUCURSAL_ANUNCIANTE, SF_OBJETO_COBRO.NIT_PROPIETARIO, SF_OBJETO_COBRO.SUCURSAL_PROPIETARIO, SF_OBJETO_COBRO.VALOR_TOTAL, SF_OBJETO_COBRO.OBSERVACIONES, SF_OBJETO_COBRO.REFERENCIA_OBJCOBRO, SF_OBJETO_COBRO.ESTRATO, SF_OBJETO_COBRO.TIPOFACTURA, SF_OBJETO_COBRO.NRO_FACTURA, ( CASE SF_OBJETO_COBRO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END ) IMPRESO, SF_OBJETO_COBRO.TIPOCONTRATO, SF_OBJETO_COBRO.CONTRATO, SF_OBJETO_COBRO.CCOSTO_CONTRATO, SF_OBJETO_COBRO.PERIODOCONTRATO, SF_OBJETO_COBRO.TIPO_ACUERDO, SF_OBJETO_COBRO.NRO_ACUERDO, SF_OBJETO_COBRO.CUOTA_ACUERDO, ( CASE SF_OBJETO_COBRO.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END ) DIFERIDA, SF_OBJETO_COBRO.TIPO_ABONO, SF_OBJETO_COBRO.NRO_ABONO, SF_OBJETO_COBRO.VLR_EFECTIVO, SF_OBJETO_COBRO.VLR_CREDITO, SF_OBJETO_COBRO.CUOTAS_DIFERIDAS, SF_OBJETO_COBRO.VLR_PROM_CUOTA, SF_OBJETO_COBRO.CUENTA_RECAUDO, SF_OBJETO_COBRO.TIPOCPTE_RECAUDO, SF_OBJETO_COBRO.NIT_TERCEROFACTURADO, SF_OBJETO_COBRO.SUCURSAL_TERCEROFACTURADO, SF_OBJETO_COBRO.NOMBRE_TERCEROFACTURADO, SF_OBJETO_COBRO.FORMULARIO_DELURBANA, SF_OBJETO_COBRO.TASA_INTERES, SF_OBJETO_COBRO.DIRECCION, SF_OBJETO_COBRO.CODIGOPOSTAL, SF_OBJETO_COBRO.GRUPO_CONCEPTOS, SF_OBJETO_COBRO.TOTAL_GRUPO, SF_OBJETO_COBRO.CANTIDAD_GRUPO, ( TO_CHAR( SF_OBJETO_COBRO.FECHA_VENCIMIENTO, 'DD/MM/YYYY HH24:MI:SS' ) ) FECHA_VENCIMIENTO, SF_OBJETO_COBRO.CPTE_CTBLE, SF_OBJETO_COBRO.NROCPTE_CTBLE, SF_OBJETO_COBRO.BASEORIGINAL, SF_OBJETO_COBRO.INDREVERSO, SF_OBJETO_COBRO.TELEFONOS, ( CASE SF_OBJETO_COBRO.INDPAGO WHEN 0 THEN 'false' ELSE 'true' END ) INDPAGO, SF_OBJETO_COBRO.NUMERO_LIQUIDACION, ( TO_CHAR( SF_OBJETO_COBRO.FECHA_PRELIQUIDACION, 'DD/MM/YYYY HH24:MI:SS' ) ) FECHA_PRELIQUIDACION, SF_OBJETO_COBRO.CREATED_BY, ( TO_CHAR( SF_OBJETO_COBRO.DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS' ) ) DATE_CREATED, SF_OBJETO_COBRO.MODIFIED_BY, ( TO_CHAR( SF_OBJETO_COBRO.DATE_MODIFIED, 'DD/MM/YYYY HH24:MI:SS' ) ) DATE_MODIFIED, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, AUXILIAR.NOMBRE NOMBREAUXILIAR, CONCAT( TERCERO.APELLIDO1, CONCAT( ' ', CONCAT( TERCERO.APELLIDO2, CONCAT( ' ', CONCAT( TERCERO.NOMBRE1, CONCAT( ' ', TERCERO.NOMBRE2 ) ) ) ) ) ) NOMBRETERCERO, SF_CONTRATOS.OBJETO_CONTRATO, SF_OBJETO_COBRO.COD_DESCRIPCION, SF_OBJETO_COBRO.COD_TARIFABASE, SF_OBJETO_COBRO.BASE_FIJA_ANT, SF_OBJETO_COBRO.FUENTE_RECURSO, FUENTE_RECURSOS.NOMBRE NOMBRE_FUENTE_RECURSO, SF_FACTURA.NRO_ABONO NUMERO_ABONO, ( CASE SF_FACTURA.ANULADA WHEN - 1 THEN 'true' ELSE 'false' END ) ANULADA, SF_OBJETO_COBRO.TIPO_MEDIOPAGO, SF_OBJETO_COBRO.TIPO_PAGO, SF_OBJETO_COBRO.AJUSTE, SF_OBJETO_COBRO.REF_FACTURACION, SF_FACTURA.NROCPTE_PAGO, SF_FACTURA.TIPOCPTE_PAGO, TERCERO.DIRECCIONEMAIL AS EMAIL, ( CASE SF_OBJETO_COBRO.FACTURA_DOLARES WHEN 0 THEN 'false' ELSE 'true' END ) FACTURA_DOLARES, SF_OBJETO_COBRO.TRM_DOLARES_FAC, SF_OBJETO_COBRO.TRM_DOLARES_REC, SF_OBJETO_COBRO.VALOR_TOTAL_DOLARES, SF_OBJETO_COBRO.TXTCONTRATO, SF_OBJETO_COBRO.DESCRIPCION_TIPOPAGO, TIPO_PAGO.DIAS,TXTPREFIJO, SF_OBJETO_COBRO.NROCONTRATOSIGEC, SF_OBJETO_COBRO.TIPOCONTRATOSIGEC, (CASE SF_OBJETO_COBRO.APLICA_DSCTO WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DSCTO,(TO_CHAR(SF_OBJETO_COBRO.FECHAVENCIDSCTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIDSCTO,(CASE SF_OBJETO_COBRO.IND_PAGOPARCIAL WHEN 0 THEN 'false' ELSE 'true' END) IND_PAGOPARCIAL FROM SF_OBJETO_COBRO LEFT JOIN CENTRO_COSTO ON SF_OBJETO_COBRO.COMPANIA = CENTRO_COSTO.COMPANIA AND SF_OBJETO_COBRO.ANO = CENTRO_COSTO.ANO AND SF_OBJETO_COBRO.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON SF_OBJETO_COBRO.COMPANIA = AUXILIAR.COMPANIA AND SF_OBJETO_COBRO.ANO = AUXILIAR.ANO AND SF_OBJETO_COBRO.AUXILIAR = AUXILIAR.CODIGO LEFT JOIN FUENTE_RECURSOS ON SF_OBJETO_COBRO.COMPANIA = FUENTE_RECURSOS.COMPANIA AND SF_OBJETO_COBRO.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO AND SF_OBJETO_COBRO.ANO = FUENTE_RECURSOS.ANO LEFT JOIN TERCERO ON SF_OBJETO_COBRO.COMPANIA = TERCERO.COMPANIA AND SF_OBJETO_COBRO.TERCERO = TERCERO.NIT AND SF_OBJETO_COBRO.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN SF_CONTRATOS ON SF_OBJETO_COBRO.COMPANIA = SF_CONTRATOS.COMPANIA AND SF_OBJETO_COBRO.TIPOCONTRATO = SF_CONTRATOS.TIPO AND SF_OBJETO_COBRO.CONTRATO = SF_CONTRATOS.NUMERO AND SF_OBJETO_COBRO.ANO = SF_CONTRATOS.ANO LEFT JOIN TIPO_PAGO ON SF_CONTRATOS.COMPANIA = TIPO_PAGO.COMPANIA AND SF_CONTRATOS.TIPO_PAGO = TIPO_PAGO.CODIGO LEFT JOIN SF_FACTURA ON SF_FACTURA.COMPANIA = SF_OBJETO_COBRO.COMPANIA AND SF_FACTURA.TIPOCOBRO = SF_OBJETO_COBRO.TIPOCOBRO AND SF_FACTURA.ANO = SF_OBJETO_COBRO.ANO AND SF_FACTURA.CODIGO_COBRO = SF_OBJETO_COBRO.CODIGO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA= :KEY_COMPANIA AND SF_OBJETO_COBRO.ANO= :KEY_ANO AND SF_OBJETO_COBRO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_OBJETO_COBRO.CODIGO_COBRO= :KEY_CODIGO_COBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","FECHA_SOLICITUD":"$FECHA_SOLICITUD","FECHA_REGISTRO":"$FECHA_REGISTRO","NIT_ANUNCIANTE":"$NIT_ANUNCIANTE","SUCURSAL_ANUNCIANTE":"$SUCURSAL_ANUNCIANTE","NIT_PROPIETARIO":"$NIT_PROPIETARIO","SUCURSAL_PROPIETARIO":"$SUCURSAL_PROPIETARIO","VALOR_TOTAL":"$VALOR_TOTAL","OBSERVACIONES":"$OBSERVACIONES","REFERENCIA_OBJCOBRO":"$REFERENCIA_OBJCOBRO","ESTRATO":"$ESTRATO","TIPOFACTURA":"$TIPOFACTURA","NRO_FACTURA":"$NRO_FACTURA(type:long)","IMPRESO":"$IMPRESO(type:boolean)","TIPOCONTRATO":"$TIPOCONTRATO","CONTRATO":"$CONTRATO(type:long)","CCOSTO_CONTRATO":"$CCOSTO_CONTRATO","PERIODOCONTRATO":"$PERIODOCONTRATO(type:long)","TIPO_ACUERDO":"$TIPO_ACUERDO","NRO_ACUERDO":"$NRO_ACUERDO(type:long)","CUOTA_ACUERDO":"$CUOTA_ACUERDO","DIFERIDA":"$DIFERIDA(type:boolean)","TIPO_ABONO":"$TIPO_ABONO","NRO_ABONO":"$NRO_ABONO(type:long)","VLR_EFECTIVO":"$VLR_EFECTIVO","VLR_CREDITO":"$VLR_CREDITO","CUOTAS_DIFERIDAS":"$CUOTAS_DIFERIDAS","VLR_PROM_CUOTA":"$VLR_PROM_CUOTA","CUENTA_RECAUDO":"$CUENTA_RECAUDO","TIPOCPTE_RECAUDO":"$TIPOCPTE_RECAUDO","NIT_TERCEROFACTURADO":"$NIT_TERCEROFACTURADO","SUCURSAL_TERCEROFACTURADO":"$SUCURSAL_TERCEROFACTURADO","NOMBRE_TERCEROFACTURADO":"$NOMBRE_TERCEROFACTURADO","FORMULARIO_DELURBANA":"$FORMULARIO_DELURBANA","TASA_INTERES":"$TASA_INTERES","DIRECCION":"$DIRECCION","CODIGOPOSTAL":"$CODIGOPOSTAL","GRUPO_CONCEPTOS":"$GRUPO_CONCEPTOS(type:integer)","TOTAL_GRUPO":"$TOTAL_GRUPO","CANTIDAD_GRUPO":"$CANTIDAD_GRUPO","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","CPTE_CTBLE":"$CPTE_CTBLE","NROCPTE_CTBLE":"$NROCPTE_CTBLE(type:long)","BASEORIGINAL":"$BASEORIGINAL(type:long)","INDREVERSO":"$INDREVERSO(type:long)","TELEFONOS":"$TELEFONOS","INDPAGO":"$INDPAGO(type:boolean)","NUMERO_LIQUIDACION":"$NUMERO_LIQUIDACION(type:long)","FECHA_PRELIQUIDACION":"$FECHA_PRELIQUIDACION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE_CENTRO_COSTO":"$NOMBRE_CENTRO_COSTO","NOMBREAUXILIAR":"$NOMBREAUXILIAR","NOMBRETERCERO":"$NOMBRETERCERO","OBJETO_CONTRATO":"$OBJETO_CONTRATO","COD_DESCRIPCION":"$COD_DESCRIPCION","COD_TARIFABASE":"$COD_TARIFABASE","BASE_FIJA_ANT":"$BASE_FIJA_ANT","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBRE_FUENTE_RECURSO":"$NOMBRE_FUENTE_RECURSO","NUMERO_ABONO":"$NUMERO_ABONO(type:long)","ANULADA":"$ANULADA(type:boolean)","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_PAGO":"$TIPO_PAGO","AJUSTE":"$AJUSTE","REF_FACTURACION":"$REF_FACTURACION","NROCPTE_PAGO":"$NROCPTE_PAGO(type:long)","TIPOCPTE_PAGO":"$TIPOCPTE_PAGO","EMAIL":"$EMAIL","FACTURA_DOLARES":"$FACTURA_DOLARES(type:boolean)","TRM_DOLARES_FAC":"$TRM_DOLARES_FAC","TRM_DOLARES_REC":"$TRM_DOLARES_REC","VALOR_TOTAL_DOLARES":"$VALOR_TOTAL_DOLARES","TXTCONTRATO":"$TXTCONTRATO","DESCRIPCION_TIPOPAGO":"$DESCRIPCION_TIPOPAGO","DIAS":"$DIAS(type:integer)","TXTPREFIJO":"$TXTPREFIJO","NROCONTRATOSIGEC":"$NROCONTRATOSIGEC","TIPOCONTRATOSIGEC":"$TIPOCONTRATOSIGEC","APLICA_DSCTO":"$APLICA_DSCTO(type:boolean)","FECHAVENCIDSCTO":"$FECHAVENCIDSCTO","IND_PAGOPARCIAL":"$IND_PAGOPARCIAL(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO_COBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/data">
		<call-query href="getSfobjetoscobroRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CODIGO_COBRO" query-param="KEY_CODIGO_COBRO"/>

		</call-query>
	</resource>
	<query id="updateSfobjetoscobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_OBJETO_COBRO SET TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, FECHA_SOLICITUD=TO_DATE(:FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS'), FECHA_REGISTRO=TO_DATE(:FECHA_REGISTRO,'DD/MM/YYYY HH24:MI:SS'), NIT_ANUNCIANTE=:NIT_ANUNCIANTE, SUCURSAL_ANUNCIANTE=:SUCURSAL_ANUNCIANTE, NIT_PROPIETARIO=:NIT_PROPIETARIO, SUCURSAL_PROPIETARIO=:SUCURSAL_PROPIETARIO, OBSERVACIONES=:OBSERVACIONES, REFERENCIA_OBJCOBRO=:REFERENCIA_OBJCOBRO, ESTRATO=:ESTRATO, TIPOFACTURA=:TIPOFACTURA, NRO_FACTURA=:NRO_FACTURA, IMPRESO=:IMPRESO, TIPOCONTRATO=:TIPOCONTRATO, CONTRATO=:CONTRATO, CCOSTO_CONTRATO=:CCOSTO_CONTRATO, PERIODOCONTRATO=:PERIODOCONTRATO, TIPO_ACUERDO=:TIPO_ACUERDO, NRO_ACUERDO=:NRO_ACUERDO, CUOTA_ACUERDO=:CUOTA_ACUERDO, DIFERIDA=:DIFERIDA, TIPO_ABONO=:TIPO_ABONO, NRO_ABONO=:NRO_ABONO, VLR_EFECTIVO=:VLR_EFECTIVO, VLR_CREDITO=:VLR_CREDITO, CUOTAS_DIFERIDAS=:CUOTAS_DIFERIDAS, VLR_PROM_CUOTA=:VLR_PROM_CUOTA, CUENTA_RECAUDO=:CUENTA_RECAUDO, TIPOCPTE_RECAUDO=:TIPOCPTE_RECAUDO, NIT_TERCEROFACTURADO=:NIT_TERCEROFACTURADO, SUCURSAL_TERCEROFACTURADO=:SUCURSAL_TERCEROFACTURADO, NOMBRE_TERCEROFACTURADO=:NOMBRE_TERCEROFACTURADO, FORMULARIO_DELURBANA=:FORMULARIO_DELURBANA, TASA_INTERES=:TASA_INTERES, DIRECCION=:DIRECCION, CODIGOPOSTAL=:CODIGOPOSTAL, GRUPO_CONCEPTOS=:GRUPO_CONCEPTOS, TOTAL_GRUPO=:TOTAL_GRUPO, CANTIDAD_GRUPO=:CANTIDAD_GRUPO, FECHA_VENCIMIENTO=TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), CPTE_CTBLE=:CPTE_CTBLE, NROCPTE_CTBLE=:NROCPTE_CTBLE, BASEORIGINAL=:BASEORIGINAL, INDREVERSO=:INDREVERSO, TELEFONOS=:TELEFONOS, INDPAGO=:INDPAGO, NUMERO_LIQUIDACION=:NUMERO_LIQUIDACION, FECHA_PRELIQUIDACION=TO_DATE(:FECHA_PRELIQUIDACION,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), COD_DESCRIPCION=:COD_DESCRIPCION, COD_TARIFABASE=:COD_TARIFABASE, FUENTE_RECURSO=:FUENTE_RECURSO, BASE_FIJA_ANT=:BASE_FIJA_ANT, TIPO_MEDIOPAGO=:TIPO_MEDIOPAGO, TIPO_PAGO=:TIPO_PAGO, AJUSTE=:AJUSTE, REF_FACTURACION=:REF_FACTURACION, FACTURA_DOLARES=:FACTURA_DOLARES, TRM_DOLARES_FAC=:TRM_DOLARES_FAC, TRM_DOLARES_REC=:TRM_DOLARES_REC, VALOR_TOTAL_DOLARES=:VALOR_TOTAL_DOLARES, TXTCONTRATO=:TXTCONTRATO, DESCRIPCION_TIPOPAGO=:DESCRIPCION_TIPOPAGO, TXTPREFIJO=:TXTPREFIJO, NROCONTRATOSIGEC=:NROCONTRATOSIGEC, TIPOCONTRATOSIGEC=:TIPOCONTRATOSIGEC, APLICA_DSCTO=:APLICA_DSCTO, FECHAVENCIDSCTO=TO_DATE(:FECHAVENCIDSCTO,'DD/MM/YYYY HH24:MI:SS'), IND_PAGOPARCIAL=:IND_PAGOPARCIAL WHERE SF_OBJETO_COBRO.COMPANIA= :KEY_COMPANIA AND SF_OBJETO_COBRO.ANO= :KEY_ANO AND SF_OBJETO_COBRO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_OBJETO_COBRO.CODIGO_COBRO= :KEY_CODIGO_COBRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param name="FECHA_REGISTRO" sqlType="STRING"/>
		<param name="NIT_ANUNCIANTE" sqlType="STRING"/>
		<param name="SUCURSAL_ANUNCIANTE" sqlType="STRING"/>
		<param name="NIT_PROPIETARIO" sqlType="STRING"/>
		<param name="SUCURSAL_PROPIETARIO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="REFERENCIA_OBJCOBRO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="CCOSTO_CONTRATO" sqlType="STRING"/>
		<param name="PERIODOCONTRATO" sqlType="STRING"/>
		<param name="TIPO_ACUERDO" sqlType="STRING"/>
		<param name="NRO_ACUERDO" sqlType="STRING"/>
		<param name="CUOTA_ACUERDO" sqlType="STRING"/>
		<param name="DIFERIDA" sqlType="STRING"/>
		<param name="TIPO_ABONO" sqlType="STRING"/>
		<param name="NRO_ABONO" sqlType="STRING"/>
		<param name="VLR_EFECTIVO" sqlType="STRING"/>
		<param name="VLR_CREDITO" sqlType="STRING"/>
		<param name="CUOTAS_DIFERIDAS" sqlType="STRING"/>
		<param name="VLR_PROM_CUOTA" sqlType="STRING"/>
		<param name="CUENTA_RECAUDO" sqlType="STRING"/>
