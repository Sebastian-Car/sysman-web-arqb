	<query id="getSfobjetoscobroGetfacturasentrefechasconusltainvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_OBJETO_COBRO.COMPANIA, SF_OBJETO_COBRO.TIPOCOBRO, SF_OBJETO_COBRO.NRO_FACTURA, SF_OBJETO_COBRO.CODIGO_COBRO,(CASE SF_OBJETO_COBRO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, SF_OBJETO_COBRO.ANO, SF_OBJETO_COBRO.TERCERO, TO_CHAR(SF_OBJETO_COBRO.FECHA_SOLICITUD, 'yyyy/MM/dd') FECHA_SOLICITUD,(TO_CHAR(SF_OBJETO_COBRO.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, SF_OBJETO_COBRO.VALOR_TOTAL, SF_TIPO_COBRO.REF_FACTURACION FROM SF_OBJETO_COBRO INNER JOIN SF_TIPO_COBRO ON SF_OBJETO_COBRO.COMPANIA = SF_TIPO_COBRO.COMPANIA AND SF_OBJETO_COBRO.ANO = SF_TIPO_COBRO.ANO AND SF_OBJETO_COBRO.TIPOCOBRO = SF_TIPO_COBRO.CODIGO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = :TIPO_COBRO AND TO_CHAR(FECHA_SOLICITUD, 'dd/MM/YYYY') BETWEEN :FECHAINCIO AND :FECHAFIN ORDER BY SF_OBJETO_COBRO.CODIGO_COBRO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOBRO":"$TIPOCOBRO","NRO_FACTURA":"$NRO_FACTURA(type:long)","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","IMPRESO":"$IMPRESO(type:boolean)","ANO":"$ANO(type:integer)","TERCERO":"$TERCERO","FECHA_SOLICITUD":"$FECHA_SOLICITUD","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","VALOR_TOTAL":"$VALOR_TOTAL","REF_FACTURACION":"$REF_FACTURACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_COBRO" sqlType="STRING"/>
		<param name="FECHAINCIO" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/getfacturasentrefechasconusltainvoway">
		<call-query href="getSfobjetoscobroGetfacturasentrefechasconusltainvowayQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_COBRO" query-param="TIPO_COBRO"/>
			<with-param name="FECHAINCIO" query-param="FECHAINCIO"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroPagListarparadevolucionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.VALOR_TOTAL, SF_FACTURA.NIT_TERCEROFACTURADO, SF_FACTURA.NOMBRE_TERCEROFACTURADO,(CASE SF_OBJETO_COBRO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, SF_FACTURA.CODIGO_COBRO,(CASE SF_OBJETO_COBRO.INDPAGO WHEN 0 THEN 'false' ELSE 'true' END) INDPAGO FROM SF_OBJETO_COBRO INNER JOIN SF_FACTURA ON SF_OBJETO_COBRO .COMPANIA = SF_FACTURA.COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = SF_FACTURA.TIPOCOBRO AND SF_OBJETO_COBRO.NRO_FACTURA = SF_FACTURA .NUMERO_FACTURA WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPOCOBRO = :TIPOCOBRO ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN NIT_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NIT_TERCEROFACTURADO) END) LIKE UPPER(CONCAT(:NIT_TERCEROFACTURADO, '%')) AND (CASE WHEN NOMBRE_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCEROFACTURADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCEROFACTURADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","TIPO_FACTURA":"$TIPO_FACTURA","VALOR_TOTAL":"$VALOR_TOTAL","NIT_TERCEROFACTURADO":"$NIT_TERCEROFACTURADO","NOMBRE_TERCEROFACTURADO":"$NOMBRE_TERCEROFACTURADO","IMPRESO":"$IMPRESO(type:boolean)","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","INDPAGO":"$INDPAGO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIT_TERCEROFACTURADO" sqlType="STRING"/>
		<param name="NOMBRE_TERCEROFACTURADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
