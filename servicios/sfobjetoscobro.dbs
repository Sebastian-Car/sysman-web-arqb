	<query id="getSfobjetoscobroNumInfFacturaPorCompaniaYTipoCobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.VALOR_TOTAL, SF_FACTURA.NIT_TERCEROFACTURADO, SF_FACTURA.NOMBRE_TERCEROFACTURADO,(CASE SF_OBJETO_COBRO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, SF_FACTURA.CODIGO_COBRO  FROM SF_OBJETO_COBRO INNER JOIN SF_FACTURA ON SF_OBJETO_COBRO.COMPANIA = SF_FACTURA.COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = SF_FACTURA.TIPOCOBRO AND SF_OBJETO_COBRO.NRO_FACTURA = SF_FACTURA.NUMERO_FACTURA WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPOCOBRO = :TIPOCOBRO ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN NIT_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NIT_TERCEROFACTURADO) END)  LIKE UPPER(:NIT_TERCEROFACTURADO || '%')  AND (CASE WHEN NOMBRE_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCEROFACTURADO) END)  LIKE UPPER( '%' || :NOMBRE_TERCEROFACTURADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIT_TERCEROFACTURADO" sqlType="STRING"/>
		<param name="NOMBRE_TERCEROFACTURADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/inffacturaporcompaniaytipocobro/num">
		<call-query href="getSfobjetoscobroNumInfFacturaPorCompaniaYTipoCobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
