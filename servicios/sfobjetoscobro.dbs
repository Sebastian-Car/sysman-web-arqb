<data name="sfobjetoscobro" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfobjetoscobroPagFacturasYTiposInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SF_OBJETO_COBRO.NRO_FACTURA , SF_OBJETO_COBRO.TIPOFACTURA  FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.NRO_FACTURA NOT IN(0) ORDER BY SF_OBJETO_COBRO.NRO_FACTURA) WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END)  LIKE UPPER(:NRO_FACTURA || '%')  AND (CASE WHEN TIPOFACTURA IS NULL THEN ' ' ELSE UPPER(TIPOFACTURA) END)  LIKE UPPER( '%' || :TIPOFACTURA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_FACTURA":"$NRO_FACTURA(type:long)","TIPOFACTURA":"$TIPOFACTURA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/facturasytiposinicial/pag">
		<call-query href="getSfobjetoscobroPagFacturasYTiposInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_FACTURA" query-param="NRO_FACTURA"/>
			<with-param name="TIPOFACTURA" query-param="TIPOFACTURA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroNumFacturasYTiposInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SF_OBJETO_COBRO.NRO_FACTURA , SF_OBJETO_COBRO.TIPOFACTURA  FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.NRO_FACTURA NOT IN(0) ORDER BY SF_OBJETO_COBRO.NRO_FACTURA) WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END)  LIKE UPPER(:NRO_FACTURA || '%')  AND (CASE WHEN TIPOFACTURA IS NULL THEN ' ' ELSE UPPER(TIPOFACTURA) END)  LIKE UPPER( '%' || :TIPOFACTURA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/facturasytiposinicial/num">
		<call-query href="getSfobjetoscobroNumFacturasYTiposInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_FACTURA" query-param="NRO_FACTURA"/>
			<with-param name="TIPOFACTURA" query-param="TIPOFACTURA"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroPagFacturasYTiposFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SF_OBJETO_COBRO.NRO_FACTURA , SF_OBJETO_COBRO.TIPOFACTURA  FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.NRO_FACTURA NOT IN(0) AND SF_OBJETO_COBRO.NRO_FACTURA &gt;= :FACTURAINICIAL ORDER BY SF_OBJETO_COBRO.NRO_FACTURA) WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END)  LIKE UPPER(:NRO_FACTURA || '%')  AND (CASE WHEN TIPOFACTURA IS NULL THEN ' ' ELSE UPPER(TIPOFACTURA) END)  LIKE UPPER( '%' || :TIPOFACTURA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_FACTURA":"$NRO_FACTURA(type:long)","TIPOFACTURA":"$TIPOFACTURA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FACTURAINICIAL" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
