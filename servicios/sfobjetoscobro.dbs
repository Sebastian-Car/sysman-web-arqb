			<with-param name="NOMBRE_TERCEROFACTURADO" query-param="NOMBRE_TERCEROFACTURADO"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroRangoFacturasContratosQuery"  useConfig="sysmandsunist">
		<sql>SELECT MAX(NRO_FACTURA) FACTURAFINAL, MIN(NRO_FACTURA) FACTURAINICIAL FROM SF_OBJETO_COBRO WHERE COMPANIA =:COMPANIA AND TIPOCONTRATO =:TIPOCOBRO AND CONTRATO BETWEEN :CONTRATOINICIAL AND :CONTRATOFINAL HAVING MAX(NRO_FACTURA) IS NOT NULL AND MIN(NRO_FACTURA) IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FACTURAFINAL":"$FACTURAFINAL(type:integer)","FACTURAINICIAL":"$FACTURAINICIAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONTRATOINICIAL" sqlType="STRING"/>
		<param name="CONTRATOFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/rangofacturascontratos">
		<call-query href="getSfobjetoscobroRangoFacturasContratosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONTRATOINICIAL" query-param="CONTRATOINICIAL"/>
			<with-param name="CONTRATOFINAL" query-param="CONTRATOFINAL"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroIndicadorFacQuery"  useConfig="sysmandsunist">
		<sql>SELECT INDICADORFAC FROM SF_OBJETO_COBRO WHERE CODIGO_COBRO =:NUMERO AND INDICADORFAC IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"INDICADORFAC":"$INDICADORFAC"}]}}		</result>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
