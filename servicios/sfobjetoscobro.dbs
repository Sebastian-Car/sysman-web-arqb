			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="NIT_TERCEROFACTURADO" query-param="NIT_TERCEROFACTURADO"/>
			<with-param name="NOMBRE_TERCEROFACTURADO" query-param="NOMBRE_TERCEROFACTURADO"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroGetobjetocobrosinfacturarinmueblesQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT SF_OBJETO_COBRO.CODIGO_COBRO, SF_OBJETO_COBRO.TIPOCOBRO FROM SF_OBJETO_COBRO INNER JOIN SF_CONTRATOS ON ( SF_OBJETO_COBRO.COMPANIA = SF_CONTRATOS.COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = SF_CONTRATOS.TIPO AND SF_OBJETO_COBRO.TXTCONTRATO = SF_CONTRATOS.NUMERO ) INNER JOIN SF_DETALLE_CONTRATO ON ( SF_DETALLE_CONTRATO.COMPANIA = SF_CONTRATOS.COMPANIA AND SF_DETALLE_CONTRATO.TIPO = SF_CONTRATOS.TIPO AND SF_DETALLE_CONTRATO.NUMERO = SF_CONTRATOS.NUMERO ) WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = :TIPOCOBRO AND ( SF_OBJETO_COBRO.NRO_FACTURA NOT IN ( 0 ) OR SF_OBJETO_COBRO.NRO_FACTURA IS NULL ) AND SF_OBJETO_COBRO.IMPRESO IN (0) AND SF_OBJETO_COBRO.ANO = :ANO AND SF_DETALLE_CONTRATO.INMUEBLE BETWEEN :INMUEBLEINCIAL AND :INMUEBLEFINAL ORDER BY SF_OBJETO_COBRO.CODIGO_COBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_COBRO":"$CODIGO_COBRO(type:long)","TIPOCOBRO":"$TIPOCOBRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="INMUEBLEINCIAL" sqlType="STRING"/>
		<param name="INMUEBLEFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/getobjetocobrosinfacturarinmuebles">
		<call-query href="getSfobjetoscobroGetobjetocobrosinfacturarinmueblesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="INMUEBLEINCIAL" query-param="INMUEBLEINCIAL"/>
			<with-param name="INMUEBLEFINAL" query-param="INMUEBLEFINAL"/>

		</call-query>
	</resource>
	<query id="updateSfobjetoscobroUpdateobjetocobroalternoconvalortotal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_OBJETO_COBRO SET VALOR_TOTAL=:VALOR_TOTAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_OBJETO_COBRO.COMPANIA= :KEY_COMPANIA AND SF_OBJETO_COBRO.ANO= :KEY_ANO AND SF_OBJETO_COBRO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_OBJETO_COBRO.CODIGO_COBRO= :KEY_CODIGO_COBRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO_COBRO" sqlType="STRING"/>

	</query>
