		<result outputType="json">{"elementos":{"elemento":[{"NRO_FACTURA":"$NRO_FACTURA(type:long)","TERCERO":"$TERCERO","FECHA_REGISTRO":"$FECHA_REGISTRO"}]}}		</result>
