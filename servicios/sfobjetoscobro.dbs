	<query id="getSfobjetoscobroPagFacturaYTerceroInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SF_OBJETO_COBRO.NRO_FACTURA , SF_OBJETO_COBRO.TERCERO,(TO_CHAR(SF_OBJETO_COBRO.FECHA_REGISTRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_REGISTRO FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.NRO_FACTURA NOT IN(0) ORDER BY SF_OBJETO_COBRO.NRO_FACTURA) WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END)  LIKE UPPER(:NRO_FACTURA || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER( '%' || :TERCERO || '%')  AND (CASE WHEN FECHA_REGISTRO IS NULL THEN ' ' ELSE UPPER(FECHA_REGISTRO) END)  LIKE UPPER( '%' || :FECHA_REGISTRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_FACTURA":"$NRO_FACTURA(type:long)","TERCERO":"$TERCERO","FECHA_REGISTRO":"$FECHA_REGISTRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHA_REGISTRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
