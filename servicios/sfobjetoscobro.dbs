	<query id="deleteSfobjetoscobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA= :KEY_COMPANIA AND SF_OBJETO_COBRO.ANO= :KEY_ANO AND SF_OBJETO_COBRO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_OBJETO_COBRO.CODIGO_COBRO= :KEY_CODIGO_COBRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CODIGO_COBRO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfobjetoscobro">
		<call-query href="deleteSfobjetoscobro">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CODIGO_COBRO" query-param="KEY_CODIGO_COBRO"/>

		</call-query>
	</resource>
	<query id="getSfobjetoscobroPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, TIPOCOBRO, NRO_FACTURA, CODIGO_COBRO,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, ANO, TERCERO,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD,(TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, VALOR_TOTAL FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = :TIPO_COBRO AND EXTRACT ( YEAR FROM FECHA_SOLICITUD) = :ANIO ORDER BY SF_OBJETO_COBRO.CODIGO_COBRO DESC) INI WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END) LIKE UPPER(CONCAT(:NRO_FACTURA, '%')) AND (CASE WHEN CODIGO_COBRO IS NULL THEN ' ' ELSE UPPER(CODIGO_COBRO) END) LIKE UPPER(CONCAT(:CODIGO_COBRO, '%')) AND (CASE WHEN IMPRESO IS NULL THEN ' ' ELSE UPPER(IMPRESO) END) LIKE UPPER(CONCAT(:IMPRESO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN FECHA_SOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHA_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_SOLICITUD), '%')) AND (CASE WHEN FECHA_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHA_VENCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_VENCIMIENTO), '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOBRO":"$TIPOCOBRO","NRO_FACTURA":"$NRO_FACTURA(type:long)","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","IMPRESO":"$IMPRESO(type:boolean)","ANO":"$ANO(type:integer)","TERCERO":"$TERCERO","FECHA_SOLICITUD":"$FECHA_SOLICITUD","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","VALOR_TOTAL":"$VALOR_TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_COBRO" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="CODIGO_COBRO" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param name="FECHA_VENCIMIENTO" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfobjetoscobro">
		<call-query href="getSfobjetoscobroPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
