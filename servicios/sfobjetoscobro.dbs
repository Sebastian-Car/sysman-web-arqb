	<query id="getSfobjetoscobroNumFacturaYTerceroFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SF_OBJETO_COBRO.NRO_FACTURA , SF_OBJETO_COBRO.TERCERO,(TO_CHAR(SF_OBJETO_COBRO.FECHA_REGISTRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_REGISTRO FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.NRO_FACTURA NOT IN(0) AND SF_OBJETO_COBRO.NRO_FACTURA &gt;= :FACTURAINICIAL ORDER BY SF_OBJETO_COBRO.NRO_FACTURA) WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END)  LIKE UPPER(:NRO_FACTURA || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER( '%' || :TERCERO || '%')  AND (CASE WHEN FECHA_REGISTRO IS NULL THEN ' ' ELSE UPPER(FECHA_REGISTRO) END)  LIKE UPPER( '%' || :FECHA_REGISTRO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
