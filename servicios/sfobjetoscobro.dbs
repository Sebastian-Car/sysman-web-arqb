	<query id="getSfobjetoscobroPagInfFacturaPorCompaniaYTipoCobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.VALOR_TOTAL, SF_FACTURA.NIT_TERCEROFACTURADO, SF_FACTURA.NOMBRE_TERCEROFACTURADO,(CASE SF_OBJETO_COBRO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, SF_FACTURA.CODIGO_COBRO  FROM SF_OBJETO_COBRO INNER JOIN SF_FACTURA ON SF_OBJETO_COBRO.COMPANIA = SF_FACTURA.COMPANIA AND SF_OBJETO_COBRO.TIPOCOBRO = SF_FACTURA.TIPOCOBRO AND SF_OBJETO_COBRO.NRO_FACTURA = SF_FACTURA.NUMERO_FACTURA WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPOCOBRO = :TIPOCOBRO ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN NIT_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NIT_TERCEROFACTURADO) END)  LIKE UPPER(:NIT_TERCEROFACTURADO || '%')  AND (CASE WHEN NOMBRE_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCEROFACTURADO) END)  LIKE UPPER( '%' || :NOMBRE_TERCEROFACTURADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","TIPO_FACTURA":"$TIPO_FACTURA","VALOR_TOTAL":"$VALOR_TOTAL","NIT_TERCEROFACTURADO":"$NIT_TERCEROFACTURADO","NOMBRE_TERCEROFACTURADO":"$NOMBRE_TERCEROFACTURADO","IMPRESO":"$IMPRESO(type:boolean)","CODIGO_COBRO":"$CODIGO_COBRO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIT_TERCEROFACTURADO" sqlType="STRING"/>
		<param name="NOMBRE_TERCEROFACTURADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfobjetoscobro/inffacturaporcompaniaytipocobro/pag">
		<call-query href="getSfobjetoscobroPagInfFacturaPorCompaniaYTipoCobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="NIT_TERCEROFACTURADO" query-param="NIT_TERCEROFACTURADO"/>
			<with-param name="NOMBRE_TERCEROFACTURADO" query-param="NOMBRE_TERCEROFACTURADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertSfobjetoscobro" keyColumns="COMPANIA,ANO,TIPOCOBRO,CODIGO_COBRO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_OBJETO_COBRO (COMPANIA, ANO, TIPOCOBRO, CODIGO_COBRO, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, FECHA_SOLICITUD, FECHA_REGISTRO, NIT_ANUNCIANTE, SUCURSAL_ANUNCIANTE, NIT_PROPIETARIO, SUCURSAL_PROPIETARIO, VALOR_TOTAL, OBSERVACIONES, REFERENCIA_OBJCOBRO, ESTRATO, TIPOFACTURA, NRO_FACTURA, IMPRESO, TIPOCONTRATO, CONTRATO, CCOSTO_CONTRATO, PERIODOCONTRATO, TIPO_ACUERDO, NRO_ACUERDO, CUOTA_ACUERDO, DIFERIDA, TIPO_ABONO, NRO_ABONO, VLR_EFECTIVO, VLR_CREDITO, CUOTAS_DIFERIDAS, VLR_PROM_CUOTA, CUENTA_RECAUDO, TIPOCPTE_RECAUDO, NIT_TERCEROFACTURADO, SUCURSAL_TERCEROFACTURADO, NOMBRE_TERCEROFACTURADO, FORMULARIO_DELURBANA, TASA_INTERES, DIRECCION, CODIGOPOSTAL, GRUPO_CONCEPTOS, TOTAL_GRUPO, CANTIDAD_GRUPO, FECHA_VENCIMIENTO, CPTE_CTBLE, NROCPTE_CTBLE, BASEORIGINAL, INDREVERSO, TELEFONOS, INDPAGO, NUMERO_LIQUIDACION, FECHA_PRELIQUIDACION, CREATED_BY, DATE_CREATED, COD_DESCRIPCION, COD_TARIFABASE, BASE_FIJA_ANT, FUENTE_RECURSO, TIPO_MEDIOPAGO, TIPO_PAGO, AJUSTE, REF_FACTURACION, FACTURA_DOLARES, TRM_DOLARES_FAC, TRM_DOLARES_REC, VALOR_TOTAL_DOLARES, TXTCONTRATO, DESCRIPCION_TIPOPAGO, TXTPREFIJO, NROCONTRATOSIGEC, TIPOCONTRATOSIGEC, APLICA_DSCTO, FECHAVENCIDSCTO) VALUES (:COMPANIA, :ANO, :TIPOCOBRO, :CODIGO_COBRO, :TERCERO, :SUCURSAL, :CENTRO_COSTO, :AUXILIAR, TO_DATE(:FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_REGISTRO,'DD/MM/YYYY HH24:MI:SS'), :NIT_ANUNCIANTE, :SUCURSAL_ANUNCIANTE, :NIT_PROPIETARIO, :SUCURSAL_PROPIETARIO, :VALOR_TOTAL, :OBSERVACIONES, :REFERENCIA_OBJCOBRO, :ESTRATO, :TIPOFACTURA, :NRO_FACTURA, :IMPRESO, :TIPOCONTRATO, :CONTRATO, :CCOSTO_CONTRATO, :PERIODOCONTRATO, :TIPO_ACUERDO, :NRO_ACUERDO, :CUOTA_ACUERDO, :DIFERIDA, :TIPO_ABONO, :NRO_ABONO, :VLR_EFECTIVO, :VLR_CREDITO, :CUOTAS_DIFERIDAS, :VLR_PROM_CUOTA, :CUENTA_RECAUDO, :TIPOCPTE_RECAUDO, :NIT_TERCEROFACTURADO, :SUCURSAL_TERCEROFACTURADO, :NOMBRE_TERCEROFACTURADO, :FORMULARIO_DELURBANA, :TASA_INTERES, :DIRECCION, :CODIGOPOSTAL, :GRUPO_CONCEPTOS, :TOTAL_GRUPO, :CANTIDAD_GRUPO, TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :CPTE_CTBLE, :NROCPTE_CTBLE, :BASEORIGINAL, :INDREVERSO, :TELEFONOS, :INDPAGO, :NUMERO_LIQUIDACION, TO_DATE(:FECHA_PRELIQUIDACION,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :COD_DESCRIPCION, :COD_TARIFABASE, :BASE_FIJA_ANT, :FUENTE_RECURSO, :TIPO_MEDIOPAGO, :TIPO_PAGO, :AJUSTE, :REF_FACTURACION, :FACTURA_DOLARES, :TRM_DOLARES_FAC, :TRM_DOLARES_REC, :VALOR_TOTAL_DOLARES, :TXTCONTRATO, :DESCRIPCION_TIPOPAGO, :TXTPREFIJO, :NROCONTRATOSIGEC, :TIPOCONTRATOSIGEC, :APLICA_DSCTO, TO_DATE(:FECHAVENCIDSCTO,'DD/MM/YYYY HH24:MI:SS'))</sql>
