		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SF_OBJETO_COBRO.NRO_FACTURA , SF_OBJETO_COBRO.TIPOFACTURA  FROM SF_OBJETO_COBRO WHERE SF_OBJETO_COBRO.COMPANIA = :COMPANIA AND SF_OBJETO_COBRO.NRO_FACTURA NOT IN(0) AND SF_OBJETO_COBRO.NRO_FACTURA &gt;= :FACTURAINICIAL ORDER BY SF_OBJETO_COBRO.NRO_FACTURA) WHERE (CASE WHEN NRO_FACTURA IS NULL THEN ' ' ELSE UPPER(NRO_FACTURA) END)  LIKE UPPER(:NRO_FACTURA || '%')  AND (CASE WHEN TIPOFACTURA IS NULL THEN ' ' ELSE UPPER(TIPOFACTURA) END)  LIKE UPPER( '%' || :TIPOFACTURA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FACTURAINICIAL" sqlType="STRING"/>
		<param name="NRO_FACTURA" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>

	</query>
