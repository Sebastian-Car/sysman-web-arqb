<data name="autoserconsultas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getAutoserconsultasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, REPORTE, CONSULTA, NOMBRE_PLANTILLA, CODIGO_PLANTILLA  FROM AUTOSER_CONSULTAS ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN REPORTE IS NULL THEN ' ' ELSE UPPER(REPORTE) END)  LIKE UPPER( '%' || :REPORTE || '%')  AND (CASE WHEN NOMBRE_PLANTILLA IS NULL THEN ' ' ELSE UPPER(NOMBRE_PLANTILLA) END)  LIKE UPPER( '%' || :NOMBRE_PLANTILLA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","REPORTE":"$REPORTE","CONSULTA":"$CONSULTA","NOMBRE_PLANTILLA":"$NOMBRE_PLANTILLA","CODIGO_PLANTILLA":"$CODIGO_PLANTILLA"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_PLANTILLA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="autoserconsultas">
		<call-query href="getAutoserconsultasPaginaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="REPORTE" query-param="REPORTE"/>
			<with-param name="NOMBRE_PLANTILLA" query-param="NOMBRE_PLANTILLA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAutoserconsultasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, REPORTE, CONSULTA, NOMBRE_PLANTILLA, CODIGO_PLANTILLA  FROM AUTOSER_CONSULTAS ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN REPORTE IS NULL THEN ' ' ELSE UPPER(REPORTE) END)  LIKE UPPER( '%' || :REPORTE || '%')  AND (CASE WHEN NOMBRE_PLANTILLA IS NULL THEN ' ' ELSE UPPER(NOMBRE_PLANTILLA) END)  LIKE UPPER( '%' || :NOMBRE_PLANTILLA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="REPORTE" sqlType="STRING"/>
		<param name="NOMBRE_PLANTILLA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="autoserconsultas/numero">
		<call-query href="getAutoserconsultasNumeroQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="REPORTE" query-param="REPORTE"/>
			<with-param name="NOMBRE_PLANTILLA" query-param="NOMBRE_PLANTILLA"/>

		</call-query>
	</resource>

</data>