<data name="propuesta" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPropuestaContarProponenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM PROPUESTA WHERE COMPANIA = :COMPANIA AND NIT = :NIT AND COD_REQUISICION = :COD_REQUISICION</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="propuesta/contarproponente">
		<call-query href="getPropuestaContarProponenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>

		</call-query>
	</resource>
	<query id="insertPropuesta" keyColumns="COD_PROPUESTA,COD_REQUISICION,COMPANIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PROPUESTA (VALORDESCUENTO, CREATED_BY, COMPANIA, VALORTOTAL, COD_PROPUESTA, FECHA_ENTREGA, HORA_ENTREGA, DATE_CREATED, COD_REQUISICION, LUGARDEENTREGA, FORMADEPAGO, PLAZOENTREGA, VALORIVA, NIT, SUCURSAL) VALUES (:VALORDESCUENTO, :CREATED_BY, :COMPANIA, :VALORTOTAL, :COD_PROPUESTA, TO_DATE(:FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_ENTREGA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :COD_REQUISICION, :LUGARDEENTREGA, :FORMADEPAGO, :PLAZOENTREGA, :VALORIVA, :NIT, :SUCURSAL)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COD_PROPUESTA":"$COD_PROPUESTA(type:long)","KEY_COD_REQUISICION":"$COD_REQUISICION(type:long)","KEY_COMPANIA":"$COMPANIA"}]}}		</result>
		<param defaultValue="0" name="VALORDESCUENTO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param name="COD_PROPUESTA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ENTREGA" sqlType="STRING"/>
		<param defaultValue="" name="HORA_ENTREGA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param defaultValue="" name="LUGARDEENTREGA" sqlType="STRING"/>
		<param defaultValue="" name="FORMADEPAGO" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZOENTREGA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORIVA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="POST" path="propuesta">
		<call-query href="insertPropuesta">
			<with-param name="VALORDESCUENTO" query-param="VALORDESCUENTO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="COD_PROPUESTA" query-param="COD_PROPUESTA"/>
			<with-param name="FECHA_ENTREGA" query-param="FECHA_ENTREGA"/>
			<with-param name="HORA_ENTREGA" query-param="HORA_ENTREGA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="LUGARDEENTREGA" query-param="LUGARDEENTREGA"/>
			<with-param name="FORMADEPAGO" query-param="FORMADEPAGO"/>
			<with-param name="PLAZOENTREGA" query-param="PLAZOENTREGA"/>
			<with-param name="VALORIVA" query-param="VALORIVA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="deletePropuesta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PROPUESTA WHERE PROPUESTA.COD_PROPUESTA= :KEY_COD_PROPUESTA AND PROPUESTA.COD_REQUISICION= :KEY_COD_REQUISICION AND PROPUESTA.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COD_PROPUESTA" sqlType="STRING"/>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="propuesta">
		<call-query href="deletePropuesta">
			<with-param name="KEY_COD_PROPUESTA" query-param="KEY_COD_PROPUESTA"/>
			<with-param name="KEY_COD_REQUISICION" query-param="KEY_COD_REQUISICION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPropuestaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PROPUESTA.COMPANIA, PROPUESTA.COD_PROPUESTA, PROPUESTA.COD_REQUISICION, PROPUESTA.NIT, PROPUESTA.SUCURSAL, TO_CHAR(PROPUESTA.FECHA_ENTREGA,'dd/MM/yyyy') FECHA_ENTREGALV,(TO_CHAR(PROPUESTA.FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENTREGA,(TO_CHAR(PROPUESTA.HORA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) HORA_ENTREGA,(TO_CHAR(PROPUESTA.HORA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) HORA_ENTREGALV, PROPUESTA.VALORIVA, PROPUESTA.VALORDESCUENTO, PROPUESTA.VALORTOTAL, PROPUESTA.PLAZOENTREGA, PROPUESTA.PORCDESCUENTO, PROPUESTA.PUNTAJE_TOTAL, PROPUESTA.SUBTOTAL,(CASE PROPUESTA.ACEPTACION WHEN 0 THEN 'false' ELSE 'true' END) ACEPTACION, PROPUESTA.NUMDOCUMENTO,(CASE PROPUESTA.RESPONDIO WHEN 0 THEN 'false' ELSE 'true' END) RESPONDIO, PROPUESTA.FORMADEPAGO, PROPUESTA.LUGARDEENTREGA, PROPUESTA.CREATED_BY,(TO_CHAR(PROPUESTA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, PROPUESTA.MODIFIED_BY,(TO_CHAR(PROPUESTA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PROPUESTA INNER JOIN TERCERO ON propuesta.COMPANIA = TERCERO.COMPANIA AND PROPUESTA.SUCURSAL = TERCERO.SUCURSAL AND PROPUESTA.NIT = TERCERO.NIT WHERE PROPUESTA.COMPANIA =:COMPANIA AND PROPUESTA.COD_REQUISICION =:COD_REQUISICION) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN COD_PROPUESTA IS NULL THEN ' ' ELSE UPPER(COD_PROPUESTA) END)  LIKE UPPER(:COD_PROPUESTA || '%')  AND (CASE WHEN COD_REQUISICION IS NULL THEN ' ' ELSE UPPER(COD_REQUISICION) END)  LIKE UPPER(:COD_REQUISICION || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN FECHA_ENTREGALV IS NULL THEN ' ' ELSE UPPER(FECHA_ENTREGALV) END)  LIKE UPPER(:FECHA_ENTREGALV || '%')  AND (CASE WHEN FECHA_ENTREGA IS NULL THEN ' ' ELSE UPPER(FECHA_ENTREGA) END)  LIKE UPPER(:FECHA_ENTREGA || '%')  AND (CASE WHEN HORA_ENTREGA IS NULL THEN ' ' ELSE UPPER(HORA_ENTREGA) END)  LIKE UPPER(:HORA_ENTREGA || '%')  AND (CASE WHEN HORA_ENTREGALV IS NULL THEN ' ' ELSE UPPER(HORA_ENTREGALV) END)  LIKE UPPER(:HORA_ENTREGALV || '%')  AND (CASE WHEN VALORIVA IS NULL THEN ' ' ELSE UPPER(VALORIVA) END)  LIKE UPPER(:VALORIVA || '%')  AND (CASE WHEN VALORDESCUENTO IS NULL THEN ' ' ELSE UPPER(VALORDESCUENTO) END)  LIKE UPPER(:VALORDESCUENTO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%')  AND (CASE WHEN PLAZOENTREGA IS NULL THEN ' ' ELSE UPPER(PLAZOENTREGA) END)  LIKE UPPER(:PLAZOENTREGA || '%')  AND (CASE WHEN PORCDESCUENTO IS NULL THEN ' ' ELSE UPPER(PORCDESCUENTO) END)  LIKE UPPER(:PORCDESCUENTO || '%')  AND (CASE WHEN PUNTAJE_TOTAL IS NULL THEN ' ' ELSE UPPER(PUNTAJE_TOTAL) END)  LIKE UPPER(:PUNTAJE_TOTAL || '%')  AND (CASE WHEN SUBTOTAL IS NULL THEN ' ' ELSE UPPER(SUBTOTAL) END)  LIKE UPPER(:SUBTOTAL || '%')  AND (CASE WHEN ACEPTACION IS NULL THEN ' ' ELSE UPPER(ACEPTACION) END)  LIKE UPPER(:ACEPTACION || '%')  AND (CASE WHEN NUMDOCUMENTO IS NULL THEN ' ' ELSE UPPER(NUMDOCUMENTO) END)  LIKE UPPER(:NUMDOCUMENTO || '%')  AND (CASE WHEN RESPONDIO IS NULL THEN ' ' ELSE UPPER(RESPONDIO) END)  LIKE UPPER(:RESPONDIO || '%')  AND (CASE WHEN FORMADEPAGO IS NULL THEN ' ' ELSE UPPER(FORMADEPAGO) END)  LIKE UPPER( '%' || :FORMADEPAGO || '%')  AND (CASE WHEN LUGARDEENTREGA IS NULL THEN ' ' ELSE UPPER(LUGARDEENTREGA) END)  LIKE UPPER( '%' || :LUGARDEENTREGA || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER(:CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER(:DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER(:MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER(:DATE_MODIFIED || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PROPUESTA":"$COD_PROPUESTA(type:long)","COD_REQUISICION":"$COD_REQUISICION(type:long)","NIT":"$NIT","SUCURSAL":"$SUCURSAL","FECHA_ENTREGALV":"$FECHA_ENTREGALV","FECHA_ENTREGA":"$FECHA_ENTREGA","HORA_ENTREGA":"$HORA_ENTREGA","HORA_ENTREGALV":"$HORA_ENTREGALV","VALORIVA":"$VALORIVA","VALORDESCUENTO":"$VALORDESCUENTO","VALORTOTAL":"$VALORTOTAL","PLAZOENTREGA":"$PLAZOENTREGA","PORCDESCUENTO":"$PORCDESCUENTO","PUNTAJE_TOTAL":"$PUNTAJE_TOTAL","SUBTOTAL":"$SUBTOTAL","ACEPTACION":"$ACEPTACION(type:boolean)","NUMDOCUMENTO":"$NUMDOCUMENTO","RESPONDIO":"$RESPONDIO(type:boolean)","FORMADEPAGO":"$FORMADEPAGO","LUGARDEENTREGA":"$LUGARDEENTREGA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="COD_PROPUESTA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA_ENTREGALV" sqlType="STRING"/>
		<param name="FECHA_ENTREGA" sqlType="STRING"/>
		<param name="HORA_ENTREGA" sqlType="STRING"/>
		<param name="HORA_ENTREGALV" sqlType="STRING"/>
		<param name="VALORIVA" sqlType="STRING"/>
		<param name="VALORDESCUENTO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PLAZOENTREGA" sqlType="STRING"/>
		<param name="PORCDESCUENTO" sqlType="STRING"/>
		<param name="PUNTAJE_TOTAL" sqlType="STRING"/>
		<param name="SUBTOTAL" sqlType="STRING"/>
		<param name="ACEPTACION" sqlType="STRING"/>
		<param name="NUMDOCUMENTO" sqlType="STRING"/>
		<param name="RESPONDIO" sqlType="STRING"/>
		<param name="FORMADEPAGO" sqlType="STRING"/>
		<param name="LUGARDEENTREGA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="propuesta">
		<call-query href="getPropuestaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="COD_PROPUESTA" query-param="COD_PROPUESTA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHA_ENTREGALV" query-param="FECHA_ENTREGALV"/>
			<with-param name="FECHA_ENTREGA" query-param="FECHA_ENTREGA"/>
			<with-param name="HORA_ENTREGA" query-param="HORA_ENTREGA"/>
			<with-param name="HORA_ENTREGALV" query-param="HORA_ENTREGALV"/>
			<with-param name="VALORIVA" query-param="VALORIVA"/>
			<with-param name="VALORDESCUENTO" query-param="VALORDESCUENTO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PLAZOENTREGA" query-param="PLAZOENTREGA"/>
			<with-param name="PORCDESCUENTO" query-param="PORCDESCUENTO"/>
			<with-param name="PUNTAJE_TOTAL" query-param="PUNTAJE_TOTAL"/>
			<with-param name="SUBTOTAL" query-param="SUBTOTAL"/>
			<with-param name="ACEPTACION" query-param="ACEPTACION"/>
			<with-param name="NUMDOCUMENTO" query-param="NUMDOCUMENTO"/>
			<with-param name="RESPONDIO" query-param="RESPONDIO"/>
			<with-param name="FORMADEPAGO" query-param="FORMADEPAGO"/>
			<with-param name="LUGARDEENTREGA" query-param="LUGARDEENTREGA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPropuestaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PROPUESTA.COMPANIA, PROPUESTA.COD_PROPUESTA, PROPUESTA.COD_REQUISICION, PROPUESTA.NIT, PROPUESTA.SUCURSAL, TO_CHAR(PROPUESTA.FECHA_ENTREGA,'dd/MM/yyyy') FECHA_ENTREGALV,(TO_CHAR(PROPUESTA.FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENTREGA,(TO_CHAR(PROPUESTA.HORA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) HORA_ENTREGA,(TO_CHAR(PROPUESTA.HORA_ENTREGA,'DD/MM/YYYY HH24:MI:SS')) HORA_ENTREGALV, PROPUESTA.VALORIVA, PROPUESTA.VALORDESCUENTO, PROPUESTA.VALORTOTAL, PROPUESTA.PLAZOENTREGA, PROPUESTA.PORCDESCUENTO, PROPUESTA.PUNTAJE_TOTAL, PROPUESTA.SUBTOTAL,(CASE PROPUESTA.ACEPTACION WHEN 0 THEN 'false' ELSE 'true' END) ACEPTACION, PROPUESTA.NUMDOCUMENTO,(CASE PROPUESTA.RESPONDIO WHEN 0 THEN 'false' ELSE 'true' END) RESPONDIO, PROPUESTA.FORMADEPAGO, PROPUESTA.LUGARDEENTREGA, PROPUESTA.CREATED_BY,(TO_CHAR(PROPUESTA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, PROPUESTA.MODIFIED_BY,(TO_CHAR(PROPUESTA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PROPUESTA INNER JOIN TERCERO ON propuesta.COMPANIA = TERCERO.COMPANIA AND PROPUESTA.SUCURSAL = TERCERO.SUCURSAL AND PROPUESTA.NIT = TERCERO.NIT WHERE PROPUESTA.COMPANIA =:COMPANIA AND PROPUESTA.COD_REQUISICION =:COD_REQUISICION) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN COD_PROPUESTA IS NULL THEN ' ' ELSE UPPER(COD_PROPUESTA) END)  LIKE UPPER(:COD_PROPUESTA || '%')  AND (CASE WHEN COD_REQUISICION IS NULL THEN ' ' ELSE UPPER(COD_REQUISICION) END)  LIKE UPPER(:COD_REQUISICION || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN FECHA_ENTREGALV IS NULL THEN ' ' ELSE UPPER(FECHA_ENTREGALV) END)  LIKE UPPER(:FECHA_ENTREGALV || '%')  AND (CASE WHEN FECHA_ENTREGA IS NULL THEN ' ' ELSE UPPER(FECHA_ENTREGA) END)  LIKE UPPER(:FECHA_ENTREGA || '%')  AND (CASE WHEN HORA_ENTREGA IS NULL THEN ' ' ELSE UPPER(HORA_ENTREGA) END)  LIKE UPPER(:HORA_ENTREGA || '%')  AND (CASE WHEN HORA_ENTREGALV IS NULL THEN ' ' ELSE UPPER(HORA_ENTREGALV) END)  LIKE UPPER(:HORA_ENTREGALV || '%')  AND (CASE WHEN VALORIVA IS NULL THEN ' ' ELSE UPPER(VALORIVA) END)  LIKE UPPER(:VALORIVA || '%')  AND (CASE WHEN VALORDESCUENTO IS NULL THEN ' ' ELSE UPPER(VALORDESCUENTO) END)  LIKE UPPER(:VALORDESCUENTO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%')  AND (CASE WHEN PLAZOENTREGA IS NULL THEN ' ' ELSE UPPER(PLAZOENTREGA) END)  LIKE UPPER(:PLAZOENTREGA || '%')  AND (CASE WHEN PORCDESCUENTO IS NULL THEN ' ' ELSE UPPER(PORCDESCUENTO) END)  LIKE UPPER(:PORCDESCUENTO || '%')  AND (CASE WHEN PUNTAJE_TOTAL IS NULL THEN ' ' ELSE UPPER(PUNTAJE_TOTAL) END)  LIKE UPPER(:PUNTAJE_TOTAL || '%')  AND (CASE WHEN SUBTOTAL IS NULL THEN ' ' ELSE UPPER(SUBTOTAL) END)  LIKE UPPER(:SUBTOTAL || '%')  AND (CASE WHEN ACEPTACION IS NULL THEN ' ' ELSE UPPER(ACEPTACION) END)  LIKE UPPER(:ACEPTACION || '%')  AND (CASE WHEN NUMDOCUMENTO IS NULL THEN ' ' ELSE UPPER(NUMDOCUMENTO) END)  LIKE UPPER(:NUMDOCUMENTO || '%')  AND (CASE WHEN RESPONDIO IS NULL THEN ' ' ELSE UPPER(RESPONDIO) END)  LIKE UPPER(:RESPONDIO || '%')  AND (CASE WHEN FORMADEPAGO IS NULL THEN ' ' ELSE UPPER(FORMADEPAGO) END)  LIKE UPPER( '%' || :FORMADEPAGO || '%')  AND (CASE WHEN LUGARDEENTREGA IS NULL THEN ' ' ELSE UPPER(LUGARDEENTREGA) END)  LIKE UPPER( '%' || :LUGARDEENTREGA || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER(:CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER(:DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER(:MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER(:DATE_MODIFIED || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="COD_PROPUESTA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHA_ENTREGALV" sqlType="STRING"/>
		<param name="FECHA_ENTREGA" sqlType="STRING"/>
		<param name="HORA_ENTREGA" sqlType="STRING"/>
		<param name="HORA_ENTREGALV" sqlType="STRING"/>
		<param name="VALORIVA" sqlType="STRING"/>
		<param name="VALORDESCUENTO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PLAZOENTREGA" sqlType="STRING"/>
		<param name="PORCDESCUENTO" sqlType="STRING"/>
		<param name="PUNTAJE_TOTAL" sqlType="STRING"/>
		<param name="SUBTOTAL" sqlType="STRING"/>
		<param name="ACEPTACION" sqlType="STRING"/>
		<param name="NUMDOCUMENTO" sqlType="STRING"/>
		<param name="RESPONDIO" sqlType="STRING"/>
		<param name="FORMADEPAGO" sqlType="STRING"/>
		<param name="LUGARDEENTREGA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>

	</query>
	<resource method="GET" path="propuesta/numero">
		<call-query href="getPropuestaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_REQUISICION" query-param="COD_REQUISICION"/>
			<with-param name="COD_PROPUESTA" query-param="COD_PROPUESTA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHA_ENTREGALV" query-param="FECHA_ENTREGALV"/>
			<with-param name="FECHA_ENTREGA" query-param="FECHA_ENTREGA"/>
			<with-param name="HORA_ENTREGA" query-param="HORA_ENTREGA"/>
			<with-param name="HORA_ENTREGALV" query-param="HORA_ENTREGALV"/>
			<with-param name="VALORIVA" query-param="VALORIVA"/>
			<with-param name="VALORDESCUENTO" query-param="VALORDESCUENTO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PLAZOENTREGA" query-param="PLAZOENTREGA"/>
			<with-param name="PORCDESCUENTO" query-param="PORCDESCUENTO"/>
			<with-param name="PUNTAJE_TOTAL" query-param="PUNTAJE_TOTAL"/>
			<with-param name="SUBTOTAL" query-param="SUBTOTAL"/>
			<with-param name="ACEPTACION" query-param="ACEPTACION"/>
			<with-param name="NUMDOCUMENTO" query-param="NUMDOCUMENTO"/>
			<with-param name="RESPONDIO" query-param="RESPONDIO"/>
			<with-param name="FORMADEPAGO" query-param="FORMADEPAGO"/>
			<with-param name="LUGARDEENTREGA" query-param="LUGARDEENTREGA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>

		</call-query>
	</resource>
	<query id="updatePropuesta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROPUESTA SET VALORDESCUENTO=:VALORDESCUENTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), SUCURSAL=:SUCURSAL, ACEPTACION=:ACEPTACION, COD_PROPUESTA=:COD_PROPUESTA, NUMDOCUMENTO=:NUMDOCUMENTO, HORA_ENTREGA=TO_DATE(:HORA_ENTREGA,'DD/MM/YYYY HH24:MI:SS'), VALORIVA=:VALORIVA, NIT=:NIT, SUBTOTAL=:SUBTOTAL, COMPANIA=:COMPANIA, PORCDESCUENTO=:PORCDESCUENTO, VALORTOTAL=:VALORTOTAL, FECHA_ENTREGA=TO_DATE(:FECHA_ENTREGA,'DD/MM/YYYY HH24:MI:SS'), RESPONDIO=:RESPONDIO, MODIFIED_BY=:MODIFIED_BY, LUGARDEENTREGA=:LUGARDEENTREGA, PLAZOENTREGA=:PLAZOENTREGA, COD_REQUISICION=:COD_REQUISICION, FORMADEPAGO=:FORMADEPAGO, PUNTAJE_TOTAL=:PUNTAJE_TOTAL WHERE PROPUESTA.COD_PROPUESTA= :KEY_COD_PROPUESTA AND PROPUESTA.COD_REQUISICION= :KEY_COD_REQUISICION AND PROPUESTA.COMPANIA= :KEY_COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORDESCUENTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ACEPTACION" sqlType="STRING"/>
		<param name="COD_PROPUESTA" sqlType="STRING"/>
		<param name="NUMDOCUMENTO" sqlType="STRING"/>
		<param name="HORA_ENTREGA" sqlType="STRING"/>
		<param name="VALORIVA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUBTOTAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PORCDESCUENTO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="FECHA_ENTREGA" sqlType="STRING"/>
		<param name="RESPONDIO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="LUGARDEENTREGA" sqlType="STRING"/>
		<param name="PLAZOENTREGA" sqlType="STRING"/>
		<param name="COD_REQUISICION" sqlType="STRING"/>
		<param name="FORMADEPAGO" sqlType="STRING"/>
		<param name="PUNTAJE_TOTAL" sqlType="STRING"/>
		<param name="KEY_COD_PROPUESTA" sqlType="STRING"/>
		<param name="KEY_COD_REQUISICION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="propuesta">
		<call-query href="updatePropuesta">
