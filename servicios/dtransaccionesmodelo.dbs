<data name="dtransaccionesmodelo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDtransaccionesmodeloOrdenmayorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(ORDEN) ORDEN  FROM D_TRANSACCIONMODELO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO = :TIPO AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ORDEN":"$ORDEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtransaccionesmodelo/ordenmayor">
		<call-query href="getDtransaccionesmodeloOrdenmayorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="insertDtransaccionesmodelo" keyColumns="COMPANIA,ANO,TIPO,NUMERO,ORDEN" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_TRANSACCIONMODELO (ANO, APLICACION, AUXILIAR, CENTRO_COSTO, CLASEAPEDIR, CLASECUENTA, CODIGO_CUENTA, COMPANIA, COND_ALERTA, COND_VALIDACION, FORMULA, FORMULA_BASE, FORMULAINTERNA, FUENTE_RECURSO, MENSAJE, MENSAJE_ALERTA, MENSAJE_VALIDACION, NATURALEZA, NUMERO, ORDEN, PEDIRMOSTRAR, REFERENCIA, RETENCION, SUCURSAL, TERCERO, TIPO, TIPORETENCION, VALORCREDITO, VALORDEBITO, CUENTA_PPTAL, CONCEPTORETENCION, DATE_CREATED, CREATED_BY) VALUES (:ANO, :APLICACION, :AUXILIAR, :CENTRO_COSTO, :CLASEAPEDIR, :CLASECUENTA, :CODIGO_CUENTA, :COMPANIA, :COND_ALERTA, :COND_VALIDACION, :FORMULA, :FORMULA_BASE, :FORMULAINTERNA, :FUENTE_RECURSO, :MENSAJE, :MENSAJE_ALERTA, :MENSAJE_VALIDACION, :NATURALEZA, :NUMERO, :ORDEN, :PEDIRMOSTRAR, :REFERENCIA, :RETENCION, :SUCURSAL, :TERCERO, :TIPO, :TIPORETENCION, :VALORCREDITO, :VALORDEBITO, :CUENTA_PPTAL, :CONCEPTORETENCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO","KEY_ORDEN":"$ORDEN"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="APLICACION" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="CLASEAPEDIR" sqlType="STRING"/>
		<param defaultValue="" name="CLASECUENTA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_CUENTA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="" name="COND_ALERTA" sqlType="STRING"/>
		<param defaultValue="" name="COND_VALIDACION" sqlType="STRING"/>
		<param defaultValue="" name="FORMULA" sqlType="STRING"/>
		<param defaultValue="" name="FORMULA_BASE" sqlType="STRING"/>
		<param defaultValue="" name="FORMULAINTERNA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param defaultValue="" name="MENSAJE" sqlType="STRING"/>
		<param defaultValue="" name="MENSAJE_ALERTA" sqlType="STRING"/>
		<param defaultValue="" name="MENSAJE_VALIDACION" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="PEDIRMOSTRAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="RETENCION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="TIPORETENCION" sqlType="STRING"/>
		<param defaultValue="0" name="VALORCREDITO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORDEBITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTA_PPTAL" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTORETENCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dtransaccionesmodelo">
		<call-query href="insertDtransaccionesmodelo">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="APLICACION" query-param="APLICACION"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="CLASEAPEDIR" query-param="CLASEAPEDIR"/>
			<with-param name="CLASECUENTA" query-param="CLASECUENTA"/>
			<with-param name="CODIGO_CUENTA" query-param="CODIGO_CUENTA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COND_ALERTA" query-param="COND_ALERTA"/>
			<with-param name="COND_VALIDACION" query-param="COND_VALIDACION"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="FORMULA_BASE" query-param="FORMULA_BASE"/>
			<with-param name="FORMULAINTERNA" query-param="FORMULAINTERNA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="MENSAJE" query-param="MENSAJE"/>
			<with-param name="MENSAJE_ALERTA" query-param="MENSAJE_ALERTA"/>
			<with-param name="MENSAJE_VALIDACION" query-param="MENSAJE_VALIDACION"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="PEDIRMOSTRAR" query-param="PEDIRMOSTRAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="RETENCION" query-param="RETENCION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="TIPORETENCION" query-param="TIPORETENCION"/>
			<with-param name="VALORCREDITO" query-param="VALORCREDITO"/>
			<with-param name="VALORDEBITO" query-param="VALORDEBITO"/>
			<with-param name="CUENTA_PPTAL" query-param="CUENTA_PPTAL"/>
			<with-param name="CONCEPTORETENCION" query-param="CONCEPTORETENCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
