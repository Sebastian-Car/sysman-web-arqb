<data name="etapapr" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEtapaprPagTodosPorCompaniaYTipocQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ETAPA_PR.IDETAPA, NVL(ETAPA_PR.DESCRIPCION,'SIN IDENTIFICAR') DESCRIPCION  FROM ETAPA_PR WHERE ETAPA_PR.COMPANIA = :COMPANIA AND ETAPA_PR.TIPOCONTRATO = :TIPOCONTRATO ORDER BY IDETAPA) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDETAPA":"$IDETAPA(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="etapapr/todosporcompaniaytipoc/pag">
		<call-query href="getEtapaprPagTodosPorCompaniaYTipocQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEtapaprNumTodosPorCompaniaYTipocQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ETAPA_PR.IDETAPA, NVL(ETAPA_PR.DESCRIPCION,'SIN IDENTIFICAR') DESCRIPCION  FROM ETAPA_PR WHERE ETAPA_PR.COMPANIA = :COMPANIA AND ETAPA_PR.TIPOCONTRATO = :TIPOCONTRATO ORDER BY IDETAPA) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="etapapr/todosporcompaniaytipoc/num">
		<call-query href="getEtapaprNumTodosPorCompaniaYTipocQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getEtapaprPagTodosPorCompaniaYetapainiQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ETAPA_PR.IDETAPA, NVL(ETAPA_PR.DESCRIPCION,'SIN IDENTIFICAR') DESCRIPCION  FROM ETAPA_PR WHERE ETAPA_PR.COMPANIA = :COMPANIA AND ETAPA_PR.TIPOCONTRATO = :TIPOCONTRATO AND ETAPA_PR.IDETAPA &gt;= :ETAPAINI ORDER BY IDETAPA) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDETAPA":"$IDETAPA(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ETAPAINI" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="etapapr/todosporcompaniayetapaini/pag">
		<call-query href="getEtapaprPagTodosPorCompaniaYetapainiQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="ETAPAINI" query-param="ETAPAINI"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEtapaprNumTodosPorCompaniaYetapainiQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ETAPA_PR.IDETAPA, NVL(ETAPA_PR.DESCRIPCION,'SIN IDENTIFICAR') DESCRIPCION  FROM ETAPA_PR WHERE ETAPA_PR.COMPANIA = :COMPANIA AND ETAPA_PR.TIPOCONTRATO = :TIPOCONTRATO AND ETAPA_PR.IDETAPA &gt;= :ETAPAINI ORDER BY IDETAPA) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ETAPAINI" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="etapapr/todosporcompaniayetapaini/num">
		<call-query href="getEtapaprNumTodosPorCompaniaYetapainiQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="ETAPAINI" query-param="ETAPAINI"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getEtapaprTodosPorCompYTipocontQuery"  useConfig="sysmandsunist">
		<sql>SELECT ETAPA_PR.IDETAPA, CONCAT(ETAPA_PR.IDETAPA,CONCAT(' ',ETAPA_PR.DESCRIPCION) ) DESCRIPCION FROM ETAPA_PR WHERE ETAPA_PR.COMPANIA =:COMPANIA AND ETAPA_PR.TIPOCONTRATO =:TIPOCONTRATO ORDER BY ETAPA_PR.IDETAPA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDETAPA":"$IDETAPA(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="etapapr/todosporcompytipocont">
		<call-query href="getEtapaprTodosPorCompYTipocontQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>

		</call-query>
	</resource>
	<query id="getEtapaprTodosPorTipocontYEtapainiQuery"  useConfig="sysmandsunist">
		<sql>SELECT ETAPA_PR.IDETAPA, CONCAT(ETAPA_PR.IDETAPA,CONCAT(' ',ETAPA_PR.DESCRIPCION) ) DESCRIPCION FROM ETAPA_PR WHERE ETAPA_PR.COMPANIA =:COMPANIA AND ETAPA_PR.TIPOCONTRATO =:TIPOCONTRATO AND ETAPA_PR.IDETAPA &gt;=:ETAPAINICIAL ORDER BY ETAPA_PR.IDETAPA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDETAPA":"$IDETAPA(type:integer)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="ETAPAINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="etapapr/todosportipocontyetapaini">
		<call-query href="getEtapaprTodosPorTipocontYEtapainiQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="ETAPAINICIAL" query-param="ETAPAINICIAL"/>

		</call-query>
	</resource>
	<query id="getEtapaprPorCompaniaYTipocontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ORDEN, IDETAPA, DESCRIPCION,(CASE HEREDABLE WHEN 0 THEN 'false' ELSE 'true' END) HEREDABLE,(CASE HEREDAPROPONENTE WHEN 0 THEN 'false' ELSE 'true' END) HEREDAPROPONENTE, TIPOCONTRATO,(CASE COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END) COTIZA_ELEMENTOS, DIAS, TIPODIAS, CASE TIPODIAS WHEN '1' THEN 'Calendario' WHEN '2' THEN 'Habiles' END TIPOD  FROM ETAPA_PR WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPOCONTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ORDEN":"$ORDEN","IDETAPA":"$IDETAPA(type:integer)","DESCRIPCION":"$DESCRIPCION","HEREDABLE":"$HEREDABLE(type:boolean)","HEREDAPROPONENTE":"$HEREDAPROPONENTE(type:boolean)","TIPOCONTRATO":"$TIPOCONTRATO","COTIZA_ELEMENTOS":"$COTIZA_ELEMENTOS(type:boolean)","DIAS":"$DIAS(type:integer)","TIPODIAS":"$TIPODIAS","TIPOD":"$TIPOD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="etapapr/porcompaniaytipocontrato">
		<call-query href="getEtapaprPorCompaniaYTipocontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>

		</call-query>
	</resource>
	<query id="getEtapaprPagIddescheredapropcotizaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IDETAPA, DESCRIPCION,(CASE HEREDAPROPONENTE WHEN 0 THEN 'false' ELSE 'true' END) HEREDAPROPONENTE,(CASE COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END) COTIZA_ELEMENTOS, ORDEN  FROM ETAPA_PR WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPO_CONTRATO MINUS SELECT ETAPA_PR.IDETAPA, ETAPA_PR.DESCRIPCION, (CASE ETAPA_PR.HEREDAPROPONENTE WHEN 0  THEN 'false'   ELSE 'true' END) HEREDAPROPONENTE, (CASE ETAPA_PR.COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END)COTIZA_ELEMENTOS, ETAPA_PR.ORDEN FROM D_TRANSACCION INNER JOIN ETAPA_PR ON D_TRANSACCION.COMPANIA = ETAPA_PR.COMPANIA AND D_TRANSACCION.TIPOCONTRATO = ETAPA_PR.TIPOCONTRATO AND D_TRANSACCION.IDETAPA = ETAPA_PR.IDETAPA WHERE D_TRANSACCION.COMPANIA = :COMPANIA AND D_TRANSACCION.TIPOCONTRATO = :TIPO_CONTRATO AND D_TRANSACCION.TRANSACCION = :TRANSACCION) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDETAPA":"$IDETAPA(type:integer)","DESCRIPCION":"$DESCRIPCION","HEREDAPROPONENTE":"$HEREDAPROPONENTE(type:boolean)","COTIZA_ELEMENTOS":"$COTIZA_ELEMENTOS(type:boolean)","ORDEN":"$ORDEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="etapapr/iddescheredapropcotiza/pag">
		<call-query href="getEtapaprPagIddescheredapropcotizaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEtapaprNumIddescheredapropcotizaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IDETAPA, DESCRIPCION,(CASE HEREDAPROPONENTE WHEN 0 THEN 'false' ELSE 'true' END) HEREDAPROPONENTE,(CASE COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END) COTIZA_ELEMENTOS, ORDEN  FROM ETAPA_PR WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPO_CONTRATO MINUS SELECT ETAPA_PR.IDETAPA, ETAPA_PR.DESCRIPCION, (CASE ETAPA_PR.HEREDAPROPONENTE WHEN 0  THEN 'false'   ELSE 'true' END) HEREDAPROPONENTE, (CASE ETAPA_PR.COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END)COTIZA_ELEMENTOS, ETAPA_PR.ORDEN FROM D_TRANSACCION INNER JOIN ETAPA_PR ON D_TRANSACCION.COMPANIA = ETAPA_PR.COMPANIA AND D_TRANSACCION.TIPOCONTRATO = ETAPA_PR.TIPOCONTRATO AND D_TRANSACCION.IDETAPA = ETAPA_PR.IDETAPA WHERE D_TRANSACCION.COMPANIA = :COMPANIA AND D_TRANSACCION.TIPOCONTRATO = :TIPO_CONTRATO AND D_TRANSACCION.TRANSACCION = :TRANSACCION) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="etapapr/iddescheredapropcotiza/num">
		<call-query href="getEtapaprNumIddescheredapropcotizaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertEtapapr" keyColumns="COMPANIA,TIPOCONTRATO,IDETAPA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ETAPA_PR (COMPANIA, ORDEN, IDETAPA, DESCRIPCION, HEREDABLE, HEREDAPROPONENTE, TIPOCONTRATO, COTIZA_ELEMENTOS, DIAS, TIPODIAS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ORDEN, :IDETAPA, :DESCRIPCION, :HEREDABLE, :HEREDAPROPONENTE, :TIPOCONTRATO, :COTIZA_ELEMENTOS, :DIAS, :TIPODIAS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCONTRATO":"$TIPOCONTRATO","KEY_IDETAPA":"$IDETAPA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="ORDEN" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="HEREDABLE" sqlType="STRING"/>
		<param defaultValue="0" name="HEREDAPROPONENTE" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param defaultValue="0" name="COTIZA_ELEMENTOS" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="" name="TIPODIAS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="etapapr">
		<call-query href="insertEtapapr">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="HEREDABLE" query-param="HEREDABLE"/>
			<with-param name="HEREDAPROPONENTE" query-param="HEREDAPROPONENTE"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="COTIZA_ELEMENTOS" query-param="COTIZA_ELEMENTOS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="TIPODIAS" query-param="TIPODIAS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEtapapr" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ETAPA_PR WHERE ETAPA_PR.COMPANIA= :KEY_COMPANIA AND ETAPA_PR.TIPOCONTRATO= :KEY_TIPOCONTRATO AND ETAPA_PR.IDETAPA= :KEY_IDETAPA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_IDETAPA" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="etapapr">
		<call-query href="deleteEtapapr">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_IDETAPA" query-param="KEY_IDETAPA"/>

		</call-query>
	</resource>
	<query id="updateEtapapr" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ETAPA_PR SET DESCRIPCION=:DESCRIPCION, ORDEN=:ORDEN, HEREDABLE=:HEREDABLE, HEREDAPROPONENTE=:HEREDAPROPONENTE, TIPOCONTRATO=:TIPOCONTRATO, COTIZA_ELEMENTOS=:COTIZA_ELEMENTOS, DIAS=:DIAS, TIPODIAS=:TIPODIAS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ETAPA_PR.COMPANIA= :KEY_COMPANIA AND ETAPA_PR.TIPOCONTRATO= :KEY_TIPOCONTRATO AND ETAPA_PR.IDETAPA= :KEY_IDETAPA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="HEREDABLE" sqlType="STRING"/>
		<param name="HEREDAPROPONENTE" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="COTIZA_ELEMENTOS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="TIPODIAS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_IDETAPA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="etapapr">
		<call-query href="updateEtapapr">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="HEREDABLE" query-param="HEREDABLE"/>
			<with-param name="HEREDAPROPONENTE" query-param="HEREDAPROPONENTE"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="COTIZA_ELEMENTOS" query-param="COTIZA_ELEMENTOS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="TIPODIAS" query-param="TIPODIAS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_IDETAPA" query-param="KEY_IDETAPA"/>

		</call-query>
	</resource>
	<query id="getEtapaprPagPruebaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IDETAPA, DESCRIPCION,(CASE HEREDAPROPONENTE WHEN 0 THEN 'false' ELSE 'true' END) HEREDAPROPONENTE,(CASE COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END) COTIZA_ELEMENTOS FROM ETAPA_PR WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPO_CONTRATO MINUS SELECT ETAPA_PR.IDETAPA, ETAPA_PR.DESCRIPCION, (CASE ETAPA_PR.HEREDAPROPONENTE WHEN 0  THEN 'false'   ELSE 'true' END) HEREDAPROPONENTE, (CASE ETAPA_PR.COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END)COTIZA_ELEMENTOS FROM D_TRANSACCION INNER JOIN ETAPA_PR ON D_TRANSACCION.COMPANIA = ETAPA_PR.COMPANIA AND D_TRANSACCION.TIPOCONTRATO = ETAPA_PR.TIPOCONTRATO AND D_TRANSACCION.IDETAPA = ETAPA_PR.IDETAPA WHERE D_TRANSACCION.COMPANIA = :COMPANIA AND D_TRANSACCION.TIPOCONTRATO = :TIPO_CONTRATO AND D_TRANSACCION.TRANSACCION = :TRANSACCION) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDETAPA":"$IDETAPA(type:integer)","DESCRIPCION":"$DESCRIPCION","HEREDAPROPONENTE":"$HEREDAPROPONENTE(type:boolean)","COTIZA_ELEMENTOS":"$COTIZA_ELEMENTOS(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="etapapr/prueba/pag">
		<call-query href="getEtapaprPagPruebaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEtapaprNumPruebaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IDETAPA, DESCRIPCION,(CASE HEREDAPROPONENTE WHEN 0 THEN 'false' ELSE 'true' END) HEREDAPROPONENTE,(CASE COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END) COTIZA_ELEMENTOS FROM ETAPA_PR WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPO_CONTRATO MINUS SELECT ETAPA_PR.IDETAPA, ETAPA_PR.DESCRIPCION, (CASE ETAPA_PR.HEREDAPROPONENTE WHEN 0  THEN 'false'   ELSE 'true' END) HEREDAPROPONENTE, (CASE ETAPA_PR.COTIZA_ELEMENTOS WHEN 0 THEN 'false' ELSE 'true' END)COTIZA_ELEMENTOS FROM D_TRANSACCION INNER JOIN ETAPA_PR ON D_TRANSACCION.COMPANIA = ETAPA_PR.COMPANIA AND D_TRANSACCION.TIPOCONTRATO = ETAPA_PR.TIPOCONTRATO AND D_TRANSACCION.IDETAPA = ETAPA_PR.IDETAPA WHERE D_TRANSACCION.COMPANIA = :COMPANIA AND D_TRANSACCION.TIPOCONTRATO = :TIPO_CONTRATO AND D_TRANSACCION.TRANSACCION = :TRANSACCION) WHERE (CASE WHEN IDETAPA IS NULL THEN ' ' ELSE UPPER(IDETAPA) END)  LIKE UPPER(:IDETAPA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="IDETAPA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="etapapr/prueba/num">
		<call-query href="getEtapaprNumPruebaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="IDETAPA" query-param="IDETAPA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>

</data>