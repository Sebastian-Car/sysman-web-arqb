			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getPeriodosListaperiofechasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.ANO , MAX( TO_CHAR ( PERIODOS.FECHAINICIO , 'DD/MM/YYYY') ) KEEP (DENSE_RANK FIRST ORDER BY ROWNUM) FECHAINICIO , MAX( TO_CHAR( PERIODOS.FECHAFINAL , 'DD/MM/YYYY') ) KEEP (DENSE_RANK LAST ORDER BY ROWNUM) FECHAFINAL  FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO &lt;&gt; 0 GROUP BY PERIODOS.ANO ORDER BY PERIODOS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/listaperiofechas">
		<call-query href="getPeriodosListaperiofechasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPeriodosTodosPorMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.MES, MES.NOMBRE  FROM MES INNER JOIN PERIODOS ON MES.COMPANIA = PERIODOS.COMPANIA AND MES.ANO = PERIODOS.ANO AND MES.NUMERO = PERIODOS.MES WHERE MES.COMPANIA = :COMPANIA AND MES.ANO = :ANO AND PERIODOS.MES &lt;&gt; 0 AND PERIODOS.ID_DE_PROCESO= :PROCESO ORDER BY PERIODOS.MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>

	</query>
