	<query id="updatePeriodos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERIODOS SET ANO=:ANO, COMPANIA=:COMPANIA, MES=:MES, PERIODO=:PERIODO, NOM_PERIODO=:NOM_PERIODO, FECHAINICIO=TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), DIAS=:DIAS, ACUMULADO=:ACUMULADO, ESTADO=:ESTADO, DIFERIDOS=:DIFERIDOS, OBSERVACION=:OBSERVACION, VALORDTF=:VALORDTF, ID_DE_PROCESO=:ID_DE_PROCESO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PERIODOS.COMPANIA= :KEY_COMPANIA AND PERIODOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND PERIODOS.ANO= :KEY_ANO AND PERIODOS.MES= :KEY_MES AND PERIODOS.PERIODO= :KEY_PERIODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOM_PERIODO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ACUMULADO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DIFERIDOS" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="VALORDTF" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="periodos">
		<call-query href="updatePeriodos">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NOM_PERIODO" query-param="NOM_PERIODO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
