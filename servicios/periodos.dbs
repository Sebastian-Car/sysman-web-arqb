	<query id="getPeriodosPagDifPeriodoNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT PERIODO, NOM_PERIODO  FROM PERIODOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN NOM_PERIODO IS NULL THEN ' ' ELSE UPPER(NOM_PERIODO) END)  LIKE UPPER( '%' || :NOM_PERIODO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOM_PERIODO":"$NOM_PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOM_PERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="periodos/difperiodonombre/pag">
		<call-query href="getPeriodosPagDifPeriodoNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NOM_PERIODO" query-param="NOM_PERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
