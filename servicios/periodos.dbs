		</call-query>
	</resource>
	<query id="getPeriodosPagTodosPorCompaniaProcesoNominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT PERIODOS.FECHAFINAL, TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY') FECHAFINAL1, CONCAT(PERIODOS.PERIODO,CONCAT(' ',PERIODOS.NOM_PERIODO) ) PER, PERIODOS.ANO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(PERIODOS.MES) MES FROM PERIODOS WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:PROCESONOMINA AND PERIODOS.DIFERIDOS NOT IN (0) ORDER BY PERIODOS.FECHAFINAL DESC) INI WHERE (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN FECHAFINAL1 IS NULL THEN ' ' ELSE UPPER(FECHAFINAL1) END) LIKE UPPER(CONCAT(:FECHAFINAL1, '%')) AND (CASE WHEN PER IS NULL THEN ' ' ELSE UPPER(PER) END) LIKE UPPER(CONCAT(CONCAT('%',:PER), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHAFINAL":"$FECHAFINAL","FECHAFINAL1":"$FECHAFINAL1","PER":"$PER","ANO":"$ANO(type:integer)","MES":"$MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESONOMINA" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAFINAL1" sqlType="STRING"/>
		<param name="PER" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="periodos/todosporcompaniaprocesonomina/pag">
		<call-query href="getPeriodosPagTodosPorCompaniaProcesoNominaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESONOMINA" query-param="PROCESONOMINA"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="FECHAFINAL1" query-param="FECHAFINAL1"/>
			<with-param name="PER" query-param="PER"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPeriodosNumTodosPorCompaniaProcesoNominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT PERIODOS.FECHAFINAL, TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY') FECHAFINAL1, CONCAT(PERIODOS.PERIODO,CONCAT(' ',PERIODOS.NOM_PERIODO) ) PER, PERIODOS.ANO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(PERIODOS.MES) MES FROM PERIODOS WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:PROCESONOMINA AND PERIODOS.DIFERIDOS NOT IN (0) ORDER BY PERIODOS.FECHAFINAL DESC) INI WHERE (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN FECHAFINAL1 IS NULL THEN ' ' ELSE UPPER(FECHAFINAL1) END) LIKE UPPER(CONCAT(:FECHAFINAL1, '%')) AND (CASE WHEN PER IS NULL THEN ' ' ELSE UPPER(PER) END) LIKE UPPER(CONCAT(CONCAT('%',:PER), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(CONCAT('%',:MES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESONOMINA" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAFINAL1" sqlType="STRING"/>
		<param name="PER" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/todosporcompaniaprocesonomina/num">
		<call-query href="getPeriodosNumTodosPorCompaniaProcesoNominaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESONOMINA" query-param="PROCESONOMINA"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="FECHAFINAL1" query-param="FECHAFINAL1"/>
			<with-param name="PER" query-param="PER"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getPeriodosEstadoporcompaniaprocesoyperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO,MES,PERIODO,ANO,(TO_CHAR(FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(CASE ACUMULADO WHEN 0 THEN 'false' ELSE 'true' END) ACUMULADO,DIAS  FROM PERIODOS WHERE COMPANIA = :COMPANIA AND ID_DE_PROCESO = :PROCESO AND ANO = :ANO AND MES = :MES AND PERIODO = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO(type:boolean)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ANO":"$ANO(type:integer)","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL","ACUMULADO":"$ACUMULADO(type:boolean)","DIAS":"$DIAS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/estadoporcompaniaprocesoyperiodo">
		<call-query href="getPeriodosEstadoporcompaniaprocesoyperiodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getPeriodosPeriodoanteriorcalculoQuery"  useConfig="sysmandsunist">
		<sql>SELECT ANO, MES, PERIODO,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL FROM ( SELECT ANO, MES, PERIODO, FECHAFINAL FROM PERIODOS WHERE COMPANIA =:COMPANIA AND ID_DE_PROCESO =:PROCESO AND ACUMULADO &lt;&gt; 0 AND CONCAT(ANO,CONCAT(MES,PERIODO) ) &lt;:PERIODO ORDER BY CONCAT(ANO,CONCAT(MES,PERIODO) ) DESC ) T WHERE ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/periodoanteriorcalculo">
		<call-query href="getPeriodosPeriodoanteriorcalculoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getPeriodosPagTodosporcompanomesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERIODO, NOM_PERIODO, ID_DE_PROCESO  FROM PERIODOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND MES = :MES) WHERE (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN NOM_PERIODO IS NULL THEN ' ' ELSE UPPER(NOM_PERIODO) END)  LIKE UPPER( '%' || :NOM_PERIODO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOM_PERIODO":"$NOM_PERIODO","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOM_PERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="periodos/todosporcompanomes/pag">
		<call-query href="getPeriodosPagTodosporcompanomesQuery">
