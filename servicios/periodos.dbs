	</resource>
	<query id="getPeriodosPagTodosPorProcesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, PERIODOS.PERIODO  FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ID_DE_PROCESO = :PROCESO AND PERIODOS.DIFERIDOS NOT IN(0) ORDER BY PERIODOS.FECHAFINAL DESC) WHERE (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHAFINAL":"$FECHAFINAL","PERIODO":"$PERIODO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="periodos/todosporproceso/pag">
		<call-query href="getPeriodosPagTodosPorProcesoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPeriodosNumTodosPorProcesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, PERIODOS.PERIODO  FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ID_DE_PROCESO = :PROCESO AND PERIODOS.DIFERIDOS NOT IN(0) ORDER BY PERIODOS.FECHAFINAL DESC) WHERE (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/todosporproceso/num">
		<call-query href="getPeriodosNumTodosPorProcesoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getPeriodosTodosPorProcesoYFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO, MES, PERIODO,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL FROM PERIODOS WHERE COMPANIA = :COMPANIA AND ID_DE_PROCESO = :PROCESO AND ACUMULADO NOT IN(0) AND DIFERIDOS NOT IN(0) AND TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS') BETWEEN FECHAINICIO AND FECHAFINAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/todosporprocesoyfecha">
