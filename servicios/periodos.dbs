	<query id="getPeriodosPorNombreYPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODO, NOM_PERIODO  FROM PERIODOS WHERE COMPANIA= :COMPANIA AND ID_DE_PROCESO = :ID_DE_PROCESO AND ANO = :ANO AND MES = :MES AND PERIODO NOT IN(0) ORDER BY PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOM_PERIODO":"$NOM_PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
