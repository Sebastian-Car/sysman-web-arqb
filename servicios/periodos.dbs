	<query id="getPeriodosPeriododiferenciasretroactivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE DIFERENCIASRETROACTIVO WHEN 0 THEN 'false' ELSE 'true' END) DIFERENCIASRETROACTIVO FROM PERIODOS WHERE COMPANIA = :COMPANIA AND ID_DE_PROCESO = :ID_DE_PROCESO AND ANO = :ANO AND MES = :MES AND PERIODO = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIFERENCIASRETROACTIVO":"$DIFERENCIASRETROACTIVO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
