		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOM_PERIODO":"$NOM_PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
