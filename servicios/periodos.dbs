	<query id="getPeriodosMesesPorProcesoYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.MES, MES.NOMBRE  FROM PERIODOS INNER JOIN MES ON PERIODOS.COMPANIA = MES.COMPANIA AND PERIODOS.ANO = MES.ANO AND PERIODOS.MES = MES.NUMERO WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ID_DE_PROCESO = :ID_DE_PROCESO AND PERIODOS.ANO = :ANO AND PERIODOS.MES &lt;&gt; 0 ORDER BY PERIODOS.MES</sql>
