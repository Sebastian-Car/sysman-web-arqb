	<query id="getPeriodosListafecinicioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TO_CHAR( PERIODOS.FECHAINICIO,'DD/MM/YYYY') FECHAINICIO , TO_CHAR(PERIODOS.FECHAINICIO,'DD/MM/YYYY') FECHA  FROM PERIODOS WHERE PERIODOS.ACUMULADO &lt;&gt; 0 AND PERIODOS.ID_DE_PROCESO = :PROCESO_SESION AND PERIODOS.COMPANIA = :COMPANIA ORDER BY TO_CHAR(PERIODOS.FECHAINICIO,'DD/MM/YYYY')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHAINICIO":"$FECHAINICIO","FECHA":"$FECHA"}]}}		</result>
