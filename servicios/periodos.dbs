	<query id="getPeriodosTodosPorMesSegunAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.MES, MES.NOMBRE  FROM MES LEFT JOIN PERIODOS ON MES.COMPANIA = PERIODOS.COMPANIA AND MES.NUMERO = PERIODOS.MES WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO = :ANO AND MES.NUMERO NOT IN(0,13) ORDER BY PERIODOS.MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
