		</call-query>
	</resource>
	<query id="getPeriodosPagTodosPorCompaniaYProcesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT PERIODOS.ANO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(PERIODOS.MES) MESNOM, CONCAT(PERIODOS.PERIODO,CONCAT(' ',PERIODOS.NOM_PERIODO) ) PER,(TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, PERIODOS.PERIODO, PERIODOS.MES FROM PERIODOS WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:ID_DE_PROCESO AND PERIODOS.DIFERIDOS NOT IN (0) ORDER BY PERIODOS.FECHAFINAL DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN MESNOM IS NULL THEN ' ' ELSE UPPER(MESNOM) END) LIKE UPPER(CONCAT(CONCAT('%',:MESNOM), '%')) AND (CASE WHEN PER IS NULL THEN ' ' ELSE UPPER(PER) END) LIKE UPPER(CONCAT(CONCAT('%',:PER), '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAFINAL), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(:MES, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","MESNOM":"$MESNOM","PER":"$PER","FECHAFINAL":"$FECHAFINAL","PERIODO":"$PERIODO(type:integer)","MES":"$MES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MESNOM" sqlType="STRING"/>
		<param name="PER" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="periodos/todosporcompaniayproceso/pag">
		<call-query href="getPeriodosPagTodosPorCompaniaYProcesoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MESNOM" query-param="MESNOM"/>
			<with-param name="PER" query-param="PER"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPeriodosNumTodosPorCompaniaYProcesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT PERIODOS.ANO, PCK_SYSMAN_UTL.FC_NOMBRE_MES(PERIODOS.MES) MESNOM, CONCAT(PERIODOS.PERIODO,CONCAT(' ',PERIODOS.NOM_PERIODO) ) PER,(TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, PERIODOS.PERIODO, PERIODOS.MES FROM PERIODOS WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:ID_DE_PROCESO AND PERIODOS.DIFERIDOS NOT IN (0) ORDER BY PERIODOS.FECHAFINAL DESC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN MESNOM IS NULL THEN ' ' ELSE UPPER(MESNOM) END) LIKE UPPER(CONCAT(CONCAT('%',:MESNOM), '%')) AND (CASE WHEN PER IS NULL THEN ' ' ELSE UPPER(PER) END) LIKE UPPER(CONCAT(CONCAT('%',:PER), '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAFINAL), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(:MES, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MESNOM" sqlType="STRING"/>
		<param name="PER" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
