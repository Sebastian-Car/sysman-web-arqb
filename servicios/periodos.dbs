<data name="periodos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPeriodosProcesosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.ID_DE_PROCESO, PROCESOS_DE_NOMINA.NOMBRE_PROCESO FROM PERIODOS LEFT JOIN PROCESOS_DE_NOMINA ON PERIODOS.COMPANIA = PROCESOS_DE_NOMINA.COMPANIA AND PERIODOS.ID_DE_PROCESO = PROCESOS_DE_NOMINA.ID_DE_PROCESO WHERE PERIODOS.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","NOMBRE_PROCESO":"$NOMBRE_PROCESO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/procesosporcompania">
		<call-query href="getPeriodosProcesosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPeriodosAniosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.ANO FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO NOT IN (0) ORDER BY PERIODOS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/aniosporcompania">
		<call-query href="getPeriodosAniosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPeriodosNombrePorAnioYMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.PERIODO, CONCAT(PERIODOS.PERIODO,CONCAT(' ',UPPER(PERIODOS.NOM_PERIODO) ) ) NOMBRE FROM PERIODOS WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ANO =:ANO AND PERIODOS.MES =:MES AND PERIODOS.PERIODO NOT IN ( 0 ) ORDER BY PERIODOS.PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/nombreporanioymes">
		<call-query href="getPeriodosNombrePorAnioYMesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getPeriodosAniosPorCompaniaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.ANO FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO NOT IN (0) AND PERIODOS.ANO &gt;= :ANO ORDER BY PERIODOS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/aniosporcompaniafinal">
		<call-query href="getPeriodosAniosPorCompaniaFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getPeriodosTodosporNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT MES, PCK_SYSMAN_UTL.FC_NOMBRE_MES(MES) NOMBRE_MES  FROM PERIODOS WHERE MES &lt;&gt; 0 ORDER BY MES ASC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBRE_MES":"$NOMBRE_MES"}]}}		</result>
 
	</query>
	<resource method="GET" path="periodos/todospornombre">
		<call-query href="getPeriodosTodosporNombreQuery">
 
		</call-query>
	</resource>
	<query id="getPeriodosAnosPorCiaDif0000Query"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.ANO FROM PERIODOS WHERE PERIODOS.ANO &lt;&gt; '0000' AND PERIODOS.COMPANIA = :COMPANIA ORDER BY PERIODOS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/anosporciadif0000">
		<call-query href="getPeriodosAnosPorCiaDif0000Query">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPeriodosNomPorCiaAnoMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.PERIODO, CONCAT(PERIODOS.PERIODO,CONCAT(' ',UPPER(PERIODOS.NOM_PERIODO) ) ) NOMBRE FROM PERIODOS WHERE PERIODOS.PERIODO &lt;&gt; 0 AND PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ANO =:ANO AND PERIODOS.MES =:MES ORDER BY PERIODOS.PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/nomporciaanomes">
		<call-query href="getPeriodosNomPorCiaAnoMesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getPeriodosPorCompaniaYIdprocesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.ANO  FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ID_DE_PROCESO= :ID_DE_PROCESO AND PERIODOS.ANO NOT IN(0) ORDER BY PERIODOS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/porcompaniayidproceso">
		<call-query href="getPeriodosPorCompaniaYIdprocesoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>

		</call-query>
	</resource>
	<query id="getPeriodosPorIdprocesoYAcumuladoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.PERIODO, CONCAT(PERIODOS.PERIODO,CONCAT(' ',UPPER(PERIODOS.NOM_PERIODO) ) ) NOMBRE FROM PERIODOS WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.PERIODO &lt;&gt; 0 AND PERIODOS.ANO =:ANO AND PERIODOS.MES =:MES AND PERIODOS.ID_DE_PROCESO =:ID_DE_PROCESO AND PERIODOS.ACUMULADO &lt;&gt; 0 ORDER BY PERIODOS.PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/poridprocesoyacumulado">
		<call-query href="getPeriodosPorIdprocesoYAcumuladoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>

		</call-query>
	</resource>
	<query id="insertPeriodos" keyColumns="COMPANIA,ID_DE_PROCESO,ANO,MES,PERIODO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PERIODOS (ANO, COMPANIA, MES, PERIODO, NOM_PERIODO, FECHAINICIO, FECHAFINAL, DIAS, ACUMULADO, ESTADO, DIFERIDOS, OBSERVACION, VALORDTF, ID_DE_PROCESO, DATE_CREATED, CREATED_BY) VALUES (:ANO, :COMPANIA, :MES, :PERIODO, :NOM_PERIODO, TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), :DIAS, :ACUMULADO, :ESTADO, :DIFERIDOS, :OBSERVACION, :VALORDTF, :ID_DE_PROCESO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_PERIODO":"$PERIODO(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOM_PERIODO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINICIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAFINAL" sqlType="STRING"/>
		<param defaultValue="30" name="DIAS" sqlType="STRING"/>
		<param defaultValue="-1" name="ACUMULADO" sqlType="STRING"/>
		<param defaultValue="-1" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="-1" name="DIFERIDOS" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION" sqlType="STRING"/>
		<param defaultValue="0" name="VALORDTF" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="periodos">
		<call-query href="insertPeriodos">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NOM_PERIODO" query-param="NOM_PERIODO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="ACUMULADO" query-param="ACUMULADO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DIFERIDOS" query-param="DIFERIDOS"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="VALORDTF" query-param="VALORDTF"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePeriodos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PERIODOS WHERE PERIODOS.COMPANIA= :KEY_COMPANIA AND PERIODOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND PERIODOS.ANO= :KEY_ANO AND PERIODOS.MES= :KEY_MES AND PERIODOS.PERIODO= :KEY_PERIODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="periodos">
		<call-query href="deletePeriodos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>

		</call-query>
	</resource>
	<query id="getPeriodosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERIODOS.ANO, PERIODOS.COMPANIA, PERIODOS.MES, PERIODOS.PERIODO, PERIODOS.NOM_PERIODO,(TO_CHAR(PERIODOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, PERIODOS.DIAS,(CASE PERIODOS.ACUMULADO WHEN 0 THEN 'false' ELSE 'true' END) ACUMULADO,(CASE PERIODOS.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO,(CASE PERIODOS.DIFERIDOS WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDOS, PERIODOS.OBSERVACION, PERIODOS.VALORDTF, PERIODOS.ID_DE_PROCESO, MES.NOMBRE  FROM PERIODOS INNER JOIN MES ON PERIODOS.COMPANIA=MES.COMPANIA AND PERIODOS.ANO =MES.ANO AND PERIODOS.MES =MES.NUMERO WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:PROCESO_SESION AND PERIODOS.ANO &lt;&gt;0 AND PERIODOS.MES &lt;&gt;0 ORDER BY PERIODOS.ANO DESC , PERIODOS.MES DESC , PERIODOS.PERIODO, PERIODOS.FECHAFINAL) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN NOM_PERIODO IS NULL THEN ' ' ELSE UPPER(NOM_PERIODO) END)  LIKE UPPER( '%' || :NOM_PERIODO || '%')  AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END)  LIKE UPPER( '%' || :FECHAINICIO || '%')  AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN ACUMULADO IS NULL THEN ' ' ELSE UPPER(ACUMULADO) END)  LIKE UPPER(:ACUMULADO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%')  AND (CASE WHEN DIFERIDOS IS NULL THEN ' ' ELSE UPPER(DIFERIDOS) END)  LIKE UPPER(:DIFERIDOS || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%')  AND (CASE WHEN VALORDTF IS NULL THEN ' ' ELSE UPPER(VALORDTF) END)  LIKE UPPER(:VALORDTF || '%')  AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END)  LIKE UPPER(:ID_DE_PROCESO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","COMPANIA":"$COMPANIA","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","NOM_PERIODO":"$NOM_PERIODO","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL","DIAS":"$DIAS","ACUMULADO":"$ACUMULADO(type:boolean)","ESTADO":"$ESTADO(type:boolean)","DIFERIDOS":"$DIFERIDOS(type:boolean)","OBSERVACION":"$OBSERVACION","VALORDTF":"$VALORDTF","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO_SESION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOM_PERIODO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ACUMULADO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DIFERIDOS" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="VALORDTF" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="periodos">
		<call-query href="getPeriodosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO_SESION" query-param="PROCESO_SESION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NOM_PERIODO" query-param="NOM_PERIODO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="ACUMULADO" query-param="ACUMULADO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DIFERIDOS" query-param="DIFERIDOS"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="VALORDTF" query-param="VALORDTF"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPeriodosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PERIODOS.ANO, PERIODOS.COMPANIA, PERIODOS.MES, PERIODOS.PERIODO, PERIODOS.NOM_PERIODO,(TO_CHAR(PERIODOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, PERIODOS.DIAS,(CASE PERIODOS.ACUMULADO WHEN 0 THEN 'false' ELSE 'true' END) ACUMULADO,(CASE PERIODOS.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO,(CASE PERIODOS.DIFERIDOS WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDOS, PERIODOS.OBSERVACION, PERIODOS.VALORDTF, PERIODOS.ID_DE_PROCESO, MES.NOMBRE  FROM PERIODOS INNER JOIN MES ON PERIODOS.COMPANIA=MES.COMPANIA AND PERIODOS.ANO =MES.ANO AND PERIODOS.MES =MES.NUMERO WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:PROCESO_SESION AND PERIODOS.ANO &lt;&gt;0 AND PERIODOS.MES &lt;&gt;0 ORDER BY PERIODOS.ANO DESC , PERIODOS.MES DESC , PERIODOS.PERIODO, PERIODOS.FECHAFINAL) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER( '%' || :MES || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN NOM_PERIODO IS NULL THEN ' ' ELSE UPPER(NOM_PERIODO) END)  LIKE UPPER( '%' || :NOM_PERIODO || '%')  AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END)  LIKE UPPER( '%' || :FECHAINICIO || '%')  AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN ACUMULADO IS NULL THEN ' ' ELSE UPPER(ACUMULADO) END)  LIKE UPPER(:ACUMULADO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%')  AND (CASE WHEN DIFERIDOS IS NULL THEN ' ' ELSE UPPER(DIFERIDOS) END)  LIKE UPPER(:DIFERIDOS || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%')  AND (CASE WHEN VALORDTF IS NULL THEN ' ' ELSE UPPER(VALORDTF) END)  LIKE UPPER(:VALORDTF || '%')  AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END)  LIKE UPPER(:ID_DE_PROCESO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO_SESION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOM_PERIODO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="ACUMULADO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DIFERIDOS" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="VALORDTF" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/numero">
