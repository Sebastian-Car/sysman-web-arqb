	<query id="getPeriodosTodosPorPeridoQuery"  useConfig="sysmandsunist">
		<sql>SELECT PERIODOS.PERIODO, CONCAT(PERIODOS.PERIODO,CONCAT(' ',PERIODOS.NOM_PERIODO) ) NOMBRE FROM PERIODOS WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.PERIODO &lt;&gt; 0 AND PERIODOS.ANO =:ANO AND PERIODOS.MES =:MES AND PERIODOS.ID_DE_PROCESO =:PROCESO AND PERIODOS.ACUMULADO &lt;&gt; 0 ORDER BY PERIODOS.PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
