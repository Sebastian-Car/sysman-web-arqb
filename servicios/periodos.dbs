	<query id="getPeriodosTodosporciaprocmenoranoactualQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.ANO  FROM PERIODOS WHERE COMPANIA = :COMPANIA AND PERIODOS.ID_DE_PROCESO = :ID_DE_PROCESO AND PERIODOS.ANO NOT IN (0) AND PERIODOS.ANO &lt;= TO_CHAR(SYSDATE, 'YYYY') ORDER BY PERIODOS.ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/todosporciaprocmenoranoactual">
		<call-query href="getPeriodosTodosporciaprocmenoranoactualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>

		</call-query>
	</resource>
	<query id="getPeriodosTodosporciapromesmenoractualQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODOS.MES, PCK_SYSMAN_UTL.FC_NOMBRE_MES(PERIODOS.MES) NOMBRE_MES FROM PERIODOS INNER JOIN MES ON PERIODOS.COMPANIA = MES.COMPANIA AND PERIODOS.MES = MES.NUMERO WHERE PERIODOS.COMPANIA =:COMPANIA AND PERIODOS.ID_DE_PROCESO =:ID_DE_PROCESO AND PERIODOS.ANO NOT IN (0) AND PERIODOS.ANO =:ANO AND TO_NUMBER(CONCAT(TRIM(TO_CHAR(PERIODOS.ANO,'0000')), TRIM(TO_CHAR(PERIODOS.MES,'00')))) &lt;= TO_NUMBER(TO_CHAR(SYSDATE,'YYYYMM') ) ORDER BY PERIODOS.MES DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBRE_MES":"$NOMBRE_MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
