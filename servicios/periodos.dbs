			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPeriodosNumTodosporcompanomesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PERIODO, NOM_PERIODO, ID_DE_PROCESO  FROM PERIODOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND MES = :MES) WHERE (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN NOM_PERIODO IS NULL THEN ' ' ELSE UPPER(NOM_PERIODO) END)  LIKE UPPER( '%' || :NOM_PERIODO || '%') ))</sql>
