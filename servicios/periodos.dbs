	<query id="getPeriodosEstadoperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_NUMBER(PERIODOS.ESTADO)ESTADO FROM PERIODOS INNER JOIN PERSONAL ON PERIODOS.COMPANIA=PERSONAL.COMPANIA WHERE PERIODOS.ANO=:ANO AND PERIODOS.MES=:MES AND PERIODOS.COMPANIA=:COMPANIA AND PERIODOS.PERIODO=:PERIODO AND PERSONAL.NUMERO_DCTO=:USUARIO GROUP BY PERIODOS.ESTADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTADO":"$ESTADO(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/estadoperiodo">
		<call-query href="getPeriodosEstadoperiodoQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="getPeriodosPeriodoscerrradosQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COMPANIA.CODIGO COMPANIA, COMPANIA.NITCOMPANIA, TO_CHAR(PERIODOS.PERIODO) PERIODO, PERIODOS.NOM_PERIODO NOMBRE FROM PERIODOS INNER JOIN HISTORICOS ON PERIODOS.COMPANIA = HISTORICOS.COMPANIA AND PERIODOS.ID_DE_PROCESO = HISTORICOS.ID_DE_PROCESO AND PERIODOS.ANO = HISTORICOS.ANO AND PERIODOS.MES = HISTORICOS.MES AND PERIODOS.PERIODO = HISTORICOS.PERIODO INNER JOIN PERSONAL ON HISTORICOS.COMPANIA = PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO INNER JOIN COMPANIA ON COMPANIA.CODIGO = PERSONAL.COMPANIA WHERE PERIODOS.ANO=:ANO AND PERIODOS.MES =:MES AND PERIODOS.ESTADO =0 AND PERSONAL.NUMERO_DCTO = :NUMERO_DOC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NITCOMPANIA":"$NITCOMPANIA","PERIODO":"$PERIODO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="NUMERO_DOC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/periodoscerrrados">
		<call-query href="getPeriodosPeriodoscerrradosQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="NUMERO_DOC" query-param="NUMERO_DOC"/>

		</call-query>
	</resource>
	<query id="getPeriodosExcluirperiodotresQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT PERIODO, NOM_PERIODO FROM PERIODOS WHERE COMPANIA = :COMPANIA AND ID_DE_PROCESO = :ID_DE_PROCESO AND ANO = :ANO AND MES = :MES AND PERIODO NOT IN (3,0) ORDER BY PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOM_PERIODO":"$NOM_PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
