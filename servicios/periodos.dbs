	<query id="getPeriodosListafecfinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY') FECHAFINAL, TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY') FECHA  FROM PERIODOS WHERE PERIODOS.ACUMULADO &lt;&gt; 0 AND PERIODOS.ID_DE_PROCESO = :PROCESO_SESION AND PERIODOS.COMPANIA = :COMPANIA ORDER BY TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY') DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHAFINAL":"$FECHAFINAL","FECHA":"$FECHA"}]}}		</result>
