	<query id="getPeriodosTodoPorProcesoCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.ID_DE_PROCESO, PROCESOS_DE_NOMINA.NOMBRE_PROCESO  FROM PERIODOS LEFT JOIN PROCESOS_DE_NOMINA ON PERIODOS.COMPANIA = PROCESOS_DE_NOMINA.COMPANIA AND PERIODOS.ID_DE_PROCESO = PROCESOS_DE_NOMINA.ID_DE_PROCESO WHERE PERIODOS.ID_DE_PROCESO NOT IN (0) AND PERIODOS.COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","NOMBRE_PROCESO":"$NOMBRE_PROCESO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/todoporprocesocompania">
		<call-query href="getPeriodosTodoPorProcesoCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPeriodosPorPeriodoNotInCeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.PERIODO, PERIODOS.NOM_PERIODO  FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ID_DE_PROCESO = :ID_DE_PROCESO AND PERIODOS.ANO = :ANO AND PERIODOS.MES = :MES AND PERIODOS.PERIODO NOT IN(00) GROUP BY PERIODOS.PERIODO, PERIODOS.NOM_PERIODO ORDER BY PERIODOS.PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERIODO":"$PERIODO(type:integer)","NOM_PERIODO":"$NOM_PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/porperiodonotincero">
		<call-query href="getPeriodosPorPeriodoNotInCeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getPeriodosNombreMesSegunProanioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERIODOS.MES, PCK_SYSMAN_UTL.FC_NOMBRE_MES(PERIODOS.MES) NOMBRE_MES  FROM PERIODOS LEFT JOIN MES ON PERIODOS.COMPANIA = MES.COMPANIA AND PERIODOS.MES = MES.NUMERO WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ID_DE_PROCESO = :ID_DE_PROCESO AND PERIODOS.ANO = :ANO AND PERIODOS.MES NOT IN(0) ORDER BY PERIODOS.MES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MES":"$MES(type:integer)","NOMBRE_MES":"$NOMBRE_MES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="periodos/nombremessegunproanio">
