	<query id="getPeriodosPagListadoGeneralQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, PERIODO CODIGO, ANO NOMBRE, MES EXPRESION1, ID_DE_PROCESO EXPRESION2  FROM PERIODOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN EXPRESION1 IS NULL THEN ' ' ELSE UPPER(EXPRESION1) END)  LIKE UPPER( '%' || :EXPRESION1 || '%')  AND (CASE WHEN EXPRESION2 IS NULL THEN ' ' ELSE UPPER(EXPRESION2) END)  LIKE UPPER( '%' || :EXPRESION2 || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE(type:integer)","EXPRESION1":"$EXPRESION1(type:integer)","EXPRESION2":"$EXPRESION2(type:integer)"}]}}		</result>
