<data name="dtramitevariables" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateDtramitevariablesAdjunto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_TRAMITE_VARIABLES SET ADJUNTO                                 =:ADJUNTO,   DATE_MODIFIED                             =TO_DATE(SYSDATE,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY                               =:MODIFIED_BY WHERE COMPANIA           = :COMPANIA AND CODIGO_PROCESO       = :PROCESO AND TIPO_TRAMITE         = :TIPO_TRAMITE AND NUMERO_TRAMITE       = :TRAMITE AND CONSECUTIVO_TRAMITE  = :D_TRAMITE AND CODIGO_NODO          = :NODO AND CODIGO_NODO_VARIABLE = :VARIABLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ADJUNTO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="D_TRAMITE" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="VARIABLE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables/adjunto">
		<call-query href="updateDtramitevariablesAdjunto">
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="D_TRAMITE" query-param="D_TRAMITE"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="VARIABLE" query-param="VARIABLE"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesVariablesportramiteQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(CHR(39),CONCAT(VALOR,CONCAT(VALOR_TEXTO,CONCAT(VALOR_FECHA,CONCAT(CHR(39),CONCAT(CHR(32),CODIGO_NODO_VARIABLE) ) ) ) ) ) CODIGO FROM D_TRAMITE_VARIABLES WHERE COMPANIA =:COMPANIA AND TIPO_TRAMITE =:TIPO_TRAMITE AND CODIGO_PROCESO =:PROCESO AND NUMERO_TRAMITE =:TRAMITE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtramitevariables/variablesportramite">
		<call-query href="getDtramitevariablesVariablesportramiteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>

		</call-query>
	</resource>
	<query id="updateDtramitevariablesAdjuntonulo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_TRAMITE_VARIABLES SET ADJUNTO = CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT('/C', COMPANIA), 'P'), CODIGO_PROCESO), 'T'), TIPO_TRAMITE), 'N'), NUMERO_TRAMITE), 'D'), CODIGO_NODO), 'S'),CONSECUTIVO_TRAMITE),'.jpg') WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND TIPO_TRAMITE = :TIPO_TRAMITE AND NUMERO_TRAMITE = :NUMERO AND ADJUNTO IS NULL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables/adjuntonulo">
		<call-query href="updateDtramitevariablesAdjuntonulo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="updateDtramitevariablesAdjuntoanexouno" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE d_tramite_variables d SET d.adjunto =:un_adjunto WHERE compania =:un_compania AND d.codigo_nodo ='0000' AND d.CODIGO_PROCESO='00000' AND d.tipo_tramite =:un_tramite AND numero_tramite =:un_numero AND codigo_nodo_variable = '060'</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="UN_ADJUNTO" sqlType="STRING"/>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_TRAMITE" sqlType="STRING"/>
		<param name="UN_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables/adjuntoanexouno">
		<call-query href="updateDtramitevariablesAdjuntoanexouno">
			<with-param name="UN_ADJUNTO" query-param="UN_ADJUNTO"/>
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_TRAMITE" query-param="UN_TRAMITE"/>
			<with-param name="UN_NUMERO" query-param="UN_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateDtramitevariablesAdjuntoanexodos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE d_tramite_variables d SET d.adjunto =:un_adjunto WHERE compania =:un_compania AND d.codigo_nodo ='0000' AND d.CODIGO_PROCESO='00000' AND d.tipo_tramite =:un_tramite AND numero_tramite =:un_numero AND codigo_nodo_variable = '070'</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="UN_ADJUNTO" sqlType="STRING"/>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_TRAMITE" sqlType="STRING"/>
		<param name="UN_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables/adjuntoanexodos">
		<call-query href="updateDtramitevariablesAdjuntoanexodos">
			<with-param name="UN_ADJUNTO" query-param="UN_ADJUNTO"/>
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_TRAMITE" query-param="UN_TRAMITE"/>
			<with-param name="UN_NUMERO" query-param="UN_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateDtramitevariablesAdjuntoanexotres" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_TRAMITE_VARIABLES D SET D.VALOR_TEXTO =:UN_ADJUNTO,D.ADJUNTO =:UN_ADJUNTO WHERE COMPANIA =:UN_COMPANIA AND D.CODIGO_NODO ='0000' AND D.CODIGO_PROCESO='00000' AND D.TIPO_TRAMITE =:UN_TRAMITE AND NUMERO_TRAMITE =:UN_NUMERO AND CODIGO_NODO_VARIABLE =:UN_NODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="UN_ADJUNTO" sqlType="STRING"/>
		<param name="UN_COMPANIA" sqlType="STRING"/>
		<param name="UN_TRAMITE" sqlType="STRING"/>
		<param name="UN_NUMERO" sqlType="STRING"/>
		<param name="UN_NODO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables/adjuntoanexotres">
		<call-query href="updateDtramitevariablesAdjuntoanexotres">
			<with-param name="UN_ADJUNTO" query-param="UN_ADJUNTO"/>
			<with-param name="UN_COMPANIA" query-param="UN_COMPANIA"/>
			<with-param name="UN_TRAMITE" query-param="UN_TRAMITE"/>
			<with-param name="UN_NUMERO" query-param="UN_NUMERO"/>
			<with-param name="UN_NODO" query-param="UN_NODO"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesCargartramiteQuery"  useConfig="sysmandsunist">
		<sql>SELECT NUMERO_TRAMITE FROM D_TRAMITE_VARIABLES WHERE COMPANIA = :COMPANIA AND VALOR_TEXTO = :NIT</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_TRAMITE":"$NUMERO_TRAMITE(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtramitevariables/cargartramite">
		<call-query href="getDtramitevariablesCargartramiteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesPagHistorialadjuntosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_TRAMITE_VARIABLES.COMPANIA, CODIGO_NODO_VARIABLE, CODIGO_NODO, D_TRAMITE_VARIABLES.TIPO_TRAMITE, NUMERO_TRAMITE, ETIQUETA, CASE WHEN ADJUNTO LIKE '/C001/P'|| D_TRAMITES_GENERADO.PROCESOS||'%' THEN 'true' ELSE 'false' END BLOQUEO, D_TRAMITE_VARIABLES.ADJUNTO  FROM D_TRAMITE_VARIABLES INNER JOIN D_TRAMITES_GENERADO ON D_TRAMITES_GENERADO.COMPANIA = D_TRAMITE_VARIABLES.COMPANIA AND D_TRAMITES_GENERADO.PROCESOS = D_TRAMITE_VARIABLES.CODIGO_PROCESO AND D_TRAMITES_GENERADO.TIPO_TRAMITE = D_TRAMITE_VARIABLES.TIPO_TRAMITE AND D_TRAMITES_GENERADO.NUMERO = D_TRAMITE_VARIABLES.NUMERO_TRAMITE WHERE D_TRAMITES_GENERADO.COMPANIA_GEN = :COMPANIA AND D_TRAMITES_GENERADO.PROCESOS IN (20000,20002) AND D_TRAMITES_GENERADO.TIPO_TRAMITE_GEN = :TIPOTRAMITE AND D_TRAMITES_GENERADO.PROCESOS_GEN = :PROCESO AND D_TRAMITES_GENERADO.NUMERO_GEN = :TRAMITE AND D_TRAMITE_VARIABLES.CODIGO_NODO_VARIABLE IN (019,013,014,020,021,023,024,025,027,033,035,048,029,031,036,055,046,044,051,038,042,049) ORDER BY D_TRAMITE_VARIABLES.CODIGO_NODO) WHERE (CASE WHEN NUMERO_TRAMITE IS NULL THEN ' ' ELSE UPPER(NUMERO_TRAMITE) END)  LIKE UPPER( '%' || :NUMERO_TRAMITE || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN BLOQUEO IS NULL THEN ' ' ELSE UPPER(BLOQUEO) END)  LIKE UPPER(:BLOQUEO || '%')  AND (CASE WHEN ADJUNTO IS NULL THEN ' ' ELSE UPPER(ADJUNTO) END)  LIKE UPPER( '%' || :ADJUNTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_NODO_VARIABLE":"$CODIGO_NODO_VARIABLE","CODIGO_NODO":"$CODIGO_NODO","TIPO_TRAMITE":"$TIPO_TRAMITE","NUMERO_TRAMITE":"$NUMERO_TRAMITE(type:long)","ETIQUETA":"$ETIQUETA","BLOQUEO":"$BLOQUEO","ADJUNTO":"$ADJUNTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRAMITE" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="NUMERO_TRAMITE" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="BLOQUEO" sqlType="STRING"/>
		<param name="ADJUNTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dtramitevariables/historialadjuntos/pag">
		<call-query href="getDtramitevariablesPagHistorialadjuntosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRAMITE" query-param="TIPOTRAMITE"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="NUMERO_TRAMITE" query-param="NUMERO_TRAMITE"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="BLOQUEO" query-param="BLOQUEO"/>
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesNumHistorialadjuntosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_TRAMITE_VARIABLES.COMPANIA, CODIGO_NODO_VARIABLE, CODIGO_NODO, D_TRAMITE_VARIABLES.TIPO_TRAMITE, NUMERO_TRAMITE, ETIQUETA, CASE WHEN ADJUNTO LIKE '/C001/P'|| D_TRAMITES_GENERADO.PROCESOS||'%' THEN 'true' ELSE 'false' END BLOQUEO, D_TRAMITE_VARIABLES.ADJUNTO  FROM D_TRAMITE_VARIABLES INNER JOIN D_TRAMITES_GENERADO ON D_TRAMITES_GENERADO.COMPANIA = D_TRAMITE_VARIABLES.COMPANIA AND D_TRAMITES_GENERADO.PROCESOS = D_TRAMITE_VARIABLES.CODIGO_PROCESO AND D_TRAMITES_GENERADO.TIPO_TRAMITE = D_TRAMITE_VARIABLES.TIPO_TRAMITE AND D_TRAMITES_GENERADO.NUMERO = D_TRAMITE_VARIABLES.NUMERO_TRAMITE WHERE D_TRAMITES_GENERADO.COMPANIA_GEN = :COMPANIA AND D_TRAMITES_GENERADO.PROCESOS IN (20000,20002) AND D_TRAMITES_GENERADO.TIPO_TRAMITE_GEN = :TIPOTRAMITE AND D_TRAMITES_GENERADO.PROCESOS_GEN = :PROCESO AND D_TRAMITES_GENERADO.NUMERO_GEN = :TRAMITE AND D_TRAMITE_VARIABLES.CODIGO_NODO_VARIABLE IN (019,013,014,020,021,023,024,025,027,033,035,048,029,031,036,055,046,044,051,038,042,049) ORDER BY D_TRAMITE_VARIABLES.CODIGO_NODO) WHERE (CASE WHEN NUMERO_TRAMITE IS NULL THEN ' ' ELSE UPPER(NUMERO_TRAMITE) END)  LIKE UPPER( '%' || :NUMERO_TRAMITE || '%')  AND (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN BLOQUEO IS NULL THEN ' ' ELSE UPPER(BLOQUEO) END)  LIKE UPPER(:BLOQUEO || '%')  AND (CASE WHEN ADJUNTO IS NULL THEN ' ' ELSE UPPER(ADJUNTO) END)  LIKE UPPER( '%' || :ADJUNTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRAMITE" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="NUMERO_TRAMITE" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="BLOQUEO" sqlType="STRING"/>
		<param name="ADJUNTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtramitevariables/historialadjuntos/num">
		<call-query href="getDtramitevariablesNumHistorialadjuntosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRAMITE" query-param="TIPOTRAMITE"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="NUMERO_TRAMITE" query-param="NUMERO_TRAMITE"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="BLOQUEO" query-param="BLOQUEO"/>
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , CODIGO_PROCESO , CODIGO_NODO , CODIGO_NODO_VARIABLE, TIPO_TRAMITE , NUMERO_TRAMITE , CONSECUTIVO_TRAMITE , ETIQUETA ,(CASE OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGATORIO, VALOR , VALOR_TEXTO , TO_CHAR(VALOR_FECHA,'DD/MM/YYYY') VALOR_FECHA_STR,(TO_CHAR(VALOR_FECHA,'DD/MM/YYYY HH24:MI:SS')) VALOR_FECHA,(CASE MANEJA_ADJUNTO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_ADJUNTO,(CASE ADJUNTO_OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) ADJUNTO_OBLIGATORIO, ADJUNTO, ADJUNTO ADJUNTO_NOM, TIPO_DATO,OCR,(CASE ADJUNTO_CORREO WHEN 0 THEN 'false' ELSE 'true' END) ADJUNTO_CORREO FROM D_TRAMITE_VARIABLES WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO_NODO = :NODO AND TIPO_TRAMITE = :TIPO_TRAMITE AND NUMERO_TRAMITE = :TRAMITE AND CONSECUTIVO_TRAMITE = :D_TRAMITE ORDER BY CODIGO_NODO_VARIABLE) WHERE (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN OBLIGATORIO IS NULL THEN ' ' ELSE UPPER(OBLIGATORIO) END)  LIKE UPPER( '%' || :OBLIGATORIO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN VALOR_TEXTO IS NULL THEN ' ' ELSE UPPER(VALOR_TEXTO) END)  LIKE UPPER( '%' || :VALOR_TEXTO || '%')  AND (CASE WHEN VALOR_FECHA_STR IS NULL THEN ' ' ELSE UPPER(VALOR_FECHA_STR) END)  LIKE UPPER( '%' || :VALOR_FECHA_STR || '%')  AND (CASE WHEN VALOR_FECHA IS NULL THEN ' ' ELSE UPPER(VALOR_FECHA) END)  LIKE UPPER( '%' || :VALOR_FECHA || '%')  AND (CASE WHEN MANEJA_ADJUNTO IS NULL THEN ' ' ELSE UPPER(MANEJA_ADJUNTO) END)  LIKE UPPER( '%' || :MANEJA_ADJUNTO || '%')  AND (CASE WHEN ADJUNTO_OBLIGATORIO IS NULL THEN ' ' ELSE UPPER(ADJUNTO_OBLIGATORIO) END)  LIKE UPPER( '%' || :ADJUNTO_OBLIGATORIO || '%')  AND (CASE WHEN ADJUNTO IS NULL THEN ' ' ELSE UPPER(ADJUNTO) END)  LIKE UPPER( '%' || :ADJUNTO || '%')  AND (CASE WHEN ADJUNTO_NOM IS NULL THEN ' ' ELSE UPPER(ADJUNTO_NOM) END)  LIKE UPPER( '%' || :ADJUNTO_NOM || '%')  AND (CASE WHEN ADJUNTO_CORREO IS NULL THEN ' ' ELSE UPPER(ADJUNTO_CORREO) END)  LIKE UPPER( '%' || :ADJUNTO_CORREO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_PROCESO":"$CODIGO_PROCESO","CODIGO_NODO":"$CODIGO_NODO","CODIGO_NODO_VARIABLE":"$CODIGO_NODO_VARIABLE","TIPO_TRAMITE":"$TIPO_TRAMITE","NUMERO_TRAMITE":"$NUMERO_TRAMITE(type:long)","CONSECUTIVO_TRAMITE":"$CONSECUTIVO_TRAMITE(type:long)","ETIQUETA":"$ETIQUETA","OBLIGATORIO":"$OBLIGATORIO(type:boolean)","VALOR":"$VALOR","VALOR_TEXTO":"$VALOR_TEXTO","VALOR_FECHA_STR":"$VALOR_FECHA_STR","VALOR_FECHA":"$VALOR_FECHA","MANEJA_ADJUNTO":"$MANEJA_ADJUNTO(type:boolean)","ADJUNTO_OBLIGATORIO":"$ADJUNTO_OBLIGATORIO(type:boolean)","ADJUNTO":"$ADJUNTO","ADJUNTO_NOM":"$ADJUNTO_NOM","TIPO_DATO":"$TIPO_DATO(type:integer)","OCR":"$OCR","ADJUNTO_CORREO":"$ADJUNTO_CORREO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="D_TRAMITE" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="OBLIGATORIO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_TEXTO" sqlType="STRING"/>
		<param name="VALOR_FECHA_STR" sqlType="STRING"/>
		<param name="VALOR_FECHA" sqlType="STRING"/>
		<param name="MANEJA_ADJUNTO" sqlType="STRING"/>
		<param name="ADJUNTO_OBLIGATORIO" sqlType="STRING"/>
		<param name="ADJUNTO" sqlType="STRING"/>
		<param name="ADJUNTO_NOM" sqlType="STRING"/>
		<param name="ADJUNTO_CORREO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dtramitevariables">
		<call-query href="getDtramitevariablesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="D_TRAMITE" query-param="D_TRAMITE"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_TEXTO" query-param="VALOR_TEXTO"/>
			<with-param name="VALOR_FECHA_STR" query-param="VALOR_FECHA_STR"/>
			<with-param name="VALOR_FECHA" query-param="VALOR_FECHA"/>
			<with-param name="MANEJA_ADJUNTO" query-param="MANEJA_ADJUNTO"/>
			<with-param name="ADJUNTO_OBLIGATORIO" query-param="ADJUNTO_OBLIGATORIO"/>
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>
			<with-param name="ADJUNTO_NOM" query-param="ADJUNTO_NOM"/>
			<with-param name="ADJUNTO_CORREO" query-param="ADJUNTO_CORREO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , CODIGO_PROCESO , CODIGO_NODO , CODIGO_NODO_VARIABLE, TIPO_TRAMITE , NUMERO_TRAMITE , CONSECUTIVO_TRAMITE , ETIQUETA ,(CASE OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGATORIO, VALOR , VALOR_TEXTO , TO_CHAR(VALOR_FECHA,'DD/MM/YYYY') VALOR_FECHA_STR,(TO_CHAR(VALOR_FECHA,'DD/MM/YYYY HH24:MI:SS')) VALOR_FECHA,(CASE MANEJA_ADJUNTO WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_ADJUNTO,(CASE ADJUNTO_OBLIGATORIO WHEN 0 THEN 'false' ELSE 'true' END) ADJUNTO_OBLIGATORIO, ADJUNTO, ADJUNTO ADJUNTO_NOM, TIPO_DATO,OCR,(CASE ADJUNTO_CORREO WHEN 0 THEN 'false' ELSE 'true' END) ADJUNTO_CORREO FROM D_TRAMITE_VARIABLES WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO_NODO = :NODO AND TIPO_TRAMITE = :TIPO_TRAMITE AND NUMERO_TRAMITE = :TRAMITE AND CONSECUTIVO_TRAMITE = :D_TRAMITE ORDER BY CODIGO_NODO_VARIABLE) WHERE (CASE WHEN ETIQUETA IS NULL THEN ' ' ELSE UPPER(ETIQUETA) END)  LIKE UPPER( '%' || :ETIQUETA || '%')  AND (CASE WHEN OBLIGATORIO IS NULL THEN ' ' ELSE UPPER(OBLIGATORIO) END)  LIKE UPPER( '%' || :OBLIGATORIO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN VALOR_TEXTO IS NULL THEN ' ' ELSE UPPER(VALOR_TEXTO) END)  LIKE UPPER( '%' || :VALOR_TEXTO || '%')  AND (CASE WHEN VALOR_FECHA_STR IS NULL THEN ' ' ELSE UPPER(VALOR_FECHA_STR) END)  LIKE UPPER( '%' || :VALOR_FECHA_STR || '%')  AND (CASE WHEN VALOR_FECHA IS NULL THEN ' ' ELSE UPPER(VALOR_FECHA) END)  LIKE UPPER( '%' || :VALOR_FECHA || '%')  AND (CASE WHEN MANEJA_ADJUNTO IS NULL THEN ' ' ELSE UPPER(MANEJA_ADJUNTO) END)  LIKE UPPER( '%' || :MANEJA_ADJUNTO || '%')  AND (CASE WHEN ADJUNTO_OBLIGATORIO IS NULL THEN ' ' ELSE UPPER(ADJUNTO_OBLIGATORIO) END)  LIKE UPPER( '%' || :ADJUNTO_OBLIGATORIO || '%')  AND (CASE WHEN ADJUNTO IS NULL THEN ' ' ELSE UPPER(ADJUNTO) END)  LIKE UPPER( '%' || :ADJUNTO || '%')  AND (CASE WHEN ADJUNTO_NOM IS NULL THEN ' ' ELSE UPPER(ADJUNTO_NOM) END)  LIKE UPPER( '%' || :ADJUNTO_NOM || '%')  AND (CASE WHEN ADJUNTO_CORREO IS NULL THEN ' ' ELSE UPPER(ADJUNTO_CORREO) END)  LIKE UPPER( '%' || :ADJUNTO_CORREO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="D_TRAMITE" sqlType="STRING"/>
		<param name="ETIQUETA" sqlType="STRING"/>
		<param name="OBLIGATORIO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_TEXTO" sqlType="STRING"/>
		<param name="VALOR_FECHA_STR" sqlType="STRING"/>
		<param name="VALOR_FECHA" sqlType="STRING"/>
		<param name="MANEJA_ADJUNTO" sqlType="STRING"/>
		<param name="ADJUNTO_OBLIGATORIO" sqlType="STRING"/>
		<param name="ADJUNTO" sqlType="STRING"/>
		<param name="ADJUNTO_NOM" sqlType="STRING"/>
		<param name="ADJUNTO_CORREO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtramitevariables/numero">
		<call-query href="getDtramitevariablesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="D_TRAMITE" query-param="D_TRAMITE"/>
			<with-param name="ETIQUETA" query-param="ETIQUETA"/>
			<with-param name="OBLIGATORIO" query-param="OBLIGATORIO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_TEXTO" query-param="VALOR_TEXTO"/>
			<with-param name="VALOR_FECHA_STR" query-param="VALOR_FECHA_STR"/>
			<with-param name="VALOR_FECHA" query-param="VALOR_FECHA"/>
			<with-param name="MANEJA_ADJUNTO" query-param="MANEJA_ADJUNTO"/>
			<with-param name="ADJUNTO_OBLIGATORIO" query-param="ADJUNTO_OBLIGATORIO"/>
			<with-param name="ADJUNTO" query-param="ADJUNTO"/>
			<with-param name="ADJUNTO_NOM" query-param="ADJUNTO_NOM"/>
			<with-param name="ADJUNTO_CORREO" query-param="ADJUNTO_CORREO"/>

		</call-query>
	</resource>
	<query id="updateDtramitevariables" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_TRAMITE_VARIABLES SET VALOR=:VALOR, VALOR_TEXTO=:VALOR_TEXTO, VALOR_FECHA=TO_DATE(:VALOR_FECHA,'DD/MM/YYYY HH24:MI:SS'), ADJUNTO_CORREO=:ADJUNTO_CORREO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_TRAMITE_VARIABLES.COMPANIA= :KEY_COMPANIA AND D_TRAMITE_VARIABLES.CODIGO_NODO_VARIABLE= :KEY_CODIGO_NODO_VARIABLE AND D_TRAMITE_VARIABLES.CODIGO_NODO= :KEY_CODIGO_NODO AND D_TRAMITE_VARIABLES.CODIGO_PROCESO= :KEY_CODIGO_PROCESO AND D_TRAMITE_VARIABLES.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND D_TRAMITE_VARIABLES.NUMERO_TRAMITE= :KEY_NUMERO_TRAMITE AND D_TRAMITE_VARIABLES.CONSECUTIVO_TRAMITE= :KEY_CONSECUTIVO_TRAMITE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="VALOR_TEXTO" sqlType="STRING"/>
		<param name="VALOR_FECHA" sqlType="STRING"/>
		<param name="ADJUNTO_CORREO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_NODO_VARIABLE" sqlType="STRING"/>
		<param name="KEY_CODIGO_NODO" sqlType="STRING"/>
		<param name="KEY_CODIGO_PROCESO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_NUMERO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_TRAMITE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables">
		<call-query href="updateDtramitevariables">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="VALOR_TEXTO" query-param="VALOR_TEXTO"/>
			<with-param name="VALOR_FECHA" query-param="VALOR_FECHA"/>
			<with-param name="ADJUNTO_CORREO" query-param="ADJUNTO_CORREO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_NODO_VARIABLE" query-param="KEY_CODIGO_NODO_VARIABLE"/>
			<with-param name="KEY_CODIGO_NODO" query-param="KEY_CODIGO_NODO"/>
			<with-param name="KEY_CODIGO_PROCESO" query-param="KEY_CODIGO_PROCESO"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_NUMERO_TRAMITE" query-param="KEY_NUMERO_TRAMITE"/>
			<with-param name="KEY_CONSECUTIVO_TRAMITE" query-param="KEY_CONSECUTIVO_TRAMITE"/>

		</call-query>
	</resource>
	<query id="updateDtramitevariablesAdjuntonuloformato" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE 	D_TRAMITE_VARIABLES SET 	ADJUNTO = CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT('/C', COMPANIA), 'P'), CODIGO_PROCESO), 'T'), TIPO_TRAMITE), 'N'), NUMERO_TRAMITE), 'D'), CODIGO_NODO), 'S'), CONSECUTIVO_TRAMITE), 'V'), CODIGO_NODO_VARIABLE), :FORMATO) WHERE 	COMPANIA = :COMPANIA 	AND CODIGO_PROCESO = :PROCESO 	AND TIPO_TRAMITE = :TIPO_TRAMITE 	AND NUMERO_TRAMITE = :NUMERO 	AND ADJUNTO IS NULL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FORMATO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables/adjuntonuloformato">
		<call-query href="updateDtramitevariablesAdjuntonuloformato">
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesVariblesenviocorreoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DIRECCION, TRAMITE, NOMBRE, EMAIL, TELEFONO, OBSERVACIONES, CARGO_FUNCIONARIO, USUARIO_INTERNO  FROM ( SELECT DTV.CODIGO_NODO_VARIABLE, DTV.NUMERO_TRAMITE TRAMITE, DTV.VALOR_TEXTO, INITCAP(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(U.NOMBRE1,' '),U.NOMBRE2),' '),U.APELLIDO1),' '),U.APELLIDO2)) AS USUARIO_INTERNO FROM D_TRAMITE_VARIABLES DTV INNER JOIN TRAMITES T ON DTV.COMPANIA = T.COMPANIA AND DTV.CODIGO_PROCESO = T.PROCESOS AND DTV.TIPO_TRAMITE = T.TIPO_TRAMITE AND DTV.NUMERO_TRAMITE = T.NUMERO LEFT JOIN USUARIO U ON T.USUARIO_INTERNO = U.CODIGO WHERE DTV.COMPANIA = :COMPANIA AND DTV.CODIGO_PROCESO = :PROCESO AND DTV.CODIGO_NODO = :NODO AND DTV.TIPO_TRAMITE = :TIPO_TRAMITE AND DTV.NUMERO_TRAMITE = :TRAMITE ORDER BY 2 ) TRAMITES PIVOT ( MAX ( VALOR_TEXTO ) FOR CODIGO_NODO_VARIABLE IN ( '006' AS "NOMBRE", '007' AS "EMAIL", '008' AS "DIRECCION", '009' AS "TELEFONO", '017' AS "OBSERVACIONES", '018' AS "CARGO_FUNCIONARIO") )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIRECCION":"$DIRECCION","TRAMITE":"$TRAMITE(type:long)","NOMBRE":"$NOMBRE","EMAIL":"$EMAIL","TELEFONO":"$TELEFONO","OBSERVACIONES":"$OBSERVACIONES","CARGO_FUNCIONARIO":"$CARGO_FUNCIONARIO","USUARIO_INTERNO":"$USUARIO_INTERNO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtramitevariables/variblesenviocorreo">
		<call-query href="getDtramitevariablesVariblesenviocorreoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>

		</call-query>
	</resource>
	<query id="getDtramitevariablesAdjuntoenviocorreoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO_PROCESO, CODIGO_NODO, CODIGO_NODO_VARIABLE, TIPO_TRAMITE, NUMERO_TRAMITE, ETIQUETA, ADJUNTO, SUBSTR(ADJUNTO, INSTR(ADJUNTO, :SEPARADOR, - 1) + 1) ADJUNTO_NOM FROM D_TRAMITE_VARIABLES WHERE COMPANIA = :COMPANIA AND CODIGO_PROCESO = :PROCESO AND CODIGO_NODO = :NODO AND TIPO_TRAMITE = :TIPO_TRAMITE AND NUMERO_TRAMITE = :TRAMITE AND ADJUNTO_CORREO NOT IN (0) ORDER BY ETIQUETA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_PROCESO":"$CODIGO_PROCESO","CODIGO_NODO":"$CODIGO_NODO","CODIGO_NODO_VARIABLE":"$CODIGO_NODO_VARIABLE","TIPO_TRAMITE":"$TIPO_TRAMITE","NUMERO_TRAMITE":"$NUMERO_TRAMITE(type:long)","ETIQUETA":"$ETIQUETA","ADJUNTO":"$ADJUNTO","ADJUNTO_NOM":"$ADJUNTO_NOM"}]}}		</result>
		<param name="SEPARADOR" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dtramitevariables/adjuntoenviocorreo">
		<call-query href="getDtramitevariablesAdjuntoenviocorreoQuery">
			<with-param name="SEPARADOR" query-param="SEPARADOR"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>

		</call-query>
	</resource>
	<query id="updateDtramitevariablesOcrformato" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE 	D_TRAMITE_VARIABLES SET OCR = :OCR WHERE 	COMPANIA = :COMPANIA 	AND CODIGO_PROCESO = :PROCESO 	AND TIPO_TRAMITE = :TIPO_TRAMITE 	AND NUMERO_TRAMITE = :NUMERO 	AND CODIGO_NODO = :NODO 	AND CODIGO_NODO_VARIABLE = :NODO_VAR 	AND CONSECUTIVO_TRAMITE = :CONS_TRAMITE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="OCR" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="NODO_VAR" sqlType="STRING"/>
		<param name="CONS_TRAMITE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dtramitevariables/ocrformato">
		<call-query href="updateDtramitevariablesOcrformato">
			<with-param name="OCR" query-param="OCR"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="NODO_VAR" query-param="NODO_VAR"/>
			<with-param name="CONS_TRAMITE" query-param="CONS_TRAMITE"/>

		</call-query>
	</resource>

</data>