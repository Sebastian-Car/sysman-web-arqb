<data name="ssttransacciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSsttransaccionesPagTerceroInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SST_TRANSACCIONES.CEDULA , TERCERO.NOMBRE  FROM SST_TRANSACCIONES INNER JOIN TERCERO ON SST_TRANSACCIONES.COMPANIA = TERCERO.COMPANIA AND SST_TRANSACCIONES.CEDULA = TERCERO.NIT AND SST_TRANSACCIONES.SUCURSAL = TERCERO.SUCURSAL WHERE SST_TRANSACCIONES.COMPANIA = :COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL ORDER BY SST_TRANSACCIONES.CEDULA) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CEDULA":"$CEDULA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttransacciones/terceroinicial/pag">
		<call-query href="getSsttransaccionesPagTerceroInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionesNumTerceroInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SST_TRANSACCIONES.CEDULA , TERCERO.NOMBRE  FROM SST_TRANSACCIONES INNER JOIN TERCERO ON SST_TRANSACCIONES.COMPANIA = TERCERO.COMPANIA AND SST_TRANSACCIONES.CEDULA = TERCERO.NIT AND SST_TRANSACCIONES.SUCURSAL = TERCERO.SUCURSAL WHERE SST_TRANSACCIONES.COMPANIA = :COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL ORDER BY SST_TRANSACCIONES.CEDULA) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttransacciones/terceroinicial/num">
		<call-query href="getSsttransaccionesNumTerceroInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionesPagTerceroFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SST_TRANSACCIONES.CEDULA , TERCERO.NOMBRE  FROM SST_TRANSACCIONES INNER JOIN TERCERO ON SST_TRANSACCIONES.COMPANIA = TERCERO.COMPANIA AND SST_TRANSACCIONES.CEDULA = TERCERO.NIT AND SST_TRANSACCIONES.SUCURSAL = TERCERO.SUCURSAL WHERE SST_TRANSACCIONES.COMPANIA = :COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL AND SST_TRANSACCIONES.CEDULA &gt;= :TERCEROINICIAL ORDER BY SST_TRANSACCIONES.CEDULA) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CEDULA":"$CEDULA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="TERCEROINICIAL" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttransacciones/tercerofinal/pag">
		<call-query href="getSsttransaccionesPagTerceroFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="TERCEROINICIAL" query-param="TERCEROINICIAL"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionesNumTerceroFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SST_TRANSACCIONES.CEDULA , TERCERO.NOMBRE  FROM SST_TRANSACCIONES INNER JOIN TERCERO ON SST_TRANSACCIONES.COMPANIA = TERCERO.COMPANIA AND SST_TRANSACCIONES.CEDULA = TERCERO.NIT AND SST_TRANSACCIONES.SUCURSAL = TERCERO.SUCURSAL WHERE SST_TRANSACCIONES.COMPANIA = :COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL AND SST_TRANSACCIONES.CEDULA &gt;= :TERCEROINICIAL ORDER BY SST_TRANSACCIONES.CEDULA) WHERE (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="TERCEROINICIAL" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttransacciones/tercerofinal/num">
		<call-query href="getSsttransaccionesNumTerceroFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="TERCEROINICIAL" query-param="TERCEROINICIAL"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertSsttransacciones" keyColumns="COMPANIA,TIPO_TRANSACCION,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_TRANSACCIONES (COMPANIA, TIPO_TRANSACCION, CONSECUTIVO, FECHA, HORA_INICIO, HORA_FIN, CLASE_EVENTO, DESCRIPCION, ID_EMPLEADO, CEDULA, SUCURSAL, TEXTO, RUTA_ANEXOS, CREATED_BY, DATE_CREATED, FECHAINI, FECHAFIN, CLASEINTEGRANTE, CARGOCOMITE, FECHAVINCULACION, FECHADESVINCULACION, COMPROMISOS, LUGAR, TIPO_COBERTURA, COBERTURA, FECHALIMITECOMP, CLASE_AGENTE, AGENTE) VALUES (:COMPANIA, :TIPO_TRANSACCION, :CONSECUTIVO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_INICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_FIN,'DD/MM/YYYY HH24:MI:SS'), :CLASE_EVENTO, :DESCRIPCION, :ID_EMPLEADO, :CEDULA, :SUCURSAL, :TEXTO, :RUTA_ANEXOS, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAINI,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFIN,'DD/MM/YYYY HH24:MI:SS'), :CLASEINTEGRANTE, :CARGOCOMITE, TO_DATE(:FECHAVINCULACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHADESVINCULACION,'DD/MM/YYYY HH24:MI:SS'), :COMPROMISOS, :LUGAR, :TIPO_COBERTURA, :COBERTURA, TO_DATE(:FECHALIMITECOMP,'DD/MM/YYYY HH24:MI:SS'), :CLASE_AGENTE, :AGENTE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA_INICIO" sqlType="STRING"/>
		<param defaultValue="" name="HORA_FIN" sqlType="STRING"/>
		<param name="CLASE_EVENTO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="CEDULA" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="TEXTO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_ANEXOS" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINI" sqlType="STRING"/>
		<param defaultValue="" name="FECHAFIN" sqlType="STRING"/>
		<param defaultValue="" name="CLASEINTEGRANTE" sqlType="STRING"/>
		<param defaultValue="" name="CARGOCOMITE" sqlType="STRING"/>
		<param defaultValue="" name="FECHAVINCULACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHADESVINCULACION" sqlType="STRING"/>
		<param defaultValue="" name="COMPROMISOS" sqlType="STRING"/>
		<param defaultValue="" name="LUGAR" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_COBERTURA" sqlType="STRING"/>
		<param defaultValue="" name="COBERTURA" sqlType="STRING"/>
		<param defaultValue="" name="FECHALIMITECOMP" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_AGENTE" sqlType="STRING"/>
		<param defaultValue="" name="AGENTE" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ssttransacciones">
		<call-query href="insertSsttransacciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA_INICIO" query-param="HORA_INICIO"/>
			<with-param name="HORA_FIN" query-param="HORA_FIN"/>
			<with-param name="CLASE_EVENTO" query-param="CLASE_EVENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TEXTO" query-param="TEXTO"/>
			<with-param name="RUTA_ANEXOS" query-param="RUTA_ANEXOS"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="CLASEINTEGRANTE" query-param="CLASEINTEGRANTE"/>
			<with-param name="CARGOCOMITE" query-param="CARGOCOMITE"/>
			<with-param name="FECHAVINCULACION" query-param="FECHAVINCULACION"/>
			<with-param name="FECHADESVINCULACION" query-param="FECHADESVINCULACION"/>
			<with-param name="COMPROMISOS" query-param="COMPROMISOS"/>
			<with-param name="LUGAR" query-param="LUGAR"/>
			<with-param name="TIPO_COBERTURA" query-param="TIPO_COBERTURA"/>
			<with-param name="COBERTURA" query-param="COBERTURA"/>
			<with-param name="FECHALIMITECOMP" query-param="FECHALIMITECOMP"/>
			<with-param name="CLASE_AGENTE" query-param="CLASE_AGENTE"/>
			<with-param name="AGENTE" query-param="AGENTE"/>

		</call-query>
	</resource>
	<query id="deleteSsttransacciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_TRANSACCIONES WHERE SST_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_TRANSACCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ssttransacciones">
		<call-query href="deleteSsttransacciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_TRANSACCIONES.COMPANIA, SST_TRANSACCIONES.TIPO_TRANSACCION, SST_TRANSACCIONES.CONSECUTIVO,(TO_CHAR(SST_TRANSACCIONES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SST_CLASE_EVENTO.NOMBRE NOMBRE_CLASE_EVENTO, SST_TRANSACCIONES.DESCRIPCION, SST_TRANSACCIONES.CEDULA, UPPER(PERSONAL.NOMBRECOMPLETO) NOMBRECOMPLETO  FROM SST_TRANSACCIONES LEFT JOIN SST_CLASE_EVENTO ON SST_TRANSACCIONES.COMPANIA =SST_CLASE_EVENTO.COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION = SST_CLASE_EVENTO.TIPO_TRANSACCION AND SST_TRANSACCIONES.CLASE_EVENTO =SST_CLASE_EVENTO.CODIGO LEFT JOIN PERSONAL ON SST_TRANSACCIONES.COMPANIA = PERSONAL.COMPANIA AND SST_TRANSACCIONES.ID_EMPLEADO = PERSONAL.ID_DE_EMPLEADO WHERE SST_TRANSACCIONES.COMPANIA = :COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION = :TIPO_TRANSACCION) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NOMBRE_CLASE_EVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CLASE_EVENTO) END)  LIKE UPPER( '%' || :NOMBRE_CLASE_EVENTO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:long)","FECHA":"$FECHA","NOMBRE_CLASE_EVENTO":"$NOMBRE_CLASE_EVENTO","DESCRIPCION":"$DESCRIPCION","CEDULA":"$CEDULA","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE_CLASE_EVENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ssttransacciones">
		<call-query href="getSsttransaccionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NOMBRE_CLASE_EVENTO" query-param="NOMBRE_CLASE_EVENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_TRANSACCIONES.COMPANIA, SST_TRANSACCIONES.TIPO_TRANSACCION, SST_TRANSACCIONES.CONSECUTIVO,(TO_CHAR(SST_TRANSACCIONES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SST_CLASE_EVENTO.NOMBRE NOMBRE_CLASE_EVENTO, SST_TRANSACCIONES.DESCRIPCION, SST_TRANSACCIONES.CEDULA, UPPER(PERSONAL.NOMBRECOMPLETO) NOMBRECOMPLETO  FROM SST_TRANSACCIONES LEFT JOIN SST_CLASE_EVENTO ON SST_TRANSACCIONES.COMPANIA =SST_CLASE_EVENTO.COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION = SST_CLASE_EVENTO.TIPO_TRANSACCION AND SST_TRANSACCIONES.CLASE_EVENTO =SST_CLASE_EVENTO.CODIGO LEFT JOIN PERSONAL ON SST_TRANSACCIONES.COMPANIA = PERSONAL.COMPANIA AND SST_TRANSACCIONES.ID_EMPLEADO = PERSONAL.ID_DE_EMPLEADO WHERE SST_TRANSACCIONES.COMPANIA = :COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION = :TIPO_TRANSACCION) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NOMBRE_CLASE_EVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CLASE_EVENTO) END)  LIKE UPPER( '%' || :NOMBRE_CLASE_EVENTO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN CEDULA IS NULL THEN ' ' ELSE UPPER(CEDULA) END)  LIKE UPPER(:CEDULA || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOMBRE_CLASE_EVENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttransacciones/numero">
		<call-query href="getSsttransaccionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NOMBRE_CLASE_EVENTO" query-param="NOMBRE_CLASE_EVENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="CEDULA" query-param="CEDULA"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>

		</call-query>
	</resource>
	<query id="getSsttransaccionesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SST_TRANSACCIONES.COMPANIA, SST_TRANSACCIONES.TIPO_TRANSACCION, SST_TRANSACCIONES.CONSECUTIVO,(TO_CHAR(SST_TRANSACCIONES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(SST_TRANSACCIONES.HORA_INICIO,'DD/MM/YYYY HH24:MI:SS')) HORA_INICIO,(TO_CHAR(SST_TRANSACCIONES.HORA_FIN,'DD/MM/YYYY HH24:MI:SS')) HORA_FIN, SST_TRANSACCIONES.CLASE_EVENTO, SST_TRANSACCIONES.DESCRIPCION, SST_TRANSACCIONES.ID_EMPLEADO, SST_TRANSACCIONES.CEDULA, SST_TRANSACCIONES.SUCURSAL, SST_TRANSACCIONES.TEXTO, SST_TRANSACCIONES.RUTA_ANEXOS, SST_TRANSACCIONES.CREATED_BY,(TO_CHAR(SST_TRANSACCIONES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SST_TRANSACCIONES.MODIFIED_BY,(TO_CHAR(SST_TRANSACCIONES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(SST_TRANSACCIONES.FECHAINI,'DD/MM/YYYY HH24:MI:SS')) FECHAINI,(TO_CHAR(SST_TRANSACCIONES.FECHAFIN,'DD/MM/YYYY HH24:MI:SS')) FECHAFIN, SST_TRANSACCIONES.CLASEINTEGRANTE, SST_TRANSACCIONES.CARGOCOMITE,(TO_CHAR(SST_TRANSACCIONES.FECHAVINCULACION,'DD/MM/YYYY HH24:MI:SS')) FECHAVINCULACION,(TO_CHAR(SST_TRANSACCIONES.FECHADESVINCULACION,'DD/MM/YYYY HH24:MI:SS')) FECHADESVINCULACION, SST_TRANSACCIONES.COMPROMISOS, CONCAT(NOMBRES,CONCAT(' ',CONCAT(APELLIDO1,CONCAT(' ',APELLIDO2) ) ) ) NOMBRE_COMPLETO, CARGOS.NOMBRE_DEL_CARGO CARGO_ACTUAL, SST_CLASE_EVENTO.NOMBRE NOMBRE_CLASE_EVENTO, SST_TIPO_TRANSACCION.RUTAFORMATO_PLANTILLA, SST_CLASE_TRANSACCION.CODIGO_PLANTILLA, SST_TRANSACCIONES.LUGAR, SST_TRANSACCIONES.TIPO_COBERTURA, SST_TRANSACCIONES.COBERTURA,(TO_CHAR(SST_TRANSACCIONES.FECHALIMITECOMP,'DD/MM/YYYY HH24:MI:SS')) FECHALIMITECOMP, SST_TRANSACCIONES.CLASE_AGENTE, SST_TRANSACCIONES.AGENTE, SST_AGENTES.NOMBRE NOMBREAGENTE FROM SST_TRANSACCIONES LEFT JOIN PERSONAL ON SST_TRANSACCIONES.COMPANIA = PERSONAL.COMPANIA AND SST_TRANSACCIONES.ID_EMPLEADO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN CARGOS ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO LEFT JOIN SST_CLASE_EVENTO ON SST_TRANSACCIONES.COMPANIA = SST_CLASE_EVENTO.COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION = SST_CLASE_EVENTO.TIPO_TRANSACCION AND SST_TRANSACCIONES.CLASE_EVENTO = SST_CLASE_EVENTO.CODIGO INNER JOIN SST_TIPO_TRANSACCION ON SST_TRANSACCIONES.COMPANIA = SST_TIPO_TRANSACCION.COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION = SST_TIPO_TRANSACCION.CODIGO LEFT JOIN SST_CLASE_TRANSACCION ON SST_TIPO_TRANSACCION.CLASE_TRANSACCION = SST_CLASE_TRANSACCION.CODIGO LEFT JOIN SST_AGENTES ON SST_TRANSACCIONES.COMPANIA = SST_AGENTES.COMPANIA AND SST_TRANSACCIONES.CLASE_AGENTE = SST_AGENTES.CLASE AND SST_TRANSACCIONES.AGENTE = SST_AGENTES.CODIGO WHERE SST_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_TRANSACCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:long)","FECHA":"$FECHA","HORA_INICIO":"$HORA_INICIO","HORA_FIN":"$HORA_FIN","CLASE_EVENTO":"$CLASE_EVENTO(type:integer)","DESCRIPCION":"$DESCRIPCION","ID_EMPLEADO":"$ID_EMPLEADO(type:integer)","CEDULA":"$CEDULA","SUCURSAL":"$SUCURSAL","TEXTO":"$TEXTO","RUTA_ANEXOS":"$RUTA_ANEXOS","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","FECHAINI":"$FECHAINI","FECHAFIN":"$FECHAFIN","CLASEINTEGRANTE":"$CLASEINTEGRANTE","CARGOCOMITE":"$CARGOCOMITE","FECHAVINCULACION":"$FECHAVINCULACION","FECHADESVINCULACION":"$FECHADESVINCULACION","COMPROMISOS":"$COMPROMISOS","NOMBRE_COMPLETO":"$NOMBRE_COMPLETO","CARGO_ACTUAL":"$CARGO_ACTUAL","NOMBRE_CLASE_EVENTO":"$NOMBRE_CLASE_EVENTO","RUTAFORMATO_PLANTILLA":"$RUTAFORMATO_PLANTILLA","CODIGO_PLANTILLA":"$CODIGO_PLANTILLA(type:integer)","LUGAR":"$LUGAR","TIPO_COBERTURA":"$TIPO_COBERTURA(type:integer)","COBERTURA":"$COBERTURA","FECHALIMITECOMP":"$FECHALIMITECOMP","CLASE_AGENTE":"$CLASE_AGENTE","AGENTE":"$AGENTE","NOMBREAGENTE":"$NOMBREAGENTE"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ssttransacciones/data">
		<call-query href="getSsttransaccionesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateSsttransacciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_TRANSACCIONES SET COMPANIA=:COMPANIA, TIPO_TRANSACCION=:TIPO_TRANSACCION, CONSECUTIVO=:CONSECUTIVO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), HORA_INICIO=TO_DATE(:HORA_INICIO,'DD/MM/YYYY HH24:MI:SS'), HORA_FIN=TO_DATE(:HORA_FIN,'DD/MM/YYYY HH24:MI:SS'), CLASE_EVENTO=:CLASE_EVENTO, DESCRIPCION=:DESCRIPCION, ID_EMPLEADO=:ID_EMPLEADO, CEDULA=:CEDULA, SUCURSAL=:SUCURSAL, TEXTO=:TEXTO, RUTA_ANEXOS=:RUTA_ANEXOS, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FECHAINI=TO_DATE(:FECHAINI,'DD/MM/YYYY HH24:MI:SS'), FECHAFIN=TO_DATE(:FECHAFIN,'DD/MM/YYYY HH24:MI:SS'), CLASEINTEGRANTE=:CLASEINTEGRANTE, CARGOCOMITE=:CARGOCOMITE, FECHAVINCULACION=TO_DATE(:FECHAVINCULACION,'DD/MM/YYYY HH24:MI:SS'), FECHADESVINCULACION=TO_DATE(:FECHADESVINCULACION,'DD/MM/YYYY HH24:MI:SS'), COMPROMISOS=:COMPROMISOS, LUGAR=:LUGAR, TIPO_COBERTURA=:TIPO_COBERTURA, COBERTURA=:COBERTURA, FECHALIMITECOMP=TO_DATE(:FECHALIMITECOMP,'DD/MM/YYYY HH24:MI:SS'), CLASE_AGENTE=:CLASE_AGENTE, AGENTE=:AGENTE WHERE SST_TRANSACCIONES.COMPANIA= :KEY_COMPANIA AND SST_TRANSACCIONES.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_TRANSACCIONES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA_INICIO" sqlType="STRING"/>
		<param name="HORA_FIN" sqlType="STRING"/>
		<param name="CLASE_EVENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="CEDULA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TEXTO" sqlType="STRING"/>
		<param name="RUTA_ANEXOS" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="CLASEINTEGRANTE" sqlType="STRING"/>
		<param name="CARGOCOMITE" sqlType="STRING"/>
		<param name="FECHAVINCULACION" sqlType="STRING"/>
		<param name="FECHADESVINCULACION" sqlType="STRING"/>
		<param name="COMPROMISOS" sqlType="STRING"/>
		<param name="LUGAR" sqlType="STRING"/>
		<param name="TIPO_COBERTURA" sqlType="STRING"/>
		<param name="COBERTURA" sqlType="STRING"/>
		<param name="FECHALIMITECOMP" sqlType="STRING"/>
		<param name="CLASE_AGENTE" sqlType="STRING"/>
		<param name="AGENTE" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
