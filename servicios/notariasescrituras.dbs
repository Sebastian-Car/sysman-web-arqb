<data name="notariasescrituras" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNotariasescriturasTodosPorNombreCodigoNotariaCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO_NOTARIA, NOMBRE  FROM NOTARIA_ESCRITURA WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO_NOTARIA":"$CODIGO_NOTARIA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="notariasescrituras/todospornombrecodigonotariacompania">
		<call-query href="getNotariasescriturasTodosPorNombreCodigoNotariaCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertNotariasescrituras" keyColumns="COMPANIA,CODIGO_NOTARIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NOTARIA_ESCRITURA (COMPANIA, CODIGO_NOTARIA, NOMBRE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_NOTARIA, :NOMBRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_NOTARIA":"$CODIGO_NOTARIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_NOTARIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="notariasescrituras">
		<call-query href="insertNotariasescrituras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_NOTARIA" query-param="CODIGO_NOTARIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNotariasescrituras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NOTARIA_ESCRITURA WHERE NOTARIA_ESCRITURA.COMPANIA= :KEY_COMPANIA AND NOTARIA_ESCRITURA.CODIGO_NOTARIA= :KEY_CODIGO_NOTARIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_NOTARIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="notariasescrituras">
		<call-query href="deleteNotariasescrituras">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_NOTARIA" query-param="KEY_CODIGO_NOTARIA"/>

		</call-query>
	</resource>
	<query id="getNotariasescriturasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NOTARIA_ESCRITURA.CODIGO_NOTARIA CODIGO, NOTARIA_ESCRITURA.NOMBRE DESCRIPCION  FROM NOTARIA_ESCRITURA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="notariasescrituras">
		<call-query href="getNotariasescriturasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNotariasescriturasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NOTARIA_ESCRITURA.CODIGO_NOTARIA CODIGO, NOTARIA_ESCRITURA.NOMBRE DESCRIPCION  FROM NOTARIA_ESCRITURA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="notariasescrituras/numero">
		<call-query href="getNotariasescriturasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateNotariasescrituras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NOTARIA_ESCRITURA SET NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NOTARIA_ESCRITURA.COMPANIA= :KEY_COMPANIA AND NOTARIA_ESCRITURA.CODIGO_NOTARIA= :KEY_CODIGO_NOTARIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_NOTARIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="notariasescrituras">
		<call-query href="updateNotariasescrituras">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_NOTARIA" query-param="KEY_CODIGO_NOTARIA"/>

		</call-query>
	</resource>

</data>