<data name="vfondodepensionvol" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVfondodepensionvolTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID_DEL_FONDO, NOMBRE_DEL_FONDO  FROM V_FONDO_DE_PENSION_VOL WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DEL_FONDO":"$ID_DEL_FONDO","NOMBRE_DEL_FONDO":"$NOMBRE_DEL_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vfondodepensionvol/todosporcompania">
		<call-query href="getVfondodepensionvolTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>