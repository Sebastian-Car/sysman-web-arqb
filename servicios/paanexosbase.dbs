<data name="paanexosbase" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updatePaanexosbaseUpdatedebeeliminar" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PA_ANEXOS_BASE SET DEBE_ELIMINAR=:DEBE_ELIMINAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PA_ANEXOS_BASE.COMPANIA= :KEY_COMPANIA AND PA_ANEXOS_BASE.TIPO= :KEY_TIPO AND PA_ANEXOS_BASE.NUMERO= :KEY_NUMERO AND PA_ANEXOS_BASE.ID_PLAN= :KEY_ID_PLAN AND PA_ANEXOS_BASE.CODIGO= :KEY_CODIGO AND PA_ANEXOS_BASE.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="paanexosbase/updatedebeeliminar">
		<call-query href="updatePaanexosbaseUpdatedebeeliminar">
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="insertPaanexosbase" keyColumns="COMPANIA,TIPO,NUMERO,ID_PLAN,CODIGO,VIGENCIA_INICIAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PA_ANEXOS_BASE (COMPANIA, TIPO, NUMERO, ID_PLAN, CODIGO, VIGENCIA_INICIAL, RUTA_FIN, ES_NUEVO, DEBE_ELIMINAR, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :TIPO, :NUMERO, :ID_PLAN, :CODIGO, :VIGENCIA_INICIAL, :RUTA_FIN, :ES_NUEVO, :DEBE_ELIMINAR, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_CODIGO":"$CODIGO","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_FIN" sqlType="STRING"/>
		<param defaultValue="" name="ES_NUEVO" sqlType="STRING"/>
		<param defaultValue="" name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="paanexosbase">
		<call-query href="insertPaanexosbase">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="RUTA_FIN" query-param="RUTA_FIN"/>
			<with-param name="ES_NUEVO" query-param="ES_NUEVO"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="getPaanexosbasePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, TIPO, NUMERO, ID_PLAN, CODIGO, VIGENCIA_INICIAL, RUTA_FIN, ES_NUEVO, DEBE_ELIMINAR FROM PA_ANEXOS_BASE WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND ID_PLAN = :ID_PLAN AND DEBE_ELIMINAR IN (0)) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_PLAN), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIA_INICIAL), '%')) AND (CASE WHEN RUTA_FIN IS NULL THEN ' ' ELSE UPPER(RUTA_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:RUTA_FIN), '%')) AND (CASE WHEN ES_NUEVO IS NULL THEN ' ' ELSE UPPER(ES_NUEVO) END) LIKE UPPER(CONCAT(CONCAT('%',:ES_NUEVO), '%')) AND (CASE WHEN DEBE_ELIMINAR IS NULL THEN ' ' ELSE UPPER(DEBE_ELIMINAR) END) LIKE UPPER(CONCAT(CONCAT('%',:DEBE_ELIMINAR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:integer)","ID_PLAN":"$ID_PLAN","CODIGO":"$CODIGO","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","RUTA_FIN":"$RUTA_FIN","ES_NUEVO":"$ES_NUEVO(type:integer)","DEBE_ELIMINAR":"$DEBE_ELIMINAR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="RUTA_FIN" sqlType="STRING"/>
		<param name="ES_NUEVO" sqlType="STRING"/>
		<param name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="paanexosbase">
		<call-query href="getPaanexosbasePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="RUTA_FIN" query-param="RUTA_FIN"/>
			<with-param name="ES_NUEVO" query-param="ES_NUEVO"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPaanexosbaseNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, TIPO, NUMERO, ID_PLAN, CODIGO, VIGENCIA_INICIAL, RUTA_FIN, ES_NUEVO, DEBE_ELIMINAR FROM PA_ANEXOS_BASE WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND ID_PLAN = :ID_PLAN AND DEBE_ELIMINAR IN (0)) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_PLAN), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN VIGENCIA_INICIAL IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIA_INICIAL), '%')) AND (CASE WHEN RUTA_FIN IS NULL THEN ' ' ELSE UPPER(RUTA_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:RUTA_FIN), '%')) AND (CASE WHEN ES_NUEVO IS NULL THEN ' ' ELSE UPPER(ES_NUEVO) END) LIKE UPPER(CONCAT(CONCAT('%',:ES_NUEVO), '%')) AND (CASE WHEN DEBE_ELIMINAR IS NULL THEN ' ' ELSE UPPER(DEBE_ELIMINAR) END) LIKE UPPER(CONCAT(CONCAT('%',:DEBE_ELIMINAR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="RUTA_FIN" sqlType="STRING"/>
		<param name="ES_NUEVO" sqlType="STRING"/>
		<param name="DEBE_ELIMINAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="paanexosbase/numero">
		<call-query href="getPaanexosbaseNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="RUTA_FIN" query-param="RUTA_FIN"/>
			<with-param name="ES_NUEVO" query-param="ES_NUEVO"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>

		</call-query>
	</resource>
	<query id="getPaanexosbaseRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPO, NUMERO, ID_PLAN, CODIGO, RUTA_INI, CREATED_BY, VIGENCIA_INICIAL, MODIFIED_BY, RUTA_FIN, ES_NUEVO, DEBE_ELIMINAR,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PA_ANEXOS_BASE WHERE PA_ANEXOS_BASE.COMPANIA= :KEY_COMPANIA AND PA_ANEXOS_BASE.TIPO= :KEY_TIPO AND PA_ANEXOS_BASE.NUMERO= :KEY_NUMERO AND PA_ANEXOS_BASE.ID_PLAN= :KEY_ID_PLAN AND PA_ANEXOS_BASE.CODIGO= :KEY_CODIGO AND PA_ANEXOS_BASE.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:integer)","ID_PLAN":"$ID_PLAN","CODIGO":"$CODIGO","RUTA_INI":"$RUTA_INI","CREATED_BY":"$CREATED_BY","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","MODIFIED_BY":"$MODIFIED_BY","RUTA_FIN":"$RUTA_FIN","ES_NUEVO":"$ES_NUEVO(type:integer)","DEBE_ELIMINAR":"$DEBE_ELIMINAR(type:integer)","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="paanexosbase/data">
		<call-query href="getPaanexosbaseRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>

		</call-query>
	</resource>
	<query id="updatePaanexosbase" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PA_ANEXOS_BASE SET COMPANIA=:COMPANIA, TIPO=:TIPO, NUMERO=:NUMERO, ID_PLAN=:ID_PLAN, CODIGO=:CODIGO, RUTA_INI=:RUTA_INI, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, MODIFIED_BY=:MODIFIED_BY, RUTA_FIN=:RUTA_FIN, ES_NUEVO=:ES_NUEVO, DEBE_ELIMINAR=:DEBE_ELIMINAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE PA_ANEXOS_BASE.COMPANIA= :KEY_COMPANIA AND PA_ANEXOS_BASE.TIPO= :KEY_TIPO AND PA_ANEXOS_BASE.NUMERO= :KEY_NUMERO AND PA_ANEXOS_BASE.ID_PLAN= :KEY_ID_PLAN AND PA_ANEXOS_BASE.CODIGO= :KEY_CODIGO AND PA_ANEXOS_BASE.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="RUTA_INI" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="RUTA_FIN" sqlType="STRING"/>
		<param name="ES_NUEVO" sqlType="STRING"/>
		<param name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="paanexosbase">
		<call-query href="updatePaanexosbase">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="RUTA_INI" query-param="RUTA_INI"/>
			<with-param name="VIGENCIA_INICIAL" query-param="VIGENCIA_INICIAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="RUTA_FIN" query-param="RUTA_FIN"/>
			<with-param name="ES_NUEVO" query-param="ES_NUEVO"/>
			<with-param name="DEBE_ELIMINAR" query-param="DEBE_ELIMINAR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_VIGENCIA_INICIAL" query-param="KEY_VIGENCIA_INICIAL"/>

		</call-query>
	</resource>

</data>