		</call-query>
	</resource>
	<query id="getVpnormaurbanisticaPagNormaurbanisticafinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VP_NORMA_URBANISTICA.COMPANIA, VP_NORMA_URBANISTICA.ID, VPD1.NOMBRE NOMBRE_TRATAMIENTO, VPD2.NOMBRE NOMBRE_ACTIVIDAD, VPD3.NOMBRE NOMBRE_USO_SUELO, VP_NORMA_URBANISTICA.INDICE_OCUPACION, VP_NORMA_URBANISTICA.VOLADIZO, VP_NORMA_URBANISTICA.NUMERO_PISOS, VP_NORMA_URBANISTICA.ALTILLO  FROM VP_NORMA_URBANISTICA LEFT JOIN VP_DOMINIOS VPD1 ON VP_NORMA_URBANISTICA.TRATAMIENTO = VPD1.CODIGO LEFT JOIN VP_DOMINIOS VPD2 ON VP_NORMA_URBANISTICA.ACTIVIDAD = VPD2.CODIGO LEFT JOIN VP_DOMINIOS VPD3 ON VP_NORMA_URBANISTICA.USO_SUELO = VPD3.CODIGO WHERE VP_NORMA_URBANISTICA.COMPANIA = :COMPANIA AND VP_NORMA_URBANISTICA.ID NOT IN :ACUERDO_INICIAL ORDER BY VP_NORMA_URBANISTICA.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE_TRATAMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TRATAMIENTO) END)  LIKE UPPER( '%' || :NOMBRE_TRATAMIENTO || '%')  AND (CASE WHEN NOMBRE_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBRE_ACTIVIDAD || '%')  AND (CASE WHEN NOMBRE_USO_SUELO IS NULL THEN ' ' ELSE UPPER(NOMBRE_USO_SUELO) END)  LIKE UPPER( '%' || :NOMBRE_USO_SUELO || '%')  AND (CASE WHEN INDICE_OCUPACION IS NULL THEN ' ' ELSE UPPER(INDICE_OCUPACION) END)  LIKE UPPER( '%' || :INDICE_OCUPACION || '%')  AND (CASE WHEN VOLADIZO IS NULL THEN ' ' ELSE UPPER(VOLADIZO) END)  LIKE UPPER( '%' || :VOLADIZO || '%')  AND (CASE WHEN NUMERO_PISOS IS NULL THEN ' ' ELSE UPPER(NUMERO_PISOS) END)  LIKE UPPER( '%' || :NUMERO_PISOS || '%')  AND (CASE WHEN ALTILLO IS NULL THEN ' ' ELSE UPPER(ALTILLO) END)  LIKE UPPER( '%' || :ALTILLO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID(type:long)","NOMBRE_TRATAMIENTO":"$NOMBRE_TRATAMIENTO","NOMBRE_ACTIVIDAD":"$NOMBRE_ACTIVIDAD","NOMBRE_USO_SUELO":"$NOMBRE_USO_SUELO","INDICE_OCUPACION":"$INDICE_OCUPACION","VOLADIZO":"$VOLADIZO","NUMERO_PISOS":"$NUMERO_PISOS(type:long)","ALTILLO":"$ALTILLO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACUERDO_INICIAL" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE_TRATAMIENTO" sqlType="STRING"/>
