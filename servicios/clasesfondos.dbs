<data name="clasesfondos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getClasesfondosNombreFondoPorClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASEFONDO.ID, FONDO.NOMBRE_FONDO FROM CLASEFONDO INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE CLASEFONDO.COMPANIA = :COMPANIA AND CLASEFONDO.CLASE = :CLASE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE_FONDO":"$NOMBRE_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesfondos/nombrefondoporclase">
		<call-query href="getClasesfondosNombreFondoPorClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="getClasesfondosPagIdnombrefondoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CLASEFONDO.ID, FONDO.NOMBRE_FONDO  FROM CLASEFONDO INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE CLASEFONDO.COMPANIA = :COMPANIA ORDER BY CLASEFONDO.ID_DE_FONDO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE_FONDO":"$NOMBRE_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="clasesfondos/idnombrefondo/pag">
		<call-query href="getClasesfondosPagIdnombrefondoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClasesfondosNumIdnombrefondoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CLASEFONDO.ID, FONDO.NOMBRE_FONDO  FROM CLASEFONDO INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE CLASEFONDO.COMPANIA = :COMPANIA ORDER BY CLASEFONDO.ID_DE_FONDO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesfondos/idnombrefondo/num">
		<call-query href="getClasesfondosNumIdnombrefondoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>

		</call-query>
	</resource>
	<query id="getClasesfondosPagIdnombrefondoporclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CLASEFONDO.ID, FONDO.NOMBRE_FONDO  FROM CLASEFONDO INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE CLASEFONDO.COMPANIA = :COMPANIA AND CLASEFONDO.CLASE = :CLASE ORDER BY CLASEFONDO.ID_DE_FONDO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE_FONDO":"$NOMBRE_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="clasesfondos/idnombrefondoporclase/pag">
		<call-query href="getClasesfondosPagIdnombrefondoporclaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClasesfondosNumIdnombrefondoporclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CLASEFONDO.ID, FONDO.NOMBRE_FONDO  FROM CLASEFONDO INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE CLASEFONDO.COMPANIA = :COMPANIA AND CLASEFONDO.CLASE = :CLASE ORDER BY CLASEFONDO.ID_DE_FONDO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesfondos/idnombrefondoporclase/num">
		<call-query href="getClasesfondosNumIdnombrefondoporclaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>

		</call-query>
	</resource>
	<query id="getClasesfondosFondoporclaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASEFONDO.ID, CLASEFONDO.COMPANIA, CLASEFONDO.CLASE, CLASEFONDO.ID_DE_FONDO , CLASEDEFONDO.NOMBRE AS NOMBRE_CLASEFONDO  FROM CLASEFONDO INNER JOIN CLASEDEFONDO ON CLASEFONDO.CLASE = CLASEDEFONDO.CODIGO WHERE COMPANIA = :COMPANIA AND ID_DE_FONDO = :FONDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","COMPANIA":"$COMPANIA","CLASE":"$CLASE","ID_DE_FONDO":"$ID_DE_FONDO","NOMBRE_CLASEFONDO":"$NOMBRE_CLASEFONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesfondos/fondoporclase">
		<call-query href="getClasesfondosFondoporclaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FONDO" query-param="FONDO"/>

		</call-query>
	</resource>
	<query id="insertClasesfondosAgregarfondo" keyColumns="COMPANIA,ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CLASEFONDO (COMPANIA, CLASE, ID_DE_FONDO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASE, :ID_DE_FONDO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID":"$ID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID_DE_FONDO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="clasesfondos/agregarfondo">
		<call-query href="insertClasesfondosAgregarfondo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID_DE_FONDO" query-param="ID_DE_FONDO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteClasesfondosFondosubform" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CLASEFONDO WHERE COMPANIA = :KEY_COMPANIA AND ID = :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="clasesfondos/fondosubform">
		<call-query href="deleteClasesfondosFondosubform">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateClasesfondosFondosubforedit" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CLASEFONDO SET CLASE=:CLASE, ID_DE_FONDO=:ID_DE_FONDO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CLASEFONDO.COMPANIA= :KEY_COMPANIA AND CLASEFONDO.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CLASE" sqlType="STRING"/>
		<param name="ID_DE_FONDO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="clasesfondos/fondosubforedit">
		<call-query href="updateClasesfondosFondosubforedit">
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ID_DE_FONDO" query-param="ID_DE_FONDO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getClasesfondosPagCodigo,claseYFondoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CLASEFONDO.ID , CLASEFONDO.CLASE, FONDO.NOMBRE_FONDO FROM CLASEFONDO INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE CLASEFONDO.COMPANIA = :COMPANIA AND CLASEFONDO.CLASE ='SIN' ORDER BY FONDO.NOMBRE_FONDO, CLASEFONDO.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE), '%')) AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FONDO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CLASE":"$CLASE","NOMBRE_FONDO":"$NOMBRE_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="clasesfondos/codigo,claseyfondo/pag">
		<call-query href="getClasesfondosPagCodigo,claseYFondoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClasesfondosNumCodigo,claseYFondoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CLASEFONDO.ID , CLASEFONDO.CLASE, FONDO.NOMBRE_FONDO FROM CLASEFONDO INNER JOIN FONDO ON CLASEFONDO.COMPANIA = FONDO.COMPANIA AND CLASEFONDO.ID_DE_FONDO = FONDO.ID_DE_FONDO WHERE CLASEFONDO.COMPANIA = :COMPANIA AND CLASEFONDO.CLASE ='SIN' ORDER BY FONDO.NOMBRE_FONDO, CLASEFONDO.ID) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE), '%')) AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FONDO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesfondos/codigo,claseyfondo/num">
		<call-query href="getClasesfondosNumCodigo,claseYFondoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>

		</call-query>
	</resource>

</data>