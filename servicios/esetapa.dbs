<data name="esetapa" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsetapaPagCodetapaynombreporcontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COD_ETAPA, NOMBRE, COD_T_CONTRATO  FROM ES_ETAPA WHERE COMPANIA = :COMPANIA AND COD_T_CONTRATO = :TIPOCONTRATO) WHERE (CASE WHEN COD_ETAPA IS NULL THEN ' ' ELSE UPPER(COD_ETAPA) END)  LIKE UPPER(:COD_ETAPA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END)  LIKE UPPER(:COD_T_CONTRATO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_ETAPA":"$COD_ETAPA(type:integer)","NOMBRE":"$NOMBRE","COD_T_CONTRATO":"$COD_T_CONTRATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="COD_ETAPA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esetapa/codetapaynombreporcontrato/pag">
		<call-query href="getEsetapaPagCodetapaynombreporcontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="COD_ETAPA" query-param="COD_ETAPA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsetapaNumCodetapaynombreporcontratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COD_ETAPA, NOMBRE, COD_T_CONTRATO  FROM ES_ETAPA WHERE COMPANIA = :COMPANIA AND COD_T_CONTRATO = :TIPOCONTRATO) WHERE (CASE WHEN COD_ETAPA IS NULL THEN ' ' ELSE UPPER(COD_ETAPA) END)  LIKE UPPER(:COD_ETAPA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END)  LIKE UPPER(:COD_T_CONTRATO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="COD_ETAPA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esetapa/codetapaynombreporcontrato/num">
		<call-query href="getEsetapaNumCodetapaynombreporcontratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="COD_ETAPA" query-param="COD_ETAPA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>

		</call-query>
	</resource>
	<query id="insertEsetapa" keyColumns="COMPANIA,COD_ETAPA,COD_T_CONTRATO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_ETAPA (COMPANIA, COD_ETAPA, COD_T_CONTRATO, NOMBRE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_ETAPA, :COD_T_CONTRATO, :NOMBRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ETAPA":"$COD_ETAPA(type:integer)","KEY_COD_T_CONTRATO":"$COD_T_CONTRATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ETAPA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esetapa">
		<call-query href="insertEsetapa">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ETAPA" query-param="COD_ETAPA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsetapa" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_ETAPA WHERE ES_ETAPA.COMPANIA= :KEY_COMPANIA AND ES_ETAPA.COD_ETAPA= :KEY_COD_ETAPA AND ES_ETAPA.COD_T_CONTRATO= :KEY_COD_T_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ETAPA" sqlType="INTEGER"/>
		<param name="KEY_COD_T_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="esetapa">
		<call-query href="deleteEsetapa">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ETAPA" query-param="KEY_COD_ETAPA"/>
			<with-param name="KEY_COD_T_CONTRATO" query-param="KEY_COD_T_CONTRATO"/>

		</call-query>
	</resource>
	<query id="getEsetapaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, COD_ETAPA, COD_T_CONTRATO, NOMBRE  FROM ES_ETAPA WHERE COMPANIA = :COMPANIA AND COD_T_CONTRATO = :TIPO) WHERE (CASE WHEN COD_ETAPA IS NULL THEN ' ' ELSE UPPER(COD_ETAPA) END)  LIKE UPPER(:COD_ETAPA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ETAPA":"$COD_ETAPA(type:integer)","COD_T_CONTRATO":"$COD_T_CONTRATO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COD_ETAPA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esetapa">
		<call-query href="getEsetapaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COD_ETAPA" query-param="COD_ETAPA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsetapaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, COD_ETAPA, COD_T_CONTRATO, NOMBRE  FROM ES_ETAPA WHERE COMPANIA = :COMPANIA AND COD_T_CONTRATO = :TIPO) WHERE (CASE WHEN COD_ETAPA IS NULL THEN ' ' ELSE UPPER(COD_ETAPA) END)  LIKE UPPER(:COD_ETAPA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COD_ETAPA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esetapa/numero">
		<call-query href="getEsetapaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COD_ETAPA" query-param="COD_ETAPA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateEsetapa" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ETAPA SET COD_ETAPA=:COD_ETAPA, NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_ETAPA.COMPANIA= :KEY_COMPANIA AND ES_ETAPA.COD_ETAPA= :KEY_COD_ETAPA AND ES_ETAPA.COD_T_CONTRATO= :KEY_COD_T_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COD_ETAPA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ETAPA" sqlType="STRING"/>
		<param name="KEY_COD_T_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esetapa">
		<call-query href="updateEsetapa">
			<with-param name="COD_ETAPA" query-param="COD_ETAPA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ETAPA" query-param="KEY_COD_ETAPA"/>
			<with-param name="KEY_COD_T_CONTRATO" query-param="KEY_COD_T_CONTRATO"/>

		</call-query>
	</resource>

</data>