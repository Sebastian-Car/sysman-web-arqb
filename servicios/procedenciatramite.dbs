<data name="procedenciatramite" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getProcedenciatramiteCodnombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO ,NOMBRE  FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/codnombre">
		<call-query href="getProcedenciatramiteCodnombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE, DIRECCION  FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/todos">
		<call-query href="getProcedenciatramiteTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramitePagCodigonombreyterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PROCEDENCIA_TRAMITE.CODIGO, PROCEDENCIA_TRAMITE.NOMBRE, PROCEDENCIA_TRAMITE.NIT, TERCERO.NOMBRE AS NOMBRETERCERO, PROCEDENCIA_TRAMITE.DIRECCION FROM PROCEDENCIA_TRAMITE INNER JOIN TERCERO ON PROCEDENCIA_TRAMITE.COMPANIA = TERCERO.COMPANIA AND PROCEDENCIA_TRAMITE.NIT = TERCERO.NIT AND PROCEDENCIA_TRAMITE.SUCURSAL = TERCERO.SUCURSAL WHERE PROCEDENCIA_TRAMITE.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NIT":"$NIT","NOMBRETERCERO":"$NOMBRETERCERO","DIRECCION":"$DIRECCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procedenciatramite/codigonombreytercero/pag">
		<call-query href="getProcedenciatramitePagCodigonombreyterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteNumCodigonombreyterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PROCEDENCIA_TRAMITE.CODIGO, PROCEDENCIA_TRAMITE.NOMBRE, PROCEDENCIA_TRAMITE.NIT, TERCERO.NOMBRE AS NOMBRETERCERO, PROCEDENCIA_TRAMITE.DIRECCION FROM PROCEDENCIA_TRAMITE INNER JOIN TERCERO ON PROCEDENCIA_TRAMITE.COMPANIA = TERCERO.COMPANIA AND PROCEDENCIA_TRAMITE.NIT = TERCERO.NIT AND PROCEDENCIA_TRAMITE.SUCURSAL = TERCERO.SUCURSAL WHERE PROCEDENCIA_TRAMITE.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/codigonombreytercero/num">
		<call-query href="getProcedenciatramiteNumCodigonombreyterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramitePagCodigonombredocumentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PROCEDENCIA_TRAMITE.CODIGO, PROCEDENCIA_TRAMITE.NOMBRE, NVL(PROCEDENCIA_TRAMITE.DOCUMENTO, PROCEDENCIA_TRAMITE.NIT) AS NIT, TERCERO.NOMBRE AS NOMBRETERCERO, PROCEDENCIA_TRAMITE.DIRECCION FROM PROCEDENCIA_TRAMITE INNER JOIN TERCERO ON PROCEDENCIA_TRAMITE.COMPANIA = TERCERO.COMPANIA AND PROCEDENCIA_TRAMITE.NIT = TERCERO.NIT AND PROCEDENCIA_TRAMITE.SUCURSAL = TERCERO.SUCURSAL WHERE PROCEDENCIA_TRAMITE.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(CONCAT('%',:NIT), '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NIT":"$NIT","NOMBRETERCERO":"$NOMBRETERCERO","DIRECCION":"$DIRECCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procedenciatramite/codigonombredocumento/pag">
		<call-query href="getProcedenciatramitePagCodigonombredocumentoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteNumCodigonombredocumentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PROCEDENCIA_TRAMITE.CODIGO, PROCEDENCIA_TRAMITE.NOMBRE, NVL(PROCEDENCIA_TRAMITE.DOCUMENTO, PROCEDENCIA_TRAMITE.NIT) AS NIT, TERCERO.NOMBRE AS NOMBRETERCERO, PROCEDENCIA_TRAMITE.DIRECCION FROM PROCEDENCIA_TRAMITE INNER JOIN TERCERO ON PROCEDENCIA_TRAMITE.COMPANIA = TERCERO.COMPANIA AND PROCEDENCIA_TRAMITE.NIT = TERCERO.NIT AND PROCEDENCIA_TRAMITE.SUCURSAL = TERCERO.SUCURSAL WHERE PROCEDENCIA_TRAMITE.COMPANIA = :COMPANIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(CONCAT('%',:NIT), '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/codigonombredocumento/num">
		<call-query href="getProcedenciatramiteNumCodigonombredocumentoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteValidarnitunicoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT('X') EXISTE FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA AND DOCUMENTO = :NIT AND DOCUMENTO NOT IN ('0') AND CODIGO NOT IN (:CODIGO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/validarnitunico">
		<call-query href="getProcedenciatramiteValidarnitunicoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramitePagDocumentonombreinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT DOCUMENTO, NOMBRE FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA AND DOCUMENTO IS NOT NULL ORDER BY DOCUMENTO) INI WHERE (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END) LIKE UPPER(CONCAT(:DOCUMENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCUMENTO":"$DOCUMENTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procedenciatramite/documentonombreinicial/pag">
		<call-query href="getProcedenciatramitePagDocumentonombreinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteNumDocumentonombreinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT DOCUMENTO, NOMBRE FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA AND DOCUMENTO IS NOT NULL ORDER BY DOCUMENTO) INI WHERE (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END) LIKE UPPER(CONCAT(:DOCUMENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/documentonombreinicial/num">
		<call-query href="getProcedenciatramiteNumDocumentonombreinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertProcedenciatramite" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PROCEDENCIA_TRAMITE (COMPANIA, CODIGO, NOMBRE, DIRECCIONE_MAIL, DIRECCION, NIT, SUCURSAL, REPRESENTANTELEGAL, SUCURSAL_REPRESENTANTE, PUBLICO, EXTERNO, CONTRATISTA, TELEFONO, DOCUMENTO, CONTACTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :NOMBRE, :DIRECCIONE_MAIL, :DIRECCION, :NIT, :SUCURSAL, :REPRESENTANTELEGAL, :SUCURSAL_REPRESENTANTE, :PUBLICO, :EXTERNO, :CONTRATISTA, :TELEFONO, :DOCUMENTO, :CONTACTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCIONE_MAIL" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NIT" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="REPRESENTANTELEGAL" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL_REPRESENTANTE" sqlType="STRING"/>
		<param defaultValue="0" name="PUBLICO" sqlType="STRING"/>
		<param defaultValue="0" name="EXTERNO" sqlType="STRING"/>
		<param defaultValue="0" name="CONTRATISTA" sqlType="STRING"/>
		<param defaultValue="" name="TELEFONO" sqlType="STRING"/>
		<param defaultValue="" name="DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="CONTACTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="procedenciatramite">
		<call-query href="insertProcedenciatramite">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCIONE_MAIL" query-param="DIRECCIONE_MAIL"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="REPRESENTANTELEGAL" query-param="REPRESENTANTELEGAL"/>
			<with-param name="SUCURSAL_REPRESENTANTE" query-param="SUCURSAL_REPRESENTANTE"/>
			<with-param name="PUBLICO" query-param="PUBLICO"/>
			<with-param name="EXTERNO" query-param="EXTERNO"/>
			<with-param name="CONTRATISTA" query-param="CONTRATISTA"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="CONTACTO" query-param="CONTACTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteProcedenciatramite" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PROCEDENCIA_TRAMITE WHERE PROCEDENCIA_TRAMITE.COMPANIA= :KEY_COMPANIA AND PROCEDENCIA_TRAMITE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="procedenciatramite">
		<call-query href="deleteProcedenciatramite">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramitePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, NIT, DOCUMENTO  FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END)  LIKE UPPER(:DOCUMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NIT":"$NIT","DOCUMENTO":"$DOCUMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procedenciatramite">
		<call-query href="getProcedenciatramitePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, NOMBRE, NIT, DOCUMENTO  FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER(:NIT || '%')  AND (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END)  LIKE UPPER(:DOCUMENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/numero">
		<call-query href="getProcedenciatramiteNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT PROCEDENCIA_TRAMITE.COMPANIA, PROCEDENCIA_TRAMITE.CODIGO, TERCERO.NOMBRE AS NOMBRENIT, REPRESENTANTE.NOMBRE AS NOMBREREPRE, PROCEDENCIA_TRAMITE.NOMBRE, PROCEDENCIA_TRAMITE.DIRECCIONE_MAIL, PROCEDENCIA_TRAMITE.DIRECCION, PROCEDENCIA_TRAMITE.NIT, TERCERO.SUCURSAL, PROCEDENCIA_TRAMITE.REPRESENTANTELEGAL, PROCEDENCIA_TRAMITE.SUCURSAL_REPRESENTANTE,(CASE PROCEDENCIA_TRAMITE.PUBLICO WHEN 0 THEN 'false' ELSE 'true' END) PUBLICO,(CASE PROCEDENCIA_TRAMITE.EXTERNO WHEN 0 THEN 'false' ELSE 'true' END) EXTERNO,(CASE PROCEDENCIA_TRAMITE.CONTRATISTA WHEN 0 THEN 'false' ELSE 'true' END) CONTRATISTA, PROCEDENCIA_TRAMITE.TELEFONO, PROCEDENCIA_TRAMITE.CREATED_BY, PROCEDENCIA_TRAMITE.MODIFIED_BY,(TO_CHAR(PROCEDENCIA_TRAMITE.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(PROCEDENCIA_TRAMITE.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, PROCEDENCIA_TRAMITE.DOCUMENTO, PROCEDENCIA_TRAMITE.CONTACTO FROM PROCEDENCIA_TRAMITE INNER JOIN TERCERO ON PROCEDENCIA_TRAMITE.COMPANIA = TERCERO.COMPANIA AND PROCEDENCIA_TRAMITE.NIT = TERCERO.NIT AND PROCEDENCIA_TRAMITE.SUCURSAL = TERCERO.SUCURSAL INNER JOIN TERCERO REPRESENTANTE ON PROCEDENCIA_TRAMITE.COMPANIA = REPRESENTANTE.COMPANIA AND PROCEDENCIA_TRAMITE.REPRESENTANTELEGAL = REPRESENTANTE.NIT AND PROCEDENCIA_TRAMITE.SUCURSAL_REPRESENTANTE = REPRESENTANTE.SUCURSAL WHERE PROCEDENCIA_TRAMITE.COMPANIA= :KEY_COMPANIA AND PROCEDENCIA_TRAMITE.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRENIT":"$NOMBRENIT","NOMBREREPRE":"$NOMBREREPRE","NOMBRE":"$NOMBRE","DIRECCIONE_MAIL":"$DIRECCIONE_MAIL","DIRECCION":"$DIRECCION","NIT":"$NIT","SUCURSAL":"$SUCURSAL","REPRESENTANTELEGAL":"$REPRESENTANTELEGAL","SUCURSAL_REPRESENTANTE":"$SUCURSAL_REPRESENTANTE","PUBLICO":"$PUBLICO(type:boolean)","EXTERNO":"$EXTERNO(type:boolean)","CONTRATISTA":"$CONTRATISTA(type:boolean)","TELEFONO":"$TELEFONO","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","DOCUMENTO":"$DOCUMENTO","CONTACTO":"$CONTACTO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/data">
		<call-query href="getProcedenciatramiteRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateProcedenciatramite" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROCEDENCIA_TRAMITE SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, NOMBRE=:NOMBRE, DIRECCIONE_MAIL=:DIRECCIONE_MAIL, DIRECCION=:DIRECCION, NIT=:NIT, SUCURSAL=:SUCURSAL, REPRESENTANTELEGAL=:REPRESENTANTELEGAL, SUCURSAL_REPRESENTANTE=:SUCURSAL_REPRESENTANTE, PUBLICO=:PUBLICO, EXTERNO=:EXTERNO, CONTRATISTA=:CONTRATISTA, TELEFONO=:TELEFONO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), DOCUMENTO=:DOCUMENTO, CONTACTO=:CONTACTO WHERE PROCEDENCIA_TRAMITE.COMPANIA= :KEY_COMPANIA AND PROCEDENCIA_TRAMITE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCIONE_MAIL" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="REPRESENTANTELEGAL" sqlType="STRING"/>
		<param name="SUCURSAL_REPRESENTANTE" sqlType="STRING"/>
		<param name="PUBLICO" sqlType="STRING"/>
		<param name="EXTERNO" sqlType="STRING"/>
		<param name="CONTRATISTA" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="CONTACTO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="procedenciatramite">
		<call-query href="updateProcedenciatramite">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCIONE_MAIL" query-param="DIRECCIONE_MAIL"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="REPRESENTANTELEGAL" query-param="REPRESENTANTELEGAL"/>
			<with-param name="SUCURSAL_REPRESENTANTE" query-param="SUCURSAL_REPRESENTANTE"/>
			<with-param name="PUBLICO" query-param="PUBLICO"/>
			<with-param name="EXTERNO" query-param="EXTERNO"/>
			<with-param name="CONTRATISTA" query-param="CONTRATISTA"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="CONTACTO" query-param="CONTACTO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramitePagDocumentonombrefinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT DOCUMENTO, NOMBRE FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA AND DOCUMENTO &gt;= :NUMERO AND DOCUMENTO IS NOT NULL ORDER BY DOCUMENTO) INI WHERE (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END) LIKE UPPER(CONCAT(:DOCUMENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCUMENTO":"$DOCUMENTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procedenciatramite/documentonombrefinal/pag">
		<call-query href="getProcedenciatramitePagDocumentonombrefinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcedenciatramiteNumDocumentonombrefinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT DOCUMENTO, NOMBRE FROM PROCEDENCIA_TRAMITE WHERE COMPANIA = :COMPANIA AND DOCUMENTO &gt;= :NUMERO AND DOCUMENTO IS NOT NULL ORDER BY DOCUMENTO) INI WHERE (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END) LIKE UPPER(CONCAT(:DOCUMENTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procedenciatramite/documentonombrefinal/num">
		<call-query href="getProcedenciatramiteNumDocumentonombrefinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

</data>