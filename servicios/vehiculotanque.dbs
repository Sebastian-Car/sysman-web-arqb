<data name="vehiculotanque" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVehiculotanqueCodTanqueCapacidPorPlacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VEHICULOTANQUE.COMPANIA, VEHICULOTANQUE.PLACA, VEHICULOTANQUE.CODIGO, VEHICULOTANQUE.CAPACIDAD  FROM VEHICULOTANQUE WHERE COMPANIA=:COMPANIA AND PLACA = :PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PLACA":"$PLACA","CODIGO":"$CODIGO(type:integer)","CAPACIDAD":"$CAPACIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vehiculotanque/codtanquecapacidporplaca">
		<call-query href="getVehiculotanqueCodTanqueCapacidPorPlacaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLACA" query-param="PLACA"/>

		</call-query>
	</resource>
	<query id="getVehiculotanqueSumaCapacidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(VEHICULOTANQUE.CAPACIDAD) SUMA  FROM VEHICULOTANQUE WHERE COMPANIA=:COMPANIA AND PLACA =:PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMA":"$SUMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vehiculotanque/sumacapacidad">
		<call-query href="getVehiculotanqueSumaCapacidadQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLACA" query-param="PLACA"/>

		</call-query>
	</resource>
	<query id="insertVehiculotanque" keyColumns="COMPANIA,PLACA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VEHICULOTANQUE (CAPACIDAD, CODIGO, PLACA, COMPANIA, DATE_CREATED, CREATED_BY) VALUES (:CAPACIDAD, :CODIGO, :PLACA, :COMPANIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PLACA":"$PLACA","KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param defaultValue="0" name="CAPACIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vehiculotanque">
		<call-query href="insertVehiculotanque">
			<with-param name="CAPACIDAD" query-param="CAPACIDAD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVehiculotanque" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VEHICULOTANQUE WHERE VEHICULOTANQUE.COMPANIA= :KEY_COMPANIA AND VEHICULOTANQUE.PLACA= :KEY_PLACA AND VEHICULOTANQUE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="vehiculotanque">
		<call-query href="deleteVehiculotanque">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateVehiculotanque" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VEHICULOTANQUE SET CAPACIDAD=:CAPACIDAD, CODIGO=:CODIGO, PLACA=:PLACA, COMPANIA=:COMPANIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VEHICULOTANQUE.COMPANIA= :KEY_COMPANIA AND VEHICULOTANQUE.PLACA= :KEY_PLACA AND VEHICULOTANQUE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CAPACIDAD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PLACA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLACA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vehiculotanque">
		<call-query href="updateVehiculotanque">
			<with-param name="CAPACIDAD" query-param="CAPACIDAD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PLACA" query-param="PLACA"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLACA" query-param="KEY_PLACA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>