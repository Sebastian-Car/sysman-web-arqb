<data name="dcambiostipoactivos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDcambiostipoactivosTiposDeActivosRegsitradosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' TIPOS  FROM D_CAMBIOS_TIPOACTIVO WHERE D_CAMBIOS_TIPOACTIVO.COMPANIA = :COMPANIA AND D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND D_CAMBIOS_TIPOACTIVO.NUMERO = :CONSECUTIVO AND D_CAMBIOS_TIPOACTIVO.IND_REG NOT IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOS":"$TIPOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dcambiostipoactivos/tiposdeactivosregsitrados">
		<call-query href="getDcambiostipoactivosTiposDeActivosRegsitradosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDcambiostipoactivosTodosSinIndicadorDeRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO, D_CAMBIOS_TIPOACTIVO.NUMERO, D_CAMBIOS_TIPOACTIVO.ELEMENTO, D_CAMBIOS_TIPOACTIVO.SERIE,(CASE D_CAMBIOS_TIPOACTIVO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA,(TO_CHAR(DEVOLUTIVO.FECHAANULADA,'DD/MM/YYYY HH24:MI:SS')) FECHAANULADA FROM D_CAMBIOS_TIPOACTIVO INNER JOIN DEVOLUTIVO ON DEVOLUTIVO.COMPANIA = D_CAMBIOS_TIPOACTIVO.COMPANIA AND DEVOLUTIVO.ELEMENTO = D_CAMBIOS_TIPOACTIVO.ELEMENTO AND DEVOLUTIVO.SERIE = D_CAMBIOS_TIPOACTIVO.SERIE WHERE D_CAMBIOS_TIPOACTIVO.COMPANIA = :COMPANIA AND D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND D_CAMBIOS_TIPOACTIVO.NUMERO = :CONSECUTIVO AND D_CAMBIOS_TIPOACTIVO.IND_REG IN(0) AND DEVOLUTIVO.SERIE NOT IN (0) ORDER BY D_CAMBIOS_TIPOACTIVO.SERIE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","NUMERO":"$NUMERO(type:long)","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","IND_REG":"$IND_REG(type:boolean)","PLACAANULADA":"$PLACAANULADA(type:boolean)","FECHAANULADA":"$FECHAANULADA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dcambiostipoactivos/todossinindicadorderegistro">
		<call-query href="getDcambiostipoactivosTodosSinIndicadorDeRegistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDcambiostipoactivosTodosPorCompaniaNumeroTipoMovientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' AS X  FROM D_CAMBIOS_TIPOACTIVO LEFT JOIN INVENTARIO ON D_CAMBIOS_TIPOACTIVO.COMPANIA = INVENTARIO.COMPANIA AND D_CAMBIOS_TIPOACTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_CAMBIOS_TIPOACTIVO.COMPANIA = :COMPANIA AND D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO = :TIPOMOVIMIENTOCTA AND D_CAMBIOS_TIPOACTIVO.NUMERO =:CONSECUTIVOCTA AND D_CAMBIOS_TIPOACTIVO.IND_REG NOT IN 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTOCTA" sqlType="STRING"/>
		<param name="CONSECUTIVOCTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dcambiostipoactivos/todosporcompanianumerotipomoviento">
		<call-query href="getDcambiostipoactivosTodosPorCompaniaNumeroTipoMovientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTOCTA" query-param="TIPOMOVIMIENTOCTA"/>
			<with-param name="CONSECUTIVOCTA" query-param="CONSECUTIVOCTA"/>

		</call-query>
	</resource>
	<query id="insertDcambiostipoactivos" keyColumns="COMPANIA,NUMERO,TIPOMOVIMIENTO,ELEMENTO,SERIE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_CAMBIOS_TIPOACTIVO (HORA, FECHA, NUMERO, TIPOACTIVO_ANT, TIPOMOVIMIENTO, REVELACIONES, TIPOACTIVO_NUE, SERIE, NIIF_VALOR_BASE, COMPANIA, NIIF_VALOR_TOTAL, ELEMENTO, IND_REG, DATE_CREATED, CREATED_BY) VALUES (TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :NUMERO, :TIPOACTIVO_ANT, :TIPOMOVIMIENTO, :REVELACIONES, :TIPOACTIVO_NUE, :SERIE, :NIIF_VALOR_BASE, :COMPANIA, :NIIF_VALOR_TOTAL, :ELEMENTO, :IND_REG, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:long)","KEY_TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","KEY_ELEMENTO":"$ELEMENTO","KEY_SERIE":"$SERIE"}]}}		</result>
		<param defaultValue="" name="HORA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="TIPOACTIVO_ANT" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="REVELACIONES" sqlType="STRING"/>
		<param defaultValue="" name="TIPOACTIVO_NUE" sqlType="STRING"/>
		<param defaultValue="0" name="SERIE" sqlType="STRING"/>
		<param defaultValue="0" name="NIIF_VALOR_BASE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="IND_REG" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dcambiostipoactivos">
		<call-query href="insertDcambiostipoactivos">
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPOACTIVO_ANT" query-param="TIPOACTIVO_ANT"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="REVELACIONES" query-param="REVELACIONES"/>
			<with-param name="TIPOACTIVO_NUE" query-param="TIPOACTIVO_NUE"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="NIIF_VALOR_BASE" query-param="NIIF_VALOR_BASE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIIF_VALOR_TOTAL" query-param="NIIF_VALOR_TOTAL"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="IND_REG" query-param="IND_REG"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDcambiostipoactivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_CAMBIOS_TIPOACTIVO WHERE D_CAMBIOS_TIPOACTIVO.COMPANIA= :KEY_COMPANIA AND D_CAMBIOS_TIPOACTIVO.NUMERO= :KEY_NUMERO AND D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND D_CAMBIOS_TIPOACTIVO.ELEMENTO= :KEY_ELEMENTO AND D_CAMBIOS_TIPOACTIVO.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dcambiostipoactivos">
		<call-query href="deleteDcambiostipoactivos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getDcambiostipoactivosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_CAMBIOS_TIPOACTIVO.SERIE, D_CAMBIOS_TIPOACTIVO.ELEMENTO,(CASE D_CAMBIOS_TIPOACTIVO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.DESCRIPCION, TIPOACTINI.NOMBRE_TIPOACTIVO NOMBRETIPOACTIVO, D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_NUE, TIPOACTFIN.NOMBRE_TIPOACTIVO NOMBRETIPOACTIVOFIN,(TO_CHAR(D_CAMBIOS_TIPOACTIVO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(D_CAMBIOS_TIPOACTIVO.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, D_CAMBIOS_TIPOACTIVO.REVELACIONES, D_CAMBIOS_TIPOACTIVO.COMPANIA, D_CAMBIOS_TIPOACTIVO.NUMERO, D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO, D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_ANT, TIPOACTINI.CODIGO_TIPOACTIVO, DEVOLUTIVO.NIIF_VALOR_TOTAL VALORTOTALD, DEVOLUTIVO.NIIF_VALOR_BASE VALORBASED, D_CAMBIOS_TIPOACTIVO.NIIF_VALOR_BASE , D_CAMBIOS_TIPOACTIVO.NIIF_VALOR_TOTAL  FROM D_CAMBIOS_TIPOACTIVO LEFT JOIN INVENTARIO ON D_CAMBIOS_TIPOACTIVO.COMPANIA = INVENTARIO.COMPANIA AND D_CAMBIOS_TIPOACTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEVOLUTIVO ON D_CAMBIOS_TIPOACTIVO.COMPANIA = DEVOLUTIVO.COMPANIA AND D_CAMBIOS_TIPOACTIVO.ELEMENTO = DEVOLUTIVO.ELEMENTO AND D_CAMBIOS_TIPOACTIVO.SERIE = DEVOLUTIVO.SERIE LEFT JOIN TIPO_ACTIVO TIPOACTINI ON D_CAMBIOS_TIPOACTIVO.COMPANIA = TIPOACTINI.COMPANIA AND D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_ANT = TIPOACTINI.CODIGO_TIPOACTIVO LEFT JOIN TIPO_ACTIVO TIPOACTFIN ON D_CAMBIOS_TIPOACTIVO.COMPANIA = TIPOACTFIN.COMPANIA AND D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_NUE = TIPOACTFIN.CODIGO_TIPOACTIVO WHERE D_CAMBIOS_TIPOACTIVO.COMPANIA = :COMPANIA AND D_CAMBIOS_TIPOACTIVO.NUMERO = :CONSECUTIVOCTA AND D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO IN (:PARAMETROTIPOMOV,:TIPOMOVIMIENTOCTA)) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN IND_REG IS NULL THEN ' ' ELSE UPPER(IND_REG) END)  LIKE UPPER( '%' || :IND_REG || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRETIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRETIPOACTIVO || '%')  AND (CASE WHEN TIPOACTIVO_NUE IS NULL THEN ' ' ELSE UPPER(TIPOACTIVO_NUE) END)  LIKE UPPER( '%' || :TIPOACTIVO_NUE || '%')  AND (CASE WHEN NOMBRETIPOACTIVOFIN IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOACTIVOFIN) END)  LIKE UPPER( '%' || :NOMBRETIPOACTIVOFIN || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END)  LIKE UPPER( '%' || :HORA || '%')  AND (CASE WHEN REVELACIONES IS NULL THEN ' ' ELSE UPPER(REVELACIONES) END)  LIKE UPPER( '%' || :REVELACIONES || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","IND_REG":"$IND_REG(type:boolean)","NOMBRELARGO":"$NOMBRELARGO","DESCRIPCION":"$DESCRIPCION","NOMBRETIPOACTIVO":"$NOMBRETIPOACTIVO","TIPOACTIVO_NUE":"$TIPOACTIVO_NUE","NOMBRETIPOACTIVOFIN":"$NOMBRETIPOACTIVOFIN","FECHA":"$FECHA","HORA":"$HORA","REVELACIONES":"$REVELACIONES","COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:long)","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","TIPOACTIVO_ANT":"$TIPOACTIVO_ANT","CODIGO_TIPOACTIVO":"$CODIGO_TIPOACTIVO","VALORTOTALD":"$VALORTOTALD","VALORBASED":"$VALORBASED","NIIF_VALOR_BASE":"$NIIF_VALOR_BASE","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVOCTA" sqlType="STRING"/>
		<param name="PARAMETROTIPOMOV" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTOCTA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="IND_REG" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRETIPOACTIVO" sqlType="STRING"/>
		<param name="TIPOACTIVO_NUE" sqlType="STRING"/>
		<param name="NOMBRETIPOACTIVOFIN" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="REVELACIONES" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dcambiostipoactivos">
		<call-query href="getDcambiostipoactivosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVOCTA" query-param="CONSECUTIVOCTA"/>
			<with-param name="PARAMETROTIPOMOV" query-param="PARAMETROTIPOMOV"/>
			<with-param name="TIPOMOVIMIENTOCTA" query-param="TIPOMOVIMIENTOCTA"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="IND_REG" query-param="IND_REG"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRETIPOACTIVO" query-param="NOMBRETIPOACTIVO"/>
			<with-param name="TIPOACTIVO_NUE" query-param="TIPOACTIVO_NUE"/>
			<with-param name="NOMBRETIPOACTIVOFIN" query-param="NOMBRETIPOACTIVOFIN"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="REVELACIONES" query-param="REVELACIONES"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDcambiostipoactivosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_CAMBIOS_TIPOACTIVO.SERIE, D_CAMBIOS_TIPOACTIVO.ELEMENTO,(CASE D_CAMBIOS_TIPOACTIVO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.DESCRIPCION, TIPOACTINI.NOMBRE_TIPOACTIVO NOMBRETIPOACTIVO, D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_NUE, TIPOACTFIN.NOMBRE_TIPOACTIVO NOMBRETIPOACTIVOFIN,(TO_CHAR(D_CAMBIOS_TIPOACTIVO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(D_CAMBIOS_TIPOACTIVO.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, D_CAMBIOS_TIPOACTIVO.REVELACIONES, D_CAMBIOS_TIPOACTIVO.COMPANIA, D_CAMBIOS_TIPOACTIVO.NUMERO, D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO, D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_ANT, TIPOACTINI.CODIGO_TIPOACTIVO, DEVOLUTIVO.NIIF_VALOR_TOTAL VALORTOTALD, DEVOLUTIVO.NIIF_VALOR_BASE VALORBASED, D_CAMBIOS_TIPOACTIVO.NIIF_VALOR_BASE , D_CAMBIOS_TIPOACTIVO.NIIF_VALOR_TOTAL  FROM D_CAMBIOS_TIPOACTIVO LEFT JOIN INVENTARIO ON D_CAMBIOS_TIPOACTIVO.COMPANIA = INVENTARIO.COMPANIA AND D_CAMBIOS_TIPOACTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN DEVOLUTIVO ON D_CAMBIOS_TIPOACTIVO.COMPANIA = DEVOLUTIVO.COMPANIA AND D_CAMBIOS_TIPOACTIVO.ELEMENTO = DEVOLUTIVO.ELEMENTO AND D_CAMBIOS_TIPOACTIVO.SERIE = DEVOLUTIVO.SERIE LEFT JOIN TIPO_ACTIVO TIPOACTINI ON D_CAMBIOS_TIPOACTIVO.COMPANIA = TIPOACTINI.COMPANIA AND D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_ANT = TIPOACTINI.CODIGO_TIPOACTIVO LEFT JOIN TIPO_ACTIVO TIPOACTFIN ON D_CAMBIOS_TIPOACTIVO.COMPANIA = TIPOACTFIN.COMPANIA AND D_CAMBIOS_TIPOACTIVO.TIPOACTIVO_NUE = TIPOACTFIN.CODIGO_TIPOACTIVO WHERE D_CAMBIOS_TIPOACTIVO.COMPANIA = :COMPANIA AND D_CAMBIOS_TIPOACTIVO.NUMERO = :CONSECUTIVOCTA AND D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO IN (:PARAMETROTIPOMOV,:TIPOMOVIMIENTOCTA)) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN IND_REG IS NULL THEN ' ' ELSE UPPER(IND_REG) END)  LIKE UPPER( '%' || :IND_REG || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRETIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOACTIVO) END)  LIKE UPPER( '%' || :NOMBRETIPOACTIVO || '%')  AND (CASE WHEN TIPOACTIVO_NUE IS NULL THEN ' ' ELSE UPPER(TIPOACTIVO_NUE) END)  LIKE UPPER( '%' || :TIPOACTIVO_NUE || '%')  AND (CASE WHEN NOMBRETIPOACTIVOFIN IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOACTIVOFIN) END)  LIKE UPPER( '%' || :NOMBRETIPOACTIVOFIN || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END)  LIKE UPPER( '%' || :HORA || '%')  AND (CASE WHEN REVELACIONES IS NULL THEN ' ' ELSE UPPER(REVELACIONES) END)  LIKE UPPER( '%' || :REVELACIONES || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVOCTA" sqlType="STRING"/>
		<param name="PARAMETROTIPOMOV" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTOCTA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="IND_REG" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRETIPOACTIVO" sqlType="STRING"/>
