	<query id="updateDcambiostipoactivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_CAMBIOS_TIPOACTIVO SET HORA=TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), NUMERO=:NUMERO, TIPOACTIVO_ANT=:TIPOACTIVO_ANT, TIPOMOVIMIENTO=:TIPOMOVIMIENTO, REVELACIONES=:REVELACIONES, TIPOACTIVO_NUE=:TIPOACTIVO_NUE, SERIE=:SERIE, NIIF_VALOR_BASE=:NIIF_VALOR_BASE, COMPANIA=:COMPANIA, IND_REG=:IND_REG, NIIF_VALOR_TOTAL=:NIIF_VALOR_TOTAL, ELEMENTO=:ELEMENTO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE D_CAMBIOS_TIPOACTIVO.COMPANIA= :KEY_COMPANIA AND D_CAMBIOS_TIPOACTIVO.NUMERO= :KEY_NUMERO AND D_CAMBIOS_TIPOACTIVO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND D_CAMBIOS_TIPOACTIVO.ELEMENTO= :KEY_ELEMENTO AND D_CAMBIOS_TIPOACTIVO.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

