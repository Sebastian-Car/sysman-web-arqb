<data name="formulasprocedimiento" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFormulasprocedimientoExisteformulaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(PROCEDIMIENTO) AS EXISTE FROM FORMULAS_PROCEDIMIENTO WHERE PROCEDIMIENTO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formulasprocedimiento/existeformula">
		<call-query href="getFormulasprocedimientoExisteformulaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertFormulasprocedimiento" keyColumns="COMPANIA,PROCEDIMIENTO,ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FORMULAS_PROCEDIMIENTO (COMPANIA, PROCEDIMIENTO, FORMULA_APLICADA, CONCEPTO_RESULTANTE, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :PROCEDIMIENTO, :FORMULA_APLICADA, :CONCEPTO_RESULTANTE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROCEDIMIENTO":"$PROCEDIMIENTO(type:integer)","KEY_ID":"$ID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCEDIMIENTO" sqlType="STRING"/>
		<param name="FORMULA_APLICADA" sqlType="STRING"/>
		<param name="CONCEPTO_RESULTANTE" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="formulasprocedimiento">
		<call-query href="insertFormulasprocedimiento">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCEDIMIENTO" query-param="PROCEDIMIENTO"/>
			<with-param name="FORMULA_APLICADA" query-param="FORMULA_APLICADA"/>
			<with-param name="CONCEPTO_RESULTANTE" query-param="CONCEPTO_RESULTANTE"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteFormulasprocedimiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FORMULAS_PROCEDIMIENTO WHERE FORMULAS_PROCEDIMIENTO.COMPANIA= :KEY_COMPANIA AND FORMULAS_PROCEDIMIENTO.PROCEDIMIENTO= :KEY_PROCEDIMIENTO AND FORMULAS_PROCEDIMIENTO.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCEDIMIENTO" sqlType="INTEGER"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="formulasprocedimiento">
		<call-query href="deleteFormulasprocedimiento">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCEDIMIENTO" query-param="KEY_PROCEDIMIENTO"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getFormulasprocedimientoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT F.COMPANIA, F.PROCEDIMIENTO,F.ID,T.DESCRIPCION, to_char(F.FORMULA_APLICADA) FORMULA_APLICADA, F.CONCEPTO_RESULTANTE FROM FORMULAS_PROCEDIMIENTO F INNER JOIN TIPOS_BENEFICIOS T ON F.COMPANIA = T.COMPANIA AND F.PROCEDIMIENTO = T.ID_DE_TIPO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN PROCEDIMIENTO IS NULL THEN ' ' ELSE UPPER(PROCEDIMIENTO) END) LIKE UPPER(CONCAT(:PROCEDIMIENTO, '%')) AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FORMULA_APLICADA IS NULL THEN ' ' ELSE UPPER(FORMULA_APLICADA) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMULA_APLICADA), '%')) AND (CASE WHEN CONCEPTO_RESULTANTE IS NULL THEN ' ' ELSE UPPER(CONCEPTO_RESULTANTE) END) LIKE UPPER(CONCAT(:CONCEPTO_RESULTANTE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCEDIMIENTO":"$PROCEDIMIENTO(type:integer)","ID":"$ID(type:double)","DESCRIPCION":"$DESCRIPCION","FORMULA_APLICADA":"$FORMULA_APLICADA","CONCEPTO_RESULTANTE":"$CONCEPTO_RESULTANTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCEDIMIENTO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FORMULA_APLICADA" sqlType="STRING"/>
		<param name="CONCEPTO_RESULTANTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="formulasprocedimiento">
		<call-query href="getFormulasprocedimientoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCEDIMIENTO" query-param="PROCEDIMIENTO"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FORMULA_APLICADA" query-param="FORMULA_APLICADA"/>
			<with-param name="CONCEPTO_RESULTANTE" query-param="CONCEPTO_RESULTANTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFormulasprocedimientoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT F.COMPANIA, F.PROCEDIMIENTO,F.ID,T.DESCRIPCION, to_char(F.FORMULA_APLICADA) FORMULA_APLICADA, F.CONCEPTO_RESULTANTE FROM FORMULAS_PROCEDIMIENTO F INNER JOIN TIPOS_BENEFICIOS T ON F.COMPANIA = T.COMPANIA AND F.PROCEDIMIENTO = T.ID_DE_TIPO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPANIA), '%')) AND (CASE WHEN PROCEDIMIENTO IS NULL THEN ' ' ELSE UPPER(PROCEDIMIENTO) END) LIKE UPPER(CONCAT(:PROCEDIMIENTO, '%')) AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FORMULA_APLICADA IS NULL THEN ' ' ELSE UPPER(FORMULA_APLICADA) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMULA_APLICADA), '%')) AND (CASE WHEN CONCEPTO_RESULTANTE IS NULL THEN ' ' ELSE UPPER(CONCEPTO_RESULTANTE) END) LIKE UPPER(CONCAT(:CONCEPTO_RESULTANTE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCEDIMIENTO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FORMULA_APLICADA" sqlType="STRING"/>
		<param name="CONCEPTO_RESULTANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formulasprocedimiento/numero">
		<call-query href="getFormulasprocedimientoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCEDIMIENTO" query-param="PROCEDIMIENTO"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FORMULA_APLICADA" query-param="FORMULA_APLICADA"/>
			<with-param name="CONCEPTO_RESULTANTE" query-param="CONCEPTO_RESULTANTE"/>

		</call-query>
	</resource>
	<query id="getFormulasprocedimientoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, PROCEDIMIENTO,ID, FORMULA_APLICADA, CONCEPTO_RESULTANTE, ID FROM FORMULAS_PROCEDIMIENTO WHERE FORMULAS_PROCEDIMIENTO.COMPANIA= :KEY_COMPANIA AND FORMULAS_PROCEDIMIENTO.PROCEDIMIENTO= :KEY_PROCEDIMIENTO AND FORMULAS_PROCEDIMIENTO.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCEDIMIENTO":"$PROCEDIMIENTO(type:integer)","ID":"$ID(type:double)","FORMULA_APLICADA":"$FORMULA_APLICADA","CONCEPTO_RESULTANTE":"$CONCEPTO_RESULTANTE(type:integer)","ID":"$ID(type:double)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCEDIMIENTO" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="formulasprocedimiento/data">
		<call-query href="getFormulasprocedimientoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCEDIMIENTO" query-param="KEY_PROCEDIMIENTO"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateFormulasprocedimiento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FORMULAS_PROCEDIMIENTO SET COMPANIA=:COMPANIA, PROCEDIMIENTO=:PROCEDIMIENTO, FORMULA_APLICADA=:FORMULA_APLICADA, CONCEPTO_RESULTANTE=:CONCEPTO_RESULTANTE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), ID=:ID WHERE FORMULAS_PROCEDIMIENTO.COMPANIA= :KEY_COMPANIA AND FORMULAS_PROCEDIMIENTO.PROCEDIMIENTO= :KEY_PROCEDIMIENTO AND FORMULAS_PROCEDIMIENTO.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCEDIMIENTO" sqlType="STRING"/>
		<param name="FORMULA_APLICADA" sqlType="STRING"/>
		<param name="CONCEPTO_RESULTANTE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCEDIMIENTO" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="formulasprocedimiento">
		<call-query href="updateFormulasprocedimiento">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCEDIMIENTO" query-param="PROCEDIMIENTO"/>
			<with-param name="FORMULA_APLICADA" query-param="FORMULA_APLICADA"/>
			<with-param name="CONCEPTO_RESULTANTE" query-param="CONCEPTO_RESULTANTE"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCEDIMIENTO" query-param="KEY_PROCEDIMIENTO"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>

</data>