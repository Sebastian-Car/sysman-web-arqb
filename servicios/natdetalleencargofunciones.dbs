<data name="natdetalleencargofunciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatdetalleencargofuncionesCodigonombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBREENCARGO  FROM NAT_DETALLE_ENCARGO_FUNCIONES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBREENCARGO":"$NOMBREENCARGO"}]}}		</result>
 
	</query>
	<resource method="GET" path="natdetalleencargofunciones/codigonombre">
		<call-query href="getNatdetalleencargofuncionesCodigonombreQuery">
 
		</call-query>
	</resource>

</data>