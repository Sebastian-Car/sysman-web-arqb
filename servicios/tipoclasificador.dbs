			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGONUEVO" query-param="CODIGONUEVO"/>

		</call-query>
	</resource>
	<query id="updateTipoclasificadorActualizatemporaltipoclasificadores" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TMPCLASIFICADORESAACTUALIZAR SET CODIGONUEVO = :CODIGONUEVO WHERE CODIGO = :TIPOCLASIFICADOR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGONUEVO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>

	</query>
