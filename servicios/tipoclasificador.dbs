		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE FROM TIPOCLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CLASECLASIFICADOR = '012' AND CASE WHEN :VALOR IN (0) THEN APLICAINGRESOS ELSE PROGRAMACION END NOT IN (0)) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
