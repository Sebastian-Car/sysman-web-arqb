	<query id="getTipoclasificadorPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA ,ANO,CLASECLASIFICADOR,CODIGO,NOMBRE,DESCRIPCION, EQUIVALENTE , CASE WHEN SECCIONESADI IN(0) THEN 'NO' ELSE 'Si' END SECCIONESADI,ID ,CASE WHEN MOVIMIENTO IN(0) THEN 'NO' ELSE 'Si' END MOVIMIENTO, CASE WHEN REGALIAS IN(0) THEN 'NO' ELSE 'Si' END REGALIAS, CASE WHEN APLICAINGRESOS IN (0) THEN 'NO' ELSE 'Si' END APLICAINGRESOS,CASE WHEN OBLIGACPCDANE IN(0) THEN 'NO' ELSE 'Si' END OBLIGACPCDANE FROM TIPOCLASIFICADOR ORDER BY COMPANIA ,ANO,CLASECLASIFICADOR,CODIGO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN CLASECLASIFICADOR IS NULL THEN ' ' ELSE UPPER(CLASECLASIFICADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASECLASIFICADOR), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN EQUIVALENTE IS NULL THEN ' ' ELSE UPPER(EQUIVALENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:EQUIVALENTE), '%')) AND (CASE WHEN SECCIONESADI IS NULL THEN ' ' ELSE UPPER(SECCIONESADI) END) LIKE UPPER(CONCAT(CONCAT('%',:SECCIONESADI), '%')) AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(CONCAT('%',:ID), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MOVIMIENTO), '%')) AND (CASE WHEN REGALIAS IS NULL THEN ' ' ELSE UPPER(REGALIAS) END) LIKE UPPER(CONCAT(CONCAT('%',:REGALIAS), '%')) AND (CASE WHEN APLICAINGRESOS IS NULL THEN ' ' ELSE UPPER(APLICAINGRESOS) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICAINGRESOS), '%')) AND (CASE WHEN OBLIGACPCDANE IS NULL THEN ' ' ELSE UPPER(OBLIGACPCDANE) END) LIKE UPPER(CONCAT(CONCAT('%',:OBLIGACPCDANE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CLASECLASIFICADOR":"$CLASECLASIFICADOR","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","EQUIVALENTE":"$EQUIVALENTE","SECCIONESADI":"$SECCIONESADI","ID":"$ID","MOVIMIENTO":"$MOVIMIENTO","REGALIAS":"$REGALIAS","APLICAINGRESOS":"$APLICAINGRESOS","OBLIGACPCDANE":"$OBLIGACPCDANE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="EQUIVALENTE" sqlType="STRING"/>
		<param name="SECCIONESADI" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="APLICAINGRESOS" sqlType="STRING"/>
		<param name="OBLIGACPCDANE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
