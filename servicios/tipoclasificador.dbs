	<query id="getTipoclasificadorPagGetapropiacionesinicialesrubropptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT AP.CODIGO, AP.TERCERO, AP.SUCURSAL, AP.ID, PPPTAL.NOMBRE, AP.CENTRO_COSTO, CC.NOMBRE NOMBRE_CC, AP.AUXILIAR, AUX.NOMBRE NOMBRE_AUX, AP.REFERENCIA, RFRN.NOMBRE NOMBRE_REF, AP.FUENTE_RECURSO, FUE.NOMBRE NOMBRE_FUE, AP.CODIGO_CCPET, AP.PROGRAMA, AP.CODIGOUNIDADEJE, AP.CODIGOBPIN, AP.DETALLESECTORIAL, AP.APROPIACIONINICIAL FROM APROPIACIONESINICIALES AP INNER JOIN PLAN_PRESUPUESTAL PPPTAL ON ( AP.COMPANIA = PPPTAL.COMPANIA AND AP.ANO = PPPTAL.ANO AND AP.CODIGO = PPPTAL.CODIGO ) INNER JOIN CENTRO_COSTO CC ON ( CC.COMPANIA = AP.COMPANIA AND CC.ANO = AP.ANO AND CC.CODIGO = AP.CENTRO_COSTO ) INNER JOIN AUXILIAR AUX ON ( AUX.COMPANIA = AP.COMPANIA AND AUX.ANO = AP.ANO AND AUX.CODIGO = AP.AUXILIAR ) INNER JOIN REFERENCIA RFRN ON ( RFRN.COMPANIA = AP.COMPANIA AND RFRN.ANO = AP.ANO AND RFRN.CODIGO = AP.REFERENCIA ) INNER JOIN FUENTE_RECURSOS FUE ON ( FUE.COMPANIA = AP.COMPANIA AND FUE.ANO = AP.ANO AND FUE.CODIGO = AP.FUENTE_RECURSO ) WHERE AP.COMPANIA = :COMPANIA AND AP.ANO = :ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(CONCAT('%',:ID), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN NOMBRE_CC IS NULL THEN ' ' ELSE UPPER(NOMBRE_CC) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CC), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN NOMBRE_AUX IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUX), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN NOMBRE_REF IS NULL THEN ' ' ELSE UPPER(NOMBRE_REF) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_REF), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN NOMBRE_FUE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FUE), '%')) AND (CASE WHEN CODIGO_CCPET IS NULL THEN ' ' ELSE UPPER(CODIGO_CCPET) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CCPET), '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMA), '%')) AND (CASE WHEN CODIGOUNIDADEJE IS NULL THEN ' ' ELSE UPPER(CODIGOUNIDADEJE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOUNIDADEJE), '%')) AND (CASE WHEN CODIGOBPIN IS NULL THEN ' ' ELSE UPPER(CODIGOBPIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOBPIN), '%')) AND (CASE WHEN DETALLESECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLESECTORIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DETALLESECTORIAL), '%')) AND (CASE WHEN APROPIACIONINICIAL IS NULL THEN ' ' ELSE UPPER(APROPIACIONINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:APROPIACIONINICIAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","ID":"$ID","NOMBRE":"$NOMBRE","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRE_CC":"$NOMBRE_CC","AUXILIAR":"$AUXILIAR","NOMBRE_AUX":"$NOMBRE_AUX","REFERENCIA":"$REFERENCIA","NOMBRE_REF":"$NOMBRE_REF","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBRE_FUE":"$NOMBRE_FUE","CODIGO_CCPET":"$CODIGO_CCPET","PROGRAMA":"$PROGRAMA","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOBPIN":"$CODIGOBPIN","DETALLESECTORIAL":"$DETALLESECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="NOMBRE_CC" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="NOMBRE_AUX" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="NOMBRE_REF" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="NOMBRE_FUE" sqlType="STRING"/>
		<param name="CODIGO_CCPET" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="CODIGOUNIDADEJE" sqlType="STRING"/>
		<param name="CODIGOBPIN" sqlType="STRING"/>
		<param name="DETALLESECTORIAL" sqlType="STRING"/>
		<param name="APROPIACIONINICIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
