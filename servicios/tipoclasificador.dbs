	<query id="getTipoclasificadorNumSinregaliasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE FROM TIPOCLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CLASECLASIFICADOR = :CLASECLASIFICADOR AND (REGALIAS = CASE WHEN :REGALIAS = 0 THEN 0 ELSE 1 END OR REGALIAS = CASE WHEN :REGALIAS = 0 THEN 0 ELSE -1 END) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
