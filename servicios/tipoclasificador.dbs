	<query id="getTipoclasificadorNumGetapropiacionesinicialesrubropptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT AP.CODIGO, AP.TERCERO, AP.SUCURSAL, AP.ID, PPPTAL.NOMBRE, AP.CENTRO_COSTO, CC.NOMBRE NOMBRE_CC, AP.AUXILIAR, AUX.NOMBRE NOMBRE_AUX, AP.REFERENCIA, RFRN.NOMBRE NOMBRE_REF, AP.FUENTE_RECURSO, FUE.NOMBRE NOMBRE_FUE, AP.CODIGO_CCPET, AP.PROGRAMA, AP.CODIGOUNIDADEJE, AP.CODIGOBPIN, AP.DETALLESECTORIAL, AP.APROPIACIONINICIAL FROM APROPIACIONESINICIALES AP INNER JOIN PLAN_PRESUPUESTAL PPPTAL ON ( AP.COMPANIA = PPPTAL.COMPANIA AND AP.ANO = PPPTAL.ANO AND AP.CODIGO = PPPTAL.CODIGO ) INNER JOIN CENTRO_COSTO CC ON ( CC.COMPANIA = AP.COMPANIA AND CC.ANO = AP.ANO AND CC.CODIGO = AP.CENTRO_COSTO ) INNER JOIN AUXILIAR AUX ON ( AUX.COMPANIA = AP.COMPANIA AND AUX.ANO = AP.ANO AND AUX.CODIGO = AP.AUXILIAR ) INNER JOIN REFERENCIA RFRN ON ( RFRN.COMPANIA = AP.COMPANIA AND RFRN.ANO = AP.ANO AND RFRN.CODIGO = AP.REFERENCIA ) INNER JOIN FUENTE_RECURSOS FUE ON ( FUE.COMPANIA = AP.COMPANIA AND FUE.ANO = AP.ANO AND FUE.CODIGO = AP.FUENTE_RECURSO ) WHERE AP.COMPANIA = :COMPANIA AND AP.ANO = :ANO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL), '%')) AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(CONCAT('%',:ID), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRO_COSTO), '%')) AND (CASE WHEN NOMBRE_CC IS NULL THEN ' ' ELSE UPPER(NOMBRE_CC) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CC), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN NOMBRE_AUX IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_AUX), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN NOMBRE_REF IS NULL THEN ' ' ELSE UPPER(NOMBRE_REF) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_REF), '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTE_RECURSO), '%')) AND (CASE WHEN NOMBRE_FUE IS NULL THEN ' ' ELSE UPPER(NOMBRE_FUE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_FUE), '%')) AND (CASE WHEN CODIGO_CCPET IS NULL THEN ' ' ELSE UPPER(CODIGO_CCPET) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_CCPET), '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(CONCAT('%',:PROGRAMA), '%')) AND (CASE WHEN CODIGOUNIDADEJE IS NULL THEN ' ' ELSE UPPER(CODIGOUNIDADEJE) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOUNIDADEJE), '%')) AND (CASE WHEN CODIGOBPIN IS NULL THEN ' ' ELSE UPPER(CODIGOBPIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOBPIN), '%')) AND (CASE WHEN DETALLESECTORIAL IS NULL THEN ' ' ELSE UPPER(DETALLESECTORIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DETALLESECTORIAL), '%')) AND (CASE WHEN APROPIACIONINICIAL IS NULL THEN ' ' ELSE UPPER(APROPIACIONINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:APROPIACIONINICIAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
