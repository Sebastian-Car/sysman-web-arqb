		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TCP.CODIGO, TCH.NOMBRE ,H.IDHIJO ,H.IDPADRE FROM TIPOCLASIFICADOR T INNER JOIN TIPOCLASIFICADORESHIJO H ON T.COMPANIA = H.COMPANIA AND T.ANO = H.ANO AND T.ID = H.IDPADRE INNER JOIN TIPOCLASIFICADOR TCH ON H.COMPANIA = TCH.COMPANIA AND H.ANO = TCH.ANO AND H.IDHIJO = TCH.ID INNER JOIN TIPOCLASIFICADOR TCP ON H.COMPANIA = TCP.COMPANIA AND H.ANO = TCP.ANO AND H.IDPADRE = TCP.ID WHERE T.COMPANIA = :COMPANIA AND T.ANO = :ANO AND INSTR( CONCAT(CONCAT(',',( SELECT CLASEPADRE FROM CLASECLASIFICADOR WHERE COMPANIA =:COMPANIA AND ANO = :ANO AND CODIGO = :CLASEPADRE AND ( CASE WHEN :NATURALEZA = 'D' THEN APLICACION ELSE APLICACIONINGRESOS END ) = :APLICACION AND CLASEPADRE IS NOT NULL )),',') , CONCAT( CONCAT( ',', T.CLASECLASIFICADOR ), ',' ) ) &gt; 0 AND H.IDHIJO = :IDHIJOO AND T.CODIGO IS NOT NULL GROUP BY TCP.CODIGO, TCH.NOMBRE ,H.IDHIJO ,H.IDPADRE) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN IDHIJO IS NULL THEN ' ' ELSE UPPER(IDHIJO) END) LIKE UPPER(CONCAT(:IDHIJO, '%')) AND (CASE WHEN IDPADRE IS NULL THEN ' ' ELSE UPPER(IDPADRE) END) LIKE UPPER(CONCAT(:IDPADRE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
