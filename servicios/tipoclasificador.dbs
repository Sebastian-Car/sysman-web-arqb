	<query id="getTipoclasificadorRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA ,ANO,CLASECLASIFICADOR,CODIGO,NOMBRE,DESCRIPCION, EQUIVALENTE,(CASE SECCIONESADI WHEN 0 THEN 'false' ELSE 'true' END) SECCIONESADI,ID ,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE REGALIAS WHEN 0 THEN 'false' ELSE 'true' END) REGALIAS,(CASE APLICAINGRESOS WHEN 0 THEN 'false' ELSE 'true' END) APLICAINGRESOS,(CASE PROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) PROGRAMACION,(CASE OBLIGACPCDANE WHEN 0 THEN 'false' ELSE 'true' END) OBLIGACPCDANE FROM TIPOCLASIFICADOR WHERE TIPOCLASIFICADOR.COMPANIA= :KEY_COMPANIA AND TIPOCLASIFICADOR.ANO= :KEY_ANO AND TIPOCLASIFICADOR.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CLASECLASIFICADOR":"$CLASECLASIFICADOR","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","EQUIVALENTE":"$EQUIVALENTE","SECCIONESADI":"$SECCIONESADI(type:boolean)","ID":"$ID","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","REGALIAS":"$REGALIAS(type:boolean)","APLICAINGRESOS":"$APLICAINGRESOS(type:boolean)","PROGRAMACION":"$PROGRAMACION(type:boolean)","OBLIGACPCDANE":"$OBLIGACPCDANE(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/data">
		<call-query href="getTipoclasificadorRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateTipoclasificador" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPOCLASIFICADOR SET COMPANIA=:COMPANIA, ANO=:ANO, CLASECLASIFICADOR=:CLASECLASIFICADOR, CODIGO=:CODIGO, NOMBRE=:NOMBRE, DESCRIPCION=:DESCRIPCION, EQUIVALENTE=:EQUIVALENTE, SECCIONESADI=:SECCIONESADI, ID=:ID, MOVIMIENTO=:MOVIMIENTO, REGALIAS=:REGALIAS, APLICAINGRESOS=:APLICAINGRESOS, PROGRAMACION=:PROGRAMACION, OBLIGACPCDANE=:OBLIGACPCDANE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPOCLASIFICADOR.COMPANIA= :KEY_COMPANIA AND TIPOCLASIFICADOR.ANO= :KEY_ANO AND TIPOCLASIFICADOR.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="EQUIVALENTE" sqlType="STRING"/>
		<param name="SECCIONESADI" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="APLICAINGRESOS" sqlType="STRING"/>
		<param name="PROGRAMACION" sqlType="STRING"/>
		<param name="OBLIGACPCDANE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipoclasificador">
