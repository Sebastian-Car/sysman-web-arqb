	<query id="getTipoclasificadorPagClasclasificatipoclasificaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CLASECLASIFICADOR.CODIGO CLASECLASIFICADORPADRE, CLASECLASIFICADOR.NOMBRE NOMBREPADRE, TIPOCLASIFICADOR.CODIGO CLASECLASIFICADORHIJO, TIPOCLASIFICADOR.NOMBRE NOMBREHIJO, TIPOCLASIFICADOR.ID FROM TIPOCLASIFICADOR INNER JOIN CLASECLASIFICADOR ON TIPOCLASIFICADOR.COMPANIA = CLASECLASIFICADOR.COMPANIA AND TIPOCLASIFICADOR.ANO = CLASECLASIFICADOR.ANO AND CLASECLASIFICADOR.CODIGO = TIPOCLASIFICADOR.CLASECLASIFICADOR WHERE CLASECLASIFICADOR.COMPANIA = :COMPANIA AND CLASECLASIFICADOR.ANO = :ANO AND CLASECLASIFICADOR.CODIGO = SUBSTR(:CODCLASECLASI, 1, 3) OR CLASECLASIFICADOR.CODIGO = SUBSTR(:CODCLASECLASI, 4)) INI WHERE (CASE WHEN CLASECLASIFICADORPADRE IS NULL THEN ' ' ELSE UPPER(CLASECLASIFICADORPADRE) END) LIKE UPPER(CONCAT(:CLASECLASIFICADORPADRE, '%')) AND (CASE WHEN NOMBREPADRE IS NULL THEN ' ' ELSE UPPER(NOMBREPADRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREPADRE), '%')) AND (CASE WHEN CLASECLASIFICADORHIJO IS NULL THEN ' ' ELSE UPPER(CLASECLASIFICADORHIJO) END) LIKE UPPER(CONCAT(:CLASECLASIFICADORHIJO, '%')) AND (CASE WHEN NOMBREHIJO IS NULL THEN ' ' ELSE UPPER(NOMBREHIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREHIJO), '%')) AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASECLASIFICADORPADRE":"$CLASECLASIFICADORPADRE","NOMBREPADRE":"$NOMBREPADRE","CLASECLASIFICADORHIJO":"$CLASECLASIFICADORHIJO","NOMBREHIJO":"$NOMBREHIJO","ID":"$ID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCLASECLASI" sqlType="STRING"/>
