	<query id="getTipoclasificadorNumGettipoclasificadorsinregaliasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT T.CODIGO COD_TIPOCLASIFICADOR, T.NOMBRE TIPOCLASIFICADOR FROM CLASECLASIFICADOR C INNER JOIN TIPOCLASIFICADOR T ON C.COMPANIA= T.COMPANIA AND C.ANO = T.ANO AND C.CODIGO=T.CLASECLASIFICADOR WHERE T.CLASECLASIFICADOR = :CLASE AND C.COMPANIA = :COMPANIA AND C.ANO = :ANO AND (CASE WHEN :NATURALEZA = 'D' THEN C.APLICACION ELSE C.APLICACIONINGRESOS END) = :APLICACION AND (T.REGALIAS = CASE WHEN :REGALIAS = 0 THEN 0 ELSE 1 END OR T.REGALIAS = CASE WHEN :REGALIAS = 0 THEN 0 ELSE -1 END)) INI WHERE (CASE WHEN COD_TIPOCLASIFICADOR IS NULL THEN ' ' ELSE UPPER(COD_TIPOCLASIFICADOR) END) LIKE UPPER(CONCAT(:COD_TIPOCLASIFICADOR, '%')) AND (CASE WHEN TIPOCLASIFICADOR IS NULL THEN ' ' ELSE UPPER(TIPOCLASIFICADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCLASIFICADOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CLASE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="APLICACION" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="COD_TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>

	</query>
