<data name="tipoclasificador" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertTipoclasificadorInserttipoclasificadoranonue" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql> INSERT INTO TIPOCLASIFICADOR (COMPANIA ,ANO,CLASECLASIFICADOR,CODIGO,NOMBRE,DESCRIPCION, EQUIVALENTE, SECCIONESADI, MOVIMIENTO, REGALIAS,OBLIGACPCDANE ,CREATED_BY,DATE_CREATED) SELECT COMPANIA, :ANOPREPARAR ,CLASECLASIFICADOR,CODIGO,NOMBRE,DESCRIPCION, EQUIVALENTE, SECCIONESADI, MOVIMIENTO,REGALIAS ,OBLIGACPCDANE, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS') FROM TIPOCLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANOPREPARAR" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tipoclasificador/inserttipoclasificadoranonue">
		<call-query href="insertTipoclasificadorInserttipoclasificadoranonue">
			<with-param name="ANOPREPARAR" query-param="ANOPREPARAR"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorTiposclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,NOMBRE FROM TIPOCLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CLASECLASIFICADOR = :TIPOCLASIFICADOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/tiposclasificadores">
		<call-query href="getTipoclasificadorTiposclasificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorPagGettiposclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE FROM TIPOCLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CLASECLASIFICADOR = :TIPOCLASIFICADOR ORDER BY COMPANIA ,ANO,CLASECLASIFICADOR,CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettiposclasificadores/pag">
		<call-query href="getTipoclasificadorPagGettiposclasificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorNumGettiposclasificadoresQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE FROM TIPOCLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CLASECLASIFICADOR = :TIPOCLASIFICADOR ORDER BY COMPANIA ,ANO,CLASECLASIFICADOR,CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettiposclasificadores/num">
		<call-query href="getTipoclasificadorNumGettiposclasificadoresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorGettipoclasificadorplanpresuQuery"  useConfig="sysmandsunist">
		<sql>SELECT PL.TIPOCLASIFICADOR , CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND SUBSTR(:CUENTA,1,LENGTH(PL.CODIGO)) = PL.CODIGO AND PL.CLASECLASIFICADOR IS NOT NULL UNION SELECT SECTOR TIPOCLASIFICADOR, '001' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.SECTOR IS NOT NULL UNION SELECT PROGRAMA TIPOCLASIFICADOR, '002' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.PROGRAMA IS NOT NULL UNION SELECT SUBPROGRAMA TIPOCLASIFICADOR, '003' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.SUBPROGRAMA IS NOT NULL UNION SELECT CODIGOPRODUCTO TIPOCLASIFICADOR, '004' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.CODIGOPRODUCTO IS NOT NULL UNION SELECT CODIGOBPIN TIPOCLASIFICADOR, '005' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.CODIGOBPIN IS NOT NULL UNION SELECT CODIGOCCPET TIPOCLASIFICADOR, '006' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.CODIGOCCPET IS NOT NULL UNION SELECT CODIGOCPCDANE TIPOCLASIFICADOR, '007' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.CODIGOCPCDANE IS NOT NULL UNION SELECT CODIGOUNIDADEJE TIPOCLASIFICADOR, '008' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.CODIGOUNIDADEJE IS NOT NULL UNION SELECT CODIGOFUENTE TIPOCLASIFICADOR, '009' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.CODIGOFUENTE IS NOT NULL UNION SELECT CODIGOCCPETREGA TIPOCLASIFICADOR, '010' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.CODIGOCCPETREGA IS NOT NULL UNION SELECT POLITCA_PUBLICA_CUIPO TIPOCLASIFICADOR, '011' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.POLITCA_PUBLICA_CUIPO IS NOT NULL UNION SELECT DETALLE_SECTORIAL TIPOCLASIFICADOR, '012' AS CLASECLASIFICADOR FROM PLAN_PRESUPUESTAL PL WHERE PL.COMPANIA = :COMPANIA AND PL.ANO = :ANIO AND PL.TIPOVIGENCIA= 'VA' AND PL.CODIGO = :CUENTA AND PL.DETALLE_SECTORIAL IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOCLASIFICADOR":"$TIPOCLASIFICADOR","CLASECLASIFICADOR":"$CLASECLASIFICADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadorplanpresu">
		<call-query href="getTipoclasificadorGettipoclasificadorplanpresuQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorPagGettipoclasificadoregamovQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TC.CODIGO,TC.NOMBRE FROM CLASECLASIFICADOR CC INNER JOIN TIPOCLASIFICADOR TC ON (CC.COMPANIA = TC.COMPANIA) AND (CC.ANO = TC.ANO) AND (CC.CODIGO = TC.CLASECLASIFICADOR) WHERE CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO AND CC.APLICACION = 2 AND TC.CLASECLASIFICADOR = :TIPOCLASIFICADOR AND TC.MOVIMIENTO NOT IN(0) ORDER BY CC.COMPANIA ,CC.ANO,TC.CLASECLASIFICADOR,TC.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadoregamov/pag">
		<call-query href="getTipoclasificadorPagGettipoclasificadoregamovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorNumGettipoclasificadoregamovQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TC.CODIGO,TC.NOMBRE FROM CLASECLASIFICADOR CC INNER JOIN TIPOCLASIFICADOR TC ON (CC.COMPANIA = TC.COMPANIA) AND (CC.ANO = TC.ANO) AND (CC.CODIGO = TC.CLASECLASIFICADOR) WHERE CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO AND CC.APLICACION = 2 AND TC.CLASECLASIFICADOR = :TIPOCLASIFICADOR AND TC.MOVIMIENTO NOT IN(0) ORDER BY CC.COMPANIA ,CC.ANO,TC.CLASECLASIFICADOR,TC.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadoregamov/num">
		<call-query href="getTipoclasificadorNumGettipoclasificadoregamovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorPagGettipoclasificadoregaliasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TC.CODIGO,TC.NOMBRE FROM CLASECLASIFICADOR CC INNER JOIN TIPOCLASIFICADOR TC ON (CC.COMPANIA = TC.COMPANIA) AND (CC.ANO = TC.ANO) AND (CC.CODIGO = TC.CLASECLASIFICADOR) WHERE CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO AND CC.APLICACION = 2 AND TC.CLASECLASIFICADOR = :TIPOCLASIFICADOR AND ( REGALIAS = CASE WHEN :REGALIAS = 'NO' THEN 0 ELSE 1 END OR REGALIAS = CASE WHEN :REGALIAS = 'NO' THEN 0 ELSE -1 END ) ORDER BY CC.COMPANIA ,CC.ANO,TC.CLASECLASIFICADOR,TC.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadoregalias/pag">
		<call-query href="getTipoclasificadorPagGettipoclasificadoregaliasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>
			<with-param name="REGALIAS" query-param="REGALIAS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorNumGettipoclasificadoregaliasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TC.CODIGO,TC.NOMBRE FROM CLASECLASIFICADOR CC INNER JOIN TIPOCLASIFICADOR TC ON (CC.COMPANIA = TC.COMPANIA) AND (CC.ANO = TC.ANO) AND (CC.CODIGO = TC.CLASECLASIFICADOR) WHERE CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO AND CC.APLICACION = 2 AND TC.CLASECLASIFICADOR = :TIPOCLASIFICADOR AND ( REGALIAS = CASE WHEN :REGALIAS = 'NO' THEN 0 ELSE 1 END OR REGALIAS = CASE WHEN :REGALIAS = 'NO' THEN 0 ELSE -1 END ) ORDER BY CC.COMPANIA ,CC.ANO,TC.CLASECLASIFICADOR,TC.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCLASIFICADOR" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadoregalias/num">
		<call-query href="getTipoclasificadorNumGettipoclasificadoregaliasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCLASIFICADOR" query-param="TIPOCLASIFICADOR"/>
			<with-param name="REGALIAS" query-param="REGALIAS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertTipoclasificador" keyColumns="COMPANIA,ANO,ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOCLASIFICADOR (COMPANIA, ANO, CLASECLASIFICADOR, CODIGO, NOMBRE, DESCRIPCION, EQUIVALENTE, SECCIONESADI, MOVIMIENTO, REGALIAS, APLICAINGRESOS, PROGRAMACION, OBLIGACPCDANE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CLASECLASIFICADOR, :CODIGO, :NOMBRE, :DESCRIPCION, :EQUIVALENTE, :SECCIONESADI, :MOVIMIENTO, :REGALIAS, :APLICAINGRESOS, :PROGRAMACION, :OBLIGACPCDANE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_ID":"$ID"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVALENTE" sqlType="STRING"/>
		<param defaultValue="" name="SECCIONESADI" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="REGALIAS" sqlType="STRING"/>
		<param defaultValue="0" name="APLICAINGRESOS" sqlType="STRING"/>
		<param defaultValue="0" name="PROGRAMACION" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGACPCDANE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tipoclasificador">
		<call-query href="insertTipoclasificador">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CLASECLASIFICADOR" query-param="CLASECLASIFICADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="EQUIVALENTE" query-param="EQUIVALENTE"/>
			<with-param name="SECCIONESADI" query-param="SECCIONESADI"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="REGALIAS" query-param="REGALIAS"/>
			<with-param name="APLICAINGRESOS" query-param="APLICAINGRESOS"/>
			<with-param name="PROGRAMACION" query-param="PROGRAMACION"/>
			<with-param name="OBLIGACPCDANE" query-param="OBLIGACPCDANE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTipoclasificador" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPOCLASIFICADOR WHERE TIPOCLASIFICADOR.COMPANIA= :KEY_COMPANIA AND TIPOCLASIFICADOR.ANO= :KEY_ANO AND TIPOCLASIFICADOR.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tipoclasificador">
		<call-query href="deleteTipoclasificador">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
