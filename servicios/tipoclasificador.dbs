	<query id="getTipoclasificadorCcpetobligacpcdaneQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE OBLIGACPCDANE WHEN 0 THEN 'false' ELSE 'true' END) OBLIGACPCDANE FROM TIPOCLASIFICADOR WHERE COMPANIA=:COMPANIA AND ANO=:ANO AND CLASECLASIFICADOR=:CLASECLASIFICADOR AND CODIGO =:CODIGOCCPET</sql>
		<result outputType="json">{"elementos":{"elemento":[{"OBLIGACPCDANE":"$OBLIGACPCDANE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECLASIFICADOR" sqlType="STRING"/>
		<param name="CODIGOCCPET" sqlType="STRING"/>

	</query>
