	<query id="getTipoclasificadorPagGettipoclasificadorsinregaliasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT T.CODIGO COD_TIPOCLASIFICADOR, T.NOMBRE TIPOCLASIFICADOR FROM CLASECLASIFICADOR C INNER JOIN TIPOCLASIFICADOR T ON C.COMPANIA= T.COMPANIA AND C.ANO = T.ANO AND C.CODIGO=T.CLASECLASIFICADOR WHERE T.CLASECLASIFICADOR = :CLASE AND C.COMPANIA = :COMPANIA AND C.ANO = :ANO AND (CASE WHEN :NATURALEZA = 'D' THEN C.APLICACION ELSE C.APLICACIONINGRESOS END) = :APLICACION AND (T.REGALIAS = CASE WHEN :REGALIAS = 0 THEN 0 ELSE 1 END OR T.REGALIAS = CASE WHEN :REGALIAS = 0 THEN 0 ELSE -1 END)) INI WHERE (CASE WHEN COD_TIPOCLASIFICADOR IS NULL THEN ' ' ELSE UPPER(COD_TIPOCLASIFICADOR) END) LIKE UPPER(CONCAT(:COD_TIPOCLASIFICADOR, '%')) AND (CASE WHEN TIPOCLASIFICADOR IS NULL THEN ' ' ELSE UPPER(TIPOCLASIFICADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCLASIFICADOR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
