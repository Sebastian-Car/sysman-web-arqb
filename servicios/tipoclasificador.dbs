	<query id="getTipoclasificadorGettipoclasificadorporordenQuery"  useConfig="sysmandsunist">
		<sql>SELECT ORDEN, CODIGO, CASE WHEN CODIGO = '001' THEN 'SECTOR' WHEN CODIGO = '002' THEN 'PROGRAMA' WHEN CODIGO = '003' THEN 'SUBPROGRAMA' WHEN CODIGO = '004' THEN 'CODIGOPRODUCTO' WHEN CODIGO = '005' THEN 'CODIGOBPIN' WHEN CODIGO = '006' THEN 'CODIGOCCPET' WHEN CODIGO = '007' THEN 'CODIGOCPCDANE' WHEN CODIGO = '008' THEN 'CODIGOUNIDADEJE' WHEN CODIGO = '009' THEN 'CODIGOFUENTE' WHEN CODIGO = '010' THEN 'CODIGOCCPETREGA' WHEN CODIGO = '011' THEN 'POLITCA_PUBLICA_CUIPO' WHEN CODIGO = '012' THEN 'DETALLE_SECTORIAL' WHEN CODIGO = '013' THEN 'TIPO_RECURSO' END NOMBRE FROM CLASECLASIFICADOR WHERE COMPANIA = :COMPANIA AND :ANO = ANO AND APLICACION = 1 ORDER BY ORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ORDEN":"$ORDEN(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadorpororden">
		<call-query href="getTipoclasificadorGettipoclasificadorporordenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorPagCargardetallesectorialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE FROM TIPOCLASIFICADOR WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CLASECLASIFICADOR = '012' AND CASE WHEN :VALOR IN (0) THEN APLICAINGRESOS ELSE PROGRAMACION END NOT IN (0)) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
