	<query id="getTipoclasificadorGetplanoapropiacionesinicialesQuery"  useConfig="sysmandsunist">
		<sql>SELECT AP.CODIGO, AP.TERCERO, AP.SUCURSAL, AP.ID, PPPTAL.NOMBRE, AP.CENTRO_COSTO, CC.NOMBRE NOMBRE_CC, AP.AUXILIAR, AUX.NOMBRE NOMBRE_AUX, AP.REFERENCIA, RFRN.NOMBRE NOMBRE_REF, AP.FUENTE_RECURSO, FUE.NOMBRE NOMBRE_FUE, AP.CODIGO_CCPET, AP.PROGRAMA, AP.CODIGOUNIDADEJE, AP.CODIGOBPIN,AP.DETALLESECTORIAL, AP.APROPIACIONINICIAL FROM APROPIACIONESINICIALES AP INNER JOIN PLAN_PRESUPUESTAL PPPTAL ON (AP.COMPANIA = PPPTAL.COMPANIA AND AP.ANO = PPPTAL.ANO AND AP.CODIGO = PPPTAL.CODIGO) INNER JOIN CENTRO_COSTO CC ON (CC.COMPANIA = AP.COMPANIA AND CC.ANO = AP.ANO AND CC.CODIGO = AP.CENTRO_COSTO) INNER JOIN AUXILIAR AUX ON (AUX.COMPANIA = AP.COMPANIA AND AUX.ANO = AP.ANO AND AUX.CODIGO = AP.AUXILIAR) INNER JOIN REFERENCIA RFRN ON (RFRN.COMPANIA = AP.COMPANIA AND RFRN.ANO = AP.ANO AND RFRN.CODIGO = AP.REFERENCIA) INNER JOIN FUENTE_RECURSOS FUE ON (FUE.COMPANIA = AP.COMPANIA AND FUE.ANO = AP.ANO AND FUE.CODIGO = AP.FUENTE_RECURSO) WHERE AP.COMPANIA = :COMPANIA AND AP.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","ID":"$ID","NOMBRE":"$NOMBRE","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRE_CC":"$NOMBRE_CC","AUXILIAR":"$AUXILIAR","NOMBRE_AUX":"$NOMBRE_AUX","REFERENCIA":"$REFERENCIA","NOMBRE_REF":"$NOMBRE_REF","FUENTE_RECURSO":"$FUENTE_RECURSO","NOMBRE_FUE":"$NOMBRE_FUE","CODIGO_CCPET":"$CODIGO_CCPET","PROGRAMA":"$PROGRAMA","CODIGOUNIDADEJE":"$CODIGOUNIDADEJE","CODIGOBPIN":"$CODIGOBPIN","DETALLESECTORIAL":"$DETALLESECTORIAL","APROPIACIONINICIAL":"$APROPIACIONINICIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/getplanoapropiacionesiniciales">
		<call-query href="getTipoclasificadorGetplanoapropiacionesinicialesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorPagGettipoclasificadorhijoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE FROM ( SELECT DISTINCT TCH.IDHIJO, CC.CODIGO CLASFIFICADORHIJO, CC.NOMBRE NOMBREPADRE, TC.CODIGO, TC.NOMBRE FROM TIPOCLASIFICADORESHIJO TCH INNER JOIN TIPOCLASIFICADOR TC ON ( TCH.IDHIJO = TC.ID ) INNER JOIN CLASECLASIFICADOR CC ON ( TC.CLASECLASIFICADOR = CC.CODIGO ) WHERE TCH.IDPADRE = :IDPADRE AND CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO) ORDER BY CODIGO ASC) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadorhijo/pag">
		<call-query href="getTipoclasificadorPagGettipoclasificadorhijoQuery">
			<with-param name="IDPADRE" query-param="IDPADRE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTipoclasificadorNumGettipoclasificadorhijoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE FROM ( SELECT DISTINCT TCH.IDHIJO, CC.CODIGO CLASFIFICADORHIJO, CC.NOMBRE NOMBREPADRE, TC.CODIGO, TC.NOMBRE FROM TIPOCLASIFICADORESHIJO TCH INNER JOIN TIPOCLASIFICADOR TC ON ( TCH.IDHIJO = TC.ID ) INNER JOIN CLASECLASIFICADOR CC ON ( TC.CLASECLASIFICADOR = CC.CODIGO ) WHERE TCH.IDPADRE = :IDPADRE AND CC.COMPANIA = :COMPANIA AND CC.ANO = :ANO) ORDER BY CODIGO ASC) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="IDPADRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tipoclasificador/gettipoclasificadorhijo/num">
		<call-query href="getTipoclasificadorNumGettipoclasificadorhijoQuery">
			<with-param name="IDPADRE" query-param="IDPADRE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateTipoclasificadorUpdateapropiacionesincialespptal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPOCLASIFICADOR SET CODIGOBPIN=:CODIGOBPIN, CODIGO_CCPET=:CODIGO_CCPET, PROGRAMA=:PROGRAMA, CODIGOUNIDADEJE=:CODIGOUNIDADEJE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPOCLASIFICADOR.COMPANIA= :KEY_COMPANIA AND TIPOCLASIFICADOR.ANO= :KEY_ANO AND TIPOCLASIFICADOR.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOBPIN" sqlType="STRING"/>
		<param name="CODIGO_CCPET" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="CODIGOUNIDADEJE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tipoclasificador/updateapropiacionesincialespptal">
		<call-query href="updateTipoclasificadorUpdateapropiacionesincialespptal">
			<with-param name="CODIGOBPIN" query-param="CODIGOBPIN"/>
			<with-param name="CODIGO_CCPET" query-param="CODIGO_CCPET"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
			<with-param name="CODIGOUNIDADEJE" query-param="CODIGOUNIDADEJE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>
	
	

		</call-query>
	</resource>

	<query id="getTipoclasificadorPagGettipoclasificadorcombomayorigualQuery"  useConfig="sysmandsunist">
