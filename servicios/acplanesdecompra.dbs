<data name="acplanesdecompra" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertAcplanesdecompra" keyColumns="ACTUALIZACION,COMPANIA,ANO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ACTPLAN_DE_COMPRAS (COMPANIA, ACTUALIZACION, ANO, FECHA, NUMEROOFICIO, REALIZADA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ACTUALIZACION, :ANO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :NUMEROOFICIO, :REALIZADA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_ACTUALIZACION":"$ACTUALIZACION(type:long)","KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="ACTUALIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="NUMEROOFICIO" sqlType="STRING"/>
		<param defaultValue="0" name="REALIZADA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="acplanesdecompra">
		<call-query href="insertAcplanesdecompra">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACTUALIZACION" query-param="ACTUALIZACION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMEROOFICIO" query-param="NUMEROOFICIO"/>
			<with-param name="REALIZADA" query-param="REALIZADA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteAcplanesdecompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ACTPLAN_DE_COMPRAS WHERE ACTPLAN_DE_COMPRAS.ACTUALIZACION= :KEY_ACTUALIZACION AND ACTPLAN_DE_COMPRAS.COMPANIA= :KEY_COMPANIA AND ACTPLAN_DE_COMPRAS.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_ACTUALIZACION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="acplanesdecompra">
		<call-query href="deleteAcplanesdecompra">
			<with-param name="KEY_ACTUALIZACION" query-param="KEY_ACTUALIZACION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getAcplanesdecompraPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ACTUALIZACION, ANO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, NUMEROOFICIO  FROM ACTPLAN_DE_COMPRAS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ACTUALIZACION IS NULL THEN ' ' ELSE UPPER(ACTUALIZACION) END)  LIKE UPPER(:ACTUALIZACION || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN NUMEROOFICIO IS NULL THEN ' ' ELSE UPPER(NUMEROOFICIO) END)  LIKE UPPER(:NUMEROOFICIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ACTUALIZACION":"$ACTUALIZACION(type:long)","ANO":"$ANO(type:integer)","FECHA":"$FECHA","NUMEROOFICIO":"$NUMEROOFICIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACTUALIZACION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMEROOFICIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="acplanesdecompra">
		<call-query href="getAcplanesdecompraPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACTUALIZACION" query-param="ACTUALIZACION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMEROOFICIO" query-param="NUMEROOFICIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAcplanesdecompraNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ACTUALIZACION, ANO, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, NUMEROOFICIO  FROM ACTPLAN_DE_COMPRAS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ACTUALIZACION IS NULL THEN ' ' ELSE UPPER(ACTUALIZACION) END)  LIKE UPPER(:ACTUALIZACION || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN NUMEROOFICIO IS NULL THEN ' ' ELSE UPPER(NUMEROOFICIO) END)  LIKE UPPER(:NUMEROOFICIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACTUALIZACION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMEROOFICIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="acplanesdecompra/numero">
		<call-query href="getAcplanesdecompraNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACTUALIZACION" query-param="ACTUALIZACION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMEROOFICIO" query-param="NUMEROOFICIO"/>

		</call-query>
	</resource>
	<query id="getAcplanesdecompraRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ACTUALIZACION, ANO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, NUMEROOFICIO,(CASE REALIZADA WHEN 0 THEN 'false' ELSE 'true' END) REALIZADA, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM ACTPLAN_DE_COMPRAS WHERE ACTPLAN_DE_COMPRAS.ACTUALIZACION= :KEY_ACTUALIZACION AND ACTPLAN_DE_COMPRAS.COMPANIA= :KEY_COMPANIA AND ACTPLAN_DE_COMPRAS.ANO= :KEY_ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ACTUALIZACION":"$ACTUALIZACION(type:long)","ANO":"$ANO(type:integer)","FECHA":"$FECHA","NUMEROOFICIO":"$NUMEROOFICIO","REALIZADA":"$REALIZADA(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_ACTUALIZACION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="acplanesdecompra/data">
		<call-query href="getAcplanesdecompraRegistroQuery">
			<with-param name="KEY_ACTUALIZACION" query-param="KEY_ACTUALIZACION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="updateAcplanesdecompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ACTPLAN_DE_COMPRAS SET COMPANIA=:COMPANIA, ACTUALIZACION=:ACTUALIZACION, ANO=:ANO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), NUMEROOFICIO=:NUMEROOFICIO, REALIZADA=:REALIZADA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ACTPLAN_DE_COMPRAS.ACTUALIZACION= :KEY_ACTUALIZACION AND ACTPLAN_DE_COMPRAS.COMPANIA= :KEY_COMPANIA AND ACTPLAN_DE_COMPRAS.ANO= :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACTUALIZACION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMEROOFICIO" sqlType="STRING"/>
		<param name="REALIZADA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_ACTUALIZACION" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="acplanesdecompra">
		<call-query href="updateAcplanesdecompra">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACTUALIZACION" query-param="ACTUALIZACION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMEROOFICIO" query-param="NUMEROOFICIO"/>
			<with-param name="REALIZADA" query-param="REALIZADA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_ACTUALIZACION" query-param="KEY_ACTUALIZACION"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>

</data>