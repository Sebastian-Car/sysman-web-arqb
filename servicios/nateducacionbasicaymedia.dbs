	<query id="getNateducacionbasicaymediaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, NUMERO_DCTO, SUCURSAL, NEB_CODIGOPERSONA, GRADO, TITULO, ESTABLECIMIENTO, MUNTERMINO, DEPTERMINO, PAISTERMINO, NEB_NUMDOCUMENTO,(TO_CHAR(FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS')) FECHATERMINACION FROM NAT_EDUCACION_BASICAYMEDIA WHERE NAT_EDUCACION_BASICAYMEDIA.COMPANIA= :KEY_COMPANIA AND NAT_EDUCACION_BASICAYMEDIA.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_EDUCACION_BASICAYMEDIA.SUCURSAL= :KEY_SUCURSAL AND NAT_EDUCACION_BASICAYMEDIA.GRADO= :KEY_GRADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NEB_CODIGOPERSONA":"$NEB_CODIGOPERSONA","GRADO":"$GRADO","TITULO":"$TITULO","ESTABLECIMIENTO":"$ESTABLECIMIENTO","MUNTERMINO":"$MUNTERMINO","DEPTERMINO":"$DEPTERMINO","PAISTERMINO":"$PAISTERMINO","NEB_NUMDOCUMENTO":"$NEB_NUMDOCUMENTO","FECHATERMINACION":"$FECHATERMINACION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_GRADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nateducacionbasicaymedia/data">
