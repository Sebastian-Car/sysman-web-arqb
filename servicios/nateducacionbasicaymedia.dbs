			<with-param name="DEPTERMINO" query-param="DEPTERMINO"/>
			<with-param name="PAISTERMINO" query-param="PAISTERMINO"/>
			<with-param name="NEB_NUMDOCUMENTO" query-param="NEB_NUMDOCUMENTO"/>
			<with-param name="FECHATERMINACION" query-param="FECHATERMINACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNateducacionbasicaymedia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_EDUCACION_BASICAYMEDIA WHERE NAT_EDUCACION_BASICAYMEDIA.COMPANIA= :KEY_COMPANIA AND NAT_EDUCACION_BASICAYMEDIA.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_EDUCACION_BASICAYMEDIA.SUCURSAL= :KEY_SUCURSAL AND NAT_EDUCACION_BASICAYMEDIA.GRADO= :KEY_GRADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_GRADO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="nateducacionbasicaymedia">
		<call-query href="deleteNateducacionbasicaymedia">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_GRADO" query-param="KEY_GRADO"/>

		</call-query>
	</resource>
	<query id="getNateducacionbasicaymediaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_EDUCACION_BASICAYMEDIA.COMPANIA, NAT_EDUCACION_BASICAYMEDIA.NUMERO_DCTO, NAT_EDUCACION_BASICAYMEDIA.SUCURSAL, NAT_EDUCACION_BASICAYMEDIA.GRADO, NAT_EDUCACION_BASICAYMEDIA.TITULO, NAT_EDUCACION_BASICAYMEDIA.ESTABLECIMIENTO,(TO_CHAR(NAT_EDUCACION_BASICAYMEDIA.FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS')) FECHATERMINACION, NAT_EDUCACION_BASICAYMEDIA.PAISTERMINO, NAT_EDUCACION_BASICAYMEDIA.NEB_CODIGOPERSONA, NAT_EDUCACION_BASICAYMEDIA.DEPTERMINO, NAT_EDUCACION_BASICAYMEDIA.MUNTERMINO, UPPER(PAISES.NOMBRE) NOMBREPAIS, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTO, CIUDAD.NOMBRE NMBREMUNICIPIO, INSTITUCIONES_EDUCATIVAS.NOMBRE NOMBREINSTITUCION, ( CASE NAT_EDUCACION_BASICAYMEDIA.GRADO WHEN 1 THEN '1 Primaria' WHEN 2 THEN '2 Primaria' WHEN 3 THEN '3 Primaria' WHEN 4 THEN '4 Primaria' WHEN 5 THEN '5 Primaria' WHEN 6 THEN '6 Secundaria' WHEN 7 THEN '7 Secundaria' WHEN 8 THEN '8 Secundaria' WHEN 9 THEN '9 Secundaria' WHEN 10 THEN '10 Media' WHEN 11 THEN '11 Media' END) GRADONOMBRE, PROFESIONES.NOMBRE_PROFESION  FROM NAT_EDUCACION_BASICAYMEDIA LEFT JOIN PAISES ON NAT_EDUCACION_BASICAYMEDIA.PAISTERMINO = PAISES.PAIS LEFT JOIN DEPARTAMENTO ON NAT_EDUCACION_BASICAYMEDIA.PAISTERMINO = DEPARTAMENTO.PAIS AND NAT_EDUCACION_BASICAYMEDIA.DEPTERMINO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON NAT_EDUCACION_BASICAYMEDIA.PAISTERMINO = CIUDAD.PAIS AND NAT_EDUCACION_BASICAYMEDIA.DEPTERMINO = CIUDAD.DEPARTAMENTO AND NAT_EDUCACION_BASICAYMEDIA.MUNTERMINO = CIUDAD.CODIGO LEFT JOIN INSTITUCIONES_EDUCATIVAS ON NAT_EDUCACION_BASICAYMEDIA.ESTABLECIMIENTO = INSTITUCIONES_EDUCATIVAS.NIT LEFT JOIN PROFESIONES ON NAT_EDUCACION_BASICAYMEDIA.TITULO = PROFESIONES.CODIGOPROF WHERE NAT_EDUCACION_BASICAYMEDIA.COMPANIA = :COMPANIA AND NAT_EDUCACION_BASICAYMEDIA.NUMERO_DCTO = :NUMERO_DCTO AND NAT_EDUCACION_BASICAYMEDIA.SUCURSAL = :SUCURSAL) WHERE (CASE WHEN FECHATERMINACION IS NULL THEN ' ' ELSE UPPER(FECHATERMINACION) END)  LIKE UPPER( '%' || :FECHATERMINACION || '%')  AND (CASE WHEN NOMBREPAIS IS NULL THEN ' ' ELSE UPPER(NOMBREPAIS) END)  LIKE UPPER( '%' || :NOMBREPAIS || '%')  AND (CASE WHEN NOMBREDEPARTAMENTO IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTO) END)  LIKE UPPER( '%' || :NOMBREDEPARTAMENTO || '%')  AND (CASE WHEN NMBREMUNICIPIO IS NULL THEN ' ' ELSE UPPER(NMBREMUNICIPIO) END)  LIKE UPPER(:NMBREMUNICIPIO || '%')  AND (CASE WHEN NOMBREINSTITUCION IS NULL THEN ' ' ELSE UPPER(NOMBREINSTITUCION) END)  LIKE UPPER( '%' || :NOMBREINSTITUCION || '%')  AND (CASE WHEN GRADONOMBRE IS NULL THEN ' ' ELSE UPPER(GRADONOMBRE) END)  LIKE UPPER( '%' || :GRADONOMBRE || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","GRADO":"$GRADO","TITULO":"$TITULO","ESTABLECIMIENTO":"$ESTABLECIMIENTO","FECHATERMINACION":"$FECHATERMINACION","PAISTERMINO":"$PAISTERMINO","NEB_CODIGOPERSONA":"$NEB_CODIGOPERSONA","DEPTERMINO":"$DEPTERMINO","MUNTERMINO":"$MUNTERMINO","NOMBREPAIS":"$NOMBREPAIS","NOMBREDEPARTAMENTO":"$NOMBREDEPARTAMENTO","NMBREMUNICIPIO":"$NMBREMUNICIPIO","NOMBREINSTITUCION":"$NOMBREINSTITUCION","GRADONOMBRE":"$GRADONOMBRE","NOMBRE_PROFESION":"$NOMBRE_PROFESION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHATERMINACION" sqlType="STRING"/>
		<param name="NOMBREPAIS" sqlType="STRING"/>
		<param name="NOMBREDEPARTAMENTO" sqlType="STRING"/>
		<param name="NMBREMUNICIPIO" sqlType="STRING"/>
		<param name="NOMBREINSTITUCION" sqlType="STRING"/>
		<param name="GRADONOMBRE" sqlType="STRING"/>
		<param name="NOMBRE_PROFESION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="nateducacionbasicaymedia">
		<call-query href="getNateducacionbasicaymediaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="FECHATERMINACION" query-param="FECHATERMINACION"/>
