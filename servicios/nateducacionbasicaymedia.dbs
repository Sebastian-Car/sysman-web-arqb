<data name="nateducacionbasicaymedia" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNateducacionbasicaymediaTieneEducacionMediaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  GRADO  FROM NAT_EDUCACION_BASICAYMEDIA WHERE COMPANIA = :COMPANIA AND NUMERO_DCTO = :NUMERO_DCTO AND SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"GRADO":"$GRADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="nateducacionbasicaymedia/tieneeducacionmedia">
		<call-query href="getNateducacionbasicaymediaTieneEducacionMediaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="insertNateducacionbasicaymedia" keyColumns="COMPANIA,NUMERO_DCTO,SUCURSAL,GRADO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_EDUCACION_BASICAYMEDIA (COMPANIA, NUMERO_DCTO, SUCURSAL, NEB_CODIGOPERSONA, GRADO, TITULO, ESTABLECIMIENTO, MUNTERMINO, DEPTERMINO, PAISTERMINO, NEB_NUMDOCUMENTO, FECHATERMINACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_DCTO, :SUCURSAL, :NEB_CODIGOPERSONA, :GRADO, :TITULO, :ESTABLECIMIENTO, :MUNTERMINO, :DEPTERMINO, :PAISTERMINO, :NEB_NUMDOCUMENTO, TO_DATE(:FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_GRADO":"$GRADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NEB_CODIGOPERSONA" sqlType="STRING"/>
		<param name="GRADO" sqlType="STRING"/>
		<param defaultValue="" name="TITULO" sqlType="STRING"/>
		<param defaultValue="" name="ESTABLECIMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="MUNTERMINO" sqlType="STRING"/>
		<param defaultValue="" name="DEPTERMINO" sqlType="STRING"/>
		<param defaultValue="" name="PAISTERMINO" sqlType="STRING"/>
		<param defaultValue="" name="NEB_NUMDOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHATERMINACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="nateducacionbasicaymedia">
		<call-query href="insertNateducacionbasicaymedia">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NEB_CODIGOPERSONA" query-param="NEB_CODIGOPERSONA"/>
			<with-param name="GRADO" query-param="GRADO"/>
			<with-param name="TITULO" query-param="TITULO"/>
