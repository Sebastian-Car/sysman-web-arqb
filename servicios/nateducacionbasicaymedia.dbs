	<query id="updateNateducacionbasicaymedia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_EDUCACION_BASICAYMEDIA SET COMPANIA=:COMPANIA, NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, NEB_CODIGOPERSONA=:NEB_CODIGOPERSONA, GRADO=:GRADO, TITULO=:TITULO, ESTABLECIMIENTO=:ESTABLECIMIENTO, MUNTERMINO=:MUNTERMINO, DEPTERMINO=:DEPTERMINO, PAISTERMINO=:PAISTERMINO, FECHATERMINACION=TO_DATE(:FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_EDUCACION_BASICAYMEDIA.COMPANIA= :KEY_COMPANIA AND NAT_EDUCACION_BASICAYMEDIA.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_EDUCACION_BASICAYMEDIA.SUCURSAL= :KEY_SUCURSAL AND NAT_EDUCACION_BASICAYMEDIA.GRADO= :KEY_GRADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NEB_CODIGOPERSONA" sqlType="STRING"/>
		<param name="GRADO" sqlType="STRING"/>
		<param name="TITULO" sqlType="STRING"/>
		<param name="ESTABLECIMIENTO" sqlType="STRING"/>
		<param name="MUNTERMINO" sqlType="STRING"/>
		<param name="DEPTERMINO" sqlType="STRING"/>
		<param name="PAISTERMINO" sqlType="STRING"/>
		<param name="FECHATERMINACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_GRADO" sqlType="STRING"/>

	</query>
