<data name="saldosplanespptal" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSaldosplanespptalPagProgramacionPacTesoreriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SALDO_PLAN_PPTAL.COMPANIA, SALDO_PLAN_PPTAL.ANO, SALDO_PLAN_PPTAL.CODIGO, SALDO_PLAN_PPTAL.MES , CASE SALDO_PLAN_PPTAL.MES WHEN 0 THEN 'Saldo Inicial' WHEN 1 THEN 'Enero' WHEN 2 THEN 'Febrero' WHEN 3 THEN 'Marzo' WHEN 4 THEN 'Abril' WHEN 5 THEN 'Mayo' WHEN 6 THEN 'Junio' WHEN 7 THEN 'Julio' WHEN 8 THEN 'Agosto' WHEN 9 THEN 'Septiembre' WHEN 10 THEN 'Octubre' WHEN 11 THEN 'Noviembre' WHEN 12 THEN 'Diciembre' END MESN, ((CASE WHEN NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END) + (SALDO_PLAN_PPTAL.ADICION+SALDO_PLAN_PPTAL.REDUCCION+(CASE WHEN NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END))) TOTALAPROPIACION, SALDO_PLAN_PPTAL.PACTESORERIA, (CASE WHEN NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONES, (CASE WHEN NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONESCNT, SALDO_PLAN_PPTAL.PACTESORERIA - (CASE WHEN NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) SALDOPACTESORERIAMENSUAL, PCK_GENERALES.FC_SALDOPPTAL(SALDO_PLAN_PPTAL.COMPANIA,'SALDOPACTESORERIA',SALDO_PLAN_PPTAL.ANO , SALDO_PLAN_PPTAL.CODIGO, SALDO_PLAN_PPTAL.MES) SALDO  FROM SALDO_PLAN_PPTAL LEFT JOIN V_PLAN_PRESUPUESTAL ON SALDO_PLAN_PPTAL.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND SALDO_PLAN_PPTAL.ANO = V_PLAN_PRESUPUESTAL.ANO AND SALDO_PLAN_PPTAL.CODIGO = V_PLAN_PRESUPUESTAL.ID WHERE SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND SALDO_PLAN_PPTAL.ANO = :ANO AND SALDO_PLAN_PPTAL.CODIGO = :CODIGO AND SALDO_PLAN_PPTAL.MES BETWEEN 0 AND 12 ORDER BY SALDO_PLAN_PPTAL.COMPANIA, SALDO_PLAN_PPTAL.ANO, SALDO_PLAN_PPTAL.CODIGO, SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN MESN IS NULL THEN ' ' ELSE UPPER(MESN) END)  LIKE UPPER( '%' || :MESN || '%')  AND (CASE WHEN TOTALAPROPIACION IS NULL THEN ' ' ELSE UPPER(TOTALAPROPIACION) END)  LIKE UPPER(:TOTALAPROPIACION || '%')  AND (CASE WHEN PACTESORERIA IS NULL THEN ' ' ELSE UPPER(PACTESORERIA) END)  LIKE UPPER(:PACTESORERIA || '%')  AND (CASE WHEN EJECUCIONES IS NULL THEN ' ' ELSE UPPER(EJECUCIONES) END)  LIKE UPPER(:EJECUCIONES || '%')  AND (CASE WHEN EJECUCIONESCNT IS NULL THEN ' ' ELSE UPPER(EJECUCIONESCNT) END)  LIKE UPPER(:EJECUCIONESCNT || '%')  AND (CASE WHEN SALDOPACTESORERIAMENSUAL IS NULL THEN ' ' ELSE UPPER(SALDOPACTESORERIAMENSUAL) END)  LIKE UPPER(:SALDOPACTESORERIAMENSUAL || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER(:SALDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","MES":"$MES(type:integer)","MESN":"$MESN","TOTALAPROPIACION":"$TOTALAPROPIACION(type:integer)","PACTESORERIA":"$PACTESORERIA(type:double)","EJECUCIONES":"$EJECUCIONES(type:integer)","EJECUCIONESCNT":"$EJECUCIONESCNT(type:integer)","SALDOPACTESORERIAMENSUAL":"$SALDOPACTESORERIAMENSUAL(type:integer)","SALDO":"$SALDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MESN" sqlType="STRING"/>
		<param name="TOTALAPROPIACION" sqlType="STRING"/>
		<param name="PACTESORERIA" sqlType="STRING"/>
		<param name="EJECUCIONES" sqlType="STRING"/>
		<param name="EJECUCIONESCNT" sqlType="STRING"/>
		<param name="SALDOPACTESORERIAMENSUAL" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="saldosplanespptal/programacionpactesoreria/pag">
		<call-query href="getSaldosplanespptalPagProgramacionPacTesoreriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MESN" query-param="MESN"/>
			<with-param name="TOTALAPROPIACION" query-param="TOTALAPROPIACION"/>
			<with-param name="PACTESORERIA" query-param="PACTESORERIA"/>
			<with-param name="EJECUCIONES" query-param="EJECUCIONES"/>
			<with-param name="EJECUCIONESCNT" query-param="EJECUCIONESCNT"/>
			<with-param name="SALDOPACTESORERIAMENSUAL" query-param="SALDOPACTESORERIAMENSUAL"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSaldosplanespptalNumProgramacionPacTesoreriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SALDO_PLAN_PPTAL.COMPANIA, SALDO_PLAN_PPTAL.ANO, SALDO_PLAN_PPTAL.CODIGO, SALDO_PLAN_PPTAL.MES , CASE SALDO_PLAN_PPTAL.MES WHEN 0 THEN 'Saldo Inicial' WHEN 1 THEN 'Enero' WHEN 2 THEN 'Febrero' WHEN 3 THEN 'Marzo' WHEN 4 THEN 'Abril' WHEN 5 THEN 'Mayo' WHEN 6 THEN 'Junio' WHEN 7 THEN 'Julio' WHEN 8 THEN 'Agosto' WHEN 9 THEN 'Septiembre' WHEN 10 THEN 'Octubre' WHEN 11 THEN 'Noviembre' WHEN 12 THEN 'Diciembre' END MESN, ((CASE WHEN NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END) + (SALDO_PLAN_PPTAL.ADICION+SALDO_PLAN_PPTAL.REDUCCION+(CASE WHEN NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END))) TOTALAPROPIACION, SALDO_PLAN_PPTAL.PACTESORERIA, (CASE WHEN NATURALEZA = 'D' THEN EJE_PPT_DEBITO - EJE_PPT_CREDITO ELSE EJE_PPT_CREDITO - EJE_PPT_DEBITO END ) EJECUCIONES, (CASE WHEN NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) EJECUCIONESCNT, SALDO_PLAN_PPTAL.PACTESORERIA - (CASE WHEN NATURALEZA = 'D' THEN EJE_CNT_DEBITO - EJE_CNT_CREDITO ELSE EJE_CNT_CREDITO - EJE_CNT_DEBITO END ) SALDOPACTESORERIAMENSUAL, PCK_GENERALES.FC_SALDOPPTAL(SALDO_PLAN_PPTAL.COMPANIA,'SALDOPACTESORERIA',SALDO_PLAN_PPTAL.ANO , SALDO_PLAN_PPTAL.CODIGO, SALDO_PLAN_PPTAL.MES) SALDO  FROM SALDO_PLAN_PPTAL LEFT JOIN V_PLAN_PRESUPUESTAL ON SALDO_PLAN_PPTAL.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND SALDO_PLAN_PPTAL.ANO = V_PLAN_PRESUPUESTAL.ANO AND SALDO_PLAN_PPTAL.CODIGO = V_PLAN_PRESUPUESTAL.ID WHERE SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND SALDO_PLAN_PPTAL.ANO = :ANO AND SALDO_PLAN_PPTAL.CODIGO = :CODIGO AND SALDO_PLAN_PPTAL.MES BETWEEN 0 AND 12 ORDER BY SALDO_PLAN_PPTAL.COMPANIA, SALDO_PLAN_PPTAL.ANO, SALDO_PLAN_PPTAL.CODIGO, SALDO_PLAN_PPTAL.MES) WHERE (CASE WHEN MESN IS NULL THEN ' ' ELSE UPPER(MESN) END)  LIKE UPPER( '%' || :MESN || '%')  AND (CASE WHEN TOTALAPROPIACION IS NULL THEN ' ' ELSE UPPER(TOTALAPROPIACION) END)  LIKE UPPER( '%' || :TOTALAPROPIACION || '%')  AND (CASE WHEN PACTESORERIA IS NULL THEN ' ' ELSE UPPER(PACTESORERIA) END)  LIKE UPPER( '%' || :PACTESORERIA || '%')  AND (CASE WHEN EJECUCIONES IS NULL THEN ' ' ELSE UPPER(EJECUCIONES) END)  LIKE UPPER( '%' || :EJECUCIONES || '%')  AND (CASE WHEN EJECUCIONESCNT IS NULL THEN ' ' ELSE UPPER(EJECUCIONESCNT) END)  LIKE UPPER( '%' || :EJECUCIONESCNT || '%')  AND (CASE WHEN SALDOPACTESORERIAMENSUAL IS NULL THEN ' ' ELSE UPPER(SALDOPACTESORERIAMENSUAL) END)  LIKE UPPER( '%' || :SALDOPACTESORERIAMENSUAL || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER( '%' || :SALDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MESN" sqlType="STRING"/>
		<param name="TOTALAPROPIACION" sqlType="STRING"/>
		<param name="PACTESORERIA" sqlType="STRING"/>
		<param name="EJECUCIONES" sqlType="STRING"/>
		<param name="EJECUCIONESCNT" sqlType="STRING"/>
		<param name="SALDOPACTESORERIAMENSUAL" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="saldosplanespptal/programacionpactesoreria/num">
		<call-query href="getSaldosplanespptalNumProgramacionPacTesoreriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MESN" query-param="MESN"/>
			<with-param name="TOTALAPROPIACION" query-param="TOTALAPROPIACION"/>
			<with-param name="PACTESORERIA" query-param="PACTESORERIA"/>
			<with-param name="EJECUCIONES" query-param="EJECUCIONES"/>
			<with-param name="EJECUCIONESCNT" query-param="EJECUCIONESCNT"/>
			<with-param name="SALDOPACTESORERIAMENSUAL" query-param="SALDOPACTESORERIAMENSUAL"/>
			<with-param name="SALDO" query-param="SALDO"/>

		</call-query>
	</resource>
	<query id="updateSaldosplanespptalProgramacionPacTesoreria" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SALDO_PLAN_PPTAL SET PACTESORERIA=:PACTESORERIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SALDO_PLAN_PPTAL.COMPANIA= :KEY_COMPANIA AND SALDO_PLAN_PPTAL.ANO= :KEY_ANO AND SALDO_PLAN_PPTAL.CODIGO= :KEY_CODIGO AND SALDO_PLAN_PPTAL.MES= :KEY_MES</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PACTESORERIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="saldosplanespptal/programacionpactesoreria">
		<call-query href="updateSaldosplanespptalProgramacionPacTesoreria">
			<with-param name="PACTESORERIA" query-param="PACTESORERIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>

		</call-query>
	</resource>
	<query id="getSaldosplanespptalTotalApropiacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ((CASE WHEN NATURALEZA = 'D' THEN APROPIACION_DEBITO - APROPIACION_CREDITO ELSE APROPIACION_CREDITO - APROPIACION_DEBITO END) + (SALDO_PLAN_PPTAL.ADICION+SALDO_PLAN_PPTAL.REDUCCION + (CASE WHEN NATURALEZA = 'D' THEN TRASLADO_DEBITO - TRASLADO_CREDITO ELSE TRASLADO_CREDITO - TRASLADO_DEBITO END))) TOTALAPROPIACION  FROM SALDO_PLAN_PPTAL LEFT JOIN V_PLAN_PRESUPUESTAL ON SALDO_PLAN_PPTAL.COMPANIA = V_PLAN_PRESUPUESTAL.COMPANIA AND SALDO_PLAN_PPTAL.ANO = V_PLAN_PRESUPUESTAL.ANO AND SALDO_PLAN_PPTAL.CODIGO = V_PLAN_PRESUPUESTAL.ID WHERE SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND SALDO_PLAN_PPTAL.ANO = :ANO AND SALDO_PLAN_PPTAL.CODIGO = :CODIGO AND SALDO_PLAN_PPTAL.MES = 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTALAPROPIACION":"$TOTALAPROPIACION(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="saldosplanespptal/totalapropiacion">
		<call-query href="getSaldosplanespptalTotalApropiacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="updateSaldosplanespptalPacTesoreria" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SALDO_PLAN_PPTAL SET PACTESORERIA = :PACTESORERIA , DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND MES = :MES AND LENGTH(SALDO_PLAN_PPTAL.CODIGO) &lt; LENGTH(:CODIGO) AND SALDO_PLAN_PPTAL.CODIGO=SUBSTR(:CODIGO,0,LENGTH(SALDO_PLAN_PPTAL.CODIGO))</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PACTESORERIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="saldosplanespptal/pactesoreria">
		<call-query href="updateSaldosplanespptalPacTesoreria">
			<with-param name="PACTESORERIA" query-param="PACTESORERIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="deleteSaldosplanespptalEliminarPorCodigo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE SALDO_PLAN_PPTAL WHERE CODIGO = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="saldosplanespptal/eliminarporcodigo">
		<call-query href="deleteSaldosplanespptalEliminarPorCodigo">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>

</data>