<data name="sstprocesos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSstprocesosPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, PROCESO NOMBRE_PROCESO, ZONA_LUGAR, ACTIVIDADES, TAREAS  FROM SST_PROCESOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE_PROCESO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROCESO) END)  LIKE UPPER( '%' || :NOMBRE_PROCESO || '%')  AND (CASE WHEN ZONA_LUGAR IS NULL THEN ' ' ELSE UPPER(ZONA_LUGAR) END)  LIKE UPPER( '%' || :ZONA_LUGAR || '%')  AND (CASE WHEN ACTIVIDADES IS NULL THEN ' ' ELSE UPPER(ACTIVIDADES) END)  LIKE UPPER( '%' || :ACTIVIDADES || '%')  AND (CASE WHEN TAREAS IS NULL THEN ' ' ELSE UPPER(TAREAS) END)  LIKE UPPER( '%' || :TAREAS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE_PROCESO":"$NOMBRE_PROCESO","ZONA_LUGAR":"$ZONA_LUGAR","ACTIVIDADES":"$ACTIVIDADES","TAREAS":"$TAREAS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TAREAS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstprocesos/todosporcompania/pag">
		<call-query href="getSstprocesosPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_PROCESO" query-param="NOMBRE_PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TAREAS" query-param="TAREAS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstprocesosNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, PROCESO NOMBRE_PROCESO, ZONA_LUGAR, ACTIVIDADES, TAREAS  FROM SST_PROCESOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE_PROCESO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROCESO) END)  LIKE UPPER( '%' || :NOMBRE_PROCESO || '%')  AND (CASE WHEN ZONA_LUGAR IS NULL THEN ' ' ELSE UPPER(ZONA_LUGAR) END)  LIKE UPPER( '%' || :ZONA_LUGAR || '%')  AND (CASE WHEN ACTIVIDADES IS NULL THEN ' ' ELSE UPPER(ACTIVIDADES) END)  LIKE UPPER( '%' || :ACTIVIDADES || '%')  AND (CASE WHEN TAREAS IS NULL THEN ' ' ELSE UPPER(TAREAS) END)  LIKE UPPER( '%' || :TAREAS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TAREAS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstprocesos/todosporcompania/num">
		<call-query href="getSstprocesosNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_PROCESO" query-param="NOMBRE_PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TAREAS" query-param="TAREAS"/>

		</call-query>
	</resource>
	<query id="insertSstprocesos" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_PROCESOS (COMPANIA, CODIGO, PROCESO, ZONA_LUGAR, ACTIVIDADES, TAREAS, RUTINARIAS, DEPENDENCIA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :PROCESO, :ZONA_LUGAR, :ACTIVIDADES, :TAREAS, :RUTINARIAS, :DEPENDENCIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TAREAS" sqlType="STRING"/>
		<param defaultValue="0" name="RUTINARIAS" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstprocesos">
		<call-query href="insertSstprocesos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TAREAS" query-param="TAREAS"/>
			<with-param name="RUTINARIAS" query-param="RUTINARIAS"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSstprocesos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_PROCESOS WHERE SST_PROCESOS.COMPANIA= :KEY_COMPANIA AND SST_PROCESOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sstprocesos">
		<call-query href="deleteSstprocesos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSstprocesosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_PROCESOS.COMPANIA, SST_PROCESOS.CODIGO, SST_PROCESOS.PROCESO, SST_PROCESOS.ZONA_LUGAR, SST_PROCESOS.ACTIVIDADES, SST_PROCESOS.TAREAS,(CASE SST_PROCESOS.RUTINARIAS WHEN 0 THEN 'false' ELSE 'true' END) RUTINARIAS, SST_PROCESOS.DEPENDENCIA, DEPENDENCIA.NOMBRE  FROM SST_PROCESOS LEFT JOIN DEPENDENCIA ON SST_PROCESOS.COMPANIA = DEPENDENCIA.COMPANIA AND SST_PROCESOS.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE SST_PROCESOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN PROCESO IS NULL THEN ' ' ELSE UPPER(PROCESO) END)  LIKE UPPER( '%' || :PROCESO || '%')  AND (CASE WHEN ZONA_LUGAR IS NULL THEN ' ' ELSE UPPER(ZONA_LUGAR) END)  LIKE UPPER( '%' || :ZONA_LUGAR || '%')  AND (CASE WHEN ACTIVIDADES IS NULL THEN ' ' ELSE UPPER(ACTIVIDADES) END)  LIKE UPPER( '%' || :ACTIVIDADES || '%')  AND (CASE WHEN TAREAS IS NULL THEN ' ' ELSE UPPER(TAREAS) END)  LIKE UPPER( '%' || :TAREAS || '%')  AND (CASE WHEN RUTINARIAS IS NULL THEN ' ' ELSE UPPER(RUTINARIAS) END)  LIKE UPPER(:RUTINARIAS || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","PROCESO":"$PROCESO","ZONA_LUGAR":"$ZONA_LUGAR","ACTIVIDADES":"$ACTIVIDADES","TAREAS":"$TAREAS","RUTINARIAS":"$RUTINARIAS(type:boolean)","DEPENDENCIA":"$DEPENDENCIA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TAREAS" sqlType="STRING"/>
		<param name="RUTINARIAS" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstprocesos">
		<call-query href="getSstprocesosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TAREAS" query-param="TAREAS"/>
			<with-param name="RUTINARIAS" query-param="RUTINARIAS"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstprocesosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_PROCESOS.COMPANIA, SST_PROCESOS.CODIGO, SST_PROCESOS.PROCESO, SST_PROCESOS.ZONA_LUGAR, SST_PROCESOS.ACTIVIDADES, SST_PROCESOS.TAREAS,(CASE SST_PROCESOS.RUTINARIAS WHEN 0 THEN 'false' ELSE 'true' END) RUTINARIAS, SST_PROCESOS.DEPENDENCIA, DEPENDENCIA.NOMBRE  FROM SST_PROCESOS LEFT JOIN DEPENDENCIA ON SST_PROCESOS.COMPANIA = DEPENDENCIA.COMPANIA AND SST_PROCESOS.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE SST_PROCESOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN PROCESO IS NULL THEN ' ' ELSE UPPER(PROCESO) END)  LIKE UPPER( '%' || :PROCESO || '%')  AND (CASE WHEN ZONA_LUGAR IS NULL THEN ' ' ELSE UPPER(ZONA_LUGAR) END)  LIKE UPPER( '%' || :ZONA_LUGAR || '%')  AND (CASE WHEN ACTIVIDADES IS NULL THEN ' ' ELSE UPPER(ACTIVIDADES) END)  LIKE UPPER( '%' || :ACTIVIDADES || '%')  AND (CASE WHEN TAREAS IS NULL THEN ' ' ELSE UPPER(TAREAS) END)  LIKE UPPER( '%' || :TAREAS || '%')  AND (CASE WHEN RUTINARIAS IS NULL THEN ' ' ELSE UPPER(RUTINARIAS) END)  LIKE UPPER(:RUTINARIAS || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TAREAS" sqlType="STRING"/>
		<param name="RUTINARIAS" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstprocesos/numero">
		<call-query href="getSstprocesosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TAREAS" query-param="TAREAS"/>
			<with-param name="RUTINARIAS" query-param="RUTINARIAS"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateSstprocesos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_PROCESOS SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, PROCESO=:PROCESO, ZONA_LUGAR=:ZONA_LUGAR, ACTIVIDADES=:ACTIVIDADES, TAREAS=:TAREAS, RUTINARIAS=:RUTINARIAS, DEPENDENCIA=:DEPENDENCIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_PROCESOS.COMPANIA= :KEY_COMPANIA AND SST_PROCESOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ZONA_LUGAR" sqlType="STRING"/>
		<param name="ACTIVIDADES" sqlType="STRING"/>
		<param name="TAREAS" sqlType="STRING"/>
		<param name="RUTINARIAS" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstprocesos">
		<call-query href="updateSstprocesos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ZONA_LUGAR" query-param="ZONA_LUGAR"/>
			<with-param name="ACTIVIDADES" query-param="ACTIVIDADES"/>
			<with-param name="TAREAS" query-param="TAREAS"/>
			<with-param name="RUTINARIAS" query-param="RUTINARIAS"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>