<data name="escalafon" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEscalafonCodnomporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ESCALAFON.CODIGO, ESCALAFON.NOMBRE  FROM ESCALAFON WHERE ESCALAFON.COMPANIA = :COMPANIA ORDER BY ESCALAFON.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escalafon/codnomporcompania">
		<call-query href="getEscalafonCodnomporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getEscalafonPagNomCatPorCiaAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ESCALAFON.NOMBRE ESCALAFON, CATEGORIA.ID_DE_CATEGORIA ID, CATEGORIA.NOMBRE_CATEGORIA NOMBRE  FROM ESCALAFON LEFT JOIN CATEGORIA ON ESCALAFON.CODIGO = CATEGORIA.ESCALAFON AND ESCALAFON.COMPANIA = CATEGORIA.COMPANIA WHERE ESCALAFON.COMPANIA = :COMPANIA AND CATEGORIA.ANO = :ANO ORDER BY ESCALAFON.NOMBRE, CATEGORIA.ESCALAFON, CATEGORIA.ID_DE_CATEGORIA) WHERE (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER( '%' || :ESCALAFON || '%')  AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESCALAFON":"$ESCALAFON","ID":"$ID","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="escalafon/nomcatporciaanio/pag">
		<call-query href="getEscalafonPagNomCatPorCiaAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEscalafonNumNomCatPorCiaAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ESCALAFON.NOMBRE ESCALAFON, CATEGORIA.ID_DE_CATEGORIA ID, CATEGORIA.NOMBRE_CATEGORIA NOMBRE  FROM ESCALAFON LEFT JOIN CATEGORIA ON ESCALAFON.CODIGO = CATEGORIA.ESCALAFON AND ESCALAFON.COMPANIA = CATEGORIA.COMPANIA WHERE ESCALAFON.COMPANIA = :COMPANIA AND CATEGORIA.ANO = :ANO ORDER BY ESCALAFON.NOMBRE, CATEGORIA.ESCALAFON, CATEGORIA.ID_DE_CATEGORIA) WHERE (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER( '%' || :ESCALAFON || '%')  AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escalafon/nomcatporciaanio/num">
		<call-query href="getEscalafonNumNomCatPorCiaAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getEscalafonNombreNotInClasesQuery"  useConfig="sysmandsunist">
		<sql>SELECT ESCALAFON.CODIGO, ESCALAFON.NOMBRE FROM ESCALAFON WHERE ESCALAFON.COMPANIA = :COMPANIA AND NOT INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(NVL(:CLASE,CODIGO)), CODIGO, 1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escalafon/nombrenotinclases">
		<call-query href="getEscalafonNombreNotInClasesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="getEscalafonPagTodosPorCompaniaOrCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ESCALAFON.CODIGO, ESCALAFON.NOMBRE  FROM ESCALAFON WHERE ESCALAFON.COMPANIA = :COMPANIA ORDER BY ESCALAFON.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="escalafon/todosporcompaniaorcodigo/pag">
		<call-query href="getEscalafonPagTodosPorCompaniaOrCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEscalafonNumTodosPorCompaniaOrCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ESCALAFON.CODIGO, ESCALAFON.NOMBRE  FROM ESCALAFON WHERE ESCALAFON.COMPANIA = :COMPANIA ORDER BY ESCALAFON.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escalafon/todosporcompaniaorcodigo/num">
		<call-query href="getEscalafonNumTodosPorCompaniaOrCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getEscalafonPagEscalafonJefeInmediatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ESCALAFON.CODIGO ESCALAFON_JEFE_INMEDIATO , ESCALAFON.NOMBRE NOMBREESCALAFON  FROM ESCALAFON INNER JOIN PERSONAL ON ESCALAFON.COMPANIA = PERSONAL.COMPANIA AND ESCALAFON.CODIGO = PERSONAL.ESCALAFON INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = PERSONAL.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = PERSONAL.NUMERO_DCTO AND DEPENDENCIA_RESPONSABLE.SUCURSAL = PERSONAL.SUCURSAL WHERE ESCALAFON.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA) WHERE (CASE WHEN ESCALAFON_JEFE_INMEDIATO IS NULL THEN ' ' ELSE UPPER(ESCALAFON_JEFE_INMEDIATO) END)  LIKE UPPER(:ESCALAFON_JEFE_INMEDIATO || '%')  AND (CASE WHEN NOMBREESCALAFON IS NULL THEN ' ' ELSE UPPER(NOMBREESCALAFON) END)  LIKE UPPER( '%' || :NOMBREESCALAFON || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESCALAFON_JEFE_INMEDIATO":"$ESCALAFON_JEFE_INMEDIATO","NOMBREESCALAFON":"$NOMBREESCALAFON"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="ESCALAFON_JEFE_INMEDIATO" sqlType="STRING"/>
		<param name="NOMBREESCALAFON" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="escalafon/escalafonjefeinmediato/pag">
		<call-query href="getEscalafonPagEscalafonJefeInmediatoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="ESCALAFON_JEFE_INMEDIATO" query-param="ESCALAFON_JEFE_INMEDIATO"/>
			<with-param name="NOMBREESCALAFON" query-param="NOMBREESCALAFON"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEscalafonNumEscalafonJefeInmediatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ESCALAFON.CODIGO ESCALAFON_JEFE_INMEDIATO , ESCALAFON.NOMBRE NOMBREESCALAFON  FROM ESCALAFON INNER JOIN PERSONAL ON ESCALAFON.COMPANIA = PERSONAL.COMPANIA AND ESCALAFON.CODIGO = PERSONAL.ESCALAFON INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = PERSONAL.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = PERSONAL.NUMERO_DCTO AND DEPENDENCIA_RESPONSABLE.SUCURSAL = PERSONAL.SUCURSAL WHERE ESCALAFON.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA) WHERE (CASE WHEN ESCALAFON_JEFE_INMEDIATO IS NULL THEN ' ' ELSE UPPER(ESCALAFON_JEFE_INMEDIATO) END)  LIKE UPPER(:ESCALAFON_JEFE_INMEDIATO || '%')  AND (CASE WHEN NOMBREESCALAFON IS NULL THEN ' ' ELSE UPPER(NOMBREESCALAFON) END)  LIKE UPPER( '%' || :NOMBREESCALAFON || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="ESCALAFON_JEFE_INMEDIATO" sqlType="STRING"/>
		<param name="NOMBREESCALAFON" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escalafon/escalafonjefeinmediato/num">
		<call-query href="getEscalafonNumEscalafonJefeInmediatoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="ESCALAFON_JEFE_INMEDIATO" query-param="ESCALAFON_JEFE_INMEDIATO"/>
			<with-param name="NOMBREESCALAFON" query-param="NOMBREESCALAFON"/>

		</call-query>
	</resource>
	<query id="insertEscalafon" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ESCALAFON (CODCMD, CODIGO, NOMBRE, COMPANIA, CODSIDEF, CONTRATO, CGR_CODIGO, DATE_CREATED, CREATED_BY) VALUES (:CODCMD, :CODIGO, :NOMBRE, :COMPANIA, :CODSIDEF, :CONTRATO, :CGR_CODIGO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param defaultValue="0" name="CODCMD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="CODSIDEF" sqlType="STRING"/>
		<param defaultValue="0" name="CONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="CGR_CODIGO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="escalafon">
		<call-query href="insertEscalafon">
			<with-param name="CODCMD" query-param="CODCMD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODSIDEF" query-param="CODSIDEF"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="CGR_CODIGO" query-param="CGR_CODIGO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEscalafon" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ESCALAFON WHERE ESCALAFON.COMPANIA= :KEY_COMPANIA AND ESCALAFON.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="escalafon">
		<call-query href="deleteEscalafon">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getEscalafonPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ESCALAFON.COMPANIA, ESCALAFON.CODIGO, ESCALAFON.NOMBRE  FROM ESCALAFON WHERE ESCALAFON.COMPANIA =:COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="escalafon">
		<call-query href="getEscalafonPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEscalafonNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ESCALAFON.COMPANIA, ESCALAFON.CODIGO, ESCALAFON.NOMBRE  FROM ESCALAFON WHERE ESCALAFON.COMPANIA =:COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escalafon/numero">
		<call-query href="getEscalafonNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getEscalafonRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CODIGO, NOMBRE, CODSIDEF,(CASE CONTRATO WHEN 0 THEN 'false' ELSE 'true' END) CONTRATO, CODCMD, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CGR_CODIGO  FROM ESCALAFON WHERE ESCALAFON.COMPANIA= :KEY_COMPANIA AND ESCALAFON.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODSIDEF":"$CODSIDEF","CONTRATO":"$CONTRATO(type:boolean)","CODCMD":"$CODCMD","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CGR_CODIGO":"$CGR_CODIGO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="escalafon/data">
		<call-query href="getEscalafonRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateEscalafon" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ESCALAFON SET CODCMD=:CODCMD, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CODIGO=:CODIGO, NOMBRE=:NOMBRE, COMPANIA=:COMPANIA, CODSIDEF=:CODSIDEF, MODIFIED_BY=:MODIFIED_BY, CONTRATO=:CONTRATO, CGR_CODIGO=:CGR_CODIGO WHERE ESCALAFON.COMPANIA= :KEY_COMPANIA AND ESCALAFON.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODCMD" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODSIDEF" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="CGR_CODIGO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="escalafon">
		<call-query href="updateEscalafon">
			<with-param name="CODCMD" query-param="CODCMD"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODSIDEF" query-param="CODSIDEF"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="CONTRATO" query-param="CONTRATO"/>
			<with-param name="CGR_CODIGO" query-param="CGR_CODIGO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>