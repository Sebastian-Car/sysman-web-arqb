<data name="historialdecargos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertHistorialdecargosHistoriadecargos" keyColumns="COMPANIA,NUMERODOC,SUCURSAL,TIPOACTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO HISTORIAL_DE_CARGOS (COMPANIA, NUMERODOC, SUCURSAL, TIPOACTO, FECHAACTO, CODCARGO, SALARIO, CODSECRE, CODSECCION, TIPOFUN, TIPOVINCULO, DOCUMENTO, NUM_DOCUMENTO, FECHA_DOCUMENTO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NUMERODOC, :SUCURSAL, :TIPOACTO, TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), :CODCARGO, :SALARIO, :CODSECRE, :CODSECCION, :TIPOFUN, :TIPOVINCULO, :DOCUMENTO, :NUM_DOCUMENTO, TO_DATE(:FECHA_DOCUMENTO,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERODOC":"$NUMERODOC","KEY_SUCURSAL":"$SUCURSAL","KEY_FECHAACTO":"$FECHAACTO","KEY_TIPOACTO":"$TIPOACTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NUMERODOC" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="FECHAACTO" sqlType="STRING"/>
		<param defaultValue="" name="CODCARGO" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIO" sqlType="STRING"/>
		<param defaultValue="0" name="CODSECRE" sqlType="STRING"/>
		<param defaultValue="0" name="CODSECCION" sqlType="STRING"/>
		<param defaultValue="" name="TIPOFUN" sqlType="STRING"/>
		<param defaultValue="" name="TIPOVINCULO" sqlType="STRING"/>
		<param defaultValue="" name="DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="NUM_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_DOCUMENTO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="historialdecargos/historiadecargos">
		<call-query href="insertHistorialdecargosHistoriadecargos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
