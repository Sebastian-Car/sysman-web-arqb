	<query id="getHistorialdecargosVerificarregistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(COMPANIA) X FROM HISTORIAL_DE_CARGOS WHERE COMPANIA = :COMPANIA AND NUMERODOC =:NUMERODOC AND SUCURSAL = :SUCURSAL AND TIPOACTO = :TIPOACTO AND CODCARGO =:CODCARGO AND CODSECRE =:CODSECRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERODOC" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="CODCARGO" sqlType="STRING"/>
		<param name="CODSECRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historialdecargos/verificarregistro">
		<call-query href="getHistorialdecargosVerificarregistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERODOC" query-param="NUMERODOC"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPOACTO" query-param="TIPOACTO"/>
			<with-param name="CODCARGO" query-param="CODCARGO"/>
			<with-param name="CODSECRE" query-param="CODSECRE"/>

		</call-query>
	</resource>
	<query id="updateHistorialdecargosActualizafechaacto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE HISTORIAL_DE_CARGOS SET FECHAACTO=TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE HISTORIAL_DE_CARGOS.COMPANIA= :KEY_COMPANIA AND HISTORIAL_DE_CARGOS.NUMERODOC= :KEY_NUMERODOC AND HISTORIAL_DE_CARGOS.SUCURSAL= :KEY_SUCURSAL AND HISTORIAL_DE_CARGOS.FECHAACTO= TO_DATE(:KEY_FECHAACTO,'DD/MM/YYYY HH24:MI:SS') AND HISTORIAL_DE_CARGOS.TIPOACTO= :KEY_TIPOACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAACTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERODOC" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FECHAACTO" sqlType="STRING"/>
		<param name="KEY_TIPOACTO" sqlType="STRING"/>

	</query>
