			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="insertHistorialdecargosRetiro" keyColumns="COMPANIA,NUMERODOC,SUCURSAL,TIPOACTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO HISTORIAL_DE_CARGOS (COMPANIA, NUMERODOC, TIPOACTO, FECHAACTO, CODCARGO, SALARIO, CODSECRE, CODSECCION, TIPOFUN, TIPOVINCULO, DOCUMENTO, NUM_DOCUMENTO, FECHA_DOCUMENTO, SUCURSAL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NUMERODOC, :TIPOACTO, TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), :CODCARGO, :SALARIO, :CODSECRE, :CODSECCION, :TIPOFUN, :TIPOVINCULO, :DOCUMENTO, :NUM_DOCUMENTO, TO_DATE(:FECHA_DOCUMENTO,'DD/MM/YYYY HH24:MI:SS'), :SUCURSAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
