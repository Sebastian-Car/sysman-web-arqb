	</resource>
	<query id="insertHistorialdecargos" keyColumns="COMPANIA,NUMERODOC,SUCURSAL,TIPOACTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO HISTORIAL_DE_CARGOS (COMPANIA, NUMERODOC, SUCURSAL, TIPOACTO, FECHAACTO, CAUSARETIRO, CODCARGO, SALARIO, CODSECRE, CODSECCION, DOCUMENTO, NUM_DOCUMENTO, FECHA_DOCUMENTO, TIPOVINCULO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERODOC, :SUCURSAL, :TIPOACTO, TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), :CAUSARETIRO, :CODCARGO, :SALARIO, :CODSECRE, :CODSECCION, :DOCUMENTO, :NUM_DOCUMENTO, TO_DATE(:FECHA_DOCUMENTO,'DD/MM/YYYY HH24:MI:SS'), :TIPOVINCULO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERODOC":"$NUMERODOC","KEY_SUCURSAL":"$SUCURSAL","KEY_FECHAACTO":"$FECHAACTO","KEY_TIPOACTO":"$TIPOACTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="NUMERODOC" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="FECHAACTO" sqlType="STRING"/>
		<param defaultValue="" name="CAUSARETIRO" sqlType="STRING"/>
		<param defaultValue="" name="CODCARGO" sqlType="STRING"/>
		<param defaultValue="0" name="SALARIO" sqlType="STRING"/>
		<param defaultValue="0" name="CODSECRE" sqlType="STRING"/>
		<param defaultValue="0" name="CODSECCION" sqlType="STRING"/>
		<param defaultValue="" name="DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="NUM_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_DOCUMENTO" sqlType="STRING"/>
		<param defaultValue="" name="TIPOVINCULO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="historialdecargos">
