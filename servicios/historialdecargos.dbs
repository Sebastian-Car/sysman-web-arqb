	<query id="deleteHistorialdecargos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM HISTORIAL_DE_CARGOS WHERE HISTORIAL_DE_CARGOS.COMPANIA= :KEY_COMPANIA AND HISTORIAL_DE_CARGOS.NUMERODOC= :KEY_NUMERODOC AND HISTORIAL_DE_CARGOS.SUCURSAL= :KEY_SUCURSAL AND HISTORIAL_DE_CARGOS.FECHAACTO= TO_DATE(:KEY_FECHAACTO,'DD/MM/YYYY HH24:MI:SS')  AND HISTORIAL_DE_CARGOS.TIPOACTO= :KEY_TIPOACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERODOC" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FECHAACTO" sqlType="STRING"/>
		<param name="KEY_TIPOACTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="historialdecargos">
		<call-query href="deleteHistorialdecargos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERODOC" query-param="KEY_NUMERODOC"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_FECHAACTO" query-param="KEY_FECHAACTO"/>
			<with-param name="KEY_TIPOACTO" query-param="KEY_TIPOACTO"/>

		</call-query>
	</resource>
	<query id="getHistorialdecargosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  HISTORIAL_DE_CARGOS.COMPANIA, HISTORIAL_DE_CARGOS.NUMERODOC, HISTORIAL_DE_CARGOS.SUCURSAL, HISTORIAL_DE_CARGOS.TIPOACTO, TIPOACTO.NOMBREACTO, TO_CHAR(HISTORIAL_DE_CARGOS.FECHAACTO, 'DD/MM/YYYY') FECHAACTO_LB,(TO_CHAR(HISTORIAL_DE_CARGOS.FECHAACTO,'DD/MM/YYYY HH24:MI:SS')) FECHAACTO, HISTORIAL_DE_CARGOS.CAUSARETIRO, CAUSARETIRO.NOMBRE CAUSARETIRO_LB, HISTORIAL_DE_CARGOS.CODCARGO, HISTORIAL_DE_CARGOS.SALARIO, HISTORIAL_DE_CARGOS.CODSECRE, HISTORIAL_DE_CARGOS.CODSECCION, HISTORIAL_DE_CARGOS.DOCUMENTO, HISTORIAL_DE_CARGOS.NUM_DOCUMENTO,(TO_CHAR(HISTORIAL_DE_CARGOS.FECHA_DOCUMENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_DOCUMENTO, TO_CHAR(HISTORIAL_DE_CARGOS.FECHA_DOCUMENTO, 'DD/MM/YYYY') FECHADOCUMENTO_LB  FROM HISTORIAL_DE_CARGOS INNER JOIN TIPOACTO ON HISTORIAL_DE_CARGOS.TIPOACTO = TIPOACTO.TIPOACTO LEFT JOIN CAUSARETIRO ON HISTORIAL_DE_CARGOS.COMPANIA =CAUSARETIRO.COMPANIA AND HISTORIAL_DE_CARGOS.CAUSARETIRO =CAUSARETIRO.CODIGO WHERE HISTORIAL_DE_CARGOS.COMPANIA= :COMPANIA AND NUMERODOC = :NUMERODOCUMENTO AND SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERODOC":"$NUMERODOC","SUCURSAL":"$SUCURSAL","TIPOACTO":"$TIPOACTO","NOMBREACTO":"$NOMBREACTO","FECHAACTO_LB":"$FECHAACTO_LB","FECHAACTO":"$FECHAACTO","CAUSARETIRO":"$CAUSARETIRO","CAUSARETIRO_LB":"$CAUSARETIRO_LB","CODCARGO":"$CODCARGO","SALARIO":"$SALARIO","CODSECRE":"$CODSECRE","CODSECCION":"$CODSECCION","DOCUMENTO":"$DOCUMENTO","NUM_DOCUMENTO":"$NUM_DOCUMENTO","FECHA_DOCUMENTO":"$FECHA_DOCUMENTO","FECHADOCUMENTO_LB":"$FECHADOCUMENTO_LB"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERODOCUMENTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="historialdecargos">
		<call-query href="getHistorialdecargosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERODOCUMENTO" query-param="NUMERODOCUMENTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateHistorialdecargos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE HISTORIAL_DE_CARGOS SET COMPANIA=:COMPANIA, NUMERODOC=:NUMERODOC, SUCURSAL=:SUCURSAL, TIPOACTO=:TIPOACTO, FECHAACTO=TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), CAUSARETIRO=:CAUSARETIRO, CODCARGO=:CODCARGO, SALARIO=:SALARIO, CODSECRE=:CODSECRE, CODSECCION=:CODSECCION, DOCUMENTO=:DOCUMENTO, NUM_DOCUMENTO=:NUM_DOCUMENTO, FECHA_DOCUMENTO=TO_DATE(:FECHA_DOCUMENTO,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE HISTORIAL_DE_CARGOS.COMPANIA= :KEY_COMPANIA AND HISTORIAL_DE_CARGOS.NUMERODOC= :KEY_NUMERODOC AND HISTORIAL_DE_CARGOS.SUCURSAL= :KEY_SUCURSAL AND HISTORIAL_DE_CARGOS.FECHAACTO= TO_DATE(:KEY_FECHAACTO,'DD/MM/YYYY HH24:MI:SS')  AND HISTORIAL_DE_CARGOS.TIPOACTO= :KEY_TIPOACTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERODOC" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPOACTO" sqlType="STRING"/>
		<param name="FECHAACTO" sqlType="STRING"/>
		<param name="CAUSARETIRO" sqlType="STRING"/>
