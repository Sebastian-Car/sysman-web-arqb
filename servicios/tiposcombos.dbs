<data name="tiposcombos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTiposcombosCodigosPorTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO , DESCRIPCION FROM TIPOS_COMBO WHERE ID=:TIPO ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposcombos/codigosportipo">
		<call-query href="getTiposcombosCodigosPorTipoQuery">
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="deleteTiposcombosBorrarDatosDeTabla" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPOS_COMBO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

 
	</query>
	<resource method="DELETE" path="tiposcombos/borrardatosdetabla">
		<call-query href="deleteTiposcombosBorrarDatosDeTabla">
 
		</call-query>
	</resource>
	<query id="insertTiposcombos" keyColumns="CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPOS_COMBO (ID, CODIGO, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:ID, :CODIGO, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param defaultValue="" name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tiposcombos">
		<call-query href="insertTiposcombos">
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>

</data>