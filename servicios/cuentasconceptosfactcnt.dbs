	<query id="getCuentasconceptosfactcntNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CUENTAS_CONCEPTOS_FACT_CNT.COMPANIA, CUENTAS_CONCEPTOS_FACT_CNT.ANO, CUENTAS_CONCEPTOS_FACT_CNT.CONCEPTO, CUENTAS_CONCEPTOS_FACT_CNT.CENTRO_COSTO, CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_BASE_C, CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_BASE_C, CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_IVA_C, CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_IVA_C, CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_RTFTE_C, CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_RTFTE_C, CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_BASE_R, CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_BASE_R, CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_IVA_R, CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_IVA_R, CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_RTFTE_R, CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_RTFTE_R, CUENTAS_CONCEPTOS_FACT_CNT.CUENTA_BASE_VA, CUENTAS_CONCEPTOS_FACT_CNT.CUENTA_IVA_VA, CUENTAS_CONCEPTOS_FACT_CNT.CUENTA_RTFT_VA, CUENTAS_CONCEPTOS_FACT_CNT.CUENTAREFINAN, CUENTAS_CONCEPTOS_FACT_CNT.CUENTAREFINAN_VA  FROM CUENTAS_CONCEPTOS_FACT_CNT WHERE ANO =:ANO AND CONCEPTO =:CONCEPTO) WHERE (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN DEBITO_BASE_C IS NULL THEN ' ' ELSE UPPER(DEBITO_BASE_C) END)  LIKE UPPER(:DEBITO_BASE_C || '%')  AND (CASE WHEN CREDITO_BASE_C IS NULL THEN ' ' ELSE UPPER(CREDITO_BASE_C) END)  LIKE UPPER(:CREDITO_BASE_C || '%')  AND (CASE WHEN DEBITO_IVA_C IS NULL THEN ' ' ELSE UPPER(DEBITO_IVA_C) END)  LIKE UPPER(:DEBITO_IVA_C || '%')  AND (CASE WHEN CREDITO_IVA_C IS NULL THEN ' ' ELSE UPPER(CREDITO_IVA_C) END)  LIKE UPPER(:CREDITO_IVA_C || '%')  AND (CASE WHEN DEBITO_RTFTE_C IS NULL THEN ' ' ELSE UPPER(DEBITO_RTFTE_C) END)  LIKE UPPER(:DEBITO_RTFTE_C || '%')  AND (CASE WHEN CREDITO_RTFTE_C IS NULL THEN ' ' ELSE UPPER(CREDITO_RTFTE_C) END)  LIKE UPPER(:CREDITO_RTFTE_C || '%')  AND (CASE WHEN DEBITO_BASE_R IS NULL THEN ' ' ELSE UPPER(DEBITO_BASE_R) END)  LIKE UPPER(:DEBITO_BASE_R || '%')  AND (CASE WHEN CREDITO_BASE_R IS NULL THEN ' ' ELSE UPPER(CREDITO_BASE_R) END)  LIKE UPPER(:CREDITO_BASE_R || '%')  AND (CASE WHEN DEBITO_IVA_R IS NULL THEN ' ' ELSE UPPER(DEBITO_IVA_R) END)  LIKE UPPER(:DEBITO_IVA_R || '%')  AND (CASE WHEN CREDITO_IVA_R IS NULL THEN ' ' ELSE UPPER(CREDITO_IVA_R) END)  LIKE UPPER(:CREDITO_IVA_R || '%')  AND (CASE WHEN DEBITO_RTFTE_R IS NULL THEN ' ' ELSE UPPER(DEBITO_RTFTE_R) END)  LIKE UPPER(:DEBITO_RTFTE_R || '%')  AND (CASE WHEN CREDITO_RTFTE_R IS NULL THEN ' ' ELSE UPPER(CREDITO_RTFTE_R) END)  LIKE UPPER(:CREDITO_RTFTE_R || '%')  AND (CASE WHEN CUENTA_BASE_VA IS NULL THEN ' ' ELSE UPPER(CUENTA_BASE_VA) END)  LIKE UPPER(:CUENTA_BASE_VA || '%')  AND (CASE WHEN CUENTA_IVA_VA IS NULL THEN ' ' ELSE UPPER(CUENTA_IVA_VA) END)  LIKE UPPER(:CUENTA_IVA_VA || '%')  AND (CASE WHEN CUENTA_RTFT_VA IS NULL THEN ' ' ELSE UPPER(CUENTA_RTFT_VA) END)  LIKE UPPER(:CUENTA_RTFT_VA || '%')  AND (CASE WHEN CUENTAREFINAN IS NULL THEN ' ' ELSE UPPER(CUENTAREFINAN) END)  LIKE UPPER(:CUENTAREFINAN || '%')  AND (CASE WHEN CUENTAREFINAN_VA IS NULL THEN ' ' ELSE UPPER(CUENTAREFINAN_VA) END)  LIKE UPPER( '%' || :CUENTAREFINAN_VA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="DEBITO_BASE_C" sqlType="STRING"/>
		<param name="CREDITO_BASE_C" sqlType="STRING"/>
		<param name="DEBITO_IVA_C" sqlType="STRING"/>
		<param name="CREDITO_IVA_C" sqlType="STRING"/>
		<param name="DEBITO_RTFTE_C" sqlType="STRING"/>
		<param name="CREDITO_RTFTE_C" sqlType="STRING"/>
		<param name="DEBITO_BASE_R" sqlType="STRING"/>
		<param name="CREDITO_BASE_R" sqlType="STRING"/>
