	<query id="insertCuentasconceptosfactcnt" keyColumns="COMPANIA,ANO,CENTRO_COSTO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CUENTAS_CONCEPTOS_FACT_CNT (CENTRO_COSTO, DEBITO_BASE_C, CREDITO_BASE_C, DEBITO_IVA_C, CREDITO_IVA_C, DEBITO_RTFTE_C, CREDITO_RTFTE_C, DEBITO_BASE_R, CREDITO_BASE_R, DEBITO_IVA_R, CREDITO_IVA_R, DEBITO_RTFTE_R, CREDITO_RTFTE_R, CUENTA_BASE_VA, CUENTA_IVA_VA, CUENTA_RTFT_VA, CUENTAREFINAN, CUENTAREFINAN_VA, DATE_CREATED, CREATED_BY) VALUES (:CENTRO_COSTO, :DEBITO_BASE_C, :CREDITO_BASE_C, :DEBITO_IVA_C, :CREDITO_IVA_C, :DEBITO_RTFTE_C, :CREDITO_RTFTE_C, :DEBITO_BASE_R, :CREDITO_BASE_R, :DEBITO_IVA_R, :CREDITO_IVA_R, :DEBITO_RTFTE_R, :CREDITO_RTFTE_R, :CUENTA_BASE_VA, :CUENTA_IVA_VA, :CUENTA_RTFT_VA, :CUENTAREFINAN, :CUENTAREFINAN_VA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CENTRO_COSTO":"$CENTRO_COSTO","KEY_CONCEPTO":"$CONCEPTO"}]}}		</result>
