	<query id="deleteCuentasconceptosfactcnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CUENTAS_CONCEPTOS_FACT_CNT WHERE CUENTAS_CONCEPTOS_FACT_CNT.COMPANIA= :KEY_COMPANIA AND CUENTAS_CONCEPTOS_FACT_CNT.ANO= :KEY_ANO AND CUENTAS_CONCEPTOS_FACT_CNT.CENTRO_COSTO= :KEY_CENTRO_COSTO AND CUENTAS_CONCEPTOS_FACT_CNT.CONCEPTO= :KEY_CONCEPTO</sql>
