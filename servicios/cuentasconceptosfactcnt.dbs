	<query id="insertCuentasconceptosfactcntConceptosfact" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CUENTAS_CONCEPTOS_FACT_CNT   (     COMPANIA,     ANO,     CENTRO_COSTO,     CONCEPTO,     DEBITO_BASE_C,     CREDITO_BASE_C,     DEBITO_IVA_C,     CREDITO_IVA_C,     DEBITO_RTFTE_C,     CREDITO_RTFTE_C,     DEBITO_BASE_R,     CREDITO_BASE_R,     DEBITO_IVA_R,     CREDITO_IVA_R,     DEBITO_RTFTE_R,     CREDITO_RTFTE_R,     CUENTA_BASE_VA,     CUENTA_IVA_VA,     CUENTA_RTFT_VA,     TIPO_CONCEPTO ,     CUENTAREFINAN,     CUENTAREFINAN_VA,     CREATED_BY,   DATE_CREATED) SELECT CUENTAS_CONCEPTOS_FACT_CNT.COMPANIA,   CUENTAS_CONCEPTOS_FACT_CNT.ano +1 ANIO,   CUENTAS_CONCEPTOS_FACT_CNT.CENTRO_COSTO,   CUENTAS_CONCEPTOS_FACT_CNT.CONCEPTO,   CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_BASE_C,   CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_BASE_C,   CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_IVA_C,   CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_IVA_C,   CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_RTFTE_C,   CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_RTFTE_C,   CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_BASE_R,   CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_BASE_R,   CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_IVA_R,   CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_IVA_R,   CUENTAS_CONCEPTOS_FACT_CNT.DEBITO_RTFTE_R,   CUENTAS_CONCEPTOS_FACT_CNT.CREDITO_RTFTE_R,   CUENTAS_CONCEPTOS_FACT_CNT.CUENTA_BASE_VA,   CUENTAS_CONCEPTOS_FACT_CNT.CUENTA_IVA_VA,   CUENTAS_CONCEPTOS_FACT_CNT.CUENTA_RTFT_VA,   CUENTAS_CONCEPTOS_FACT_CNT.TIPO_CONCEPTO,   CUENTAS_CONCEPTOS_FACT_CNT.CUENTAREFINAN,   CUENTAS_CONCEPTOS_FACT_CNT.CUENTAREFINAN_VA,   :USUARIO,   SYSDATE FROM CUENTAS_CONCEPTOS_FACT_CNT WHERE CUENTAS_CONCEPTOS_FACT_CNT.ANO=:ANO -1;</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="USUARIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
