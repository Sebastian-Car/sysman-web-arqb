	<query id="updateCuentasconceptosfactcnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CUENTAS_CONCEPTOS_FACT_CNT SET CONCEPTO=:CONCEPTO, ANO=:ANO, CENTRO_COSTO=:CENTRO_COSTO, DEBITO_BASE_C=:DEBITO_BASE_C, CREDITO_BASE_C=:CREDITO_BASE_C, DEBITO_IVA_C=:DEBITO_IVA_C, CREDITO_IVA_C=:CREDITO_IVA_C, DEBITO_RTFTE_C=:DEBITO_RTFTE_C, CREDITO_RTFTE_C=:CREDITO_RTFTE_C, DEBITO_BASE_R=:DEBITO_BASE_R, CREDITO_BASE_R=:CREDITO_BASE_R, DEBITO_IVA_R=:DEBITO_IVA_R, CREDITO_IVA_R=:CREDITO_IVA_R, DEBITO_RTFTE_R=:DEBITO_RTFTE_R, CREDITO_RTFTE_R=:CREDITO_RTFTE_R, CUENTA_BASE_VA=:CUENTA_BASE_VA, CUENTA_IVA_VA=:CUENTA_IVA_VA, CUENTA_RTFT_VA=:CUENTA_RTFT_VA, CUENTAREFINAN=:CUENTAREFINAN, CUENTAREFINAN_VA=:CUENTAREFINAN_VA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CUENTAS_CONCEPTOS_FACT_CNT.COMPANIA= :KEY_COMPANIA AND CUENTAS_CONCEPTOS_FACT_CNT.ANO= :KEY_ANO AND CUENTAS_CONCEPTOS_FACT_CNT.CENTRO_COSTO= :KEY_CENTRO_COSTO AND CUENTAS_CONCEPTOS_FACT_CNT.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
