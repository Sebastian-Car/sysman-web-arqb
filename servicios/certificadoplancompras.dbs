<data name="certificadoplancompras" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCertificadoplancomprasNumsPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CERTIFICADO_PLAN_COMPRAS.NUMERO FROM CERTIFICADO_PLAN_COMPRAS WHERE CERTIFICADO_PLAN_COMPRAS.COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="certificadoplancompras/numsporcia">
		<call-query href="getCertificadoplancomprasNumsPorCiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertCertificadoplancompras" keyColumns="COMPANIA,ANO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CERTIFICADO_PLAN_COMPRAS (COMPANIA, ANO, NUMERO, DEPENDENCIA, RESPONSABLE, SUCURSAL, MES, CONSECUTIVO_PC, OBSERVACIONES, IMPRESO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :ANO, :NUMERO, :DEPENDENCIA, :RESPONSABLE, :SUCURSAL, :MES, :CONSECUTIVO_PC, :OBSERVACIONES, :IMPRESO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="MES" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO_PC" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="IMPRESO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="certificadoplancompras">
		<call-query href="insertCertificadoplancompras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CONSECUTIVO_PC" query-param="CONSECUTIVO_PC"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteCertificadoplancompras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CERTIFICADO_PLAN_COMPRAS WHERE CERTIFICADO_PLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND CERTIFICADO_PLAN_COMPRAS.ANO= :KEY_ANO AND CERTIFICADO_PLAN_COMPRAS.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="certificadoplancompras">
		<call-query href="deleteCertificadoplancompras">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getCertificadoplancomprasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, NUMERO, DEPENDENCIA, RESPONSABLE, MES, CONSECUTIVO_PC FROM CERTIFICADO_PLAN_COMPRAS ORDER BY ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(:RESPONSABLE, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(:MES, '%')) AND (CASE WHEN CONSECUTIVO_PC IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_PC) END) LIKE UPPER(CONCAT(:CONSECUTIVO_PC, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","MES":"$MES(type:integer)","CONSECUTIVO_PC":"$CONSECUTIVO_PC(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CONSECUTIVO_PC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="certificadoplancompras">
		<call-query href="getCertificadoplancomprasPaginaQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CONSECUTIVO_PC" query-param="CONSECUTIVO_PC"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCertificadoplancomprasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, NUMERO, DEPENDENCIA, RESPONSABLE, MES, CONSECUTIVO_PC FROM CERTIFICADO_PLAN_COMPRAS ORDER BY ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END) LIKE UPPER(CONCAT(:RESPONSABLE, '%')) AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END) LIKE UPPER(CONCAT(:MES, '%')) AND (CASE WHEN CONSECUTIVO_PC IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_PC) END) LIKE UPPER(CONCAT(:CONSECUTIVO_PC, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CONSECUTIVO_PC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="certificadoplancompras/numero">
		<call-query href="getCertificadoplancomprasNumeroQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CONSECUTIVO_PC" query-param="CONSECUTIVO_PC"/>

		</call-query>
	</resource>
	<query id="getCertificadoplancomprasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, NUMERO, DEPENDENCIA, RESPONSABLE, SUCURSAL, MES, CONSECUTIVO_PC, OBSERVACIONES,(CASE IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED FROM CERTIFICADO_PLAN_COMPRAS WHERE CERTIFICADO_PLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND CERTIFICADO_PLAN_COMPRAS.ANO= :KEY_ANO AND CERTIFICADO_PLAN_COMPRAS.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","DEPENDENCIA":"$DEPENDENCIA","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","MES":"$MES(type:integer)","CONSECUTIVO_PC":"$CONSECUTIVO_PC(type:integer)","OBSERVACIONES":"$OBSERVACIONES","IMPRESO":"$IMPRESO(type:boolean)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="certificadoplancompras/data">
		<call-query href="getCertificadoplancomprasRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateCertificadoplancompras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CERTIFICADO_PLAN_COMPRAS SET ANO=:ANO, NUMERO=:NUMERO, DEPENDENCIA=:DEPENDENCIA, RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, MES=:MES, CONSECUTIVO_PC=:CONSECUTIVO_PC, OBSERVACIONES=:OBSERVACIONES, IMPRESO=:IMPRESO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE CERTIFICADO_PLAN_COMPRAS.COMPANIA= :KEY_COMPANIA AND CERTIFICADO_PLAN_COMPRAS.ANO= :KEY_ANO AND CERTIFICADO_PLAN_COMPRAS.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CONSECUTIVO_PC" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="certificadoplancompras">
		<call-query href="updateCertificadoplancompras">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CONSECUTIVO_PC" query-param="CONSECUTIVO_PC"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="IMPRESO" query-param="IMPRESO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>

</data>