	<query id="getIprecibosdepagoPagTodosDatosCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DOCNUM ,PRECOD,(CASE ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO,(CASE PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, (NVL(ESABONO, 0)) ESABONO, (NVL(ESACUERDO, 0)) ESACUERDO, NCUOTA_ACUERDO, (NVL(ESCUOTA, 0)) ESCUOTA, NCUOTA,CASE PREFEC WHEN NULL THEN ' ' ELSE TO_CHAR(PREFEC,'DD/MM/YYYY') END AS PREFEC, CASE PREFECLIM WHEN NULL THEN ' ' ELSE TO_CHAR(PREFECLIM,'DD/MM/YYYY') END AS PREFECLIM, PREVAL, CASE PREFECPAG WHEN NULL THEN ' ' ELSE TO_CHAR(PREFECPAG,'DD/MM/YYYY') END AS PREFECPAG, NVL(PAG_BANPAG,' ') AS PAG_BANPAG, CASE FECHAANULACION WHEN NULL THEN ' ' ELSE TO_CHAR(FECHAANULACION,'DD/MM/YYYY') END AS FECHAANULACION, PREANOI, PREANOF, ACUERDO  FROM IP_RECIBOS_DE_PAGO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER(:PRECOD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCNUM":"$DOCNUM","PRECOD":"$PRECOD","ANULADO":"$ANULADO(type:boolean)","PAGO":"$PAGO(type:boolean)","ESABONO":"$ESABONO(type:integer)","ESACUERDO":"$ESACUERDO(type:integer)","NCUOTA_ACUERDO":"$NCUOTA_ACUERDO","ESCUOTA":"$ESCUOTA(type:integer)","NCUOTA":"$NCUOTA","PREFEC":"$PREFEC","PREFECLIM":"$PREFECLIM","PREVAL":"$PREVAL","PREFECPAG":"$PREFECPAG","PAG_BANPAG":"$PAG_BANPAG","FECHAANULACION":"$FECHAANULACION","PREANOI":"$PREANOI(type:integer)","PREANOF":"$PREANOF(type:integer)","ACUERDO":"$ACUERDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
