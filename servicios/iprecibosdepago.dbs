	<query id="getIprecibosdepagoNumFactsExpPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.COMPANIA, IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.PREANO,(TO_CHAR(IP_RECIBOS_DE_PAGO.PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC,(TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECLIM,'DD/MM/YYYY HH24:MI:SS')) PREFECLIM, IP_RECIBOS_DE_PAGO.PREVAL, IP_RECIBOS_DE_PAGO.PREUSU,(TO_CHAR(IP_RECIBOS_DE_PAGO.MODFEC,'DD/MM/YYYY HH24:MI:SS')) MODFEC, IP_RECIBOS_DE_PAGO.AVALUO, IP_RECIBOS_DE_PAGO.TRPFOR, IP_RECIBOS_DE_PAGO.PAG_BAN,(CASE IP_RECIBOS_DE_PAGO.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO,(CASE IP_RECIBOS_DE_PAGO.PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, IP_RECIBOS_DE_PAGO.PAG_BANPAG,(TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY HH24:MI:SS')) PREFECPAG, IP_RECIBOS_DE_PAGO.PAQUETEPAG  FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD = :CODIGO ORDER BY IP_RECIBOS_DE_PAGO.PREFEC, IP_RECIBOS_DE_PAGO.DOCNUM) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN PREFEC IS NULL THEN ' ' ELSE UPPER(PREFEC) END)  LIKE UPPER( '%' || :PREFEC || '%')  AND (CASE WHEN PREFECLIM IS NULL THEN ' ' ELSE UPPER(PREFECLIM) END)  LIKE UPPER( '%' || :PREFECLIM || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER( '%' || :PREVAL || '%')  AND (CASE WHEN PREUSU IS NULL THEN ' ' ELSE UPPER(PREUSU) END)  LIKE UPPER( '%' || :PREUSU || '%')  AND (CASE WHEN MODFEC IS NULL THEN ' ' ELSE UPPER(MODFEC) END)  LIKE UPPER( '%' || :MODFEC || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN ANULADO IS NULL THEN ' ' ELSE UPPER(ANULADO) END)  LIKE UPPER( '%' || :ANULADO || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER( '%' || :PAGO || '%')  AND (CASE WHEN PAG_BANPAG IS NULL THEN ' ' ELSE UPPER(PAG_BANPAG) END)  LIKE UPPER( '%' || :PAG_BANPAG || '%')  AND (CASE WHEN PREFECPAG IS NULL THEN ' ' ELSE UPPER(PREFECPAG) END)  LIKE UPPER( '%' || :PREFECPAG || '%')  AND (CASE WHEN PAQUETEPAG IS NULL THEN ' ' ELSE UPPER(PAQUETEPAG) END)  LIKE UPPER( '%' || :PAQUETEPAG || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
