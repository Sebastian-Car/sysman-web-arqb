	<query id="getIprecibosdepagoCodigofacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PRECOD  FROM IP_RECIBOS_DE_PAGO WHERE COMPANIA = :COMPANIA AND DOCNUM =:NUMFACTURA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRECOD":"$PRECOD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMFACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="iprecibosdepago/codigofactura">
		<call-query href="getIprecibosdepagoCodigofacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMFACTURA" query-param="NUMFACTURA"/>

		</call-query>
	</resource>
	<query id="getIprecibosdepagoDatosfacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DOCNUM, PREANO, PREVAL,(TO_CHAR(PREFECLIM,'DD/MM/YYYY HH24:MI:SS')) PREFECLIM,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC FROM IP_RECIBOS_DE_PAGO WHERE COMPANIA = :COMPANIA AND PRECOD = :PRECOD AND DOCNUM = :DOCNUM AND ANULADO IN (0) AND PAGO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCNUM":"$DOCNUM","PREANO":"$PREANO(type:integer)","PREVAL":"$PREVAL","PREFECLIM":"$PREFECLIM","PREFEC":"$PREFEC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="iprecibosdepago/datosfactura">
		<call-query href="getIprecibosdepagoDatosfacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PRECOD" query-param="PRECOD"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>

		</call-query>
	</resource>
	<query id="updateIprecibosdepagoAnularReciboPago" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_RECIBOS_DE_PAGO SET ANULADO = -1 WHERE COMPANIA = :COMPANIA AND DOCNUM = :DOCNUM AND PRECOD = :PRECOD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="iprecibosdepago/anularrecibopago">
		<call-query href="updateIprecibosdepagoAnularReciboPago">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PRECOD" query-param="PRECOD"/>

		</call-query>
	</resource>

