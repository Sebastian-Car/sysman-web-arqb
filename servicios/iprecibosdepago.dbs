<data name="iprecibosdepago" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIprecibosdepagoPagAnulacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PREANO,(TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY HH24:MI:SS')) PREFECPAG, IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.PAG_BANPAG, IP_RECIBOS_DE_PAGO.PAQUETEPAG, NVL(IP_RECIBOS_DE_PAGO.ACUERDO, 0)ACUERDO  FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD IS NOT NULL AND IP_RECIBOS_DE_PAGO.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_RECIBOS_DE_PAGO.ANULADO IN(0) AND IP_RECIBOS_DE_PAGO.PAGO NOT IN(0) ORDER BY IP_RECIBOS_DE_PAGO.DOCNUM) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER( '%' || :PRECOD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCNUM":"$DOCNUM","PREANO":"$PREANO(type:integer)","PREFECPAG":"$PREFECPAG","PRECOD":"$PRECOD","PAG_BANPAG":"$PAG_BANPAG","PAQUETEPAG":"$PAQUETEPAG","ACUERDO":"$ACUERDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="iprecibosdepago/anulacionregistro/pag">
		<call-query href="getIprecibosdepagoPagAnulacionRegistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PRECOD" query-param="PRECOD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIprecibosdepagoNumAnulacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PREANO,(TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY HH24:MI:SS')) PREFECPAG, IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.PAG_BANPAG, IP_RECIBOS_DE_PAGO.PAQUETEPAG, NVL(IP_RECIBOS_DE_PAGO.ACUERDO, 0)ACUERDO  FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD IS NOT NULL AND IP_RECIBOS_DE_PAGO.NUMERO_ORDEN = :NUMERO_ORDEN AND IP_RECIBOS_DE_PAGO.ANULADO IN(0) AND IP_RECIBOS_DE_PAGO.PAGO NOT IN(0) ORDER BY IP_RECIBOS_DE_PAGO.DOCNUM) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PRECOD IS NULL THEN ' ' ELSE UPPER(PRECOD) END)  LIKE UPPER( '%' || :PRECOD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PRECOD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="iprecibosdepago/anulacionregistro/num">
		<call-query href="getIprecibosdepagoNumAnulacionRegistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_ORDEN" query-param="NUMERO_ORDEN"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PRECOD" query-param="PRECOD"/>

		</call-query>
	</resource>
	<query id="getIprecibosdepagoPagCargarReciboSoportePorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PREANOF, IP_RECIBOS_DE_PAGO.PREANOI, IP_RECIBOS_DE_PAGO.PREVAL PREVAL, IP_RECIBOS_DE_PAGO.C13 TOTALDESC  FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD = :CODIGO AND IP_RECIBOS_DE_PAGO.PAGO IN(0) AND IP_RECIBOS_DE_PAGO.ANULADO IN(0) AND IP_RECIBOS_DE_PAGO.ESABONO IN(0) AND IP_RECIBOS_DE_PAGO.ESACUERDO IN(0) AND IP_RECIBOS_DE_PAGO.ESCUOTA IN(0) AND IP_RECIBOS_DE_PAGO.ACUERDO IS NULL) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PREANOF IS NULL THEN ' ' ELSE UPPER(PREANOF) END)  LIKE UPPER( '%' || :PREANOF || '%')  AND (CASE WHEN PREANOI IS NULL THEN ' ' ELSE UPPER(PREANOI) END)  LIKE UPPER( '%' || :PREANOI || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER( '%' || :PREVAL || '%')  AND (CASE WHEN TOTALDESC IS NULL THEN ' ' ELSE UPPER(TOTALDESC) END)  LIKE UPPER( '%' || :TOTALDESC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCNUM":"$DOCNUM","PREANOF":"$PREANOF(type:integer)","PREANOI":"$PREANOI(type:integer)","PREVAL":"$PREVAL","TOTALDESC":"$TOTALDESC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PREANOF" sqlType="STRING"/>
		<param name="PREANOI" sqlType="STRING"/>
		<param name="PREVAL" sqlType="STRING"/>
		<param name="TOTALDESC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="iprecibosdepago/cargarrecibosoporteporcodigo/pag">
		<call-query href="getIprecibosdepagoPagCargarReciboSoportePorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PREANOF" query-param="PREANOF"/>
			<with-param name="PREANOI" query-param="PREANOI"/>
			<with-param name="PREVAL" query-param="PREVAL"/>
			<with-param name="TOTALDESC" query-param="TOTALDESC"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIprecibosdepagoNumCargarReciboSoportePorCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PREANOF, IP_RECIBOS_DE_PAGO.PREANOI, IP_RECIBOS_DE_PAGO.PREVAL PREVAL, IP_RECIBOS_DE_PAGO.C13 TOTALDESC  FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD = :CODIGO AND IP_RECIBOS_DE_PAGO.PAGO IN(0) AND IP_RECIBOS_DE_PAGO.ANULADO IN(0) AND IP_RECIBOS_DE_PAGO.ESABONO IN(0) AND IP_RECIBOS_DE_PAGO.ESACUERDO IN(0) AND IP_RECIBOS_DE_PAGO.ESCUOTA IN(0) AND IP_RECIBOS_DE_PAGO.ACUERDO IS NULL) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN PREANOF IS NULL THEN ' ' ELSE UPPER(PREANOF) END)  LIKE UPPER( '%' || :PREANOF || '%')  AND (CASE WHEN PREANOI IS NULL THEN ' ' ELSE UPPER(PREANOI) END)  LIKE UPPER( '%' || :PREANOI || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER( '%' || :PREVAL || '%')  AND (CASE WHEN TOTALDESC IS NULL THEN ' ' ELSE UPPER(TOTALDESC) END)  LIKE UPPER( '%' || :TOTALDESC || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PREANOF" sqlType="STRING"/>
		<param name="PREANOI" sqlType="STRING"/>
		<param name="PREVAL" sqlType="STRING"/>
		<param name="TOTALDESC" sqlType="STRING"/>

	</query>
	<resource method="GET" path="iprecibosdepago/cargarrecibosoporteporcodigo/num">
		<call-query href="getIprecibosdepagoNumCargarReciboSoportePorCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="PREANOF" query-param="PREANOF"/>
			<with-param name="PREANOI" query-param="PREANOI"/>
			<with-param name="PREVAL" query-param="PREVAL"/>
			<with-param name="TOTALDESC" query-param="TOTALDESC"/>

		</call-query>
	</resource>
	<query id="getIprecibosdepagoPagOrigengrillafacturacontroladorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.COMPANIA, IP_RECIBOS_DE_PAGO.DOCNUM , IP_RECIBOS_DE_PAGO.PREANOI , IP_RECIBOS_DE_PAGO.PREANO , TO_CHAR(IP_RECIBOS_DE_PAGO.PREFEC,'DD/MM/YYYY') PREFEC, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECLIM,'DD/MM/YYYY') PREFECLIM, IP_RECIBOS_DE_PAGO.PREVAL , IP_RECIBOS_DE_PAGO.AVALUO ,(CASE IP_RECIBOS_DE_PAGO.PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY') PREFECPAG, IP_RECIBOS_DE_PAGO.PAG_BANPAG , IP_RECIBOS_DE_PAGO.PAQUETEPAG ,(CASE IP_RECIBOS_DE_PAGO.ESABONO WHEN 0 THEN 'false' ELSE 'true' END) ESABONO,(CASE IP_RECIBOS_DE_PAGO.ESCUOTA WHEN 0 THEN 'false' ELSE 'true' END) ESCUOTA,(CASE IP_RECIBOS_DE_PAGO.ESACUERDO WHEN 0 THEN 'false' ELSE 'true' END) ESACUERDO, IP_RECIBOS_DE_PAGO.PREUSU , TO_CHAR(IP_RECIBOS_DE_PAGO.MODFEC ,'DD/MM/YYYY') MODFEC, IP_RECIBOS_DE_PAGO.USUARIO_REGRECAUDO , TO_CHAR(IP_RECIBOS_DE_PAGO.FECHA_REGRECAUDO ,'DD/MM/YYYY') FECHA_REGRECAUDO,(CASE IP_RECIBOS_DE_PAGO.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO, IP_RECIBOS_DE_PAGO.ANULADO_POR , TO_CHAR(IP_RECIBOS_DE_PAGO.FECHAANULACION,'DD/MM/YYYY') FECHAANULACION, IP_RECIBOS_DE_PAGO.PRECOD , IP_RECIBOS_DE_PAGO.TRPFOR , IP_RECIBOS_DE_PAGO.PAG_BAN , IP_RECIBOS_DE_PAGO.PREANOF  FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD = :CODIGO AND IP_RECIBOS_DE_PAGO.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_RECIBOS_DE_PAGO.PREFEC DESC, TO_NUMBER(IP_RECIBOS_DE_PAGO.DOCNUM) DESC) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PREANOI IS NULL THEN ' ' ELSE UPPER(PREANOI) END)  LIKE UPPER(:PREANOI || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER(:PREANO || '%')  AND (CASE WHEN PREFEC IS NULL THEN ' ' ELSE UPPER(PREFEC) END)  LIKE UPPER( '%' || :PREFEC || '%')  AND (CASE WHEN PREFECLIM IS NULL THEN ' ' ELSE UPPER(PREFECLIM) END)  LIKE UPPER( '%' || :PREFECLIM || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER(:PREVAL || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER(:AVALUO || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER(:PAGO || '%')  AND (CASE WHEN PREFECPAG IS NULL THEN ' ' ELSE UPPER(PREFECPAG) END)  LIKE UPPER( '%' || :PREFECPAG || '%')  AND (CASE WHEN PAG_BANPAG IS NULL THEN ' ' ELSE UPPER(PAG_BANPAG) END)  LIKE UPPER(:PAG_BANPAG || '%')  AND (CASE WHEN PAQUETEPAG IS NULL THEN ' ' ELSE UPPER(PAQUETEPAG) END)  LIKE UPPER(:PAQUETEPAG || '%')  AND (CASE WHEN ESABONO IS NULL THEN ' ' ELSE UPPER(ESABONO) END)  LIKE UPPER(:ESABONO || '%')  AND (CASE WHEN ESCUOTA IS NULL THEN ' ' ELSE UPPER(ESCUOTA) END)  LIKE UPPER(:ESCUOTA || '%')  AND (CASE WHEN ESACUERDO IS NULL THEN ' ' ELSE UPPER(ESACUERDO) END)  LIKE UPPER(:ESACUERDO || '%')  AND (CASE WHEN PREUSU IS NULL THEN ' ' ELSE UPPER(PREUSU) END)  LIKE UPPER( '%' || :PREUSU || '%')  AND (CASE WHEN MODFEC IS NULL THEN ' ' ELSE UPPER(MODFEC) END)  LIKE UPPER( '%' || :MODFEC || '%')  AND (CASE WHEN USUARIO_REGRECAUDO IS NULL THEN ' ' ELSE UPPER(USUARIO_REGRECAUDO) END)  LIKE UPPER( '%' || :USUARIO_REGRECAUDO || '%')  AND (CASE WHEN FECHA_REGRECAUDO IS NULL THEN ' ' ELSE UPPER(FECHA_REGRECAUDO) END)  LIKE UPPER( '%' || :FECHA_REGRECAUDO || '%')  AND (CASE WHEN ANULADO IS NULL THEN ' ' ELSE UPPER(ANULADO) END)  LIKE UPPER(:ANULADO || '%')  AND (CASE WHEN ANULADO_POR IS NULL THEN ' ' ELSE UPPER(ANULADO_POR) END)  LIKE UPPER( '%' || :ANULADO_POR || '%')  AND (CASE WHEN FECHAANULACION IS NULL THEN ' ' ELSE UPPER(FECHAANULACION) END)  LIKE UPPER( '%' || :FECHAANULACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DOCNUM":"$DOCNUM","PREANOI":"$PREANOI(type:integer)","PREANO":"$PREANO(type:integer)","PREFEC":"$PREFEC","PREFECLIM":"$PREFECLIM","PREVAL":"$PREVAL","AVALUO":"$AVALUO","PAGO":"$PAGO(type:boolean)","PREFECPAG":"$PREFECPAG","PAG_BANPAG":"$PAG_BANPAG","PAQUETEPAG":"$PAQUETEPAG","ESABONO":"$ESABONO(type:boolean)","ESCUOTA":"$ESCUOTA(type:boolean)","ESACUERDO":"$ESACUERDO(type:boolean)","PREUSU":"$PREUSU","MODFEC":"$MODFEC","USUARIO_REGRECAUDO":"$USUARIO_REGRECAUDO","FECHA_REGRECAUDO":"$FECHA_REGRECAUDO","ANULADO":"$ANULADO(type:boolean)","ANULADO_POR":"$ANULADO_POR","FECHAANULACION":"$FECHAANULACION","PRECOD":"$PRECOD","TRPFOR":"$TRPFOR","PAG_BAN":"$PAG_BAN","PREANOF":"$PREANOF(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PREANOI" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="PREFEC" sqlType="STRING"/>
		<param name="PREFECLIM" sqlType="STRING"/>
		<param name="PREVAL" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="PAGO" sqlType="STRING"/>
		<param name="PREFECPAG" sqlType="STRING"/>
		<param name="PAG_BANPAG" sqlType="STRING"/>
		<param name="PAQUETEPAG" sqlType="STRING"/>
		<param name="ESABONO" sqlType="STRING"/>
		<param name="ESCUOTA" sqlType="STRING"/>
		<param name="ESACUERDO" sqlType="STRING"/>
		<param name="PREUSU" sqlType="STRING"/>
		<param name="MODFEC" sqlType="STRING"/>
		<param name="USUARIO_REGRECAUDO" sqlType="STRING"/>
		<param name="FECHA_REGRECAUDO" sqlType="STRING"/>
		<param name="ANULADO" sqlType="STRING"/>
		<param name="ANULADO_POR" sqlType="STRING"/>
		<param name="FECHAANULACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
