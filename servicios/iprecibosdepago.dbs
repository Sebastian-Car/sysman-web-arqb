	<query id="getIprecibosdepagoPagFacturascontotalporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.DOCNUM, IP_USUARIOS_PREDIAL.NOMBRE, IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.VALOR_APORTE,(CASE IP_RECIBOS_DE_PAGO.INDAPORTE WHEN 0 THEN 'false' ELSE 'true' END) INDAPORTE, IP_RECIBOS_DE_PAGO.PROYECTO_APORTE,(CASE IP_RECIBOS_DE_PAGO.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO,(CASE IP_RECIBOS_DE_PAGO.PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, IP_RECIBOS_DE_PAGO.PREVAL, IP_RECIBOS_DE_PAGO.C1 + IP_RECIBOS_DE_PAGO.C2 + IP_RECIBOS_DE_PAGO.C3 + IP_RECIBOS_DE_PAGO.C4 + IP_RECIBOS_DE_PAGO.C5 + IP_RECIBOS_DE_PAGO.C6 + IP_RECIBOS_DE_PAGO.C7 + IP_RECIBOS_DE_PAGO.C8 + IP_RECIBOS_DE_PAGO.C9 + IP_RECIBOS_DE_PAGO.C10 + IP_RECIBOS_DE_PAGO.C11 + IP_RECIBOS_DE_PAGO.C12 + IP_RECIBOS_DE_PAGO.C13 + IP_RECIBOS_DE_PAGO.C14 + IP_RECIBOS_DE_PAGO.C15 + IP_RECIBOS_DE_PAGO.C16 + IP_RECIBOS_DE_PAGO.C17 + IP_RECIBOS_DE_PAGO.C18 + IP_RECIBOS_DE_PAGO.C19 + IP_RECIBOS_DE_PAGO.C20 - DECODE(:CONCEPTO ,1,IP_RECIBOS_DE_PAGO.C1 ,2,IP_RECIBOS_DE_PAGO.C2 ,3,IP_RECIBOS_DE_PAGO.C3 ,4,IP_RECIBOS_DE_PAGO.C4 ,5,IP_RECIBOS_DE_PAGO.C5 ,6,IP_RECIBOS_DE_PAGO.C6 ,7,IP_RECIBOS_DE_PAGO.C7 ,8,IP_RECIBOS_DE_PAGO.C8 ,9,IP_RECIBOS_DE_PAGO.C9 ,10,IP_RECIBOS_DE_PAGO.C10 ,11,IP_RECIBOS_DE_PAGO.C11 ,12,IP_RECIBOS_DE_PAGO.C12 ,13,IP_RECIBOS_DE_PAGO.C13 ,13,IP_RECIBOS_DE_PAGO.C14 ,15,IP_RECIBOS_DE_PAGO.C15 ,16,IP_RECIBOS_DE_PAGO.C16 ,17,IP_RECIBOS_DE_PAGO.C17 ,18,IP_RECIBOS_DE_PAGO.C18 ,19,IP_RECIBOS_DE_PAGO.C19 ,20,IP_RECIBOS_DE_PAGO.C20) VLRTOTAL  FROM IP_RECIBOS_DE_PAGO INNER JOIN IP_USUARIOS_PREDIAL ON IP_RECIBOS_DE_PAGO.COMPANIA = IP_USUARIOS_PREDIAL.COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD = IP_USUARIOS_PREDIAL.CODIGO AND IP_RECIBOS_DE_PAGO.NUMERO_ORDEN = IP_USUARIOS_PREDIAL.NUMERO_ORDEN WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA ORDER BY DOCNUM) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCNUM":"$DOCNUM","NOMBRE":"$NOMBRE","PRECOD":"$PRECOD","VALOR_APORTE":"$VALOR_APORTE","INDAPORTE":"$INDAPORTE(type:boolean)","PROYECTO_APORTE":"$PROYECTO_APORTE","ANULADO":"$ANULADO(type:boolean)","PAGO":"$PAGO(type:boolean)","PREVAL":"$PREVAL","VLRTOTAL":"$VLRTOTAL(type:integer)"}]}}		</result>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

