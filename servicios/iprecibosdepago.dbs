	<query id="getIprecibosdepagoNumOrigengrillafacturacontroladorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_RECIBOS_DE_PAGO.COMPANIA, IP_RECIBOS_DE_PAGO.DOCNUM , IP_RECIBOS_DE_PAGO.PREANOI , IP_RECIBOS_DE_PAGO.PREANO , TO_CHAR(IP_RECIBOS_DE_PAGO.PREFEC,'DD/MM/YYYY') PREFEC, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECLIM,'DD/MM/YYYY') PREFECLIM, IP_RECIBOS_DE_PAGO.PREVAL , IP_RECIBOS_DE_PAGO.AVALUO ,(CASE IP_RECIBOS_DE_PAGO.PAGO WHEN 0 THEN 'false' ELSE 'true' END) PAGO, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY') PREFECPAG, IP_RECIBOS_DE_PAGO.PAG_BANPAG , IP_RECIBOS_DE_PAGO.PAQUETEPAG ,(CASE IP_RECIBOS_DE_PAGO.ESABONO WHEN 0 THEN 'false' ELSE 'true' END) ESABONO,(CASE IP_RECIBOS_DE_PAGO.ESCUOTA WHEN 0 THEN 'false' ELSE 'true' END) ESCUOTA,(CASE IP_RECIBOS_DE_PAGO.ESACUERDO WHEN 0 THEN 'false' ELSE 'true' END) ESACUERDO, IP_RECIBOS_DE_PAGO.PREUSU , TO_CHAR(IP_RECIBOS_DE_PAGO.MODFEC ,'DD/MM/YYYY') MODFEC, IP_RECIBOS_DE_PAGO.USUARIO_REGRECAUDO , TO_CHAR(IP_RECIBOS_DE_PAGO.FECHA_REGRECAUDO ,'DD/MM/YYYY') FECHA_REGRECAUDO,(CASE IP_RECIBOS_DE_PAGO.ANULADO WHEN 0 THEN 'false' ELSE 'true' END) ANULADO, IP_RECIBOS_DE_PAGO.ANULADO_POR , TO_CHAR(IP_RECIBOS_DE_PAGO.FECHAANULACION,'DD/MM/YYYY') FECHAANULACION, IP_RECIBOS_DE_PAGO.PRECOD , IP_RECIBOS_DE_PAGO.TRPFOR , IP_RECIBOS_DE_PAGO.PAG_BAN , IP_RECIBOS_DE_PAGO.PREANOF  FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA = :COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD = :CODIGO AND IP_RECIBOS_DE_PAGO.NUMERO_ORDEN = :NUMERO_ORDEN ORDER BY IP_RECIBOS_DE_PAGO.PREFEC DESC, TO_NUMBER(IP_RECIBOS_DE_PAGO.DOCNUM) DESC) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PREANOI IS NULL THEN ' ' ELSE UPPER(PREANOI) END)  LIKE UPPER( '%' || :PREANOI || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN PREFEC IS NULL THEN ' ' ELSE UPPER(PREFEC) END)  LIKE UPPER( '%' || :PREFEC || '%')  AND (CASE WHEN PREFECLIM IS NULL THEN ' ' ELSE UPPER(PREFECLIM) END)  LIKE UPPER( '%' || :PREFECLIM || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER( '%' || :PREVAL || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN PAGO IS NULL THEN ' ' ELSE UPPER(PAGO) END)  LIKE UPPER( '%' || :PAGO || '%')  AND (CASE WHEN PREFECPAG IS NULL THEN ' ' ELSE UPPER(PREFECPAG) END)  LIKE UPPER( '%' || :PREFECPAG || '%')  AND (CASE WHEN PAG_BANPAG IS NULL THEN ' ' ELSE UPPER(PAG_BANPAG) END)  LIKE UPPER( '%' || :PAG_BANPAG || '%')  AND (CASE WHEN PAQUETEPAG IS NULL THEN ' ' ELSE UPPER(PAQUETEPAG) END)  LIKE UPPER( '%' || :PAQUETEPAG || '%')  AND (CASE WHEN ESABONO IS NULL THEN ' ' ELSE UPPER(ESABONO) END)  LIKE UPPER( '%' || :ESABONO || '%')  AND (CASE WHEN ESCUOTA IS NULL THEN ' ' ELSE UPPER(ESCUOTA) END)  LIKE UPPER( '%' || :ESCUOTA || '%')  AND (CASE WHEN ESACUERDO IS NULL THEN ' ' ELSE UPPER(ESACUERDO) END)  LIKE UPPER( '%' || :ESACUERDO || '%')  AND (CASE WHEN PREUSU IS NULL THEN ' ' ELSE UPPER(PREUSU) END)  LIKE UPPER( '%' || :PREUSU || '%')  AND (CASE WHEN MODFEC IS NULL THEN ' ' ELSE UPPER(MODFEC) END)  LIKE UPPER( '%' || :MODFEC || '%')  AND (CASE WHEN USUARIO_REGRECAUDO IS NULL THEN ' ' ELSE UPPER(USUARIO_REGRECAUDO) END)  LIKE UPPER( '%' || :USUARIO_REGRECAUDO || '%')  AND (CASE WHEN FECHA_REGRECAUDO IS NULL THEN ' ' ELSE UPPER(FECHA_REGRECAUDO) END)  LIKE UPPER( '%' || :FECHA_REGRECAUDO || '%')  AND (CASE WHEN ANULADO IS NULL THEN ' ' ELSE UPPER(ANULADO) END)  LIKE UPPER( '%' || :ANULADO || '%')  AND (CASE WHEN ANULADO_POR IS NULL THEN ' ' ELSE UPPER(ANULADO_POR) END)  LIKE UPPER( '%' || :ANULADO_POR || '%')  AND (CASE WHEN FECHAANULACION IS NULL THEN ' ' ELSE UPPER(FECHAANULACION) END)  LIKE UPPER( '%' || :FECHAANULACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PREANOI" sqlType="STRING"/>
		<param name="PREANO" sqlType="STRING"/>
		<param name="PREFEC" sqlType="STRING"/>
		<param name="PREFECLIM" sqlType="STRING"/>
