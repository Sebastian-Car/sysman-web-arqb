	<query id="getIprecibosdepagoPagPreanoprevalYTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DOCNUM, PREANO, PREVAL, CASE WHEN ESACUERDO NOT IN (0) THEN 'ACUERDO' ELSE CASE WHEN ESABONO NOT IN (0) THEN 'ABONO' ELSE 'VIGENCIA' END END TIPO  FROM IP_RECIBOS_DE_PAGO WHERE COMPANIA = :COMPANIA AND NUMERO_ORDEN = :NUMERO_ORDEN AND PRECOD = :CODIGO AND ANULADO NOT IN (0) AND PAGO = 0 ORDER BY PREANO, DOCNUM) WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER(:DOCNUM || '%')  AND (CASE WHEN PREANO IS NULL THEN ' ' ELSE UPPER(PREANO) END)  LIKE UPPER( '%' || :PREANO || '%')  AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END)  LIKE UPPER( '%' || :PREVAL || '%')  AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER(:TIPO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DOCNUM":"$DOCNUM","PREANO":"$PREANO(type:integer)","PREVAL":"$PREVAL","TIPO":"$TIPO"}]}}		</result>
