	<query id="getIprecibosdepagoNumHistoricosPagosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT * FROM ( SELECT IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PAGO, IP_RECIBOS_DE_PAGO.PAQUETEPAG, IP_RECIBOS_DE_PAGO.ANULADO, IP_RECIBOS_DE_PAGO.PREANO, IP_RECIBOS_DE_PAGO.PREANOI, IP_RECIBOS_DE_PAGO.AVALUO, IP_RECIBOS_DE_PAGO.PREVAL, IP_RECIBOS_DE_PAGO.PAG_BANPAG, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY') PREFECPAG, '1' TIPO, CASE WHEN IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; IP_RECIBOS_DE_PAGO.PREANO AND IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; 0 THEN CONCAT( TO_CHAR(IP_RECIBOS_DE_PAGO.PREANOI), CONCAT(' - ' , TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO))) ELSE TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO) END FINALPREANO FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA =:COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD =:PREDIO AND NOT IP_RECIBOS_DE_PAGO.PAGO IN (0) AND IP_RECIBOS_DE_PAGO.ANULADO IN (0) AND NOT IP_RECIBOS_DE_PAGO.ESCUOTA IN (0) UNION SELECT IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PAGO, IP_RECIBOS_DE_PAGO.PAQUETEPAG, IP_RECIBOS_DE_PAGO.ANULADO, IP_RECIBOS_DE_PAGO.PREANO, IP_RECIBOS_DE_PAGO.PREANOI, IP_RECIBOS_DE_PAGO.AVALUO, IP_RECIBOS_DE_PAGO.PREVAL, IP_RECIBOS_DE_PAGO.PAG_BANPAG, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY') PREFECPAG, '2' TIPO, CASE WHEN IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; IP_RECIBOS_DE_PAGO.PREANO AND IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; 0 THEN CONCAT(TO_CHAR(IP_RECIBOS_DE_PAGO.PREANOI),CONCAT( ' - ' , TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO))) ELSE TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO) END FINALPREANO FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA =:COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD =:PREDIO AND NOT IP_RECIBOS_DE_PAGO.PAGO IN (0) AND IP_RECIBOS_DE_PAGO.ANULADO IN (0) AND NOT IP_RECIBOS_DE_PAGO.ESABONO IN (0) UNION SELECT IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PAGO, IP_RECIBOS_DE_PAGO.PAQUETEPAG, IP_RECIBOS_DE_PAGO.ANULADO, IP_RECIBOS_DE_PAGO.PREANO, IP_RECIBOS_DE_PAGO.PREANOI, IP_RECIBOS_DE_PAGO.AVALUO, IP_RECIBOS_DE_PAGO.PREVAL, IP_RECIBOS_DE_PAGO.PAG_BANPAG, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY') PREFECPAG, '3' TIPO, CASE WHEN IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; IP_RECIBOS_DE_PAGO.PREANO AND IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; 0 THEN CONCAT(TO_CHAR(IP_RECIBOS_DE_PAGO.PREANOI),CONCAT( ' - ' , TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO))) ELSE TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO) END FINALPREANO FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA =:COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD =:PREDIO AND NOT IP_RECIBOS_DE_PAGO.PAGO IN (0) AND IP_RECIBOS_DE_PAGO.ANULADO IN (0) AND NOT IP_RECIBOS_DE_PAGO.ESACUERDO IN (0) UNION SELECT IP_RECIBOS_DE_PAGO.PRECOD, IP_RECIBOS_DE_PAGO.DOCNUM, IP_RECIBOS_DE_PAGO.PAGO, IP_RECIBOS_DE_PAGO.PAQUETEPAG, IP_RECIBOS_DE_PAGO.ANULADO, IP_RECIBOS_DE_PAGO.PREANO, IP_RECIBOS_DE_PAGO.PREANOI, IP_RECIBOS_DE_PAGO.AVALUO, IP_RECIBOS_DE_PAGO.PREVAL, IP_RECIBOS_DE_PAGO.PAG_BANPAG, TO_CHAR(IP_RECIBOS_DE_PAGO.PREFECPAG,'DD/MM/YYYY') PREFECPAG, '4' TIPO, CASE WHEN IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; IP_RECIBOS_DE_PAGO.PREANO AND IP_RECIBOS_DE_PAGO.PREANOI &lt;&gt; 0 THEN CONCAT(TO_CHAR(IP_RECIBOS_DE_PAGO.PREANOI),CONCAT( ' - ' , TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO))) ELSE TO_CHAR(IP_RECIBOS_DE_PAGO.PREANO) END FINALPREANO FROM IP_RECIBOS_DE_PAGO WHERE IP_RECIBOS_DE_PAGO.COMPANIA =:COMPANIA AND IP_RECIBOS_DE_PAGO.PRECOD =:PREDIO AND NOT IP_RECIBOS_DE_PAGO.PAGO IN (0) AND IP_RECIBOS_DE_PAGO.ANULADO IN (0) AND IP_RECIBOS_DE_PAGO.ESACUERDO IN (0) AND IP_RECIBOS_DE_PAGO.ESCUOTA IN (0) AND IP_RECIBOS_DE_PAGO.ESABONO IN (0) ) ORDER BY PREANO DESC) INI WHERE (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END) LIKE UPPER(CONCAT(CONCAT('%',:DOCNUM), '%')) AND (CASE WHEN PAQUETEPAG IS NULL THEN ' ' ELSE UPPER(PAQUETEPAG) END) LIKE UPPER(CONCAT(CONCAT('%',:PAQUETEPAG), '%')) AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END) LIKE UPPER(CONCAT(CONCAT('%',:AVALUO), '%')) AND (CASE WHEN PREVAL IS NULL THEN ' ' ELSE UPPER(PREVAL) END) LIKE UPPER(CONCAT(CONCAT('%',:PREVAL), '%')) AND (CASE WHEN PAG_BANPAG IS NULL THEN ' ' ELSE UPPER(PAG_BANPAG) END) LIKE UPPER(CONCAT(CONCAT('%',:PAG_BANPAG), '%')) AND (CASE WHEN PREFECPAG IS NULL THEN ' ' ELSE UPPER(PREFECPAG) END) LIKE UPPER(CONCAT(CONCAT('%',:PREFECPAG), '%')) AND (CASE WHEN FINALPREANO IS NULL THEN ' ' ELSE UPPER(FINALPREANO) END) LIKE UPPER(CONCAT(CONCAT('%',:FINALPREANO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="PAQUETEPAG" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="PREVAL" sqlType="STRING"/>
		<param name="PAG_BANPAG" sqlType="STRING"/>
		<param name="PREFECPAG" sqlType="STRING"/>
		<param name="FINALPREANO" sqlType="STRING"/>

	</query>
