<data name="vfondodesindicatos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVfondodesindicatosTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FONDO_SINDICATO, NOMBRE_FONDO_SINDICATO  FROM V_FONDO_DE_SINDICATOS WHERE COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FONDO_SINDICATO":"$FONDO_SINDICATO","NOMBRE_FONDO_SINDICATO":"$NOMBRE_FONDO_SINDICATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vfondodesindicatos/todosporcompania">
		<call-query href="getVfondodesindicatosTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>