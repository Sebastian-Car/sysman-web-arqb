	<query id="getSffacturaPagConTerceroPorTipoFacturaYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FACTURA.NUMERO_FACTURA, D.CODIGO_COBRO, FACTURA.VALOR_TOTAL, FACTURA.TERCERO, FACTURA.SUCURSAL, TERCERO.NOMBRE, FACTURA.OBSERVACIONES, TIPOCOBRO.NOMBRE NOMBRETIPOC, FACTURA.TIPO_FACTURA, FACTURA.NRO_ABONO, FACTURA.ANO, FACTURA.TIPO_ABONO,(CASE FACTURA.INTERFAZADA WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZADA, FACTURA.CUENTA_RECAUDO, PLAN_CONTABLE.NOMBRE NOMBRE_BANCO, FACTURA.ANO_CPTE,(CASE FACTURA.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA,(TO_CHAR(FACTURA.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION,(TO_CHAR(FACTURA.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, FACTURA.TIPOCOBRO ,(CASE FACTURA.PAGOS_PARCIALES WHEN 0 THEN 'false' ELSE 'true' END) PAGOS_PARCIALES FROM SF_FACTURA FACTURA INNER JOIN TERCERO ON FACTURA.COMPANIA = TERCERO.COMPANIA AND FACTURA.TERCERO = TERCERO.NIT AND FACTURA.SUCURSAL = TERCERO.SUCURSAL INNER JOIN SF_OBJETO_COBRO D ON FACTURA.COMPANIA = D.COMPANIA AND FACTURA.TIPOCOBRO = D.TIPOCOBRO AND FACTURA.CODIGO_COBRO = D.CODIGO_COBRO INNER JOIN SF_TIPO_COBRO TIPOCOBRO ON FACTURA.COMPANIA = TIPOCOBRO.COMPANIA AND FACTURA.ANO = TIPOCOBRO.ANO AND FACTURA.TIPO_FACTURA = TIPOCOBRO.CODIGO LEFT JOIN PLAN_CONTABLE ON FACTURA.COMPANIA = PLAN_CONTABLE.COMPANIA AND FACTURA.CUENTA_RECAUDO = PLAN_CONTABLE.CODIGO AND FACTURA.ANO = PLAN_CONTABLE.ANO WHERE FACTURA.COMPANIA = :COMPANIA AND FACTURA.TIPO_FACTURA = :TIPO_FACTURA AND FACTURA.FECHA_PAGO IS NULL AND D.INDPAGO IN (0) AND NVL(FACTURA.ANULADA,0) IN (0) AND EXTRACT (YEAR FROM (D.FECHA_REGISTRO)) = :ANO AND NROFRA_PAGOPARCIAL IS NULL AND TIPOFRA_PAGOPARCIAL IS NULL ORDER BY FACTURA.NUMERO_FACTURA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN NOMBRETIPOC IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOC) END)  LIKE UPPER(:NOMBRETIPOC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","VALOR_TOTAL":"$VALOR_TOTAL","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","OBSERVACIONES":"$OBSERVACIONES","NOMBRETIPOC":"$NOMBRETIPOC","TIPO_FACTURA":"$TIPO_FACTURA","NRO_ABONO":"$NRO_ABONO(type:long)","ANO":"$ANO(type:integer)","TIPO_ABONO":"$TIPO_ABONO","INTERFAZADA":"$INTERFAZADA(type:boolean)","CUENTA_RECAUDO":"$CUENTA_RECAUDO","NOMBRE_BANCO":"$NOMBRE_BANCO","ANO_CPTE":"$ANO_CPTE(type:integer)","DIFERIDA":"$DIFERIDA(type:boolean)","FECHA_EXPEDICION":"$FECHA_EXPEDICION","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","TIPOCOBRO":"$TIPOCOBRO","PAGOS_PARCIALES":"$PAGOS_PARCIALES(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_FACTURA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="NOMBRETIPOC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
