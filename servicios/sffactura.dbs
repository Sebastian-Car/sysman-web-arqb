	<query id="getSffacturaNumTerceroYObservacionesPorAnioFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUMERO_FACTURA, VALOR_TOTAL, SF_FACTURA.TERCERO, OBSERVACIONES FROM SF_FACTURA WHERE SF_FACTURA.COMPANIA = :COMPANIA AND TIPO_FACTURA = :TIPOFACTURA AND ANO = :ANO AND NUMERO_FACTURA &gt;= :FACTURA ORDER BY NUMERO_FACTURA) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_TOTAL), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/terceroyobservacionesporaniofinal/num">
		<call-query href="getSffacturaNumTerceroYObservacionesPorAnioFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOFACTURA" query-param="TIPOFACTURA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

