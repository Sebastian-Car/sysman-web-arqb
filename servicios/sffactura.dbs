	</resource>
	<query id="getSffacturaCargarDatosFacturaRecaudoQuery"  useConfig="sysmandsunist">
		<sql>SELECT FACTURA.NUMERO_FACTURA, FACTURA.VALOR_TOTAL, FACTURA.TERCERO, FACTURA.SUCURSAL, TERCERO.NOMBRE, FACTURA.OBSERVACIONES, TIPOCOBRO.NOMBRE NOMBRETIPOC, FACTURA.TIPO_FACTURA, FACTURA.TIPO_ABONO, FACTURA.NRO_ABONO,(CASE FACTURA.INTERFAZADA WHEN 0 THEN 'false' ELSE 'true' END) INTERFAZADA, FACTURA.CUENTA_RECAUDO, PLAN_CONTABLE.NOMBRE NOMBRE_BANCO, FACTURA.ANO_CPTE,(CASE FACTURA.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA,(TO_CHAR(FACTURA.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION,(TO_CHAR(FACTURA.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, FACTURA.TIPOCOBRO,(CASE FACTURA.PAGOS_PARCIALES WHEN 0 THEN 'false' ELSE 'true' END) PAGOS_PARCIALES, FACTURA.TRM_DOLARES_FAC FROM SF_FACTURA FACTURA INNER JOIN TERCERO ON FACTURA.COMPANIA = TERCERO.COMPANIA AND FACTURA.TERCERO = TERCERO.NIT AND FACTURA.SUCURSAL = TERCERO.SUCURSAL INNER JOIN SF_OBJETO_COBRO D ON FACTURA.COMPANIA = D.COMPANIA AND FACTURA.TIPOCOBRO = D.TIPOCOBRO AND FACTURA.CODIGO_COBRO = D.CODIGO_COBRO INNER JOIN SF_TIPO_COBRO TIPOCOBRO ON FACTURA.COMPANIA = TIPOCOBRO.COMPANIA AND FACTURA.ANO = TIPOCOBRO.ANO AND FACTURA.TIPO_FACTURA = TIPOCOBRO.CODIGO LEFT JOIN PLAN_CONTABLE ON FACTURA.COMPANIA = PLAN_CONTABLE.COMPANIA AND FACTURA.CUENTA_RECAUDO = PLAN_CONTABLE.CODIGO AND FACTURA.ANO = PLAN_CONTABLE.ANO WHERE FACTURA.COMPANIA = :COMPANIA AND FACTURA.TIPO_FACTURA = :TIPO_FACTURA AND FACTURA.NUMERO_FACTURA = :NUMERO_FACTURA ORDER BY FACTURA.NUMERO_FACTURA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","VALOR_TOTAL":"$VALOR_TOTAL","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","OBSERVACIONES":"$OBSERVACIONES","NOMBRETIPOC":"$NOMBRETIPOC","TIPO_FACTURA":"$TIPO_FACTURA","TIPO_ABONO":"$TIPO_ABONO","NRO_ABONO":"$NRO_ABONO(type:long)","INTERFAZADA":"$INTERFAZADA(type:boolean)","CUENTA_RECAUDO":"$CUENTA_RECAUDO","NOMBRE_BANCO":"$NOMBRE_BANCO","ANO_CPTE":"$ANO_CPTE(type:integer)","DIFERIDA":"$DIFERIDA(type:boolean)","FECHA_EXPEDICION":"$FECHA_EXPEDICION","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","TIPOCOBRO":"$TIPOCOBRO","PAGOS_PARCIALES":"$PAGOS_PARCIALES(type:boolean)","TRM_DOLARES_FAC":"$TRM_DOLARES_FAC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_FACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/cargardatosfacturarecaudo">
		<call-query href="getSffacturaCargarDatosFacturaRecaudoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_FACTURA" query-param="TIPO_FACTURA"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>

		</call-query>
	</resource>
	<query id="getSffacturaPagFacturasEntreFechasInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUMERO_FACTURA, CODIGO_COBRO  FROM SF_FACTURA WHERE COMPANIA = :COMPANIA AND TIPO_FACTURA = :TIPOCOBRO AND FECHA_EXPEDICION BETWEEN TO_DATE(:FECHAINICIAL,'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL,'DD/MM/YYYY') ORDER BY NUMERO_FACTURA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN CODIGO_COBRO IS NULL THEN ' ' ELSE UPPER(CODIGO_COBRO) END)  LIKE UPPER(:CODIGO_COBRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","CODIGO_COBRO":"$CODIGO_COBRO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="CODIGO_COBRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
