	<query id="getSffacturaSysman_factProductosxfacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT F.CREATED_BY, F.TERCERO NUMTERCERO,(TO_CHAR(F.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURA, F.NUMERO_FACTURA NUMEROFACTURA, F.TIPO_MEDIOPAGO MEDIOPAGO, T.REF_FACTURACION PREFIJO, C.CODEQUIV_DIAN CODIGOPRODUCTO, D.CANTIDAD, C.NOMBRE DESCRIPCIONPRODUCTO, D.VALOR_UNITARIO VALORUNITARIO, D.VALOR_NETO TOTALITEM, D.VALOR_BASE SUBTOTAL, C.PORCENTAJEIVA PORCENTAJEIVAX, D.VALOR_IVA VALORIMPUESTO, C.PORCENTAJERETEFUENTE PORCENTAJERETEFUENTEX, D.VALOR_RETEFUENTE, C.PORCENTAJEICA PORCENTAJEICAX, D.VALOR_ICA, C.PORCENTAJERETEIVA PORCENTAJERETEIVADX, D.RETEIVA, 0 PORCENTAJERETEICAX, D.RETEICA, C.PORCENTAJEINC PORCENTAJEINCX, D.IMPUESTO_INC, F.DESCUENTOFACTURA, D.VALOR_DESCUENTO, F.OBSERVACIONES, F.TIPO_PAGO, T.TIPO_MONEDA,(CASE D.DESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) DESCUENTO, C.PORCENTAJEDESCUENTO, TER.TELEFONOS,(TO_CHAR(F.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA,D.ANO,F.CUENTA_RECAUDO) CUENTA, CASE WHEN D.VALOR_IVA &gt; 0 THEN NVL(D.VALOR_BASE,0) - NVL(D.VALOR_DESCUENTO,0) ELSE 0 END BASEIMPUESTOIVA, CASE WHEN D.VALOR_RETEFUENTE &gt; 0 THEN NVL(D.VALOR_BASE,0) - NVL(D.VALOR_DESCUENTO,0) ELSE 0 END BASEIMPUESTORETEFUENTE, CASE WHEN D.VALOR_ICA &gt; 0 THEN NVL(D.VALOR_BASE,0) - NVL(D.VALOR_DESCUENTO,0) ELSE 0 END BASEIMPUESTOICA, CASE WHEN D.RETEIVA &gt; 0 THEN NVL(D.VALOR_BASE,0) - NVL(D.VALOR_DESCUENTO,0) ELSE 0 END BASEIMPUESTORETEIVA, CASE WHEN D.IMPUESTO_INC &gt; 0 THEN NVL(D.VALOR_BASE,0) - NVL(D.VALOR_DESCUENTO,0) ELSE 0 END BASEIMPUESTOINC, CASE WHEN D.RETEICA &gt; 0 THEN NVL(D.VALOR_BASE,0) - NVL(D.VALOR_DESCUENTO,0) ELSE 0 END BASEIMPUESTORETEICA, T.TIPOFACDIAN, O.TIPOCOBRO,(CASE C.DESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO,(CASE C.CARGO_FE WHEN 0 THEN 'false' ELSE 'true' END) CARGO_FE,(CASE C.DESCUENTOS_FE WHEN 0 THEN 'false' ELSE 'true' END) DESCUENTOS_FE,(CASE O.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA, O.CUOTAS_DIFERIDAS, F.CUENTA_RECAUDO FROM SF_TIPO_COBRO T INNER JOIN SF_FACTURA F INNER JOIN SF_DETALLE_FACTURA D ON F.COMPANIA = D.COMPANIA AND F.TIPO_FACTURA = D.TIPO_FACTURA AND F.NUMERO_FACTURA = D.FACTURA AND F.TIPOCOBRO = D.TIPOCOBRO ON ( T.ANO = D.ANO ) AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL WHERE F.COMPANIA =:COMPANIA AND TRUNC(F.FECHA_EXPEDICION) BETWEEN :FECHAINICIAL AND :FECHAFINAL AND O.IMPRESO NOT IN (0) AND F.NUMERO_FACTURA =:NUMEROFACTURA AND O.TIPOCOBRO =:TIPOCOBRO ORDER BY F.NUMERO_FACTURA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREATED_BY":"$CREATED_BY","NUMTERCERO":"$NUMTERCERO","FECHAFACTURA":"$FECHAFACTURA","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","MEDIOPAGO":"$MEDIOPAGO","PREFIJO":"$PREFIJO","CODIGOPRODUCTO":"$CODIGOPRODUCTO","CANTIDAD":"$CANTIDAD","DESCRIPCIONPRODUCTO":"$DESCRIPCIONPRODUCTO","VALORUNITARIO":"$VALORUNITARIO","TOTALITEM":"$TOTALITEM","SUBTOTAL":"$SUBTOTAL","PORCENTAJEIVAX":"$PORCENTAJEIVAX","VALORIMPUESTO":"$VALORIMPUESTO","PORCENTAJERETEFUENTEX":"$PORCENTAJERETEFUENTEX","VALOR_RETEFUENTE":"$VALOR_RETEFUENTE","PORCENTAJEICAX":"$PORCENTAJEICAX","VALOR_ICA":"$VALOR_ICA","PORCENTAJERETEIVADX":"$PORCENTAJERETEIVADX","RETEIVA":"$RETEIVA","PORCENTAJERETEICAX":"$PORCENTAJERETEICAX(type:double)","RETEICA":"$RETEICA","PORCENTAJEINCX":"$PORCENTAJEINCX","IMPUESTO_INC":"$IMPUESTO_INC","DESCUENTOFACTURA":"$DESCUENTOFACTURA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","OBSERVACIONES":"$OBSERVACIONES","TIPO_PAGO":"$TIPO_PAGO","TIPO_MONEDA":"$TIPO_MONEDA","DESCUENTO":"$DESCUENTO(type:boolean)","PORCENTAJEDESCUENTO":"$PORCENTAJEDESCUENTO","TELEFONOS":"$TELEFONOS","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","CUENTA":"$CUENTA","BASEIMPUESTOIVA":"$BASEIMPUESTOIVA(type:double)","BASEIMPUESTORETEFUENTE":"$BASEIMPUESTORETEFUENTE(type:double)","BASEIMPUESTOICA":"$BASEIMPUESTOICA(type:double)","BASEIMPUESTORETEIVA":"$BASEIMPUESTORETEIVA(type:double)","BASEIMPUESTOINC":"$BASEIMPUESTOINC(type:double)","BASEIMPUESTORETEICA":"$BASEIMPUESTORETEICA(type:double)","TIPOFACDIAN":"$TIPOFACDIAN","TIPOCOBRO":"$TIPOCOBRO","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","CARGO_FE":"$CARGO_FE(type:boolean)","DESCUENTOS_FE":"$DESCUENTOS_FE(type:boolean)","DIFERIDA":"$DIFERIDA(type:boolean)","CUOTAS_DIFERIDAS":"$CUOTAS_DIFERIDAS","CUENTA_RECAUDO":"$CUENTA_RECAUDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
