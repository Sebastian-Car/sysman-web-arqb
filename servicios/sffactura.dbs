<data name="sffactura" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSffacturaPagTodosPorCompaniaTipoCobroAnoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO  FROM SF_FACTURA INNER JOIN SF_DETALLE_FACTURA ON SF_FACTURA.TIPOCOBRO = SF_DETALLE_FACTURA.TIPOCOBRO AND SF_FACTURA.COMPANIA = SF_DETALLE_FACTURA.COMPANIA AND SF_FACTURA.TIPO_FACTURA = SF_DETALLE_FACTURA.TIPO_FACTURA AND SF_FACTURA.NUMERO_FACTURA = SF_DETALLE_FACTURA.FACTURA WHERE SF_FACTURA.COMPANIA =:COMPANIA AND SF_FACTURA.TIPOCOBRO =:TIPOCOBRO AND SF_DETALLE_FACTURA.ANO =:ANOCOBRO AND SF_FACTURA.NUMERO_FACTURA &gt;=:NUMEROFACTURA GROUP BY SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.DIFERIDA , SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO HAVING SF_FACTURA.DIFERIDA NOT IN (0) ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","OBSERVACIONES":"$OBSERVACIONES","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sffactura/todosporcompaniatipocobroanofinal/pag">
		<call-query href="getSffacturaPagTodosPorCompaniaTipoCobroAnoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANOCOBRO" query-param="ANOCOBRO"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSffacturaNumTodosPorCompaniaTipoCobroAnoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO  FROM SF_FACTURA INNER JOIN SF_DETALLE_FACTURA ON SF_FACTURA.TIPOCOBRO = SF_DETALLE_FACTURA.TIPOCOBRO AND SF_FACTURA.COMPANIA = SF_DETALLE_FACTURA.COMPANIA AND SF_FACTURA.TIPO_FACTURA = SF_DETALLE_FACTURA.TIPO_FACTURA AND SF_FACTURA.NUMERO_FACTURA = SF_DETALLE_FACTURA.FACTURA WHERE SF_FACTURA.COMPANIA =:COMPANIA AND SF_FACTURA.TIPOCOBRO =:TIPOCOBRO AND SF_DETALLE_FACTURA.ANO =:ANOCOBRO AND SF_FACTURA.NUMERO_FACTURA &gt;=:NUMEROFACTURA GROUP BY SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.DIFERIDA , SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO HAVING SF_FACTURA.DIFERIDA NOT IN (0) ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/todosporcompaniatipocobroanofinal/num">
		<call-query href="getSffacturaNumTodosPorCompaniaTipoCobroAnoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANOCOBRO" query-param="ANOCOBRO"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSffacturaPagTodosPorCompaniaTipoCobroAnoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO  FROM SF_FACTURA INNER JOIN SF_DETALLE_FACTURA ON SF_FACTURA.TIPOCOBRO = SF_DETALLE_FACTURA.TIPOCOBRO AND SF_FACTURA.COMPANIA = SF_DETALLE_FACTURA.COMPANIA AND SF_FACTURA.TIPO_FACTURA = SF_DETALLE_FACTURA.TIPO_FACTURA AND SF_FACTURA.NUMERO_FACTURA = SF_DETALLE_FACTURA.FACTURA WHERE SF_FACTURA.COMPANIA =:COMPANIA AND SF_FACTURA.TIPOCOBRO =:TIPOCOBRO AND SF_DETALLE_FACTURA.ANO =:ANOCOBRO GROUP BY SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.DIFERIDA, SF_FACTURA.OBSERVACIONES, SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO HAVING SF_FACTURA.DIFERIDA NOT IN (0) ORDER BY SF_FACTURA.NUMERO_FACTURA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","OBSERVACIONES":"$OBSERVACIONES","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sffactura/todosporcompaniatipocobroanoinicial/pag">
		<call-query href="getSffacturaPagTodosPorCompaniaTipoCobroAnoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
