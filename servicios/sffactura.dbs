			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSffacturaNumNumnitnombrefinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  FACTURA_SF.NUMERO_FACTURA, FACTURA_SF.VALOR_TOTAL, FACTURA_SF.NIT_TERCEROFACTURADO, FACTURA_SF.NOMBRE_TERCEROFACTURADO  FROM SF_FACTURA FACTURA_SF WHERE FACTURA_SF.COMPANIA = :COMPANIA AND FACTURA_SF.TIPO_FACTURA = :TIPOCOBRO AND FACTURA_SF.ANO = :ANO AND ANULADA IN (0) AND IND_ACUERDO IN (0) AND FACTURA_SF.NUMERO_FACTURA &gt;= :FACTURA ORDER BY FACTURA_SF.NUMERO_FACTURA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN NIT_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NIT_TERCEROFACTURADO) END)  LIKE UPPER(:NIT_TERCEROFACTURADO || '%')  AND (CASE WHEN NOMBRE_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCEROFACTURADO) END)  LIKE UPPER( '%' || :NOMBRE_TERCEROFACTURADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="NIT_TERCEROFACTURADO" sqlType="STRING"/>
		<param name="NOMBRE_TERCEROFACTURADO" sqlType="STRING"/>

	</query>
