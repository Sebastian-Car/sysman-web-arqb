	<query id="getSffacturaGetfacturaobjetocobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT TIPO_FACTURA, NUMERO_FACTURA FROM SF_FACTURA WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO AND CODIGO_COBRO = :NUMEROCOBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO_FACTURA":"$TIPO_FACTURA","NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="NUMEROCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/getfacturaobjetocobro">
		<call-query href="getSffacturaGetfacturaobjetocobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="NUMEROCOBRO" query-param="NUMEROCOBRO"/>

		</call-query>
	</resource>
	<query id="getSffacturaGetconceptosconfigfacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_CONCEPTOS.CODIGO, SF_CONCEPTOS.CUENTA_RECAUDO FROM SF_FACTURA INNER JOIN SF_TIPO_COBRO ON SF_FACTURA.COMPANIA = SF_TIPO_COBRO.COMPANIA AND SF_FACTURA.ANO = SF_TIPO_COBRO.ANO AND SF_FACTURA.TIPO_FACTURA = SF_TIPO_COBRO.CODIGO INNER JOIN SF_DETALLE_FACTURA ON SF_FACTURA.COMPANIA = SF_DETALLE_FACTURA.COMPANIA AND SF_FACTURA.ANO = SF_DETALLE_FACTURA.ANO AND SF_FACTURA.NUMERO_FACTURA = SF_DETALLE_FACTURA.FACTURA AND SF_TIPO_COBRO.CODIGO = SF_DETALLE_FACTURA.TIPOCOBRO LEFT JOIN SF_CONCEPTOS ON SF_DETALLE_FACTURA.COMPANIA = SF_CONCEPTOS.COMPANIA AND SF_DETALLE_FACTURA.ANO = SF_CONCEPTOS.ANO AND SF_DETALLE_FACTURA.CONCEPTO = SF_CONCEPTOS.CODIGO AND SF_TIPO_COBRO.CODIGO = SF_CONCEPTOS.TIPOCOBRO WHERE SF_FACTURA.NUMERO_FACTURA LIKE :FACTURA AND SF_TIPO_COBRO.TIPOFACTURA_RECAUDO = :TIPORECAUDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","CUENTA_RECAUDO":"$CUENTA_RECAUDO"}]}}		</result>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="TIPORECAUDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/getconceptosconfigfactura">
		<call-query href="getSffacturaGetconceptosconfigfacturaQuery">
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="TIPORECAUDO" query-param="TIPORECAUDO"/>

		</call-query>
	</resource>
	
	<query id="getSffacturaGetobservaciondeltipocobroQuery"  useConfig="sysmandsunist">
		<sql>SELECT FACT_SYSMAN.OBSERVACIONES DESCRIPCION FROM ( SELECT F.CREATED_BY, F.TERCERO NUMTERCERO, F.FECHA_EXPEDICION FECHAFACTURA, F.NUMERO_FACTURA NUMEROFACTURA, F.TIPO_MEDIOPAGO MEDIOPAGO, T.REF_FACTURACION PREFIJO, C.CODEQUIV_DIAN CODIGOPRODUCTO, D.CANTIDAD, C.NOMBRE DESCRIPCIONPRODUCTO, D.VALOR_UNITARIO VALORUNITARIO, D.VALOR_NETO TOTALITEM, D.VALOR_BASE SUBTOTAL, C.PORCENTAJEIVA PORCENTAJEIVAX, D.VALOR_IVA VALORIMPUESTO, C.PORCENTAJERETEFUENTE PORCENTAJERETEFUENTEX, D.VALOR_RETEFUENTE, C.PORCENTAJEICA PORCENTAJEICAX, D.VALOR_ICA, C.PORCENTAJERETEIVA PORCENTAJERETEIVADX, D.RETEIVA, 0 PORCENTAJERETEICAX, D.RETEICA, C.PORCENTAJEINC PORCENTAJEINCX, D.IMPUESTO_INC, F.DESCUENTOFACTURA, D.VALOR_DESCUENTO, O.OBSERVACIONES, F.TIPO_PAGO, T.TIPO_MONEDA, D.DESCUENTO, C.PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VENCIMIENTO, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA, D.ANO, F.CUENTA_RECAUDO) CUENTA, CASE WHEN D.VALOR_IVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOIVA, CASE WHEN D.VALOR_RETEFUENTE &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEFUENTE, CASE WHEN D.VALOR_ICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOICA, CASE WHEN D.RETEIVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEIVA, CASE WHEN D.IMPUESTO_INC &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOINC, CASE WHEN D.RETEICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEICA, T.TIPOFACDIAN, O.TIPOCOBRO, C.DESCUENTO APLICADESCUENTO, C.CARGO_FE, C.DESCUENTOS_FE, O.DIFERIDA, O.CUOTAS_DIFERIDAS, F.CUENTA_RECAUDO FROM SF_TIPO_COBRO T INNER JOIN SF_FACTURA F INNER JOIN SF_DETALLE_FACTURA D ON F.COMPANIA = D.COMPANIA AND F.TIPO_FACTURA = D.TIPO_FACTURA AND F.NUMERO_FACTURA = D.FACTURA AND F.TIPOCOBRO = D.TIPOCOBRO ON ( T.ANO = D.ANO ) AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL WHERE F.COMPANIA = :COMPANIA AND TO_CHAR(F.FECHA_EXPEDICION,'dd/MM/YYYY') BETWEEN :FECHAINICIAL AND :FECHAFINAL AND O.IMPRESO NOT IN ( 0 ) AND F.NUMERO_FACTURA = :NUMEROFACTURA AND O.TIPOCOBRO = :TIPOCOBRO ORDER BY F.NUMERO_FACTURA ) FACT_SYSMAN WHERE CARGO_FE IN ( 0 ) AND DESCUENTOS_FE IN ( 0 ) AND APLICADESCUENTO IN ( 0 )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/getobservaciondeltipocobro">
		<call-query href="getSffacturaGetobservaciondeltipocobroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="getSffacturaGetdatafactenvioinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT FACT_SYSMAN.CREATED_BY, TO_CHAR(FACT_SYSMAN.FECHAFACTURA, 'YYYY-MM-DD') FECHAFACTURA, TO_CHAR(FACT_SYSMAN.FECHAFACTURA_SOL, 'YYYY-MM-DD') FECHAFACTURA_SOL, FACT_SYSMAN.NUMEROFACTURA, FACT_SYSMAN.MEDIOPAGO, FACT_SYSMAN.NUMTERCERO, FACT_SYSMAN.PREFIJO, TO_CHAR(FACT_SYSMAN.FECHA_VENCIMIENTO, 'YYYY-MM-DD') FECHA_VENCIMIENTO, FACT_SYSMAN.TELEFONOS, FACT_SYSMAN.DESCUENTOFACTURA, FACT_SYSMAN.TIPO_MONEDA, FACT_SYSMAN.OBSERVACIONES, FACT_SYSMAN.TIPO_PAGO, FACT_SYSMAN.CUENTA, FACT_SYSMAN.TIPOFACDIAN,(CASE FACT_SYSMAN.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA, FACT_SYSMAN.CUOTAS_DIFERIDAS, FACT_SYSMAN.CUENTA_RECAUDO, FACT_SYSMAN.PREFIJOORDEN, FACT_SYSMAN.DIRECCIONCOMPANIA, FACT_SYSMAN.CIUDADCOMPANIA, FACT_SYSMAN.DEPTOCOMPANIA, FACT_SYSMAN.CIUDADTERCERO, FACT_SYSMAN.DEPTOTERCERO, FACT_SYSMAN.REGIMENTERCERO, FACT_SYSMAN.RAZONSOCIAL, FACT_SYSMAN.NATURALEZATERCERO, FACT_SYSMAN.NOMBRECLIENTE, FACT_SYSMAN.APELLIDO1CLIENTE, FACT_SYSMAN.APELLIDO2CLIENTE, FACT_SYSMAN.DIRECCIONTERECERO, FACT_SYSMAN.CODIGOPOSTALTERCERO, FACT_SYSMAN.PAISTERCERO, FACT_SYSMAN.EMAILTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONCOMPANIA, FACT_SYSMAN.VALOR_TOTAL, FACT_SYSMAN.VLR_BASE FROM ( SELECT F.CREATED_BY, F.TERCERO NUMTERCERO, F.FECHA_EXPEDICION FECHAFACTURA, O.FECHA_SOLICITUD FECHAFACTURA_SOL, F.NUMERO_FACTURA NUMEROFACTURA, F.TIPO_MEDIOPAGO MEDIOPAGO, T.REF_FACTURACION PREFIJO, C.CODEQUIV_DIAN CODIGOPRODUCTO, D.CANTIDAD, C.NOMBRE DESCRIPCIONPRODUCTO, D.VALOR_UNITARIO VALORUNITARIO, D.VALOR_NETO TOTALITEM, D.VALOR_BASE SUBTOTAL, C.PORCENTAJEIVA PORCENTAJEIVAX, D.VALOR_IVA VALORIMPUESTO, C.PORCENTAJERETEFUENTE PORCENTAJERETEFUENTEX, D.VALOR_RETEFUENTE, C.PORCENTAJEICA PORCENTAJEICAX, D.VALOR_ICA, C.PORCENTAJERETEIVA * 100 PORCENTAJERETEIVADX, D.RETEIVA, 0 PORCENTAJERETEICAX, D.RETEICA, C.PORCENTAJEINC PORCENTAJEINCX, D.IMPUESTO_INC, F.DESCUENTOFACTURA, D.VALOR_DESCUENTO, F.OBSERVACIONES, F.TIPO_PAGO, T.TIPO_MONEDA, D.DESCUENTO, C.PORCENTAJEDESCUENTO, TER.TELEFONOS, TER.CIUDAD CIUDADTERCERO, TER.DEPARTAMENTO DEPTOTERCERO, TER.REGIMEN REGIMENTERCERO, TER.NOMBRE1 RAZONSOCIAL, TER.NATURALEZA NATURALEZATERCERO, TER.NOMBRE NOMBRECLIENTE, TER.APELLIDO1 APELLIDO1CLIENTE, TER.APELLIDO2 APELLIDO2CLIENTE, TER.DIRECCION DIRECCIONTERECERO, TER.CODIGOPOSTAL CODIGOPOSTALTERCERO, TER.DIRECCIONEMAIL EMAILTERCERO, TER.DIGITOVERIFICACION DIGITOVERIFICACIONTERCERO, (SELECT CODIGODIAN FROM PAISES WHERE PAIS = TER.PAIS) PAISTERCERO, F.FECHA_VENCIMIENTO, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA, D.ANO, F.CUENTA_RECAUDO) CUENTA, CASE WHEN D.VALOR_IVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOIVA, CASE WHEN D.VALOR_RETEFUENTE &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEFUENTE, CASE WHEN D.VALOR_ICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOICA, CASE WHEN D.RETEIVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEIVA, CASE WHEN D.IMPUESTO_INC &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOINC, CASE WHEN D.RETEICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEICA, T.TIPOFACDIAN, O.TIPOCOBRO, C.DESCUENTO APLICADESCUENTO, C.CARGO_FE, C.DESCUENTOS_FE, O.DIFERIDA, O.CUOTAS_DIFERIDAS, F.CUENTA_RECAUDO, CONCAT(O.TXTPREFIJO, CONCAT('¬', O.TXTCONTRATO)) AS PREFIJOORDEN, CPN.DIRECCION DIRECCIONCOMPANIA, CPN.CIUDAD CIUDADCOMPANIA, CPN.DEPARTAMENTO DEPTOCOMPANIA, (SELECT DIGITOVERIFICACION FROM TERCERO WHERE NIT = CPN.NITCOMPANIA AND ROWNUM = 1) DIGITOVERIFICACIONCOMPANIA, F.VALOR_TOTAL, CNT.VLR_BASE FROM SF_TIPO_COBRO T INNER JOIN SF_FACTURA F INNER JOIN SF_DETALLE_FACTURA D ON F.COMPANIA = D.COMPANIA AND F.TIPO_FACTURA = D.TIPO_FACTURA AND F.NUMERO_FACTURA = D.FACTURA AND F.TIPOCOBRO = D.TIPOCOBRO ON ( T.ANO = D.ANO ) AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL INNER JOIN COMPANIA CPN ON (F.COMPANIA = CPN.CODIGO) INNER JOIN COMPROBANTE_CNT CNT ON (CNT.COMPANIA = O.COMPANIA AND CNT.TIPO = O.TIPOCOBRO AND CNT.NUMERO = O.CODIGO_COBRO) WHERE F.COMPANIA = :COMPANIA AND TO_CHAR(F.FECHA_EXPEDICION, 'dd/MM/YYYY') BETWEEN :FECHAINICIAL AND :FECHAFINAL AND O.IMPRESO NOT IN ( 0 ) AND F.NUMERO_FACTURA = :NUMEROFACTURA AND O.TIPOCOBRO = :TIPOCOBRO ORDER BY F.NUMERO_FACTURA ) FACT_SYSMAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREATED_BY":"$CREATED_BY","FECHAFACTURA":"$FECHAFACTURA","FECHAFACTURA_SOL":"$FECHAFACTURA_SOL","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","MEDIOPAGO":"$MEDIOPAGO","NUMTERCERO":"$NUMTERCERO","PREFIJO":"$PREFIJO","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","TELEFONOS":"$TELEFONOS","DESCUENTOFACTURA":"$DESCUENTOFACTURA","TIPO_MONEDA":"$TIPO_MONEDA","OBSERVACIONES":"$OBSERVACIONES","TIPO_PAGO":"$TIPO_PAGO","CUENTA":"$CUENTA","TIPOFACDIAN":"$TIPOFACDIAN","DIFERIDA":"$DIFERIDA(type:boolean)","CUOTAS_DIFERIDAS":"$CUOTAS_DIFERIDAS","CUENTA_RECAUDO":"$CUENTA_RECAUDO","PREFIJOORDEN":"$PREFIJOORDEN","DIRECCIONCOMPANIA":"$DIRECCIONCOMPANIA","CIUDADCOMPANIA":"$CIUDADCOMPANIA","DEPTOCOMPANIA":"$DEPTOCOMPANIA","CIUDADTERCERO":"$CIUDADTERCERO","DEPTOTERCERO":"$DEPTOTERCERO","REGIMENTERCERO":"$REGIMENTERCERO","RAZONSOCIAL":"$RAZONSOCIAL","NATURALEZATERCERO":"$NATURALEZATERCERO","NOMBRECLIENTE":"$NOMBRECLIENTE","APELLIDO1CLIENTE":"$APELLIDO1CLIENTE","APELLIDO2CLIENTE":"$APELLIDO2CLIENTE","DIRECCIONTERECERO":"$DIRECCIONTERECERO","CODIGOPOSTALTERCERO":"$CODIGOPOSTALTERCERO","PAISTERCERO":"$PAISTERCERO","EMAILTERCERO":"$EMAILTERCERO","DIGITOVERIFICACIONTERCERO":"$DIGITOVERIFICACIONTERCERO(type:long)","DIGITOVERIFICACIONCOMPANIA":"$DIGITOVERIFICACIONCOMPANIA(type:integer)","VALOR_TOTAL":"$VALOR_TOTAL","VLR_BASE":"$VLR_BASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/getdatafactenvioinvoway">
		<call-query href="getSffacturaGetdatafactenvioinvowayQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
		<query id="getSffacturaGetdatafactenvioinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT FACT_SYSMAN.CREATED_BY, TO_CHAR(FACT_SYSMAN.FECHAFACTURA, 'YYYY-MM-DD hh:mm:ss') FECHAFACTURA, TO_CHAR(FACT_SYSMAN.FECHAFACTURA_SOL, 'YYYY-MM-DD hh:mm:ss') FECHAFACTURA_SOL, FACT_SYSMAN.NUMEROFACTURA, FACT_SYSMAN.MEDIOPAGO, FACT_SYSMAN.NUMTERCERO, FACT_SYSMAN.PREFIJO, TO_CHAR(FACT_SYSMAN.FECHA_VENCIMIENTO, 'YYYY-MM-DD hh:mm:ss') FECHA_VENCIMIENTO, FACT_SYSMAN.TELEFONOS, FACT_SYSMAN.DESCUENTOFACTURA, FACT_SYSMAN.TIPO_MONEDA, FACT_SYSMAN.OBSERVACIONES, FACT_SYSMAN.TIPO_PAGO, FACT_SYSMAN.CUENTA, FACT_SYSMAN.TIPOFACDIAN,(CASE FACT_SYSMAN.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA, FACT_SYSMAN.CUOTAS_DIFERIDAS, FACT_SYSMAN.CUENTA_RECAUDO, FACT_SYSMAN.PREFIJOORDEN, FACT_SYSMAN.DIRECCIONCOMPANIA, FACT_SYSMAN.CIUDADCOMPANIA, FACT_SYSMAN.DEPTOCOMPANIA, FACT_SYSMAN.CIUDADTERCERO, FACT_SYSMAN.DEPTOTERCERO, FACT_SYSMAN.REGIMENTERCERO, FACT_SYSMAN.RAZONSOCIAL, FACT_SYSMAN.NATURALEZATERCERO, FACT_SYSMAN.NOMBRECLIENTE, FACT_SYSMAN.APELLIDO1CLIENTE, FACT_SYSMAN.APELLIDO2CLIENTE, FACT_SYSMAN.DIRECCIONTERECERO, FACT_SYSMAN.CODIGOPOSTALTERCERO, FACT_SYSMAN.PAISTERCERO, FACT_SYSMAN.EMAILTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONTERCERO, FACT_SYSMAN.DIGITOVERIFICACIONCOMPANIA, FACT_SYSMAN.VALOR_TOTAL, FACT_SYSMAN.VLR_BASE, FACT_SYSMAN.SUBTOTAL  FROM ( SELECT F.CREATED_BY, F.TERCERO NUMTERCERO, F.FECHA_EXPEDICION FECHAFACTURA, O.FECHA_SOLICITUD FECHAFACTURA_SOL, F.NUMERO_FACTURA NUMEROFACTURA, F.TIPO_MEDIOPAGO MEDIOPAGO, T.REF_FACTURACION PREFIJO, C.CODEQUIV_DIAN CODIGOPRODUCTO, D.CANTIDAD, C.NOMBRE DESCRIPCIONPRODUCTO, D.VALOR_UNITARIO VALORUNITARIO, D.VALOR_NETO TOTALITEM, D.VALOR_BASE SUBTOTAL, C.PORCENTAJEIVA PORCENTAJEIVAX, D.VALOR_IVA VALORIMPUESTO, C.PORCENTAJERETEFUENTE PORCENTAJERETEFUENTEX, D.VALOR_RETEFUENTE, C.PORCENTAJEICA PORCENTAJEICAX, D.VALOR_ICA, C.PORCENTAJERETEIVA * 100 PORCENTAJERETEIVADX, D.RETEIVA, 0 PORCENTAJERETEICAX, D.RETEICA, C.PORCENTAJEINC PORCENTAJEINCX, D.IMPUESTO_INC, F.DESCUENTOFACTURA, D.VALOR_DESCUENTO, F.OBSERVACIONES, F.TIPO_PAGO, T.TIPO_MONEDA, D.DESCUENTO, C.PORCENTAJEDESCUENTO, TER.TELEFONOS, TER.CIUDAD CIUDADTERCERO, TER.DEPARTAMENTO DEPTOTERCERO, TER.REGIMEN REGIMENTERCERO, TER.NOMBRE1 RAZONSOCIAL, TER.NATURALEZA NATURALEZATERCERO, TER.NOMBRE NOMBRECLIENTE, TER.APELLIDO1 APELLIDO1CLIENTE, TER.APELLIDO2 APELLIDO2CLIENTE, TER.DIRECCION DIRECCIONTERECERO, TER.CODIGOPOSTAL CODIGOPOSTALTERCERO, TER.DIRECCIONEMAIL EMAILTERCERO, TER.DIGITOVERIFICACION DIGITOVERIFICACIONTERCERO, (SELECT CODIGODIAN FROM PAISES WHERE PAIS = TER.PAIS) PAISTERCERO, F.FECHA_VENCIMIENTO, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA, D.ANO, F.CUENTA_RECAUDO) CUENTA, CASE WHEN D.VALOR_IVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOIVA, CASE WHEN D.VALOR_RETEFUENTE &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEFUENTE, CASE WHEN D.VALOR_ICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOICA, CASE WHEN D.RETEIVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEIVA, CASE WHEN D.IMPUESTO_INC &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOINC, CASE WHEN D.RETEICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEICA, T.TIPOFACDIAN, O.TIPOCOBRO, C.DESCUENTO APLICADESCUENTO, C.CARGO_FE, C.DESCUENTOS_FE, O.DIFERIDA, O.CUOTAS_DIFERIDAS, F.CUENTA_RECAUDO, CONCAT(O.TXTPREFIJO, CONCAT('#', O.TXTCONTRATO)) AS PREFIJOORDEN, CPN.DIRECCION DIRECCIONCOMPANIA, CPN.CIUDAD CIUDADCOMPANIA, CPN.DEPARTAMENTO DEPTOCOMPANIA, (SELECT DIGITOVERIFICACION FROM TERCERO WHERE NIT = CPN.NITCOMPANIA AND ROWNUM = 1) DIGITOVERIFICACIONCOMPANIA, F.VALOR_TOTAL, CNT.VLR_BASE FROM SF_TIPO_COBRO T INNER JOIN SF_FACTURA F INNER JOIN SF_DETALLE_FACTURA D ON F.COMPANIA = D.COMPANIA AND F.TIPO_FACTURA = D.TIPO_FACTURA AND F.NUMERO_FACTURA = D.FACTURA AND F.TIPOCOBRO = D.TIPOCOBRO ON ( T.ANO = D.ANO ) AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL INNER JOIN COMPANIA CPN ON (F.COMPANIA = CPN.CODIGO) INNER JOIN COMPROBANTE_CNT CNT ON (CNT.COMPANIA = O.COMPANIA AND CNT.TIPO = O.TIPOCOBRO AND CNT.NUMERO = O.CODIGO_COBRO) WHERE F.COMPANIA = :COMPANIA AND TRUNC(F.FECHA_EXPEDICION) BETWEEN :FECHAINICIAL AND :FECHAFINAL AND O.IMPRESO NOT IN ( 0 ) AND F.NUMERO_FACTURA = :NUMEROFACTURA AND O.TIPOCOBRO = :TIPOCOBRO ORDER BY F.NUMERO_FACTURA ) FACT_SYSMAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CREATED_BY":"$CREATED_BY","FECHAFACTURA":"$FECHAFACTURA","FECHAFACTURA_SOL":"$FECHAFACTURA_SOL","NUMEROFACTURA":"$NUMEROFACTURA(type:long)","MEDIOPAGO":"$MEDIOPAGO","NUMTERCERO":"$NUMTERCERO","PREFIJO":"$PREFIJO","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","TELEFONOS":"$TELEFONOS","DESCUENTOFACTURA":"$DESCUENTOFACTURA","TIPO_MONEDA":"$TIPO_MONEDA","OBSERVACIONES":"$OBSERVACIONES","TIPO_PAGO":"$TIPO_PAGO","CUENTA":"$CUENTA","TIPOFACDIAN":"$TIPOFACDIAN","DIFERIDA":"$DIFERIDA(type:boolean)","CUOTAS_DIFERIDAS":"$CUOTAS_DIFERIDAS","CUENTA_RECAUDO":"$CUENTA_RECAUDO","PREFIJOORDEN":"$PREFIJOORDEN","DIRECCIONCOMPANIA":"$DIRECCIONCOMPANIA","CIUDADCOMPANIA":"$CIUDADCOMPANIA","DEPTOCOMPANIA":"$DEPTOCOMPANIA","CIUDADTERCERO":"$CIUDADTERCERO","DEPTOTERCERO":"$DEPTOTERCERO","REGIMENTERCERO":"$REGIMENTERCERO","RAZONSOCIAL":"$RAZONSOCIAL","NATURALEZATERCERO":"$NATURALEZATERCERO","NOMBRECLIENTE":"$NOMBRECLIENTE","APELLIDO1CLIENTE":"$APELLIDO1CLIENTE","APELLIDO2CLIENTE":"$APELLIDO2CLIENTE","DIRECCIONTERECERO":"$DIRECCIONTERECERO","CODIGOPOSTALTERCERO":"$CODIGOPOSTALTERCERO","PAISTERCERO":"$PAISTERCERO","EMAILTERCERO":"$EMAILTERCERO","DIGITOVERIFICACIONTERCERO":"$DIGITOVERIFICACIONTERCERO(type:long)","DIGITOVERIFICACIONCOMPANIA":"$DIGITOVERIFICACIONCOMPANIA(type:integer)","VALOR_TOTAL":"$VALOR_TOTAL","VLR_BASE":"$VLR_BASE","SUBTOTAL":"$SUBTOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/getdatafactenvioinvoway">
		<call-query href="getSffacturaGetdatafactenvioinvowayQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="NUMEROFACTURA" query-param="NUMEROFACTURA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
		<query id="getSffacturaGetfacturasmasivoinvowayQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT F.NUMERO_FACTURA NUMEROFACTURA FROM SF_TIPO_COBRO T INNER JOIN SF_FACTURA F INNER JOIN SF_DETALLE_FACTURA D ON F.COMPANIA = D.COMPANIA AND F.TIPO_FACTURA = D.TIPO_FACTURA AND F.NUMERO_FACTURA = D.FACTURA AND F.TIPOCOBRO = D.TIPOCOBRO ON ( T.ANO = D.ANO ) AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL WHERE F.COMPANIA = :COMPANIA AND F.FECHA_EXPEDICION BETWEEN TO_DATE(:FECHAINICIAL, 'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL, 'DD/MM/YYYY') AND O.IMPRESO NOT IN ( 0 ) AND O.TIPOCOBRO = :TIPOCOBRO ORDER BY F.NUMERO_FACTURA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMEROFACTURA":"$NUMEROFACTURA(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/getfacturasmasivoinvoway">
		<call-query href="getSffacturaGetfacturasmasivoinvowayQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>

		</call-query>
	</resource>
	<query id="getSffacturaGetfacturasporinmueblesQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT SFF.NUMERO_FACTURA, SFF.TIPO_FACTURA, SFF.TERCERO, SFF.CODIGO_COBRO, SFF.ANO,(CASE SFO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO FROM SF_FACTURA SFF INNER JOIN SF_OBJETO_COBRO SFO ON ( SFF.COMPANIA = SFO.COMPANIA AND SFF.ANO = SFO.ANO AND SFF.CODIGO_COBRO = SFO.CODIGO_COBRO AND SFF.TIPOCOBRO = SFO.TIPOCOBRO ) INNER JOIN SF_CONTRATOS SFC ON ( SFO.COMPANIA = SFC.COMPANIA AND SFO.ANO = SFC.ANO AND SFO.TXTCONTRATO = SFC.NUMERO ) LEFT JOIN SF_DETALLE_CONTRATO SFDT ON ( SFDT.COMPANIA = SFC.COMPANIA AND SFDT.NUMERO = SFC.NUMERO AND SFDT.TIPO = SFC.TIPO ) INNER JOIN INMUEBLE_FACTURACION IMF ON ( SFDT.INMUEBLE = IMF.CODIGOINMUEBLE AND SFDT.COMPANIA = IMF.COMPANIA ) WHERE SFF.COMPANIA = :COMPANIA AND IMF.CODIGOINMUEBLE BETWEEN :IMFINICIAL AND :IMFFINAL AND SFF.ANO = :ANO AND SFO.IMPRESO NOT IN ( 0 ) ORDER BY SFF.NUMERO_FACTURA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","TIPO_FACTURA":"$TIPO_FACTURA","TERCERO":"$TERCERO","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","ANO":"$ANO(type:integer)","IMPRESO":"$IMPRESO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IMFINICIAL" sqlType="STRING"/>
		<param name="IMFFINAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/getfacturasporinmuebles">
		<call-query href="getSffacturaGetfacturasporinmueblesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IMFINICIAL" query-param="IMFINICIAL"/>
			<with-param name="IMFFINAL" query-param="IMFFINAL"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSffacturaPagTodasporanotipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF.NUMERO_FACTURA, SF.OBSERVACIONES FROM SF_FACTURA SF INNER JOIN SF_OBJETO_COBRO SFO ON SF.COMPANIA = SFO.COMPANIA AND SF.ANO = SFO.ANO AND SF.TIPOCOBRO = SFO.TIPOCOBRO AND SF.CODIGO_COBRO = SFO.CODIGO_COBRO WHERE SF.COMPANIA = :COMPANIA AND SF.TIPOCOBRO = :TIPOCOBRO AND SF.ANO = :ANO AND (:FECHA_VENC IS NULL OR TRUNC(SF.FECHA_VENCIMIENTO) = :FECHA_VENC) AND (:FECHA_EXP IS NULL OR TRUNC(SF.FECHA_EXPEDICION) = :FECHA_EXP) AND SF.ANULADA IN ( 0 ) AND SFO.INDPAGO IN ( 0 ) ORDER BY SF.NUMERO_FACTURA) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_VENC" sqlType="STRING"/>
		<param name="FECHA_EXP" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sffactura/todasporanotipo/pag">
		<call-query href="getSffacturaPagTodasporanotipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_VENC" query-param="FECHA_VENC"/>
			<with-param name="FECHA_EXP" query-param="FECHA_EXP"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSffacturaNumTodasporanotipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF.NUMERO_FACTURA, SF.OBSERVACIONES FROM SF_FACTURA SF INNER JOIN SF_OBJETO_COBRO SFO ON SF.COMPANIA = SFO.COMPANIA AND SF.ANO = SFO.ANO AND SF.TIPOCOBRO = SFO.TIPOCOBRO AND SF.CODIGO_COBRO = SFO.CODIGO_COBRO WHERE SF.COMPANIA = :COMPANIA AND SF.TIPOCOBRO = :TIPOCOBRO AND SF.ANO = :ANO AND (:FECHA_VENC IS NULL OR TRUNC(SF.FECHA_VENCIMIENTO) = :FECHA_VENC) AND (:FECHA_EXP IS NULL OR TRUNC(SF.FECHA_EXPEDICION) = :FECHA_EXP) AND SF.ANULADA IN ( 0 ) AND SFO.INDPAGO IN ( 0 ) ORDER BY SF.NUMERO_FACTURA) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_VENC" sqlType="STRING"/>
		<param name="FECHA_EXP" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/todasporanotipo/num">
		<call-query href="getSffacturaNumTodasporanotipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_VENC" query-param="FECHA_VENC"/>
			<with-param name="FECHA_EXP" query-param="FECHA_EXP"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="getSffacturaPagTodasporanotipofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF.NUMERO_FACTURA, SF.OBSERVACIONES FROM SF_FACTURA SF INNER JOIN SF_OBJETO_COBRO SFO ON SF.COMPANIA = SFO.COMPANIA AND SF.ANO = SFO.ANO AND SF.TIPOCOBRO = SFO.TIPOCOBRO AND SF.CODIGO_COBRO = SFO.CODIGO_COBRO WHERE SF.COMPANIA = :COMPANIA AND SF.TIPOCOBRO = :TIPOCOBRO AND SF.ANO = :ANO AND (:FECHA_VENC IS NULL OR TRUNC(SF.FECHA_VENCIMIENTO) = :FECHA_VENC) AND (:FECHA_EXP IS NULL OR TRUNC(SF.FECHA_EXPEDICION) = :FECHA_EXP) AND SF.ANULADA = 0 AND SFO.INDPAGO = 0 AND SF.NUMERO_FACTURA &gt;= :FACTURA ORDER BY SF.NUMERO_FACTURA) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
