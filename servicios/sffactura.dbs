	<query id="getSffacturaPagNumnitnombreinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FACTURA_SF.NUMERO_FACTURA, FACTURA_SF.VALOR_TOTAL, FACTURA_SF.NIT_TERCEROFACTURADO, FACTURA_SF.NOMBRE_TERCEROFACTURADO  FROM SF_FACTURA FACTURA_SF WHERE FACTURA_SF.COMPANIA = :COMPANIA AND FACTURA_SF.TIPO_FACTURA = :TIPOCOBRO AND FACTURA_SF.ANO = :ANO AND ANULADA IN (0) AND IND_ACUERDO IN (0) ORDER BY FACTURA_SF.NUMERO_FACTURA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN NIT_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NIT_TERCEROFACTURADO) END)  LIKE UPPER(:NIT_TERCEROFACTURADO || '%')  AND (CASE WHEN NOMBRE_TERCEROFACTURADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCEROFACTURADO) END)  LIKE UPPER( '%' || :NOMBRE_TERCEROFACTURADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","VALOR_TOTAL":"$VALOR_TOTAL","NIT_TERCEROFACTURADO":"$NIT_TERCEROFACTURADO","NOMBRE_TERCEROFACTURADO":"$NOMBRE_TERCEROFACTURADO"}]}}		</result>
