	<query id="getSffacturaPagTipofacttipogrillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_DETALLE_ABONO.CUOTA, SF_DETALLE_ABONO.CODIGO_ABONO, CASE WHEN SF_DETALLE_ABONO.CUOTA = 0 THEN 'Cuota Inicial' ELSE TO_CHAR(SF_DETALLE_ABONO.CUOTA) END CUOTAD, CASE WHEN SF_DETALLE_ABONO.ESTADO = 'R' THEN 'PAGA' WHEN SF_DETALLE_ABONO.ESTADO = 'A' THEN 'ACTIVA' ELSE 'N/A' END EST,(TO_CHAR(SF_DETALLE_ABONO.FECHACUOTA,'DD/MM/YYYY HH24:MI:SS')) FECHACUOTA, SF_DETALLE_ABONO.TOTAL_CUOTA  FROM SF_FACTURA INNER JOIN SF_DETALLE_ABONO ON SF_FACTURA.NRO_ABONO = SF_DETALLE_ABONO.CODIGO_ABONO AND SF_FACTURA.TIPO_ABONO = SF_DETALLE_ABONO.TIPO_ABONO AND SF_FACTURA.COMPANIA = SF_DETALLE_ABONO.COMPANIA WHERE SF_FACTURA.COMPANIA =:COMPANIA AND SF_FACTURA.TERCERO =:TERCERO ORDER BY SF_FACTURA.NUMERO_FACTURA, SF_DETALLE_ABONO.CUOTA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN CODIGO_ABONO IS NULL THEN ' ' ELSE UPPER(CODIGO_ABONO) END)  LIKE UPPER(:CODIGO_ABONO || '%')  AND (CASE WHEN CUOTAD IS NULL THEN ' ' ELSE UPPER(CUOTAD) END)  LIKE UPPER(:CUOTAD || '%')  AND (CASE WHEN EST IS NULL THEN ' ' ELSE UPPER(EST) END)  LIKE UPPER(:EST || '%')  AND (CASE WHEN FECHACUOTA IS NULL THEN ' ' ELSE UPPER(FECHACUOTA) END)  LIKE UPPER(:FECHACUOTA || '%')  AND (CASE WHEN TOTAL_CUOTA IS NULL THEN ' ' ELSE UPPER(TOTAL_CUOTA) END)  LIKE UPPER(:TOTAL_CUOTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","CUOTA":"$CUOTA(type:integer)","CODIGO_ABONO":"$CODIGO_ABONO(type:long)","CUOTAD":"$CUOTAD","EST":"$EST","FECHACUOTA":"$FECHACUOTA","TOTAL_CUOTA":"$TOTAL_CUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="CODIGO_ABONO" sqlType="STRING"/>
		<param name="CUOTAD" sqlType="STRING"/>
		<param name="EST" sqlType="STRING"/>
		<param name="FECHACUOTA" sqlType="STRING"/>
		<param name="TOTAL_CUOTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
