 F.TIPOCOBRO = D.TIPOCOBRO ON ( T.ANO = D.ANO ) AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL WHERE F.COMPANIA =:COMPANIA AND TO_CHAR(F.FECHA_EXPEDICION,'dd/MM/YYYY') BETWEEN :FECHAINICIAL AND :FECHAFINAL AND O.IMPRESO NOT IN ( 0 ) AND F.NUMERO_FACTURA =:NUMEROFACTURA AND O.TIPOCOBRO =:TIPOCOBRO ORDER BY F.NUMERO_FACTURA ) FACT_SYSMAN WHERE FACT_SYSMAN.PORCENTAJEINCX &lt;&gt; 0 GROUP BY FACT_SYSMAN.PORCENTAJEINCX</sql>
