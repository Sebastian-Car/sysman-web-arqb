	<query id="getSffacturaUltimoabonoparcialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FECHA_ULTIMOABONO  FROM ( SELECT DC.COMPANIA, DC.TIPOFACT, DC.NROFACT, TO_CHAR(FRA.FECHA_EXPEDICION, 'DD/MM/YYYY') FECHA_ULTIMOABONO FROM SF_DETALLE_CUOTAABONO DC INNER JOIN SF_DETALLE_ABONO DA ON DC.COMPANIA = DA.COMPANIA AND DC.TIPO_ABONO = DA.TIPO_ABONO AND DC.CODIGO_ABONO = DA.CODIGO_ABONO AND DC.CUOTA = DA.CUOTA INNER JOIN SF_ABONOS A ON DC.COMPANIA = A.COMPANIA AND DC.TIPO_ABONO = A.TIPO AND DC.CODIGO_ABONO = A.CODIGO INNER JOIN SF_FACTURA FRA ON DC.COMPANIA = FRA.COMPANIA AND DC.TIPOFACT = FRA.TIPO_FACTURA AND DC.NROFACT = FRA.NUMERO_FACTURA WHERE A.COMPANIA = :COMPANIA AND A.TIPO_FACT =:TIPO AND A.NRO_FACT = :FACTURA AND DA.ESTADO = 'R' ORDER BY DC.CUOTA DESC) WHERE ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA_ULTIMOABONO":"$FECHA_ULTIMOABONO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>

	</query>
