	<query id="getSffacturaPagBancoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SF_FACTURA.BANCO_PAGO, PLAN_CONTABLE.NOMBRE  FROM SF_FACTURA INNER JOIN PLAN_CONTABLE ON PLAN_CONTABLE.COMPANIA = SF_FACTURA.COMPANIA AND PLAN_CONTABLE.ANO = EXTRACT(YEAR FROM SF_FACTURA.FECHA_EXPEDICION) AND PLAN_CONTABLE.CODIGO = SF_FACTURA.BANCO_PAGO WHERE SF_FACTURA.COMPANIA = :COMPANIA) WHERE (CASE WHEN BANCO_PAGO IS NULL THEN ' ' ELSE UPPER(BANCO_PAGO) END)  LIKE UPPER(:BANCO_PAGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BANCO_PAGO":"$BANCO_PAGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BANCO_PAGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
