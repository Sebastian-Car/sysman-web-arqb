	</resource>
	<query id="getSffacturaFacturasWsCajicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_FACTURA.COMPANIA, SF_FACTURA.NUMERO_FACTURA, TO_CHAR(SF_FACTURA.FECHA_VENCIMIENTO,'DD/MM/YYYY')FECHA_LIMITE, TO_CHAR(SF_FACTURA.FECHA_EXPEDICION,'DD/MM/YYYY')FECHA_EX, SF_FACTURA.VALOR_TOTAL, SF_FACTURA.TIPO_FACTURA , CASE WHEN SF_FACTURA.ANULADA NOT IN( 0 ) THEN 'Factura Anulada' WHEN SF_FACTURA.FECHA_PAGO IS NOT NULL THEN 'Factura Paga.' ELSE 'OK' END ESTADO, SF_FACTURA.CREATED_BY FROM SF_FACTURA INNER JOIN SF_TIPO_COBRO ON SF_FACTURA.COMPANIA = SF_TIPO_COBRO.COMPANIA AND SF_FACTURA.ANO = SF_TIPO_COBRO.ANO AND SF_FACTURA.TIPO_FACTURA = SF_TIPO_COBRO.CODIGO WHERE SF_FACTURA.NUMERO_FACTURA = :FACTURA AND SF_TIPO_COBRO.TIPOFACTURA_RECAUDO = :TIPORECAUDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","FECHA_LIMITE":"$FECHA_LIMITE","FECHA_EX":"$FECHA_EX","VALOR_TOTAL":"$VALOR_TOTAL","TIPO_FACTURA":"$TIPO_FACTURA","ESTADO":"$ESTADO","CREATED_BY":"$CREATED_BY"}]}}		</result>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="TIPORECAUDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/facturaswscajica">
		<call-query href="getSffacturaFacturasWsCajicaQuery">
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="TIPORECAUDO" query-param="TIPORECAUDO"/>

		</call-query>
	</resource>
	<query id="getSffacturaPagConpagosparcialesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_FACTURA.COMPANIA, SF_FACTURA.TIPO_FACTURA TIPOCOBRO, TERCERO.NIT, TERCERO.NOMBRE, SF_FACTURA.NUMERO_FACTURA FACTURA, SF_FACTURA.OBSERVACIONES DESCRIPCION, SF_FACTURA.VALOR_TOTAL VALORTOTAL,(TO_CHAR(SF_FACTURA.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION,(TO_CHAR(SF_FACTURA.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, SF_FACTURA.NUMERO_RESOLUCION, SF_FACTURA.NUMERO_EXPEDIENTE,(TO_CHAR(SF_FACTURA.FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION,(TO_CHAR(SF_FACTURA.FECHA_EJECUTORA,'DD/MM/YYYY HH24:MI:SS')) FECHA_EJECUTORA,(TO_CHAR(SF_FACTURA.FECHA_CORTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_CORTE FROM SF_FACTURA INNER JOIN TERCERO ON SF_FACTURA.COMPANIA = TERCERO.COMPANIA AND SF_FACTURA.TERCERO = TERCERO.NIT WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPO_FACTURA = :TIPOCOBRO AND SF_FACTURA.ANO = :ANOCOBRO AND SF_FACTURA.ANULADA IN (0) AND SF_FACTURA.TIPOFRA_PAGOPARCIAL IS NULL AND SF_FACTURA.NROFRA_PAGOPARCIAL IS NULL ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FACTURA IS NULL THEN ' ' ELSE UPPER(FACTURA) END) LIKE UPPER(CONCAT(:FACTURA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FECHA_CORTE IS NULL THEN ' ' ELSE UPPER(FECHA_CORTE) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_CORTE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOBRO":"$TIPOCOBRO","NIT":"$NIT","NOMBRE":"$NOMBRE","FACTURA":"$FACTURA(type:long)","DESCRIPCION":"$DESCRIPCION","VALORTOTAL":"$VALORTOTAL","FECHA_EXPEDICION":"$FECHA_EXPEDICION","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","NUMERO_RESOLUCION":"$NUMERO_RESOLUCION","NUMERO_EXPEDIENTE":"$NUMERO_EXPEDIENTE","FECHA_RESOLUCION":"$FECHA_RESOLUCION","FECHA_EJECUTORA":"$FECHA_EJECUTORA","FECHA_CORTE":"$FECHA_CORTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA_CORTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sffactura/conpagosparciales/pag">
		<call-query href="getSffacturaPagConpagosparcialesQuery">
