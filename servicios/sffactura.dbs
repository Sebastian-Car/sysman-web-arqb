	<query id="getSffacturaNumTodospornumerofacturaterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.TERCERO, SF_FACTURA.SUCURSAL, SF_FACTURA.CENTRO_COSTO, SF_FACTURA.AUXILIAR, SF_FACTURA.VALOR_TOTAL,(CASE SF_FACTURA.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA, SF_FACTURA.TIPO_ABONO, SF_FACTURA.NRO_ABONO, SF_OBJETO_COBRO.TASA_INTERES, SF_OBJETO_COBRO.VLR_EFECTIVO, SF_OBJETO_COBRO.VLR_CREDITO, SF_OBJETO_COBRO.CUOTAS_DIFERIDAS, SF_OBJETO_COBRO.VLR_PROM_CUOTA,(TO_CHAR(SF_FACTURA.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION, SF_FACTURA.OBSERVACIONES  FROM SF_FACTURA INNER JOIN SF_OBJETO_COBRO ON SF_FACTURA.COMPANIA = SF_OBJETO_COBRO.COMPANIA AND SF_FACTURA.TIPOCOBRO = SF_OBJETO_COBRO.TIPOCOBRO AND SF_FACTURA.ANO = SF_OBJETO_COBRO.ANO AND SF_FACTURA.CODIGO_COBRO = SF_OBJETO_COBRO.CODIGO_COBRO WHERE SF_FACTURA.COMPANIA = :COMPANIA AND TIPO_FACTURA = :TIPOFACTURA AND FECHA_PAGO IS NULL AND IND_ACUERDO IN (0) AND SF_OBJETO_COBRO.INDPAGO IN (0) AND SF_FACTURA.ANO =:ANOCOBRO ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN TIPO_FACTURA IS NULL THEN ' ' ELSE UPPER(TIPO_FACTURA) END)  LIKE UPPER(:TIPO_FACTURA || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN DIFERIDA IS NULL THEN ' ' ELSE UPPER(DIFERIDA) END)  LIKE UPPER(:DIFERIDA || '%')  AND (CASE WHEN TIPO_ABONO IS NULL THEN ' ' ELSE UPPER(TIPO_ABONO) END)  LIKE UPPER(:TIPO_ABONO || '%')  AND (CASE WHEN NRO_ABONO IS NULL THEN ' ' ELSE UPPER(NRO_ABONO) END)  LIKE UPPER(:NRO_ABONO || '%')  AND (CASE WHEN TASA_INTERES IS NULL THEN ' ' ELSE UPPER(TASA_INTERES) END)  LIKE UPPER(:TASA_INTERES || '%')  AND (CASE WHEN VLR_EFECTIVO IS NULL THEN ' ' ELSE UPPER(VLR_EFECTIVO) END)  LIKE UPPER(:VLR_EFECTIVO || '%')  AND (CASE WHEN VLR_CREDITO IS NULL THEN ' ' ELSE UPPER(VLR_CREDITO) END)  LIKE UPPER(:VLR_CREDITO || '%')  AND (CASE WHEN CUOTAS_DIFERIDAS IS NULL THEN ' ' ELSE UPPER(CUOTAS_DIFERIDAS) END)  LIKE UPPER(:CUOTAS_DIFERIDAS || '%')  AND (CASE WHEN VLR_PROM_CUOTA IS NULL THEN ' ' ELSE UPPER(VLR_PROM_CUOTA) END)  LIKE UPPER(:VLR_PROM_CUOTA || '%')  AND (CASE WHEN FECHA_EXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHA_EXPEDICION) END)  LIKE UPPER(:FECHA_EXPEDICION || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
