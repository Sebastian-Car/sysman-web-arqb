	<query id="getSffacturaFact_sysmanImpuestosReteQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(FACT_SYSMAN.BASEIMPUESTORETEFUENTE) SUMADEBASEIMPUESTORETEFUENTE, FACT_SYSMAN.PORCENTAJERETEFUENTEX PORCENTAJE, SUM(FACT_SYSMAN.VALOR_RETEFUENTE) SUMADEVALOR_RETEFUENTE FROM ( SELECT F.CREATED_BY, F.TERCERO NUMTERCERO, F.FECHA_EXPEDICION FECHAFACTURA, F.NUMERO_FACTURA NUMEROFACTURA, F.TIPO_MEDIOPAGO MEDIOPAGO, T.REF_FACTURACION PREFIJO, C.CODEQUIV_DIAN CODIGOPRODUCTO, D.CANTIDAD, C.NOMBRE DESCRIPCIONPRODUCTO, D.VALOR_UNITARIO VALORUNITARIO, D.VALOR_NETO TOTALITEM, D.VALOR_BASE SUBTOTAL, C.PORCENTAJEIVA PORCENTAJEIVAX, D.VALOR_IVA VALORIMPUESTO, C.PORCENTAJERETEFUENTE PORCENTAJERETEFUENTEX, D.VALOR_RETEFUENTE, C.PORCENTAJEICA PORCENTAJEICAX, D.VALOR_ICA, C.PORCENTAJERETEIVA PORCENTAJERETEIVADX, D.RETEIVA, 0 PORCENTAJERETEICAX, D.RETEICA, C.PORCENTAJEINC PORCENTAJEINCX, D.IMPUESTO_INC, F.DESCUENTOFACTURA, D.VALOR_DESCUENTO, F.OBSERVACIONES, F.TIPO_PAGO, T.TIPO_MONEDA, D.DESCUENTO, C.PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VENCIMIENTO, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA, D.ANO, F.CUENTA_RECAUDO) CUENTA, CASE WHEN D.VALOR_IVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOIVA, CASE WHEN D.VALOR_RETEFUENTE &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEFUENTE, CASE WHEN D.VALOR_ICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOICA, CASE WHEN D.RETEIVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEIVA, CASE WHEN D.IMPUESTO_INC &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOINC, CASE WHEN D.RETEICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEICA, T.TIPOFACDIAN, O.TIPOCOBRO, C.DESCUENTO APLICADESCUENTO, C.CARGO_FE, C.DESCUENTOS_FE, O.DIFERIDA, O.CUOTAS_DIFERIDAS, F.CUENTA_RECAUDO FROM SF_TIPO_COBRO T INNER JOIN SF_FACTURA F ON T.ANO = F.ANO AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_DETALLE_FACTURA D ON F.COMPANIA = D.COMPANIA AND F.ANO = D.ANO AND F.TIPO_FACTURA = D.TIPO_FACTURA AND F.NUMERO_FACTURA = D.FACTURA INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.ANO = O.ANO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL WHERE F.COMPANIA = :COMPANIA AND TO_CHAR(F.FECHA_EXPEDICION, 'dd/MM/YYYY') BETWEEN :FECHAINICIAL AND :FECHAFINAL AND O.IMPRESO NOT IN ( 0 ) AND F.NUMERO_FACTURA = :NUMEROFACTURA AND O.TIPOCOBRO = :TIPOCOBRO ORDER BY F.NUMERO_FACTURA ) FACT_SYSMAN WHERE FACT_SYSMAN.PORCENTAJERETEFUENTEX &lt;&gt; 0 GROUP BY FACT_SYSMAN.PORCENTAJERETEFUENTEX</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMADEBASEIMPUESTORETEFUENTE":"$SUMADEBASEIMPUESTORETEFUENTE","PORCENTAJE":"$PORCENTAJE","SUMADEVALOR_RETEFUENTE":"$SUMADEVALOR_RETEFUENTE"}]}}		</result>
