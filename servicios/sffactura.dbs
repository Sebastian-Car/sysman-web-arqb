	</resource>
	<query id="getSffacturaNumTodasporanotipofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF.NUMERO_FACTURA, SF.OBSERVACIONES FROM SF_FACTURA SF INNER JOIN SF_OBJETO_COBRO SFO ON SF.COMPANIA = SFO.COMPANIA AND SF.ANO = SFO.ANO AND SF.TIPOCOBRO = SFO.TIPOCOBRO AND SF.CODIGO_COBRO = SFO.CODIGO_COBRO WHERE SF.COMPANIA = :COMPANIA AND SF.TIPOCOBRO = :TIPOCOBRO AND SF.ANO = :ANO AND (:FECHA_VENC IS NULL OR TRUNC(SF.FECHA_VENCIMIENTO) = :FECHA_VENC) AND (:FECHA_EXP IS NULL OR TRUNC(SF.FECHA_EXPEDICION) = :FECHA_EXP) AND SF.ANULADA = 0 AND SFO.INDPAGO = 0 AND SF.NUMERO_FACTURA &gt;= :FACTURA ORDER BY SF.NUMERO_FACTURA) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="FECHA_VENC" sqlType="STRING"/>
		<param name="FECHA_EXP" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/todasporanotipofinal/num">
		<call-query href="getSffacturaNumTodasporanotipofinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA_VENC" query-param="FECHA_VENC"/>
			<with-param name="FECHA_EXP" query-param="FECHA_EXP"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>

</data>