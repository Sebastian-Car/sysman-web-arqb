		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO_FACTURA ,VALOR_TOTAL ,(TO_CHAR(FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION,(TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO,OBSERVACIONES FROM SF_FACTURA WHERE COMPANIA = :COMPANIA AND TERCERO = :TERCERO AND SUCURSAL = :SUCURSAL AND TIPO_FACTURA = :TIPO AND BANCO_PAGO IS NULL AND IND_ACUERDO IN(0) AND INTERFAZADA NOT IN(0) AND AFECTO_INVENTARIO NOT IN(0) ORDER BY NUMERO_FACTURA DESC) INI WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END) LIKE UPPER(CONCAT(:NUMERO_FACTURA, '%')) AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END) LIKE UPPER(CONCAT(:VALOR_TOTAL, '%')) AND (CASE WHEN FECHA_EXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHA_EXPEDICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_EXPEDICION), '%')) AND (CASE WHEN FECHA_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHA_VENCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_VENCIMIENTO), '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","VALOR_TOTAL":"$VALOR_TOTAL","FECHA_EXPEDICION":"$FECHA_EXPEDICION","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
