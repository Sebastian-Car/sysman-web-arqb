			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="FECHA_CORTE" query-param="FECHA_CORTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSffacturaNumConpagosparcialesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_FACTURA.COMPANIA, SF_FACTURA.TIPO_FACTURA TIPOCOBRO, TERCERO.NIT, TERCERO.NOMBRE, SF_FACTURA.NUMERO_FACTURA FACTURA, SF_FACTURA.OBSERVACIONES DESCRIPCION, SF_FACTURA.VALOR_TOTAL VALORTOTAL,(TO_CHAR(SF_FACTURA.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION,(TO_CHAR(SF_FACTURA.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, SF_FACTURA.NUMERO_RESOLUCION, SF_FACTURA.NUMERO_EXPEDIENTE,(TO_CHAR(SF_FACTURA.FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION,(TO_CHAR(SF_FACTURA.FECHA_EJECUTORA,'DD/MM/YYYY HH24:MI:SS')) FECHA_EJECUTORA,(TO_CHAR(SF_FACTURA.FECHA_CORTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_CORTE FROM SF_FACTURA INNER JOIN TERCERO ON SF_FACTURA.COMPANIA = TERCERO.COMPANIA AND SF_FACTURA.TERCERO = TERCERO.NIT WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPO_FACTURA = :TIPOCOBRO AND SF_FACTURA.ANO = :ANOCOBRO AND SF_FACTURA.ANULADA IN (0) AND SF_FACTURA.TIPOFRA_PAGOPARCIAL IS NULL AND SF_FACTURA.NROFRA_PAGOPARCIAL IS NULL ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FACTURA IS NULL THEN ' ' ELSE UPPER(FACTURA) END) LIKE UPPER(CONCAT(:FACTURA, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN FECHA_CORTE IS NULL THEN ' ' ELSE UPPER(FECHA_CORTE) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_CORTE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA_CORTE" sqlType="STRING"/>

	</query>
