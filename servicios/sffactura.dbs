	<query id="getSffacturaPagNumeroCuentaRecaudoDiferidaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA,SF_FACTURA.CODIGO_COBRO, SF_FACTURA.VALOR_TOTAL, SF_FACTURA.TERCERO, SF_FACTURA.SUCURSAL, TERCERO.NOMBRE, SF_FACTURA.OBSERVACIONES, SF_FACTURA.CUENTA_RECAUDO,(CASE SF_FACTURA.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA,SF_FACTURA.TIPO_ABONO , SF_FACTURA.NRO_ABONO  FROM SF_FACTURA INNER JOIN TERCERO ON SF_FACTURA.COMPANIA = TERCERO.COMPANIA AND SF_FACTURA.TERCERO = TERCERO.NIT AND SF_FACTURA.SUCURSAL = TERCERO.SUCURSAL WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPO_FACTURA = :TIPOFACTURA AND SF_FACTURA.FECHA_PAGO IS NULL ORDER BY SF_FACTURA.NUMERO_FACTURA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER( '%' || :VALOR_TOTAL || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","CODIGO_COBRO":"$CODIGO_COBRO(type:long)","VALOR_TOTAL":"$VALOR_TOTAL","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","OBSERVACIONES":"$OBSERVACIONES","CUENTA_RECAUDO":"$CUENTA_RECAUDO","DIFERIDA":"$DIFERIDA(type:boolean)","TIPO_ABONO":"$TIPO_ABONO","NRO_ABONO":"$NRO_ABONO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOFACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
