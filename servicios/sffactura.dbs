	</resource>
	<query id="getSffacturaNumTodosPorCompaniaTipoCobroAnoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO  FROM SF_FACTURA INNER JOIN SF_DETALLE_FACTURA ON SF_FACTURA.TIPOCOBRO = SF_DETALLE_FACTURA.TIPOCOBRO AND SF_FACTURA.COMPANIA = SF_DETALLE_FACTURA.COMPANIA AND SF_FACTURA.TIPO_FACTURA = SF_DETALLE_FACTURA.TIPO_FACTURA AND SF_FACTURA.NUMERO_FACTURA = SF_DETALLE_FACTURA.FACTURA WHERE SF_FACTURA.COMPANIA =:COMPANIA AND SF_FACTURA.TIPOCOBRO =:TIPOCOBRO AND SF_DETALLE_FACTURA.ANO =:ANOCOBRO GROUP BY SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.DIFERIDA, SF_FACTURA.OBSERVACIONES, SF_FACTURA.OBSERVACIONES, SF_DETALLE_FACTURA.ANO HAVING SF_FACTURA.DIFERIDA NOT IN (0) ORDER BY SF_FACTURA.NUMERO_FACTURA) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
