	</resource>
	<query id="getSffacturaFact_sysmanFacturasQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(NVL(SUBTOTAL, 0) - NVL(VALOR_DESCUENTO, 0)) SUBTOTALFACTURA, SUM(VALORIMPUESTO) IVA, MAX(PORCENTAJEIVAX) PORCENTAJEIVAX, SUM(VALOR_RETEFUENTE) RETE, SUM(NVL(VALOR_ICA, 0)) ICA, SUM(NVL(VALOR_RETEIVA, 0)) RETE_IVA, SUM(NVL(RETEICA, 0)) RETE_ICA, SUM(NVL(IMPUESTO_INC, 0)) INC, SUM(NVL(VALOR_DESCUENTO, 0)) DESCUENTOPARCIAL, SUM(NVL(DESCUENTOFACTURA, 0)) DESCUENTO_FACTURA, PCK_SYSMAN_UTL.FC_ROUND(SUM(NVL(TOTALITEM, 0)), 0) AS TOTAL, SUM(FACT_SYSMAN.BASEIMPUESTOIVA) BASEGRAVABLEIVA, SUM(FACT_SYSMAN.BASEIMPUESTORETEFUENTE) BASEGRAVABLERETE, SUM(FACT_SYSMAN.BASEIMPUESTOICA) BASEGRAVABLEICA, SUM(FACT_SYSMAN.BASEIMPUESTORETEIVA) BASEGRAVABLERETEIVA, SUM(FACT_SYSMAN.BASEIMPUESTORETEICA) BASEGRAVABLERETEICA, SUM(FACT_SYSMAN.BASEIMPUESTOINC) BASEGRAVABLEINC, SUM(FACT_SYSMAN.BASEIMPONIBLE) BASEIMPONIBLE,MAX(PORCENTAJERETEFUENTEX) PORCENTAJERETEFUENTEX,MAX(PORCENTAJERETEIVADX) PORCENTAJERETEIVADX,MAX(PORCENTAJERETEICAX) PORCENTAJERETEICAX FROM ( SELECT F.CREATED_BY, F.TERCERO NUMTERCERO, F.FECHA_EXPEDICION FECHAFACTURA, F.NUMERO_FACTURA NUMEROFACTURA, F.TIPO_MEDIOPAGO MEDIOPAGO, T.REF_FACTURACION PREFIJO, C.CODEQUIV_DIAN CODIGOPRODUCTO, D.CANTIDAD, C.NOMBRE DESCRIPCIONPRODUCTO, D.VALOR_UNITARIO VALORUNITARIO, D.VALOR_NETO TOTALITEM, D.VALOR_BASE SUBTOTAL, C.PORCENTAJEIVA PORCENTAJEIVAX, D.VALOR_IVA VALORIMPUESTO, C.PORCENTAJERETEFUENTE PORCENTAJERETEFUENTEX, D.VALOR_RETEFUENTE, C.PORCENTAJEICA PORCENTAJEICAX, D.VALOR_ICA, C.PORCENTAJERETEIVA PORCENTAJERETEIVADX, D.VALOR_RETEIVA, C.PORCENTAJEICA PORCENTAJERETEICAX, D.RETEICA, C.PORCENTAJEINC PORCENTAJEINCX, D.IMPUESTO_INC, F.DESCUENTOFACTURA, D.VALOR_DESCUENTO, F.OBSERVACIONES, F.TIPO_PAGO, T.TIPO_MONEDA, D.DESCUENTO, C.PORCENTAJEDESCUENTO, TER.TELEFONOS, F.FECHA_VENCIMIENTO, PCK_SYSMAN_UTL.FC_NOMBRECUENTA(F.COMPANIA, D.ANO, F.CUENTA_RECAUDO) CUENTA, CASE WHEN D.VALOR_IVA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOIVA, CASE WHEN D.VALOR_RETEFUENTE &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEFUENTE, CASE WHEN D.VALOR_ICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOICA, CASE WHEN D.VALOR_RETEIVA &gt; 0 THEN D.VALOR_IVA ELSE 0 END BASEIMPUESTORETEIVA, CASE WHEN D.IMPUESTO_INC &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTOINC, CASE WHEN D.RETEICA &gt; 0 THEN NVL(D.VALOR_BASE, 0) - NVL(D.VALOR_DESCUENTO, 0) ELSE 0 END BASEIMPUESTORETEICA, T.TIPOFACDIAN, O.TIPOCOBRO, C.DESCUENTO APLICADESCUENTO, C.CARGO_FE, C.DESCUENTOS_FE, O.DIFERIDA, O.CUOTAS_DIFERIDAS, F.CUENTA_RECAUDO, NVL(D.VALOR_BASE, 0) BASEIMPONIBLE FROM SF_TIPO_COBRO T INNER JOIN SF_FACTURA F INNER JOIN SF_DETALLE_FACTURA D ON F.COMPANIA = D.COMPANIA AND F.TIPO_FACTURA = D.TIPO_FACTURA AND F.NUMERO_FACTURA = D.FACTURA AND F.TIPOCOBRO = D.TIPOCOBRO ON ( T.ANO = D.ANO ) AND T.COMPANIA = F.COMPANIA AND T.CODIGO = F.TIPOCOBRO INNER JOIN SF_CONCEPTOS C ON D.COMPANIA = C.COMPANIA AND D.ANO = C.ANO AND D.TIPOCOBRO = C.TIPOCOBRO AND D.CONCEPTO = C.CODIGO INNER JOIN SF_OBJETO_COBRO O ON F.COMPANIA = O.COMPANIA AND F.TIPOCOBRO = O.TIPOCOBRO AND F.CODIGO_COBRO = O.CODIGO_COBRO INNER JOIN TERCERO TER ON F.COMPANIA = TER.COMPANIA AND F.TERCERO = TER.NIT AND F.SUCURSAL = TER.SUCURSAL INNER JOIN COMPROBANTE_CNT CPTE ON ( CPTE.COMPANIA = O.COMPANIA AND CPTE.TIPO = O.TIPOCOBRO AND CPTE.NUMERO = CASE WHEN PCK_SYSMAN_UTL.FC_PAR(F.COMPANIA,'SF NRO FACTURA MANUAL COMO NRO COMPROBANTE',-1,SYSDATE)='SI' THEN O.NRO_FACTURA ELSE O.CODIGO_COBRO END ) WHERE F.COMPANIA = :COMPANIA AND TO_DATE(TO_CHAR(F.FECHA_EXPEDICION, 'DD/MM/YYYY'), 'DD/MM/YYYY') BETWEEN TO_DATE(:FECHAINICIAL, 'DD/MM/YYYY') AND TO_DATE(:FECHAFINAL, 'DD/MM/YYYY') AND O.IMPRESO NOT IN ( 0 ) AND F.NUMERO_FACTURA = :NUMEROFACTURA AND O.TIPOCOBRO = :TIPOCOBRO ORDER BY F.NUMERO_FACTURA ) FACT_SYSMAN WHERE CARGO_FE IN ( 0 ) AND DESCUENTOS_FE IN ( 0 ) AND APLICADESCUENTO IN ( 0 )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUBTOTALFACTURA":"$SUBTOTALFACTURA","IVA":"$IVA","PORCENTAJEIVAX":"$PORCENTAJEIVAX(type:integer)","RETE":"$RETE","ICA":"$ICA","RETE_IVA":"$RETE_IVA","RETE_ICA":"$RETE_ICA","INC":"$INC","DESCUENTOPARCIAL":"$DESCUENTOPARCIAL","DESCUENTO_FACTURA":"$DESCUENTO_FACTURA","TOTAL":"$TOTAL","BASEGRAVABLEIVA":"$BASEGRAVABLEIVA","BASEGRAVABLERETE":"$BASEGRAVABLERETE","BASEGRAVABLEICA":"$BASEGRAVABLEICA","BASEGRAVABLERETEIVA":"$BASEGRAVABLERETEIVA","BASEGRAVABLERETEICA":"$BASEGRAVABLERETEICA","BASEGRAVABLEINC":"$BASEGRAVABLEINC","BASEIMPONIBLE":"$BASEIMPONIBLE","PORCENTAJERETEFUENTEX":"$PORCENTAJERETEFUENTEX(type:integer)","PORCENTAJERETEIVADX":"$PORCENTAJERETEIVADX(type:integer)","PORCENTAJERETEICAX":"$PORCENTAJERETEICAX(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
