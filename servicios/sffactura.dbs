	<query id="getSffacturaFact_sysmanimpuestosretefuenteclasQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(fact_sysman.baseimpuestoretefuente) sumadebaseimpuestoretefuente, fact_sysman.porcentajeretefuente porcentaje, SUM(fact_sysman.valor_retefuente) sumadevalor_retefuente FROM ( SELECT f.created_by, f.tercero numtercero, f.fecha_expedicion fechafactura, f.numero_factura numerofactura, f.tipo_mediopago mediopago, t.ref_facturacion prefijo, c.codequiv_dian codigoproducto, d.cantidad, c.nombre descripcionproducto, d.valor_unitario valorunitario, d.valor_neto totalitem, d.valor_base subtotal, c.porcentajeiva porcentajeivax, d.valor_iva valorimpuesto, c.PORCENTAJERETEFUENTE porcentajeretefuente, d.valor_retefuente, c.porcentajeica porcentajeicax, d.valor_ica, c.porcentajereteiva porcentajereteivadx, d.reteiva, 0 porcentajereteicax, d.reteica, c.porcentajeinc porcentajeincx, d.impuesto_inc, f.descuentofactura, d.valor_descuento, f.observaciones, f.tipo_pago, t.tipo_moneda, d.descuento, c.porcentajedescuento, ter.telefonos, f.fecha_vencimiento, pck_sysman_utl.fc_nombrecuenta(f.compania, d.ano, f.cuenta_recaudo) cuenta, CASE WHEN d.valor_iva &gt; 0 THEN nvl(d.valor_base, 0) - nvl(d.valor_descuento, 0) ELSE 0 END baseimpuestoiva, CASE WHEN d.valor_retefuente &gt; 0 THEN nvl(d.valor_base, 0) - nvl(d.valor_descuento, 0) ELSE 0 END baseimpuestoretefuente, CASE WHEN d.valor_ica &gt; 0 THEN nvl(d.valor_base, 0) - nvl(d.valor_descuento, 0) ELSE 0 END baseimpuestoica, CASE WHEN d.reteiva &gt; 0 THEN nvl(d.valor_base, 0) - nvl(d.valor_descuento, 0) ELSE 0 END baseimpuestoreteiva, CASE WHEN d.impuesto_inc &gt; 0 THEN nvl(d.valor_base, 0) - nvl(d.valor_descuento, 0) ELSE 0 END baseimpuestoinc, CASE WHEN d.reteica &gt; 0 THEN nvl(d.valor_base, 0) - nvl(d.valor_descuento, 0) ELSE 0 END baseimpuestoreteica, t.tipofacdian, o.tipocobro, c.descuento aplicadescuento, c.cargo_fe, c.descuentos_fe, o.diferida, o.cuotas_diferidas, f.cuenta_recaudo FROM sf_tipo_cobro t INNER JOIN sf_factura f INNER JOIN sf_detalle_factura d ON f.compania = d.compania AND f.tipo_factura = d.tipo_factura AND f.numero_factura = d.factura AND f.tipocobro = d.tipocobro ON ( t.ano = d.ano ) AND t.compania = f.compania AND t.codigo = f.tipocobro INNER JOIN sf_conceptos c ON d.compania = c.compania AND d.ano = c.ano AND d.tipocobro = c.tipocobro AND d.concepto = c.codigo INNER JOIN sf_objeto_cobro o ON f.compania = o.compania AND f.tipocobro = o.tipocobro AND f.codigo_cobro = o.codigo_cobro INNER JOIN tercero ter ON f.compania = ter.compania AND f.tercero = ter.nit AND f.sucursal = ter.sucursal WHERE f.compania = :compania AND f.fecha_expedicion BETWEEN :fechainicial AND :fechafinal AND o.impreso NOT IN ( 0 ) AND f.numero_factura = :numerofactura AND o.tipocobro = :tipocobro ORDER BY f.numero_factura ) fact_sysman WHERE fact_sysman.porcentajeretefuente &lt;&gt; 0 GROUP BY fact_sysman.porcentajeretefuente</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMADEBASEIMPUESTORETEFUENTE":"$SUMADEBASEIMPUESTORETEFUENTE(type:integer)","PORCENTAJE":"$PORCENTAJE","SUMADEVALOR_RETEFUENTE":"$SUMADEVALOR_RETEFUENTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMEROFACTURA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>

	</query>
