			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="ANOCOBRO" query-param="ANOCOBRO"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSffacturaPagPorTipoSinFechaDePagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.VALOR_TOTAL, SF_FACTURA.TERCERO, SF_FACTURA.SUCURSAL, TERCERO.NOMBRE, SF_FACTURA.OBSERVACIONES, SF_FACTURA.CUENTA_RECAUDO  FROM SF_FACTURA INNER JOIN TERCERO ON SF_FACTURA.COMPANIA = TERCERO.COMPANIA AND SF_FACTURA.TERCERO = TERCERO.NIT AND SF_FACTURA.SUCURSAL = TERCERO.SUCURSAL WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPO_FACTURA = :TIPO_FACTURA AND SF_FACTURA.FECHA_PAGO IS NOT NULL ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","VALOR_TOTAL":"$VALOR_TOTAL","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","NOMBRE":"$NOMBRE","OBSERVACIONES":"$OBSERVACIONES","CUENTA_RECAUDO":"$CUENTA_RECAUDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_FACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sffactura/portiposinfechadepago/pag">
		<call-query href="getSffacturaPagPorTipoSinFechaDePagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_FACTURA" query-param="TIPO_FACTURA"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSffacturaNumPorTipoSinFechaDePagoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.VALOR_TOTAL, SF_FACTURA.TERCERO, SF_FACTURA.SUCURSAL, TERCERO.NOMBRE, SF_FACTURA.OBSERVACIONES, SF_FACTURA.CUENTA_RECAUDO  FROM SF_FACTURA INNER JOIN TERCERO ON SF_FACTURA.COMPANIA = TERCERO.COMPANIA AND SF_FACTURA.TERCERO = TERCERO.NIT AND SF_FACTURA.SUCURSAL = TERCERO.SUCURSAL WHERE SF_FACTURA.COMPANIA = :COMPANIA AND SF_FACTURA.TIPO_FACTURA = :TIPO_FACTURA AND SF_FACTURA.FECHA_PAGO IS NOT NULL ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_FACTURA" sqlType="STRING"/>
		<param name="NUMERO_FACTURA" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sffactura/portiposinfechadepago/num">
		<call-query href="getSffacturaNumPorTipoSinFechaDePagoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_FACTURA" query-param="TIPO_FACTURA"/>
			<with-param name="NUMERO_FACTURA" query-param="NUMERO_FACTURA"/>
			<with-param name="VALOR_TOTAL" query-param="VALOR_TOTAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>

		</call-query>
	</resource>
	<query id="getSffacturaPagTodospornumerofacturaterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_FACTURA.NUMERO_FACTURA, SF_FACTURA.TIPO_FACTURA, SF_FACTURA.TERCERO, SF_FACTURA.SUCURSAL, SF_FACTURA.CENTRO_COSTO, SF_FACTURA.AUXILIAR, SF_FACTURA.VALOR_TOTAL,(CASE SF_FACTURA.DIFERIDA WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDA, SF_FACTURA.TIPO_ABONO, SF_FACTURA.NRO_ABONO, SF_OBJETO_COBRO.TASA_INTERES, SF_OBJETO_COBRO.VLR_EFECTIVO, SF_OBJETO_COBRO.VLR_CREDITO, SF_OBJETO_COBRO.CUOTAS_DIFERIDAS, SF_OBJETO_COBRO.VLR_PROM_CUOTA,(TO_CHAR(SF_FACTURA.FECHA_EXPEDICION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION, SF_FACTURA.OBSERVACIONES  FROM SF_FACTURA INNER JOIN SF_OBJETO_COBRO ON SF_FACTURA.COMPANIA = SF_OBJETO_COBRO.COMPANIA AND SF_FACTURA.TIPOCOBRO = SF_OBJETO_COBRO.TIPOCOBRO AND SF_FACTURA.ANO = SF_OBJETO_COBRO.ANO AND SF_FACTURA.CODIGO_COBRO = SF_OBJETO_COBRO.CODIGO_COBRO WHERE SF_FACTURA.COMPANIA = :COMPANIA AND TIPO_FACTURA = :TIPOFACTURA AND FECHA_PAGO IS NULL AND IND_ACUERDO IN (0) AND SF_OBJETO_COBRO.INDPAGO IN (0) AND SF_FACTURA.ANO =:ANOCOBRO ORDER BY SF_FACTURA.NUMERO_FACTURA DESC) WHERE (CASE WHEN NUMERO_FACTURA IS NULL THEN ' ' ELSE UPPER(NUMERO_FACTURA) END)  LIKE UPPER(:NUMERO_FACTURA || '%')  AND (CASE WHEN TIPO_FACTURA IS NULL THEN ' ' ELSE UPPER(TIPO_FACTURA) END)  LIKE UPPER(:TIPO_FACTURA || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN DIFERIDA IS NULL THEN ' ' ELSE UPPER(DIFERIDA) END)  LIKE UPPER(:DIFERIDA || '%')  AND (CASE WHEN TIPO_ABONO IS NULL THEN ' ' ELSE UPPER(TIPO_ABONO) END)  LIKE UPPER(:TIPO_ABONO || '%')  AND (CASE WHEN NRO_ABONO IS NULL THEN ' ' ELSE UPPER(NRO_ABONO) END)  LIKE UPPER(:NRO_ABONO || '%')  AND (CASE WHEN TASA_INTERES IS NULL THEN ' ' ELSE UPPER(TASA_INTERES) END)  LIKE UPPER(:TASA_INTERES || '%')  AND (CASE WHEN VLR_EFECTIVO IS NULL THEN ' ' ELSE UPPER(VLR_EFECTIVO) END)  LIKE UPPER(:VLR_EFECTIVO || '%')  AND (CASE WHEN VLR_CREDITO IS NULL THEN ' ' ELSE UPPER(VLR_CREDITO) END)  LIKE UPPER(:VLR_CREDITO || '%')  AND (CASE WHEN CUOTAS_DIFERIDAS IS NULL THEN ' ' ELSE UPPER(CUOTAS_DIFERIDAS) END)  LIKE UPPER(:CUOTAS_DIFERIDAS || '%')  AND (CASE WHEN VLR_PROM_CUOTA IS NULL THEN ' ' ELSE UPPER(VLR_PROM_CUOTA) END)  LIKE UPPER(:VLR_PROM_CUOTA || '%')  AND (CASE WHEN FECHA_EXPEDICION IS NULL THEN ' ' ELSE UPPER(FECHA_EXPEDICION) END)  LIKE UPPER(:FECHA_EXPEDICION || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_FACTURA":"$NUMERO_FACTURA(type:long)","TIPO_FACTURA":"$TIPO_FACTURA","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VALOR_TOTAL":"$VALOR_TOTAL","DIFERIDA":"$DIFERIDA(type:boolean)","TIPO_ABONO":"$TIPO_ABONO","NRO_ABONO":"$NRO_ABONO(type:long)","TASA_INTERES":"$TASA_INTERES","VLR_EFECTIVO":"$VLR_EFECTIVO","VLR_CREDITO":"$VLR_CREDITO","CUOTAS_DIFERIDAS":"$CUOTAS_DIFERIDAS","VLR_PROM_CUOTA":"$VLR_PROM_CUOTA","FECHA_EXPEDICION":"$FECHA_EXPEDICION","OBSERVACIONES":"$OBSERVACIONES"}]}}		</result>
