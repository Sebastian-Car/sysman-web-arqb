	<query id="getComponentesactividadesNumGcomponentesactividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGOPROYECTO, COMPONENTE, TIPOCOMPONENTE, ACTIVIDAD, NOMBREACTIVIDAD, VIGENCIA, CANTIDAD, CANTIDAD_EJE, COSTOUNITARIO, COSTOTOTAL, VALORPROGRAMADO, VALOREJECUTADO, PORCEJECUTADO, VALOR_SOLICITADO_ACTIVIDAD, VALOR_DISMINUIDO, DESCRIPCION, PRIORIDAD,(CASE CONPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) CONPROGRAMACION FROM COMPONENTES_ACTIVIDADES WHERE COMPANIA = :COMPANIA AND COMPONENTE = :COMPONENTE AND CODIGOPROYECTO = :CODIGOPROYECTO AND TIPOCOMPONENTE = :TIPOCOMPONENTE) WHERE (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER(:CANTIDAD || '%')  AND (CASE WHEN CANTIDAD_EJE IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJE) END)  LIKE UPPER(:CANTIDAD_EJE || '%')  AND (CASE WHEN COSTOUNITARIO IS NULL THEN ' ' ELSE UPPER(COSTOUNITARIO) END)  LIKE UPPER(:COSTOUNITARIO || '%')  AND (CASE WHEN COSTOTOTAL IS NULL THEN ' ' ELSE UPPER(COSTOTOTAL) END)  LIKE UPPER(:COSTOTOTAL || '%')  AND (CASE WHEN VALORPROGRAMADO IS NULL THEN ' ' ELSE UPPER(VALORPROGRAMADO) END)  LIKE UPPER(:VALORPROGRAMADO || '%')  AND (CASE WHEN VALOREJECUTADO IS NULL THEN ' ' ELSE UPPER(VALOREJECUTADO) END)  LIKE UPPER(:VALOREJECUTADO || '%')  AND (CASE WHEN PORCEJECUTADO IS NULL THEN ' ' ELSE UPPER(PORCEJECUTADO) END)  LIKE UPPER(:PORCEJECUTADO || '%')  AND (CASE WHEN VALOR_SOLICITADO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(VALOR_SOLICITADO_ACTIVIDAD) END)  LIKE UPPER(:VALOR_SOLICITADO_ACTIVIDAD || '%')  AND (CASE WHEN VALOR_DISMINUIDO IS NULL THEN ' ' ELSE UPPER(VALOR_DISMINUIDO) END)  LIKE UPPER( '%' || :VALOR_DISMINUIDO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="CANTIDAD_EJE" sqlType="STRING"/>
		<param name="COSTOUNITARIO" sqlType="STRING"/>
		<param name="COSTOTOTAL" sqlType="STRING"/>
		<param name="VALORPROGRAMADO" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
		<param name="PORCEJECUTADO" sqlType="STRING"/>
		<param name="VALOR_SOLICITADO_ACTIVIDAD" sqlType="STRING"/>
		<param name="VALOR_DISMINUIDO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="componentesactividades/gcomponentesactividades/num">
		<call-query href="getComponentesactividadesNumGcomponentesactividadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
