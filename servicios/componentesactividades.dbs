	<query id="getComponentesactividadesPagActividadesporproyectoycomponenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPONENTES_ACTIVIDADES.ACTIVIDAD, NVL(COMPONENTES_ACTIVIDADES.NOMBREACTIVIDAD, BP_ACTIVIDADES.NOMBRE) NOMBRE, COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE, COMPONENTES_ACTIVIDADES.COSTOTOTAL VALORTOTAL, COMPONENTES_ACTIVIDADES.CANTIDAD  FROM COMPONENTES_ACTIVIDADES INNER JOIN BP_ACTIVIDADES ON COMPONENTES_ACTIVIDADES.COMPANIA = BP_ACTIVIDADES.COMPANIA AND COMPONENTES_ACTIVIDADES.ACTIVIDAD = BP_ACTIVIDADES.CODIGO WHERE COMPONENTES_ACTIVIDADES.COMPANIA = :COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = :PROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE = :COMPONENTE ORDER BY COMPONENTES_ACTIVIDADES.ACTIVIDAD) WHERE (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPONENTE) END)  LIKE UPPER(:TIPOCOMPONENTE || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER(:CANTIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ACTIVIDAD":"$ACTIVIDAD","NOMBRE":"$NOMBRE","TIPOCOMPONENTE":"$TIPOCOMPONENTE","VALORTOTAL":"$VALORTOTAL","CANTIDAD":"$CANTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="componentesactividades/actividadesporproyectoycomponente/pag">
