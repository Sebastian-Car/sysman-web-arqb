	<query id="insertComponentesactividades" keyColumns="COMPANIA,CODIGOPROYECTO,COMPONENTE,TIPOCOMPONENTE,ACTIVIDAD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO COMPONENTES_ACTIVIDADES (COMPANIA, CODIGOPROYECTO, COMPONENTE, TIPOCOMPONENTE, ACTIVIDAD, NOMBREACTIVIDAD, VIGENCIA, CANTIDAD, CANTIDAD_EJE, COSTOUNITARIO, COSTOTOTAL, VALORPROGRAMADO, VALOREJECUTADO, PORCEJECUTADO, VALOR_SOLICITADO_ACTIVIDAD, VALOR_DISMINUIDO, DESCRIPCION, PRIORIDAD, CONPROGRAMACION, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGOPROYECTO, :COMPONENTE, :TIPOCOMPONENTE, :ACTIVIDAD, :NOMBREACTIVIDAD, :VIGENCIA, :CANTIDAD, :CANTIDAD_EJE, :COSTOUNITARIO, :COSTOTOTAL, :VALORPROGRAMADO, :VALOREJECUTADO, :PORCEJECUTADO, :VALOR_SOLICITADO_ACTIVIDAD, :VALOR_DISMINUIDO, :DESCRIPCION, :PRIORIDAD, :CONPROGRAMACION, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOPROYECTO":"$CODIGOPROYECTO","KEY_COMPONENTE":"$COMPONENTE","KEY_TIPOCOMPONENTE":"$TIPOCOMPONENTE","KEY_ACTIVIDAD":"$ACTIVIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param defaultValue="" name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
