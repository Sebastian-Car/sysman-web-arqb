	<query id="updateComponentesactividades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE COMPONENTES_ACTIVIDADES SET NOMBREACTIVIDAD=:NOMBREACTIVIDAD, VIGENCIA=:VIGENCIA, CANTIDAD=:CANTIDAD, CANTIDAD_EJE=:CANTIDAD_EJE, COSTOUNITARIO=:COSTOUNITARIO, COSTOTOTAL=:COSTOTOTAL, VALORPROGRAMADO=:VALORPROGRAMADO, VALOREJECUTADO=:VALOREJECUTADO, PORCEJECUTADO=:PORCEJECUTADO, VALOR_SOLICITADO_ACTIVIDAD=:VALOR_SOLICITADO_ACTIVIDAD, VALOR_DISMINUIDO=:VALOR_DISMINUIDO, DESCRIPCION=:DESCRIPCION, PRIORIDAD=:PRIORIDAD, CONPROGRAMACION=:CONPROGRAMACION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE COMPONENTES_ACTIVIDADES.COMPANIA= :KEY_COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE= :KEY_COMPONENTE AND COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE AND COMPONENTES_ACTIVIDADES.ACTIVIDAD= :KEY_ACTIVIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="CANTIDAD_EJE" sqlType="STRING"/>
		<param name="COSTOUNITARIO" sqlType="STRING"/>
		<param name="COSTOTOTAL" sqlType="STRING"/>
		<param name="VALORPROGRAMADO" sqlType="STRING"/>
		<param name="VALOREJECUTADO" sqlType="STRING"/>
