	<query id="deleteComponentesactividades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM COMPONENTES_ACTIVIDADES WHERE COMPONENTES_ACTIVIDADES.COMPANIA= :KEY_COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO= :KEY_CODIGOPROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE= :KEY_COMPONENTE AND COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE AND COMPONENTES_ACTIVIDADES.ACTIVIDAD= :KEY_ACTIVIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

