<data name="sstelementosproteccion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSstelementosproteccionPagCodigoYNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SST_ELEMENTO_PROTECCION.CODIGOELEMENTO, SST_ELEMENTO_PROTECCION.NOMBRE  FROM SST_ELEMENTO_PROTECCION INNER JOIN INVENTARIO ON SST_ELEMENTO_PROTECCION.COMPANIA = INVENTARIO.COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE SST_ELEMENTO_PROTECCION.COMPANIA = :COMPANIA AND INVENTARIO.IND_SST NOT IN(0) ORDER BY SST_ELEMENTO_PROTECCION.CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstelementosproteccion/codigoynombreporcompania/pag">
		<call-query href="getSstelementosproteccionPagCodigoYNombrePorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstelementosproteccionNumCodigoYNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SST_ELEMENTO_PROTECCION.CODIGOELEMENTO, SST_ELEMENTO_PROTECCION.NOMBRE  FROM SST_ELEMENTO_PROTECCION INNER JOIN INVENTARIO ON SST_ELEMENTO_PROTECCION.COMPANIA = INVENTARIO.COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE SST_ELEMENTO_PROTECCION.COMPANIA = :COMPANIA AND INVENTARIO.IND_SST NOT IN(0) ORDER BY SST_ELEMENTO_PROTECCION.CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstelementosproteccion/codigoynombreporcompania/num">
		<call-query href="getSstelementosproteccionNumCodigoYNombrePorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSstelementosproteccionPagCodigoelementonombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SST_ELEMENTO_PROTECCION.CODIGOELEMENTO, SST_ELEMENTO_PROTECCION.NOMBRE  FROM SST_ELEMENTO_PROTECCION INNER JOIN INVENTARIO ON SST_ELEMENTO_PROTECCION.COMPANIA = INVENTARIO.COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE SST_ELEMENTO_PROTECCION.COMPANIA = :COMPANIA AND INVENTARIO.IND_SST NOT IN(0) ORDER BY SST_ELEMENTO_PROTECCION.CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstelementosproteccion/codigoelementonombre/pag">
		<call-query href="getSstelementosproteccionPagCodigoelementonombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstelementosproteccionNumCodigoelementonombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SST_ELEMENTO_PROTECCION.CODIGOELEMENTO, SST_ELEMENTO_PROTECCION.NOMBRE  FROM SST_ELEMENTO_PROTECCION INNER JOIN INVENTARIO ON SST_ELEMENTO_PROTECCION.COMPANIA = INVENTARIO.COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE SST_ELEMENTO_PROTECCION.COMPANIA = :COMPANIA AND INVENTARIO.IND_SST NOT IN(0) ORDER BY SST_ELEMENTO_PROTECCION.CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstelementosproteccion/codigoelementonombre/num">
		<call-query href="getSstelementosproteccionNumCodigoelementonombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSstelementosproteccionPagPorcodigoelementonombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SST_ELEMENTO_PROTECCION.CODIGOELEMENTO, SST_ELEMENTO_PROTECCION.NOMBRE  FROM SST_ELEMENTO_PROTECCION INNER JOIN INVENTARIO ON SST_ELEMENTO_PROTECCION.COMPANIA = INVENTARIO.COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE SST_ELEMENTO_PROTECCION.COMPANIA = :COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO &gt;= :CODIGOELEMENTOS AND INVENTARIO.IND_SST NOT IN(0) ORDER BY SST_ELEMENTO_PROTECCION.CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTOS" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstelementosproteccion/porcodigoelementonombre/pag">
		<call-query href="getSstelementosproteccionPagPorcodigoelementonombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTOS" query-param="CODIGOELEMENTOS"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstelementosproteccionNumPorcodigoelementonombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SST_ELEMENTO_PROTECCION.CODIGOELEMENTO, SST_ELEMENTO_PROTECCION.NOMBRE  FROM SST_ELEMENTO_PROTECCION INNER JOIN INVENTARIO ON SST_ELEMENTO_PROTECCION.COMPANIA = INVENTARIO.COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE SST_ELEMENTO_PROTECCION.COMPANIA = :COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO &gt;= :CODIGOELEMENTOS AND INVENTARIO.IND_SST NOT IN(0) ORDER BY SST_ELEMENTO_PROTECCION.CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTOS" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstelementosproteccion/porcodigoelementonombre/num">
		<call-query href="getSstelementosproteccionNumPorcodigoelementonombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTOS" query-param="CODIGOELEMENTOS"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertSstelementosproteccion" keyColumns="COMPANIA,CODIGOELEMENTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_ELEMENTO_PROTECCION (CODIGOELEMENTO, COMPANIA, NOMBRE, OBSERVACION, DATE_CREATED, CREATED_BY) VALUES (:CODIGOELEMENTO, :COMPANIA, :NOMBRE, :OBSERVACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOELEMENTO":"$CODIGOELEMENTO"}]}}		</result>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstelementosproteccion">
		<call-query href="insertSstelementosproteccion">
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSstelementosproteccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_ELEMENTO_PROTECCION WHERE SST_ELEMENTO_PROTECCION.COMPANIA= :KEY_COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO= :KEY_CODIGOELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sstelementosproteccion">
		<call-query href="deleteSstelementosproteccion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>

		</call-query>
	</resource>
	<query id="getSstelementosproteccionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGOELEMENTO, NOMBRE, TO_CHAR(OBSERVACION) OBSERVACION  FROM SST_ELEMENTO_PROTECCION WHERE COMPANIA=:COMPANIA ORDER BY CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRE":"$NOMBRE","OBSERVACION":"$OBSERVACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstelementosproteccion">
		<call-query href="getSstelementosproteccionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstelementosproteccionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGOELEMENTO, NOMBRE, TO_CHAR(OBSERVACION) OBSERVACION  FROM SST_ELEMENTO_PROTECCION WHERE COMPANIA=:COMPANIA ORDER BY CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstelementosproteccion/numero">
		<call-query href="getSstelementosproteccionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>

		</call-query>
	</resource>
	<query id="updateSstelementosproteccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_ELEMENTO_PROTECCION SET CODIGOELEMENTO=:CODIGOELEMENTO, NOMBRE=:NOMBRE, OBSERVACION=:OBSERVACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_ELEMENTO_PROTECCION.COMPANIA= :KEY_COMPANIA AND SST_ELEMENTO_PROTECCION.CODIGOELEMENTO= :KEY_CODIGOELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstelementosproteccion">
		<call-query href="updateSstelementosproteccion">
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>

		</call-query>
	</resource>

</data>