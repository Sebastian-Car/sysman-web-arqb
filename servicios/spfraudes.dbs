	<query id="deleteSpfraudes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_FRAUDES WHERE SP_FRAUDES.COMPANIA= :KEY_COMPANIA AND SP_FRAUDES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spfraudes">
		<call-query href="deleteSpfraudes">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSpfraudesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_FRAUDES.COMPANIA, SP_FRAUDES.CONSECUTIVO, SP_FRAUDES.CODIGORUTA, SP_USUARIO.NOMBRES, SP_USUARIO.PRIMERAPELLIDO, SP_USUARIO.SEGUNDOAPELLIDO, CASE WHEN SP_FRAUDES.ESTADO = 'A' THEN 'Abierto' WHEN SP_FRAUDES.ESTADO = 'C' THEN 'Cerrado' END ESTADO  FROM SP_FRAUDES INNER JOIN SP_USUARIO ON SP_FRAUDES.COMPANIA = SP_USUARIO.COMPANIA AND SP_FRAUDES.CICLO = SP_USUARIO.CICLO AND SP_FRAUDES.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_FRAUDES.COMPANIA = :COMPANIA AND SP_FRAUDES.CICLO = :CICLO AND SP_FRAUDES.EXTERNO IN(0)) WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN PRIMERAPELLIDO IS NULL THEN ' ' ELSE UPPER(PRIMERAPELLIDO) END)  LIKE UPPER( '%' || :PRIMERAPELLIDO || '%')  AND (CASE WHEN SEGUNDOAPELLIDO IS NULL THEN ' ' ELSE UPPER(SEGUNDOAPELLIDO) END)  LIKE UPPER( '%' || :SEGUNDOAPELLIDO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER(:ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","CODIGORUTA":"$CODIGORUTA","NOMBRES":"$NOMBRES","PRIMERAPELLIDO":"$PRIMERAPELLIDO","SEGUNDOAPELLIDO":"$SEGUNDOAPELLIDO","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="PRIMERAPELLIDO" sqlType="STRING"/>
		<param name="SEGUNDOAPELLIDO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spfraudes">
		<call-query href="getSpfraudesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="PRIMERAPELLIDO" query-param="PRIMERAPELLIDO"/>
			<with-param name="SEGUNDOAPELLIDO" query-param="SEGUNDOAPELLIDO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpfraudesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_FRAUDES.COMPANIA, SP_FRAUDES.CONSECUTIVO, SP_FRAUDES.CODIGORUTA, SP_USUARIO.NOMBRES, SP_USUARIO.PRIMERAPELLIDO, SP_USUARIO.SEGUNDOAPELLIDO, CASE WHEN SP_FRAUDES.ESTADO = 'A' THEN 'Abierto' WHEN SP_FRAUDES.ESTADO = 'C' THEN 'Cerrado' END ESTADO  FROM SP_FRAUDES INNER JOIN SP_USUARIO ON SP_FRAUDES.COMPANIA = SP_USUARIO.COMPANIA AND SP_FRAUDES.CICLO = SP_USUARIO.CICLO AND SP_FRAUDES.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_FRAUDES.COMPANIA = :COMPANIA AND SP_FRAUDES.CICLO = :CICLO AND SP_FRAUDES.EXTERNO IN(0)) WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN PRIMERAPELLIDO IS NULL THEN ' ' ELSE UPPER(PRIMERAPELLIDO) END)  LIKE UPPER( '%' || :PRIMERAPELLIDO || '%')  AND (CASE WHEN SEGUNDOAPELLIDO IS NULL THEN ' ' ELSE UPPER(SEGUNDOAPELLIDO) END)  LIKE UPPER( '%' || :SEGUNDOAPELLIDO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="PRIMERAPELLIDO" sqlType="STRING"/>
		<param name="SEGUNDOAPELLIDO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfraudes/numero">
		<call-query href="getSpfraudesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="PRIMERAPELLIDO" query-param="PRIMERAPELLIDO"/>
			<with-param name="SEGUNDOAPELLIDO" query-param="SEGUNDOAPELLIDO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getSpfraudesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_FRAUDES.COMPANIA, SP_FRAUDES.CONSECUTIVO, SP_FRAUDES.CODIGORUTA, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) NOMBRERUTA , SP_FRAUDES.ESTADO, SP_FRAUDES.CICLO, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_USUARIO.COMPANIA,SP_FRAUDES.ANO,SP_FRAUDES.PERIODO,NULL) AS PER, SP_FRAUDES.ANO, SP_FRAUDES.PERIODO, SP_FRAUDES.TIPO, SP_FRAUDES.ANOCOBRO, SP_FRAUDES.PERIODOCOBRO, SP_FRAUDES.VALORACOBRAR, SP_FRAUDES.CUOTASDECOBRO, SP_FRAUDES.DECISION, SP_USUARIO.ANO ANOCIERREP, SP_USUARIO.PERIODO PERIODOCIERREP, CASE WHEN SP_FRAUDES.ANOCIERRE IS NULL THEN ' ' ELSE PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_USUARIO.COMPANIA,SP_FRAUDES.ANOCIERRE,SP_FRAUDES.PERIODOCIERRE,NULL) END PERCIERRE, SP_FRAUDES.PERIODOCIERRE, SP_FRAUDES.METROSCOBRAR,(CASE SP_FRAUDES.EXTERNO WHEN 0 THEN 'false' ELSE 'true' END) EXTERNO,(TO_CHAR(SP_FRAUDES.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(SP_FRAUDES.FECHACIERRE,'DD/MM/YYYY HH24:MI:SS')) FECHACIERRE,(TO_CHAR(SP_FRAUDES.FECHANOTIFICACION,'DD/MM/YYYY HH24:MI:SS')) FECHANOTIFICACION,(TO_CHAR(SP_FRAUDES.FECHAMEDIACION,'DD/MM/YYYY HH24:MI:SS')) FECHAMEDIACION,(TO_CHAR(SP_FRAUDES.FECHAINSPECCION,'DD/MM/YYYY HH24:MI:SS')) FECHAINSPECCION, SP_FRAUDES.MODIFIED_BY,(TO_CHAR(SP_FRAUDES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_FRAUDES.CREATED_BY,(TO_CHAR(SP_FRAUDES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_FRAUDES INNER JOIN SP_USUARIO ON SP_FRAUDES.COMPANIA = SP_USUARIO.COMPANIA AND SP_FRAUDES.CICLO = SP_USUARIO.CICLO AND SP_FRAUDES.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_FRAUDES.COMPANIA= :KEY_COMPANIA AND SP_FRAUDES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO","CODIGORUTA":"$CODIGORUTA","NOMBRERUTA":"$NOMBRERUTA","ESTADO":"$ESTADO","CICLO":"$CICLO(type:integer)","PER":"$PER","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","TIPO":"$TIPO","ANOCOBRO":"$ANOCOBRO(type:integer)","PERIODOCOBRO":"$PERIODOCOBRO","VALORACOBRAR":"$VALORACOBRAR","CUOTASDECOBRO":"$CUOTASDECOBRO","DECISION":"$DECISION","ANOCIERREP":"$ANOCIERREP(type:integer)","PERIODOCIERREP":"$PERIODOCIERREP","PERCIERRE":"$PERCIERRE","PERIODOCIERRE":"$PERIODOCIERRE","METROSCOBRAR":"$METROSCOBRAR(type:integer)","EXTERNO":"$EXTERNO(type:boolean)","FECHA":"$FECHA","FECHACIERRE":"$FECHACIERRE","FECHANOTIFICACION":"$FECHANOTIFICACION","FECHAMEDIACION":"$FECHAMEDIACION","FECHAINSPECCION":"$FECHAINSPECCION","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfraudes/data">
		<call-query href="getSpfraudesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateSpfraudes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_FRAUDES SET CODIGORUTA=:CODIGORUTA, ESTADO=:ESTADO, CICLO=:CICLO, ANO=:ANO, PERIODO=:PERIODO, TIPO=:TIPO, ANOCOBRO=:ANOCOBRO, PERIODOCOBRO=:PERIODOCOBRO, VALORACOBRAR=:VALORACOBRAR, CUOTASDECOBRO=:CUOTASDECOBRO, DECISION=:DECISION, PERIODOCIERRE=:PERIODOCIERRE, METROSCOBRAR=:METROSCOBRAR, EXTERNO=:EXTERNO, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), FECHACIERRE=TO_DATE(:FECHACIERRE,'DD/MM/YYYY HH24:MI:SS'), FECHANOTIFICACION=TO_DATE(:FECHANOTIFICACION,'DD/MM/YYYY HH24:MI:SS'), FECHAMEDIACION=TO_DATE(:FECHAMEDIACION,'DD/MM/YYYY HH24:MI:SS'), FECHAINSPECCION=TO_DATE(:FECHAINSPECCION,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_FRAUDES.COMPANIA= :KEY_COMPANIA AND SP_FRAUDES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="PERIODOCOBRO" sqlType="STRING"/>
		<param name="VALORACOBRAR" sqlType="STRING"/>
		<param name="CUOTASDECOBRO" sqlType="STRING"/>
		<param name="DECISION" sqlType="STRING"/>
		<param name="PERIODOCIERRE" sqlType="STRING"/>
		<param name="METROSCOBRAR" sqlType="STRING"/>
		<param name="EXTERNO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="FECHACIERRE" sqlType="STRING"/>
		<param name="FECHANOTIFICACION" sqlType="STRING"/>
		<param name="FECHAMEDIACION" sqlType="STRING"/>
		<param name="FECHAINSPECCION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spfraudes">
		<call-query href="updateSpfraudes">
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANOCOBRO" query-param="ANOCOBRO"/>
			<with-param name="PERIODOCOBRO" query-param="PERIODOCOBRO"/>
			<with-param name="VALORACOBRAR" query-param="VALORACOBRAR"/>
			<with-param name="CUOTASDECOBRO" query-param="CUOTASDECOBRO"/>
			<with-param name="DECISION" query-param="DECISION"/>
			<with-param name="PERIODOCIERRE" query-param="PERIODOCIERRE"/>
			<with-param name="METROSCOBRAR" query-param="METROSCOBRAR"/>
			<with-param name="EXTERNO" query-param="EXTERNO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="FECHACIERRE" query-param="FECHACIERRE"/>
			<with-param name="FECHANOTIFICACION" query-param="FECHANOTIFICACION"/>
			<with-param name="FECHAMEDIACION" query-param="FECHAMEDIACION"/>
			<with-param name="FECHAINSPECCION" query-param="FECHAINSPECCION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
