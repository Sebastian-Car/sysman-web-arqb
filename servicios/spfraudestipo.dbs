<data name="spfraudestipo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpfraudestipoTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_FRAUDES_TIPO.CONSECUTIVO, SP_FRAUDES_TIPO.NOMBRE  FROM SP_FRAUDES_TIPO WHERE SP_FRAUDES_TIPO.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfraudestipo/todosporcompania">
		<call-query href="getSpfraudestipoTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>