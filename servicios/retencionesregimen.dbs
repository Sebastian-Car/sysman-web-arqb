<data name="retencionesregimen" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getRetencionesregimenPagTipoconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CONCAT(TIPORETENCION.NOMBRE,CONCAT(' - ',RETENCIONCONCEPTO.NOMBRE) ) NOMBRERETE, RETENCIONES_REGIMEN.TIPO, RETENCIONES_REGIMEN.RETENCIONCONCEPTO, RETENCIONES.CUENTA_CREDITO , CTAS.NOMBRE NOMBRECTA, CTAS.NATURALEZA, CTAS.CUENTA_PPTAL, CTAS.NOMBREPPTAL FROM RETENCIONES_REGIMEN INNER JOIN RETENCIONCONCEPTO ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONCONCEPTO.COMPANIA AND RETENCIONES_REGIMEN.RETENCIONCONCEPTO = RETENCIONCONCEPTO.CODIGO INNER JOIN TIPORETENCION ON RETENCIONES_REGIMEN.TIPO = TIPORETENCION.CODIGO LEFT JOIN RETENCIONES ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONES.COMPANIA AND RETENCIONES_REGIMEN.TIPO = RETENCIONES.TIPO AND RETENCIONES_REGIMEN.ANO = RETENCIONES.ANO AND RETENCIONES_REGIMEN.CODIGO = RETENCIONES.CODIGO LEFT JOIN ( SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.NATURALEZA, PLAN_CONTABLE.CUENTA_PPTAL, PLAN_PRESUPUESTAL.NOMBRE NOMBREPPTAL FROM PLAN_CONTABLE LEFT JOIN PLAN_PRESUPUESTAL ON PLAN_CONTABLE.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PLAN_CONTABLE.ANO = PLAN_PRESUPUESTAL.ANO AND PLAN_CONTABLE.CUENTA_PPTAL = PLAN_PRESUPUESTAL.CODIGO WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND (PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0))) CTAS ON RETENCIONES.COMPANIA = CTAS.COMPANIA AND RETENCIONES.ANO = CTAS.ANO AND RETENCIONES.CUENTA_CREDITO = CTAS.CODIGO WHERE RETENCIONES_REGIMEN.COMPANIA =:COMPANIA AND RETENCIONES_REGIMEN.ANO = :ANO) INI WHERE (CASE WHEN NOMBRERETE IS NULL THEN ' ' ELSE UPPER(NOMBRERETE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRERETE), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN RETENCIONCONCEPTO IS NULL THEN ' ' ELSE UPPER(RETENCIONCONCEPTO) END) LIKE UPPER(CONCAT(:RETENCIONCONCEPTO, '%')) AND (CASE WHEN CUENTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CUENTA_CREDITO) END) LIKE UPPER(CONCAT(:CUENTA_CREDITO, '%')) AND (CASE WHEN NOMBRECTA IS NULL THEN ' ' ELSE UPPER(NOMBRECTA) END) LIKE UPPER(CONCAT(:NOMBRECTA, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) AND (CASE WHEN CUENTA_PPTAL IS NULL THEN ' ' ELSE UPPER(CUENTA_PPTAL) END) LIKE UPPER(CONCAT(:CUENTA_PPTAL, '%')) AND (CASE WHEN NOMBREPPTAL IS NULL THEN ' ' ELSE UPPER(NOMBREPPTAL) END) LIKE UPPER(CONCAT(:NOMBREPPTAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRERETE":"$NOMBRERETE","TIPO":"$TIPO","RETENCIONCONCEPTO":"$RETENCIONCONCEPTO","CUENTA_CREDITO":"$CUENTA_CREDITO","NOMBRECTA":"$NOMBRECTA","NATURALEZA":"$NATURALEZA","CUENTA_PPTAL":"$CUENTA_PPTAL","NOMBREPPTAL":"$NOMBREPPTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRERETE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="RETENCIONCONCEPTO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="NOMBRECTA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CUENTA_PPTAL" sqlType="STRING"/>
		<param name="NOMBREPPTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="retencionesregimen/tipoconcepto/pag">
		<call-query href="getRetencionesregimenPagTipoconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRERETE" query-param="NOMBRERETE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="RETENCIONCONCEPTO" query-param="RETENCIONCONCEPTO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="NOMBRECTA" query-param="NOMBRECTA"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="CUENTA_PPTAL" query-param="CUENTA_PPTAL"/>
			<with-param name="NOMBREPPTAL" query-param="NOMBREPPTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRetencionesregimenNumTipoconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT CONCAT(TIPORETENCION.NOMBRE,CONCAT(' - ',RETENCIONCONCEPTO.NOMBRE) ) NOMBRERETE, RETENCIONES_REGIMEN.TIPO, RETENCIONES_REGIMEN.RETENCIONCONCEPTO, RETENCIONES.CUENTA_CREDITO , CTAS.NOMBRE NOMBRECTA, CTAS.NATURALEZA, CTAS.CUENTA_PPTAL, CTAS.NOMBREPPTAL FROM RETENCIONES_REGIMEN INNER JOIN RETENCIONCONCEPTO ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONCONCEPTO.COMPANIA AND RETENCIONES_REGIMEN.RETENCIONCONCEPTO = RETENCIONCONCEPTO.CODIGO INNER JOIN TIPORETENCION ON RETENCIONES_REGIMEN.TIPO = TIPORETENCION.CODIGO LEFT JOIN RETENCIONES ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONES.COMPANIA AND RETENCIONES_REGIMEN.TIPO = RETENCIONES.TIPO AND RETENCIONES_REGIMEN.ANO = RETENCIONES.ANO AND RETENCIONES_REGIMEN.CODIGO = RETENCIONES.CODIGO LEFT JOIN ( SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.NATURALEZA, PLAN_CONTABLE.CUENTA_PPTAL, PLAN_PRESUPUESTAL.NOMBRE NOMBREPPTAL FROM PLAN_CONTABLE LEFT JOIN PLAN_PRESUPUESTAL ON PLAN_CONTABLE.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PLAN_CONTABLE.ANO = PLAN_PRESUPUESTAL.ANO AND PLAN_CONTABLE.CUENTA_PPTAL = PLAN_PRESUPUESTAL.CODIGO WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND (PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0))) CTAS ON RETENCIONES.COMPANIA = CTAS.COMPANIA AND RETENCIONES.ANO = CTAS.ANO AND RETENCIONES.CUENTA_CREDITO = CTAS.CODIGO WHERE RETENCIONES_REGIMEN.COMPANIA =:COMPANIA AND RETENCIONES_REGIMEN.ANO = :ANO) INI WHERE (CASE WHEN NOMBRERETE IS NULL THEN ' ' ELSE UPPER(NOMBRERETE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRERETE), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN RETENCIONCONCEPTO IS NULL THEN ' ' ELSE UPPER(RETENCIONCONCEPTO) END) LIKE UPPER(CONCAT(:RETENCIONCONCEPTO, '%')) AND (CASE WHEN CUENTA_CREDITO IS NULL THEN ' ' ELSE UPPER(CUENTA_CREDITO) END) LIKE UPPER(CONCAT(:CUENTA_CREDITO, '%')) AND (CASE WHEN NOMBRECTA IS NULL THEN ' ' ELSE UPPER(NOMBRECTA) END) LIKE UPPER(CONCAT(:NOMBRECTA, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) AND (CASE WHEN CUENTA_PPTAL IS NULL THEN ' ' ELSE UPPER(CUENTA_PPTAL) END) LIKE UPPER(CONCAT(:CUENTA_PPTAL, '%')) AND (CASE WHEN NOMBREPPTAL IS NULL THEN ' ' ELSE UPPER(NOMBREPPTAL) END) LIKE UPPER(CONCAT(:NOMBREPPTAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRERETE" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="RETENCIONCONCEPTO" sqlType="STRING"/>
		<param name="CUENTA_CREDITO" sqlType="STRING"/>
		<param name="NOMBRECTA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="CUENTA_PPTAL" sqlType="STRING"/>
		<param name="NOMBREPPTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="retencionesregimen/tipoconcepto/num">
		<call-query href="getRetencionesregimenNumTipoconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRERETE" query-param="NOMBRERETE"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="RETENCIONCONCEPTO" query-param="RETENCIONCONCEPTO"/>
			<with-param name="CUENTA_CREDITO" query-param="CUENTA_CREDITO"/>
			<with-param name="NOMBRECTA" query-param="NOMBRECTA"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="CUENTA_PPTAL" query-param="CUENTA_PPTAL"/>
			<with-param name="NOMBREPPTAL" query-param="NOMBREPPTAL"/>

		</call-query>
	</resource>
	<query id="insertRetencionesregimen" keyColumns="COMPANIA,TIPO,ANO,CODIGO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO RETENCIONES_REGIMEN (COMPANIA, TIPO, ANO, CODIGO, CONSECUTIVO, RETENCIONCONCEPTO, REGIMEN, NATURALEZA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :ANO, :CODIGO, :CONSECUTIVO, :RETENCIONCONCEPTO, :REGIMEN, :NATURALEZA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="RETENCIONCONCEPTO" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param defaultValue="" name="NATURALEZA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="retencionesregimen">
		<call-query href="insertRetencionesregimen">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="RETENCIONCONCEPTO" query-param="RETENCIONCONCEPTO"/>
			<with-param name="REGIMEN" query-param="REGIMEN"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteRetencionesregimen" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM RETENCIONES_REGIMEN WHERE RETENCIONES_REGIMEN.COMPANIA= :KEY_COMPANIA AND RETENCIONES_REGIMEN.TIPO= :KEY_TIPO AND RETENCIONES_REGIMEN.ANO= :KEY_ANO AND RETENCIONES_REGIMEN.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="retencionesregimen">
		<call-query href="deleteRetencionesregimen">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getRetencionesregimenPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT RETENCIONES_REGIMEN.COMPANIA, RETENCIONES_REGIMEN.TIPO, CONCAT(CONCAT(RETENCIONES_REGIMEN.TIPO,'-'),TIPORETENCION.NOMBRE) NOMBRETIPO, RETENCIONES_REGIMEN.ANO, RETENCIONES_REGIMEN.CONSECUTIVO, RETENCIONES_REGIMEN.CODIGO, CONCAT(CONCAT(RETENCIONES_REGIMEN.CODIGO,'-'), RETENCIONES.NOMBRE) NOMBRE, RETENCIONES_REGIMEN.REGIMEN, CONCAT(CONCAT(RETENCIONES_REGIMEN.REGIMEN, '-'),TIPOREGIMEN.NOMBRE) NOMBREREGIMEN, RETENCIONES_REGIMEN.NATURALEZA, CASE RETENCIONES_REGIMEN.NATURALEZA WHEN 'N' THEN 'Natural' WHEN 'J' THEN 'Jurídica' ELSE '' END NATURALEZAAUX, RETENCIONES_REGIMEN.RETENCIONCONCEPTO, CONCAT(CONCAT(RETENCIONES_REGIMEN.RETENCIONCONCEPTO,'-'), RETENCIONCONCEPTO.NOMBRE) NOMBRECONCEPTO FROM RETENCIONES_REGIMEN INNER JOIN RETENCIONES ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONES.COMPANIA AND RETENCIONES_REGIMEN.TIPO = RETENCIONES.TIPO AND RETENCIONES_REGIMEN.ANO = RETENCIONES.ANO AND RETENCIONES_REGIMEN.CODIGO = RETENCIONES.CODIGO INNER JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO INNER JOIN RETENCIONCONCEPTO ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONCONCEPTO.COMPANIA AND RETENCIONES_REGIMEN.RETENCIONCONCEPTO = RETENCIONCONCEPTO.CODIGO INNER JOIN TIPOREGIMEN ON RETENCIONES_REGIMEN.REGIMEN = TIPOREGIMEN.CODIGO WHERE RETENCIONES_REGIMEN.COMPANIA = :COMPANIA AND RETENCIONES_REGIMEN.ANO = :ANO ORDER BY CONCAT(CONCAT(RETENCIONES_REGIMEN.RETENCIONCONCEPTO,'-'), RETENCIONCONCEPTO.NOMBRE)) INI WHERE (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREREGIMEN IS NULL THEN ' ' ELSE UPPER(NOMBREREGIMEN) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREREGIMEN), '%')) AND (CASE WHEN NATURALEZAAUX IS NULL THEN ' ' ELSE UPPER(NATURALEZAAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NATURALEZAAUX), '%')) AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECONCEPTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NOMBRETIPO":"$NOMBRETIPO","ANO":"$ANO(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","REGIMEN":"$REGIMEN","NOMBREREGIMEN":"$NOMBREREGIMEN","NATURALEZA":"$NATURALEZA","NATURALEZAAUX":"$NATURALEZAAUX","RETENCIONCONCEPTO":"$RETENCIONCONCEPTO","NOMBRECONCEPTO":"$NOMBRECONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREREGIMEN" sqlType="STRING"/>
		<param name="NATURALEZAAUX" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="retencionesregimen">
		<call-query href="getRetencionesregimenPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREREGIMEN" query-param="NOMBREREGIMEN"/>
			<with-param name="NATURALEZAAUX" query-param="NATURALEZAAUX"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRetencionesregimenNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT RETENCIONES_REGIMEN.COMPANIA, RETENCIONES_REGIMEN.TIPO, CONCAT(CONCAT(RETENCIONES_REGIMEN.TIPO,'-'),TIPORETENCION.NOMBRE) NOMBRETIPO, RETENCIONES_REGIMEN.ANO, RETENCIONES_REGIMEN.CONSECUTIVO, RETENCIONES_REGIMEN.CODIGO, CONCAT(CONCAT(RETENCIONES_REGIMEN.CODIGO,'-'), RETENCIONES.NOMBRE) NOMBRE, RETENCIONES_REGIMEN.REGIMEN, CONCAT(CONCAT(RETENCIONES_REGIMEN.REGIMEN, '-'),TIPOREGIMEN.NOMBRE) NOMBREREGIMEN, RETENCIONES_REGIMEN.NATURALEZA, CASE RETENCIONES_REGIMEN.NATURALEZA WHEN 'N' THEN 'Natural' WHEN 'J' THEN 'Jurídica' ELSE '' END NATURALEZAAUX, RETENCIONES_REGIMEN.RETENCIONCONCEPTO, CONCAT(CONCAT(RETENCIONES_REGIMEN.RETENCIONCONCEPTO,'-'), RETENCIONCONCEPTO.NOMBRE) NOMBRECONCEPTO FROM RETENCIONES_REGIMEN INNER JOIN RETENCIONES ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONES.COMPANIA AND RETENCIONES_REGIMEN.TIPO = RETENCIONES.TIPO AND RETENCIONES_REGIMEN.ANO = RETENCIONES.ANO AND RETENCIONES_REGIMEN.CODIGO = RETENCIONES.CODIGO INNER JOIN TIPORETENCION ON RETENCIONES.TIPO = TIPORETENCION.CODIGO INNER JOIN RETENCIONCONCEPTO ON RETENCIONES_REGIMEN.COMPANIA = RETENCIONCONCEPTO.COMPANIA AND RETENCIONES_REGIMEN.RETENCIONCONCEPTO = RETENCIONCONCEPTO.CODIGO INNER JOIN TIPOREGIMEN ON RETENCIONES_REGIMEN.REGIMEN = TIPOREGIMEN.CODIGO WHERE RETENCIONES_REGIMEN.COMPANIA = :COMPANIA AND RETENCIONES_REGIMEN.ANO = :ANO ORDER BY CONCAT(CONCAT(RETENCIONES_REGIMEN.RETENCIONCONCEPTO,'-'), RETENCIONCONCEPTO.NOMBRE)) INI WHERE (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETIPO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREREGIMEN IS NULL THEN ' ' ELSE UPPER(NOMBREREGIMEN) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREREGIMEN), '%')) AND (CASE WHEN NATURALEZAAUX IS NULL THEN ' ' ELSE UPPER(NATURALEZAAUX) END) LIKE UPPER(CONCAT(CONCAT('%',:NATURALEZAAUX), '%')) AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECONCEPTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREREGIMEN" sqlType="STRING"/>
		<param name="NATURALEZAAUX" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="retencionesregimen/numero">
		<call-query href="getRetencionesregimenNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREREGIMEN" query-param="NOMBREREGIMEN"/>
			<with-param name="NATURALEZAAUX" query-param="NATURALEZAAUX"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateRetencionesregimen" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RETENCIONES_REGIMEN SET TIPO=:TIPO, CODIGO=:CODIGO, RETENCIONCONCEPTO=:RETENCIONCONCEPTO, REGIMEN=:REGIMEN, NATURALEZA=:NATURALEZA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE RETENCIONES_REGIMEN.COMPANIA= :KEY_COMPANIA AND RETENCIONES_REGIMEN.TIPO= :KEY_TIPO AND RETENCIONES_REGIMEN.ANO= :KEY_ANO AND RETENCIONES_REGIMEN.CODIGO= :KEY_CODIGO AND RETENCIONES_REGIMEN.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="RETENCIONCONCEPTO" sqlType="STRING"/>
		<param name="REGIMEN" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
