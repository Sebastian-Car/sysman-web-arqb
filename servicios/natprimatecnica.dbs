	<query id="getNatprimatecnicaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_PRIMA_TECNICA.COMPANIA, NAT_PRIMA_TECNICA.DP_NUMEDOCU, NAT_PRIMA_TECNICA.SUCURSAL, NAT_PRIMA_TECNICA.PT_CODIGOPERSONA, NAT_PRIMA_TECNICA.CONSECUTIVO, NAT_PRIMA_TECNICA.CLASEPT, NAT_PRIMA_TECNICA.PT_TIPODOCUACTO, NAT_PRIMA_TECNICA.PT_NUME,(TO_CHAR(NAT_PRIMA_TECNICA.PT_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) PT_FECHRESODECR,(TO_CHAR(NAT_PRIMA_TECNICA.PT_FECHEFEC,'DD/MM/YYYY HH24:MI:SS')) PT_FECHEFEC, NAT_PRIMA_TECNICA.PT_FACTLIQ, NAT_PRIMA_TECNICA.VALOR_PAGADO, NAT_PRIMA_TECNICA.PT_TITUUNIV, NAT_PRIMA_TECNICA.PT_CAPAESPE, NAT_PRIMA_TECNICA.PT_TITUUNIVADIC, NAT_PRIMA_TECNICA.PT_EXPERIENCIA, NAT_PRIMA_TECNICA.PT_RESIHORAACUM, NAT_PRIMA_TECNICA.PT_EXEPCIONAL, NAT_PRIMA_TECNICA.PT_CAPANOFORM  FROM NAT_PRIMA_TECNICA WHERE NAT_PRIMA_TECNICA.COMPANIA= :KEY_COMPANIA AND NAT_PRIMA_TECNICA.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_PRIMA_TECNICA.SUCURSAL= :KEY_SUCURSAL AND NAT_PRIMA_TECNICA.PT_CODIGOPERSONA= :KEY_PT_CODIGOPERSONA AND NAT_PRIMA_TECNICA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","PT_CODIGOPERSONA":"$PT_CODIGOPERSONA(type:integer)","CONSECUTIVO":"$CONSECUTIVO","CLASEPT":"$CLASEPT","PT_TIPODOCUACTO":"$PT_TIPODOCUACTO(type:integer)","PT_NUME":"$PT_NUME","PT_FECHRESODECR":"$PT_FECHRESODECR","PT_FECHEFEC":"$PT_FECHEFEC","PT_FACTLIQ":"$PT_FACTLIQ","VALOR_PAGADO":"$VALOR_PAGADO","PT_TITUUNIV":"$PT_TITUUNIV","PT_CAPAESPE":"$PT_CAPAESPE","PT_TITUUNIVADIC":"$PT_TITUUNIVADIC","PT_EXPERIENCIA":"$PT_EXPERIENCIA","PT_RESIHORAACUM":"$PT_RESIHORAACUM","PT_EXEPCIONAL":"$PT_EXEPCIONAL","PT_CAPANOFORM":"$PT_CAPANOFORM"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_PT_CODIGOPERSONA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natprimatecnica/data">
		<call-query href="getNatprimatecnicaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_PT_CODIGOPERSONA" query-param="KEY_PT_CODIGOPERSONA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateNatprimatecnica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_PRIMA_TECNICA SET CLASEPT=:CLASEPT, PT_TIPODOCUACTO=:PT_TIPODOCUACTO, PT_NUME=:PT_NUME, PT_FECHRESODECR=TO_DATE(:PT_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), PT_FECHEFEC=TO_DATE(:PT_FECHEFEC,'DD/MM/YYYY HH24:MI:SS'), PT_FACTLIQ=:PT_FACTLIQ, VALOR_PAGADO=:VALOR_PAGADO, PT_TITUUNIV=:PT_TITUUNIV, PT_CAPAESPE=:PT_CAPAESPE, PT_TITUUNIVADIC=:PT_TITUUNIVADIC, PT_EXPERIENCIA=:PT_EXPERIENCIA, PT_RESIHORAACUM=:PT_RESIHORAACUM, PT_EXEPCIONAL=:PT_EXEPCIONAL, PT_CAPANOFORM=:PT_CAPANOFORM, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_PRIMA_TECNICA.COMPANIA= :KEY_COMPANIA AND NAT_PRIMA_TECNICA.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_PRIMA_TECNICA.SUCURSAL= :KEY_SUCURSAL AND NAT_PRIMA_TECNICA.PT_CODIGOPERSONA= :KEY_PT_CODIGOPERSONA AND NAT_PRIMA_TECNICA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CLASEPT" sqlType="STRING"/>
		<param name="PT_TIPODOCUACTO" sqlType="STRING"/>
		<param name="PT_NUME" sqlType="STRING"/>
		<param name="PT_FECHRESODECR" sqlType="STRING"/>
		<param name="PT_FECHEFEC" sqlType="STRING"/>
		<param name="PT_FACTLIQ" sqlType="STRING"/>
		<param name="VALOR_PAGADO" sqlType="STRING"/>
		<param name="PT_TITUUNIV" sqlType="STRING"/>
		<param name="PT_CAPAESPE" sqlType="STRING"/>
		<param name="PT_TITUUNIVADIC" sqlType="STRING"/>
		<param name="PT_EXPERIENCIA" sqlType="STRING"/>
		<param name="PT_RESIHORAACUM" sqlType="STRING"/>
		<param name="PT_EXEPCIONAL" sqlType="STRING"/>
		<param name="PT_CAPANOFORM" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_PT_CODIGOPERSONA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natprimatecnica">
