	<query id="getNatprimatecnicaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_PRIMA_TECNICA.COMPANIA, NAT_PRIMA_TECNICA.DP_NUMEDOCU, NAT_PRIMA_TECNICA.SUCURSAL, NAT_PRIMA_TECNICA.PT_CODIGOPERSONA, NAT_PRIMA_TECNICA.CONSECUTIVO, NAT_PRIMA_TECNICA.CLASEPT, NAT_PRIMA_TECNICA.PT_TIPODOCUACTO, NAT_PRIMA_TECNICA.PT_NUME,(TO_CHAR(NAT_PRIMA_TECNICA.PT_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) PT_FECHRESODECR,(TO_CHAR(NAT_PRIMA_TECNICA.PT_FECHEFEC,'DD/MM/YYYY HH24:MI:SS')) PT_FECHEFEC, NAT_PRIMA_TECNICA.PT_FACTLIQ, NAT_PRIMA_TECNICA.VALOR_PAGADO, NAT_PRIMA_TECNICA.PT_TITUUNIV, NAT_PRIMA_TECNICA.PT_CAPAESPE, NAT_PRIMA_TECNICA.PT_TITUUNIVADIC, NAT_PRIMA_TECNICA.PT_EXPERIENCIA, NAT_PRIMA_TECNICA.PT_RESIHORAACUM, NAT_PRIMA_TECNICA.PT_EXEPCIONAL, NAT_PRIMA_TECNICA.PT_CAPANOFORM  FROM NAT_PRIMA_TECNICA ORDER BY NAT_PRIMA_TECNICA.PT_FECHRESODECR DESC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN PT_CODIGOPERSONA IS NULL THEN ' ' ELSE UPPER(PT_CODIGOPERSONA) END)  LIKE UPPER(:PT_CODIGOPERSONA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CLASEPT IS NULL THEN ' ' ELSE UPPER(CLASEPT) END)  LIKE UPPER(:CLASEPT || '%')  AND (CASE WHEN PT_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(PT_TIPODOCUACTO) END)  LIKE UPPER(:PT_TIPODOCUACTO || '%')  AND (CASE WHEN PT_NUME IS NULL THEN ' ' ELSE UPPER(PT_NUME) END)  LIKE UPPER(:PT_NUME || '%')  AND (CASE WHEN PT_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(PT_FECHRESODECR) END)  LIKE UPPER(:PT_FECHRESODECR || '%')  AND (CASE WHEN PT_FECHEFEC IS NULL THEN ' ' ELSE UPPER(PT_FECHEFEC) END)  LIKE UPPER(:PT_FECHEFEC || '%')  AND (CASE WHEN PT_FACTLIQ IS NULL THEN ' ' ELSE UPPER(PT_FACTLIQ) END)  LIKE UPPER(:PT_FACTLIQ || '%')  AND (CASE WHEN VALOR_PAGADO IS NULL THEN ' ' ELSE UPPER(VALOR_PAGADO) END)  LIKE UPPER(:VALOR_PAGADO || '%')  AND (CASE WHEN PT_TITUUNIV IS NULL THEN ' ' ELSE UPPER(PT_TITUUNIV) END)  LIKE UPPER(:PT_TITUUNIV || '%')  AND (CASE WHEN PT_CAPAESPE IS NULL THEN ' ' ELSE UPPER(PT_CAPAESPE) END)  LIKE UPPER(:PT_CAPAESPE || '%')  AND (CASE WHEN PT_TITUUNIVADIC IS NULL THEN ' ' ELSE UPPER(PT_TITUUNIVADIC) END)  LIKE UPPER(:PT_TITUUNIVADIC || '%')  AND (CASE WHEN PT_EXPERIENCIA IS NULL THEN ' ' ELSE UPPER(PT_EXPERIENCIA) END)  LIKE UPPER(:PT_EXPERIENCIA || '%')  AND (CASE WHEN PT_RESIHORAACUM IS NULL THEN ' ' ELSE UPPER(PT_RESIHORAACUM) END)  LIKE UPPER(:PT_RESIHORAACUM || '%')  AND (CASE WHEN PT_EXEPCIONAL IS NULL THEN ' ' ELSE UPPER(PT_EXEPCIONAL) END)  LIKE UPPER(:PT_EXEPCIONAL || '%')  AND (CASE WHEN PT_CAPANOFORM IS NULL THEN ' ' ELSE UPPER(PT_CAPANOFORM) END)  LIKE UPPER(:PT_CAPANOFORM || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
