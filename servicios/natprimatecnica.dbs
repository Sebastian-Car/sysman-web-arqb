<data name="natprimatecnica" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatprimatecnica" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,PT_CODIGOPERSONA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_PRIMA_TECNICA (COMPANIA, DP_NUMEDOCU, SUCURSAL, PT_CODIGOPERSONA, CONSECUTIVO, CLASEPT, PT_TIPODOCUACTO, PT_NUME, PT_FECHRESODECR, PT_FECHEFEC, PT_FACTLIQ, VALOR_PAGADO, PT_TITUUNIV, PT_CAPAESPE, PT_TITUUNIVADIC, PT_EXPERIENCIA, PT_RESIHORAACUM, PT_EXEPCIONAL, PT_CAPANOFORM, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :PT_CODIGOPERSONA, :CONSECUTIVO, :CLASEPT, :PT_TIPODOCUACTO, :PT_NUME, TO_DATE(:PT_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:PT_FECHEFEC,'DD/MM/YYYY HH24:MI:SS'), :PT_FACTLIQ, :VALOR_PAGADO, :PT_TITUUNIV, :PT_CAPAESPE, :PT_TITUUNIVADIC, :PT_EXPERIENCIA, :PT_RESIHORAACUM, :PT_EXEPCIONAL, :PT_CAPANOFORM, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_PT_CODIGOPERSONA":"$PT_CODIGOPERSONA(type:integer)","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PT_CODIGOPERSONA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="CLASEPT" sqlType="STRING"/>
		<param name="PT_TIPODOCUACTO" sqlType="STRING"/>
		<param defaultValue="" name="PT_NUME" sqlType="STRING"/>
		<param defaultValue="" name="PT_FECHRESODECR" sqlType="STRING"/>
		<param defaultValue="" name="PT_FECHEFEC" sqlType="STRING"/>
		<param defaultValue="0" name="PT_FACTLIQ" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PAGADO" sqlType="STRING"/>
		<param defaultValue="0" name="PT_TITUUNIV" sqlType="STRING"/>
		<param defaultValue="0" name="PT_CAPAESPE" sqlType="STRING"/>
		<param defaultValue="0" name="PT_TITUUNIVADIC" sqlType="STRING"/>
		<param defaultValue="0" name="PT_EXPERIENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="PT_RESIHORAACUM" sqlType="STRING"/>
		<param defaultValue="0" name="PT_EXEPCIONAL" sqlType="STRING"/>
		<param defaultValue="0" name="PT_CAPANOFORM" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natprimatecnica">
		<call-query href="insertNatprimatecnica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PT_CODIGOPERSONA" query-param="PT_CODIGOPERSONA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CLASEPT" query-param="CLASEPT"/>
			<with-param name="PT_TIPODOCUACTO" query-param="PT_TIPODOCUACTO"/>
			<with-param name="PT_NUME" query-param="PT_NUME"/>
			<with-param name="PT_FECHRESODECR" query-param="PT_FECHRESODECR"/>
			<with-param name="PT_FECHEFEC" query-param="PT_FECHEFEC"/>
			<with-param name="PT_FACTLIQ" query-param="PT_FACTLIQ"/>
			<with-param name="VALOR_PAGADO" query-param="VALOR_PAGADO"/>
			<with-param name="PT_TITUUNIV" query-param="PT_TITUUNIV"/>
			<with-param name="PT_CAPAESPE" query-param="PT_CAPAESPE"/>
			<with-param name="PT_TITUUNIVADIC" query-param="PT_TITUUNIVADIC"/>
			<with-param name="PT_EXPERIENCIA" query-param="PT_EXPERIENCIA"/>
			<with-param name="PT_RESIHORAACUM" query-param="PT_RESIHORAACUM"/>
			<with-param name="PT_EXEPCIONAL" query-param="PT_EXEPCIONAL"/>
			<with-param name="PT_CAPANOFORM" query-param="PT_CAPANOFORM"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatprimatecnica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_PRIMA_TECNICA WHERE NAT_PRIMA_TECNICA.COMPANIA= :KEY_COMPANIA AND NAT_PRIMA_TECNICA.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_PRIMA_TECNICA.SUCURSAL= :KEY_SUCURSAL AND NAT_PRIMA_TECNICA.PT_CODIGOPERSONA= :KEY_PT_CODIGOPERSONA AND NAT_PRIMA_TECNICA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_PT_CODIGOPERSONA" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natprimatecnica">
		<call-query href="deleteNatprimatecnica">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_PT_CODIGOPERSONA" query-param="KEY_PT_CODIGOPERSONA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getNatprimatecnicaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_PRIMA_TECNICA.COMPANIA, NAT_PRIMA_TECNICA.DP_NUMEDOCU, NAT_PRIMA_TECNICA.SUCURSAL, NAT_PRIMA_TECNICA.PT_CODIGOPERSONA, NAT_PRIMA_TECNICA.CONSECUTIVO, NAT_PRIMA_TECNICA.CLASEPT, NAT_PRIMA_TECNICA.PT_TIPODOCUACTO, NAT_PRIMA_TECNICA.PT_NUME,(TO_CHAR(NAT_PRIMA_TECNICA.PT_FECHRESODECR,'DD/MM/YYYY HH24:MI:SS')) PT_FECHRESODECR,(TO_CHAR(NAT_PRIMA_TECNICA.PT_FECHEFEC,'DD/MM/YYYY HH24:MI:SS')) PT_FECHEFEC, NAT_PRIMA_TECNICA.PT_FACTLIQ, NAT_PRIMA_TECNICA.VALOR_PAGADO, NAT_PRIMA_TECNICA.PT_TITUUNIV, NAT_PRIMA_TECNICA.PT_CAPAESPE, NAT_PRIMA_TECNICA.PT_TITUUNIVADIC, NAT_PRIMA_TECNICA.PT_EXPERIENCIA, NAT_PRIMA_TECNICA.PT_RESIHORAACUM, NAT_PRIMA_TECNICA.PT_EXEPCIONAL, NAT_PRIMA_TECNICA.PT_CAPANOFORM  FROM NAT_PRIMA_TECNICA ORDER BY NAT_PRIMA_TECNICA.PT_FECHRESODECR DESC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN PT_CODIGOPERSONA IS NULL THEN ' ' ELSE UPPER(PT_CODIGOPERSONA) END)  LIKE UPPER(:PT_CODIGOPERSONA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CLASEPT IS NULL THEN ' ' ELSE UPPER(CLASEPT) END)  LIKE UPPER(:CLASEPT || '%')  AND (CASE WHEN PT_TIPODOCUACTO IS NULL THEN ' ' ELSE UPPER(PT_TIPODOCUACTO) END)  LIKE UPPER(:PT_TIPODOCUACTO || '%')  AND (CASE WHEN PT_NUME IS NULL THEN ' ' ELSE UPPER(PT_NUME) END)  LIKE UPPER(:PT_NUME || '%')  AND (CASE WHEN PT_FECHRESODECR IS NULL THEN ' ' ELSE UPPER(PT_FECHRESODECR) END)  LIKE UPPER(:PT_FECHRESODECR || '%')  AND (CASE WHEN PT_FECHEFEC IS NULL THEN ' ' ELSE UPPER(PT_FECHEFEC) END)  LIKE UPPER(:PT_FECHEFEC || '%')  AND (CASE WHEN PT_FACTLIQ IS NULL THEN ' ' ELSE UPPER(PT_FACTLIQ) END)  LIKE UPPER(:PT_FACTLIQ || '%')  AND (CASE WHEN VALOR_PAGADO IS NULL THEN ' ' ELSE UPPER(VALOR_PAGADO) END)  LIKE UPPER(:VALOR_PAGADO || '%')  AND (CASE WHEN PT_TITUUNIV IS NULL THEN ' ' ELSE UPPER(PT_TITUUNIV) END)  LIKE UPPER(:PT_TITUUNIV || '%')  AND (CASE WHEN PT_CAPAESPE IS NULL THEN ' ' ELSE UPPER(PT_CAPAESPE) END)  LIKE UPPER(:PT_CAPAESPE || '%')  AND (CASE WHEN PT_TITUUNIVADIC IS NULL THEN ' ' ELSE UPPER(PT_TITUUNIVADIC) END)  LIKE UPPER(:PT_TITUUNIVADIC || '%')  AND (CASE WHEN PT_EXPERIENCIA IS NULL THEN ' ' ELSE UPPER(PT_EXPERIENCIA) END)  LIKE UPPER(:PT_EXPERIENCIA || '%')  AND (CASE WHEN PT_RESIHORAACUM IS NULL THEN ' ' ELSE UPPER(PT_RESIHORAACUM) END)  LIKE UPPER(:PT_RESIHORAACUM || '%')  AND (CASE WHEN PT_EXEPCIONAL IS NULL THEN ' ' ELSE UPPER(PT_EXEPCIONAL) END)  LIKE UPPER(:PT_EXEPCIONAL || '%')  AND (CASE WHEN PT_CAPANOFORM IS NULL THEN ' ' ELSE UPPER(PT_CAPANOFORM) END)  LIKE UPPER(:PT_CAPANOFORM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","PT_CODIGOPERSONA":"$PT_CODIGOPERSONA(type:integer)","CONSECUTIVO":"$CONSECUTIVO","CLASEPT":"$CLASEPT","PT_TIPODOCUACTO":"$PT_TIPODOCUACTO(type:integer)","PT_NUME":"$PT_NUME","PT_FECHRESODECR":"$PT_FECHRESODECR","PT_FECHEFEC":"$PT_FECHEFEC","PT_FACTLIQ":"$PT_FACTLIQ","VALOR_PAGADO":"$VALOR_PAGADO","PT_TITUUNIV":"$PT_TITUUNIV","PT_CAPAESPE":"$PT_CAPAESPE","PT_TITUUNIVADIC":"$PT_TITUUNIVADIC","PT_EXPERIENCIA":"$PT_EXPERIENCIA","PT_RESIHORAACUM":"$PT_RESIHORAACUM","PT_EXEPCIONAL":"$PT_EXEPCIONAL","PT_CAPANOFORM":"$PT_CAPANOFORM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="PT_CODIGOPERSONA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CLASEPT" sqlType="STRING"/>
		<param name="PT_TIPODOCUACTO" sqlType="STRING"/>
		<param name="PT_NUME" sqlType="STRING"/>
		<param name="PT_FECHRESODECR" sqlType="STRING"/>
		<param name="PT_FECHEFEC" sqlType="STRING"/>
		<param name="PT_FACTLIQ" sqlType="STRING"/>
		<param name="VALOR_PAGADO" sqlType="STRING"/>
		<param name="PT_TITUUNIV" sqlType="STRING"/>
		<param name="PT_CAPAESPE" sqlType="STRING"/>
		<param name="PT_TITUUNIVADIC" sqlType="STRING"/>
		<param name="PT_EXPERIENCIA" sqlType="STRING"/>
		<param name="PT_RESIHORAACUM" sqlType="STRING"/>
		<param name="PT_EXEPCIONAL" sqlType="STRING"/>
		<param name="PT_CAPANOFORM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
