<data name="sstdocumentoinscrito" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSstdocumentoinscrito" keyColumns="COMPANIA,IDEVENTO,TIPOEVENTO,NUMERO_DCTO,SUCURSAL,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_DOCUMENTO_INSCRITO (COMPANIA, IDEVENTO, TIPOEVENTO, NUMERO_DCTO, CONSECUTIVO, SUCURSAL, NOMBRE_ARCHIVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :IDEVENTO, :TIPOEVENTO, :NUMERO_DCTO, :CONSECUTIVO, :SUCURSAL, :NOMBRE_ARCHIVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDEVENTO":"$IDEVENTO","KEY_TIPOEVENTO":"$TIPOEVENTO","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstdocumentoinscrito">
		<call-query href="insertSstdocumentoinscrito">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSstdocumentoinscrito" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_DOCUMENTO_INSCRITO WHERE SST_DOCUMENTO_INSCRITO.COMPANIA= :KEY_COMPANIA AND SST_DOCUMENTO_INSCRITO.IDEVENTO= :KEY_IDEVENTO AND SST_DOCUMENTO_INSCRITO.TIPOEVENTO= :KEY_TIPOEVENTO AND SST_DOCUMENTO_INSCRITO.NUMERO_DCTO= :KEY_NUMERO_DCTO AND SST_DOCUMENTO_INSCRITO.SUCURSAL= :KEY_SUCURSAL AND SST_DOCUMENTO_INSCRITO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sstdocumentoinscrito">
		<call-query href="deleteSstdocumentoinscrito">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSstdocumentoinscritoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SST_DOCUMENTO_INSCRITO.COMPANIA, CONSECUTIVO, SST_DOCUMENTO_INSCRITO.IDEVENTO, SST_DOCUMENTO_INSCRITO.TIPOEVENTO, SST_DOCUMENTO_INSCRITO.NUMERO_DCTO, SST_DOCUMENTO_INSCRITO.SUCURSAL, SST_DOCUMENTO_INSCRITO.NOMBRE_ARCHIVO, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO FROM SST_DOCUMENTO_INSCRITO LEFT JOIN NAT_DATOS_PERSONALES ON SST_DOCUMENTO_INSCRITO.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND SST_DOCUMENTO_INSCRITO.NUMERO_DCTO = NAT_DATOS_PERSONALES.NUMERO_DCTO AND SST_DOCUMENTO_INSCRITO.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE SST_DOCUMENTO_INSCRITO.COMPANIA =:COMPANIA AND SST_DOCUMENTO_INSCRITO.IDEVENTO =:IDEVENTO AND SST_DOCUMENTO_INSCRITO.TIPOEVENTO =:TIPOEVENTO AND SST_DOCUMENTO_INSCRITO.NUMERO_DCTO =:NUMERO_DCTO AND SST_DOCUMENTO_INSCRITO.SUCURSAL =:SUCURSAL) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END) LIKE UPPER(CONCAT(:IDEVENTO, '%')) AND (CASE WHEN TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(TIPOEVENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOEVENTO), '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_DCTO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ARCHIVO), '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(:NOMBRECOMPLETO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NOMBRE_ARCHIVO":"$NOMBRE_ARCHIVO","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstdocumentoinscrito">
		<call-query href="getSstdocumentoinscritoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstdocumentoinscritoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SST_DOCUMENTO_INSCRITO.COMPANIA, CONSECUTIVO, SST_DOCUMENTO_INSCRITO.IDEVENTO, SST_DOCUMENTO_INSCRITO.TIPOEVENTO, SST_DOCUMENTO_INSCRITO.NUMERO_DCTO, SST_DOCUMENTO_INSCRITO.SUCURSAL, SST_DOCUMENTO_INSCRITO.NOMBRE_ARCHIVO, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(APELLIDO2,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO FROM SST_DOCUMENTO_INSCRITO LEFT JOIN NAT_DATOS_PERSONALES ON SST_DOCUMENTO_INSCRITO.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND SST_DOCUMENTO_INSCRITO.NUMERO_DCTO = NAT_DATOS_PERSONALES.NUMERO_DCTO AND SST_DOCUMENTO_INSCRITO.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE SST_DOCUMENTO_INSCRITO.COMPANIA =:COMPANIA AND SST_DOCUMENTO_INSCRITO.IDEVENTO =:IDEVENTO AND SST_DOCUMENTO_INSCRITO.TIPOEVENTO =:TIPOEVENTO AND SST_DOCUMENTO_INSCRITO.NUMERO_DCTO =:NUMERO_DCTO AND SST_DOCUMENTO_INSCRITO.SUCURSAL =:SUCURSAL) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN IDEVENTO IS NULL THEN ' ' ELSE UPPER(IDEVENTO) END) LIKE UPPER(CONCAT(:IDEVENTO, '%')) AND (CASE WHEN TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(TIPOEVENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOEVENTO), '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO_DCTO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ARCHIVO), '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(:NOMBRECOMPLETO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstdocumentoinscrito/numero">
		<call-query href="getSstdocumentoinscritoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>

		</call-query>
	</resource>
	<query id="updateSstdocumentoinscrito" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_DOCUMENTO_INSCRITO SET COMPANIA=:COMPANIA, IDEVENTO=:IDEVENTO, CONSECUTIVO=:CONSECUTIVO, TIPOEVENTO=:TIPOEVENTO, NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, NOMBRE_ARCHIVO=:NOMBRE_ARCHIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_DOCUMENTO_INSCRITO.COMPANIA= :KEY_COMPANIA AND SST_DOCUMENTO_INSCRITO.IDEVENTO= :KEY_IDEVENTO AND SST_DOCUMENTO_INSCRITO.TIPOEVENTO= :KEY_TIPOEVENTO AND SST_DOCUMENTO_INSCRITO.NUMERO_DCTO= :KEY_NUMERO_DCTO AND SST_DOCUMENTO_INSCRITO.SUCURSAL= :KEY_SUCURSAL AND SST_DOCUMENTO_INSCRITO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstdocumentoinscrito">
		<call-query href="updateSstdocumentoinscrito">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>