	</resource>
	<query id="getNovedadescontratosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NOVEDADCONTRATO.COMPANIA, NOVEDADCONTRATO.CLASEORDEN, NOVEDADCONTRATO.ORDENDECOMPRA, NOVEDADCONTRATO.NOVEDAD, NOVEDADCONTRATO.CLASET, NOVEDADCONTRATO.TIPOT,(TO_CHAR(NOVEDADCONTRATO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(NOVEDADCONTRATO.FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(NOVEDADCONTRATO.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(NOVEDADCONTRATO.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO, NOVEDADCONTRATO.ANO, NOVEDADCONTRATO.NUMERO, NOVEDADCONTRATO.VALORTOTAL, NOVEDADCONTRATO.OBSERVACIONES, NOVEDADCONTRATO.POREJECUCION, NOVEDADCONTRATO.VISITAIN, NOVEDADCONTRATO.RESULTADOS,(CASE NOVEDADCONTRATO.INDADICION WHEN 0 THEN 'false' ELSE 'true' END) INDADICION, NOVEDADCONTRATO.DIAS_CONTRATO, NOVEDADCONTRATO.VLR_ALQ_VEHICULO, CLASETRANSACCIONC.CLASENOVEDAD, CLASETRANSACCIONC.TIPOMODELO, CLASETRANSACCIONC.TIPOFORMATO, NOVEDADCONTRATO.VALOR_LIBERADO,(CASE NOVEDADCONTRATO.INDICADOR_CUMPLIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) INDICADOR_CUMPLIMIENTO, NOVEDADCONTRATO.TIPO_RETENCION, NOVEDADCONTRATO.APORTESTE, NOVEDADCONTRATO.CONSIDERANDOS, NOVEDADCONTRATO.ORDENADOR,(CASE NOVEDADCONTRATO.IMPRESO WHEN 0 THEN 'false' ELSE 'true' END) IMPRESO, NOVEDADCONTRATO.CALIFICACIONCONTR,(TO_CHAR(NOVEDADCONTRATO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, NOVEDADCONTRATO.CREATED_BY, NOVEDADCONTRATO.MODIFIED_BY,(TO_CHAR(NOVEDADCONTRATO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM NOVEDADCONTRATO LEFT JOIN CLASETRANSACCIONC ON NOVEDADCONTRATO.TIPOT = CLASETRANSACCIONC.TIPOT AND NOVEDADCONTRATO.CLASET = CLASETRANSACCIONC.CLASET WHERE NOVEDADCONTRATO.COMPANIA= :KEY_COMPANIA AND NOVEDADCONTRATO.CLASEORDEN= :KEY_CLASEORDEN AND NOVEDADCONTRATO.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND NOVEDADCONTRATO.NOVEDAD= :KEY_NOVEDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","NOVEDAD":"$NOVEDAD","CLASET":"$CLASET","TIPOT":"$TIPOT","FECHA":"$FECHA","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO","VALORTOTAL":"$VALORTOTAL","OBSERVACIONES":"$OBSERVACIONES","POREJECUCION":"$POREJECUCION","VISITAIN":"$VISITAIN(type:integer)","RESULTADOS":"$RESULTADOS","INDADICION":"$INDADICION(type:boolean)","DIAS_CONTRATO":"$DIAS_CONTRATO","VLR_ALQ_VEHICULO":"$VLR_ALQ_VEHICULO","CLASENOVEDAD":"$CLASENOVEDAD","TIPOMODELO":"$TIPOMODELO","TIPOFORMATO":"$TIPOFORMATO","VALOR_LIBERADO":"$VALOR_LIBERADO","INDICADOR_CUMPLIMIENTO":"$INDICADOR_CUMPLIMIENTO(type:boolean)","TIPO_RETENCION":"$TIPO_RETENCION","APORTESTE":"$APORTESTE","CONSIDERANDOS":"$CONSIDERANDOS","ORDENADOR":"$ORDENADOR","IMPRESO":"$IMPRESO(type:boolean)","CALIFICACIONCONTR":"$CALIFICACIONCONTR","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="novedadescontratos/data">
		<call-query href="getNovedadescontratosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_ORDENDECOMPRA" query-param="KEY_ORDENDECOMPRA"/>
			<with-param name="KEY_NOVEDAD" query-param="KEY_NOVEDAD"/>

		</call-query>
	</resource>
	<query id="getNovedadescontratosNumNovedadlistadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NOVEDADCONTRATO.COMPANIA, NOVEDADCONTRATO.CLASEORDEN, NOVEDADCONTRATO.ORDENDECOMPRA, NOVEDADCONTRATO.NOVEDAD, NOVEDADCONTRATO.NUMERO, ( CASE WHEN NOVEDADCONTRATO.CLASET = 'P' THEN 'PRESUPUESTO' ELSE CASE WHEN NOVEDADCONTRATO.CLASET = 'C' THEN 'CONTABILIDAD' ELSE CASE WHEN NOVEDADCONTRATO.CLASET = 'A' THEN 'ALMACEN' ELSE CASE WHEN NOVEDADCONTRATO.CLASET = 'N' THEN 'OTRO' END END END END) AS CLASET, CLASETRANSACCIONC.NOMBRE AS TIPOT, TO_CHAR(NOVEDADCONTRATO.FECHA,'DD/MM/YYYY') AS FECHA, NOVEDADCONTRATO.VALORTOTAL, NOVEDADCONTRATO.OBSERVACIONES,(CASE NOVEDADCONTRATO.INDADICION WHEN 0 THEN 'false' ELSE 'true' END) INDADICION,(CASE NOVEDADCONTRATO.INDICADOR_CUMPLIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) INDICADOR_CUMPLIMIENTO FROM NOVEDADCONTRATO LEFT JOIN CLASETRANSACCIONC ON NOVEDADCONTRATO.TIPOT = CLASETRANSACCIONC.TIPOT AND NOVEDADCONTRATO.CLASET = CLASETRANSACCIONC.CLASET WHERE NOVEDADCONTRATO.COMPANIA = :COMPANIA AND NOVEDADCONTRATO.CLASEORDEN = :CLASEORDEN AND NOVEDADCONTRATO.ORDENDECOMPRA = :ORDENDECOMPRA AND CLASETRANSACCIONC.CLASENOVEDAD = :CLASENOVEDADORD ORDER BY NOVEDADCONTRATO.COMPANIA, NOVEDADCONTRATO.CLASEORDEN, NOVEDADCONTRATO.ORDENDECOMPRA, NOVEDADCONTRATO.NOVEDAD DESC, NOVEDADCONTRATO.NUMERO) INI WHERE (CASE WHEN ORDENDECOMPRA IS NULL THEN ' ' ELSE UPPER(ORDENDECOMPRA) END) LIKE UPPER(CONCAT(:ORDENDECOMPRA, '%')) AND (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END) LIKE UPPER(CONCAT(:NOVEDAD, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASET), '%')) AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOT), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END) LIKE UPPER(CONCAT(:VALORTOTAL, '%')) AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:OBSERVACIONES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="CLASENOVEDADORD" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="novedadescontratos/novedadlistado/num">
