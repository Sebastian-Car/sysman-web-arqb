	<query id="getNovedadescontratosControlactasQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(NOVEDADCONTRATO.VALORTOTAL) VLRTOTALACTAS FROM NOVEDADCONTRATO INNER JOIN CLASETRANSACCIONC ON NOVEDADCONTRATO.TIPOT = CLASETRANSACCIONC.TIPOT AND NOVEDADCONTRATO.CLASET = CLASETRANSACCIONC.CLASET WHERE NOVEDADCONTRATO.COMPANIA = :COMPANIA AND NOVEDADCONTRATO.CLASEORDEN = :CLASEORDEN AND NOVEDADCONTRATO.ORDENDECOMPRA = :ORDENDECOMPRA AND CLASETRANSACCIONC.CLASET = 'N' AND CLASETRANSACCIONC.CLASENOVEDAD = 'A'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLRTOTALACTAS":"$VLRTOTALACTAS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="novedadescontratos/controlactas">
		<call-query href="getNovedadescontratosControlactasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>

		</call-query>
	</resource>
		<query id="getNovedadescontratosValidarexistenaciQuery"  useConfig="sysmandsunist">
		<sql>SELECT 1 AS EXISTE_ACI FROM ( SELECT 1 FROM NOVEDADCONTRATO WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA = :ORDENDECOMPRA AND TIPOT = 'ACI' ) WHERE ROWNUM = 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE_ACI":"$EXISTE_ACI(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="novedadescontratos/validarexistenaci">
		<call-query href="getNovedadescontratosValidarexistenaciQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>

		</call-query>
	</resource>

</data>