		<param name="TIPO_RETENCION" sqlType="STRING"/>
		<param name="APORTESTE" sqlType="STRING"/>
		<param name="CONSIDERANDOS" sqlType="STRING"/>
		<param name="ORDENADOR" sqlType="STRING"/>
		<param name="IMPRESO" sqlType="STRING"/>
		<param name="CALIFICACIONCONTR" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="JUSTIFICACION" sqlType="STRING"/>
		<param name="PORCAMORTIZADO" sqlType="STRING"/>
		<param name="VLRAMORTIZADO" sqlType="STRING"/>
