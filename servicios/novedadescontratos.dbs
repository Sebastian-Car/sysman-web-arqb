	<query id="insertNovedadescontratos" keyColumns="COMPANIA,CLASEORDEN,ORDENDECOMPRA,NOVEDAD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NOVEDADCONTRATO (COMPANIA, CLASEORDEN, ORDENDECOMPRA, NOVEDAD, NUMERO, CLASET, TIPOT, FECHA, VALORTOTAL, OBSERVACIONES, INDADICION, INDICADOR_CUMPLIMIENTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :ORDENDECOMPRA, :NOVEDAD, :NUMERO, :CLASET, :TIPOT, :FECHA, :VALORTOTAL, :OBSERVACIONES, :INDADICION, :INDICADOR_CUMPLIMIENTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_ORDENDECOMPRA":"$ORDENDECOMPRA","KEY_NOVEDAD":"$NOVEDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param defaultValue="0" name="ORDENDECOMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="NOVEDAD" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="CLASET" sqlType="STRING"/>
		<param defaultValue="" name="TIPOT" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="INDADICION" sqlType="STRING"/>
		<param defaultValue="0" name="INDICADOR_CUMPLIMIENTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="novedadescontratos">
		<call-query href="insertNovedadescontratos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
