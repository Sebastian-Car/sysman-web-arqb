	<query id="updateNovedadescontratosActnovedadcon" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NOVEDADCONTRATO SET CLASET=:CLASET, TIPOT=:TIPOT, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), ANO=:ANO, NUMERO=:NUMERO, VALORTOTAL=:VALORTOTAL, OBSERVACIONES=:OBSERVACIONES, POREJECUCION=:POREJECUCION, VISITAIN=:VISITAIN, RESULTADOS=:RESULTADOS, INDADICION=:INDADICION, DIAS_CONTRATO=:DIAS_CONTRATO, VLR_ALQ_VEHICULO=:VLR_ALQ_VEHICULO, VALOR_LIBERADO=:VALOR_LIBERADO, INDICADOR_CUMPLIMIENTO=:INDICADOR_CUMPLIMIENTO, TIPO_RETENCION=:TIPO_RETENCION, APORTESTE=:APORTESTE, CONSIDERANDOS=:CONSIDERANDOS, ORDENADOR=:ORDENADOR, IMPRESO=:IMPRESO, CALIFICACIONCONTR=:CALIFICACIONCONTR, MODIFIED_BY=:MODIFIED_BY, SUCURSAL=:SUCURSAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), CALIFICACION=:CALIFICACION, JUSTIFICACION=:JUSTIFICACION, PORCAMORTIZADO=:PORCAMORTIZADO, VLRAMORTIZADO=:VLRAMORTIZADO WHERE NOVEDADCONTRATO.COMPANIA= :KEY_COMPANIA AND NOVEDADCONTRATO.CLASEORDEN= :KEY_CLASEORDEN AND NOVEDADCONTRATO.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND NOVEDADCONTRATO.NOVEDAD= :KEY_NOVEDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CLASET" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
