	<query id="deleteNovedadescontratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NOVEDADCONTRATO WHERE NOVEDADCONTRATO.COMPANIA= :KEY_COMPANIA AND NOVEDADCONTRATO.CLASEORDEN= :KEY_CLASEORDEN AND NOVEDADCONTRATO.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND NOVEDADCONTRATO.NOVEDAD= :KEY_NOVEDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_NOVEDAD" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="novedadescontratos">
		<call-query href="deleteNovedadescontratos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_ORDENDECOMPRA" query-param="KEY_ORDENDECOMPRA"/>
			<with-param name="KEY_NOVEDAD" query-param="KEY_NOVEDAD"/>

		</call-query>
	</resource>
	<query id="getNovedadescontratosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BORRA_TEMPNOVEDADES.COMPANIA, BORRA_TEMPNOVEDADES.CLASEORDEN, BORRA_TEMPNOVEDADES.ORDENDECOMPRA, BORRA_TEMPNOVEDADES.NOVEDAD, BORRA_TEMPNOVEDADES.TIPOT, BORRA_TEMPNOVEDADES.NUMERO, TO_CHAR(BORRA_TEMPNOVEDADES.FECHA,'DD/MM/YYYY') FECHA, SUBSTR(BORRA_TEMPNOVEDADES.OBSERVACIONES,1,255) OBSERVACIONES, BORRA_TEMPNOVEDADES.VALORTOTAL  FROM ((SELECT TIPOORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.TIPOAFECTADO CLASEORDEN, ORDENDECOMPRA.NUMEROAFECTADO ORDENDECOMPRA, ORDENDECOMPRA.NUMERO , ORDENDECOMPRA.CONSECUTIVOADICIONES NOVEDAD, TIPOORDENDECOMPRA.CODIGO TIPOT, ORDENDECOMPRA.FECHA, ORDENDECOMPRA.OBJETOCONTRATO OBSERVACIONES, ORDENDECOMPRA.VALORTOTAL FROM TIPOORDENDECOMPRA INNER JOIN ORDENDECOMPRA ON TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA AND TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN WHERE TIPOORDENDECOMPRA.CLASE = 'M' ) UNION ALL (SELECT NOVEDADCONTRATO.COMPANIA, NOVEDADCONTRATO.CLASEORDEN, NOVEDADCONTRATO.ORDENDECOMPRA, NOVEDADCONTRATO.NUMERO, NOVEDADCONTRATO.NOVEDAD, NOVEDADCONTRATO.TIPOT, NOVEDADCONTRATO.FECHA, CASE WHEN NOVEDADCONTRATO.OBSERVACIONES &lt;&gt; '' THEN NOVEDADCONTRATO.OBSERVACIONES ELSE UPPER(TIPO_COMPROBANTE.NOMBRE) END OBSERVACIONES, NOVEDADCONTRATO.VALORTOTAL FROM NOVEDADCONTRATO LEFT JOIN TIPO_COMPROBANTE ON NOVEDADCONTRATO.TIPOT = TIPO_COMPROBANTE.CODIGO AND NOVEDADCONTRATO.COMPANIA = TIPO_COMPROBANTE.COMPANIA WHERE NOVEDADCONTRATO.TIPOT &lt;&gt; 'COM') UNION ALL (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPOCONTRATO CLASEORDEN, COMPROBANTE_CNT.NUMEROCONTRATO ORDENDECOMPRA, COMPROBANTE_CNT.NUMERO, 0 NOVEDAD, COMPROBANTE_CNT.TIPO TIPOT, COMPROBANTE_CNT.FECHA, COMPROBANTE_CNT.DESCRIPCION OBSERVACIONES, SUM(COMPROBANTE_CNT.VLR_DOCUMENTO) VALORTOTAL FROM COMPROBANTE_CNT LEFT JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO AND COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA WHERE TIPO_COMPROBANTE.CLASE_CONTABLE = 'P' AND COMPROBANTE_CNT.VLR_DOCUMENTO &gt; 0 GROUP BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPOCONTRATO, COMPROBANTE_CNT.NUMEROCONTRATO, COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.FECHA, COMPROBANTE_CNT.DESCRIPCION, 0)) BORRA_TEMPNOVEDADES WHERE BORRA_TEMPNOVEDADES.COMPANIA = :COMPANIA AND BORRA_TEMPNOVEDADES.CLASEORDEN = :CLASE AND BORRA_TEMPNOVEDADES.ORDENDECOMPRA = :NUMORDEN GROUP BY COMPANIA, CLASEORDEN, ORDENDECOMPRA, NUMERO, NOVEDAD, TIPOT, FECHA, SUBSTR(BORRA_TEMPNOVEDADES.OBSERVACIONES,1,255), VALORTOTAL ORDER BY NOVEDAD) WHERE (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END)  LIKE UPPER(:NOVEDAD || '%')  AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER( '%' || :TIPOT || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER( '%' || :VALORTOTAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA(type:double)","NOVEDAD":"$NOVEDAD(type:long)","TIPOT":"$TIPOT","NUMERO":"$NUMERO(type:long)","FECHA":"$FECHA","OBSERVACIONES":"$OBSERVACIONES","VALORTOTAL":"$VALORTOTAL(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="novedadescontratos">
		<call-query href="getNovedadescontratosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="NUMORDEN" query-param="NUMORDEN"/>
			<with-param name="NOVEDAD" query-param="NOVEDAD"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNovedadescontratosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BORRA_TEMPNOVEDADES.COMPANIA, BORRA_TEMPNOVEDADES.CLASEORDEN, BORRA_TEMPNOVEDADES.ORDENDECOMPRA, BORRA_TEMPNOVEDADES.NOVEDAD, BORRA_TEMPNOVEDADES.TIPOT, BORRA_TEMPNOVEDADES.NUMERO, TO_CHAR(BORRA_TEMPNOVEDADES.FECHA,'DD/MM/YYYY') FECHA, SUBSTR(BORRA_TEMPNOVEDADES.OBSERVACIONES,1,255) OBSERVACIONES, BORRA_TEMPNOVEDADES.VALORTOTAL  FROM ((SELECT TIPOORDENDECOMPRA.COMPANIA, ORDENDECOMPRA.TIPOAFECTADO CLASEORDEN, ORDENDECOMPRA.NUMEROAFECTADO ORDENDECOMPRA, ORDENDECOMPRA.NUMERO , ORDENDECOMPRA.CONSECUTIVOADICIONES NOVEDAD, TIPOORDENDECOMPRA.CODIGO TIPOT, ORDENDECOMPRA.FECHA, ORDENDECOMPRA.OBJETOCONTRATO OBSERVACIONES, ORDENDECOMPRA.VALORTOTAL FROM TIPOORDENDECOMPRA INNER JOIN ORDENDECOMPRA ON TIPOORDENDECOMPRA.COMPANIA = ORDENDECOMPRA.COMPANIA AND TIPOORDENDECOMPRA.CODIGO = ORDENDECOMPRA.CLASEORDEN WHERE TIPOORDENDECOMPRA.CLASE = 'M' ) UNION ALL (SELECT NOVEDADCONTRATO.COMPANIA, NOVEDADCONTRATO.CLASEORDEN, NOVEDADCONTRATO.ORDENDECOMPRA, NOVEDADCONTRATO.NUMERO, NOVEDADCONTRATO.NOVEDAD, NOVEDADCONTRATO.TIPOT, NOVEDADCONTRATO.FECHA, CASE WHEN NOVEDADCONTRATO.OBSERVACIONES &lt;&gt; '' THEN NOVEDADCONTRATO.OBSERVACIONES ELSE UPPER(TIPO_COMPROBANTE.NOMBRE) END OBSERVACIONES, NOVEDADCONTRATO.VALORTOTAL FROM NOVEDADCONTRATO LEFT JOIN TIPO_COMPROBANTE ON NOVEDADCONTRATO.TIPOT = TIPO_COMPROBANTE.CODIGO AND NOVEDADCONTRATO.COMPANIA = TIPO_COMPROBANTE.COMPANIA WHERE NOVEDADCONTRATO.TIPOT &lt;&gt; 'COM') UNION ALL (SELECT COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPOCONTRATO CLASEORDEN, COMPROBANTE_CNT.NUMEROCONTRATO ORDENDECOMPRA, COMPROBANTE_CNT.NUMERO, 0 NOVEDAD, COMPROBANTE_CNT.TIPO TIPOT, COMPROBANTE_CNT.FECHA, COMPROBANTE_CNT.DESCRIPCION OBSERVACIONES, SUM(COMPROBANTE_CNT.VLR_DOCUMENTO) VALORTOTAL FROM COMPROBANTE_CNT LEFT JOIN TIPO_COMPROBANTE ON COMPROBANTE_CNT.TIPO = TIPO_COMPROBANTE.CODIGO AND COMPROBANTE_CNT.COMPANIA = TIPO_COMPROBANTE.COMPANIA WHERE TIPO_COMPROBANTE.CLASE_CONTABLE = 'P' AND COMPROBANTE_CNT.VLR_DOCUMENTO &gt; 0 GROUP BY COMPROBANTE_CNT.COMPANIA, COMPROBANTE_CNT.TIPOCONTRATO, COMPROBANTE_CNT.NUMEROCONTRATO, COMPROBANTE_CNT.NUMERO, COMPROBANTE_CNT.TIPO, COMPROBANTE_CNT.FECHA, COMPROBANTE_CNT.DESCRIPCION, 0)) BORRA_TEMPNOVEDADES WHERE BORRA_TEMPNOVEDADES.COMPANIA = :COMPANIA AND BORRA_TEMPNOVEDADES.CLASEORDEN = :CLASE AND BORRA_TEMPNOVEDADES.ORDENDECOMPRA = :NUMORDEN GROUP BY COMPANIA, CLASEORDEN, ORDENDECOMPRA, NUMERO, NOVEDAD, TIPOT, FECHA, SUBSTR(BORRA_TEMPNOVEDADES.OBSERVACIONES,1,255), VALORTOTAL ORDER BY NOVEDAD) WHERE (CASE WHEN NOVEDAD IS NULL THEN ' ' ELSE UPPER(NOVEDAD) END)  LIKE UPPER(:NOVEDAD || '%')  AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER( '%' || :TIPOT || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER( '%' || :VALORTOTAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="NUMORDEN" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>

	</query>
