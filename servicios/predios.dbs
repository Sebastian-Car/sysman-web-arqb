		</call-query>
	</resource>
	<query id="getPrediosTodosPorCompaniaSerieplacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PREDIOS.ROWID RID, PREDIOS.ID_PREDIO, PREDIOS.SERIE_PLACA, PREDIOS.COMPANIA  FROM PREDIOS WHERE PREDIOS.COMPANIA= :COMPANIA AND PREDIOS.SERIE_PLACA= :SERIE_PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RID":"$RID","ID_PREDIO":"$ID_PREDIO","SERIE_PLACA":"$SERIE_PLACA(type:long)","COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="predios/todosporcompaniaserieplaca">
