			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>

		</call-query>
	</resource>
	<query id="updatePrediosPrecioYValor" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PREDIOS SET PRECIO_TERRENO   = :PRECIO,   VALOR_CONSTRUCCION = :VALOR,   VALOR_TOTAL        = :TOTAL,   MODIFIED_BY        = :MODIFIED_BY,    DATE_MODIFIED      = :DATE_MODIFIED WHERE COMPANIA       = :COMPANIA AND ID_PREDIO        = :PREDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PRECIO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="predios/precioyvalor">
		<call-query href="updatePrediosPrecioYValor">
			<with-param name="PRECIO" query-param="PRECIO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>

</data>