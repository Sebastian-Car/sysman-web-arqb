	<query id="getPrediosPagTodosConElementoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PREDIOS.ID_PREDIO SELECCION , PREDIOS.NOMBRE , PREDIOS.DIRECCION , PREDIOS.ESCRITURA_NO , PREDIOS.COD_PREDIAL , PREDIOS.SERIE_PLACA , DEVOLUTIVO.ELEMENTO ,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA FROM PREDIOS LEFT JOIN DEVOLUTIVO ON PREDIOS.COMPANIA = DEVOLUTIVO.COMPANIA AND PREDIOS.SERIE_PLACA = DEVOLUTIVO.SERIE WHERE PREDIOS.COMPANIA = :COMPANIA ORDER BY ID_PREDIO) WHERE (CASE WHEN SELECCION IS NULL THEN ' ' ELSE UPPER(SELECCION) END)  LIKE UPPER(:SELECCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SELECCION":"$SELECCION","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","ESCRITURA_NO":"$ESCRITURA_NO","COD_PREDIAL":"$COD_PREDIAL","SERIE_PLACA":"$SERIE_PLACA(type:long)","ELEMENTO":"$ELEMENTO","PLACAANULADA":"$PLACAANULADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SELECCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="predios/todosconelementoporcompania/pag">
		<call-query href="getPrediosPagTodosConElementoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SELECCION" query-param="SELECCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPrediosNumTodosConElementoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PREDIOS.ID_PREDIO SELECCION , PREDIOS.NOMBRE , PREDIOS.DIRECCION , PREDIOS.ESCRITURA_NO , PREDIOS.COD_PREDIAL , PREDIOS.SERIE_PLACA , DEVOLUTIVO.ELEMENTO ,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA FROM PREDIOS LEFT JOIN DEVOLUTIVO ON PREDIOS.COMPANIA = DEVOLUTIVO.COMPANIA AND PREDIOS.SERIE_PLACA = DEVOLUTIVO.SERIE WHERE PREDIOS.COMPANIA = :COMPANIA ORDER BY ID_PREDIO) WHERE (CASE WHEN SELECCION IS NULL THEN ' ' ELSE UPPER(SELECCION) END)  LIKE UPPER(:SELECCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SELECCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="predios/todosconelementoporcompania/num">
		<call-query href="getPrediosNumTodosConElementoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SELECCION" query-param="SELECCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPrediosCantPorSerieplacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM PREDIOS WHERE COMPANIA = :COMPANIA AND SERIE_PLACA = :SERIE_PLACA</sql>
