		</call-query>
	</resource>
	<query id="getPrediosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_PREDIO, NOMBRE, DIRECCION, UBICACION, DESTINACION, USO_ACTUAL, ESCRITURA_NO,(TO_CHAR(FECHA_ESCRITURA,'DD/MM/YYYY HH24:MI:SS')) FECHA_ESCRITURA, NOTARIA, PAIS, DPTO_ESCRITURA, CIUDAD_ESCRITURA, MODALIDAD, AREA_ESCRITURA, MATR_INMOVILIARIA, COD_PREDIAL, TIPO_PREDIO,(CASE ACC_PRINCIPAL WHEN 0 THEN 'false' ELSE 'true' END) ACC_PRINCIPAL,(CASE ACC_SECUNDARIA WHEN 0 THEN 'false' ELSE 'true' END) ACC_SECUNDARIA,(CASE ACC_ASFALTO WHEN 0 THEN 'false' ELSE 'true' END) ACC_ASFALTO,(CASE ACC_RIGIDO WHEN 0 THEN 'false' ELSE 'true' END) ACC_RIGIDO,(CASE ACC_ADOQUIN WHEN 0 THEN 'false' ELSE 'true' END) ACC_ADOQUIN,(CASE PREDIO_REGULAR WHEN 0 THEN 'false' ELSE 'true' END) PREDIO_REGULAR,(CASE PREDIO_IRREGULAR WHEN 0 THEN 'false' ELSE 'true' END) PREDIO_IRREGULAR,(CASE PREDIO_INCLINADO WHEN 0 THEN 'false' ELSE 'true' END) PREDIO_INCLINADO,(CASE PREDIO_PLANO WHEN 0 THEN 'false' ELSE 'true' END) PREDIO_PLANO,(CASE NECESITA_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) NECESITA_INVENTARIO, ANO_CONSTRUCCION, PRECIO_TERRENO, VALOR_CONSTRUCCION, VALOR_TOTAL, EXT_LINDEROS_FRENTE, EXT_LINDEROS_FONDO, EXT_LINDEROS_DER, EXT_LINDEROS_IZQ, DESC_LINDEROS_FRENTE, DESC_LINDEROS_FONDO, DESC_LINDEROS_DER, DESC_LINDEROS_IZQ, RESPONSABLE, SUCURSAL, ENCUESTA_VALOR, COD_FOTO, RUTA_FOTO, COD_PLANO, RUTA_PLANO,(CASE USO_PUBLICO WHEN 0 THEN 'false' ELSE 'true' END) USO_PUBLICO, OBSERVACIONES, SERIE_PLACA, COD_INVENTARIO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM PREDIOS WHERE PREDIOS.COMPANIA= :KEY_COMPANIA AND PREDIOS.ID_PREDIO= :KEY_ID_PREDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_PREDIO":"$ID_PREDIO","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","UBICACION":"$UBICACION","DESTINACION":"$DESTINACION","USO_ACTUAL":"$USO_ACTUAL","ESCRITURA_NO":"$ESCRITURA_NO","FECHA_ESCRITURA":"$FECHA_ESCRITURA","NOTARIA":"$NOTARIA","PAIS":"$PAIS","DPTO_ESCRITURA":"$DPTO_ESCRITURA","CIUDAD_ESCRITURA":"$CIUDAD_ESCRITURA","MODALIDAD":"$MODALIDAD","AREA_ESCRITURA":"$AREA_ESCRITURA","MATR_INMOVILIARIA":"$MATR_INMOVILIARIA","COD_PREDIAL":"$COD_PREDIAL","TIPO_PREDIO":"$TIPO_PREDIO","ACC_PRINCIPAL":"$ACC_PRINCIPAL(type:boolean)","ACC_SECUNDARIA":"$ACC_SECUNDARIA(type:boolean)","ACC_ASFALTO":"$ACC_ASFALTO(type:boolean)","ACC_RIGIDO":"$ACC_RIGIDO(type:boolean)","ACC_ADOQUIN":"$ACC_ADOQUIN(type:boolean)","PREDIO_REGULAR":"$PREDIO_REGULAR(type:boolean)","PREDIO_IRREGULAR":"$PREDIO_IRREGULAR(type:boolean)","PREDIO_INCLINADO":"$PREDIO_INCLINADO(type:boolean)","PREDIO_PLANO":"$PREDIO_PLANO(type:boolean)","NECESITA_INVENTARIO":"$NECESITA_INVENTARIO(type:boolean)","ANO_CONSTRUCCION":"$ANO_CONSTRUCCION(type:integer)","PRECIO_TERRENO":"$PRECIO_TERRENO","VALOR_CONSTRUCCION":"$VALOR_CONSTRUCCION","VALOR_TOTAL":"$VALOR_TOTAL","EXT_LINDEROS_FRENTE":"$EXT_LINDEROS_FRENTE","EXT_LINDEROS_FONDO":"$EXT_LINDEROS_FONDO","EXT_LINDEROS_DER":"$EXT_LINDEROS_DER","EXT_LINDEROS_IZQ":"$EXT_LINDEROS_IZQ","DESC_LINDEROS_FRENTE":"$DESC_LINDEROS_FRENTE","DESC_LINDEROS_FONDO":"$DESC_LINDEROS_FONDO","DESC_LINDEROS_DER":"$DESC_LINDEROS_DER","DESC_LINDEROS_IZQ":"$DESC_LINDEROS_IZQ","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","ENCUESTA_VALOR":"$ENCUESTA_VALOR","COD_FOTO":"$COD_FOTO","RUTA_FOTO":"$RUTA_FOTO","COD_PLANO":"$COD_PLANO","RUTA_PLANO":"$RUTA_PLANO","USO_PUBLICO":"$USO_PUBLICO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","SERIE_PLACA":"$SERIE_PLACA(type:long)","COD_INVENTARIO":"$COD_INVENTARIO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_PREDIO" sqlType="STRING"/>

	</query>
