	<query id="updatePredios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PREDIOS SET EXT_LINDEROS_FRENTE=:EXT_LINDEROS_FRENTE, ACC_ADOQUIN=:ACC_ADOQUIN, SUCURSAL=:SUCURSAL, NOTARIA=:NOTARIA, PREDIO_IRREGULAR=:PREDIO_IRREGULAR, RUTA_FOTO=:RUTA_FOTO, NECESITA_INVENTARIO=:NECESITA_INVENTARIO, FECHA_ESCRITURA=TO_DATE(:FECHA_ESCRITURA,'DD/MM/YYYY HH24:MI:SS'), ESCRITURA_NO=:ESCRITURA_NO, USO_ACTUAL=:USO_ACTUAL, MODIFIED_BY=:MODIFIED_BY, DESC_LINDEROS_FONDO=:DESC_LINDEROS_FONDO, COD_FOTO=:COD_FOTO, NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), COD_INVENTARIO=:COD_INVENTARIO, DESTINACION=:DESTINACION, DESC_LINDEROS_DER=:DESC_LINDEROS_DER, DESC_LINDEROS_FRENTE=:DESC_LINDEROS_FRENTE, MATR_INMOVILIARIA=:MATR_INMOVILIARIA, PAIS=:PAIS, EXT_LINDEROS_FONDO=:EXT_LINDEROS_FONDO, COD_PLANO=:COD_PLANO, UBICACION=:UBICACION, OBSERVACIONES=:OBSERVACIONES, ACC_RIGIDO=:ACC_RIGIDO, ACC_ASFALTO=:ACC_ASFALTO, PRECIO_TERRENO=:PRECIO_TERRENO, ACC_PRINCIPAL=:ACC_PRINCIPAL, EXT_LINDEROS_IZQ=:EXT_LINDEROS_IZQ, ENCUESTA_VALOR=:ENCUESTA_VALOR, PREDIO_PLANO=:PREDIO_PLANO, DESC_LINDEROS_IZQ=:DESC_LINDEROS_IZQ, DPTO_ESCRITURA=:DPTO_ESCRITURA, MODALIDAD=:MODALIDAD, VALOR_TOTAL=:VALOR_TOTAL, COD_PREDIAL=:COD_PREDIAL, CIUDAD_ESCRITURA=:CIUDAD_ESCRITURA, PREDIO_REGULAR=:PREDIO_REGULAR, PREDIO_INCLINADO=:PREDIO_INCLINADO, ACC_SECUNDARIA=:ACC_SECUNDARIA, VALOR_CONSTRUCCION=:VALOR_CONSTRUCCION, ANO_CONSTRUCCION=:ANO_CONSTRUCCION, DIRECCION=:DIRECCION, RESPONSABLE=:RESPONSABLE, TIPO_PREDIO=:TIPO_PREDIO, USO_PUBLICO=:USO_PUBLICO, SERIE_PLACA=:SERIE_PLACA, EXT_LINDEROS_DER=:EXT_LINDEROS_DER, AREA_ESCRITURA=:AREA_ESCRITURA, RUTA_PLANO=:RUTA_PLANO WHERE PREDIOS.COMPANIA= :KEY_COMPANIA AND PREDIOS.ID_PREDIO= :KEY_ID_PREDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="EXT_LINDEROS_FRENTE" sqlType="STRING"/>
		<param name="ACC_ADOQUIN" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOTARIA" sqlType="STRING"/>
