	<query id="deletePredios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PREDIOS WHERE PREDIOS.COMPANIA= :KEY_COMPANIA AND PREDIOS.ID_PREDIO= :KEY_ID_PREDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_PREDIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="predios">
		<call-query href="deletePredios">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_PREDIO" query-param="KEY_ID_PREDIO"/>

		</call-query>
	</resource>
	<query id="getPrediosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ID_PREDIO, NOMBRE, DIRECCION, UBICACION, COD_PREDIAL, SERIE_PLACA, COD_INVENTARIO  FROM PREDIOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_PREDIO IS NULL THEN ' ' ELSE UPPER(ID_PREDIO) END)  LIKE UPPER( '%' || :ID_PREDIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END)  LIKE UPPER(:UBICACION || '%')  AND (CASE WHEN COD_PREDIAL IS NULL THEN ' ' ELSE UPPER(COD_PREDIAL) END)  LIKE UPPER( '%' || :COD_PREDIAL || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER( '%' || :SERIE_PLACA || '%')  AND (CASE WHEN COD_INVENTARIO IS NULL THEN ' ' ELSE UPPER(COD_INVENTARIO) END)  LIKE UPPER( '%' || :COD_INVENTARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_PREDIO":"$ID_PREDIO","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","UBICACION":"$UBICACION","COD_PREDIAL":"$COD_PREDIAL","SERIE_PLACA":"$SERIE_PLACA(type:long)","COD_INVENTARIO":"$COD_INVENTARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PREDIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="COD_PREDIAL" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="COD_INVENTARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="predios">
		<call-query href="getPrediosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PREDIO" query-param="ID_PREDIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="COD_PREDIAL" query-param="COD_PREDIAL"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="COD_INVENTARIO" query-param="COD_INVENTARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPrediosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ID_PREDIO, NOMBRE, DIRECCION, UBICACION, COD_PREDIAL, SERIE_PLACA, COD_INVENTARIO  FROM PREDIOS WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_PREDIO IS NULL THEN ' ' ELSE UPPER(ID_PREDIO) END)  LIKE UPPER( '%' || :ID_PREDIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN UBICACION IS NULL THEN ' ' ELSE UPPER(UBICACION) END)  LIKE UPPER( '%' || :UBICACION || '%')  AND (CASE WHEN COD_PREDIAL IS NULL THEN ' ' ELSE UPPER(COD_PREDIAL) END)  LIKE UPPER( '%' || :COD_PREDIAL || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER( '%' || :SERIE_PLACA || '%')  AND (CASE WHEN COD_INVENTARIO IS NULL THEN ' ' ELSE UPPER(COD_INVENTARIO) END)  LIKE UPPER( '%' || :COD_INVENTARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PREDIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param name="COD_PREDIAL" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="COD_INVENTARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="predios/numero">
		<call-query href="getPrediosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PREDIO" query-param="ID_PREDIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="COD_PREDIAL" query-param="COD_PREDIAL"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
