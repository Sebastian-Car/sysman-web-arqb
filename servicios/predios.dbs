<data name="predios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPrediosPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_PREDIO, NOMBRE, DIRECCION, ESCRITURA_NO, COD_PREDIAL, COD_INVENTARIO  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY ID_PREDIO) WHERE (CASE WHEN ID_PREDIO IS NULL THEN ' ' ELSE UPPER(ID_PREDIO) END)  LIKE UPPER(:ID_PREDIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_PREDIO":"$ID_PREDIO","NOMBRE":"$NOMBRE","DIRECCION":"$DIRECCION","ESCRITURA_NO":"$ESCRITURA_NO","COD_PREDIAL":"$COD_PREDIAL","COD_INVENTARIO":"$COD_INVENTARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PREDIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="predios/todosporcompania/pag">
		<call-query href="getPrediosPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PREDIO" query-param="ID_PREDIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPrediosNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID_PREDIO, NOMBRE, DIRECCION, ESCRITURA_NO, COD_PREDIAL, COD_INVENTARIO  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY ID_PREDIO) WHERE (CASE WHEN ID_PREDIO IS NULL THEN ' ' ELSE UPPER(ID_PREDIO) END)  LIKE UPPER(:ID_PREDIO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PREDIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="predios/todosporcompania/num">
		<call-query href="getPrediosNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_PREDIO" query-param="ID_PREDIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updatePrediosNombre" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PREDIOS SET NOMBRE = :NOMBRE, MODIFIED_BY = :MODIFIED_BY, DATE_MODIFIED = :DATE_MODIFIED WHERE COMPANIA = :KEY_COMPANIA AND ID_PREDIO = :KEY_PREDIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PREDIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="predios/nombre">
		<call-query href="updatePrediosNombre">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PREDIO" query-param="KEY_PREDIO"/>

		</call-query>
	</resource>
	<query id="getPrediosPagTodosOrdenadosPorSerie_placaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_PREDIO ID, SERIE_PLACA,NOMBRE  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY SERIE_PLACA) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER(:SERIE_PLACA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","SERIE_PLACA":"$SERIE_PLACA(type:long)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="predios/todosordenadosporserie_placainicial/pag">
		<call-query href="getPrediosPagTodosOrdenadosPorSerie_placaInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPrediosNumTodosOrdenadosPorSerie_placaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID_PREDIO ID, SERIE_PLACA,NOMBRE  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY SERIE_PLACA) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER( '%' || :SERIE_PLACA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="predios/todosordenadosporserie_placainicial/num">
		<call-query href="getPrediosNumTodosOrdenadosPorSerie_placaInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPrediosPagTodosOrdenadosPorNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_PREDIO ID, SERIE_PLACA,NOMBRE  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY NOMBRE) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER(:SERIE_PLACA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","SERIE_PLACA":"$SERIE_PLACA(type:long)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="predios/todosordenadospornombreinicial/pag">
		<call-query href="getPrediosPagTodosOrdenadosPorNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPrediosNumTodosOrdenadosPorNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID_PREDIO ID, SERIE_PLACA,NOMBRE  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY NOMBRE) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER( '%' || :SERIE_PLACA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="predios/todosordenadospornombreinicial/num">
		<call-query href="getPrediosNumTodosOrdenadosPorNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPrediosPagTodosOrdenadosPorId_predioInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_PREDIO ID, SERIE_PLACA,NOMBRE  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY ID_PREDIO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER(:SERIE_PLACA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","SERIE_PLACA":"$SERIE_PLACA(type:long)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="predios/todosordenadosporid_predioinicial/pag">
		<call-query href="getPrediosPagTodosOrdenadosPorId_predioInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPrediosNumTodosOrdenadosPorId_predioInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID_PREDIO ID, SERIE_PLACA,NOMBRE  FROM PREDIOS WHERE COMPANIA = :COMPANIA ORDER BY ID_PREDIO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN SERIE_PLACA IS NULL THEN ' ' ELSE UPPER(SERIE_PLACA) END)  LIKE UPPER( '%' || :SERIE_PLACA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="predios/todosordenadosporid_predioinicial/num">
		<call-query href="getPrediosNumTodosOrdenadosPorId_predioInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertPredios" keyColumns="COMPANIA,ID_PREDIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PREDIOS (EXT_LINDEROS_FRENTE, ACC_ADOQUIN, SUCURSAL, PREDIO_IRREGULAR, NOTARIA, ACC_PRINCIPAL, RUTA_FOTO, EXT_LINDEROS_IZQ, NECESITA_INVENTARIO, CREATED_BY, PREDIO_PLANO, DESC_LINDEROS_IZQ, FECHA_ESCRITURA, DPTO_ESCRITURA, ESCRITURA_NO, MODALIDAD, DESC_LINDEROS_FONDO, COD_PREDIAL, CIUDAD_ESCRITURA, PREDIO_REGULAR, PREDIO_INCLINADO, COD_FOTO, ACC_SECUNDARIA, NOMBRE, ID_PREDIO, COD_INVENTARIO, ANO_CONSTRUCCION, DIRECCION, DESTINACION, DESC_LINDEROS_FRENTE, DESC_LINDEROS_DER, MATR_INMOVILIARIA, RESPONSABLE, COMPANIA, PAIS, TIPO_PREDIO, EXT_LINDEROS_FONDO, COD_PLANO, OBSERVACIONES, UBICACION, ACC_RIGIDO, DATE_CREATED, ACC_ASFALTO, SERIE_PLACA, EXT_LINDEROS_DER, AREA_ESCRITURA, RUTA_PLANO, ENCUESTA_VALOR) VALUES (:EXT_LINDEROS_FRENTE, :ACC_ADOQUIN, :SUCURSAL, :PREDIO_IRREGULAR, :NOTARIA, :ACC_PRINCIPAL, :RUTA_FOTO, :EXT_LINDEROS_IZQ, :NECESITA_INVENTARIO, :CREATED_BY, :PREDIO_PLANO, :DESC_LINDEROS_IZQ, TO_DATE(:FECHA_ESCRITURA,'DD/MM/YYYY HH24:MI:SS'), :DPTO_ESCRITURA, :ESCRITURA_NO, :MODALIDAD, :DESC_LINDEROS_FONDO, :COD_PREDIAL, :CIUDAD_ESCRITURA, :PREDIO_REGULAR, :PREDIO_INCLINADO, :COD_FOTO, :ACC_SECUNDARIA, :NOMBRE, :ID_PREDIO, :COD_INVENTARIO, :ANO_CONSTRUCCION, :DIRECCION, :DESTINACION, :DESC_LINDEROS_FRENTE, :DESC_LINDEROS_DER, :MATR_INMOVILIARIA, :RESPONSABLE, :COMPANIA, :PAIS, :TIPO_PREDIO, :EXT_LINDEROS_FONDO, :COD_PLANO, :OBSERVACIONES, :UBICACION, :ACC_RIGIDO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :ACC_ASFALTO, :SERIE_PLACA, :EXT_LINDEROS_DER, :AREA_ESCRITURA, :RUTA_PLANO, :ENCUESTA_VALOR)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_PREDIO":"$ID_PREDIO"}]}}		</result>
		<param defaultValue="0" name="EXT_LINDEROS_FRENTE" sqlType="STRING"/>
		<param defaultValue="0" name="ACC_ADOQUIN" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="PREDIO_IRREGULAR" sqlType="STRING"/>
		<param name="NOTARIA" sqlType="STRING"/>
		<param defaultValue="0" name="ACC_PRINCIPAL" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_FOTO" sqlType="STRING"/>
		<param defaultValue="0" name="EXT_LINDEROS_IZQ" sqlType="STRING"/>
		<param defaultValue="0" name="NECESITA_INVENTARIO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param defaultValue="0" name="PREDIO_PLANO" sqlType="STRING"/>
		<param defaultValue="" name="DESC_LINDEROS_IZQ" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_ESCRITURA" sqlType="STRING"/>
		<param name="DPTO_ESCRITURA" sqlType="STRING"/>
		<param defaultValue="" name="ESCRITURA_NO" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param defaultValue="" name="DESC_LINDEROS_FONDO" sqlType="STRING"/>
		<param name="COD_PREDIAL" sqlType="STRING"/>
		<param name="CIUDAD_ESCRITURA" sqlType="STRING"/>
		<param defaultValue="0" name="PREDIO_REGULAR" sqlType="STRING"/>
		<param defaultValue="0" name="PREDIO_INCLINADO" sqlType="STRING"/>
		<param defaultValue="" name="COD_FOTO" sqlType="STRING"/>
		<param defaultValue="0" name="ACC_SECUNDARIA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="ID_PREDIO" sqlType="STRING"/>
		<param name="COD_INVENTARIO" sqlType="STRING"/>
		<param name="ANO_CONSTRUCCION" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION" sqlType="STRING"/>
		<param defaultValue="" name="DESTINACION" sqlType="STRING"/>
		<param defaultValue="" name="DESC_LINDEROS_FRENTE" sqlType="STRING"/>
		<param defaultValue="" name="DESC_LINDEROS_DER" sqlType="STRING"/>
		<param defaultValue="" name="MATR_INMOVILIARIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PAIS" sqlType="STRING"/>
		<param name="TIPO_PREDIO" sqlType="STRING"/>
		<param defaultValue="0" name="EXT_LINDEROS_FONDO" sqlType="STRING"/>
		<param defaultValue="" name="COD_PLANO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="UBICACION" sqlType="STRING"/>
		<param defaultValue="0" name="ACC_RIGIDO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="ACC_ASFALTO" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param defaultValue="0" name="EXT_LINDEROS_DER" sqlType="STRING"/>
		<param defaultValue="0" name="AREA_ESCRITURA" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_PLANO" sqlType="STRING"/>
		<param defaultValue="" name="ENCUESTA_VALOR" sqlType="STRING"/>

	</query>
	<resource method="POST" path="predios">
		<call-query href="insertPredios">
			<with-param name="EXT_LINDEROS_FRENTE" query-param="EXT_LINDEROS_FRENTE"/>
			<with-param name="ACC_ADOQUIN" query-param="ACC_ADOQUIN"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="PREDIO_IRREGULAR" query-param="PREDIO_IRREGULAR"/>
			<with-param name="NOTARIA" query-param="NOTARIA"/>
			<with-param name="ACC_PRINCIPAL" query-param="ACC_PRINCIPAL"/>
			<with-param name="RUTA_FOTO" query-param="RUTA_FOTO"/>
			<with-param name="EXT_LINDEROS_IZQ" query-param="EXT_LINDEROS_IZQ"/>
			<with-param name="NECESITA_INVENTARIO" query-param="NECESITA_INVENTARIO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="PREDIO_PLANO" query-param="PREDIO_PLANO"/>
			<with-param name="DESC_LINDEROS_IZQ" query-param="DESC_LINDEROS_IZQ"/>
			<with-param name="FECHA_ESCRITURA" query-param="FECHA_ESCRITURA"/>
			<with-param name="DPTO_ESCRITURA" query-param="DPTO_ESCRITURA"/>
			<with-param name="ESCRITURA_NO" query-param="ESCRITURA_NO"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="DESC_LINDEROS_FONDO" query-param="DESC_LINDEROS_FONDO"/>
			<with-param name="COD_PREDIAL" query-param="COD_PREDIAL"/>
			<with-param name="CIUDAD_ESCRITURA" query-param="CIUDAD_ESCRITURA"/>
			<with-param name="PREDIO_REGULAR" query-param="PREDIO_REGULAR"/>
			<with-param name="PREDIO_INCLINADO" query-param="PREDIO_INCLINADO"/>
			<with-param name="COD_FOTO" query-param="COD_FOTO"/>
			<with-param name="ACC_SECUNDARIA" query-param="ACC_SECUNDARIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ID_PREDIO" query-param="ID_PREDIO"/>
			<with-param name="COD_INVENTARIO" query-param="COD_INVENTARIO"/>
			<with-param name="ANO_CONSTRUCCION" query-param="ANO_CONSTRUCCION"/>
			<with-param name="DIRECCION" query-param="DIRECCION"/>
			<with-param name="DESTINACION" query-param="DESTINACION"/>
			<with-param name="DESC_LINDEROS_FRENTE" query-param="DESC_LINDEROS_FRENTE"/>
			<with-param name="DESC_LINDEROS_DER" query-param="DESC_LINDEROS_DER"/>
			<with-param name="MATR_INMOVILIARIA" query-param="MATR_INMOVILIARIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PAIS" query-param="PAIS"/>
			<with-param name="TIPO_PREDIO" query-param="TIPO_PREDIO"/>
			<with-param name="EXT_LINDEROS_FONDO" query-param="EXT_LINDEROS_FONDO"/>
			<with-param name="COD_PLANO" query-param="COD_PLANO"/>
