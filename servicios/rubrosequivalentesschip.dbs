<data name="rubrosequivalentesschip" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getRubrosequivalentesschipPagTodosPorEntidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  RUBROS_EQUIVALENTES_SCHIP.CODIGO, RUBROS_EQUIVALENTES_SCHIP.NOMBRE,(CASE RUBROS_EQUIVALENTES_SCHIP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM RUBROS_EQUIVALENTES_SCHIP WHERE RUBROS_EQUIVALENTES_SCHIP.ENTIDAD = :ENTIDAD ORDER BY RUBROS_EQUIVALENTES_SCHIP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="ENTIDAD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="rubrosequivalentesschip/todosporentidad/pag">
		<call-query href="getRubrosequivalentesschipPagTodosPorEntidadQuery">
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRubrosequivalentesschipNumTodosPorEntidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  RUBROS_EQUIVALENTES_SCHIP.CODIGO, RUBROS_EQUIVALENTES_SCHIP.NOMBRE,(CASE RUBROS_EQUIVALENTES_SCHIP.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM RUBROS_EQUIVALENTES_SCHIP WHERE RUBROS_EQUIVALENTES_SCHIP.ENTIDAD = :ENTIDAD ORDER BY RUBROS_EQUIVALENTES_SCHIP.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ENTIDAD" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="rubrosequivalentesschip/todosporentidad/num">
		<call-query href="getRubrosequivalentesschipNumTodosPorEntidadQuery">
			<with-param name="ENTIDAD" query-param="ENTIDAD"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

</data>