			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="TIPO_NOVEDAD" query-param="TIPO_NOVEDAD"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>

		</call-query>
	</resource>
	<query id="getEncargosOrigendatossubencargosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ENCARGOS.COMPANIA, ENCARGOS.ID_DE_EMPLEADO, ENCARGOS.ID_DE_PROCESO, ENCARGOS.ESCALAFON, ENCARGOS.ID_DE_CARGO, ENCARGOS.ID_DE_CATEGORIA, (TO_CHAR(ENCARGOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO, ENCARGOS.TIPO_NOVEDAD, ENCARGOS.CLASE_ENCARGO, ENCARGOS.DETALLE_ENCARGOC, ENCARGOS.TIPOACTO, ENCARGOS.ACTO, (TO_CHAR(ENCARGOS.FECHAACTO,'DD/MM/YYYY HH24:MI:SS')) FECHAACTO, ENCARGOS.OBSERVACION_E, ENCARGOS.DEPENDENCIA, ENCARGOS.CARGO, (TO_CHAR(ENCARGOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, ENCARGOS.ACTA, (TO_CHAR(ENCARGOS.FECHAACTA,'DD/MM/YYYY HH24:MI:SS')) FECHAACTA, (TO_CHAR(ENCARGOS.FECHAEFECTIVIDAD,'DD/MM/YYYY HH24:MI:SS')) FECHAEFECTIVIDAD, ENCARGOS.SUELDOMENSUAL, ENCARGOS.EC_PRIMATECNICAFACTOR, ENCARGOS.EC_PRIMATECNICANFACTOR, ENCARGOS.EC_GASTOSREPRESENTACION, ENCARGOS.EC_PRIMAALTAGESTION, ENCARGOS.EC_AUXT, ENCARGOS.EC_AUXA, ENCARGOS.CREATED_BY, (TO_CHAR(ENCARGOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, ENCARGOS.MODIFIED_BY, (TO_CHAR(ENCARGOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CARGOS.NOMBRE_DEL_CARGO, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA  FROM ENCARGOS LEFT JOIN CARGOS ON ENCARGOS.COMPANIA = CARGOS.COMPANIA AND ENCARGOS.ID_DE_CARGO = CARGOS.ID_DE_CARGO LEFT JOIN DEPENDENCIA ON ENCARGOS.COMPANIA = DEPENDENCIA.COMPANIA AND ENCARGOS.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE ENCARGOS.COMPANIA = :KEY_COMPANIA AND ENCARGOS.ID_DE_EMPLEADO = :KEY_ID_DE_EMPLEADO AND ENCARGOS.ID_DE_PROCESO = :KEY_ID_DE_PROCESO AND ENCARGOS.ESCALAFON = :KEY_ESCALAFON AND ENCARGOS.ID_DE_CARGO = :KEY_ID_DE_CARGO AND ENCARGOS.ID_DE_CATEGORIA= :KEY_ID_DE_CATEGORIA AND ENCARGOS.FECHAINICIO = TO_DATE(:KEY_FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ESCALAFON":"$ESCALAFON","ID_DE_CARGO":"$ID_DE_CARGO","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","FECHAINICIO":"$FECHAINICIO","TIPO_NOVEDAD":"$TIPO_NOVEDAD","CLASE_ENCARGO":"$CLASE_ENCARGO","DETALLE_ENCARGOC":"$DETALLE_ENCARGOC(type:integer)","TIPOACTO":"$TIPOACTO","ACTO":"$ACTO","FECHAACTO":"$FECHAACTO","OBSERVACION_E":"$OBSERVACION_E","DEPENDENCIA":"$DEPENDENCIA","CARGO":"$CARGO","FECHAFINAL":"$FECHAFINAL","ACTA":"$ACTA","FECHAACTA":"$FECHAACTA","FECHAEFECTIVIDAD":"$FECHAEFECTIVIDAD","SUELDOMENSUAL":"$SUELDOMENSUAL","EC_PRIMATECNICAFACTOR":"$EC_PRIMATECNICAFACTOR","EC_PRIMATECNICANFACTOR":"$EC_PRIMATECNICANFACTOR","EC_GASTOSREPRESENTACION":"$EC_GASTOSREPRESENTACION","EC_PRIMAALTAGESTION":"$EC_PRIMAALTAGESTION","EC_AUXT":"$EC_AUXT","EC_AUXA":"$EC_AUXA","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ESCALAFON" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="KEY_FECHAINICIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="encargos/origendatossubencargos">
		<call-query href="getEncargosOrigendatossubencargosQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ESCALAFON" query-param="KEY_ESCALAFON"/>
			<with-param name="KEY_ID_DE_CARGO" query-param="KEY_ID_DE_CARGO"/>
			<with-param name="KEY_ID_DE_CATEGORIA" query-param="KEY_ID_DE_CATEGORIA"/>
			<with-param name="KEY_FECHAINICIO" query-param="KEY_FECHAINICIO"/>

		</call-query>
	</resource>
	<query id="getEncargosPagListadoencargosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ENCARGOS.ANO, ENCARGOS.COMPANIA, ENCARGOS.ID_DE_PROCESO, ENCARGOS.ESCALAFON, ENCARGOS.ID_DE_CARGO, ENCARGOS.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO NOMBRE, ESCALAFON.NOMBRE NIVEL, CARGOS.NOMBRE_DEL_CARGO CARGO, ENCARGOS.ID_DE_CATEGORIA,(TO_CHAR(ENCARGOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(ENCARGOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(ENCARGOS.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, ENCARGOS.ACTO, ENCARGOS.SUELDOMENSUAL, ENCARGOS.MODIFIED_BY,(TO_CHAR(ENCARGOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM ENCARGOS INNER JOIN PERSONAL ON PERSONAL.COMPANIA = ENCARGOS.COMPANIA AND PERSONAL.ID_DE_EMPLEADO = ENCARGOS.ID_DE_EMPLEADO INNER JOIN ESCALAFON ON ESCALAFON.CODIGO = ENCARGOS.ESCALAFON AND ESCALAFON.COMPANIA = ENCARGOS.COMPANIA INNER JOIN CARGOS ON CARGOS.COMPANIA = ENCARGOS.COMPANIA AND CARGOS.ID_DE_CARGO = ENCARGOS.ID_DE_CARGO WHERE ENCARGOS.FECHAFINAL &gt;= ( SELECT DISTINCT PERIODOS.FECHAINICIO FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO = :ANIO AND PERIODOS.MES = :MES AND PERIODOS.ID_DE_PROCESO = :PROCESO AND PERIODOS.PERIODO = :PERIODO ) ORDER BY PERSONAL.NOMBRECOMPLETO ASC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIVEL IS NULL THEN ' ' ELSE UPPER(NIVEL) END) LIKE UPPER(CONCAT(CONCAT('%',:NIVEL), '%')) AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CARGO), '%')) AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END) LIKE UPPER(CONCAT(:ID_DE_CATEGORIA, '%')) AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END) LIKE UPPER(CONCAT(:FECHAINICIO, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END) LIKE UPPER(CONCAT(:FECHAPAGO, '%')) AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END) LIKE UPPER(CONCAT(:ACTO, '%')) AND (CASE WHEN SUELDOMENSUAL IS NULL THEN ' ' ELSE UPPER(SUELDOMENSUAL) END) LIKE UPPER(CONCAT(:SUELDOMENSUAL, '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(:MODIFIED_BY, '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(:DATE_MODIFIED, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ESCALAFON":"$ESCALAFON","ID_DE_CARGO":"$ID_DE_CARGO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRE":"$NOMBRE","NIVEL":"$NIVEL","CARGO":"$CARGO","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL","FECHAPAGO":"$FECHAPAGO","ACTO":"$ACTO","SUELDOMENSUAL":"$SUELDOMENSUAL","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>
		<param name="SUELDOMENSUAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="encargos/listadoencargos/pag">
		<call-query href="getEncargosPagListadoencargosQuery">
