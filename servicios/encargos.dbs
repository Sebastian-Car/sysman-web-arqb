	</resource>
	<query id="getEncargosNumListadoencargosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ENCARGOS.ANO, ENCARGOS.COMPANIA, ENCARGOS.ID_DE_PROCESO, ENCARGOS.ESCALAFON, ENCARGOS.ID_DE_CARGO, ENCARGOS.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO NOMBRE, ESCALAFON.NOMBRE NIVEL, CARGOS.NOMBRE_DEL_CARGO CARGO, ENCARGOS.ID_DE_CATEGORIA,(TO_CHAR(ENCARGOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(ENCARGOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(ENCARGOS.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, ENCARGOS.ACTO, ENCARGOS.SUELDOMENSUAL, ENCARGOS.MODIFIED_BY,(TO_CHAR(ENCARGOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM ENCARGOS INNER JOIN PERSONAL ON PERSONAL.COMPANIA = ENCARGOS.COMPANIA AND PERSONAL.ID_DE_EMPLEADO = ENCARGOS.ID_DE_EMPLEADO INNER JOIN ESCALAFON ON ESCALAFON.CODIGO = ENCARGOS.ESCALAFON AND ESCALAFON.COMPANIA = ENCARGOS.COMPANIA INNER JOIN CARGOS ON CARGOS.COMPANIA = ENCARGOS.COMPANIA AND CARGOS.ID_DE_CARGO = ENCARGOS.ID_DE_CARGO WHERE ENCARGOS.FECHAFINAL &gt;= ( SELECT DISTINCT PERIODOS.FECHAINICIO FROM PERIODOS WHERE PERIODOS.COMPANIA = :COMPANIA AND PERIODOS.ANO = :ANIO AND PERIODOS.MES = :MES AND PERIODOS.ID_DE_PROCESO = :PROCESO AND PERIODOS.PERIODO = :PERIODO ) ORDER BY PERSONAL.NOMBRECOMPLETO ASC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIVEL IS NULL THEN ' ' ELSE UPPER(NIVEL) END) LIKE UPPER(CONCAT(CONCAT('%',:NIVEL), '%')) AND (CASE WHEN CARGO IS NULL THEN ' ' ELSE UPPER(CARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CARGO), '%')) AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END) LIKE UPPER(CONCAT(:ID_DE_CATEGORIA, '%')) AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END) LIKE UPPER(CONCAT(:FECHAINICIO, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END) LIKE UPPER(CONCAT(:FECHAPAGO, '%')) AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END) LIKE UPPER(CONCAT(:ACTO, '%')) AND (CASE WHEN SUELDOMENSUAL IS NULL THEN ' ' ELSE UPPER(SUELDOMENSUAL) END) LIKE UPPER(CONCAT(:SUELDOMENSUAL, '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(:MODIFIED_BY, '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(:DATE_MODIFIED, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>
		<param name="SUELDOMENSUAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>

	</query>
