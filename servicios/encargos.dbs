	<query id="getEncargosDiasencargoQuery"  useConfig="sysmandsunist">
		<sql>SELECT PCK_SYSMAN_UTL.FC_EDAD(FECHAINICIO, FECHAFINAL,3,0) AS DIAS FROM ENCARGOS WHERE COMPANIA = :COMPANIA AND ID_DE_EMPLEADO = :ID_DE_EMPLEADO AND ID_DE_PROCESO = :ID_DE_PROCESO AND ESCALAFON = :ESCALAFON AND ID_DE_CARGO = :ID_DE_CARGO AND ID_DE_CATEGORIA = :ID_DE_CATEGORIA AND FECHAINICIO = TO_DATE(:FECHAINICIO,'DD/MM/YYYY')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIAS":"$DIAS"}]}}		</result>
