	<query id="deleteEncargos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ENCARGOS WHERE ENCARGOS.COMPANIA= :KEY_COMPANIA AND ENCARGOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND ENCARGOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND ENCARGOS.ESCALAFON= :KEY_ESCALAFON AND ENCARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO AND ENCARGOS.ID_DE_CATEGORIA= :KEY_ID_DE_CATEGORIA AND ENCARGOS.FECHAINICIO= TO_DATE(:KEY_FECHAINICIO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>
		<param name="KEY_ESCALAFON" sqlType="STRING"/>
