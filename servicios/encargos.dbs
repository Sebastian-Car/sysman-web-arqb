	<query id="insertEncargos" keyColumns="COMPANIA,ID_DE_EMPLEADO,ID_DE_PROCESO,ESCALAFON,ID_DE_CARGO,ID_DE_CATEGORIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ENCARGOS (COMPANIA, ID_DE_PROCESO, ID_DE_EMPLEADO, ESCALAFON, ID_DE_CARGO, ID_DE_CATEGORIA, FECHAINICIO, ANO, MES, PERIODO, ACTO, FECHAFINAL, SUELDOMENSUAL, FECHAACTO, FECHAPAGO, OBSERVACION_E, TIPO_NOVEDAD, CLASE_ENCARGO, DETALLE_ENCARGOC, ASCENSO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_PROCESO, :ID_DE_EMPLEADO, :ESCALAFON, :ID_DE_CARGO, :ID_DE_CATEGORIA, TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), :ANO, :MES, :PERIODO, :ACTO, TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), :SUELDOMENSUAL, TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAPAGO,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACION_E, :TIPO_NOVEDAD, :CLASE_ENCARGO, :DETALLE_ENCARGOC, :ASCENSO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ESCALAFON":"$ESCALAFON","KEY_ID_DE_CARGO":"$ID_DE_CARGO","KEY_ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","KEY_FECHAINICIO":"$FECHAINICIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
