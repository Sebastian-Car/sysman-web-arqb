	<query id="updateEncargosActualizafechafinalencargos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ENCARGOS SET FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ENCARGOS.COMPANIA= :KEY_COMPANIA AND ENCARGOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND ENCARGOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND ENCARGOS.ESCALAFON= :KEY_ESCALAFON AND ENCARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO AND ENCARGOS.ID_DE_CATEGORIA= :KEY_ID_DE_CATEGORIA AND ENCARGOS.FECHAINICIO= TO_DATE(:KEY_FECHAINICIO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
