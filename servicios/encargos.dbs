	<query id="getEncargosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ENCARGOS.SUELDOMENSUAL, ENCARGOS.PERIODO, ENCARGOS.MES, ENCARGOS.COMPANIA, ENCARGOS.ID_DE_EMPLEADO, ENCARGOS.ID_DE_PROCESO, ENCARGOS.ANO, ESCALAFON.NOMBRE, ENCARGOS.ESCALAFON, CARGOS.NOMBRE_DEL_CARGO, ENCARGOS.ID_DE_CARGO, ENCARGOS.ID_DE_CATEGORIA,(TO_CHAR(ENCARGOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(ENCARGOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(ENCARGOS.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, ENCARGOS.ACTO  FROM ENCARGOS INNER JOIN CARGOS ON CARGOS.COMPANIA =ENCARGOS.COMPANIA AND CARGOS.ID_DE_CARGO=ENCARGOS.ID_DE_CARGO INNER JOIN ESCALAFON ON ESCALAFON.COMPANIA =ENCARGOS.COMPANIA AND ESCALAFON.CODIGO =ENCARGOS.ESCALAFON WHERE ENCARGOS.COMPANIA = :COMPANIA AND ENCARGOS.ID_DE_EMPLEADO= :ID_DE_EMPLEADO ORDER BY ENCARGOS.ID_DE_EMPLEADO, ENCARGOS.FECHAINICIO DESC, ENCARGOS.FECHAFINAL DESC) WHERE (CASE WHEN SUELDOMENSUAL IS NULL THEN ' ' ELSE UPPER(SUELDOMENSUAL) END)  LIKE UPPER(:SUELDOMENSUAL || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END)  LIKE UPPER(:ID_DE_PROCESO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER(:ESCALAFON || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END)  LIKE UPPER( '%' || :FECHAINICIO || '%')  AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%')  AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END)  LIKE UPPER(:ACTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUELDOMENSUAL":"$SUELDOMENSUAL","PERIODO":"$PERIODO(type:integer)","MES":"$MES(type:integer)","COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","NOMBRE":"$NOMBRE","ESCALAFON":"$ESCALAFON","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","ID_DE_CARGO":"$ID_DE_CARGO","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL","FECHAPAGO":"$FECHAPAGO","ACTO":"$ACTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="SUELDOMENSUAL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="encargos">
		<call-query href="getEncargosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="SUELDOMENSUAL" query-param="SUELDOMENSUAL"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="FECHAPAGO" query-param="FECHAPAGO"/>
			<with-param name="ACTO" query-param="ACTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEncargosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ENCARGOS.SUELDOMENSUAL, ENCARGOS.PERIODO, ENCARGOS.MES, ENCARGOS.COMPANIA, ENCARGOS.ID_DE_EMPLEADO, ENCARGOS.ID_DE_PROCESO, ENCARGOS.ANO, ESCALAFON.NOMBRE, ENCARGOS.ESCALAFON, CARGOS.NOMBRE_DEL_CARGO, ENCARGOS.ID_DE_CARGO, ENCARGOS.ID_DE_CATEGORIA,(TO_CHAR(ENCARGOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(ENCARGOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(TO_CHAR(ENCARGOS.FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, ENCARGOS.ACTO  FROM ENCARGOS INNER JOIN CARGOS ON CARGOS.COMPANIA =ENCARGOS.COMPANIA AND CARGOS.ID_DE_CARGO=ENCARGOS.ID_DE_CARGO INNER JOIN ESCALAFON ON ESCALAFON.COMPANIA =ENCARGOS.COMPANIA AND ESCALAFON.CODIGO =ENCARGOS.ESCALAFON WHERE ENCARGOS.COMPANIA = :COMPANIA AND ENCARGOS.ID_DE_EMPLEADO= :ID_DE_EMPLEADO ORDER BY ENCARGOS.ID_DE_EMPLEADO, ENCARGOS.FECHAINICIO DESC, ENCARGOS.FECHAFINAL DESC) WHERE (CASE WHEN SUELDOMENSUAL IS NULL THEN ' ' ELSE UPPER(SUELDOMENSUAL) END)  LIKE UPPER(:SUELDOMENSUAL || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN MES IS NULL THEN ' ' ELSE UPPER(MES) END)  LIKE UPPER(:MES || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END)  LIKE UPPER(:ID_DE_PROCESO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER(:ESCALAFON || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER(:ID_DE_CARGO || '%')  AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER(:ID_DE_CATEGORIA || '%')  AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END)  LIKE UPPER( '%' || :FECHAINICIO || '%')  AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%')  AND (CASE WHEN ACTO IS NULL THEN ' ' ELSE UPPER(ACTO) END)  LIKE UPPER(:ACTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="SUELDOMENSUAL" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="encargos/numero">
		<call-query href="getEncargosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="SUELDOMENSUAL" query-param="SUELDOMENSUAL"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="FECHAPAGO" query-param="FECHAPAGO"/>
			<with-param name="ACTO" query-param="ACTO"/>

		</call-query>
	</resource>
	<query id="getEncargosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_DE_PROCESO, ID_DE_EMPLEADO, ESCALAFON, ID_DE_CARGO, ID_DE_CATEGORIA,(TO_CHAR(FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO, ANO, MES, PERIODO, ACTO,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, DETALLE_ENCARGOC, SUELDOMENSUAL,(TO_CHAR(FECHAACTO,'DD/MM/YYYY HH24:MI:SS')) FECHAACTO, TO_CHAR(TRUNC(TO_DATE(FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')),'DD/MM/YYYY')FECHAPAGO, VALORGR, OBSERVACION_E,(CASE ASCENSO WHEN 0 THEN 'false' ELSE 'true' END) ASCENSO,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CREATED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, MODIFIED_BY  FROM ENCARGOS WHERE ENCARGOS.COMPANIA= :KEY_COMPANIA AND ENCARGOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND ENCARGOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND ENCARGOS.ESCALAFON= :KEY_ESCALAFON AND ENCARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO AND ENCARGOS.ID_DE_CATEGORIA= :KEY_ID_DE_CATEGORIA AND ENCARGOS.FECHAINICIO= TO_DATE(:KEY_FECHAINICIO,'DD/MM/YYYY HH24:MI:SS') </sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ESCALAFON":"$ESCALAFON","ID_DE_CARGO":"$ID_DE_CARGO","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","FECHAINICIO":"$FECHAINICIO","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ACTO":"$ACTO","FECHAFINAL":"$FECHAFINAL","DETALLE_ENCARGOC":"$DETALLE_ENCARGOC(type:integer)","SUELDOMENSUAL":"$SUELDOMENSUAL","FECHAACTO":"$FECHAACTO","FECHAPAGO":"$FECHAPAGO","VALORGR":"$VALORGR","OBSERVACION_E":"$OBSERVACION_E","ASCENSO":"$ASCENSO(type:boolean)","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ESCALAFON" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="KEY_FECHAINICIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="encargos/data">
		<call-query href="getEncargosRegistroQuery">
