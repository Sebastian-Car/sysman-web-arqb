	<query id="updateEncargos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ENCARGOS SET COMPANIA=:COMPANIA, ID_DE_PROCESO=:ID_DE_PROCESO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ESCALAFON=:ESCALAFON, ID_DE_CARGO=:ID_DE_CARGO, ID_DE_CATEGORIA=:ID_DE_CATEGORIA, FECHAINICIO=TO_DATE(:FECHAINICIO,'DD/MM/YYYY HH24:MI:SS'), ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ACTO=:ACTO, FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), SUELDOMENSUAL=:SUELDOMENSUAL, FECHAACTO=TO_DATE(:FECHAACTO,'DD/MM/YYYY HH24:MI:SS'), FECHAPAGO=TO_DATE(:FECHAPAGO,'DD/MM/YYYY HH24:MI:SS'), OBSERVACION_E=:OBSERVACION_E, ASCENSO=:ASCENSO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ENCARGOS.COMPANIA= :KEY_COMPANIA AND ENCARGOS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND ENCARGOS.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND ENCARGOS.ESCALAFON= :KEY_ESCALAFON AND ENCARGOS.ID_DE_CARGO= :KEY_ID_DE_CARGO AND ENCARGOS.ID_DE_CATEGORIA= :KEY_ID_DE_CATEGORIA AND ENCARGOS.FECHAINICIO= TO_DATE(:KEY_FECHAINICIO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ACTO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="SUELDOMENSUAL" sqlType="STRING"/>
		<param name="FECHAACTO" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="OBSERVACION_E" sqlType="STRING"/>
		<param name="ASCENSO" sqlType="STRING"/>								  
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ESCALAFON" sqlType="STRING"/>
		<param name="KEY_ID_DE_CARGO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="KEY_FECHAINICIO" sqlType="STRING"/>

	</query>
