<data name="encargos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEncargosPagOrigengrillasubencargosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ENCARGOS.COMPANIA, ENCARGOS.ID_DE_EMPLEADO, ENCARGOS.ID_DE_PROCESO, ENCARGOS.ESCALAFON, ENCARGOS.ID_DE_CARGO, ENCARGOS.ID_DE_CATEGORIA, DECODE (ENCARGOS.TIPO_NOVEDAD, 1, 'ENCARGO', 2, 'TRASLADO', '') TIPO_NOVEDAD, CARGOS.NOMBRE_DEL_CARGO, TO_CHAR(ENCARGOS.FECHAINICIO, 'DD/MM/YYYY') FECHAINICIO, TO_CHAR(ENCARGOS.FECHAFINAL, 'DD/MM/YYYY') FECHAFINAL  FROM ENCARGOS INNER JOIN CARGOS ON ENCARGOS.COMPANIA = CARGOS.COMPANIA AND ENCARGOS.ID_DE_CARGO = CARGOS.ID_DE_CARGO WHERE ENCARGOS.COMPANIA = :COMPANIA AND ENCARGOS.ID_DE_EMPLEADO = :CODIGO ORDER BY TO_DATE(FECHAFINAL) DESC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER( '%' || :ID_DE_EMPLEADO || '%')  AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END)  LIKE UPPER( '%' || :ID_DE_PROCESO || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER( '%' || :ESCALAFON || '%')  AND (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER( '%' || :ID_DE_CARGO || '%')  AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER( '%' || :ID_DE_CATEGORIA || '%')  AND (CASE WHEN TIPO_NOVEDAD IS NULL THEN ' ' ELSE UPPER(TIPO_NOVEDAD) END)  LIKE UPPER( '%' || :TIPO_NOVEDAD || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END)  LIKE UPPER( '%' || :FECHAINICIO || '%')  AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ESCALAFON":"$ESCALAFON","ID_DE_CARGO":"$ID_DE_CARGO","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","TIPO_NOVEDAD":"$TIPO_NOVEDAD","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="TIPO_NOVEDAD" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="encargos/origengrillasubencargos/pag">
		<call-query href="getEncargosPagOrigengrillasubencargosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ID_DE_PROCESO" query-param="ID_DE_PROCESO"/>
			<with-param name="ESCALAFON" query-param="ESCALAFON"/>
			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="ID_DE_CATEGORIA" query-param="ID_DE_CATEGORIA"/>
			<with-param name="TIPO_NOVEDAD" query-param="TIPO_NOVEDAD"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEncargosNumOrigengrillasubencargosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ENCARGOS.COMPANIA, ENCARGOS.ID_DE_EMPLEADO, ENCARGOS.ID_DE_PROCESO, ENCARGOS.ESCALAFON, ENCARGOS.ID_DE_CARGO, ENCARGOS.ID_DE_CATEGORIA, DECODE (ENCARGOS.TIPO_NOVEDAD, 1, 'ENCARGO', 2, 'TRASLADO', '') TIPO_NOVEDAD, CARGOS.NOMBRE_DEL_CARGO, TO_CHAR(ENCARGOS.FECHAINICIO, 'DD/MM/YYYY') FECHAINICIO, TO_CHAR(ENCARGOS.FECHAFINAL, 'DD/MM/YYYY') FECHAFINAL  FROM ENCARGOS INNER JOIN CARGOS ON ENCARGOS.COMPANIA = CARGOS.COMPANIA AND ENCARGOS.ID_DE_CARGO = CARGOS.ID_DE_CARGO WHERE ENCARGOS.COMPANIA = :COMPANIA AND ENCARGOS.ID_DE_EMPLEADO = :CODIGO ORDER BY TO_DATE(FECHAFINAL) DESC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER( '%' || :ID_DE_EMPLEADO || '%')  AND (CASE WHEN ID_DE_PROCESO IS NULL THEN ' ' ELSE UPPER(ID_DE_PROCESO) END)  LIKE UPPER( '%' || :ID_DE_PROCESO || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER( '%' || :ESCALAFON || '%')  AND (CASE WHEN ID_DE_CARGO IS NULL THEN ' ' ELSE UPPER(ID_DE_CARGO) END)  LIKE UPPER( '%' || :ID_DE_CARGO || '%')  AND (CASE WHEN ID_DE_CATEGORIA IS NULL THEN ' ' ELSE UPPER(ID_DE_CATEGORIA) END)  LIKE UPPER( '%' || :ID_DE_CATEGORIA || '%')  AND (CASE WHEN TIPO_NOVEDAD IS NULL THEN ' ' ELSE UPPER(TIPO_NOVEDAD) END)  LIKE UPPER( '%' || :TIPO_NOVEDAD || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%')  AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END)  LIKE UPPER( '%' || :FECHAINICIO || '%')  AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END)  LIKE UPPER( '%' || :FECHAFINAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_DE_CARGO" sqlType="STRING"/>
		<param name="ID_DE_CATEGORIA" sqlType="STRING"/>
		<param name="TIPO_NOVEDAD" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="encargos/origengrillasubencargos/num">
		<call-query href="getEncargosNumOrigengrillasubencargosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
