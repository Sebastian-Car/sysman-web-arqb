	<query id="deleteNatformacionacademica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_FORMACION_ACADEMICA WHERE NAT_FORMACION_ACADEMICA.COMPANIA= :KEY_COMPANIA AND NAT_FORMACION_ACADEMICA.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_FORMACION_ACADEMICA.SUCURSAL= :KEY_SUCURSAL AND NAT_FORMACION_ACADEMICA.NUMERO= :KEY_NUMERO AND NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA= :KEY_NFA_CODIGOPERSONA AND NAT_FORMACION_ACADEMICA.TITULOOBTENIDO= :KEY_TITULOOBTENIDO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
