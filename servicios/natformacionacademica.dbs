<data name="natformacionacademica" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatformacionacademicaPagModNiveltitPatroPorModalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NAT_FORMACION_ACADEMICA.MODALIDAD, CONCAT(NAT_FORMACION_ACADEMICA.NIVELAPROBADO,CONCAT(' ',NAT_FORMACION_ACADEMICA.TITULOOBTENIDO) ) NIVELTITULO,(CASE NAT_FORMACION_ACADEMICA.PATROCINADO WHEN 0 THEN 'false' ELSE 'true' END) PATROCINADO FROM NAT_FORMACION_ACADEMICA WHERE NAT_FORMACION_ACADEMICA.COMPANIA =:COMPANIA AND ( NAT_FORMACION_ACADEMICA.MODALIDAD = 'TC' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'TL' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'TE' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'UN' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'EP' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'MG' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'DC' )) INI WHERE (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END) LIKE UPPER(CONCAT(:MODALIDAD, '%')) AND (CASE WHEN NIVELTITULO IS NULL THEN ' ' ELSE UPPER(NIVELTITULO) END) LIKE UPPER(CONCAT(CONCAT('%',:NIVELTITULO), '%')) AND (CASE WHEN PATROCINADO IS NULL THEN ' ' ELSE UPPER(PATROCINADO) END) LIKE UPPER(CONCAT(:PATROCINADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MODALIDAD":"$MODALIDAD","NIVELTITULO":"$NIVELTITULO","PATROCINADO":"$PATROCINADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="NIVELTITULO" sqlType="STRING"/>
		<param name="PATROCINADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natformacionacademica/modniveltitpatropormodal/pag">
		<call-query href="getNatformacionacademicaPagModNiveltitPatroPorModalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="NIVELTITULO" query-param="NIVELTITULO"/>
			<with-param name="PATROCINADO" query-param="PATROCINADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatformacionacademicaNumModNiveltitPatroPorModalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NAT_FORMACION_ACADEMICA.MODALIDAD, CONCAT(NAT_FORMACION_ACADEMICA.NIVELAPROBADO,CONCAT(' ',NAT_FORMACION_ACADEMICA.TITULOOBTENIDO) ) NIVELTITULO,(CASE NAT_FORMACION_ACADEMICA.PATROCINADO WHEN 0 THEN 'false' ELSE 'true' END) PATROCINADO FROM NAT_FORMACION_ACADEMICA WHERE NAT_FORMACION_ACADEMICA.COMPANIA =:COMPANIA AND ( NAT_FORMACION_ACADEMICA.MODALIDAD = 'TC' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'TL' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'TE' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'UN' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'EP' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'MG' OR NAT_FORMACION_ACADEMICA.MODALIDAD = 'DC' )) INI WHERE (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END) LIKE UPPER(CONCAT(:MODALIDAD, '%')) AND (CASE WHEN NIVELTITULO IS NULL THEN ' ' ELSE UPPER(NIVELTITULO) END) LIKE UPPER(CONCAT(CONCAT('%',:NIVELTITULO), '%')) AND (CASE WHEN PATROCINADO IS NULL THEN ' ' ELSE UPPER(PATROCINADO) END) LIKE UPPER(CONCAT(:PATROCINADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="NIVELTITULO" sqlType="STRING"/>
		<param name="PATROCINADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natformacionacademica/modniveltitpatropormodal/num">
		<call-query href="getNatformacionacademicaNumModNiveltitPatroPorModalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="NIVELTITULO" query-param="NIVELTITULO"/>
			<with-param name="PATROCINADO" query-param="PATROCINADO"/>

		</call-query>
	</resource>
	<query id="insertNatformacionacademicaNatformacionacademicamodalidad" keyColumns="COMPANIA,NUMERO_DCTO,SUCURSAL,NUMERO,NFA_CODIGOPERSONA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_FORMACION_ACADEMICA (COMPANIA, NUMERO_DCTO, SUCURSAL, NUMERO, NFA_CODIGOPERSONA, MODALIDAD, TITULOOBTENIDO, PATROCINADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_DCTO, :SUCURSAL, :NUMERO, :NFA_CODIGOPERSONA, :MODALIDAD, :TITULOOBTENIDO, :PATROCINADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_NUMERO":"$NUMERO","KEY_NFA_CODIGOPERSONA":"$NFA_CODIGOPERSONA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NFA_CODIGOPERSONA" sqlType="STRING"/>
		<param defaultValue="" name="MODALIDAD" sqlType="STRING"/>
		<param name="TITULOOBTENIDO" sqlType="STRING"/>
		<param defaultValue="0" name="PATROCINADO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natformacionacademica/natformacionacademicamodalidad">
		<call-query href="insertNatformacionacademicaNatformacionacademicamodalidad">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NFA_CODIGOPERSONA" query-param="NFA_CODIGOPERSONA"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="TITULOOBTENIDO" query-param="TITULOOBTENIDO"/>
			<with-param name="PATROCINADO" query-param="PATROCINADO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateNatformacionacademicaNatformacionacademicamodalidad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_FORMACION_ACADEMICA SET MODALIDAD=:MODALIDAD, TITULOOBTENIDO=:TITULOOBTENIDO, PATROCINADO=:PATROCINADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_FORMACION_ACADEMICA.COMPANIA= :KEY_COMPANIA AND NAT_FORMACION_ACADEMICA.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_FORMACION_ACADEMICA.SUCURSAL= :KEY_SUCURSAL AND NAT_FORMACION_ACADEMICA.NUMERO= :KEY_NUMERO AND NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA= :KEY_NFA_CODIGOPERSONA AND NAT_FORMACION_ACADEMICA.TITULOOBTENIDO= :KEY_TITULOOBTENIDO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="TITULOOBTENIDO" sqlType="STRING"/>
		<param name="PATROCINADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_NFA_CODIGOPERSONA" sqlType="STRING"/>
		<param name="KEY_TITULOOBTENIDO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natformacionacademica/natformacionacademicamodalidad">
		<call-query href="updateNatformacionacademicaNatformacionacademicamodalidad">
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="TITULOOBTENIDO" query-param="TITULOOBTENIDO"/>
			<with-param name="PATROCINADO" query-param="PATROCINADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_NFA_CODIGOPERSONA" query-param="KEY_NFA_CODIGOPERSONA"/>
			<with-param name="KEY_TITULOOBTENIDO" query-param="KEY_TITULOOBTENIDO"/>

		</call-query>
	</resource>
	<query id="getNatformacionacademicaPagNatformacionacademicamodalidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_FORMACION_ACADEMICA.COMPANIA, NAT_FORMACION_ACADEMICA.NUMERO_DCTO, NAT_FORMACION_ACADEMICA.SUCURSAL, NAT_FORMACION_ACADEMICA.NUMERO, NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA, NAT_FORMACION_ACADEMICA.MODALIDAD, PROFESIONES.NOMBRE_PROFESION NOMBRETITULO, NAT_FORMACION_ACADEMICA.TITULOOBTENIDO,(CASE NAT_FORMACION_ACADEMICA.PATROCINADO WHEN 0 THEN 'false' ELSE 'true' END) PATROCINADO FROM NAT_FORMACION_ACADEMICA INNER JOIN PROFESIONES ON PROFESIONES.CODIGOPROF = NAT_FORMACION_ACADEMICA.TITULOOBTENIDO WHERE NAT_FORMACION_ACADEMICA.COMPANIA =:COMPANIA AND NAT_FORMACION_ACADEMICA.NUMERO_DCTO =:DP_NUMEDOCU AND NAT_FORMACION_ACADEMICA.SUCURSAL =:SUCURSAL AND NAT_FORMACION_ACADEMICA.NUMERO =:CONSECUTIVO AND NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA =:ID_DE_EMPLEADO ORDER BY NAT_FORMACION_ACADEMICA.NUMERO) WHERE (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END)  LIKE UPPER(:MODALIDAD || '%')  AND (CASE WHEN NOMBRETITULO IS NULL THEN ' ' ELSE UPPER(NOMBRETITULO) END)  LIKE UPPER(:NOMBRETITULO || '%')  AND (CASE WHEN PATROCINADO IS NULL THEN ' ' ELSE UPPER(PATROCINADO) END)  LIKE UPPER( '%' || :PATROCINADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NUMERO":"$NUMERO","NFA_CODIGOPERSONA":"$NFA_CODIGOPERSONA","MODALIDAD":"$MODALIDAD","NOMBRETITULO":"$NOMBRETITULO","TITULOOBTENIDO":"$TITULOOBTENIDO","PATROCINADO":"$PATROCINADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="NOMBRETITULO" sqlType="STRING"/>
		<param name="PATROCINADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natformacionacademica/natformacionacademicamodalidad/pag">
		<call-query href="getNatformacionacademicaPagNatformacionacademicamodalidadQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="NOMBRETITULO" query-param="NOMBRETITULO"/>
			<with-param name="PATROCINADO" query-param="PATROCINADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatformacionacademicaNumNatformacionacademicamodalidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_FORMACION_ACADEMICA.COMPANIA, NAT_FORMACION_ACADEMICA.NUMERO_DCTO, NAT_FORMACION_ACADEMICA.SUCURSAL, NAT_FORMACION_ACADEMICA.NUMERO, NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA, NAT_FORMACION_ACADEMICA.MODALIDAD, PROFESIONES.NOMBRE_PROFESION NOMBRETITULO, NAT_FORMACION_ACADEMICA.TITULOOBTENIDO,(CASE NAT_FORMACION_ACADEMICA.PATROCINADO WHEN 0 THEN 'false' ELSE 'true' END) PATROCINADO FROM NAT_FORMACION_ACADEMICA INNER JOIN PROFESIONES ON PROFESIONES.CODIGOPROF = NAT_FORMACION_ACADEMICA.TITULOOBTENIDO WHERE NAT_FORMACION_ACADEMICA.COMPANIA =:COMPANIA AND NAT_FORMACION_ACADEMICA.NUMERO_DCTO =:DP_NUMEDOCU AND NAT_FORMACION_ACADEMICA.SUCURSAL =:SUCURSAL AND NAT_FORMACION_ACADEMICA.NUMERO =:CONSECUTIVO AND NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA =:ID_DE_EMPLEADO ORDER BY NAT_FORMACION_ACADEMICA.NUMERO) WHERE (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END)  LIKE UPPER(:MODALIDAD || '%')  AND (CASE WHEN NOMBRETITULO IS NULL THEN ' ' ELSE UPPER(NOMBRETITULO) END)  LIKE UPPER(:NOMBRETITULO || '%')  AND (CASE WHEN PATROCINADO IS NULL THEN ' ' ELSE UPPER(PATROCINADO) END)  LIKE UPPER( '%' || :PATROCINADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="NOMBRETITULO" sqlType="STRING"/>
		<param name="PATROCINADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natformacionacademica/natformacionacademicamodalidad/num">
		<call-query href="getNatformacionacademicaNumNatformacionacademicamodalidadQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="NOMBRETITULO" query-param="NOMBRETITULO"/>
			<with-param name="PATROCINADO" query-param="PATROCINADO"/>

