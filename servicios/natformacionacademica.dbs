	</resource>
	<query id="insertNatformacionacademica" keyColumns="COMPANIA,NUMERO_DCTO,SUCURSAL,NUMERO,NFA_CODIGOPERSONA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_FORMACION_ACADEMICA (COMPANIA, NUMERO_DCTO, SUCURSAL, NUMERO, NFA_CODIGOPERSONA, MODALIDAD, TITULOOBTENIDO, NIVELAPROBADO, ESTABLECIMIENTO, TARJETAPROFESIONAL, PAIS, DEPARTAMENTO, MUNICIPIO, FECHATERMINACION, DIATERMINACION, MESTERMINACION, ANOTERMINACION, GRADUADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_DCTO, :SUCURSAL, :NUMERO, :NFA_CODIGOPERSONA, :MODALIDAD, :TITULOOBTENIDO, :NIVELAPROBADO, :ESTABLECIMIENTO, :TARJETAPROFESIONAL, :PAIS, :DEPARTAMENTO, :MUNICIPIO, TO_DATE(:FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS'), :DIATERMINACION, :MESTERMINACION, :ANOTERMINACION, :GRADUADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL","KEY_NUMERO":"$NUMERO","KEY_NFA_CODIGOPERSONA":"$NFA_CODIGOPERSONA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
