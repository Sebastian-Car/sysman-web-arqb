	<query id="updateNatformacionacademica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_FORMACION_ACADEMICA SET NUMERO=:NUMERO, MODALIDAD=:MODALIDAD, TITULOOBTENIDO=:TITULOOBTENIDO, NIVELAPROBADO=:NIVELAPROBADO, ESTABLECIMIENTO=:ESTABLECIMIENTO, TARJETAPROFESIONAL=:TARJETAPROFESIONAL, PAIS=:PAIS, DEPARTAMENTO=:DEPARTAMENTO, MUNICIPIO=:MUNICIPIO, FECHATERMINACION=TO_DATE(:FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS'), DIATERMINACION=:DIATERMINACION, MESTERMINACION=:MESTERMINACION, ANOTERMINACION=:ANOTERMINACION, GRADUADO=:GRADUADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_FORMACION_ACADEMICA.COMPANIA= :KEY_COMPANIA AND NAT_FORMACION_ACADEMICA.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_FORMACION_ACADEMICA.SUCURSAL= :KEY_SUCURSAL AND NAT_FORMACION_ACADEMICA.NUMERO= :KEY_NUMERO AND NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA= :KEY_NFA_CODIGOPERSONA AND NAT_FORMACION_ACADEMICA.TITULOOBTENIDO= :KEY_TITULOOBTENIDO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="TITULOOBTENIDO" sqlType="STRING"/>
		<param name="NIVELAPROBADO" sqlType="STRING"/>
