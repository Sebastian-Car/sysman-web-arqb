			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_NFA_CODIGOPERSONA" query-param="KEY_NFA_CODIGOPERSONA"/>
			<with-param name="KEY_TITULOOBTENIDO" query-param="KEY_TITULOOBTENIDO"/>

		</call-query>
	</resource>
	<query id="getNatformacionacademicaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_FORMACION_ACADEMICA.COMPANIA, NAT_FORMACION_ACADEMICA.NUMERO_DCTO, NAT_FORMACION_ACADEMICA.SUCURSAL, NAT_FORMACION_ACADEMICA.NUMERO, NAT_FORMACION_ACADEMICA.NFA_CODIGOPERSONA, NAT_FORMACION_ACADEMICA.MODALIDAD, NAT_MODALIDAD_ESTUDIOSUPERIOR.MO_NOMBRE NOMBREMODALIDAD, NAT_FORMACION_ACADEMICA.TITULOOBTENIDO, NAT_FORMACION_ACADEMICA.NIVELAPROBADO, NAT_FORMACION_ACADEMICA.ESTABLECIMIENTO, INSTITUCIONES_EDUCATIVAS.NOMBRE NOMBRE_ESTABLECIMIENTO, NAT_FORMACION_ACADEMICA.TARJETAPROFESIONAL, NAT_FORMACION_ACADEMICA.PAIS, UPPER(PAISES.NOMBRE) NOMBREPAISACA, NAT_FORMACION_ACADEMICA.DEPARTAMENTO, DEPARTAMENTO.NOMBRE NOMBREDEPARTAMENTOACA, NAT_FORMACION_ACADEMICA.MUNICIPIO, CIUDAD.NOMBRE NOMBRECIUDADACA,(TO_CHAR(NAT_FORMACION_ACADEMICA.FECHATERMINACION,'DD/MM/YYYY HH24:MI:SS')) FECHATERMINACION, NAT_FORMACION_ACADEMICA.DIATERMINACION, NAT_FORMACION_ACADEMICA.MESTERMINACION, NAT_FORMACION_ACADEMICA.ANOTERMINACION,(CASE NAT_FORMACION_ACADEMICA.GRADUADO WHEN 0 THEN 'false' ELSE 'true' END) GRADUADO, PROFESIONES.NOMBRE_PROFESION  FROM NAT_FORMACION_ACADEMICA LEFT JOIN PAISES ON NAT_FORMACION_ACADEMICA.PAIS = PAISES.PAIS LEFT JOIN DEPARTAMENTO ON NAT_FORMACION_ACADEMICA.PAIS = DEPARTAMENTO.PAIS AND NAT_FORMACION_ACADEMICA.DEPARTAMENTO = DEPARTAMENTO.CODIGO LEFT JOIN CIUDAD ON NAT_FORMACION_ACADEMICA.PAIS = CIUDAD.PAIS AND NAT_FORMACION_ACADEMICA.DEPARTAMENTO = CIUDAD.DEPARTAMENTO AND NAT_FORMACION_ACADEMICA.MUNICIPIO = CIUDAD.CODIGO LEFT JOIN NAT_MODALIDAD_ESTUDIOSUPERIOR ON NAT_FORMACION_ACADEMICA.MODALIDAD = NAT_MODALIDAD_ESTUDIOSUPERIOR.MO_CODIGO LEFT JOIN PROFESIONES ON NAT_FORMACION_ACADEMICA.TITULOOBTENIDO = PROFESIONES.CODIGOPROF LEFT JOIN INSTITUCIONES_EDUCATIVAS ON NAT_FORMACION_ACADEMICA.ESTABLECIMIENTO = INSTITUCIONES_EDUCATIVAS.NIT WHERE NAT_FORMACION_ACADEMICA.COMPANIA = :COMPANIA AND NAT_FORMACION_ACADEMICA.NUMERO_DCTO = :NUMERO_DCTO AND NAT_FORMACION_ACADEMICA.SUCURSAL = :SUCURSAL ORDER BY NAT_FORMACION_ACADEMICA.ANOTERMINACION DESC) WHERE (CASE WHEN NOMBREMODALIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREMODALIDAD) END)  LIKE UPPER( '%' || :NOMBREMODALIDAD || '%')  AND (CASE WHEN NIVELAPROBADO IS NULL THEN ' ' ELSE UPPER(NIVELAPROBADO) END)  LIKE UPPER( '%' || :NIVELAPROBADO || '%')  AND (CASE WHEN NOMBRE_ESTABLECIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTABLECIMIENTO) END)  LIKE UPPER( '%' || :NOMBRE_ESTABLECIMIENTO || '%')  AND (CASE WHEN TARJETAPROFESIONAL IS NULL THEN ' ' ELSE UPPER(TARJETAPROFESIONAL) END)  LIKE UPPER( '%' || :TARJETAPROFESIONAL || '%')  AND (CASE WHEN NOMBREPAISACA IS NULL THEN ' ' ELSE UPPER(NOMBREPAISACA) END)  LIKE UPPER( '%' || :NOMBREPAISACA || '%')  AND (CASE WHEN NOMBREDEPARTAMENTOACA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPARTAMENTOACA) END)  LIKE UPPER( '%' || :NOMBREDEPARTAMENTOACA || '%')  AND (CASE WHEN NOMBRECIUDADACA IS NULL THEN ' ' ELSE UPPER(NOMBRECIUDADACA) END)  LIKE UPPER( '%' || :NOMBRECIUDADACA || '%')  AND (CASE WHEN FECHATERMINACION IS NULL THEN ' ' ELSE UPPER(FECHATERMINACION) END)  LIKE UPPER( '%' || :FECHATERMINACION || '%')  AND (CASE WHEN ANOTERMINACION IS NULL THEN ' ' ELSE UPPER(ANOTERMINACION) END)  LIKE UPPER( '%' || :ANOTERMINACION || '%')  AND (CASE WHEN GRADUADO IS NULL THEN ' ' ELSE UPPER(GRADUADO) END)  LIKE UPPER( '%' || :GRADUADO || '%')  AND (CASE WHEN NOMBRE_PROFESION IS NULL THEN ' ' ELSE UPPER(NOMBRE_PROFESION) END)  LIKE UPPER( '%' || :NOMBRE_PROFESION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NUMERO":"$NUMERO","NFA_CODIGOPERSONA":"$NFA_CODIGOPERSONA","MODALIDAD":"$MODALIDAD","NOMBREMODALIDAD":"$NOMBREMODALIDAD","TITULOOBTENIDO":"$TITULOOBTENIDO","NIVELAPROBADO":"$NIVELAPROBADO","ESTABLECIMIENTO":"$ESTABLECIMIENTO","NOMBRE_ESTABLECIMIENTO":"$NOMBRE_ESTABLECIMIENTO","TARJETAPROFESIONAL":"$TARJETAPROFESIONAL","PAIS":"$PAIS","NOMBREPAISACA":"$NOMBREPAISACA","DEPARTAMENTO":"$DEPARTAMENTO","NOMBREDEPARTAMENTOACA":"$NOMBREDEPARTAMENTOACA","MUNICIPIO":"$MUNICIPIO","NOMBRECIUDADACA":"$NOMBRECIUDADACA","FECHATERMINACION":"$FECHATERMINACION","DIATERMINACION":"$DIATERMINACION(type:integer)","MESTERMINACION":"$MESTERMINACION(type:integer)","ANOTERMINACION":"$ANOTERMINACION(type:integer)","GRADUADO":"$GRADUADO(type:boolean)","NOMBRE_PROFESION":"$NOMBRE_PROFESION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NOMBREMODALIDAD" sqlType="STRING"/>
		<param name="NIVELAPROBADO" sqlType="STRING"/>
