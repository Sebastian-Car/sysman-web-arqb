	<query id="insertDmovimientos" keyColumns="COMPANIA,TIPOMOVIMIENTO,MOVIMIENTO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_MOVIMIENTO (COMPANIA, TIPOMOVIMIENTO, MOVIMIENTO, CODIGO, ELEMENTO, SERIE, CANTIDAD, SALDOCANT, VLRUNITARIO_ANTESIVA, PORCIVA, VALORUNITARIO, VALORTOTAL, IND_REG, ESPECIFICACION, MARCA, SERIEDEVOLUTIVO, VALORBASE, VLRUNITARIOPROM, VALORANTERIOR, FECHA, HORA, VALORDOCAS, AJUSTECENTAVOS, AJUSTECENTAVOS1, AJUSTECREDITO, AJUSTEDEBITO, AREA, AUXILIAR, CANTANTERIOR, CANTIDADAFECTADA, CANTIDADDOCAS, CENTRODECOSTO, COD_CHIP, COMPROBACION, COSTOSALIDA, COSTOSALIDAAJ, CUENTACREDITO, CUENTADEBITO, DETERIORO, ENTREGA, ESCRITURA, ESTADO, FECHA_MODIFICA_PROMEDIO, FECHAADEPRECIAR, FECHAENTRADA, FECHAMOVIMIENTO, IDENTIFICADOR, INCREMENAJUS, INFINMUEBLE, INSTALACION, ITEM, MATINMOBILIARIA, MODIFICA_PROMEDIO, NIIF_TIPO_ACTIVO, NIIF_VALOR_BASE, NIIF_VALOR_TOTAL, NUMEROCATASTRAL, ORDENDESUMINISTRO, PEDIDO, PLACAANTERIOR, PORCDESCUENTO, PORCIVAUNI, PREPARACION, PROVEEDORCA, REGISTRADOBI, REVELACIONES, SALDO_PEPS, SALDOELEMENTO, SALDOKARDEX, SALVAMENTO, SUCURSALCA, VALORIVA, VALORSALDO, VALORTOTALCONIVA, VLRAJUSTADO, VLRUNITANTERIOR, VIDAUTILPLACA, VIDAUTILPLACANIIF, APLICANIIF, MODELO, COMPONENTE, FECHA_INSTALACION, ACTA_INSTALACION, DIRECCION, TIPOMOVIMIENTO_AFECT, MOVIMIENTO_AFECT, CODIGOPROYECTO, TIPOMOVASOCIADO, MOVASOCIADO, OPERACION, AUX_ALMACEN, RUEDA, PLACA_NIIF, REFERENCIA, UNIDAD, LOTE, TEMPERATURA, FECHA_VENCIMIENTO, REGISTRO_SANITARIO, UBICACION, FUENTEDERECURSO, VLR_COLGAAP, PORC_VALOR_RESIDUAL, REFERENCIA_CNT, VLRIMPCONSUMO, PORC_IMPCONSUMO, PORC_AIU, VLR_AIU, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOMOVIMIENTO, :MOVIMIENTO, :CODIGO, :ELEMENTO, :SERIE, :CANTIDAD, :SALDOCANT, :VLRUNITARIO_ANTESIVA, :PORCIVA, :VALORUNITARIO, :VALORTOTAL, :IND_REG, :ESPECIFICACION, :MARCA, :SERIEDEVOLUTIVO, :VALORBASE, :VLRUNITARIOPROM, :VALORANTERIOR, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE('30/12/1899' || TO_CHAR(CURRENT_DATE,' HH24:MI:SS'), 'DD/MM/YYYY HH24:MI:SS'), :VALORDOCAS, :AJUSTECENTAVOS, :AJUSTECENTAVOS1, :AJUSTECREDITO, :AJUSTEDEBITO, :AREA, :AUXILIAR, :CANTANTERIOR, :CANTIDADAFECTADA, :CANTIDADDOCAS, :CENTRODECOSTO, :COD_CHIP, :COMPROBACION, :COSTOSALIDA, :COSTOSALIDAAJ, :CUENTACREDITO, :CUENTADEBITO, :DETERIORO, :ENTREGA, :ESCRITURA, :ESTADO, TO_DATE(:FECHA_MODIFICA_PROMEDIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAADEPRECIAR,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAENTRADA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAMOVIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :IDENTIFICADOR, :INCREMENAJUS, :INFINMUEBLE, :INSTALACION, :ITEM, :MATINMOBILIARIA, :MODIFICA_PROMEDIO, :NIIF_TIPO_ACTIVO, :NIIF_VALOR_BASE, :NIIF_VALOR_TOTAL, :NUMEROCATASTRAL, :ORDENDESUMINISTRO, :PEDIDO, :PLACAANTERIOR, :PORCDESCUENTO, :PORCIVAUNI, :PREPARACION, :PROVEEDORCA, :REGISTRADOBI, :REVELACIONES, :SALDO_PEPS, :SALDOELEMENTO, :SALDOKARDEX, :SALVAMENTO, :SUCURSALCA, :VALORIVA, :VALORSALDO, :VALORTOTALCONIVA, :VLRAJUSTADO, :VLRUNITANTERIOR, :VIDAUTILPLACA, :VIDAUTILPLACANIIF, :APLICANIIF, :MODELO, :COMPONENTE, TO_DATE(:FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS'), :ACTA_INSTALACION, :DIRECCION, :TIPOMOVIMIENTO_AFECT, :MOVIMIENTO_AFECT, :CODIGOPROYECTO, :TIPOMOVASOCIADO, :MOVASOCIADO, :OPERACION, :AUX_ALMACEN, :RUEDA, :PLACA_NIIF, :REFERENCIA, :UNIDAD, :LOTE, :TEMPERATURA, TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :REGISTRO_SANITARIO, :UBICACION, :FUENTEDERECURSO, :VLR_COLGAAP, :PORC_VALOR_RESIDUAL, :REFERENCIA_CNT, :VLRIMPCONSUMO, :PORC_IMPCONSUMO, :PORC_AIU, :VLR_AIU, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","KEY_MOVIMIENTO":"$MOVIMIENTO","KEY_CODIGO":"$CODIGO"}]}}		</result>
