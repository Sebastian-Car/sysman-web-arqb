			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>

		</call-query>
	</resource>
	<query id="getDmovimientosPagTodosPorSerieTipoElementoDnQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_MOVIMIENTO.CODIGO , D_MOVIMIENTO.TIPOMOVIMIENTO TIPO_MOV , D_MOVIMIENTO.MOVIMIENTO NUMERO , TIPOMOVIMIENTO.NOMBRE NOMBRE_MOVIMIENTO , D_MOVIMIENTO.VALORTOTAL , TO_CHAR(TRUNC(D_MOVIMIENTO.FECHA),'DD/MM/YYYY') FECHA  FROM D_MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON D_MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO INNER JOIN V_MOVIMIENTO ON D_MOVIMIENTO.COMPANIA = V_MOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = V_MOVIMIENTO.TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO = V_MOVIMIENTO.NUMERO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND D_MOVIMIENTO.SERIE = :SERIE AND TIPOMOVIMIENTO.TIPOELEMENTO IN ('D','N') AND TIPOMOVIMIENTO.CONCEPTO = 'CR' AND D_MOVIMIENTO.IND_REG NOT IN (0)) WHERE (CASE WHEN TIPO_MOV IS NULL THEN ' ' ELSE UPPER(TIPO_MOV) END)  LIKE UPPER(:TIPO_MOV || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN NOMBRE_MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_MOVIMIENTO) END)  LIKE UPPER( '%' || :NOMBRE_MOVIMIENTO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER(:VALORTOTAL || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","TIPO_MOV":"$TIPO_MOV","NUMERO":"$NUMERO","NOMBRE_MOVIMIENTO":"$NOMBRE_MOVIMIENTO","VALORTOTAL":"$VALORTOTAL","FECHA":"$FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="TIPO_MOV" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE_MOVIMIENTO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dmovimientos/todosporserietipoelementodn/pag">
