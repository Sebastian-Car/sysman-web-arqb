			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getDmovimientosExisteMenorASerieQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM D_MOVIMIENTO WHERE D_MOVIMIENTO.ELEMENTO= :ELEMENTO AND D_MOVIMIENTO.ELEMENTO IS NOT NULL AND D_MOVIMIENTO.SERIE NOT IN(0) AND D_MOVIMIENTO.SERIE &lt;= :SERIE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>

	</query>
