<data name="dmovimientos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDmovimientosPagTodosPorAuxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DM.COMPANIA, DM.TIPOMOVIMIENTO, DM.MOVIMIENTO, DM.CODIGO, DM.ELEMENTO, DM.CANTIDAD, DM.VALORUNITARIO, DM.VALORTOTAL, M.DESCRIPCION, I.NOMBRELARGO NOM_ELEMENTO, DEP.NOMBRE NOM_DEPENDENCIA, DM.TERCERO ID_TERCERO, DM.SUCURSAL, T.NOMBRE NOMBRE_TERCERO, DM.AUXILIAR, A.NOMBRE NOMBRE_AUXILIAR  FROM D_MOVIMIENTO DM INNER JOIN MOVIMIENTO M ON DM.COMPANIA = M.COMPANIA AND DM.TIPOMOVIMIENTO = M.TIPOMOVIMIENTO AND DM.MOVIMIENTO = M.NUMERO INNER JOIN TERCERO T ON DM.COMPANIA = T.COMPANIA AND DM.TERCERO = T.NIT AND DM.SUCURSAL = T.SUCURSAL INNER JOIN AUXILIAR A ON DM.COMPANIA = A.COMPANIA AND TO_NUMBER(TO_CHAR(DM.FECHA, 'YYYY')) = A.ANO AND DM.AUXILIAR = A.CODIGO INNER JOIN INVENTARIO I ON DM.COMPANIA = I.COMPANIA AND DM.ELEMENTO = I.CODIGOELEMENTO INNER JOIN DEPENDENCIA DEP ON M.COMPANIA = DEP.COMPANIA AND M.DEPENDENCIA_DESTINO = DEP.CODIGO WHERE DM.COMPANIA = :COMPANIA AND TO_NUMBER(TO_CHAR(DM.FECHA, 'YYYY')) = :ANO AND TO_NUMBER(TO_CHAR(DM.FECHA, 'MM')) BETWEEN :MESINICIAL AND :MESFINAL AND M.AUXILIAR = :AUXILIAR ORDER BY DM.COMPANIA, DM.TIPOMOVIMIENTO, DM.MOVIMIENTO, DM.CODIGO) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER( '%' || :CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER( '%' || :VALORUNITARIO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER( '%' || :VALORTOTAL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOM_ELEMENTO IS NULL THEN ' ' ELSE UPPER(NOM_ELEMENTO) END)  LIKE UPPER( '%' || :NOM_ELEMENTO || '%')  AND (CASE WHEN NOM_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOM_DEPENDENCIA) END)  LIKE UPPER( '%' || :NOM_DEPENDENCIA || '%')  AND (CASE WHEN ID_TERCERO IS NULL THEN ' ' ELSE UPPER(ID_TERCERO) END)  LIKE UPPER( '%' || :ID_TERCERO || '%')  AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END)  LIKE UPPER( '%' || :NOMBRE_TERCERO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER( '%' || :AUXILIAR || '%')  AND (CASE WHEN NOMBRE_AUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUXILIAR) END)  LIKE UPPER( '%' || :NOMBRE_AUXILIAR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","MOVIMIENTO":"$MOVIMIENTO(type:long)","CODIGO":"$CODIGO(type:long)","ELEMENTO":"$ELEMENTO","CANTIDAD":"$CANTIDAD(type:double)","VALORUNITARIO":"$VALORUNITARIO(type:double)","VALORTOTAL":"$VALORTOTAL(type:double)","DESCRIPCION":"$DESCRIPCION","NOM_ELEMENTO":"$NOM_ELEMENTO","NOM_DEPENDENCIA":"$NOM_DEPENDENCIA","ID_TERCERO":"$ID_TERCERO","SUCURSAL":"$SUCURSAL","NOMBRE_TERCERO":"$NOMBRE_TERCERO","AUXILIAR":"$AUXILIAR","NOMBRE_AUXILIAR":"$NOMBRE_AUXILIAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOM_ELEMENTO" sqlType="STRING"/>
		<param name="NOM_DEPENDENCIA" sqlType="STRING"/>
		<param name="ID_TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_AUXILIAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dmovimientos/todosporauxiliar/pag">
		<call-query href="getDmovimientosPagTodosPorAuxiliarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MESINICIAL" query-param="MESINICIAL"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VALORTOTAL" query-param="VALORTOTAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOM_ELEMENTO" query-param="NOM_ELEMENTO"/>
			<with-param name="NOM_DEPENDENCIA" query-param="NOM_DEPENDENCIA"/>
			<with-param name="ID_TERCERO" query-param="ID_TERCERO"/>
			<with-param name="NOMBRE_TERCERO" query-param="NOMBRE_TERCERO"/>
			<with-param name="NOMBRE_AUXILIAR" query-param="NOMBRE_AUXILIAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDmovimientosNumTodosPorAuxiliarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DM.COMPANIA, DM.TIPOMOVIMIENTO, DM.MOVIMIENTO, DM.CODIGO, DM.ELEMENTO, DM.CANTIDAD, DM.VALORUNITARIO, DM.VALORTOTAL, M.DESCRIPCION, I.NOMBRELARGO NOM_ELEMENTO, DEP.NOMBRE NOM_DEPENDENCIA, DM.TERCERO ID_TERCERO, DM.SUCURSAL, T.NOMBRE NOMBRE_TERCERO, DM.AUXILIAR, A.NOMBRE NOMBRE_AUXILIAR  FROM D_MOVIMIENTO DM INNER JOIN MOVIMIENTO M ON DM.COMPANIA = M.COMPANIA AND DM.TIPOMOVIMIENTO = M.TIPOMOVIMIENTO AND DM.MOVIMIENTO = M.NUMERO INNER JOIN TERCERO T ON DM.COMPANIA = T.COMPANIA AND DM.TERCERO = T.NIT AND DM.SUCURSAL = T.SUCURSAL INNER JOIN AUXILIAR A ON DM.COMPANIA = A.COMPANIA AND TO_NUMBER(TO_CHAR(DM.FECHA, 'YYYY')) = A.ANO AND DM.AUXILIAR = A.CODIGO INNER JOIN INVENTARIO I ON DM.COMPANIA = I.COMPANIA AND DM.ELEMENTO = I.CODIGOELEMENTO INNER JOIN DEPENDENCIA DEP ON M.COMPANIA = DEP.COMPANIA AND M.DEPENDENCIA_DESTINO = DEP.CODIGO WHERE DM.COMPANIA = :COMPANIA AND TO_NUMBER(TO_CHAR(DM.FECHA, 'YYYY')) = :ANO AND TO_NUMBER(TO_CHAR(DM.FECHA, 'MM')) BETWEEN :MESINICIAL AND :MESFINAL AND M.AUXILIAR = :AUXILIAR ORDER BY DM.COMPANIA, DM.TIPOMOVIMIENTO, DM.MOVIMIENTO, DM.CODIGO) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER( '%' || :CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER( '%' || :VALORUNITARIO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER( '%' || :VALORTOTAL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOM_ELEMENTO IS NULL THEN ' ' ELSE UPPER(NOM_ELEMENTO) END)  LIKE UPPER( '%' || :NOM_ELEMENTO || '%')  AND (CASE WHEN NOM_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOM_DEPENDENCIA) END)  LIKE UPPER( '%' || :NOM_DEPENDENCIA || '%')  AND (CASE WHEN ID_TERCERO IS NULL THEN ' ' ELSE UPPER(ID_TERCERO) END)  LIKE UPPER( '%' || :ID_TERCERO || '%')  AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END)  LIKE UPPER( '%' || :NOMBRE_TERCERO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER( '%' || :AUXILIAR || '%')  AND (CASE WHEN NOMBRE_AUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUXILIAR) END)  LIKE UPPER( '%' || :NOMBRE_AUXILIAR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MESINICIAL" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOM_ELEMENTO" sqlType="STRING"/>
		<param name="NOM_DEPENDENCIA" sqlType="STRING"/>
		<param name="ID_TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_AUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/todosporauxiliar/num">
		<call-query href="getDmovimientosNumTodosPorAuxiliarQuery">
