	<query id="updateDmovimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_MOVIMIENTO SET ELEMENTO=:ELEMENTO, SERIE=:SERIE, CANTIDAD=:CANTIDAD, SALDOCANT=:SALDOCANT, VLRUNITARIO_ANTESIVA=:VLRUNITARIO_ANTESIVA, PORCIVA=:PORCIVA, VALORUNITARIO=:VALORUNITARIO, VALORTOTAL=:VALORTOTAL, IND_REG=:IND_REG, ESPECIFICACION=:ESPECIFICACION, MARCA=:MARCA, SERIEDEVOLUTIVO=:SERIEDEVOLUTIVO, VALORBASE=:VALORBASE, VLRUNITARIOPROM=:VLRUNITARIOPROM, VALORANTERIOR=:VALORANTERIOR, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), HORA=TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), VALORDOCAS=:VALORDOCAS, AJUSTECENTAVOS=:AJUSTECENTAVOS, AJUSTECENTAVOS1=:AJUSTECENTAVOS1, AJUSTECREDITO=:AJUSTECREDITO, AJUSTEDEBITO=:AJUSTEDEBITO, AREA=:AREA, AUXILIAR=:AUXILIAR, CANTANTERIOR=:CANTANTERIOR, CANTIDADAFECTADA=:CANTIDADAFECTADA, CANTIDADDOCAS=:CANTIDADDOCAS, CENTRODECOSTO=:CENTRODECOSTO, COD_CHIP=:COD_CHIP, COMPROBACION=:COMPROBACION, COSTOSALIDA=:COSTOSALIDA, COSTOSALIDAAJ=:COSTOSALIDAAJ, CUENTACREDITO=:CUENTACREDITO, CUENTADEBITO=:CUENTADEBITO, DETERIORO=:DETERIORO, ENTREGA=:ENTREGA, ESCRITURA=:ESCRITURA, ESTADO=:ESTADO, FECHA_MODIFICA_PROMEDIO=TO_DATE(:FECHA_MODIFICA_PROMEDIO,'DD/MM/YYYY HH24:MI:SS'), FECHAADEPRECIAR=TO_DATE(:FECHAADEPRECIAR,'DD/MM/YYYY HH24:MI:SS'), FECHAENTRADA=TO_DATE(:FECHAENTRADA,'DD/MM/YYYY HH24:MI:SS'), FECHAMOVIMIENTO=TO_DATE(:FECHAMOVIMIENTO,'DD/MM/YYYY HH24:MI:SS'), IDENTIFICADOR=:IDENTIFICADOR, INCREMENAJUS=:INCREMENAJUS, INFINMUEBLE=:INFINMUEBLE, INSTALACION=:INSTALACION, ITEM=:ITEM, MATINMOBILIARIA=:MATINMOBILIARIA, MODIFICA_PROMEDIO=:MODIFICA_PROMEDIO, NIIF_TIPO_ACTIVO=:NIIF_TIPO_ACTIVO, NIIF_VALOR_BASE=:NIIF_VALOR_BASE, NIIF_VALOR_TOTAL=:NIIF_VALOR_TOTAL, NUMEROCATASTRAL=:NUMEROCATASTRAL, ORDENDESUMINISTRO=:ORDENDESUMINISTRO, PEDIDO=:PEDIDO, PLACAANTERIOR=:PLACAANTERIOR, PORCDESCUENTO=:PORCDESCUENTO, PORCIVAUNI=:PORCIVAUNI, PREPARACION=:PREPARACION, PROVEEDORCA=:PROVEEDORCA, REGISTRADOBI=:REGISTRADOBI, REVELACIONES=:REVELACIONES, SALDO_PEPS=:SALDO_PEPS, SALDOELEMENTO=:SALDOELEMENTO, SALDOKARDEX=:SALDOKARDEX, SALVAMENTO=:SALVAMENTO, SUCURSALCA=:SUCURSALCA, VALORIVA=:VALORIVA, VALORSALDO=:VALORSALDO, VALORTOTALCONIVA=:VALORTOTALCONIVA, VLRAJUSTADO=:VLRAJUSTADO, VLRUNITANTERIOR=:VLRUNITANTERIOR, VIDAUTILPLACA=:VIDAUTILPLACA, VIDAUTILPLACANIIF=:VIDAUTILPLACANIIF, APLICANIIF=:APLICANIIF, MODELO=:MODELO, DIRECCION=:DIRECCION, COMPONENTE=:COMPONENTE, FECHA_INSTALACION=TO_DATE(:FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS'), ACTA_INSTALACION=:ACTA_INSTALACION, PLACA_NIIF=:PLACA_NIIF, REFERENCIA=:REFERENCIA, UNIDAD=:UNIDAD, LOTE=:LOTE, TEMPERATURA=:TEMPERATURA, FECHA_VENCIMIENTO=TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), REGISTRO_SANITARIO=:REGISTRO_SANITARIO, FUENTEDERECURSO=:FUENTEDERECURSO, VLR_COLGAAP=:VLR_COLGAAP, PORC_VALOR_RESIDUAL=:PORC_VALOR_RESIDUAL, CODIGO_AFECT=:CODIGO_AFECT, REFERENCIA_CNT=:REFERENCIA_CNT, CODIGOPROYECTO=:CODIGOPROYECTO, VLRIMPCONSUMO=:VLRIMPCONSUMO, PORC_IMPCONSUMO=:PORC_IMPCONSUMO, PORC_AIU=:PORC_AIU, VLR_AIU=:VLR_AIU, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_MOVIMIENTO.COMPANIA= :KEY_COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO= :KEY_MOVIMIENTO AND D_MOVIMIENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

