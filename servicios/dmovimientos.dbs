	<query id="getDmovimientosNumTodosPorSerieTipoElementoDnQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_MOVIMIENTO.CODIGO , D_MOVIMIENTO.TIPOMOVIMIENTO TIPO_MOV , D_MOVIMIENTO.MOVIMIENTO NUMERO , TIPOMOVIMIENTO.NOMBRE NOMBRE_MOVIMIENTO , D_MOVIMIENTO.VALORTOTAL , TO_CHAR(TRUNC(D_MOVIMIENTO.FECHA),'DD/MM/YYYY') FECHA  FROM D_MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON D_MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO INNER JOIN V_MOVIMIENTO ON D_MOVIMIENTO.COMPANIA = V_MOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = V_MOVIMIENTO.TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO = V_MOVIMIENTO.NUMERO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND D_MOVIMIENTO.SERIE = :SERIE AND TIPOMOVIMIENTO.TIPOELEMENTO IN ('D','N') AND TIPOMOVIMIENTO.CONCEPTO = 'CR' AND D_MOVIMIENTO.IND_REG NOT IN (0)) WHERE (CASE WHEN TIPO_MOV IS NULL THEN ' ' ELSE UPPER(TIPO_MOV) END)  LIKE UPPER(:TIPO_MOV || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN NOMBRE_MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_MOVIMIENTO) END)  LIKE UPPER( '%' || :NOMBRE_MOVIMIENTO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER( '%' || :VALORTOTAL || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="TIPO_MOV" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE_MOVIMIENTO" sqlType="STRING"/>
		<param name="VALORTOTAL" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/todosporserietipoelementodn/num">
