			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="LOTE" query-param="LOTE"/>
			<with-param name="TEMPERATURA" query-param="TEMPERATURA"/>
			<with-param name="FECHA_VENCIMIENTO" query-param="FECHA_VENCIMIENTO"/>
			<with-param name="REGISTRO_SANITARIO" query-param="REGISTRO_SANITARIO"/>
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="FUENTEDERECURSO" query-param="FUENTEDERECURSO"/>
			<with-param name="VLR_COLGAAP" query-param="VLR_COLGAAP"/>
			<with-param name="PORC_VALOR_RESIDUAL" query-param="PORC_VALOR_RESIDUAL"/>
			<with-param name="REFERENCIA_CNT" query-param="REFERENCIA_CNT"/>
			<with-param name="VLRIMPCONSUMO" query-param="VLRIMPCONSUMO"/>
			<with-param name="PORC_IMPCONSUMO" query-param="PORC_IMPCONSUMO"/>
			<with-param name="PORC_AIU" query-param="PORC_AIU"/>
			<with-param name="VLR_AIU" query-param="VLR_AIU"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDmovimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_MOVIMIENTO WHERE D_MOVIMIENTO.COMPANIA= :KEY_COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO= :KEY_MOVIMIENTO AND D_MOVIMIENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_MOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dmovimientos">
		<call-query href="deleteDmovimientos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_MOVIMIENTO" query-param="KEY_MOVIMIENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getDmovimientosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D_MOVIMIENTO.COMPANIA, D_MOVIMIENTO.TIPOMOVIMIENTO, D_MOVIMIENTO.MOVIMIENTO, D_MOVIMIENTO.CODIGO, D_MOVIMIENTO.ELEMENTO, D_MOVIMIENTO.ELEMENTO ELEMENTO_PEPS, D_MOVIMIENTO.SERIE, D_MOVIMIENTO.PLACA_NIIF, INVENTARIO.NOMBRELARGO, D_MOVIMIENTO.CANTIDAD, D_MOVIMIENTO.SALDOCANT, D_MOVIMIENTO.VLRUNITARIO_ANTESIVA, D_MOVIMIENTO.PORCIVA, D_MOVIMIENTO.VALORUNITARIO, D_MOVIMIENTO.VALORTOTAL,(CASE D_MOVIMIENTO.IND_REG WHEN 0 THEN 'false' ELSE 'true' END) IND_REG, D_MOVIMIENTO.ESPECIFICACION, D_MOVIMIENTO.MARCA, D_MOVIMIENTO.SERIEDEVOLUTIVO, D_MOVIMIENTO.VALORBASE, D_MOVIMIENTO.VLRUNITARIOPROM, D_MOVIMIENTO.VALORANTERIOR,(TO_CHAR(D_MOVIMIENTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(D_MOVIMIENTO.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, D_MOVIMIENTO.VALORDOCAS, D_MOVIMIENTO.AJUSTECENTAVOS, D_MOVIMIENTO.AJUSTECENTAVOS1, D_MOVIMIENTO.AJUSTECREDITO, D_MOVIMIENTO.AJUSTEDEBITO, D_MOVIMIENTO.AREA, D_MOVIMIENTO.AUXILIAR, D_MOVIMIENTO.CANTANTERIOR, D_MOVIMIENTO.CANTIDADAFECTADA, D_MOVIMIENTO.CANTIDADDOCAS, D_MOVIMIENTO.CENTRODECOSTO, D_MOVIMIENTO.COD_CHIP, D_MOVIMIENTO.COMPROBACION, D_MOVIMIENTO.COSTOSALIDA, D_MOVIMIENTO.COSTOSALIDAAJ, D_MOVIMIENTO.CUENTACREDITO, D_MOVIMIENTO.CUENTADEBITO, D_MOVIMIENTO.DETERIORO, D_MOVIMIENTO.ENTREGA, D_MOVIMIENTO.ESCRITURA, D_MOVIMIENTO.ESTADO,(TO_CHAR(D_MOVIMIENTO.FECHA_MODIFICA_PROMEDIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_MODIFICA_PROMEDIO,(TO_CHAR(D_MOVIMIENTO.FECHAADEPRECIAR,'DD/MM/YYYY HH24:MI:SS')) FECHAADEPRECIAR,(TO_CHAR(D_MOVIMIENTO.FECHAENTRADA,'DD/MM/YYYY HH24:MI:SS')) FECHAENTRADA,(TO_CHAR(D_MOVIMIENTO.FECHAMOVIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAMOVIMIENTO, D_MOVIMIENTO.IDENTIFICADOR, D_MOVIMIENTO.INCREMENAJUS,(CASE D_MOVIMIENTO.INFINMUEBLE WHEN 0 THEN 'false' ELSE 'true' END) INFINMUEBLE, D_MOVIMIENTO.INSTALACION, D_MOVIMIENTO.ITEM, D_MOVIMIENTO.MATINMOBILIARIA, D_MOVIMIENTO.MODIFICA_PROMEDIO, D_MOVIMIENTO.NIIF_TIPO_ACTIVO, D_MOVIMIENTO.NIIF_VALOR_BASE, D_MOVIMIENTO.NIIF_VALOR_TOTAL, D_MOVIMIENTO.NUMEROCATASTRAL, D_MOVIMIENTO.ORDENDESUMINISTRO, D_MOVIMIENTO.PEDIDO, D_MOVIMIENTO.PLACAANTERIOR, D_MOVIMIENTO.PORCDESCUENTO, D_MOVIMIENTO.PORCIVAUNI, D_MOVIMIENTO.PREPARACION, D_MOVIMIENTO.PROVEEDORCA,(CASE D_MOVIMIENTO.REGISTRADOBI WHEN 0 THEN 'false' ELSE 'true' END) REGISTRADOBI, D_MOVIMIENTO.REVELACIONES, D_MOVIMIENTO.SALDO_PEPS, D_MOVIMIENTO.SALDOELEMENTO, D_MOVIMIENTO.SALDOKARDEX, D_MOVIMIENTO.SALVAMENTO, D_MOVIMIENTO.SUCURSALCA, D_MOVIMIENTO.VALORIVA, D_MOVIMIENTO.VALORSALDO, D_MOVIMIENTO.VALORTOTALCONIVA, D_MOVIMIENTO.VLRAJUSTADO, D_MOVIMIENTO.VLRUNITANTERIOR, D_MOVIMIENTO.VIDAUTILPLACA, D_MOVIMIENTO.VIDAUTILPLACANIIF,(CASE D_MOVIMIENTO.APLICANIIF WHEN 0 THEN 'false' ELSE 'true' END) APLICANIIF, D_MOVIMIENTO.MODELO, D_MOVIMIENTO.COMPONENTE,(TO_CHAR(D_MOVIMIENTO.FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_INSTALACION, D_MOVIMIENTO.ACTA_INSTALACION,D_MOVIMIENTO.REFERENCIA, D_MOVIMIENTO.UNIDAD, D_MOVIMIENTO.LOTE, D_MOVIMIENTO.TEMPERATURA,(TO_CHAR(D_MOVIMIENTO.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, D_MOVIMIENTO.REGISTRO_SANITARIO,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO,D_MOVIMIENTO.FUENTEDERECURSO,D_MOVIMIENTO.VLR_COLGAAP, D_MOVIMIENTO.PORC_VALOR_RESIDUAL,D_MOVIMIENTO.CODIGO_AFECT,D_MOVIMIENTO.REFERENCIA_CNT,D_MOVIMIENTO.CODIGOPROYECTO, D_MOVIMIENTO.VLRIMPCONSUMO, D_MOVIMIENTO.PORC_IMPCONSUMO,D_MOVIMIENTO.PORC_AIU ,D_MOVIMIENTO.VLR_AIU FROM D_MOVIMIENTO INNER JOIN INVENTARIO ON D_MOVIMIENTO.COMPANIA = INVENTARIO.COMPANIA AND D_MOVIMIENTO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = :TIPO AND D_MOVIMIENTO.MOVIMIENTO = :NUMERO) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN ELEMENTO_PEPS IS NULL THEN ' ' ELSE UPPER(ELEMENTO_PEPS) END) LIKE UPPER(CONCAT(:ELEMENTO_PEPS, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN PLACA_NIIF IS NULL THEN ' ' ELSE UPPER(PLACA_NIIF) END) LIKE UPPER(CONCAT(:PLACA_NIIF, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(:NOMBRELARGO, '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDAD), '%')) AND (CASE WHEN SALDOCANT IS NULL THEN ' ' ELSE UPPER(SALDOCANT) END) LIKE UPPER(CONCAT(:SALDOCANT, '%')) AND (CASE WHEN VLRUNITARIO_ANTESIVA IS NULL THEN ' ' ELSE UPPER(VLRUNITARIO_ANTESIVA) END) LIKE UPPER(CONCAT(:VLRUNITARIO_ANTESIVA, '%')) AND (CASE WHEN PORCIVA IS NULL THEN ' ' ELSE UPPER(PORCIVA) END) LIKE UPPER(CONCAT(:PORCIVA, '%')) AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END) LIKE UPPER(CONCAT(:VALORUNITARIO, '%')) AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END) LIKE UPPER(CONCAT(:VALORTOTAL, '%')) AND (CASE WHEN IND_REG IS NULL THEN ' ' ELSE UPPER(IND_REG) END) LIKE UPPER(CONCAT(:IND_REG, '%')) AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END) LIKE UPPER(CONCAT(:ESPECIFICACION, '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(CONCAT('%',:MARCA), '%')) AND (CASE WHEN SERIEDEVOLUTIVO IS NULL THEN ' ' ELSE UPPER(SERIEDEVOLUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIEDEVOLUTIVO), '%')) AND (CASE WHEN VALORBASE IS NULL THEN ' ' ELSE UPPER(VALORBASE) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORBASE), '%')) AND (CASE WHEN VLRUNITARIOPROM IS NULL THEN ' ' ELSE UPPER(VLRUNITARIOPROM) END) LIKE UPPER(CONCAT(:VLRUNITARIOPROM, '%')) AND (CASE WHEN VALORANTERIOR IS NULL THEN ' ' ELSE UPPER(VALORANTERIOR) END) LIKE UPPER(CONCAT(:VALORANTERIOR, '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END) LIKE UPPER(CONCAT(:HORA, '%')) AND (CASE WHEN VALORDOCAS IS NULL THEN ' ' ELSE UPPER(VALORDOCAS) END) LIKE UPPER(CONCAT(:VALORDOCAS, '%')) AND (CASE WHEN AJUSTECENTAVOS IS NULL THEN ' ' ELSE UPPER(AJUSTECENTAVOS) END) LIKE UPPER(CONCAT(CONCAT('%',:AJUSTECENTAVOS), '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(CONCAT('%',:AUXILIAR), '%')) AND (CASE WHEN CENTRODECOSTO IS NULL THEN ' ' ELSE UPPER(CENTRODECOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTRODECOSTO), '%')) AND (CASE WHEN COMPROBACION IS NULL THEN ' ' ELSE UPPER(COMPROBACION) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPROBACION), '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(CONCAT('%',:DETERIORO), '%')) AND (CASE WHEN ENTREGA IS NULL THEN ' ' ELSE UPPER(ENTREGA) END) LIKE UPPER(CONCAT(CONCAT('%',:ENTREGA), '%')) AND (CASE WHEN INSTALACION IS NULL THEN ' ' ELSE UPPER(INSTALACION) END) LIKE UPPER(CONCAT(CONCAT('%',:INSTALACION), '%')) AND (CASE WHEN NIIF_TIPO_ACTIVO IS NULL THEN ' ' ELSE UPPER(NIIF_TIPO_ACTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NIIF_TIPO_ACTIVO), '%')) AND (CASE WHEN NIIF_VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:NIIF_VALOR_TOTAL), '%')) AND (CASE WHEN PREPARACION IS NULL THEN ' ' ELSE UPPER(PREPARACION) END) LIKE UPPER(CONCAT(CONCAT('%',:PREPARACION), '%')) AND (CASE WHEN REVELACIONES IS NULL THEN ' ' ELSE UPPER(REVELACIONES) END) LIKE UPPER(CONCAT(CONCAT('%',:REVELACIONES), '%')) AND (CASE WHEN SALVAMENTO IS NULL THEN ' ' ELSE UPPER(SALVAMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:SALVAMENTO), '%')) AND (CASE WHEN VIDAUTILPLACA IS NULL THEN ' ' ELSE UPPER(VIDAUTILPLACA) END) LIKE UPPER(CONCAT(CONCAT('%',:VIDAUTILPLACA), '%')) AND (CASE WHEN VIDAUTILPLACANIIF IS NULL THEN ' ' ELSE UPPER(VIDAUTILPLACANIIF) END) LIKE UPPER(CONCAT(CONCAT('%',:VIDAUTILPLACANIIF), '%')) AND (CASE WHEN APLICANIIF IS NULL THEN ' ' ELSE UPPER(APLICANIIF) END) LIKE UPPER(CONCAT(CONCAT('%',:APLICANIIF), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(CONCAT('%',:MODELO), '%')) AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPONENTE), '%')) AND (CASE WHEN FECHA_INSTALACION IS NULL THEN ' ' ELSE UPPER(FECHA_INSTALACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INSTALACION), '%')) AND (CASE WHEN ACTA_INSTALACION IS NULL THEN ' ' ELSE UPPER(ACTA_INSTALACION) END) LIKE UPPER(CONCAT(CONCAT('%',:ACTA_INSTALACION), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA), '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:UNIDAD), '%')) AND (CASE WHEN LOTE IS NULL THEN ' ' ELSE UPPER(LOTE) END) LIKE UPPER(CONCAT(CONCAT('%',:LOTE), '%')) AND (CASE WHEN TEMPERATURA IS NULL THEN ' ' ELSE UPPER(TEMPERATURA) END) LIKE UPPER(CONCAT(CONCAT('%',:TEMPERATURA), '%')) AND (CASE WHEN FECHA_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHA_VENCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_VENCIMIENTO), '%')) AND (CASE WHEN REGISTRO_SANITARIO IS NULL THEN ' ' ELSE UPPER(REGISTRO_SANITARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:REGISTRO_SANITARIO), '%')) AND (CASE WHEN FUENTEDERECURSO IS NULL THEN ' ' ELSE UPPER(FUENTEDERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTEDERECURSO), '%')) AND (CASE WHEN  REFERENCIA_CNT IS NULL THEN ' ' ELSE UPPER(REFERENCIA_CNT) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA_CNT), '%')) AND (CASE WHEN CODIGOPROYECTO IS NULL THEN ' ' ELSE UPPER(CODIGOPROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPROYECTO), '%')) AND (CASE WHEN VLRIMPCONSUMO IS NULL THEN ' ' ELSE UPPER(VLRIMPCONSUMO) END) LIKE UPPER(CONCAT(:VLRIMPCONSUMO, '%')) AND (CASE WHEN PORC_IMPCONSUMO IS NULL THEN ' ' ELSE UPPER(PORC_IMPCONSUMO) END) LIKE UPPER(CONCAT(:PORC_IMPCONSUMO, '%')) AND (CASE WHEN PORC_AIU IS NULL THEN ' ' ELSE UPPER(PORC_AIU) END) LIKE UPPER(CONCAT(CONCAT('%',:PORC_AIU), '%')) AND (CASE WHEN VLR_AIU IS NULL THEN ' ' ELSE UPPER(VLR_AIU) END) LIKE UPPER(CONCAT(CONCAT('%',:VLR_AIU), '%')) ) A WHERE ROWNUM  &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","MOVIMIENTO":"$MOVIMIENTO","CODIGO":"$CODIGO","ELEMENTO":"$ELEMENTO","ELEMENTO_PEPS":"$ELEMENTO_PEPS","SERIE":"$SERIE","PLACA_NIIF":"$PLACA_NIIF(type:long)","NOMBRELARGO":"$NOMBRELARGO","CANTIDAD":"$CANTIDAD","SALDOCANT":"$SALDOCANT","VLRUNITARIO_ANTESIVA":"$VLRUNITARIO_ANTESIVA","PORCIVA":"$PORCIVA","VALORUNITARIO":"$VALORUNITARIO","VALORTOTAL":"$VALORTOTAL","IND_REG":"$IND_REG(type:boolean)","ESPECIFICACION":"$ESPECIFICACION","MARCA":"$MARCA","SERIEDEVOLUTIVO":"$SERIEDEVOLUTIVO","VALORBASE":"$VALORBASE","VLRUNITARIOPROM":"$VLRUNITARIOPROM","VALORANTERIOR":"$VALORANTERIOR","FECHA":"$FECHA","HORA":"$HORA","VALORDOCAS":"$VALORDOCAS","AJUSTECENTAVOS":"$AJUSTECENTAVOS","AJUSTECENTAVOS1":"$AJUSTECENTAVOS1","AJUSTECREDITO":"$AJUSTECREDITO","AJUSTEDEBITO":"$AJUSTEDEBITO","AREA":"$AREA","AUXILIAR":"$AUXILIAR","CANTANTERIOR":"$CANTANTERIOR","CANTIDADAFECTADA":"$CANTIDADAFECTADA","CANTIDADDOCAS":"$CANTIDADDOCAS","CENTRODECOSTO":"$CENTRODECOSTO","COD_CHIP":"$COD_CHIP","COMPROBACION":"$COMPROBACION","COSTOSALIDA":"$COSTOSALIDA","COSTOSALIDAAJ":"$COSTOSALIDAAJ","CUENTACREDITO":"$CUENTACREDITO","CUENTADEBITO":"$CUENTADEBITO","DETERIORO":"$DETERIORO","ENTREGA":"$ENTREGA","ESCRITURA":"$ESCRITURA","ESTADO":"$ESTADO","FECHA_MODIFICA_PROMEDIO":"$FECHA_MODIFICA_PROMEDIO","FECHAADEPRECIAR":"$FECHAADEPRECIAR","FECHAENTRADA":"$FECHAENTRADA","FECHAMOVIMIENTO":"$FECHAMOVIMIENTO","IDENTIFICADOR":"$IDENTIFICADOR","INCREMENAJUS":"$INCREMENAJUS","INFINMUEBLE":"$INFINMUEBLE(type:boolean)","INSTALACION":"$INSTALACION","ITEM":"$ITEM","MATINMOBILIARIA":"$MATINMOBILIARIA","MODIFICA_PROMEDIO":"$MODIFICA_PROMEDIO","NIIF_TIPO_ACTIVO":"$NIIF_TIPO_ACTIVO","NIIF_VALOR_BASE":"$NIIF_VALOR_BASE","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL","NUMEROCATASTRAL":"$NUMEROCATASTRAL","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO","PEDIDO":"$PEDIDO","PLACAANTERIOR":"$PLACAANTERIOR","PORCDESCUENTO":"$PORCDESCUENTO","PORCIVAUNI":"$PORCIVAUNI","PREPARACION":"$PREPARACION","PROVEEDORCA":"$PROVEEDORCA","REGISTRADOBI":"$REGISTRADOBI(type:boolean)","REVELACIONES":"$REVELACIONES","SALDO_PEPS":"$SALDO_PEPS","SALDOELEMENTO":"$SALDOELEMENTO","SALDOKARDEX":"$SALDOKARDEX","SALVAMENTO":"$SALVAMENTO","SUCURSALCA":"$SUCURSALCA","VALORIVA":"$VALORIVA","VALORSALDO":"$VALORSALDO","VALORTOTALCONIVA":"$VALORTOTALCONIVA","VLRAJUSTADO":"$VLRAJUSTADO","VLRUNITANTERIOR":"$VLRUNITANTERIOR","VIDAUTILPLACA":"$VIDAUTILPLACA","VIDAUTILPLACANIIF":"$VIDAUTILPLACANIIF","APLICANIIF":"$APLICANIIF(type:boolean)","MODELO":"$MODELO","COMPONENTE":"$COMPONENTE(type:integer)","FECHA_INSTALACION":"$FECHA_INSTALACION","ACTA_INSTALACION":"$ACTA_INSTALACION","REFERENCIA":"$REFERENCIA","UNIDAD":"$UNIDAD","LOTE":"$LOTE","TEMPERATURA":"$TEMPERATURA","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","REGISTRO_SANITARIO":"$REGISTRO_SANITARIO","PIDE_VENCIMIENTO":"$PIDE_VENCIMIENTO(type:boolean)","FUENTEDERECURSO":"$FUENTEDERECURSO","VLR_COLGAAP":"$VLR_COLGAAP","PORC_VALOR_RESIDUAL":"$PORC_VALOR_RESIDUAL(type:integer)","CODIGO_AFECT":"$CODIGO_AFECT","REFERENCIA_CNT":"$REFERENCIA_CNT","CODIGOPROYECTO":"$CODIGOPROYECTO","VLRIMPCONSUMO":"$VLRIMPCONSUMO","PORC_IMPCONSUMO":"$PORC_IMPCONSUMO","PORC_AIU":"$PORC_AIU","VLR_AIU":"$VLR_AIU"}]}}		</result>
