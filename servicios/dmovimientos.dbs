	<query id="updateDmovimientosEspecificacionPorTipomovMovYSerie" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_MOVIMIENTO SET ESPECIFICACION = :ESPECIFICACION ,   DATE_MODIFIED    = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') ,   MODIFIED_BY      = :MODIFIED_BY WHERE COMPANIA     = :COMPANIA AND TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND MOVIMIENTO     = :MOVIMIENTO AND SERIE          = :SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>

	</query>
