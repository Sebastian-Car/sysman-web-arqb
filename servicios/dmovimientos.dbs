	<query id="getDmovimientosNumTodosPorTerceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DM.COMPANIA, DM.TIPOMOVIMIENTO, DM.MOVIMIENTO, DM.CODIGO, DM.ELEMENTO, DM.CANTIDAD, DM.VALORUNITARIO, DM.VALORTOTAL, M.DESCRIPCION, I.NOMBRELARGO NOM_ELEMENTO, DEP.NOMBRE NOM_DEPENDENCIA, M.TERCERO ID_TERCERO, M.SUCURSAL, T.NOMBRE NOMBRE_TERCERO, DM.AUXILIAR, A.NOMBRE NOMBRE_AUXILIAR  FROM D_MOVIMIENTO DM INNER JOIN MOVIMIENTO M ON DM.COMPANIA = M.COMPANIA AND DM.TIPOMOVIMIENTO = M.TIPOMOVIMIENTO AND DM.MOVIMIENTO = M.NUMERO INNER JOIN TERCERO T ON M.COMPANIA = T.COMPANIA AND M.TERCERO = T.NIT AND M.SUCURSAL = T.SUCURSAL LEFT JOIN AUXILIAR A ON DM.COMPANIA = A.COMPANIA AND TO_NUMBER(TO_CHAR(DM.FECHA,'YYYY') ) = A.ANO AND DM.AUXILIAR = A.CODIGO INNER JOIN INVENTARIO I ON DM.COMPANIA = I.COMPANIA AND DM.ELEMENTO = I.CODIGOELEMENTO INNER JOIN DEPENDENCIA DEP ON M.COMPANIA = DEP.COMPANIA AND M.DEPENDENCIA_DESTINO = DEP.CODIGO WHERE M.COMPANIA =:COMPANIA AND TO_NUMBER(TO_CHAR(DM.FECHA,'YYYY') ) =:ANO AND TO_NUMBER(TO_CHAR(DM.FECHA,'MM') ) BETWEEN :MESINICIAL AND :MESFINAL AND M.TERCERO =:TERCERO AND M.SUCURSAL =:SUCURSAL ORDER BY DM.COMPANIA, DM.TIPOMOVIMIENTO, DM.MOVIMIENTO, DM.CODIGO) WHERE (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END)  LIKE UPPER( '%' || :TIPOMOVIMIENTO || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER( '%' || :CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER( '%' || :VALORUNITARIO || '%')  AND (CASE WHEN VALORTOTAL IS NULL THEN ' ' ELSE UPPER(VALORTOTAL) END)  LIKE UPPER( '%' || :VALORTOTAL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOM_ELEMENTO IS NULL THEN ' ' ELSE UPPER(NOM_ELEMENTO) END)  LIKE UPPER( '%' || :NOM_ELEMENTO || '%')  AND (CASE WHEN NOM_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOM_DEPENDENCIA) END)  LIKE UPPER( '%' || :NOM_DEPENDENCIA || '%')  AND (CASE WHEN ID_TERCERO IS NULL THEN ' ' ELSE UPPER(ID_TERCERO) END)  LIKE UPPER( '%' || :ID_TERCERO || '%')  AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END)  LIKE UPPER( '%' || :NOMBRE_TERCERO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER( '%' || :AUXILIAR || '%')  AND (CASE WHEN NOMBRE_AUXILIAR IS NULL THEN ' ' ELSE UPPER(NOMBRE_AUXILIAR) END)  LIKE UPPER( '%' || :NOMBRE_AUXILIAR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
