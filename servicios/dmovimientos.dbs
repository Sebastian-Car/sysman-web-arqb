	<query id="getDmovimientosPepsQuery"  useConfig="sysmandsunist">
		<sql>SELECT  INVENTARIO.CODIGOELEMENTO, D_MOVIMIENTO.TIPOMOVIMIENTO, D_MOVIMIENTO.MOVIMIENTO, INVENTARIO.NOMBRELARGO, D_MOVIMIENTO.CANTIDAD, D_MOVIMIENTO.SALDO_PEPS, INVENTARIO.TIPO, D_MOVIMIENTO.VALORUNITARIO, INVENTARIO.PRECIOULTCOMPRA, INVENTARIO.IDENTIFICADOR, INVENTARIO.UNIDAD, TIPOMOVIMIENTO.CLASE, TIPOMOVIMIENTO.TIPOELEMENTO,(TO_CHAR(D_MOVIMIENTO.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(D_MOVIMIENTO.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA FROM D_MOVIMIENTO INNER JOIN INVENTARIO ON D_MOVIMIENTO.COMPANIA = INVENTARIO.COMPANIA AND D_MOVIMIENTO.ELEMENTO = INVENTARIO.CODIGOELEMENTO INNER JOIN TIPOMOVIMIENTO ON D_MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND D_MOVIMIENTO.SALDO_PEPS &gt; 0 AND TIPOMOVIMIENTO.CLASE = 'E' AND TIPOMOVIMIENTO.TIPOELEMENTO = 'C' AND INVENTARIO.TIPO = :TIPOELEMENTO AND INVENTARIO.TIENEMOVIMIENTO &lt;&gt; 0 AND INVENTARIO.INACTIVO = 0 AND INVENTARIO.CODIGOELEMENTO = :ELEMENTO ORDER BY INVENTARIO.CODIGOELEMENTO, D_MOVIMIENTO.FECHA, D_MOVIMIENTO.HORA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","TIPOMOVIMIENTO":"$TIPOMOVIMIENTO","MOVIMIENTO":"$MOVIMIENTO","NOMBRELARGO":"$NOMBRELARGO","CANTIDAD":"$CANTIDAD","SALDO_PEPS":"$SALDO_PEPS","TIPO":"$TIPO","VALORUNITARIO":"$VALORUNITARIO","PRECIOULTCOMPRA":"$PRECIOULTCOMPRA","IDENTIFICADOR":"$IDENTIFICADOR","UNIDAD":"$UNIDAD","CLASE":"$CLASE","TIPOELEMENTO":"$TIPOELEMENTO","FECHA":"$FECHA","HORA":"$HORA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOELEMENTO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/peps">
		<call-query href="getDmovimientosPepsQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOELEMENTO" query-param="TIPOELEMENTO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>

		</call-query>
	</resource>
	<query id="getDmovimientosElementodetalleQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ELEMENTO, CANTIDAD  FROM D_MOVIMIENTO WHERE D_MOVIMIENTO.COMPANIA = :KEY_COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO= :KEY_TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO = :KEY_MOVIMIENTO AND D_MOVIMIENTO.CODIGO = :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","CANTIDAD":"$CANTIDAD"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_MOVIMIENTO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/elementodetalle">
		<call-query href="getDmovimientosElementodetalleQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOMOVIMIENTO" query-param="KEY_TIPOMOVIMIENTO"/>
			<with-param name="KEY_MOVIMIENTO" query-param="KEY_MOVIMIENTO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateDmovimientosUbicacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_MOVIMIENTO SET PAIS                       = :PAIS,   DEPARTAMENTO                 = :DEPARTAMENTO,   CIUDAD                    = :MUNICIPIO,   DIRECCION                    = :DIRECCION WHERE COMPANIA   = :COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO= :TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO    = :MOVIMIENTO AND D_MOVIMIENTO.CODIGO        = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PAIS" sqlType="STRING"/>
		<param name="DEPARTAMENTO" sqlType="STRING"/>
		<param name="MUNICIPIO" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
