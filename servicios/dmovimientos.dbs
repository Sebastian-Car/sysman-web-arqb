	<query id="updateDmovimientosFechaactaInstalacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_MOVIMIENTO SET FECHA_INSTALACION = TO_DATE(:FECHA_INSTALACION,'DD/MM/YYYY HH24:MI:SS'), ACTA_INSTALACION =:ACTA_INSTALACION WHERE D_MOVIMIENTO.COMPANIA =:COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO =:TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO =:MOVIMIENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_INSTALACION" sqlType="STRING"/>
		<param name="ACTA_INSTALACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dmovimientos/fechaactainstalacion">
		<call-query href="updateDmovimientosFechaactaInstalacion">
			<with-param name="FECHA_INSTALACION" query-param="FECHA_INSTALACION"/>
			<with-param name="ACTA_INSTALACION" query-param="ACTA_INSTALACION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="getDmovimientosValordiariosiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(:CONSECUTIVO) CONSECUTIVO, TO_CHAR(ROWNUM) CONSECUTIVO_O, CODIGO_CONTABLE, TO_CHAR(VALOR_DEBE) VALOR_DEBE, TO_CHAR(VALOR_HABER) VALOR_HABER FROM (SELECT CASE WHEN NIIF_CUENTACREDITO IS NOT NULL THEN NIIF_CUENTACREDITO ELSE ALMACENCONTABILIDAD.CUENTACREDITO END CODIGO_CONTABLE, 0 VALOR_DEBE, SUM(CASE WHEN 0 NOT IN(0) THEN NIIF_VALOR_TOTAL ELSE D_MOVIMIENTO.VALORTOTAL END) VALOR_HABER FROM D_MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON TIPOMOVIMIENTO.COMPANIA = D_MOVIMIENTO.COMPANIA AND TIPOMOVIMIENTO.CODIGO = D_MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN ALMACENCONTABILIDAD ON D_MOVIMIENTO.COMPANIA = ALMACENCONTABILIDAD.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = ALMACENCONTABILIDAD.TIPOMOVIMIENTO AND SUBSTR(D_MOVIMIENTO.ELEMENTO,1,LENGTH(ALMACENCONTABILIDAD.CODIGOELEMENTO)) = ALMACENCONTABILIDAD.CODIGOELEMENTO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND TRUNC(D_MOVIMIENTO.FECHA)=TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY') AND IND_REG NOT IN(0) AND ALMACENCONTABILIDAD.ANO = TO_NUMBER(TO_CHAR(TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY'),'YYYY')) AND NOT (TIPOMOVIMIENTO.CONCEPTO IN ('T') AND TIPOMOVIMIENTO.CLASE IN('T')) GROUP BY CASE WHEN NIIF_CUENTACREDITO IS NOT NULL THEN NIIF_CUENTACREDITO ELSE ALMACENCONTABILIDAD.CUENTACREDITO END , 0 UNION SELECT CASE WHEN NIIF_CUENTADEBITO IS NOT NULL THEN NIIF_CUENTADEBITO ELSE ALMACENCONTABILIDAD.CUENTADEBITO END CODIGO_CONTABLE, SUM(CASE WHEN 0 NOT IN(0) THEN NIIF_VALOR_TOTAL ELSE D_MOVIMIENTO.VALORTOTAL END) VALOR_DEBE, 0 VALOR_HABER FROM D_MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON TIPOMOVIMIENTO.COMPANIA = D_MOVIMIENTO.COMPANIA AND TIPOMOVIMIENTO.CODIGO = D_MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN ALMACENCONTABILIDAD ON D_MOVIMIENTO.COMPANIA = ALMACENCONTABILIDAD.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = ALMACENCONTABILIDAD.TIPOMOVIMIENTO AND SUBSTR(D_MOVIMIENTO.ELEMENTO,1,LENGTH(ALMACENCONTABILIDAD.CODIGOELEMENTO)) = ALMACENCONTABILIDAD.CODIGOELEMENTO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND TRUNC(D_MOVIMIENTO.FECHA)=TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY') AND IND_REG NOT IN(0) AND ALMACENCONTABILIDAD.ANO = TO_NUMBER(TO_CHAR(TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY'),'YYYY')) AND NOT (TIPOMOVIMIENTO.CONCEPTO IN ('T') AND TIPOMOVIMIENTO.CLASE IN('T')) GROUP BY CASE WHEN NIIF_CUENTADEBITO IS NOT NULL THEN NIIF_CUENTADEBITO ELSE ALMACENCONTABILIDAD.CUENTADEBITO END, 0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","CONSECUTIVO_O":"$CONSECUTIVO_O","CODIGO_CONTABLE":"$CODIGO_CONTABLE","VALOR_DEBE":"$VALOR_DEBE","VALOR_HABER":"$VALOR_HABER"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAALMACENCONTABILIDADTSIIF" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/valordiariosiif">
		<call-query href="getDmovimientosValordiariosiifQuery">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAALMACENCONTABILIDADTSIIF" query-param="FECHAALMACENCONTABILIDADTSIIF"/>

		</call-query>
	</resource>
	<query id="getDmovimientosValordiarioauxiliarsiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(ROWNUM) CONSECUTIVO_O, '1' TIPO_AUXILIAR, '1' AUXILIAR_CONTABLE, :IDENTIFICACION_AUXILIAR IDENTIFICACION_AUXILIAR, (VALOR_DEBE + VALOR_HABER) VALOR_AUXILIAR FROM (SELECT CASE WHEN NIIF_CUENTACREDITO IS NOT NULL THEN NIIF_CUENTACREDITO ELSE ALMACENCONTABILIDAD.CUENTACREDITO END CODIGO_CONTABLE, 0 VALOR_DEBE, SUM(CASE WHEN 0 NOT IN(0) THEN NIIF_VALOR_TOTAL ELSE D_MOVIMIENTO.VALORTOTAL END) VALOR_HABER FROM D_MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON TIPOMOVIMIENTO.COMPANIA = D_MOVIMIENTO.COMPANIA AND TIPOMOVIMIENTO.CODIGO = D_MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN ALMACENCONTABILIDAD ON D_MOVIMIENTO.COMPANIA = ALMACENCONTABILIDAD.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = ALMACENCONTABILIDAD.TIPOMOVIMIENTO AND SUBSTR(D_MOVIMIENTO.ELEMENTO,1,LENGTH(ALMACENCONTABILIDAD.CODIGOELEMENTO)) = ALMACENCONTABILIDAD.CODIGOELEMENTO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND TRUNC(D_MOVIMIENTO.FECHA)=TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY') AND IND_REG NOT IN(0) AND ALMACENCONTABILIDAD.ANO = TO_NUMBER(TO_CHAR(TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY'),'YYYY')) AND NOT (TIPOMOVIMIENTO.CONCEPTO IN ('T') AND TIPOMOVIMIENTO.CLASE IN('T')) GROUP BY CASE WHEN NIIF_CUENTACREDITO IS NOT NULL THEN NIIF_CUENTACREDITO ELSE ALMACENCONTABILIDAD.CUENTACREDITO END , 0 UNION SELECT CASE WHEN NIIF_CUENTADEBITO IS NOT NULL THEN NIIF_CUENTADEBITO ELSE ALMACENCONTABILIDAD.CUENTADEBITO END CODIGO_CONTABLE, SUM(CASE WHEN 0 NOT IN(0) THEN NIIF_VALOR_TOTAL ELSE D_MOVIMIENTO.VALORTOTAL END) VALOR_DEBE, 0 VALOR_HABER FROM D_MOVIMIENTO INNER JOIN TIPOMOVIMIENTO ON TIPOMOVIMIENTO.COMPANIA = D_MOVIMIENTO.COMPANIA AND TIPOMOVIMIENTO.CODIGO = D_MOVIMIENTO.TIPOMOVIMIENTO INNER JOIN ALMACENCONTABILIDAD ON D_MOVIMIENTO.COMPANIA = ALMACENCONTABILIDAD.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = ALMACENCONTABILIDAD.TIPOMOVIMIENTO AND SUBSTR(D_MOVIMIENTO.ELEMENTO,1,LENGTH(ALMACENCONTABILIDAD.CODIGOELEMENTO)) = ALMACENCONTABILIDAD.CODIGOELEMENTO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND TRUNC(D_MOVIMIENTO.FECHA)=TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY') AND IND_REG NOT IN(0) AND ALMACENCONTABILIDAD.ANO = TO_NUMBER(TO_CHAR(TO_DATE(:FECHAALMACENCONTABILIDADTSIIF,'DD/MM/YYYY'),'YYYY')) AND NOT (TIPOMOVIMIENTO.CONCEPTO IN ('T') AND TIPOMOVIMIENTO.CLASE IN('T')) GROUP BY CASE WHEN NIIF_CUENTADEBITO IS NOT NULL THEN NIIF_CUENTADEBITO ELSE ALMACENCONTABILIDAD.CUENTADEBITO END, 0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO_O":"$CONSECUTIVO_O","TIPO_AUXILIAR":"$TIPO_AUXILIAR","AUXILIAR_CONTABLE":"$AUXILIAR_CONTABLE","IDENTIFICACION_AUXILIAR":"$IDENTIFICACION_AUXILIAR","VALOR_AUXILIAR":"$VALOR_AUXILIAR(type:integer)"}]}}		</result>
		<param name="IDENTIFICACION_AUXILIAR" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAALMACENCONTABILIDADTSIIF" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/valordiarioauxiliarsiif">
		<call-query href="getDmovimientosValordiarioauxiliarsiifQuery">
			<with-param name="IDENTIFICACION_AUXILIAR" query-param="IDENTIFICACION_AUXILIAR"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHAALMACENCONTABILIDADTSIIF" query-param="FECHAALMACENCONTABILIDADTSIIF"/>

		</call-query>
	</resource>
	<query id="getDmovimientosValormensualsiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(:CONSECUTIVO) CONSECUTIVO, TO_CHAR(ROWNUM) CONSECUTIVO_O, CODIGO_CONTABLE, TO_CHAR(VALOR_DEBE) VALOR_DEBE, TO_CHAR(VALOR_HABER) VALOR_HABER FROM (SELECT CUENTADEBITO CODIGO_CONTABLE, SUM(DEPRECIAR.NIIF_VLRDEPRECIACION) AS VALOR_DEBE, 0 VALOR_HABER FROM DEPRECIAR LEFT JOIN NIIF_INVENTARIOCONTA NI ON DEPRECIAR.COMPANIA = NI.COMPANIA AND DEPRECIAR.ANO = NI.ANO AND SUBSTR(DEPRECIAR.ELEMENTO,1, :DIGITOS_AGRUPACION_INVENTARIO) = NI.CODIGOELEMENTO AND DEPRECIAR.NIIF_TIPO_ACTIVO = NI.TIPOACTIVO AND DEPRECIAR.BODEGA = NI.BODEGA AND (CASE WHEN :MANEJA_CENTRO = 'SI' THEN DEPRECIAR.CENTRO_COSTO ELSE '99999999999999999999' END ) = NI.CENTRO_COSTO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_DEBITO ON PLAN_DEBITO.COMPANIA = NI.COMPANIA AND PLAN_DEBITO.ANO = NI.ANO AND PLAN_DEBITO.CODIGO = NI.CUENTADEBITO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_CREDITO ON PLAN_CREDITO.COMPANIA = NI.COMPANIA AND PLAN_CREDITO.ANO = NI.ANO AND PLAN_CREDITO.CODIGO = NI.CUENTACREDITO WHERE DEPRECIAR.COMPANIA = :COMPANIA AND DEPRECIAR.ANO = :ANO AND DEPRECIAR.MES = :MES GROUP BY CUENTADEBITO, 0 HAVING SUM(DEPRECIAR.NIIF_VLRDEPRECIACION )&gt;0 UNION SELECT CUENTACREDITO CODIGO_CONTABLE,0 VALOR_DEBE, SUM(DEPRECIAR.NIIF_VLRDEPRECIACION) AS VALOR_HABER FROM DEPRECIAR LEFT JOIN NIIF_INVENTARIOCONTA NI ON DEPRECIAR.COMPANIA = NI.COMPANIA AND DEPRECIAR.ANO = NI.ANO AND SUBSTR(DEPRECIAR.ELEMENTO,1, :DIGITOS_AGRUPACION_INVENTARIO) = NI.CODIGOELEMENTO AND DEPRECIAR.NIIF_TIPO_ACTIVO = NI.TIPOACTIVO AND DEPRECIAR.BODEGA = NI.BODEGA AND (CASE WHEN :MANEJA_CENTRO = 'SI' THEN DEPRECIAR.CENTRO_COSTO ELSE '99999999999999999999' END ) = NI.CENTRO_COSTO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_DEBITO ON PLAN_DEBITO.COMPANIA = NI.COMPANIA AND PLAN_DEBITO.ANO = NI.ANO AND PLAN_DEBITO.CODIGO = NI.CUENTADEBITO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_CREDITO ON PLAN_CREDITO.COMPANIA = NI.COMPANIA AND PLAN_CREDITO.ANO = NI.ANO AND PLAN_CREDITO.CODIGO = NI.CUENTACREDITO WHERE DEPRECIAR.COMPANIA = :COMPANIA AND DEPRECIAR.ANO = :ANO AND DEPRECIAR.MES = :MES GROUP BY 0, CUENTACREDITO HAVING SUM(DEPRECIAR.NIIF_VLRDEPRECIACION )&gt;0) ORDER BY CODIGO_CONTABLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","CONSECUTIVO_O":"$CONSECUTIVO_O","CODIGO_CONTABLE":"$CODIGO_CONTABLE","VALOR_DEBE":"$VALOR_DEBE","VALOR_HABER":"$VALOR_HABER"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DIGITOS_AGRUPACION_INVENTARIO" sqlType="STRING"/>
		<param name="MANEJA_CENTRO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/valormensualsiif">
		<call-query href="getDmovimientosValormensualsiifQuery">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DIGITOS_AGRUPACION_INVENTARIO" query-param="DIGITOS_AGRUPACION_INVENTARIO"/>
			<with-param name="MANEJA_CENTRO" query-param="MANEJA_CENTRO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>

		</call-query>
	</resource>
	<query id="getDmovimientosValormensualauxiliarsiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(ROWNUM) CONSECUTIVO_O, '1' TIPO_AUXILIAR, '1' AUXILIAR_CONTABLE, :IDENTIFICACION_AUXILIAR IDENTIFICACION_AUXILIAR, (VALOR_DEBE + VALOR_HABER) VALOR_AUXILIAR FROM (SELECT CUENTADEBITO CODIGO_CONTABLE, SUM(DEPRECIAR.NIIF_VLRDEPRECIACION) AS VALOR_DEBE, 0 VALOR_HABER FROM DEPRECIAR LEFT JOIN NIIF_INVENTARIOCONTA NI ON DEPRECIAR.COMPANIA = NI.COMPANIA AND DEPRECIAR.ANO = NI.ANO AND SUBSTR(DEPRECIAR.ELEMENTO,1, :DIGITOS_AGRUPACION_INVENTARIO) = NI.CODIGOELEMENTO AND DEPRECIAR.NIIF_TIPO_ACTIVO = NI.TIPOACTIVO AND DEPRECIAR.BODEGA = NI.BODEGA AND (CASE WHEN :MANEJA_CENTRO = 'SI' THEN DEPRECIAR.CENTRO_COSTO ELSE '99999999999999999999' END ) = NI.CENTRO_COSTO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_DEBITO ON PLAN_DEBITO.COMPANIA = NI.COMPANIA AND PLAN_DEBITO.ANO = NI.ANO AND PLAN_DEBITO.CODIGO = NI.CUENTADEBITO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_CREDITO ON PLAN_CREDITO.COMPANIA = NI.COMPANIA AND PLAN_CREDITO.ANO = NI.ANO AND PLAN_CREDITO.CODIGO = NI.CUENTACREDITO WHERE DEPRECIAR.COMPANIA = :COMPANIA AND DEPRECIAR.ANO = :ANO AND DEPRECIAR.MES = :MES GROUP BY CUENTADEBITO, 0 HAVING SUM(DEPRECIAR.NIIF_VLRDEPRECIACION )&gt;0 UNION SELECT CUENTACREDITO CODIGO_CONTABLE,0 VALOR_DEBE, SUM(DEPRECIAR.NIIF_VLRDEPRECIACION) AS VALOR_HABER FROM DEPRECIAR LEFT JOIN NIIF_INVENTARIOCONTA NI ON DEPRECIAR.COMPANIA = NI.COMPANIA AND DEPRECIAR.ANO = NI.ANO AND SUBSTR(DEPRECIAR.ELEMENTO,1, :DIGITOS_AGRUPACION_INVENTARIO) = NI.CODIGOELEMENTO AND DEPRECIAR.NIIF_TIPO_ACTIVO = NI.TIPOACTIVO AND DEPRECIAR.BODEGA = NI.BODEGA AND (CASE WHEN :MANEJA_CENTRO = 'SI' THEN DEPRECIAR.CENTRO_COSTO ELSE '99999999999999999999' END ) = NI.CENTRO_COSTO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_DEBITO ON PLAN_DEBITO.COMPANIA = NI.COMPANIA AND PLAN_DEBITO.ANO = NI.ANO AND PLAN_DEBITO.CODIGO = NI.CUENTADEBITO LEFT JOIN (SELECT COMPANIA, ANO, CODIGO, NATURALEZA FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0) ) ) PLAN_CREDITO ON PLAN_CREDITO.COMPANIA = NI.COMPANIA AND PLAN_CREDITO.ANO = NI.ANO AND PLAN_CREDITO.CODIGO = NI.CUENTACREDITO WHERE DEPRECIAR.COMPANIA = :COMPANIA AND DEPRECIAR.ANO = :ANO AND DEPRECIAR.MES = :MES GROUP BY 0, CUENTACREDITO HAVING SUM(DEPRECIAR.NIIF_VLRDEPRECIACION )&gt;0) ORDER BY CODIGO_CONTABLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO_O":"$CONSECUTIVO_O","TIPO_AUXILIAR":"$TIPO_AUXILIAR","AUXILIAR_CONTABLE":"$AUXILIAR_CONTABLE","IDENTIFICACION_AUXILIAR":"$IDENTIFICACION_AUXILIAR","VALOR_AUXILIAR":"$VALOR_AUXILIAR"}]}}		</result>
		<param name="IDENTIFICACION_AUXILIAR" sqlType="STRING"/>
		<param name="DIGITOS_AGRUPACION_INVENTARIO" sqlType="STRING"/>
		<param name="MANEJA_CENTRO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/valormensualauxiliarsiif">
		<call-query href="getDmovimientosValormensualauxiliarsiifQuery">
			<with-param name="IDENTIFICACION_AUXILIAR" query-param="IDENTIFICACION_AUXILIAR"/>
			<with-param name="DIGITOS_AGRUPACION_INVENTARIO" query-param="DIGITOS_AGRUPACION_INVENTARIO"/>
			<with-param name="MANEJA_CENTRO" query-param="MANEJA_CENTRO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>									   

		</call-query>
	</resource>
	<query id="getDmovimientosCamposauditardetallemovQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ELEMENTO, SERIE, CANTIDAD, VALORUNITARIO, PORCIVA, VALORTOTAL, CREATED_BY, MODIFIED_BY, NIIF_VALOR_BASE, REVELACIONES, DETERIORO, NIIF_VALOR_TOTAL, SALVAMENTO,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TO_CHAR(FECHA, 'DD/MM/YYYY') FECHA, VLRIMPCONSUMO,(CASE APLICANIIF WHEN 0 THEN 'false' ELSE 'true' END) APLICANIIF, NIIF_VIDA_UTIL FROM D_MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND MOVIMIENTO = :NUMERO AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","CANTIDAD":"$CANTIDAD","VALORUNITARIO":"$VALORUNITARIO","PORCIVA":"$PORCIVA","VALORTOTAL":"$VALORTOTAL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","NIIF_VALOR_BASE":"$NIIF_VALOR_BASE","REVELACIONES":"$REVELACIONES","DETERIORO":"$DETERIORO","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL","SALVAMENTO":"$SALVAMENTO","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","FECHA":"$FECHA","VLRIMPCONSUMO":"$VLRIMPCONSUMO","APLICANIIF":"$APLICANIIF(type:boolean)","NIIF_VIDA_UTIL":"$NIIF_VIDA_UTIL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/camposauditardetallemov">
		<call-query href="getDmovimientosCamposauditardetallemovQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="updateDmovimientosActubicacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_MOVIMIENTO SET UBICACION = :CODIGO, UBICACION_ORIGEN = :UBICACION_ORIGEN, UBICACION_DESTINO = :UBICACION_DESTINO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND MOVIMIENTO = :NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="UBICACION_ORIGEN" sqlType="STRING"/>
		<param name="UBICACION_DESTINO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dmovimientos/actubicacion">
		<call-query href="updateDmovimientosActubicacion">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="UBICACION_ORIGEN" query-param="UBICACION_ORIGEN"/>
			<with-param name="UBICACION_DESTINO" query-param="UBICACION_DESTINO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
<query id="updateDmovimientosPutdevolutivodmovubica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>MERGE INTO DEVOLUTIVO TABLA USING ( SELECT D_MOVIMIENTO.COMPANIA, D_MOVIMIENTO.ELEMENTO, D_MOVIMIENTO.SERIE, D_MOVIMIENTO.UBICACION_DESTINO FROM D_MOVIMIENTO WHERE D_MOVIMIENTO.COMPANIA = :COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = :TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO = :NUMERO )VISTA ON ( TABLA.COMPANIA = VISTA.COMPANIA AND TABLA.ELEMENTO = VISTA.ELEMENTO AND TABLA.SERIE = VISTA.SERIE ) WHEN MATCHED THEN UPDATE SET TABLA.UBICACION = VISTA.UBICACION_DESTINO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dmovimientos/putdevolutivodmovubica">
		<call-query href="updateDmovimientosPutdevolutivodmovubica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVIMIENTO" query-param="TIPOMOVIMIENTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getDmovimientosCantidadanteriorQuery"  useConfig="sysmandsunist">
		<sql>SELECT CANTIDAD FROM D_MOVIMIENTO WHERE COMPANIA = :COMPANIA AND TIPOMOVIMIENTO = :TIPOMOV AND MOVIMIENTO = :MOVIMIENTO AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOV" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/cantidadanterior">
		<call-query href="getDmovimientosCantidadanteriorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOV" query-param="TIPOMOV"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getDmovimientosLotesporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT LOTE FROM D_MOVIMIENTO WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LOTE":"$LOTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dmovimientos/lotesporcompania">
		<call-query href="getDmovimientosLotesporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

