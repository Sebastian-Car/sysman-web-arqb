	<query id="insertDmovimientosSeleccionPlacas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_MOVIMIENTO ( COMPANIA, TIPOMOVIMIENTO, MOVIMIENTO, ELEMENTO, SERIE, IND_REG, VALORUNITARIO, VALORTOTAL, VLRUNITARIO_ANTESIVA, FECHA, HORA, CODIGO, CANTIDAD, SALDOCANT, ESPECIFICACION, MARCA, CREATED_BY, DATE_CREATED ) SELECT :COMPANIA, :TIPOMOVP, :MOVP, DEVOLUTIVO.ELEMENTO, DEVOLUTIVO.SERIE, 0, DEVOLUTIVO.VALOR, DEVOLUTIVO.VALOR, DEVOLUTIVO.VALOR, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS')FECHA ,TO_DATE('30/12/1899 ' || TO_CHAR(CURRENT_DATE,' HH24:MI:SS'), 'DD/MM/YYYY HH24:MI:SS') HORA, (:CODIGOA ) + ROWNUM, 1, 0, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.MARCA, :CREATED_BY, SYSDATE FROM DEVOLUTIVO INNER JOIN INVENTARIO ON DEVOLUTIVO.COMPANIA = INVENTARIO.COMPANIA AND DEVOLUTIVO.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE DEVOLUTIVO.COMPANIA =:COMPANIA AND DEVOLUTIVO.DEPENDENCIA =:DEPENDENCIA AND DEVOLUTIVO.RESPONSABLE =:RESPONSABLE AND DEVOLUTIVO.SUCURSAL_RESPONSABLE =:SUCURSAL AND DEVOLUTIVO.PLACAANULADA = 0</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOMOVP" sqlType="STRING"/>
		<param name="MOVP" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="CODIGOA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dmovimientos/seleccionplacas">
		<call-query href="insertDmovimientosSeleccionPlacas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOMOVP" query-param="TIPOMOVP"/>
			<with-param name="MOVP" query-param="MOVP"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CODIGOA" query-param="CODIGOA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
