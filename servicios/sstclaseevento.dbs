			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstclaseeventoNumCodigoPlantillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_CLASE_EVENTO.CODIGO, SST_CLASE_EVENTO.NOMBRE,(CASE SST_CLASE_EVENTO.IND_REUNION WHEN 0 THEN 'false' ELSE 'true' END) IND_REUNION, SST_CLASE_EVENTO.CODIGO_PLANTILLA  FROM SST_CLASE_EVENTO WHERE SST_CLASE_EVENTO.COMPANIA = :COMPANIA AND SST_CLASE_EVENTO.TIPO_TRANSACCION = :TIPO_TRANSACCION) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_REUNION IS NULL THEN ' ' ELSE UPPER(IND_REUNION) END)  LIKE UPPER(:IND_REUNION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
