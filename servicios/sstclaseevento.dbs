	<resource method="GET" path="sstclaseevento/codigoplantilla/num">
		<call-query href="getSstclaseeventoNumCodigoPlantillaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
