			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="CLASEEVENTOINICIAL" query-param="CLASEEVENTOINICIAL"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_REUNION" query-param="IND_REUNION"/>

		</call-query>
	</resource>
	<query id="insertSstclaseevento" keyColumns="COMPANIA,TIPO_TRANSACCION,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_CLASE_EVENTO (COMPANIA, TIPO_TRANSACCION, CODIGO, NOMBRE, IND_REUNION, CODIGO_PLANTILLA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO_TRANSACCION, :CODIGO, :NOMBRE, :IND_REUNION, :CODIGO_PLANTILLA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="IND_REUNION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_PLANTILLA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstclaseevento">
		<call-query href="insertSstclaseevento">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_REUNION" query-param="IND_REUNION"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSstclaseevento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SST_CLASE_EVENTO WHERE SST_CLASE_EVENTO.COMPANIA= :KEY_COMPANIA AND SST_CLASE_EVENTO.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_CLASE_EVENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="sstclaseevento">
		<call-query href="deleteSstclaseevento">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSstclaseeventoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_CLASE_EVENTO.COMPANIA, SST_CLASE_EVENTO.TIPO_TRANSACCION, SST_CLASE_EVENTO.CODIGO, SST_CLASE_EVENTO.NOMBRE,(CASE SST_CLASE_EVENTO.IND_REUNION WHEN 0 THEN 'false' ELSE 'true' END) IND_REUNION, SST_TIPO_TRANSACCION.NOMBRE NOMBRETIPOTX, SST_CLASE_EVENTO.CODIGO_PLANTILLA  FROM SST_CLASE_EVENTO LEFT JOIN SST_TIPO_TRANSACCION ON SST_CLASE_EVENTO.COMPANIA = SST_TIPO_TRANSACCION.COMPANIA AND SST_CLASE_EVENTO.TIPO_TRANSACCION = SST_TIPO_TRANSACCION.CODIGO WHERE SST_CLASE_EVENTO.COMPANIA = :COMPANIA AND SST_CLASE_EVENTO.TIPO_TRANSACCION = :TIPOTRANSACCION ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_REUNION IS NULL THEN ' ' ELSE UPPER(IND_REUNION) END)  LIKE UPPER(:IND_REUNION || '%')  AND (CASE WHEN CODIGO_PLANTILLA IS NULL THEN ' ' ELSE UPPER(CODIGO_PLANTILLA) END)  LIKE UPPER( '%' || :CODIGO_PLANTILLA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","IND_REUNION":"$IND_REUNION(type:boolean)","NOMBRETIPOTX":"$NOMBRETIPOTX","CODIGO_PLANTILLA":"$CODIGO_PLANTILLA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_REUNION" sqlType="STRING"/>
		<param name="CODIGO_PLANTILLA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstclaseevento">
		<call-query href="getSstclaseeventoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_REUNION" query-param="IND_REUNION"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstclaseeventoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_CLASE_EVENTO.COMPANIA, SST_CLASE_EVENTO.TIPO_TRANSACCION, SST_CLASE_EVENTO.CODIGO, SST_CLASE_EVENTO.NOMBRE,(CASE SST_CLASE_EVENTO.IND_REUNION WHEN 0 THEN 'false' ELSE 'true' END) IND_REUNION, SST_TIPO_TRANSACCION.NOMBRE NOMBRETIPOTX, SST_CLASE_EVENTO.CODIGO_PLANTILLA  FROM SST_CLASE_EVENTO LEFT JOIN SST_TIPO_TRANSACCION ON SST_CLASE_EVENTO.COMPANIA = SST_TIPO_TRANSACCION.COMPANIA AND SST_CLASE_EVENTO.TIPO_TRANSACCION = SST_TIPO_TRANSACCION.CODIGO WHERE SST_CLASE_EVENTO.COMPANIA = :COMPANIA AND SST_CLASE_EVENTO.TIPO_TRANSACCION = :TIPOTRANSACCION ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_REUNION IS NULL THEN ' ' ELSE UPPER(IND_REUNION) END)  LIKE UPPER(:IND_REUNION || '%')  AND (CASE WHEN CODIGO_PLANTILLA IS NULL THEN ' ' ELSE UPPER(CODIGO_PLANTILLA) END)  LIKE UPPER( '%' || :CODIGO_PLANTILLA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOTRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_REUNION" sqlType="STRING"/>
		<param name="CODIGO_PLANTILLA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstclaseevento/numero">
		<call-query href="getSstclaseeventoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOTRANSACCION" query-param="TIPOTRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_REUNION" query-param="IND_REUNION"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>

		</call-query>
	</resource>
	<query id="updateSstclaseevento" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_CLASE_EVENTO SET TIPO_TRANSACCION=:TIPO_TRANSACCION, NOMBRE=:NOMBRE, IND_REUNION=:IND_REUNION, CODIGO_PLANTILLA=:CODIGO_PLANTILLA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_CLASE_EVENTO.COMPANIA= :KEY_COMPANIA AND SST_CLASE_EVENTO.TIPO_TRANSACCION= :KEY_TIPO_TRANSACCION AND SST_CLASE_EVENTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_REUNION" sqlType="STRING"/>
		<param name="CODIGO_PLANTILLA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sstclaseevento">
		<call-query href="updateSstclaseevento">
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_REUNION" query-param="IND_REUNION"/>
			<with-param name="CODIGO_PLANTILLA" query-param="CODIGO_PLANTILLA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO_TRANSACCION" query-param="KEY_TIPO_TRANSACCION"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>