	</resource>
	<query id="getSstclaseeventoNumClaseEventoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA,TIPO_TRANSACCION,CODIGO, NOMBRE,(CASE IND_REUNION WHEN 0 THEN 'false' ELSE 'true' END) IND_REUNION FROM SST_CLASE_EVENTO WHERE COMPANIA = :COMPANIA AND TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL AND CODIGO &gt;= :CLASEEVENTOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPO_TRANSACCION IS NULL THEN ' ' ELSE UPPER(TIPO_TRANSACCION) END)  LIKE UPPER( '%' || :TIPO_TRANSACCION || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_REUNION IS NULL THEN ' ' ELSE UPPER(IND_REUNION) END)  LIKE UPPER( '%' || :IND_REUNION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
