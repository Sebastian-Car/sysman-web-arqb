	<query id="getSstclaseeventoPagClaseEventoFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,TIPO_TRANSACCION,CODIGO, NOMBRE,(CASE IND_REUNION WHEN 0 THEN 'false' ELSE 'true' END) IND_REUNION FROM SST_CLASE_EVENTO WHERE COMPANIA = :COMPANIA AND TIPO_TRANSACCION BETWEEN :TIPOINICIAL AND :TIPOFINAL AND CODIGO &gt;= :CLASEEVENTOINICIAL ORDER BY CODIGO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN TIPO_TRANSACCION IS NULL THEN ' ' ELSE UPPER(TIPO_TRANSACCION) END)  LIKE UPPER( '%' || :TIPO_TRANSACCION || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN IND_REUNION IS NULL THEN ' ' ELSE UPPER(IND_REUNION) END)  LIKE UPPER( '%' || :IND_REUNION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_TRANSACCION":"$TIPO_TRANSACCION(type:integer)","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","IND_REUNION":"$IND_REUNION(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOINICIAL" sqlType="STRING"/>
		<param name="TIPOFINAL" sqlType="STRING"/>
		<param name="CLASEEVENTOINICIAL" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="IND_REUNION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstclaseevento/claseeventofinal/pag">
		<call-query href="getSstclaseeventoPagClaseEventoFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOINICIAL" query-param="TIPOINICIAL"/>
			<with-param name="TIPOFINAL" query-param="TIPOFINAL"/>
			<with-param name="CLASEEVENTOINICIAL" query-param="CLASEEVENTOINICIAL"/>
			<with-param name="TIPO_TRANSACCION" query-param="TIPO_TRANSACCION"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="IND_REUNION" query-param="IND_REUNION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

