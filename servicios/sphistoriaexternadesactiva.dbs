<data name="sphistoriaexternadesactiva" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSphistoriaexternadesactivaInactivosPorCodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, ID_EMPRESA, VALORASEOANT, VALORASEO, BANCO_PAGO, TO_CHAR(FECHA_PAGO,'DD/MM/YYYY') FECHA_PAGO, PAQUETE_PAGO  FROM SP_HISTORIA_EXTERNA_DESACTIVA WHERE COMPANIA = :COMPANIA AND CODIGORUTA = :CODIGORUTA ORDER BY ANO DESC, PERIODO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","ID_EMPRESA":"$ID_EMPRESA","VALORASEOANT":"$VALORASEOANT","VALORASEO":"$VALORASEO","BANCO_PAGO":"$BANCO_PAGO","FECHA_PAGO":"$FECHA_PAGO","PAQUETE_PAGO":"$PAQUETE_PAGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sphistoriaexternadesactiva/inactivosporcodruta">
		<call-query href="getSphistoriaexternadesactivaInactivosPorCodrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>

</data>