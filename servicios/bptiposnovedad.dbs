	<query id="getBptiposnovedadDocAfectPorTipotClasetQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BPTIPONOVEDAD.TIPOT, BPTIPONOVEDAD.CLASET,(CASE BPTIPONOVEDAD.AFECTAPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) AFECTAPROGRAMACION,(CASE BPTIPONOVEDAD.AFECTADOCUMENTO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADOCUMENTO,(CASE CONTROLASALDOSOLICITADO WHEN 0 THEN 'false' ELSE 'true' END) CONTROLASALDOSOLICITADO, NOMBRE, BPTIPONOVEDAD.CLASENOVEDAD  FROM BPTIPONOVEDAD WHERE COMPANIA= :COMPANIA AND TIPOT =:TIPOT AND CLASET =:CLASET</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOT":"$TIPOT","CLASET":"$CLASET","AFECTAPROGRAMACION":"$AFECTAPROGRAMACION(type:boolean)","AFECTADOCUMENTO":"$AFECTADOCUMENTO(type:boolean)","CONTROLASALDOSOLICITADO":"$CONTROLASALDOSOLICITADO(type:boolean)","NOMBRE":"$NOMBRE","CLASENOVEDAD":"$CLASENOVEDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>

	</query>
