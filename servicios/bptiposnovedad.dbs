	<query id="getBptiposnovedadNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BPTIPONOVEDAD.COMPANIA, BPTIPONOVEDAD.TIPOT, BPTIPONOVEDAD.CLASET, (CASE BPTIPONOVEDAD.CLASET WHEN 'B' THEN 'Banco de Proyectos' WHEN 'C' THEN 'Contabilidad' WHEN 'P' THEN 'Presupuesto' WHEN 'A' THEN 'Almacén' WHEN 'N' THEN 'Contratos' END) NOMBRECLASET, BPTIPONOVEDAD.CLASENOVEDAD, BPCLASENOVEDADP.NOMBRE NOMBRECLASENOV, BPTIPONOVEDAD.NOMBRE, BPTIPONOVEDAD.TIPODOCAFECTADO, BPTIPONOVEDAD.TITULOFORMATO, BPTIPONOVEDAD.CODIGODOC, BPTIPONOVEDAD.VERSIONDOC,(TO_CHAR(BPTIPONOVEDAD.FECHAVERSIONDOC,'DD/MM/YYYY HH24:MI:SS')) FECHAVERSIONDOC, BPTIPONOVEDAD.APLICA_MODIFICACION  FROM BPTIPONOVEDAD BPTIPONOVEDAD LEFT JOIN BPCLASENOVEDADP ON BPTIPONOVEDAD.CLASENOVEDAD = BPCLASENOVEDADP.CODIGO WHERE BPTIPONOVEDAD.COMPANIA = :COMPANIA) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%')  AND (CASE WHEN NOMBRECLASET IS NULL THEN ' ' ELSE UPPER(NOMBRECLASET) END)  LIKE UPPER( '%' || :NOMBRECLASET || '%')  AND (CASE WHEN NOMBRECLASENOV IS NULL THEN ' ' ELSE UPPER(NOMBRECLASENOV) END)  LIKE UPPER( '%' || :NOMBRECLASENOV || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN TIPODOCAFECTADO IS NULL THEN ' ' ELSE UPPER(TIPODOCAFECTADO) END)  LIKE UPPER(:TIPODOCAFECTADO || '%')  AND (CASE WHEN TITULOFORMATO IS NULL THEN ' ' ELSE UPPER(TITULOFORMATO) END)  LIKE UPPER( '%' || :TITULOFORMATO || '%')  AND (CASE WHEN CODIGODOC IS NULL THEN ' ' ELSE UPPER(CODIGODOC) END)  LIKE UPPER(:CODIGODOC || '%')  AND (CASE WHEN VERSIONDOC IS NULL THEN ' ' ELSE UPPER(VERSIONDOC) END)  LIKE UPPER(:VERSIONDOC || '%')  AND (CASE WHEN FECHAVERSIONDOC IS NULL THEN ' ' ELSE UPPER(FECHAVERSIONDOC) END)  LIKE UPPER( '%' || :FECHAVERSIONDOC || '%')  AND (CASE WHEN APLICA_MODIFICACION IS NULL THEN ' ' ELSE UPPER(APLICA_MODIFICACION) END)  LIKE UPPER(:APLICA_MODIFICACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="NOMBRECLASET" sqlType="STRING"/>
		<param name="NOMBRECLASENOV" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPODOCAFECTADO" sqlType="STRING"/>
		<param name="TITULOFORMATO" sqlType="STRING"/>
		<param name="CODIGODOC" sqlType="STRING"/>
		<param name="VERSIONDOC" sqlType="STRING"/>
		<param name="FECHAVERSIONDOC" sqlType="STRING"/>
		<param name="APLICA_MODIFICACION" sqlType="STRING"/>

	</query>
