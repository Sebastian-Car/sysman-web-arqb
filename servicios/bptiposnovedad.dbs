	</resource>
	<query id="getBptiposnovedadRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT BPTIPONOVEDAD.COMPANIA, BPTIPONOVEDAD.TIPOT, BPTIPONOVEDAD.CLASET, BPTIPONOVEDAD.CLASENOVEDAD, BPTIPONOVEDAD.NOMBRE, BPTIPONOVEDAD.TAUTOMATICA,(CASE BPTIPONOVEDAD.AFECTAPROGRAMACION WHEN 0 THEN 'false' ELSE 'true' END) AFECTAPROGRAMACION, BPTIPONOVEDAD.TIPOMODELO, BPTIPONOVEDAD.TIPOFORMATO,(CASE BPTIPONOVEDAD.AFECTADOCUMENTO WHEN 0 THEN 'false' ELSE 'true' END) AFECTADOCUMENTO,(CASE BPTIPONOVEDAD.CONTROLASALDOSOLICITADO WHEN 0 THEN 'false' ELSE 'true' END) CONTROLASALDOSOLICITADO,(CASE BPTIPONOVEDAD.ACT_PLAN_INDI WHEN 0 THEN 'false' ELSE 'true' END) ACT_PLAN_INDI, BPTIPONOVEDAD.CREATED_BY,(TO_CHAR(BPTIPONOVEDAD.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, BPTIPONOVEDAD.MODIFIED_BY,(TO_CHAR(BPTIPONOVEDAD.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, BPTIPONOVEDAD.TIPODOCAFECTADO, BPTIPONOVEDAD.TITULOFORMATO, BPTIPONOVEDAD.CODIGODOC, BPTIPONOVEDAD.VERSIONDOC,(TO_CHAR(BPTIPONOVEDAD.FECHAVERSIONDOC,'DD/MM/YYYY HH24:MI:SS')) FECHAVERSIONDOC,(CASE BPTIPONOVEDAD.APLICA_MODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) APLICA_MODIFICACION,(CASE BPTIPONOVEDAD.REST_VIG_COMP_META WHEN 0 THEN 'false' ELSE 'true' END) REST_VIG_COMP_META FROM BPTIPONOVEDAD WHERE BPTIPONOVEDAD.COMPANIA= :KEY_COMPANIA AND BPTIPONOVEDAD.TIPOT= :KEY_TIPOT AND BPTIPONOVEDAD.CLASET= :KEY_CLASET</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOT":"$TIPOT","CLASET":"$CLASET","CLASENOVEDAD":"$CLASENOVEDAD","NOMBRE":"$NOMBRE","TAUTOMATICA":"$TAUTOMATICA","AFECTAPROGRAMACION":"$AFECTAPROGRAMACION(type:boolean)","TIPOMODELO":"$TIPOMODELO","TIPOFORMATO":"$TIPOFORMATO","AFECTADOCUMENTO":"$AFECTADOCUMENTO(type:boolean)","CONTROLASALDOSOLICITADO":"$CONTROLASALDOSOLICITADO(type:boolean)","ACT_PLAN_INDI":"$ACT_PLAN_INDI(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","TIPODOCAFECTADO":"$TIPODOCAFECTADO","TITULOFORMATO":"$TITULOFORMATO","CODIGODOC":"$CODIGODOC","VERSIONDOC":"$VERSIONDOC","FECHAVERSIONDOC":"$FECHAVERSIONDOC","APLICA_MODIFICACION":"$APLICA_MODIFICACION(type:boolean)","REST_VIG_COMP_META":"$REST_VIG_COMP_META(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOT" sqlType="STRING"/>
		<param name="KEY_CLASET" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bptiposnovedad/data">
		<call-query href="getBptiposnovedadRegistroQuery">
