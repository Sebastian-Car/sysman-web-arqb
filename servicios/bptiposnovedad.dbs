	<query id="updateBptiposnovedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPTIPONOVEDAD SET COMPANIA=:COMPANIA, TIPOT=:TIPOT, CLASET=:CLASET, CLASENOVEDAD=:CLASENOVEDAD, NOMBRE=:NOMBRE, TAUTOMATICA=:TAUTOMATICA, AFECTAPROGRAMACION=:AFECTAPROGRAMACION, TIPOMODELO=:TIPOMODELO, TIPOFORMATO=:TIPOFORMATO, AFECTADOCUMENTO=:AFECTADOCUMENTO, CONTROLASALDOSOLICITADO=:CONTROLASALDOSOLICITADO, ACT_PLAN_INDI=:ACT_PLAN_INDI, TIPODOCAFECTADO=:TIPODOCAFECTADO, TITULOFORMATO=:TITULOFORMATO, CODIGODOC=:CODIGODOC, VERSIONDOC=:VERSIONDOC, FECHAVERSIONDOC=TO_DATE(:FECHAVERSIONDOC,'DD/MM/YYYY HH24:MI:SS'), APLICA_MODIFICACION=:APLICA_MODIFICACION, REST_VIG_COMP_META=:REST_VIG_COMP_META, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BPTIPONOVEDAD.COMPANIA= :KEY_COMPANIA AND BPTIPONOVEDAD.TIPOT= :KEY_TIPOT AND BPTIPONOVEDAD.CLASET= :KEY_CLASET</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="CLASENOVEDAD" sqlType="STRING"/>
