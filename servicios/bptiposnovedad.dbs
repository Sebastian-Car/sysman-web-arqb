	</resource>
	<query id="getBptiposnovedadNumTipotClasetNomCiaPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BPTIPONOVEDAD.TIPOT, BPTIPONOVEDAD.CLASET, BPTIPONOVEDAD.NOMBRE, BPTIPONOVEDAD.COMPANIA  FROM BPTIPONOVEDAD WHERE BPTIPONOVEDAD.COMPANIA = :COMPANIA ORDER BY BPTIPONOVEDAD.TIPOT, BPTIPONOVEDAD.CLASET) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%')  AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END)  LIKE UPPER( '%' || :CLASET || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bptiposnovedad/tipotclasetnomciaporcia/num">
		<call-query href="getBptiposnovedadNumTipotClasetNomCiaPorCiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBptiposnovedadPagNombretipotcasetQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NOMBRE, TIPOT, CLASET FROM BPTIPONOVEDAD WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPO,' ','') ),CONCAT('',CONCAT( TIPOT, '')),1) &gt; 0 AND CLASET IN ('B') ORDER BY NOMBRE) INI WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOT), '%')) AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASET), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","TIPOT":"$TIPOT","CLASET":"$CLASET"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bptiposnovedad/nombretipotcaset/pag">
		<call-query href="getBptiposnovedadPagNombretipotcasetQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBptiposnovedadNumNombretipotcasetQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NOMBRE, TIPOT, CLASET FROM BPTIPONOVEDAD WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPO,' ','') ),CONCAT('',CONCAT( TIPOT, '')),1) &gt; 0 AND CLASET IN ('B') ORDER BY NOMBRE) INI WHERE (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOT), '%')) AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASET), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bptiposnovedad/nombretipotcaset/num">
		<call-query href="getBptiposnovedadNumNombretipotcasetQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>

		</call-query>
	</resource>
	<query id="getBptiposnovedadTipoformatoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TIPOFORMATO  FROM BPTIPONOVEDAD WHERE COMPANIA = :COMPANIA AND TIPOT = :TIPOT AND CLASET = :CLASET</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOFORMATO":"$TIPOFORMATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bptiposnovedad/tipoformato">
		<call-query href="getBptiposnovedadTipoformatoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>
			<with-param name="CLASET" query-param="CLASET"/>

		</call-query>
	</resource>
	<query id="getBptiposnovedadExisteclasenovcompmetaQuery"  useConfig="sysmandsunist">
		<sql>SELECT CASE WHEN ( SELECT COUNT(1) FROM BPTIPONOVEDAD WHERE COMPANIA = :COMPANIA AND TIPOT = :TIPOT AND REST_VIG_COMP_META &lt;&gt; 0 ) &gt; 0 THEN 1 ELSE 0 END AS EXISTE FROM DUAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bptiposnovedad/existeclasenovcompmeta">
		<call-query href="getBptiposnovedadExisteclasenovcompmetaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOT" query-param="TIPOT"/>

		</call-query>
	</resource>

</data>