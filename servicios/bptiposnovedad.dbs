	<query id="getBptiposnovedadPagTipotClasetNomCiaPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BPTIPONOVEDAD.TIPOT, BPTIPONOVEDAD.CLASET, BPTIPONOVEDAD.NOMBRE, BPTIPONOVEDAD.COMPANIA  FROM BPTIPONOVEDAD WHERE BPTIPONOVEDAD.COMPANIA = :COMPANIA ORDER BY BPTIPONOVEDAD.TIPOT, BPTIPONOVEDAD.CLASET) WHERE (CASE WHEN TIPOT IS NULL THEN ' ' ELSE UPPER(TIPOT) END)  LIKE UPPER(:TIPOT || '%')  AND (CASE WHEN CLASET IS NULL THEN ' ' ELSE UPPER(CLASET) END)  LIKE UPPER( '%' || :CLASET || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOT":"$TIPOT","CLASET":"$CLASET","NOMBRE":"$NOMBRE","COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOT" sqlType="STRING"/>
		<param name="CLASET" sqlType="STRING"/>
