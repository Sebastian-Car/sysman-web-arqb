<data name="emaildestinos" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getEmaildestinosPagDestinatariostodosQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, PLANTILLA, NOMBRE_DESTINATARIO, CORREO_DESTINATARIO, CODIGO_DESTINATARIO  FROM EMAIL_DESTINO WHERE COMPANIA = :COMPANIA AND PLANTILLA = :PLANTILLA ORDER BY PLANTILLA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN PLANTILLA IS NULL THEN ' ' ELSE UPPER(PLANTILLA) END)  LIKE UPPER(:PLANTILLA || '%')  AND (CASE WHEN NOMBRE_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DESTINATARIO) END)  LIKE UPPER( '%' || :NOMBRE_DESTINATARIO || '%')  AND (CASE WHEN CORREO_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(CORREO_DESTINATARIO) END)  LIKE UPPER( '%' || :CORREO_DESTINATARIO || '%')  AND (CASE WHEN CODIGO_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(CODIGO_DESTINATARIO) END)  LIKE UPPER( '%' || :CODIGO_DESTINATARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PLANTILLA":"$PLANTILLA","NOMBRE_DESTINATARIO":"$NOMBRE_DESTINATARIO","CORREO_DESTINATARIO":"$CORREO_DESTINATARIO","CODIGO_DESTINATARIO":"$CODIGO_DESTINATARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="NOMBRE_DESTINATARIO" sqlType="STRING"/>
		<param name="CORREO_DESTINATARIO" sqlType="STRING"/>
		<param name="CODIGO_DESTINATARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="emaildestinos/destinatariostodos/pag">
		<call-query href="getEmaildestinosPagDestinatariostodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="NOMBRE_DESTINATARIO" query-param="NOMBRE_DESTINATARIO"/>
			<with-param name="CORREO_DESTINATARIO" query-param="CORREO_DESTINATARIO"/>
			<with-param name="CODIGO_DESTINATARIO" query-param="CODIGO_DESTINATARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEmaildestinosNumDestinatariostodosQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, PLANTILLA, NOMBRE_DESTINATARIO, CORREO_DESTINATARIO, CODIGO_DESTINATARIO  FROM EMAIL_DESTINO WHERE COMPANIA = :COMPANIA AND PLANTILLA = :PLANTILLA ORDER BY PLANTILLA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN PLANTILLA IS NULL THEN ' ' ELSE UPPER(PLANTILLA) END)  LIKE UPPER(:PLANTILLA || '%')  AND (CASE WHEN NOMBRE_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DESTINATARIO) END)  LIKE UPPER( '%' || :NOMBRE_DESTINATARIO || '%')  AND (CASE WHEN CORREO_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(CORREO_DESTINATARIO) END)  LIKE UPPER( '%' || :CORREO_DESTINATARIO || '%')  AND (CASE WHEN CODIGO_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(CODIGO_DESTINATARIO) END)  LIKE UPPER( '%' || :CODIGO_DESTINATARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="NOMBRE_DESTINATARIO" sqlType="STRING"/>
		<param name="CORREO_DESTINATARIO" sqlType="STRING"/>
		<param name="CODIGO_DESTINATARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="emaildestinos/destinatariostodos/num">
		<call-query href="getEmaildestinosNumDestinatariostodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="NOMBRE_DESTINATARIO" query-param="NOMBRE_DESTINATARIO"/>
			<with-param name="CORREO_DESTINATARIO" query-param="CORREO_DESTINATARIO"/>
			<with-param name="CODIGO_DESTINATARIO" query-param="CODIGO_DESTINATARIO"/>

		</call-query>
	</resource>
	<query id="insertEmaildestinos" keyColumns="COMPANIA,PLANTILLA,CODIGO_DESTINATARIO" returnGeneratedKeys="true" useConfig="sysmanirisst">
		<sql>INSERT INTO EMAIL_DESTINO (COMPANIA, PLANTILLA, CODIGO_DESTINATARIO, NOMBRE_DESTINATARIO, CORREO_DESTINATARIO, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :PLANTILLA, :CODIGO_DESTINATARIO, :NOMBRE_DESTINATARIO, :CORREO_DESTINATARIO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PLANTILLA":"$PLANTILLA","KEY_CODIGO_DESTINATARIO":"$CODIGO_DESTINATARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="CODIGO_DESTINATARIO" sqlType="STRING"/>
		<param name="NOMBRE_DESTINATARIO" sqlType="STRING"/>
		<param name="CORREO_DESTINATARIO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="emaildestinos">
		<call-query href="insertEmaildestinos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="CODIGO_DESTINATARIO" query-param="CODIGO_DESTINATARIO"/>
			<with-param name="NOMBRE_DESTINATARIO" query-param="NOMBRE_DESTINATARIO"/>
			<with-param name="CORREO_DESTINATARIO" query-param="CORREO_DESTINATARIO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteEmaildestinos" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>DELETE FROM EMAIL_DESTINO WHERE EMAIL_DESTINO.COMPANIA= :KEY_COMPANIA AND EMAIL_DESTINO.PLANTILLA= :KEY_PLANTILLA AND EMAIL_DESTINO.CODIGO_DESTINATARIO= :KEY_CODIGO_DESTINATARIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLANTILLA" sqlType="STRING"/>
		<param name="KEY_CODIGO_DESTINATARIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="emaildestinos">
		<call-query href="deleteEmaildestinos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLANTILLA" query-param="KEY_PLANTILLA"/>
			<with-param name="KEY_CODIGO_DESTINATARIO" query-param="KEY_CODIGO_DESTINATARIO"/>

		</call-query>
	</resource>
	<query id="getEmaildestinosPaginaQuery"  useConfig="sysmanirisst">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , PLANTILLA , CODIGO_DESTINATARIO, NOMBRE_DESTINATARIO , CORREO_DESTINATARIO  FROM EMAIL_DESTINO WHERE COMPANIA = :COMPANIA AND PLANTILLA = :PLANTILLA) WHERE (CASE WHEN NOMBRE_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DESTINATARIO) END)  LIKE UPPER( '%' || :NOMBRE_DESTINATARIO || '%')  AND (CASE WHEN CORREO_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(CORREO_DESTINATARIO) END)  LIKE UPPER( '%' || :CORREO_DESTINATARIO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PLANTILLA":"$PLANTILLA","CODIGO_DESTINATARIO":"$CODIGO_DESTINATARIO","NOMBRE_DESTINATARIO":"$NOMBRE_DESTINATARIO","CORREO_DESTINATARIO":"$CORREO_DESTINATARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="NOMBRE_DESTINATARIO" sqlType="STRING"/>
		<param name="CORREO_DESTINATARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="emaildestinos">
		<call-query href="getEmaildestinosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="NOMBRE_DESTINATARIO" query-param="NOMBRE_DESTINATARIO"/>
			<with-param name="CORREO_DESTINATARIO" query-param="CORREO_DESTINATARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEmaildestinosNumeroQuery"  useConfig="sysmanirisst">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , PLANTILLA , CODIGO_DESTINATARIO, NOMBRE_DESTINATARIO , CORREO_DESTINATARIO  FROM EMAIL_DESTINO WHERE COMPANIA = :COMPANIA AND PLANTILLA = :PLANTILLA) WHERE (CASE WHEN NOMBRE_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DESTINATARIO) END)  LIKE UPPER( '%' || :NOMBRE_DESTINATARIO || '%')  AND (CASE WHEN CORREO_DESTINATARIO IS NULL THEN ' ' ELSE UPPER(CORREO_DESTINATARIO) END)  LIKE UPPER( '%' || :CORREO_DESTINATARIO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="NOMBRE_DESTINATARIO" sqlType="STRING"/>
		<param name="CORREO_DESTINATARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="emaildestinos/numero">
		<call-query href="getEmaildestinosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="NOMBRE_DESTINATARIO" query-param="NOMBRE_DESTINATARIO"/>
			<with-param name="CORREO_DESTINATARIO" query-param="CORREO_DESTINATARIO"/>

		</call-query>
	</resource>
	<query id="updateEmaildestinos" returnUpdatedRowCount="true" useConfig="sysmanirisst">
		<sql>UPDATE EMAIL_DESTINO SET PLANTILLA=:PLANTILLA, CODIGO_DESTINATARIO=:CODIGO_DESTINATARIO, NOMBRE_DESTINATARIO=:NOMBRE_DESTINATARIO, CORREO_DESTINATARIO=:CORREO_DESTINATARIO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE EMAIL_DESTINO.COMPANIA= :KEY_COMPANIA AND EMAIL_DESTINO.PLANTILLA= :KEY_PLANTILLA AND EMAIL_DESTINO.CODIGO_DESTINATARIO= :KEY_CODIGO_DESTINATARIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PLANTILLA" sqlType="STRING"/>
		<param name="CODIGO_DESTINATARIO" sqlType="STRING"/>
		<param name="NOMBRE_DESTINATARIO" sqlType="STRING"/>
		<param name="CORREO_DESTINATARIO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PLANTILLA" sqlType="STRING"/>
		<param name="KEY_CODIGO_DESTINATARIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="emaildestinos">
		<call-query href="updateEmaildestinos">
			<with-param name="PLANTILLA" query-param="PLANTILLA"/>
			<with-param name="CODIGO_DESTINATARIO" query-param="CODIGO_DESTINATARIO"/>
			<with-param name="NOMBRE_DESTINATARIO" query-param="NOMBRE_DESTINATARIO"/>
			<with-param name="CORREO_DESTINATARIO" query-param="CORREO_DESTINATARIO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PLANTILLA" query-param="KEY_PLANTILLA"/>
			<with-param name="KEY_CODIGO_DESTINATARIO" query-param="KEY_CODIGO_DESTINATARIO"/>

		</call-query>
	</resource>

</data>