<data name="natconceptoriesgo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatconceptoriesgoPagTodosPorConceptoRiesgoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_CONCEPTO_RIESGO.ID_CONCEPTO, NAT_CONCEPTO_RIESGO.NOMBRE AS NOMBRE_CONCEPTO  FROM NAT_CONCEPTO_RIESGO WHERE NAT_CONCEPTO_RIESGO.ID_RIESGO=:ID_RIESGO) WHERE (CASE WHEN ID_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_CONCEPTO) END)  LIKE UPPER(:ID_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_CONCEPTO":"$ID_CONCEPTO","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="ID_RIESGO" sqlType="STRING"/>
		<param name="ID_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natconceptoriesgo/todosporconceptoriesgoinicial/pag">
		<call-query href="getNatconceptoriesgoPagTodosPorConceptoRiesgoInicialQuery">
			<with-param name="ID_RIESGO" query-param="ID_RIESGO"/>
			<with-param name="ID_CONCEPTO" query-param="ID_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatconceptoriesgoNumTodosPorConceptoRiesgoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_CONCEPTO_RIESGO.ID_CONCEPTO, NAT_CONCEPTO_RIESGO.NOMBRE AS NOMBRE_CONCEPTO  FROM NAT_CONCEPTO_RIESGO WHERE NAT_CONCEPTO_RIESGO.ID_RIESGO=:ID_RIESGO) WHERE (CASE WHEN ID_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_CONCEPTO) END)  LIKE UPPER(:ID_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ID_RIESGO" sqlType="STRING"/>
		<param name="ID_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natconceptoriesgo/todosporconceptoriesgoinicial/num">
		<call-query href="getNatconceptoriesgoNumTodosPorConceptoRiesgoInicialQuery">
			<with-param name="ID_RIESGO" query-param="ID_RIESGO"/>
			<with-param name="ID_CONCEPTO" query-param="ID_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getNatconceptoriesgoPagCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT NAT_CONCEPTO_RIESGO.ID_CONCEPTO, NAT_CONCEPTO_RIESGO.NOMBRE  FROM NAT_CONCEPTO_RIESGO WHERE NAT_CONCEPTO_RIESGO.ID_RIESGO = :ID_RIESGO) WHERE (CASE WHEN ID_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_CONCEPTO) END)  LIKE UPPER(:ID_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_CONCEPTO":"$ID_CONCEPTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="ID_RIESGO" sqlType="STRING"/>
		<param name="ID_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natconceptoriesgo/codigoynombrefinal/pag">
		<call-query href="getNatconceptoriesgoPagCodigoYNombreFinalQuery">
			<with-param name="ID_RIESGO" query-param="ID_RIESGO"/>
			<with-param name="ID_CONCEPTO" query-param="ID_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatconceptoriesgoNumCodigoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT NAT_CONCEPTO_RIESGO.ID_CONCEPTO, NAT_CONCEPTO_RIESGO.NOMBRE  FROM NAT_CONCEPTO_RIESGO WHERE NAT_CONCEPTO_RIESGO.ID_RIESGO = :ID_RIESGO) WHERE (CASE WHEN ID_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_CONCEPTO) END)  LIKE UPPER(:ID_CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ID_RIESGO" sqlType="STRING"/>
		<param name="ID_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natconceptoriesgo/codigoynombrefinal/num">
		<call-query href="getNatconceptoriesgoNumCodigoYNombreFinalQuery">
			<with-param name="ID_RIESGO" query-param="ID_RIESGO"/>
			<with-param name="ID_CONCEPTO" query-param="ID_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getNatconceptoriesgoTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,ID_RIESGO, ID_CONCEPTO, NOMBRE  FROM NAT_CONCEPTO_RIESGO WHERE NAT_CONCEPTO_RIESGO.COMPANIA = :COMPANIA AND NAT_CONCEPTO_RIESGO.ID_RIESGO = :ID_RIESGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_RIESGO":"$ID_RIESGO","ID_CONCEPTO":"$ID_CONCEPTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_RIESGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natconceptoriesgo/todos">
		<call-query href="getNatconceptoriesgoTodosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_RIESGO" query-param="ID_RIESGO"/>

		</call-query>
	</resource>
	<query id="insertNatconceptoriesgo" keyColumns="COMPANIA,ID_CONCEPTO,ID_RIESGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_CONCEPTO_RIESGO (COMPANIA, ID_CONCEPTO, ID_RIESGO, NOMBRE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_CONCEPTO, :ID_RIESGO, :NOMBRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_CONCEPTO":"$ID_CONCEPTO","KEY_ID_RIESGO":"$ID_RIESGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_CONCEPTO" sqlType="STRING"/>
		<param name="ID_RIESGO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natconceptoriesgo">
		<call-query href="insertNatconceptoriesgo">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_CONCEPTO" query-param="ID_CONCEPTO"/>
			<with-param name="ID_RIESGO" query-param="ID_RIESGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatconceptoriesgo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_CONCEPTO_RIESGO WHERE NAT_CONCEPTO_RIESGO.COMPANIA= :KEY_COMPANIA AND NAT_CONCEPTO_RIESGO.ID_CONCEPTO= :KEY_ID_CONCEPTO AND NAT_CONCEPTO_RIESGO.ID_RIESGO= :KEY_ID_RIESGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_ID_RIESGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natconceptoriesgo">
		<call-query href="deleteNatconceptoriesgo">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_CONCEPTO" query-param="KEY_ID_CONCEPTO"/>
			<with-param name="KEY_ID_RIESGO" query-param="KEY_ID_RIESGO"/>

		</call-query>
	</resource>
	<query id="updateNatconceptoriesgo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_CONCEPTO_RIESGO SET ID_CONCEPTO=:ID_CONCEPTO, NOMBRE=:NOMBRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_CONCEPTO_RIESGO.COMPANIA= :KEY_COMPANIA AND NAT_CONCEPTO_RIESGO.ID_CONCEPTO= :KEY_ID_CONCEPTO AND NAT_CONCEPTO_RIESGO.ID_RIESGO= :KEY_ID_RIESGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_ID_RIESGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natconceptoriesgo">
		<call-query href="updateNatconceptoriesgo">
			<with-param name="ID_CONCEPTO" query-param="ID_CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_CONCEPTO" query-param="KEY_ID_CONCEPTO"/>
			<with-param name="KEY_ID_RIESGO" query-param="KEY_ID_RIESGO"/>

		</call-query>
	</resource>

</data>