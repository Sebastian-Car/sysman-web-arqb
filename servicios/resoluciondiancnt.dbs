	<query id="updateResoluciondiancntSetupdateconseccomprcnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RESOLUCIONDIAN_CT SET CONSECUTIVODIAN=:CONSECUTIVODIAN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE RESOLUCIONDIAN_CT.COMPANIA= :KEY_COMPANIA AND RESOLUCIONDIAN_CT.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND RESOLUCIONDIAN_CT.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVODIAN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="resoluciondiancnt/setupdateconseccomprcnt">
		<call-query href="updateResoluciondiancntSetupdateconseccomprcnt">
			<with-param name="CONSECUTIVODIAN" query-param="CONSECUTIVODIAN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOMPROBANTE" query-param="KEY_TIPOCOMPROBANTE"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getResoluciondiancntGetnumeroresoluciondianQuery"  useConfig="sysmandsunist">
		<sql>SELECT RESOLUCIONDIAN_CT.NUMERO, RESOLUCIONDIAN_CT.PREFIJO, RESOLUCIONDIAN_CT.CONSECUTIVOINI FROM RESOLUCIONDIAN_CT INNER JOIN TIPO_COMPROBANTE ON(RESOLUCIONDIAN_CT.COMPANIA = TIPO_COMPROBANTE.COMPANIA AND RESOLUCIONDIAN_CT.TIPOCOMPROBANTE = TIPO_COMPROBANTE.CODIGO) WHERE RESOLUCIONDIAN_CT.COMPANIA = :COMPANIA AND SYSDATE BETWEEN RESOLUCIONDIAN_CT.FECHAINICIAL AND RESOLUCIONDIAN_CT.FECHAFINAL AND TIPO_COMPROBANTE.CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","PREFIJO":"$PREFIJO","CONSECUTIVOINI":"$CONSECUTIVOINI"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="resoluciondiancnt/getnumeroresoluciondian">
		<call-query href="getResoluciondiancntGetnumeroresoluciondianQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getResoluciondiancntGetmaxconsecutivodianQuery"  useConfig="sysmandsunist">
		<sql>SELECT MAX(TO_NUMBER(CONSECUTIVODIAN)) CONSECDIAN FROM COMPROBANTE_CNT WHERE COMPANIA = :COMPANIA AND TIPO = :CODIGO AND PREFIJODIAN = :PREFIJO AND RESOLUCIONDIAN = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECDIAN":"$CONSECDIAN(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="PREFIJO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="resoluciondiancnt/getmaxconsecutivodian">
		<call-query href="getResoluciondiancntGetmaxconsecutivodianQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="PREFIJO" query-param="PREFIJO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getResoluciondiancntTodoresolucionportipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM RESOLUCIONDIAN_CT WHERE COMPANIA = :COMPANIA AND TIPOCOMPROBANTE = :TIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOMPROBANTE":"$TIPOCOMPROBANTE","NUMERO":"$NUMERO","PREFIJO":"$PREFIJO","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","CONSECUTIVOINI":"$CONSECUTIVOINI","CONSECUTIVOFIN":"$CONSECUTIVOFIN","TIPOFACDIAN":"$TIPOFACDIAN","TIPO_MONEDA":"$TIPO_MONEDA","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_PAGO":"$TIPO_PAGO","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="resoluciondiancnt/todoresolucionportipo">
		<call-query href="getResoluciondiancntTodoresolucionportipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="insertResoluciondiancnt" keyColumns="COMPANIA,TIPOCOMPROBANTE,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO RESOLUCIONDIAN_CT (COMPANIA, TIPOCOMPROBANTE, NUMERO, PREFIJO, FECHAINICIAL, FECHAFINAL, CONSECUTIVOINI, CONSECUTIVOFIN, TIPOFACDIAN, TIPO_MONEDA, TIPO_MEDIOPAGO, TIPO_PAGO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOCOMPROBANTE, :NUMERO, :PREFIJO, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), :CONSECUTIVOINI, :CONSECUTIVOFIN, :TIPOFACDIAN, :TIPO_MONEDA, :TIPO_MEDIOPAGO, :TIPO_PAGO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCOMPROBANTE":"$TIPOCOMPROBANTE","KEY_NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PREFIJO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CONSECUTIVOINI" sqlType="STRING"/>
		<param name="CONSECUTIVOFIN" sqlType="STRING"/>
		<param defaultValue="" name="TIPOFACDIAN" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_MONEDA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_MEDIOPAGO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_PAGO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="resoluciondiancnt">
		<call-query href="insertResoluciondiancnt">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PREFIJO" query-param="PREFIJO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="CONSECUTIVOINI" query-param="CONSECUTIVOINI"/>
			<with-param name="CONSECUTIVOFIN" query-param="CONSECUTIVOFIN"/>
			<with-param name="TIPOFACDIAN" query-param="TIPOFACDIAN"/>
			<with-param name="TIPO_MONEDA" query-param="TIPO_MONEDA"/>
			<with-param name="TIPO_MEDIOPAGO" query-param="TIPO_MEDIOPAGO"/>
			<with-param name="TIPO_PAGO" query-param="TIPO_PAGO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteResoluciondiancnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM RESOLUCIONDIAN_CT WHERE RESOLUCIONDIAN_CT.COMPANIA= :KEY_COMPANIA AND RESOLUCIONDIAN_CT.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND RESOLUCIONDIAN_CT.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="resoluciondiancnt">
		<call-query href="deleteResoluciondiancnt">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOMPROBANTE" query-param="KEY_TIPOCOMPROBANTE"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getResoluciondiancntPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, TIPOCOMPROBANTE, NUMERO, PREFIJO ,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, CONSECUTIVOINI,CONSECUTIVOFIN , TIPOFACDIAN, TIPO_MONEDA,TIPO_MEDIOPAGO, TIPO_PAGO FROM RESOLUCIONDIAN_CT WHERE RESOLUCIONDIAN_CT.COMPANIA = :COMPANNIA AND TIPOCOMPROBANTE = :TIPOCOMP) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN TIPOCOMPROBANTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCOMPROBANTE), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN PREFIJO IS NULL THEN ' ' ELSE UPPER(PREFIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:PREFIJO), '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN CONSECUTIVOINI IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOINI) END) LIKE UPPER(CONCAT(:CONSECUTIVOINI, '%')) AND (CASE WHEN CONSECUTIVOFIN IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOFIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVOFIN), '%')) AND (CASE WHEN TIPOFACDIAN IS NULL THEN ' ' ELSE UPPER(TIPOFACDIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOFACDIAN), '%')) AND (CASE WHEN TIPO_MONEDA IS NULL THEN ' ' ELSE UPPER(TIPO_MONEDA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_MONEDA), '%')) AND (CASE WHEN TIPO_MEDIOPAGO IS NULL THEN ' ' ELSE UPPER(TIPO_MEDIOPAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_MEDIOPAGO), '%')) AND (CASE WHEN TIPO_PAGO IS NULL THEN ' ' ELSE UPPER(TIPO_PAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_PAGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOMPROBANTE":"$TIPOCOMPROBANTE","NUMERO":"$NUMERO","PREFIJO":"$PREFIJO","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","CONSECUTIVOINI":"$CONSECUTIVOINI","CONSECUTIVOFIN":"$CONSECUTIVOFIN","TIPOFACDIAN":"$TIPOFACDIAN","TIPO_MONEDA":"$TIPO_MONEDA","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_PAGO":"$TIPO_PAGO"}]}}		</result>
		<param name="COMPANNIA" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PREFIJO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CONSECUTIVOINI" sqlType="STRING"/>
		<param name="CONSECUTIVOFIN" sqlType="STRING"/>
		<param name="TIPOFACDIAN" sqlType="STRING"/>
		<param name="TIPO_MONEDA" sqlType="STRING"/>
		<param name="TIPO_MEDIOPAGO" sqlType="STRING"/>
		<param name="TIPO_PAGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="resoluciondiancnt">
		<call-query href="getResoluciondiancntPaginaQuery">
			<with-param name="COMPANNIA" query-param="COMPANNIA"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PREFIJO" query-param="PREFIJO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="CONSECUTIVOINI" query-param="CONSECUTIVOINI"/>
			<with-param name="CONSECUTIVOFIN" query-param="CONSECUTIVOFIN"/>
			<with-param name="TIPOFACDIAN" query-param="TIPOFACDIAN"/>
			<with-param name="TIPO_MONEDA" query-param="TIPO_MONEDA"/>
			<with-param name="TIPO_MEDIOPAGO" query-param="TIPO_MEDIOPAGO"/>
			<with-param name="TIPO_PAGO" query-param="TIPO_PAGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getResoluciondiancntNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, TIPOCOMPROBANTE, NUMERO, PREFIJO ,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, CONSECUTIVOINI,CONSECUTIVOFIN , TIPOFACDIAN, TIPO_MONEDA,TIPO_MEDIOPAGO, TIPO_PAGO FROM RESOLUCIONDIAN_CT WHERE RESOLUCIONDIAN_CT.COMPANIA = :COMPANNIA AND TIPOCOMPROBANTE = :TIPOCOMP) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN TIPOCOMPROBANTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCOMPROBANTE), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN PREFIJO IS NULL THEN ' ' ELSE UPPER(PREFIJO) END) LIKE UPPER(CONCAT(CONCAT('%',:PREFIJO), '%')) AND (CASE WHEN FECHAINICIAL IS NULL THEN ' ' ELSE UPPER(FECHAINICIAL) END) LIKE UPPER(CONCAT(:FECHAINICIAL, '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(:FECHAFINAL, '%')) AND (CASE WHEN CONSECUTIVOINI IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOINI) END) LIKE UPPER(CONCAT(:CONSECUTIVOINI, '%')) AND (CASE WHEN CONSECUTIVOFIN IS NULL THEN ' ' ELSE UPPER(CONSECUTIVOFIN) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSECUTIVOFIN), '%')) AND (CASE WHEN TIPOFACDIAN IS NULL THEN ' ' ELSE UPPER(TIPOFACDIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOFACDIAN), '%')) AND (CASE WHEN TIPO_MONEDA IS NULL THEN ' ' ELSE UPPER(TIPO_MONEDA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_MONEDA), '%')) AND (CASE WHEN TIPO_MEDIOPAGO IS NULL THEN ' ' ELSE UPPER(TIPO_MEDIOPAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_MEDIOPAGO), '%')) AND (CASE WHEN TIPO_PAGO IS NULL THEN ' ' ELSE UPPER(TIPO_PAGO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_PAGO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANNIA" sqlType="STRING"/>
		<param name="TIPOCOMP" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PREFIJO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CONSECUTIVOINI" sqlType="STRING"/>
		<param name="CONSECUTIVOFIN" sqlType="STRING"/>
		<param name="TIPOFACDIAN" sqlType="STRING"/>
		<param name="TIPO_MONEDA" sqlType="STRING"/>
		<param name="TIPO_MEDIOPAGO" sqlType="STRING"/>
		<param name="TIPO_PAGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="resoluciondiancnt/numero">
		<call-query href="getResoluciondiancntNumeroQuery">
			<with-param name="COMPANNIA" query-param="COMPANNIA"/>
			<with-param name="TIPOCOMP" query-param="TIPOCOMP"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PREFIJO" query-param="PREFIJO"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="CONSECUTIVOINI" query-param="CONSECUTIVOINI"/>
			<with-param name="CONSECUTIVOFIN" query-param="CONSECUTIVOFIN"/>
			<with-param name="TIPOFACDIAN" query-param="TIPOFACDIAN"/>
			<with-param name="TIPO_MONEDA" query-param="TIPO_MONEDA"/>
			<with-param name="TIPO_MEDIOPAGO" query-param="TIPO_MEDIOPAGO"/>
			<with-param name="TIPO_PAGO" query-param="TIPO_PAGO"/>

		</call-query>
	</resource>
	<query id="getResoluciondiancntRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA , TIPOCOMPROBANTE, NUMERO, PREFIJO ,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(TO_CHAR(FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, CONSECUTIVOINI,CONSECUTIVOFIN , TIPOFACDIAN, TIPO_MONEDA,TIPO_MEDIOPAGO, TIPO_PAGO FROM RESOLUCIONDIAN_CT WHERE RESOLUCIONDIAN_CT.COMPANIA= :KEY_COMPANIA AND RESOLUCIONDIAN_CT.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND RESOLUCIONDIAN_CT.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCOMPROBANTE":"$TIPOCOMPROBANTE","NUMERO":"$NUMERO","PREFIJO":"$PREFIJO","FECHAINICIAL":"$FECHAINICIAL","FECHAFINAL":"$FECHAFINAL","CONSECUTIVOINI":"$CONSECUTIVOINI","CONSECUTIVOFIN":"$CONSECUTIVOFIN","TIPOFACDIAN":"$TIPOFACDIAN","TIPO_MONEDA":"$TIPO_MONEDA","TIPO_MEDIOPAGO":"$TIPO_MEDIOPAGO","TIPO_PAGO":"$TIPO_PAGO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="resoluciondiancnt/data">
		<call-query href="getResoluciondiancntRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCOMPROBANTE" query-param="KEY_TIPOCOMPROBANTE"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateResoluciondiancnt" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RESOLUCIONDIAN_CT SET COMPANIA=:COMPANIA, TIPOCOMPROBANTE=:TIPOCOMPROBANTE, NUMERO=:NUMERO, PREFIJO=:PREFIJO, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), CONSECUTIVOINI=:CONSECUTIVOINI, CONSECUTIVOFIN=:CONSECUTIVOFIN, TIPOFACDIAN=:TIPOFACDIAN, TIPO_MONEDA=:TIPO_MONEDA, TIPO_MEDIOPAGO=:TIPO_MEDIOPAGO, TIPO_PAGO=:TIPO_PAGO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE RESOLUCIONDIAN_CT.COMPANIA= :KEY_COMPANIA AND RESOLUCIONDIAN_CT.TIPOCOMPROBANTE= :KEY_TIPOCOMPROBANTE AND RESOLUCIONDIAN_CT.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PREFIJO" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CONSECUTIVOINI" sqlType="STRING"/>
		<param name="CONSECUTIVOFIN" sqlType="STRING"/>
		<param name="TIPOFACDIAN" sqlType="STRING"/>
		<param name="TIPO_MONEDA" sqlType="STRING"/>
		<param name="TIPO_MEDIOPAGO" sqlType="STRING"/>
		<param name="TIPO_PAGO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="resoluciondiancnt">
