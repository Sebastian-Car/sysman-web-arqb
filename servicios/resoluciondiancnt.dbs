<data name="resoluciondiancnt" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getResoluciondiancntGetexisteresoluciondiannumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT NUMERO AS EXISTE FROM RESOLUCIONDIAN_CT WHERE COMPANIA = :COMPANIA AND TIPOCOMPROBANTE = :TIPOCOMPROBANTE AND TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS') BETWEEN FECHAINICIAL AND FECHAFINAL AND NUMERO NOT IN(:NUMERO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPROBANTE" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="resoluciondiancnt/getexisteresoluciondiannumero">
		<call-query href="getResoluciondiancntGetexisteresoluciondiannumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPROBANTE" query-param="TIPOCOMPROBANTE"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
