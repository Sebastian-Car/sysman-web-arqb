	<query id="getInformesentesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA,TIPO,CODIGO,NOMBRE,SUBTIPO,CONSULTA,ENCABEZADO,(CASE TOTAL WHEN 0 THEN 'false' ELSE 'true' END) TOTAL,CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,NOMBRE_ARCHIVO,FORMATO,COLUMNAS,SEPARADOR FROM INFORMES_ENTES WHERE INFORMES_ENTES.COMPANIA= :KEY_COMPANIA AND INFORMES_ENTES.TIPO= :KEY_TIPO AND INFORMES_ENTES.SUBTIPO= :KEY_SUBTIPO AND INFORMES_ENTES.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SUBTIPO":"$SUBTIPO","CONSULTA":"$CONSULTA","ENCABEZADO":"$ENCABEZADO","TOTAL":"$TOTAL(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE_ARCHIVO":"$NOMBRE_ARCHIVO","FORMATO":"$FORMATO","COLUMNAS":"$COLUMNAS","SEPARADOR":"$SEPARADOR"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_SUBTIPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="informesentes/data">
