	<query id="getInformesentesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA,TIPO,CODIGO,NOMBRE,SUBTIPO,CONSULTA,ENCABEZADO,(CASE TOTAL WHEN 0 THEN 'false' ELSE 'true' END) TOTAL,CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,NOMBRE_ARCHIVO,FORMATO,COLUMNAS,SEPARADOR,VIGENCIAS_APPUI FROM INFORMES_ENTES WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND SUBTIPO = :SUBTIPO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SUBTIPO IS NULL THEN ' ' ELSE UPPER(SUBTIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:SUBTIPO), '%')) AND (CASE WHEN CONSULTA IS NULL THEN ' ' ELSE UPPER(CONSULTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSULTA), '%')) AND (CASE WHEN ENCABEZADO IS NULL THEN ' ' ELSE UPPER(ENCABEZADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENCABEZADO), '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTAL), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:CREATED_BY), '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_CREATED), '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFIED_BY), '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_MODIFIED), '%')) AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ARCHIVO), '%')) AND (CASE WHEN FORMATO IS NULL THEN ' ' ELSE UPPER(FORMATO) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMATO), '%')) AND (CASE WHEN COLUMNAS IS NULL THEN ' ' ELSE UPPER(COLUMNAS) END) LIKE UPPER(CONCAT(CONCAT('%',:COLUMNAS), '%')) AND (CASE WHEN SEPARADOR IS NULL THEN ' ' ELSE UPPER(SEPARADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SEPARADOR), '%')) AND (CASE WHEN VIGENCIAS_APPUI IS NULL THEN ' ' ELSE UPPER(VIGENCIAS_APPUI) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIAS_APPUI), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CONSULTA" sqlType="STRING"/>
		<param name="ENCABEZADO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="COLUMNAS" sqlType="STRING"/>
		<param name="SEPARADOR" sqlType="STRING"/>
		<param name="VIGENCIAS_APPUI" sqlType="STRING"/>

	</query>
