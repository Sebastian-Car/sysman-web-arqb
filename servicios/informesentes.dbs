			<with-param name="KEY_SUBTIPO" query-param="KEY_SUBTIPO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateInformesentes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INFORMES_ENTES SET COMPANIA=:COMPANIA, TIPO=:TIPO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, SUBTIPO=:SUBTIPO, CONSULTA=:CONSULTA, ENCABEZADO=:ENCABEZADO, TOTAL=:TOTAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), NOMBRE_ARCHIVO=:NOMBRE_ARCHIVO, FORMATO=:FORMATO, COLUMNAS=:COLUMNAS, SEPARADOR=:SEPARADOR, VIGENCIAS_APPUI=:VIGENCIAS_APPUI WHERE INFORMES_ENTES.COMPANIA= :KEY_COMPANIA AND INFORMES_ENTES.TIPO= :KEY_TIPO AND INFORMES_ENTES.SUBTIPO= :KEY_SUBTIPO AND INFORMES_ENTES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CONSULTA" sqlType="STRING"/>
		<param name="ENCABEZADO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="COLUMNAS" sqlType="STRING"/>
		<param name="SEPARADOR" sqlType="STRING"/>
		<param name="VIGENCIAS_APPUI" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_SUBTIPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
