	</resource>
	<query id="getInformesentesNumInformespermiteconsolidarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  INFORMES_ENTES.CODIGO,INFORMES_ENTES.NOMBRE,INFORMES_ENTES.ENCABEZADO,INFORMES_ENTES.CONSULTA,INFORMES_ENTES.NOMBRE_ARCHIVO,INFORMES_ENTES.FORMATO,INFORMES_ENTES.COLUMNAS,INFORMES_ENTES.SEPARADOR  FROM INFORMES_ENTES INNER JOIN TIPO_INFORMES_ENTES ON INFORMES_ENTES.TIPO = TIPO_INFORMES_ENTES.CODIGO WHERE INFORMES_ENTES.COMPANIA = :COMPANIA AND INFORMES_ENTES.TIPO =:TIPO AND INFORMES_ENTES.SUBTIPO =:SUBTIPO AND TIPO_INFORMES_ENTES.PERMITE_CONSOLIDAR NOT IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="informesentes/informespermiteconsolidar/num">
		<call-query href="getInformesentesNumInformespermiteconsolidarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

