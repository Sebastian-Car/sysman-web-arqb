			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="REPORTE" query-param="REPORTE"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>

		</call-query>
	</resource>
	<query id="getInformesentesPagInformespermiteconsolidarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  INFORMES_ENTES.CODIGO,INFORMES_ENTES.NOMBRE,INFORMES_ENTES.ENCABEZADO,INFORMES_ENTES.CONSULTA,INFORMES_ENTES.NOMBRE_ARCHIVO,INFORMES_ENTES.FORMATO,INFORMES_ENTES.COLUMNAS,INFORMES_ENTES.SEPARADOR  FROM INFORMES_ENTES INNER JOIN TIPO_INFORMES_ENTES ON INFORMES_ENTES.TIPO = TIPO_INFORMES_ENTES.CODIGO WHERE INFORMES_ENTES.COMPANIA = :COMPANIA AND INFORMES_ENTES.TIPO =:TIPO AND INFORMES_ENTES.SUBTIPO =:SUBTIPO AND TIPO_INFORMES_ENTES.PERMITE_CONSOLIDAR NOT IN (0)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ENCABEZADO":"$ENCABEZADO","CONSULTA":"$CONSULTA","NOMBRE_ARCHIVO":"$NOMBRE_ARCHIVO","FORMATO":"$FORMATO","COLUMNAS":"$COLUMNAS","SEPARADOR":"$SEPARADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="informesentes/informespermiteconsolidar/pag">
		<call-query href="getInformesentesPagInformespermiteconsolidarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

