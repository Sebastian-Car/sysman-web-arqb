	<query id="getInformesentesTiposubtipoyreporteQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONSULTA FROM INFORMES_ENTES WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND CODIGO = :REPORTE AND SUBTIPO = :SUBTIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSULTA":"$CONSULTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="REPORTE" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="informesentes/tiposubtipoyreporte">
		<call-query href="getInformesentesTiposubtipoyreporteQuery">
