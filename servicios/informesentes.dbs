<data name="informesentes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getInformesentesPagInformesEntesDeControlQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE,ENCABEZADO,CONSULTA,NOMBRE_ARCHIVO,FORMATO,COLUMNAS,SEPARADOR FROM INFORMES_ENTES WHERE COMPANIA = :COMPANIA AND TIPO =:TIPO AND SUBTIPO =:SUBTIPO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ENCABEZADO":"$ENCABEZADO","CONSULTA":"$CONSULTA","NOMBRE_ARCHIVO":"$NOMBRE_ARCHIVO","FORMATO":"$FORMATO","COLUMNAS":"$COLUMNAS","SEPARADOR":"$SEPARADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="informesentes/informesentesdecontrol/pag">
		<call-query href="getInformesentesPagInformesEntesDeControlQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInformesentesNumInformesEntesDeControlQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE,ENCABEZADO,CONSULTA,NOMBRE_ARCHIVO,FORMATO,COLUMNAS,SEPARADOR FROM INFORMES_ENTES WHERE COMPANIA = :COMPANIA AND TIPO =:TIPO AND SUBTIPO =:SUBTIPO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="informesentes/informesentesdecontrol/num">
		<call-query href="getInformesentesNumInformesEntesDeControlQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getInformesentesPagGetlistacleopatraQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE,ENCABEZADO,CONSULTA,NOMBRE_ARCHIVO,FORMATO,COLUMNAS,SEPARADOR,VIGENCIAS_APPUI FROM INFORMES_ENTES WHERE COMPANIA = :COMPANIA AND TIPO =:TIPO AND SUBTIPO =:SUBTIPO AND CODIGO BETWEEN :CODINI AND :CODFIN) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ENCABEZADO IS NULL THEN ' ' ELSE UPPER(ENCABEZADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENCABEZADO), '%')) AND (CASE WHEN CONSULTA IS NULL THEN ' ' ELSE UPPER(CONSULTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSULTA), '%')) AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ARCHIVO), '%')) AND (CASE WHEN FORMATO IS NULL THEN ' ' ELSE UPPER(FORMATO) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMATO), '%')) AND (CASE WHEN COLUMNAS IS NULL THEN ' ' ELSE UPPER(COLUMNAS) END) LIKE UPPER(CONCAT(CONCAT('%',:COLUMNAS), '%')) AND (CASE WHEN SEPARADOR IS NULL THEN ' ' ELSE UPPER(SEPARADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SEPARADOR), '%')) AND (CASE WHEN VIGENCIAS_APPUI IS NULL THEN ' ' ELSE UPPER(VIGENCIAS_APPUI) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIAS_APPUI), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ENCABEZADO":"$ENCABEZADO","CONSULTA":"$CONSULTA","NOMBRE_ARCHIVO":"$NOMBRE_ARCHIVO","FORMATO":"$FORMATO","COLUMNAS":"$COLUMNAS","SEPARADOR":"$SEPARADOR","VIGENCIAS_APPUI":"$VIGENCIAS_APPUI"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODINI" sqlType="STRING"/>
		<param name="CODFIN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ENCABEZADO" sqlType="STRING"/>
		<param name="CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="COLUMNAS" sqlType="STRING"/>
		<param name="SEPARADOR" sqlType="STRING"/>
		<param name="VIGENCIAS_APPUI" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="informesentes/getlistacleopatra/pag">
		<call-query href="getInformesentesPagGetlistacleopatraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="CODINI" query-param="CODINI"/>
			<with-param name="CODFIN" query-param="CODFIN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ENCABEZADO" query-param="ENCABEZADO"/>
			<with-param name="CONSULTA" query-param="CONSULTA"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="COLUMNAS" query-param="COLUMNAS"/>
			<with-param name="SEPARADOR" query-param="SEPARADOR"/>
			<with-param name="VIGENCIAS_APPUI" query-param="VIGENCIAS_APPUI"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInformesentesNumGetlistacleopatraQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE,ENCABEZADO,CONSULTA,NOMBRE_ARCHIVO,FORMATO,COLUMNAS,SEPARADOR,VIGENCIAS_APPUI FROM INFORMES_ENTES WHERE COMPANIA = :COMPANIA AND TIPO =:TIPO AND SUBTIPO =:SUBTIPO AND CODIGO BETWEEN :CODINI AND :CODFIN) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ENCABEZADO IS NULL THEN ' ' ELSE UPPER(ENCABEZADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENCABEZADO), '%')) AND (CASE WHEN CONSULTA IS NULL THEN ' ' ELSE UPPER(CONSULTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSULTA), '%')) AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ARCHIVO), '%')) AND (CASE WHEN FORMATO IS NULL THEN ' ' ELSE UPPER(FORMATO) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMATO), '%')) AND (CASE WHEN COLUMNAS IS NULL THEN ' ' ELSE UPPER(COLUMNAS) END) LIKE UPPER(CONCAT(CONCAT('%',:COLUMNAS), '%')) AND (CASE WHEN SEPARADOR IS NULL THEN ' ' ELSE UPPER(SEPARADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SEPARADOR), '%')) AND (CASE WHEN VIGENCIAS_APPUI IS NULL THEN ' ' ELSE UPPER(VIGENCIAS_APPUI) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIAS_APPUI), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODINI" sqlType="STRING"/>
		<param name="CODFIN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="ENCABEZADO" sqlType="STRING"/>
		<param name="CONSULTA" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="COLUMNAS" sqlType="STRING"/>
		<param name="SEPARADOR" sqlType="STRING"/>
		<param name="VIGENCIAS_APPUI" sqlType="STRING"/>

	</query>
	<resource method="GET" path="informesentes/getlistacleopatra/num">
		<call-query href="getInformesentesNumGetlistacleopatraQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="CODINI" query-param="CODINI"/>
			<with-param name="CODFIN" query-param="CODFIN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="ENCABEZADO" query-param="ENCABEZADO"/>
			<with-param name="CONSULTA" query-param="CONSULTA"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="COLUMNAS" query-param="COLUMNAS"/>
			<with-param name="SEPARADOR" query-param="SEPARADOR"/>
			<with-param name="VIGENCIAS_APPUI" query-param="VIGENCIAS_APPUI"/>

		</call-query>
	</resource>
	<query id="getInformesentesListasubtipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT TIPO,SUBTIPO FROM INFORMES_ENTES WHERE TIPO = :TIPO AND COMPANIA = :COMPANIA ORDER BY SUBTIPO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPO":"$TIPO","SUBTIPO":"$SUBTIPO"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="informesentes/listasubtipo">
		<call-query href="getInformesentesListasubtipoQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getInformesentesPagSubtipodepartamentosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT IF.SUBTIPO, D.NOMBRE FROM INFORMES_ENTES IF LEFT JOIN DEPARTAMENTO D ON IF.SUBTIPO = D.CODIGO WHERE TIPO = :TIPO AND COMPANIA = :COMPANIA ORDER BY SUBTIPO) INI WHERE (CASE WHEN SUBTIPO IS NULL THEN ' ' ELSE UPPER(SUBTIPO) END) LIKE UPPER(CONCAT(:SUBTIPO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUBTIPO":"$SUBTIPO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="informesentes/subtipodepartamentos/pag">
		<call-query href="getInformesentesPagSubtipodepartamentosQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInformesentesNumSubtipodepartamentosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT IF.SUBTIPO, D.NOMBRE FROM INFORMES_ENTES IF LEFT JOIN DEPARTAMENTO D ON IF.SUBTIPO = D.CODIGO WHERE TIPO = :TIPO AND COMPANIA = :COMPANIA ORDER BY SUBTIPO) INI WHERE (CASE WHEN SUBTIPO IS NULL THEN ' ' ELSE UPPER(SUBTIPO) END) LIKE UPPER(CONCAT(:SUBTIPO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="informesentes/subtipodepartamentos/num">
		<call-query href="getInformesentesNumSubtipodepartamentosQuery">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertInformesentes" keyColumns="COMPANIA,TIPO,SUBTIPO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO INFORMES_ENTES (COMPANIA, TIPO, CODIGO, NOMBRE, SUBTIPO, CONSULTA, ENCABEZADO, TOTAL, CREATED_BY, DATE_CREATED, NOMBRE_ARCHIVO, FORMATO, SEPARADOR, COLUMNAS, VIGENCIAS_APPUI) VALUES (:COMPANIA, :TIPO, :CODIGO, :NOMBRE, :SUBTIPO, :CONSULTA, :ENCABEZADO, :TOTAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :NOMBRE_ARCHIVO, :FORMATO, :SEPARADOR, :COLUMNAS, :VIGENCIAS_APPUI)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_SUBTIPO":"$SUBTIPO","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="0" name="SUBTIPO" sqlType="STRING"/>
		<param defaultValue="" name="CONSULTA" sqlType="STRING"/>
		<param defaultValue="" name="ENCABEZADO" sqlType="STRING"/>
		<param defaultValue="0" name="TOTAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO" sqlType="STRING"/>
		<param defaultValue="|" name="SEPARADOR" sqlType="STRING"/>
		<param defaultValue="" name="COLUMNAS" sqlType="STRING"/>
		<param defaultValue="" name="VIGENCIAS_APPUI" sqlType="STRING"/>

	</query>
	<resource method="POST" path="informesentes">
		<call-query href="insertInformesentes">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SUBTIPO" query-param="SUBTIPO"/>
			<with-param name="CONSULTA" query-param="CONSULTA"/>
			<with-param name="ENCABEZADO" query-param="ENCABEZADO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="NOMBRE_ARCHIVO" query-param="NOMBRE_ARCHIVO"/>
			<with-param name="FORMATO" query-param="FORMATO"/>
			<with-param name="SEPARADOR" query-param="SEPARADOR"/>
			<with-param name="COLUMNAS" query-param="COLUMNAS"/>
			<with-param name="VIGENCIAS_APPUI" query-param="VIGENCIAS_APPUI"/>

		</call-query>
	</resource>
	<query id="getInformesentesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA,TIPO,CODIGO,NOMBRE,SUBTIPO,CONSULTA,ENCABEZADO,(CASE TOTAL WHEN 0 THEN 'false' ELSE 'true' END) TOTAL,CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,NOMBRE_ARCHIVO,FORMATO,COLUMNAS,SEPARADOR,VIGENCIAS_APPUI FROM INFORMES_ENTES WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND SUBTIPO = :SUBTIPO) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SUBTIPO IS NULL THEN ' ' ELSE UPPER(SUBTIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:SUBTIPO), '%')) AND (CASE WHEN CONSULTA IS NULL THEN ' ' ELSE UPPER(CONSULTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSULTA), '%')) AND (CASE WHEN ENCABEZADO IS NULL THEN ' ' ELSE UPPER(ENCABEZADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ENCABEZADO), '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTAL), '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:CREATED_BY), '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_CREATED), '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(CONCAT('%',:MODIFIED_BY), '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(CONCAT('%',:DATE_MODIFIED), '%')) AND (CASE WHEN NOMBRE_ARCHIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ARCHIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ARCHIVO), '%')) AND (CASE WHEN FORMATO IS NULL THEN ' ' ELSE UPPER(FORMATO) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMATO), '%')) AND (CASE WHEN COLUMNAS IS NULL THEN ' ' ELSE UPPER(COLUMNAS) END) LIKE UPPER(CONCAT(CONCAT('%',:COLUMNAS), '%')) AND (CASE WHEN SEPARADOR IS NULL THEN ' ' ELSE UPPER(SEPARADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SEPARADOR), '%')) AND (CASE WHEN VIGENCIAS_APPUI IS NULL THEN ' ' ELSE UPPER(VIGENCIAS_APPUI) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIAS_APPUI), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SUBTIPO":"$SUBTIPO","CONSULTA":"$CONSULTA","ENCABEZADO":"$ENCABEZADO","TOTAL":"$TOTAL(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRE_ARCHIVO":"$NOMBRE_ARCHIVO","FORMATO":"$FORMATO","COLUMNAS":"$COLUMNAS","SEPARADOR":"$SEPARADOR","VIGENCIAS_APPUI":"$VIGENCIAS_APPUI"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="SUBTIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CONSULTA" sqlType="STRING"/>
		<param name="ENCABEZADO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="NOMBRE_ARCHIVO" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="COLUMNAS" sqlType="STRING"/>
		<param name="SEPARADOR" sqlType="STRING"/>
		<param name="VIGENCIAS_APPUI" sqlType="STRING"/>
