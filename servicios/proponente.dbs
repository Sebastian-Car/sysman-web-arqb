	<query id="updateProponente" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PROPONENTE SET COMPANIA=:COMPANIA, TIPOCONTRATO=:TIPOCONTRATO, TRANSACCION=:TRANSACCION, CONSECUTIVODETALLE=:CONSECUTIVODETALLE, PROPONENTE=:PROPONENTE, SUCURSAL=:SUCURSAL, FECHAINSCRIPCION=TO_DATE(:FECHAINSCRIPCION,'DD/MM/YYYY HH24:MI:SS'), DOCUMENTOSOPORTE=:DOCUMENTOSOPORTE, ESTADO=:ESTADO, FOLIO=:FOLIO, VALORP=:VALORP, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PROPONENTE.COMPANIA= :KEY_COMPANIA AND PROPONENTE.TIPOCONTRATO= :KEY_TIPOCONTRATO AND PROPONENTE.TRANSACCION= :KEY_TRANSACCION AND PROPONENTE.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND PROPONENTE.PROPONENTE= :KEY_PROPONENTE AND PROPONENTE.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="FECHAINSCRIPCION" sqlType="STRING"/>
		<param name="DOCUMENTOSOPORTE" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
