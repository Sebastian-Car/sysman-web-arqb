<data name="anos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getAnosTodosPorNumeroDescQuery"  useConfig="sysmandsunist">
		<sql>SELECT ANO.NUMERO FROM ANO WHERE ANO.COMPANIA =:COMPANIA AND ANO.NUMERO NOT IN (0) ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/todospornumerodesc">
		<call-query href="getAnosTodosPorNumeroDescQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getAnosHastaActualQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO.NUMERO  FROM ANO WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO &lt;= EXTRACT(YEAR FROM SYSDATE) AND NUMERO NOT IN (0) ORDER BY ANO.NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/hastaactual">
		<call-query href="getAnosHastaActualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getAnosTodosPorCuantiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO,SALARIOMINIMO,CUANTIAMINIMADEPRE,CUANTIAMINIMA  FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO NOT IN (0) ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","SALARIOMINIMO":"$SALARIOMINIMO","CUANTIAMINIMADEPRE":"$CUANTIAMINIMADEPRE","CUANTIAMINIMA":"$CUANTIAMINIMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/todosporcuantia">
		<call-query href="getAnosTodosPorCuantiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertAnosValoresCuantia" keyColumns="COMPANIA,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ANO (COMPANIA, NUMERO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="anos/valorescuantia">
		<call-query href="insertAnosValoresCuantia">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateAnosValoresCuantia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ANO SET SALARIOMINIMO = TO_NUMBER(:SALARIOMINIMO,'99999999999999999999.99'), CUANTIAMINIMA = TO_NUMBER(:CUANTIAMINIMA,'99999999999999999999.99'), CUANTIAMINIMADEPRE = TO_NUMBER(:CUANTIAMINIMADEPRE,'99999999999999999999.99'),DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') ,MODIFIED_BY=:MODIFIED_BY  WHERE COMPANIA = :COMPANIA AND NUMERO = :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SALARIOMINIMO" sqlType="STRING"/>
		<param name="CUANTIAMINIMA" sqlType="STRING"/>
		<param name="CUANTIAMINIMADEPRE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="anos/valorescuantia">
		<call-query href="updateAnosValoresCuantia">
			<with-param name="SALARIOMINIMO" query-param="SALARIOMINIMO"/>
			<with-param name="CUANTIAMINIMA" query-param="CUANTIAMINIMA"/>
			<with-param name="CUANTIAMINIMADEPRE" query-param="CUANTIAMINIMADEPRE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAnosTodosPorNumeroMenorIgualActualQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM ANO WHERE COMPANIA =:COMPANIA AND NUMERO &lt;= EXTRACT(YEAR FROM SYSDATE) AND NUMERO NOT IN(0) ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/todospornumeromenorigualactual">
		<call-query href="getAnosTodosPorNumeroMenorIgualActualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getAnosRetencionesMinimasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO.NUMERO  FROM ANO LEFT JOIN RETENCIONES_MINIMAS ON ANO.COMPANIA = RETENCIONES_MINIMAS.COMPANIA AND ANO.NUMERO = RETENCIONES_MINIMAS.ANO WHERE ANO.COMPANIA = :COMPANIA AND (ANO.NUMERO NOT IN (0) AND RETENCIONES_MINIMAS.ANO IS NULL) ORDER BY NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/retencionesminimas">
		<call-query href="getAnosRetencionesMinimasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getAnosTodosPorEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO.NUMERO  FROM ANO WHERE ANO.COMPANIA =:COMPANIA AND ANO.NUMERO NOT IN (0) ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/todosporestado">
		<call-query href="getAnosTodosPorEstadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertAnos" keyColumns="COMPANIA,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ANO (COMPANIA, NUMERO, VALORUVT, VLRFONDOSOL_PENSIONAL, PORCENTAJESALUD, PORCENTAJEPENSION, PATRIMONIOBRUTO_UVT, INGRESOSTOTALES_UVT, CONSUMOTARJETACRE_UVT, COMPRASYCONSUMO_UVT, CONSIGNACIONESBANCARIAS_UVT, INICIA_CONTABILIDAD, FORMATO_DIAN, CEDULAFIRMACERT_DIAN, NOMBREFIRMACERT_DIAN, MODELO, CLASE_CUIPO, LIM_25_RE, LIM_40_DRE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO, :VALORUVT, :VLRFONDOSOL_PENSIONAL, :PORCENTAJESALUD, :PORCENTAJEPENSION, :PATRIMONIOBRUTO_UVT, :INGRESOSTOTALES_UVT, :CONSUMOTARJETACRE_UVT, :COMPRASYCONSUMO_UVT, :CONSIGNACIONESBANCARIAS_UVT, :INICIA_CONTABILIDAD, :FORMATO_DIAN, :CEDULAFIRMACERT_DIAN, :NOMBREFIRMACERT_DIAN, :MODELO, :CLASE_CUIPO, :LIM_25_RE, :LIM_40_DRE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUVT" sqlType="STRING"/>
		<param defaultValue="0" name="VLRFONDOSOL_PENSIONAL" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJESALUD" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJEPENSION" sqlType="STRING"/>
		<param defaultValue="0" name="PATRIMONIOBRUTO_UVT" sqlType="STRING"/>
		<param defaultValue="0" name="INGRESOSTOTALES_UVT" sqlType="STRING"/>
		<param defaultValue="0" name="CONSUMOTARJETACRE_UVT" sqlType="STRING"/>
		<param defaultValue="0" name="COMPRASYCONSUMO_UVT" sqlType="STRING"/>
		<param defaultValue="0" name="CONSIGNACIONESBANCARIAS_UVT" sqlType="STRING"/>
		<param defaultValue="0" name="INICIA_CONTABILIDAD" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO_DIAN" sqlType="STRING"/>
		<param defaultValue="" name="CEDULAFIRMACERT_DIAN" sqlType="STRING"/>
		<param defaultValue="" name="NOMBREFIRMACERT_DIAN" sqlType="STRING"/>
		<param defaultValue="1" name="MODELO" sqlType="STRING"/>
		<param defaultValue="" name="LIM_25_RE" sqlType="STRING"/>
		<param defaultValue="" name="LIM_40_DRE" sqlType="STRING"/>
		<param defaultValue="" name="CLASE_CUIPO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="anos">
		<call-query href="insertAnos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALORUVT" query-param="VALORUVT"/>
			<with-param name="VLRFONDOSOL_PENSIONAL" query-param="VLRFONDOSOL_PENSIONAL"/>
			<with-param name="PORCENTAJESALUD" query-param="PORCENTAJESALUD"/>
			<with-param name="PORCENTAJEPENSION" query-param="PORCENTAJEPENSION"/>
			<with-param name="PATRIMONIOBRUTO_UVT" query-param="PATRIMONIOBRUTO_UVT"/>
			<with-param name="INGRESOSTOTALES_UVT" query-param="INGRESOSTOTALES_UVT"/>
			<with-param name="CONSUMOTARJETACRE_UVT" query-param="CONSUMOTARJETACRE_UVT"/>
			<with-param name="COMPRASYCONSUMO_UVT" query-param="COMPRASYCONSUMO_UVT"/>
			<with-param name="CONSIGNACIONESBANCARIAS_UVT" query-param="CONSIGNACIONESBANCARIAS_UVT"/>
			<with-param name="INICIA_CONTABILIDAD" query-param="INICIA_CONTABILIDAD"/>
			<with-param name="FORMATO_DIAN" query-param="FORMATO_DIAN"/>
			<with-param name="CEDULAFIRMACERT_DIAN" query-param="CEDULAFIRMACERT_DIAN"/>
			<with-param name="NOMBREFIRMACERT_DIAN" query-param="NOMBREFIRMACERT_DIAN"/>
			<with-param name="MODELO" query-param="MODELO"/>
			<with-param name="LIM_25_RE" query-param="LIM_25_RE"/>
			<with-param name="LIM_40_DRE" query-param="LIM_40_DRE"/>
			<with-param name="CLASE_CUIPO" query-param="CLASE_CUIPO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getAnosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, NUMERO, VALORUVT, VLRFONDOSOL_PENSIONAL, PORCENTAJESALUD, PORCENTAJEPENSION, PATRIMONIOBRUTO_UVT, INGRESOSTOTALES_UVT, CONSUMOTARJETACRE_UVT, COMPRASYCONSUMO_UVT, CONSIGNACIONESBANCARIAS_UVT,(CASE INICIA_CONTABILIDAD WHEN 0 THEN 'false' ELSE 'true' END) INICIA_CONTABILIDAD, FORMATO_DIAN, CEDULAFIRMACERT_DIAN, NOMBREFIRMACERT_DIAN, MODELO, CASE MODELO WHEN '1' THEN 'SIN CUIPO' WHEN '2' THEN 'CON AUXILIARES' WHEN '3' THEN 'ARBOL' END NOMBREMODELO, CLASE_CUIPO, LIM_25_RE, LIM_40_DRE FROM ANO WHERE ANO.COMPANIA = :COMPANIA ORDER BY ANO.COMPANIA DESC, ANO.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN VALORUVT IS NULL THEN ' ' ELSE UPPER(VALORUVT) END) LIKE UPPER(CONCAT(:VALORUVT, '%')) AND (CASE WHEN VLRFONDOSOL_PENSIONAL IS NULL THEN ' ' ELSE UPPER(VLRFONDOSOL_PENSIONAL) END) LIKE UPPER(CONCAT(:VLRFONDOSOL_PENSIONAL, '%')) AND (CASE WHEN PORCENTAJESALUD IS NULL THEN ' ' ELSE UPPER(PORCENTAJESALUD) END) LIKE UPPER(CONCAT(:PORCENTAJESALUD, '%')) AND (CASE WHEN PORCENTAJEPENSION IS NULL THEN ' ' ELSE UPPER(PORCENTAJEPENSION) END) LIKE UPPER(CONCAT(:PORCENTAJEPENSION, '%')) AND (CASE WHEN PATRIMONIOBRUTO_UVT IS NULL THEN ' ' ELSE UPPER(PATRIMONIOBRUTO_UVT) END) LIKE UPPER(CONCAT(:PATRIMONIOBRUTO_UVT, '%')) AND (CASE WHEN INGRESOSTOTALES_UVT IS NULL THEN ' ' ELSE UPPER(INGRESOSTOTALES_UVT) END) LIKE UPPER(CONCAT(:INGRESOSTOTALES_UVT, '%')) AND (CASE WHEN CONSUMOTARJETACRE_UVT IS NULL THEN ' ' ELSE UPPER(CONSUMOTARJETACRE_UVT) END) LIKE UPPER(CONCAT(:CONSUMOTARJETACRE_UVT, '%')) AND (CASE WHEN COMPRASYCONSUMO_UVT IS NULL THEN ' ' ELSE UPPER(COMPRASYCONSUMO_UVT) END) LIKE UPPER(CONCAT(:COMPRASYCONSUMO_UVT, '%')) AND (CASE WHEN CONSIGNACIONESBANCARIAS_UVT IS NULL THEN ' ' ELSE UPPER(CONSIGNACIONESBANCARIAS_UVT) END) LIKE UPPER(CONCAT(:CONSIGNACIONESBANCARIAS_UVT, '%')) AND (CASE WHEN INICIA_CONTABILIDAD IS NULL THEN ' ' ELSE UPPER(INICIA_CONTABILIDAD) END) LIKE UPPER(CONCAT(:INICIA_CONTABILIDAD, '%')) AND (CASE WHEN FORMATO_DIAN IS NULL THEN ' ' ELSE UPPER(FORMATO_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMATO_DIAN), '%')) AND (CASE WHEN CEDULAFIRMACERT_DIAN IS NULL THEN ' ' ELSE UPPER(CEDULAFIRMACERT_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CEDULAFIRMACERT_DIAN), '%')) AND (CASE WHEN NOMBREFIRMACERT_DIAN IS NULL THEN ' ' ELSE UPPER(NOMBREFIRMACERT_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFIRMACERT_DIAN), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(:MODELO, '%')) AND (CASE WHEN NOMBREMODELO IS NULL THEN ' ' ELSE UPPER(NOMBREMODELO) END) LIKE UPPER(CONCAT(:NOMBREMODELO, '%')) AND (CASE WHEN CLASE_CUIPO IS NULL THEN ' ' ELSE UPPER(CLASE_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CUIPO), '%')) AND (CASE WHEN LIM_25_RE IS NULL THEN ' ' ELSE UPPER(LIM_25_RE) END) LIKE UPPER(CONCAT(CONCAT('%',:LIM_25_RE), '%')) AND (CASE WHEN LIM_40_DRE IS NULL THEN ' ' ELSE UPPER(LIM_40_DRE) END) LIKE UPPER(CONCAT(CONCAT('%',:LIM_40_DRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","VALORUVT":"$VALORUVT","VLRFONDOSOL_PENSIONAL":"$VLRFONDOSOL_PENSIONAL","PORCENTAJESALUD":"$PORCENTAJESALUD","PORCENTAJEPENSION":"$PORCENTAJEPENSION","PATRIMONIOBRUTO_UVT":"$PATRIMONIOBRUTO_UVT","INGRESOSTOTALES_UVT":"$INGRESOSTOTALES_UVT","CONSUMOTARJETACRE_UVT":"$CONSUMOTARJETACRE_UVT","COMPRASYCONSUMO_UVT":"$COMPRASYCONSUMO_UVT","CONSIGNACIONESBANCARIAS_UVT":"$CONSIGNACIONESBANCARIAS_UVT","INICIA_CONTABILIDAD":"$INICIA_CONTABILIDAD(type:boolean)","FORMATO_DIAN":"$FORMATO_DIAN","CEDULAFIRMACERT_DIAN":"$CEDULAFIRMACERT_DIAN","NOMBREFIRMACERT_DIAN":"$NOMBREFIRMACERT_DIAN","MODELO":"$MODELO","NOMBREMODELO":"$NOMBREMODELO","CLASE_CUIPO":"$CLASE_CUIPO","LIM_25_RE":"$LIM_25_RE","LIM_40_DRE":"$LIM_40_DRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALORUVT" sqlType="STRING"/>
		<param name="VLRFONDOSOL_PENSIONAL" sqlType="STRING"/>
		<param name="PORCENTAJESALUD" sqlType="STRING"/>
		<param name="PORCENTAJEPENSION" sqlType="STRING"/>
		<param name="PATRIMONIOBRUTO_UVT" sqlType="STRING"/>
		<param name="INGRESOSTOTALES_UVT" sqlType="STRING"/>
		<param name="CONSUMOTARJETACRE_UVT" sqlType="STRING"/>
		<param name="COMPRASYCONSUMO_UVT" sqlType="STRING"/>
		<param name="CONSIGNACIONESBANCARIAS_UVT" sqlType="STRING"/>
		<param name="INICIA_CONTABILIDAD" sqlType="STRING"/>
		<param name="FORMATO_DIAN" sqlType="STRING"/>
		<param name="CEDULAFIRMACERT_DIAN" sqlType="STRING"/>
		<param name="NOMBREFIRMACERT_DIAN" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="NOMBREMODELO" sqlType="STRING"/>
		<param name="LIM_25_RE" sqlType="STRING"/>
		<param name="LIM_40_DRE" sqlType="STRING"/>
		<param name="CLASE_CUIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="anos">
		<call-query href="getAnosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VALORUVT" query-param="VALORUVT"/>
			<with-param name="VLRFONDOSOL_PENSIONAL" query-param="VLRFONDOSOL_PENSIONAL"/>
			<with-param name="PORCENTAJESALUD" query-param="PORCENTAJESALUD"/>
			<with-param name="PORCENTAJEPENSION" query-param="PORCENTAJEPENSION"/>
			<with-param name="PATRIMONIOBRUTO_UVT" query-param="PATRIMONIOBRUTO_UVT"/>
			<with-param name="INGRESOSTOTALES_UVT" query-param="INGRESOSTOTALES_UVT"/>
			<with-param name="CONSUMOTARJETACRE_UVT" query-param="CONSUMOTARJETACRE_UVT"/>
			<with-param name="COMPRASYCONSUMO_UVT" query-param="COMPRASYCONSUMO_UVT"/>
			<with-param name="CONSIGNACIONESBANCARIAS_UVT" query-param="CONSIGNACIONESBANCARIAS_UVT"/>
			<with-param name="INICIA_CONTABILIDAD" query-param="INICIA_CONTABILIDAD"/>
			<with-param name="FORMATO_DIAN" query-param="FORMATO_DIAN"/>
			<with-param name="CEDULAFIRMACERT_DIAN" query-param="CEDULAFIRMACERT_DIAN"/>
			<with-param name="NOMBREFIRMACERT_DIAN" query-param="NOMBREFIRMACERT_DIAN"/>
			<with-param name="MODELO" query-param="MODELO"/>
			<with-param name="NOMBREMODELO" query-param="NOMBREMODELO"/>
			<with-param name="LIM_25_RE" query-param="LIM_25_RE"/>
			<with-param name="LIM_40_DRE" query-param="LIM_40_DRE"/>
			<with-param name="CLASE_CUIPO" query-param="CLASE_CUIPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAnosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, NUMERO, VALORUVT, VLRFONDOSOL_PENSIONAL, PORCENTAJESALUD, PORCENTAJEPENSION, PATRIMONIOBRUTO_UVT, INGRESOSTOTALES_UVT, CONSUMOTARJETACRE_UVT, COMPRASYCONSUMO_UVT, CONSIGNACIONESBANCARIAS_UVT,(CASE INICIA_CONTABILIDAD WHEN 0 THEN 'false' ELSE 'true' END) INICIA_CONTABILIDAD, FORMATO_DIAN, CEDULAFIRMACERT_DIAN, NOMBREFIRMACERT_DIAN, MODELO, CASE MODELO WHEN '1' THEN 'SIN CUIPO' WHEN '2' THEN 'CON AUXILIARES' WHEN '3' THEN 'ARBOL' END NOMBREMODELO , CLASE_CUIPO, LIM_25_RE, LIM_40_DRE FROM ANO WHERE ANO.COMPANIA = :COMPANIA ORDER BY ANO.COMPANIA DESC, ANO.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN VALORUVT IS NULL THEN ' ' ELSE UPPER(VALORUVT) END) LIKE UPPER(CONCAT(:VALORUVT, '%')) AND (CASE WHEN VLRFONDOSOL_PENSIONAL IS NULL THEN ' ' ELSE UPPER(VLRFONDOSOL_PENSIONAL) END) LIKE UPPER(CONCAT(:VLRFONDOSOL_PENSIONAL, '%')) AND (CASE WHEN PORCENTAJESALUD IS NULL THEN ' ' ELSE UPPER(PORCENTAJESALUD) END) LIKE UPPER(CONCAT(:PORCENTAJESALUD, '%')) AND (CASE WHEN PORCENTAJEPENSION IS NULL THEN ' ' ELSE UPPER(PORCENTAJEPENSION) END) LIKE UPPER(CONCAT(:PORCENTAJEPENSION, '%')) AND (CASE WHEN PATRIMONIOBRUTO_UVT IS NULL THEN ' ' ELSE UPPER(PATRIMONIOBRUTO_UVT) END) LIKE UPPER(CONCAT(:PATRIMONIOBRUTO_UVT, '%')) AND (CASE WHEN INGRESOSTOTALES_UVT IS NULL THEN ' ' ELSE UPPER(INGRESOSTOTALES_UVT) END) LIKE UPPER(CONCAT(:INGRESOSTOTALES_UVT, '%')) AND (CASE WHEN CONSUMOTARJETACRE_UVT IS NULL THEN ' ' ELSE UPPER(CONSUMOTARJETACRE_UVT) END) LIKE UPPER(CONCAT(:CONSUMOTARJETACRE_UVT, '%')) AND (CASE WHEN COMPRASYCONSUMO_UVT IS NULL THEN ' ' ELSE UPPER(COMPRASYCONSUMO_UVT) END) LIKE UPPER(CONCAT(:COMPRASYCONSUMO_UVT, '%')) AND (CASE WHEN CONSIGNACIONESBANCARIAS_UVT IS NULL THEN ' ' ELSE UPPER(CONSIGNACIONESBANCARIAS_UVT) END) LIKE UPPER(CONCAT(:CONSIGNACIONESBANCARIAS_UVT, '%')) AND (CASE WHEN INICIA_CONTABILIDAD IS NULL THEN ' ' ELSE UPPER(INICIA_CONTABILIDAD) END) LIKE UPPER(CONCAT(:INICIA_CONTABILIDAD, '%')) AND (CASE WHEN FORMATO_DIAN IS NULL THEN ' ' ELSE UPPER(FORMATO_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:FORMATO_DIAN), '%')) AND (CASE WHEN CEDULAFIRMACERT_DIAN IS NULL THEN ' ' ELSE UPPER(CEDULAFIRMACERT_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:CEDULAFIRMACERT_DIAN), '%')) AND (CASE WHEN NOMBREFIRMACERT_DIAN IS NULL THEN ' ' ELSE UPPER(NOMBREFIRMACERT_DIAN) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREFIRMACERT_DIAN), '%')) AND (CASE WHEN MODELO IS NULL THEN ' ' ELSE UPPER(MODELO) END) LIKE UPPER(CONCAT(:MODELO, '%')) AND (CASE WHEN NOMBREMODELO IS NULL THEN ' ' ELSE UPPER(NOMBREMODELO) END) LIKE UPPER(CONCAT(:NOMBREMODELO, '%')) AND (CASE WHEN CLASE_CUIPO IS NULL THEN ' ' ELSE UPPER(CLASE_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE_CUIPO), '%')) AND (CASE WHEN LIM_25_RE IS NULL THEN ' ' ELSE UPPER(LIM_25_RE) END) LIKE UPPER(CONCAT(CONCAT('%',:LIM_25_RE), '%')) AND (CASE WHEN LIM_40_DRE IS NULL THEN ' ' ELSE UPPER(LIM_40_DRE) END) LIKE UPPER(CONCAT(CONCAT('%',:LIM_40_DRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VALORUVT" sqlType="STRING"/>
		<param name="VLRFONDOSOL_PENSIONAL" sqlType="STRING"/>
		<param name="PORCENTAJESALUD" sqlType="STRING"/>
		<param name="PORCENTAJEPENSION" sqlType="STRING"/>
		<param name="PATRIMONIOBRUTO_UVT" sqlType="STRING"/>
		<param name="INGRESOSTOTALES_UVT" sqlType="STRING"/>
		<param name="CONSUMOTARJETACRE_UVT" sqlType="STRING"/>
		<param name="COMPRASYCONSUMO_UVT" sqlType="STRING"/>
		<param name="CONSIGNACIONESBANCARIAS_UVT" sqlType="STRING"/>
		<param name="INICIA_CONTABILIDAD" sqlType="STRING"/>
		<param name="FORMATO_DIAN" sqlType="STRING"/>
		<param name="CEDULAFIRMACERT_DIAN" sqlType="STRING"/>
		<param name="NOMBREFIRMACERT_DIAN" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="NOMBREMODELO" sqlType="STRING"/>
		<param name="LIM_25_RE" sqlType="STRING"/>
		<param name="LIM_40_DRE" sqlType="STRING"/>

		<param name="CLASE_CUIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/numero">
