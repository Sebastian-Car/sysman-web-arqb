	<query id="getAnosTodosPorMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO.NUMERO ANO  FROM ANO WHERE ANO.COMPANIA =:COMPANIA AND ANO.NUMERO NOT IN (0) ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
