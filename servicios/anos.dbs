	<query id="getAnosTodosDeNivelDeCumplimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO.NUMERO  FROM ANO LEFT JOIN BP_NIVEL_CUMPLIMIENTO ON ANO.COMPANIA = BP_NIVEL_CUMPLIMIENTO.COMPANIA AND ANO.NUMERO = BP_NIVEL_CUMPLIMIENTO.VIGENCIA WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO &gt;= :ANO AND ANO.NUMERO NOT IN(0) ORDER BY ANO.NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
