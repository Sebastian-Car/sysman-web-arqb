			<with-param name="FECHA_CIERRE_PLAN_INDI_EJEC" query-param="FECHA_CIERRE_PLAN_INDI_EJEC"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getAnosEstadoactivopresupuestoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM ANO WHERE COMPANIA = :COMPANIA AND PCK_SYSMAN_UTL.FC_VERIFICAR_ESTADOANO(COMPANIA, NUMERO,3,1) ='A' ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
