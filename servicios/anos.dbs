	<query id="getAnosTodosLosAnosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'TODAS' NUMERO  FROM ANO UNION SELECT TO_CHAR(NUMERO) FROM ANO WHERE ANO.COMPANIA = :COMPANIA AND NUMERO &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/todoslosanos">
