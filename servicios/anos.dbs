			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateAnos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ANO SET VALORUVT=:VALORUVT, VLRFONDOSOL_PENSIONAL=:VLRFONDOSOL_PENSIONAL, PORCENTAJESALUD=:PORCENTAJESALUD, PORCENTAJEPENSION=:PORCENTAJEPENSION, PATRIMONIOBRUTO_UVT=:PATRIMONIOBRUTO_UVT, INGRESOSTOTALES_UVT=:INGRESOSTOTALES_UVT, CONSUMOTARJETACRE_UVT=:CONSUMOTARJETACRE_UVT, COMPRASYCONSUMO_UVT=:COMPRASYCONSUMO_UVT, CONSIGNACIONESBANCARIAS_UVT=:CONSIGNACIONESBANCARIAS_UVT, INICIA_CONTABILIDAD=:INICIA_CONTABILIDAD, FORMATO_DIAN=:FORMATO_DIAN, CEDULAFIRMACERT_DIAN=:CEDULAFIRMACERT_DIAN, NOMBREFIRMACERT_DIAN=:NOMBREFIRMACERT_DIAN, MODELO=:MODELO, CLASE_CUIPO=:CLASE_CUIPO, LIM_25_RE=:LIM_25_RE, LIM_40_DRE=:LIM_40_DRE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ANO.COMPANIA= :KEY_COMPANIA AND ANO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALORUVT" sqlType="STRING"/>
		<param name="VLRFONDOSOL_PENSIONAL" sqlType="STRING"/>
		<param name="PORCENTAJESALUD" sqlType="STRING"/>
		<param name="PORCENTAJEPENSION" sqlType="STRING"/>
		<param name="PATRIMONIOBRUTO_UVT" sqlType="STRING"/>
		<param name="INGRESOSTOTALES_UVT" sqlType="STRING"/>
		<param name="CONSUMOTARJETACRE_UVT" sqlType="STRING"/>
		<param name="COMPRASYCONSUMO_UVT" sqlType="STRING"/>
		<param name="CONSIGNACIONESBANCARIAS_UVT" sqlType="STRING"/>
		<param name="INICIA_CONTABILIDAD" sqlType="STRING"/>
		<param name="FORMATO_DIAN" sqlType="STRING"/>
		<param name="CEDULAFIRMACERT_DIAN" sqlType="STRING"/>
		<param name="NOMBREFIRMACERT_DIAN" sqlType="STRING"/>
		<param name="MODELO" sqlType="STRING"/>
		<param name="LIM_25_RE" sqlType="STRING"/>
		<param name="LIM_40_DRE" sqlType="STRING"/>
		<param name="CLASE_CUIPO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
