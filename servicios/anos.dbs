			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getAnosAniosEntreVigenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO, ROWNUM  FROM (SELECT DISTINCT NUMERO FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO BETWEEN :VIGENCIAINICIAL AND :VIGENCIAFIN ORDER BY NUMERO )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","ROWNUM":"$ROWNUM(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIAINICIAL" sqlType="STRING"/>
		<param name="VIGENCIAFIN" sqlType="STRING"/>

	</query>
