	</resource>
	<query id="getAnosMayoranofuenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO &gt;= :ANO ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
