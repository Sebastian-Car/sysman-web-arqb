		</call-query>
	</resource>
	<query id="getAnosPagPorCompaniaFacturacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ANO.COMPANIA, ANO.NUMERO, ANO.SALARIOMINIMO, ANO.VALORUVT  FROM ANO WHERE ANO.COMPANIA = :COMPANIA ORDER BY ANO.NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN SALARIOMINIMO IS NULL THEN ' ' ELSE UPPER(SALARIOMINIMO) END)  LIKE UPPER(:SALARIOMINIMO || '%')  AND (CASE WHEN VALORUVT IS NULL THEN ' ' ELSE UPPER(VALORUVT) END)  LIKE UPPER(:VALORUVT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","SALARIOMINIMO":"$SALARIOMINIMO","VALORUVT":"$VALORUVT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="SALARIOMINIMO" sqlType="STRING"/>
		<param name="VALORUVT" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="anos/porcompaniafacturacion/pag">
		<call-query href="getAnosPagPorCompaniaFacturacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="SALARIOMINIMO" query-param="SALARIOMINIMO"/>
			<with-param name="VALORUVT" query-param="VALORUVT"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAnosNumPorCompaniaFacturacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ANO.COMPANIA, ANO.NUMERO, ANO.SALARIOMINIMO, ANO.VALORUVT  FROM ANO WHERE ANO.COMPANIA = :COMPANIA ORDER BY ANO.NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN SALARIOMINIMO IS NULL THEN ' ' ELSE UPPER(SALARIOMINIMO) END)  LIKE UPPER(:SALARIOMINIMO || '%')  AND (CASE WHEN VALORUVT IS NULL THEN ' ' ELSE UPPER(VALORUVT) END)  LIKE UPPER(:VALORUVT || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="SALARIOMINIMO" sqlType="STRING"/>
		<param name="VALORUVT" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/porcompaniafacturacion/num">
		<call-query href="getAnosNumPorCompaniaFacturacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="SALARIOMINIMO" query-param="SALARIOMINIMO"/>
			<with-param name="VALORUVT" query-param="VALORUVT"/>

		</call-query>
	</resource>
	<query id="updateAnosPorCompaniaFacturacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ANO SET SALARIOMINIMO=:SALARIOMINIMO, VALORUVT=:VALORUVT, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ANO.COMPANIA= :KEY_COMPANIA AND ANO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="SALARIOMINIMO" sqlType="STRING"/>
		<param name="VALORUVT" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="anos/porcompaniafacturacion">
		<call-query href="updateAnosPorCompaniaFacturacion">
			<with-param name="SALARIOMINIMO" query-param="SALARIOMINIMO"/>
			<with-param name="VALORUVT" query-param="VALORUVT"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
