	<query id="updateAnosPlanAprobado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ANO    SET PLANAPROBADO  = :PLANAPROBADO,        MODIFIED_BY   = :MODIFIED_BY,        DATE_MODIFIED = TO_DATE(:DATE_MODIFIED, 'DD/MM/YYYY HH24:MI:SS')  WHERE COMPANIA = :COMPANIA    AND NUMERO   = :NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

