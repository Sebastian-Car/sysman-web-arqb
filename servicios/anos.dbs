	<query id="getAnosAnopdQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO.COMPANIA, ANO.NUMERO,(TO_CHAR(ANO.FECHA_CIERRE_ADQUISICIONES,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_ADQUISICIONES,(TO_CHAR(ANO.FECHA_CIERRE_ADQUI_EJEC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_ADQUI_EJEC,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_INDICATIVO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_INDICATIVO,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_ACCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_ACCION,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_ACCION_EJEC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_ACCION_EJEC,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_INDI_EJEC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_INDI_EJEC FROM ANO WHERE ANO.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","FECHA_CIERRE_ADQUISICIONES":"$FECHA_CIERRE_ADQUISICIONES","FECHA_CIERRE_ADQUI_EJEC":"$FECHA_CIERRE_ADQUI_EJEC","FECHA_CIERRE_PLAN_INDICATIVO":"$FECHA_CIERRE_PLAN_INDICATIVO","FECHA_CIERRE_PLAN_ACCION":"$FECHA_CIERRE_PLAN_ACCION","FECHA_CIERRE_PLAN_ACCION_EJEC":"$FECHA_CIERRE_PLAN_ACCION_EJEC","FECHA_CIERRE_PLAN_INDI_EJEC":"$FECHA_CIERRE_PLAN_INDI_EJEC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
