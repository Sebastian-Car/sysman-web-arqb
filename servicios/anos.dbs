			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAnosVigenciaPorProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT A.NUMERO VIGENCIA  FROM ANO A, PROYECTOS P WHERE P.COMPANIA = :COMPANIA AND P.CODIGO = :CODIGO AND A.NUMERO BETWEEN P.VIGENCIAINICIO AND P.VIGENCIAFIN ORDER BY A.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA":"$VIGENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
