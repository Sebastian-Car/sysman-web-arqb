			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAnosTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM ANO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
