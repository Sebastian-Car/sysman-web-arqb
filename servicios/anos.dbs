	<query id="getAnosPagLecturaPlanComprasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NUMERO,(CASE ASOCIADOPC WHEN 0 THEN 'false' ELSE 'true' END) ASOCIADOPC,(CASE PLANAPROBADO WHEN 0 THEN 'false' ELSE 'true' END) PLANAPROBADO FROM ANO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO DESC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ASOCIADOPC IS NULL THEN ' ' ELSE UPPER(ASOCIADOPC) END)  LIKE UPPER(:ASOCIADOPC || '%')  AND (CASE WHEN PLANAPROBADO IS NULL THEN ' ' ELSE UPPER(PLANAPROBADO) END)  LIKE UPPER(:PLANAPROBADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","ASOCIADOPC":"$ASOCIADOPC(type:boolean)","PLANAPROBADO":"$PLANAPROBADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ASOCIADOPC" sqlType="STRING"/>
		<param name="PLANAPROBADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="anos/lecturaplancompras/pag">
		<call-query href="getAnosPagLecturaPlanComprasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ASOCIADOPC" query-param="ASOCIADOPC"/>
			<with-param name="PLANAPROBADO" query-param="PLANAPROBADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAnosNumLecturaPlanComprasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NUMERO,(CASE ASOCIADOPC WHEN 0 THEN 'false' ELSE 'true' END) ASOCIADOPC,(CASE PLANAPROBADO WHEN 0 THEN 'false' ELSE 'true' END) PLANAPROBADO FROM ANO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO DESC) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ASOCIADOPC IS NULL THEN ' ' ELSE UPPER(ASOCIADOPC) END)  LIKE UPPER(:ASOCIADOPC || '%')  AND (CASE WHEN PLANAPROBADO IS NULL THEN ' ' ELSE UPPER(PLANAPROBADO) END)  LIKE UPPER(:PLANAPROBADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ASOCIADOPC" sqlType="STRING"/>
		<param name="PLANAPROBADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/lecturaplancompras/num">
		<call-query href="getAnosNumLecturaPlanComprasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ASOCIADOPC" query-param="ASOCIADOPC"/>
			<with-param name="PLANAPROBADO" query-param="PLANAPROBADO"/>

		</call-query>
	</resource>
	<query id="insertAnosInsertarPlanCompras" keyColumns="COMPANIA,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ANO (COMPANIA, NUMERO, ASOCIADOPC, DATE_CREATED, PLANAPROBADO, CREATED_BY) VALUES (:COMPANIA, :NUMERO, :ASOCIADOPC, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :PLANAPROBADO, :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="ASOCIADOPC" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="PLANAPROBADO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="anos/insertarplancompras">
		<call-query href="insertAnosInsertarPlanCompras">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ASOCIADOPC" query-param="ASOCIADOPC"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="PLANAPROBADO" query-param="PLANAPROBADO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateAnosActualizacionPlanCompras" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ANO SET NUMERO=:NUMERO, ASOCIADOPC=:ASOCIADOPC, PLANAPROBADO=:PLANAPROBADO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE ANO.COMPANIA= :KEY_COMPANIA AND ANO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERO" sqlType="STRING"/>
		<param name="ASOCIADOPC" sqlType="STRING"/>
		<param name="PLANAPROBADO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="anos/actualizacionplancompras">
		<call-query href="updateAnosActualizacionPlanCompras">
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ASOCIADOPC" query-param="ASOCIADOPC"/>
			<with-param name="PLANAPROBADO" query-param="PLANAPROBADO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getAnosPagConPlanAprobadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUMERO,(CASE PLANAPROBADO WHEN 0 THEN 'false' ELSE 'true' END) PLANAPROBADO FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO NOT IN 0 ORDER BY NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN PLANAPROBADO IS NULL THEN ' ' ELSE UPPER(PLANAPROBADO) END)  LIKE UPPER(:PLANAPROBADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","PLANAPROBADO":"$PLANAPROBADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PLANAPROBADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
