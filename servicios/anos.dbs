			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PLANAPROBADO" query-param="PLANAPROBADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAnosNumConPlanAprobadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NUMERO,(CASE PLANAPROBADO WHEN 0 THEN 'false' ELSE 'true' END) PLANAPROBADO FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO NOT IN 0 ORDER BY NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN PLANAPROBADO IS NULL THEN ' ' ELSE UPPER(PLANAPROBADO) END)  LIKE UPPER(:PLANAPROBADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PLANAPROBADO" sqlType="STRING"/>

	</query>
