			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAnosAsociadoPcQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE ASOCIADOPC WHEN 0 THEN 'false' ELSE 'true' END) ASOCIADOPC FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ASOCIADOPC":"$ASOCIADOPC(type:boolean)"}]}}		</result>
