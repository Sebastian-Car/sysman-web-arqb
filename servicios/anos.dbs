			<with-param name="VIGENCIAINICIAL" query-param="VIGENCIAINICIAL"/>
			<with-param name="VIGENCIAFIN" query-param="VIGENCIAFIN"/>

		</call-query>
	</resource>
	<query id="getAnosEntreinicialyfinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO BETWEEN :ANOINICIAL AND :ANIOFINAL ORDER BY NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
