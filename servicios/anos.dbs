			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getAnosUnionTodasVigenciasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NUMERO) NUMERO  FROM ANO WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO NOT IN (0) UNION SELECT 'TODAS' NUMERO FROM ANO ORDER BY 1</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/uniontodasvigencias">
