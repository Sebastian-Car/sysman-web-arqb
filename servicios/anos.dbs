	<query id="getAnosHastaactualfinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO.NUMERO  FROM ANO WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO &lt;= EXTRACT(YEAR FROM SYSDATE) AND NUMERO NOT IN (0) AND NUMERO &gt;= :ANO ORDER BY ANO.NUMERO DESC</sql>
