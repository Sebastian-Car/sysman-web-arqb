	<query id="insertAnosAnopd" keyColumns="COMPANIA,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ANO (COMPANIA, NUMERO, FECHA_CIERRE_ADQUISICIONES, FECHA_CIERRE_ADQUI_EJEC, FECHA_CIERRE_PLAN_INDICATIVO, FECHA_CIERRE_PLAN_ACCION, FECHA_CIERRE_PLAN_ACCION_EJEC, FECHA_CIERRE_PLAN_INDI_EJEC, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO, TO_DATE(:FECHA_CIERRE_ADQUISICIONES,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_CIERRE_ADQUI_EJEC,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_CIERRE_PLAN_INDICATIVO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_CIERRE_PLAN_ACCION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_CIERRE_PLAN_ACCION_EJEC,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_CIERRE_PLAN_INDI_EJEC,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CIERRE_ADQUISICIONES" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CIERRE_ADQUI_EJEC" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CIERRE_PLAN_INDICATIVO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CIERRE_PLAN_ACCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CIERRE_PLAN_ACCION_EJEC" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CIERRE_PLAN_INDI_EJEC" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="anos/anopd">
		<call-query href="insertAnosAnopd">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA_CIERRE_ADQUISICIONES" query-param="FECHA_CIERRE_ADQUISICIONES"/>
			<with-param name="FECHA_CIERRE_ADQUI_EJEC" query-param="FECHA_CIERRE_ADQUI_EJEC"/>
			<with-param name="FECHA_CIERRE_PLAN_INDICATIVO" query-param="FECHA_CIERRE_PLAN_INDICATIVO"/>
			<with-param name="FECHA_CIERRE_PLAN_ACCION" query-param="FECHA_CIERRE_PLAN_ACCION"/>
			<with-param name="FECHA_CIERRE_PLAN_ACCION_EJEC" query-param="FECHA_CIERRE_PLAN_ACCION_EJEC"/>
			<with-param name="FECHA_CIERRE_PLAN_INDI_EJEC" query-param="FECHA_CIERRE_PLAN_INDI_EJEC"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateAnosAnopd" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ANO SET FECHA_CIERRE_ADQUISICIONES=TO_DATE(:FECHA_CIERRE_ADQUISICIONES,'DD/MM/YYYY HH24:MI:SS'), FECHA_CIERRE_ADQUI_EJEC=TO_DATE(:FECHA_CIERRE_ADQUI_EJEC,'DD/MM/YYYY HH24:MI:SS'), FECHA_CIERRE_PLAN_INDICATIVO=TO_DATE(:FECHA_CIERRE_PLAN_INDICATIVO,'DD/MM/YYYY HH24:MI:SS'), FECHA_CIERRE_PLAN_ACCION=TO_DATE(:FECHA_CIERRE_PLAN_ACCION,'DD/MM/YYYY HH24:MI:SS'), FECHA_CIERRE_PLAN_ACCION_EJEC=TO_DATE(:FECHA_CIERRE_PLAN_ACCION_EJEC,'DD/MM/YYYY HH24:MI:SS'), FECHA_CIERRE_PLAN_INDI_EJEC=TO_DATE(:FECHA_CIERRE_PLAN_INDI_EJEC,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ANO.COMPANIA= :KEY_COMPANIA AND ANO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_CIERRE_ADQUISICIONES" sqlType="STRING"/>
		<param name="FECHA_CIERRE_ADQUI_EJEC" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_ACCION" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_ACCION_EJEC" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_INDI_EJEC" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="anos/anopd">
		<call-query href="updateAnosAnopd">
			<with-param name="FECHA_CIERRE_ADQUISICIONES" query-param="FECHA_CIERRE_ADQUISICIONES"/>
			<with-param name="FECHA_CIERRE_ADQUI_EJEC" query-param="FECHA_CIERRE_ADQUI_EJEC"/>
			<with-param name="FECHA_CIERRE_PLAN_INDICATIVO" query-param="FECHA_CIERRE_PLAN_INDICATIVO"/>
