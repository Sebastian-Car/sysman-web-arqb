			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAnosTodosDePlanIndicativoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO.NUMERO  FROM ANO LEFT JOIN BP_NIVEL_PLAN_IND ON ANO.COMPANIA = BP_NIVEL_PLAN_IND.COMPANIA AND ANO.NUMERO = BP_NIVEL_PLAN_IND.VIGENCIA WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO &gt;= :ANO AND ANO.NUMERO NOT IN(0) ORDER BY ANO.NUMERO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
