	</resource>
	<query id="getAnosTodosPorNumeroInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'TODAS' NUMERO  FROM ANO UNION SELECT TO_CHAR(NUMERO) FROM ANO WHERE ANO.COMPANIA = :COMPANIA AND ANO.NUMERO &gt;=:NUMERO AND NUMERO &lt;&gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/todospornumeroinicial">
