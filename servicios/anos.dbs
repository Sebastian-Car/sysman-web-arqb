	</resource>
	<query id="getAnosNumGetanocompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA,NUMERO FROM ANO WHERE ANO.COMPANIA = :COMPANIA ORDER BY NUMERO DESC) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/getanocompania/num">
		<call-query href="getAnosNumGetanocompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getAnosGetclasecuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CLASE_CUIPO FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASE_CUIPO":"$CLASE_CUIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/getclasecuipo">
		<call-query href="getAnosGetclasecuipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getAnosSmlvuvtsaludpensionQuery"  useConfig="sysmandsunist">
		<sql>SELECT SALARIOMINIMO, VALORUVT, PORCENTAJESALUD, PORCENTAJEPENSION FROM ANO WHERE COMPANIA = :COMPANIA AND NUMERO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALARIOMINIMO":"$SALARIOMINIMO","VALORUVT":"$VALORUVT","PORCENTAJESALUD":"$PORCENTAJESALUD","PORCENTAJEPENSION":"$PORCENTAJEPENSION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/smlvuvtsaludpension">
		<call-query href="getAnosSmlvuvtsaludpensionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>

</data>