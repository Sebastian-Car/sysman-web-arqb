	<query id="getAnosPagAnopdQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ANO.COMPANIA, ANO.NUMERO,(TO_CHAR(ANO.FECHA_CIERRE_ADQUISICIONES,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_ADQUISICIONES,(TO_CHAR(ANO.FECHA_CIERRE_ADQUI_EJEC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_ADQUI_EJEC,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_INDICATIVO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_INDICATIVO,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_ACCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_ACCION,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_ACCION_EJEC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_ACCION_EJEC,(TO_CHAR(ANO.FECHA_CIERRE_PLAN_INDI_EJEC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERRE_PLAN_INDI_EJEC FROM ANO WHERE ANO.COMPANIA = :COMPANIA) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA_CIERRE_ADQUISICIONES IS NULL THEN ' ' ELSE UPPER(FECHA_CIERRE_ADQUISICIONES) END)  LIKE UPPER(:FECHA_CIERRE_ADQUISICIONES || '%')  AND (CASE WHEN FECHA_CIERRE_ADQUI_EJEC IS NULL THEN ' ' ELSE UPPER(FECHA_CIERRE_ADQUI_EJEC) END)  LIKE UPPER(:FECHA_CIERRE_ADQUI_EJEC || '%')  AND (CASE WHEN FECHA_CIERRE_PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(FECHA_CIERRE_PLAN_INDICATIVO) END)  LIKE UPPER(:FECHA_CIERRE_PLAN_INDICATIVO || '%')  AND (CASE WHEN FECHA_CIERRE_PLAN_ACCION IS NULL THEN ' ' ELSE UPPER(FECHA_CIERRE_PLAN_ACCION) END)  LIKE UPPER(:FECHA_CIERRE_PLAN_ACCION || '%')  AND (CASE WHEN FECHA_CIERRE_PLAN_ACCION_EJEC IS NULL THEN ' ' ELSE UPPER(FECHA_CIERRE_PLAN_ACCION_EJEC) END)  LIKE UPPER(:FECHA_CIERRE_PLAN_ACCION_EJEC || '%')  AND (CASE WHEN FECHA_CIERRE_PLAN_INDI_EJEC IS NULL THEN ' ' ELSE UPPER(FECHA_CIERRE_PLAN_INDI_EJEC) END)  LIKE UPPER(:FECHA_CIERRE_PLAN_INDI_EJEC || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","FECHA_CIERRE_ADQUISICIONES":"$FECHA_CIERRE_ADQUISICIONES","FECHA_CIERRE_ADQUI_EJEC":"$FECHA_CIERRE_ADQUI_EJEC","FECHA_CIERRE_PLAN_INDICATIVO":"$FECHA_CIERRE_PLAN_INDICATIVO","FECHA_CIERRE_PLAN_ACCION":"$FECHA_CIERRE_PLAN_ACCION","FECHA_CIERRE_PLAN_ACCION_EJEC":"$FECHA_CIERRE_PLAN_ACCION_EJEC","FECHA_CIERRE_PLAN_INDI_EJEC":"$FECHA_CIERRE_PLAN_INDI_EJEC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA_CIERRE_ADQUISICIONES" sqlType="STRING"/>
		<param name="FECHA_CIERRE_ADQUI_EJEC" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_ACCION" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_ACCION_EJEC" sqlType="STRING"/>
		<param name="FECHA_CIERRE_PLAN_INDI_EJEC" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
