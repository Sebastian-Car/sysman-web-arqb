		</call-query>
	</resource>
	<query id="insertAnosMesesamnistia" keyColumns="COMPANIA,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ANO (COMPANIA, NUMERO, MESESAMNISTIA_PREDIAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO, :MESESAMNISTIA_PREDIAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="0" name="MESESAMNISTIA_PREDIAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="anos/mesesamnistia">
		<call-query href="insertAnosMesesamnistia">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="MESESAMNISTIA_PREDIAL" query-param="MESESAMNISTIA_PREDIAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getAnosPagNumymesesamnistiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NUMERO, MESESAMNISTIA_PREDIAL  FROM ANO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN MESESAMNISTIA_PREDIAL IS NULL THEN ' ' ELSE UPPER(MESESAMNISTIA_PREDIAL) END)  LIKE UPPER(:MESESAMNISTIA_PREDIAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","MESESAMNISTIA_PREDIAL":"$MESESAMNISTIA_PREDIAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="MESESAMNISTIA_PREDIAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="anos/numymesesamnistia/pag">
		<call-query href="getAnosPagNumymesesamnistiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="MESESAMNISTIA_PREDIAL" query-param="MESESAMNISTIA_PREDIAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getAnosNumNumymesesamnistiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NUMERO, MESESAMNISTIA_PREDIAL  FROM ANO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO DESC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN MESESAMNISTIA_PREDIAL IS NULL THEN ' ' ELSE UPPER(MESESAMNISTIA_PREDIAL) END)  LIKE UPPER( '%' || :MESESAMNISTIA_PREDIAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="MESESAMNISTIA_PREDIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="anos/numymesesamnistia/num">
		<call-query href="getAnosNumNumymesesamnistiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="MESESAMNISTIA_PREDIAL" query-param="MESESAMNISTIA_PREDIAL"/>

		</call-query>
	</resource>
	<query id="updateAnosNumymesesamnistia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
