<data name="cmcapituloscie" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertCmcapituloscie" keyColumns="CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CM_CAPITULOS_CIE (CODIGO, NOMBRE, RANGO_INICIAL, RANGO_FINAL, DATE_CREATED, CREATED_BY) VALUES (:CODIGO, :NOMBRE, :RANGO_INICIAL, :RANGO_FINAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RANGO_INICIAL" sqlType="STRING"/>
		<param name="RANGO_FINAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cmcapituloscie">
		<call-query href="insertCmcapituloscie">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RANGO_INICIAL" query-param="RANGO_INICIAL"/>
			<with-param name="RANGO_FINAL" query-param="RANGO_FINAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteCmcapituloscie" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CM_CAPITULOS_CIE WHERE CM_CAPITULOS_CIE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="cmcapituloscie">
		<call-query href="deleteCmcapituloscie">
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getCmcapitulosciePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE, RANGO_INICIAL, RANGO_FINAL FROM CM_CAPITULOS_CIE ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN RANGO_INICIAL IS NULL THEN ' ' ELSE UPPER(RANGO_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:RANGO_INICIAL), '%')) AND (CASE WHEN RANGO_FINAL IS NULL THEN ' ' ELSE UPPER(RANGO_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:RANGO_FINAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","RANGO_INICIAL":"$RANGO_INICIAL","RANGO_FINAL":"$RANGO_FINAL"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RANGO_INICIAL" sqlType="STRING"/>
		<param name="RANGO_FINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cmcapituloscie">
		<call-query href="getCmcapitulosciePaginaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RANGO_INICIAL" query-param="RANGO_INICIAL"/>
			<with-param name="RANGO_FINAL" query-param="RANGO_FINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCmcapituloscieNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE, RANGO_INICIAL, RANGO_FINAL FROM CM_CAPITULOS_CIE ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN RANGO_INICIAL IS NULL THEN ' ' ELSE UPPER(RANGO_INICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:RANGO_INICIAL), '%')) AND (CASE WHEN RANGO_FINAL IS NULL THEN ' ' ELSE UPPER(RANGO_FINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:RANGO_FINAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RANGO_INICIAL" sqlType="STRING"/>
		<param name="RANGO_FINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmcapituloscie/numero">
		<call-query href="getCmcapituloscieNumeroQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RANGO_INICIAL" query-param="RANGO_INICIAL"/>
			<with-param name="RANGO_FINAL" query-param="RANGO_FINAL"/>

		</call-query>
	</resource>
	<query id="updateCmcapituloscie" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_CAPITULOS_CIE SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, RANGO_INICIAL=:RANGO_INICIAL, RANGO_FINAL=:RANGO_FINAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CM_CAPITULOS_CIE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="RANGO_INICIAL" sqlType="STRING"/>
		<param name="RANGO_FINAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmcapituloscie">
		<call-query href="updateCmcapituloscie">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="RANGO_INICIAL" query-param="RANGO_INICIAL"/>
			<with-param name="RANGO_FINAL" query-param="RANGO_FINAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>