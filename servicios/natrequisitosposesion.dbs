		<param defaultValue="0" name="RP_TARJPROF" sqlType="STRING"/>
		<param defaultValue="0" name="RP_CTAAHORROS" sqlType="STRING"/>
		<param defaultValue="0" name="RP_INHAINCO" sqlType="STRING"/>
		<param defaultValue="0" name="RP_BIENRENT" sqlType="STRING"/>
