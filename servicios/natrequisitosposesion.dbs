			<with-param name="RP_FOTO" query-param="RP_FOTO"/>
			<with-param name="RP_DECLOBLIGALIM" query-param="RP_DECLOBLIGALIM"/>
			<with-param name="RP_EPS" query-param="RP_EPS"/>
			<with-param name="RP_AUTO" query-param="RP_AUTO"/>
			<with-param name="RP_AFIL" query-param="RP_AFIL"/>
