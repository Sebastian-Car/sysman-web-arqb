	</resource>
	<query id="getNatrequisitosposesionTodosPorCedulaYCompQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, DP_NUMEDOCU, SUCURSAL,(CASE RP_FORMHV WHEN 0 THEN 'false' ELSE 'true' END) RP_FORMHV,(CASE RP_ANTEDISI WHEN 0 THEN 'false' ELSE 'true' END) RP_ANTEDISI,(CASE RP_ANTEJURI WHEN 0 THEN 'false' ELSE 'true' END) RP_ANTEJURI,(CASE RP_DOCUIDEN WHEN 0 THEN 'false' ELSE 'true' END) RP_DOCUIDEN,(CASE RP_LIBRMILI WHEN 0 THEN 'false' ELSE 'true' END) RP_LIBRMILI,(CASE RP_FOTO WHEN 0 THEN 'false' ELSE 'true' END) RP_FOTO,(CASE RP_DECLOBLIGALIM WHEN 0 THEN 'false' ELSE 'true' END) RP_DECLOBLIGALIM,(CASE RP_EPS WHEN 0 THEN 'false' ELSE 'true' END) RP_EPS,(CASE RP_AUTO WHEN 0 THEN 'false' ELSE 'true' END) RP_AUTO,(CASE RP_AFIL WHEN 0 THEN 'false' ELSE 'true' END) RP_AFIL,(CASE RP_TARJPROF WHEN 0 THEN 'false' ELSE 'true' END) RP_TARJPROF,(CASE RP_CTAAHORROS WHEN 0 THEN 'false' ELSE 'true' END) RP_CTAAHORROS,(CASE RP_INHAINCO WHEN 0 THEN 'false' ELSE 'true' END) RP_INHAINCO,(CASE RP_BIENRENT WHEN 0 THEN 'false' ELSE 'true' END) RP_BIENRENT,(CASE RP_FP WHEN 0 THEN 'false' ELSE 'true' END) RP_FP,(CASE RP_CS WHEN 0 THEN 'false' ELSE 'true' END) RP_CS,(CASE RP_CC WHEN 0 THEN 'false' ELSE 'true' END) RP_CC,(CASE RP_AO WHEN 0 THEN 'false' ELSE 'true' END) RP_AO,(CASE RP_FR WHEN 0 THEN 'false' ELSE 'true' END) RP_FR,(CASE RP_AG WHEN 0 THEN 'false' ELSE 'true' END) RP_AG,(CASE RP_DP WHEN 0 THEN 'false' ELSE 'true' END) RP_DP,(CASE RP_CL WHEN 0 THEN 'false' ELSE 'true' END) RP_CL,(CASE RP_CEP WHEN 0 THEN 'false' ELSE 'true' END) RP_CEP,(CASE RP_BRF WHEN 0 THEN 'false' ELSE 'true' END) RP_BRF, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM NAT_REQUISITOS_POSESION WHERE COMPANIA = :KEY_SUCURSAL AND DP_NUMEDOCU = :KEY_DP_NUMEDOCU AND SUCURSAL = :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DP_NUMEDOCU":"$DP_NUMEDOCU","SUCURSAL":"$SUCURSAL","RP_FORMHV":"$RP_FORMHV(type:boolean)","RP_ANTEDISI":"$RP_ANTEDISI(type:boolean)","RP_ANTEJURI":"$RP_ANTEJURI(type:boolean)","RP_DOCUIDEN":"$RP_DOCUIDEN(type:boolean)","RP_LIBRMILI":"$RP_LIBRMILI(type:boolean)","RP_FOTO":"$RP_FOTO(type:boolean)","RP_DECLOBLIGALIM":"$RP_DECLOBLIGALIM(type:boolean)","RP_EPS":"$RP_EPS(type:boolean)","RP_AUTO":"$RP_AUTO(type:boolean)","RP_AFIL":"$RP_AFIL(type:boolean)","RP_TARJPROF":"$RP_TARJPROF(type:boolean)","RP_CTAAHORROS":"$RP_CTAAHORROS(type:boolean)","RP_INHAINCO":"$RP_INHAINCO(type:boolean)","RP_BIENRENT":"$RP_BIENRENT(type:boolean)","RP_FP":"$RP_FP(type:boolean)","RP_CS":"$RP_CS(type:boolean)","RP_CC":"$RP_CC(type:boolean)","RP_AO":"$RP_AO(type:boolean)","RP_FR":"$RP_FR(type:boolean)","RP_AG":"$RP_AG(type:boolean)","RP_DP":"$RP_DP(type:boolean)","RP_CL":"$RP_CL(type:boolean)","RP_CEP":"$RP_CEP(type:boolean)","RP_BRF":"$RP_BRF(type:boolean)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natrequisitosposesion/todosporcedulaycomp">
		<call-query href="getNatrequisitosposesionTodosPorCedulaYCompQuery">
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>

		</call-query>
	</resource>
	<query id="getNatrequisitosposesionExisteRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM NAT_REQUISITOS_POSESION WHERE COMPANIA = :COMPANIA AND DP_NUMEDOCU = :DP_NUMEDOCU AND SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natrequisitosposesion/existeregistro">
		<call-query href="getNatrequisitosposesionExisteRegistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>

</data>