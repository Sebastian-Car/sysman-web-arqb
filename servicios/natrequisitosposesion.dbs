<data name="natrequisitosposesion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatrequisitosposesionTodosPorCedulaYComp" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_REQUISITOS_POSESION (COMPANIA, DP_NUMEDOCU, SUCURSAL, RP_FORMHV, RP_ANTEDISI, RP_ANTEJURI, RP_DOCUIDEN, RP_LIBRMILI, RP_FOTO, RP_DECLOBLIGALIM, RP_EPS, RP_AUTO, RP_AFIL, RP_TARJPROF, RP_CTAAHORROS, RP_INHAINCO, RP_BIENRENT, RP_FP, RP_CS, RP_CC, RP_AO, RP_FR, RP_AG, RP_DP, RP_CL, RP_CEP, RP_BRF, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :DP_NUMEDOCU, :SUCURSAL, :RP_FORMHV, :RP_ANTEDISI, :RP_ANTEJURI, :RP_DOCUIDEN, :RP_LIBRMILI, :RP_FOTO, :RP_DECLOBLIGALIM, :RP_EPS, :RP_AUTO, :RP_AFIL, :RP_TARJPROF, :RP_CTAAHORROS, :RP_INHAINCO, :RP_BIENRENT, :RP_FP, :RP_CS, :RP_CC, :RP_AO, :RP_FR, :RP_AG, :RP_DP, :RP_CL, :RP_CEP, :RP_BRF, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="RP_FORMHV" sqlType="STRING"/>
