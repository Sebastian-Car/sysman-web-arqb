	<query id="updateNatrequisitosposesionTodosPorCedulaYComp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_REQUISITOS_POSESION SET COMPANIA                           =:COMPANIA,   DP_NUMEDOCU                          =:DP_NUMEDOCU,   SUCURSAL                             =:SUCURSAL,   RP_FORMHV                            =:RP_FORMHV,   RP_ANTEDISI                          =:RP_ANTEDISI,   RP_ANTEJURI                          =:RP_ANTEJURI,   RP_DOCUIDEN                          =:RP_DOCUIDEN,   RP_LIBRMILI                          =:RP_LIBRMILI,   RP_FOTO                              =:RP_FOTO,   RP_DECLOBLIGALIM                     =:RP_DECLOBLIGALIM,   RP_EPS                               =:RP_EPS,   RP_AUTO                              =:RP_AUTO,   RP_AFIL                              =:RP_AFIL,   RP_TARJPROF                          =:RP_TARJPROF,   RP_CTAAHORROS                        =:RP_CTAAHORROS,   RP_INHAINCO                          =:RP_INHAINCO,   RP_BIENRENT                          =:RP_BIENRENT,   RP_FP                                =:RP_FP,   RP_CS                                =:RP_CS,   RP_CC                                =:RP_CC,   RP_AO                                =:RP_AO,   RP_FR                                =:RP_FR,   RP_AG                                =:RP_AG,   RP_DP                                =:RP_DP,   RP_CL                                =:RP_CL,   RP_CEP                               =:RP_CEP,   RP_BRF                               =:RP_BRF,   MODIFIED_BY                          =:MODIFIED_BY,   DATE_MODIFIED                        =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE NAT_REQUISITOS_POSESION.COMPANIA = :KEY_COMPANIA AND NAT_REQUISITOS_POSESION.DP_NUMEDOCU= :KEY_DP_NUMEDOCU  AND NAT_REQUISITOS_POSESION.SUCURSAL   = :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="RP_FORMHV" sqlType="STRING"/>
		<param name="RP_ANTEDISI" sqlType="STRING"/>
		<param name="RP_ANTEJURI" sqlType="STRING"/>
		<param name="RP_DOCUIDEN" sqlType="STRING"/>
		<param name="RP_LIBRMILI" sqlType="STRING"/>
		<param name="RP_FOTO" sqlType="STRING"/>
		<param name="RP_DECLOBLIGALIM" sqlType="STRING"/>
		<param name="RP_EPS" sqlType="STRING"/>
		<param name="RP_AUTO" sqlType="STRING"/>
		<param name="RP_AFIL" sqlType="STRING"/>
		<param name="RP_TARJPROF" sqlType="STRING"/>
		<param name="RP_CTAAHORROS" sqlType="STRING"/>
		<param name="RP_INHAINCO" sqlType="STRING"/>
