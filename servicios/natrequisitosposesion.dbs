		<param name="RP_CC" sqlType="STRING"/>
		<param name="RP_AO" sqlType="STRING"/>
		<param name="RP_FR" sqlType="STRING"/>
		<param name="RP_AG" sqlType="STRING"/>
		<param name="RP_DP" sqlType="STRING"/>
		<param name="RP_CL" sqlType="STRING"/>
		<param name="RP_CEP" sqlType="STRING"/>
		<param name="RP_BRF" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natrequisitosposesion/todosporcedulaycomp">
		<call-query href="updateNatrequisitosposesionTodosPorCedulaYComp">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="RP_FORMHV" query-param="RP_FORMHV"/>
			<with-param name="RP_ANTEDISI" query-param="RP_ANTEDISI"/>
			<with-param name="RP_ANTEJURI" query-param="RP_ANTEJURI"/>
