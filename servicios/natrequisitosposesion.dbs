		<param defaultValue="0" name="RP_CS" sqlType="STRING"/>
		<param defaultValue="0" name="RP_CC" sqlType="STRING"/>
		<param defaultValue="0" name="RP_AO" sqlType="STRING"/>
		<param defaultValue="0" name="RP_FR" sqlType="STRING"/>
		<param defaultValue="0" name="RP_AG" sqlType="STRING"/>
		<param defaultValue="0" name="RP_DP" sqlType="STRING"/>
		<param defaultValue="0" name="RP_CL" sqlType="STRING"/>
		<param defaultValue="0" name="RP_CEP" sqlType="STRING"/>
		<param defaultValue="0" name="RP_BRF" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natrequisitosposesion/todosporcedulaycomp">
		<call-query href="insertNatrequisitosposesionTodosPorCedulaYComp">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
