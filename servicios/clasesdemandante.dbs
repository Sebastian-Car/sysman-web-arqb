<data name="clasesdemandante" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getClasesdemandanteListademandanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASE_DEMANDANTE.ID_DEMANDANTE, CLASE_DEMANDANTE.DEMANDANTE, CLASE_DEMANDANTE.ID_EMBARGO  FROM CLASE_DEMANDANTE WHERE CLASE_DEMANDANTE.ID_EMBARGO = :TIPOEMBARGO AND CLASE_DEMANDANTE.COMPANIA = :COMPANIA ORDER BY CLASE_DEMANDANTE.DEMANDANTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DEMANDANTE":"$ID_DEMANDANTE","DEMANDANTE":"$DEMANDANTE","ID_EMBARGO":"$ID_EMBARGO"}]}}		</result>
		<param name="TIPOEMBARGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesdemandante/listademandante">
		<call-query href="getClasesdemandanteListademandanteQuery">
			<with-param name="TIPOEMBARGO" query-param="TIPOEMBARGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getClasesdemandantePagListademandanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CLASE_DEMANDANTE.ID_DEMANDANTE, CLASE_DEMANDANTE.DEMANDANTE, CLASE_DEMANDANTE.ID_EMBARGO  FROM CLASE_DEMANDANTE WHERE CLASE_DEMANDANTE.ID_EMBARGO = :TIPOEMBARGO AND CLASE_DEMANDANTE.COMPANIA = :COMPANIA ORDER BY CLASE_DEMANDANTE.DEMANDANTE) WHERE (CASE WHEN ID_DEMANDANTE IS NULL THEN ' ' ELSE UPPER(ID_DEMANDANTE) END)  LIKE UPPER(:ID_DEMANDANTE || '%')  AND (CASE WHEN DEMANDANTE IS NULL THEN ' ' ELSE UPPER(DEMANDANTE) END)  LIKE UPPER( '%' || :DEMANDANTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DEMANDANTE":"$ID_DEMANDANTE","DEMANDANTE":"$DEMANDANTE","ID_EMBARGO":"$ID_EMBARGO"}]}}		</result>
		<param name="TIPOEMBARGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DEMANDANTE" sqlType="STRING"/>
		<param name="DEMANDANTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="clasesdemandante/listademandante/pag">
		<call-query href="getClasesdemandantePagListademandanteQuery">
			<with-param name="TIPOEMBARGO" query-param="TIPOEMBARGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DEMANDANTE" query-param="ID_DEMANDANTE"/>
			<with-param name="DEMANDANTE" query-param="DEMANDANTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClasesdemandanteNumListademandanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CLASE_DEMANDANTE.ID_DEMANDANTE, CLASE_DEMANDANTE.DEMANDANTE, CLASE_DEMANDANTE.ID_EMBARGO  FROM CLASE_DEMANDANTE WHERE CLASE_DEMANDANTE.ID_EMBARGO = :TIPOEMBARGO AND CLASE_DEMANDANTE.COMPANIA = :COMPANIA ORDER BY CLASE_DEMANDANTE.DEMANDANTE) WHERE (CASE WHEN ID_DEMANDANTE IS NULL THEN ' ' ELSE UPPER(ID_DEMANDANTE) END)  LIKE UPPER(:ID_DEMANDANTE || '%')  AND (CASE WHEN DEMANDANTE IS NULL THEN ' ' ELSE UPPER(DEMANDANTE) END)  LIKE UPPER( '%' || :DEMANDANTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="TIPOEMBARGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DEMANDANTE" sqlType="STRING"/>
		<param name="DEMANDANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesdemandante/listademandante/num">
		<call-query href="getClasesdemandanteNumListademandanteQuery">
			<with-param name="TIPOEMBARGO" query-param="TIPOEMBARGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DEMANDANTE" query-param="ID_DEMANDANTE"/>
			<with-param name="DEMANDANTE" query-param="DEMANDANTE"/>

		</call-query>
	</resource>
	<query id="insertClasesdemandante" keyColumns="COMPANIA,ID_DEMANDANTE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CLASE_DEMANDANTE (COMPANIA, ID_DEMANDANTE, DEMANDANTE, ID_EMBARGO, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DEMANDANTE, :DEMANDANTE, :ID_EMBARGO, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DEMANDANTE":"$ID_DEMANDANTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DEMANDANTE" sqlType="STRING"/>
		<param name="DEMANDANTE" sqlType="STRING"/>
		<param name="ID_EMBARGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="clasesdemandante">
		<call-query href="insertClasesdemandante">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DEMANDANTE" query-param="ID_DEMANDANTE"/>
			<with-param name="DEMANDANTE" query-param="DEMANDANTE"/>
			<with-param name="ID_EMBARGO" query-param="ID_EMBARGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteClasesdemandante" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CLASE_DEMANDANTE WHERE CLASE_DEMANDANTE.COMPANIA= :KEY_COMPANIA AND CLASE_DEMANDANTE.ID_DEMANDANTE= :KEY_ID_DEMANDANTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DEMANDANTE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="clasesdemandante">
		<call-query href="deleteClasesdemandante">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DEMANDANTE" query-param="KEY_ID_DEMANDANTE"/>

		</call-query>
	</resource>
	<query id="getClasesdemandantePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CLASE.COMPANIA, CLASE.ID_DEMANDANTE, CLASE.DEMANDANTE, CLASE.ID_EMBARGO, TIPO.NOMBRE TIPO_EMBARGO_NOM, CLASE.DESCRIPCION  FROM CLASE_DEMANDANTE CLASE INNER JOIN TIPO_EMBARGO TIPO ON CLASE.COMPANIA = TIPO.COMPANIA AND CLASE.ID_EMBARGO = TIPO.CODIGO WHERE CLASE.COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_DEMANDANTE IS NULL THEN ' ' ELSE UPPER(ID_DEMANDANTE) END)  LIKE UPPER(:ID_DEMANDANTE || '%')  AND (CASE WHEN DEMANDANTE IS NULL THEN ' ' ELSE UPPER(DEMANDANTE) END)  LIKE UPPER( '%' || :DEMANDANTE || '%')  AND (CASE WHEN TIPO_EMBARGO_NOM IS NULL THEN ' ' ELSE UPPER(TIPO_EMBARGO_NOM) END)  LIKE UPPER( '%' || :TIPO_EMBARGO_NOM || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DEMANDANTE":"$ID_DEMANDANTE","DEMANDANTE":"$DEMANDANTE","ID_EMBARGO":"$ID_EMBARGO","TIPO_EMBARGO_NOM":"$TIPO_EMBARGO_NOM","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DEMANDANTE" sqlType="STRING"/>
		<param name="DEMANDANTE" sqlType="STRING"/>
		<param name="TIPO_EMBARGO_NOM" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="clasesdemandante">
		<call-query href="getClasesdemandantePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DEMANDANTE" query-param="ID_DEMANDANTE"/>
			<with-param name="DEMANDANTE" query-param="DEMANDANTE"/>
			<with-param name="TIPO_EMBARGO_NOM" query-param="TIPO_EMBARGO_NOM"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getClasesdemandanteNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CLASE.COMPANIA, CLASE.ID_DEMANDANTE, CLASE.DEMANDANTE, CLASE.ID_EMBARGO, TIPO.NOMBRE TIPO_EMBARGO_NOM, CLASE.DESCRIPCION  FROM CLASE_DEMANDANTE CLASE INNER JOIN TIPO_EMBARGO TIPO ON CLASE.COMPANIA = TIPO.COMPANIA AND CLASE.ID_EMBARGO = TIPO.CODIGO WHERE CLASE.COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_DEMANDANTE IS NULL THEN ' ' ELSE UPPER(ID_DEMANDANTE) END)  LIKE UPPER(:ID_DEMANDANTE || '%')  AND (CASE WHEN DEMANDANTE IS NULL THEN ' ' ELSE UPPER(DEMANDANTE) END)  LIKE UPPER( '%' || :DEMANDANTE || '%')  AND (CASE WHEN TIPO_EMBARGO_NOM IS NULL THEN ' ' ELSE UPPER(TIPO_EMBARGO_NOM) END)  LIKE UPPER( '%' || :TIPO_EMBARGO_NOM || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DEMANDANTE" sqlType="STRING"/>
		<param name="DEMANDANTE" sqlType="STRING"/>
		<param name="TIPO_EMBARGO_NOM" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clasesdemandante/numero">
		<call-query href="getClasesdemandanteNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DEMANDANTE" query-param="ID_DEMANDANTE"/>
			<with-param name="DEMANDANTE" query-param="DEMANDANTE"/>
			<with-param name="TIPO_EMBARGO_NOM" query-param="TIPO_EMBARGO_NOM"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateClasesdemandante" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CLASE_DEMANDANTE SET ID_DEMANDANTE=:ID_DEMANDANTE, DEMANDANTE=:DEMANDANTE, ID_EMBARGO=:ID_EMBARGO, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CLASE_DEMANDANTE.COMPANIA= :KEY_COMPANIA AND CLASE_DEMANDANTE.ID_DEMANDANTE= :KEY_ID_DEMANDANTE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID_DEMANDANTE" sqlType="STRING"/>
		<param name="DEMANDANTE" sqlType="STRING"/>
		<param name="ID_EMBARGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DEMANDANTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="clasesdemandante">
		<call-query href="updateClasesdemandante">
			<with-param name="ID_DEMANDANTE" query-param="ID_DEMANDANTE"/>
			<with-param name="DEMANDANTE" query-param="DEMANDANTE"/>
			<with-param name="ID_EMBARGO" query-param="ID_EMBARGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DEMANDANTE" query-param="KEY_ID_DEMANDANTE"/>

		</call-query>
	</resource>

</data>