<data name="configuraciondeterioro" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertConfiguraciondeterioro" keyColumns="COMPANIA,ANO,TIPO_ENTIDAD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONFIGURACION_DETERIORO (COMPANIA, ANO, TIPO_ENTIDAD, DIAS_VENCIMIENTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO_ENTIDAD, :DIAS_VENCIMIENTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO_ENTIDAD":"$TIPO_ENTIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_ENTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS_VENCIMIENTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="configuraciondeterioro">
		<call-query href="insertConfiguraciondeterioro">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_ENTIDAD" query-param="TIPO_ENTIDAD"/>
			<with-param name="DIAS_VENCIMIENTO" query-param="DIAS_VENCIMIENTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteConfiguraciondeterioro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONFIGURACION_DETERIORO WHERE CONFIGURACION_DETERIORO.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_DETERIORO.ANO= :KEY_ANO AND CONFIGURACION_DETERIORO.TIPO_ENTIDAD= :KEY_TIPO_ENTIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_ENTIDAD" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="configuraciondeterioro">
		<call-query href="deleteConfiguraciondeterioro">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_ENTIDAD" query-param="KEY_TIPO_ENTIDAD"/>

		</call-query>
	</resource>
	<query id="getConfiguraciondeterioroPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, TIPO_ENTIDAD, DIAS_VENCIMIENTO FROM CONFIGURACION_DETERIORO WHERE COMPANIA = :COMPANIA ORDER BY ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPO_ENTIDAD IS NULL THEN ' ' ELSE UPPER(TIPO_ENTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_ENTIDAD), '%')) AND (CASE WHEN DIAS_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(DIAS_VENCIMIENTO) END) LIKE UPPER(CONCAT(:DIAS_VENCIMIENTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_ENTIDAD":"$TIPO_ENTIDAD","DIAS_VENCIMIENTO":"$DIAS_VENCIMIENTO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_ENTIDAD" sqlType="STRING"/>
		<param name="DIAS_VENCIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="configuraciondeterioro">
		<call-query href="getConfiguraciondeterioroPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_ENTIDAD" query-param="TIPO_ENTIDAD"/>
			<with-param name="DIAS_VENCIMIENTO" query-param="DIAS_VENCIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConfiguraciondeterioroNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, TIPO_ENTIDAD, DIAS_VENCIMIENTO FROM CONFIGURACION_DETERIORO WHERE COMPANIA = :COMPANIA ORDER BY ANO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN TIPO_ENTIDAD IS NULL THEN ' ' ELSE UPPER(TIPO_ENTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_ENTIDAD), '%')) AND (CASE WHEN DIAS_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(DIAS_VENCIMIENTO) END) LIKE UPPER(CONCAT(:DIAS_VENCIMIENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_ENTIDAD" sqlType="STRING"/>
		<param name="DIAS_VENCIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuraciondeterioro/numero">
		<call-query href="getConfiguraciondeterioroNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_ENTIDAD" query-param="TIPO_ENTIDAD"/>
			<with-param name="DIAS_VENCIMIENTO" query-param="DIAS_VENCIMIENTO"/>

		</call-query>
	</resource>
	<query id="getConfiguraciondeterioroRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, TIPO_ENTIDAD, DIAS_VENCIMIENTO FROM CONFIGURACION_DETERIORO WHERE CONFIGURACION_DETERIORO.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_DETERIORO.ANO= :KEY_ANO AND CONFIGURACION_DETERIORO.TIPO_ENTIDAD= :KEY_TIPO_ENTIDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO_ENTIDAD":"$TIPO_ENTIDAD","DIAS_VENCIMIENTO":"$DIAS_VENCIMIENTO(type:long)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_ENTIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="configuraciondeterioro/data">
		<call-query href="getConfiguraciondeterioroRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_ENTIDAD" query-param="KEY_TIPO_ENTIDAD"/>

		</call-query>
	</resource>
	<query id="updateConfiguraciondeterioro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONFIGURACION_DETERIORO SET COMPANIA=:COMPANIA, ANO=:ANO, TIPO_ENTIDAD=:TIPO_ENTIDAD, DIAS_VENCIMIENTO=:DIAS_VENCIMIENTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONFIGURACION_DETERIORO.COMPANIA= :KEY_COMPANIA AND CONFIGURACION_DETERIORO.ANO= :KEY_ANO AND CONFIGURACION_DETERIORO.TIPO_ENTIDAD= :KEY_TIPO_ENTIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_ENTIDAD" sqlType="STRING"/>
		<param name="DIAS_VENCIMIENTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_ENTIDAD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="configuraciondeterioro">
		<call-query href="updateConfiguraciondeterioro">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_ENTIDAD" query-param="TIPO_ENTIDAD"/>
			<with-param name="DIAS_VENCIMIENTO" query-param="DIAS_VENCIMIENTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_ENTIDAD" query-param="KEY_TIPO_ENTIDAD"/>

		</call-query>
	</resource>

</data>