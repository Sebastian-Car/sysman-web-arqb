<data name="esproymetas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEsproymetasGeneralMetasActividadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT ES_PROY_METAS.COMPANIA, ES_PROY_METAS.COD_PROY, ES_PROY_METAS.COD_ESTUDIO, ES_PROY_METAS.T_COMPONENTE, ES_PROY_METAS.COMPONENTE, ES_PROY_METAS.ACTIVIDAD, ES_PROY_METAS.ID_PLAN_P, ES_PROY_METAS.VIGENCIA_PLAN_P, ES_PROY_METAS.VIGENCIA_META_P, ES_PROY_METAS.PONDERACION_META, ES_PROY_METAS.VALOR_PROGRAMADO_META, ES_PROY_METAS.VALOR_EJECUTADO_META, ES_PROY_METAS.CANTIDAD_PROGRAMADA_P, ES_PROY_METAS.CANTIDAD_EJECUTADA_P, ES_PROY_METAS.DESCRIPCION_META, ES_PROY_METAS.DIMENSION, ES_PROY_METAS.SECTOR, ES_PROY_METAS.PROGRAMA, ES_PROY_METAS.SUBPROGRAMA, ES_PROY_METAS.META_BRUTA, CONCAT(CASE WHEN VALOR_PROGRAMADO_META &gt; 0 THEN ( CANTIDAD_PROGRAMADA_P * VALOR_EJECUTADO_META ) / VALOR_PROGRAMADO_META ELSE 0 END , '%') CANTIDAD_META_EJECUTAR FROM ES_PROY_METAS WHERE ES_PROY_METAS.COMPANIA =:COMPANIA AND ES_PROY_METAS.COD_ESTUDIO =:COD_ESTUDIO AND ES_PROY_METAS.ACTIVIDAD =:ACTIVIDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PROY":"$COD_PROY","COD_ESTUDIO":"$COD_ESTUDIO(type:long)","T_COMPONENTE":"$T_COMPONENTE","COMPONENTE":"$COMPONENTE","ACTIVIDAD":"$ACTIVIDAD","ID_PLAN_P":"$ID_PLAN_P","VIGENCIA_PLAN_P":"$VIGENCIA_PLAN_P(type:integer)","VIGENCIA_META_P":"$VIGENCIA_META_P(type:integer)","PONDERACION_META":"$PONDERACION_META","VALOR_PROGRAMADO_META":"$VALOR_PROGRAMADO_META","VALOR_EJECUTADO_META":"$VALOR_EJECUTADO_META","CANTIDAD_PROGRAMADA_P":"$CANTIDAD_PROGRAMADA_P","CANTIDAD_EJECUTADA_P":"$CANTIDAD_EJECUTADA_P","DESCRIPCION_META":"$DESCRIPCION_META","DIMENSION":"$DIMENSION","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","META_BRUTA":"$META_BRUTA","CANTIDAD_META_EJECUTAR":"$CANTIDAD_META_EJECUTAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esproymetas/generalmetasactividades">
		<call-query href="getEsproymetasGeneralMetasActividadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="insertEsproymetas" keyColumns="COMPANIA,COD_PROY,COD_ESTUDIO,T_COMPONENTE,COMPONENTE,ACTIVIDAD,ID_PLAN_P,VIGENCIA_PLAN_P,VIGENCIA_META_P" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_PROY_METAS (COMPANIA, COD_PROY, COD_ESTUDIO, T_COMPONENTE, COMPONENTE, ACTIVIDAD, ID_PLAN_P, VIGENCIA_PLAN_P, VIGENCIA_META_P, PONDERACION_META, VALOR_PROGRAMADO_META, VALOR_EJECUTADO_META, CANTIDAD_PROGRAMADA_P, CANTIDAD_EJECUTADA_P, DESCRIPCION_META, DIMENSION, SECTOR, PROGRAMA, SUBPROGRAMA, META_BRUTA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_PROY, :COD_ESTUDIO, :T_COMPONENTE, :COMPONENTE, :ACTIVIDAD, :ID_PLAN_P, :VIGENCIA_PLAN_P, :VIGENCIA_META_P, :PONDERACION_META, :VALOR_PROGRAMADO_META, :VALOR_EJECUTADO_META, :CANTIDAD_PROGRAMADA_P, :CANTIDAD_EJECUTADA_P, :DESCRIPCION_META, :DIMENSION, :SECTOR, :PROGRAMA, :SUBPROGRAMA, :META_BRUTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_PROY":"$COD_PROY","KEY_COD_ESTUDIO":"$COD_ESTUDIO(type:long)","KEY_T_COMPONENTE":"$T_COMPONENTE","KEY_COMPONENTE":"$COMPONENTE","KEY_ACTIVIDAD":"$ACTIVIDAD","KEY_ID_PLAN_P":"$ID_PLAN_P","KEY_VIGENCIA_PLAN_P":"$VIGENCIA_PLAN_P(type:integer)","KEY_VIGENCIA_META_P":"$VIGENCIA_META_P(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="T_COMPONENTE" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN_P" sqlType="STRING"/>
		<param name="VIGENCIA_META_P" sqlType="STRING"/>
		<param defaultValue="0" name="PONDERACION_META" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD_PROGRAMADA_P" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD_EJECUTADA_P" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION_META" sqlType="STRING"/>
		<param defaultValue="" name="DIMENSION" sqlType="STRING"/>
		<param defaultValue="" name="SECTOR" sqlType="STRING"/>
		<param defaultValue="" name="PROGRAMA" sqlType="STRING"/>
		<param defaultValue="" name="SUBPROGRAMA" sqlType="STRING"/>
		<param defaultValue="0" name="META_BRUTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esproymetas">
		<call-query href="insertEsproymetas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_PROY" query-param="COD_PROY"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="T_COMPONENTE" query-param="T_COMPONENTE"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="ID_PLAN_P" query-param="ID_PLAN_P"/>
			<with-param name="VIGENCIA_PLAN_P" query-param="VIGENCIA_PLAN_P"/>
			<with-param name="VIGENCIA_META_P" query-param="VIGENCIA_META_P"/>
			<with-param name="PONDERACION_META" query-param="PONDERACION_META"/>
			<with-param name="VALOR_PROGRAMADO_META" query-param="VALOR_PROGRAMADO_META"/>
			<with-param name="VALOR_EJECUTADO_META" query-param="VALOR_EJECUTADO_META"/>
			<with-param name="CANTIDAD_PROGRAMADA_P" query-param="CANTIDAD_PROGRAMADA_P"/>
			<with-param name="CANTIDAD_EJECUTADA_P" query-param="CANTIDAD_EJECUTADA_P"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="DIMENSION" query-param="DIMENSION"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
			<with-param name="SUBPROGRAMA" query-param="SUBPROGRAMA"/>
			<with-param name="META_BRUTA" query-param="META_BRUTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsproymetas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_PROY_METAS WHERE ES_PROY_METAS.COMPANIA= :KEY_COMPANIA AND ES_PROY_METAS.COD_PROY= :KEY_COD_PROY AND ES_PROY_METAS.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_PROY_METAS.T_COMPONENTE= :KEY_T_COMPONENTE AND ES_PROY_METAS.COMPONENTE= :KEY_COMPONENTE AND ES_PROY_METAS.ACTIVIDAD= :KEY_ACTIVIDAD AND ES_PROY_METAS.ID_PLAN_P= :KEY_ID_PLAN_P AND ES_PROY_METAS.VIGENCIA_PLAN_P= :KEY_VIGENCIA_PLAN_P AND ES_PROY_METAS.VIGENCIA_META_P= :KEY_VIGENCIA_META_P</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_PROY" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_T_COMPONENTE" sqlType="STRING"/>
		<param name="KEY_COMPONENTE" sqlType="STRING"/>
		<param name="KEY_ACTIVIDAD" sqlType="STRING"/>
		<param name="KEY_ID_PLAN_P" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_PLAN_P" sqlType="INTEGER"/>
		<param name="KEY_VIGENCIA_META_P" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="esproymetas">
		<call-query href="deleteEsproymetas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_PROY" query-param="KEY_COD_PROY"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_T_COMPONENTE" query-param="KEY_T_COMPONENTE"/>
			<with-param name="KEY_COMPONENTE" query-param="KEY_COMPONENTE"/>
			<with-param name="KEY_ACTIVIDAD" query-param="KEY_ACTIVIDAD"/>
			<with-param name="KEY_ID_PLAN_P" query-param="KEY_ID_PLAN_P"/>
			<with-param name="KEY_VIGENCIA_PLAN_P" query-param="KEY_VIGENCIA_PLAN_P"/>
			<with-param name="KEY_VIGENCIA_META_P" query-param="KEY_VIGENCIA_META_P"/>

		</call-query>
	</resource>
	<query id="updateEsproymetas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_PROY_METAS SET ID_PLAN_P=:ID_PLAN_P, VIGENCIA_PLAN_P=:VIGENCIA_PLAN_P, VIGENCIA_META_P=:VIGENCIA_META_P, PONDERACION_META=:PONDERACION_META, VALOR_PROGRAMADO_META=:VALOR_PROGRAMADO_META, VALOR_EJECUTADO_META=:VALOR_EJECUTADO_META, CANTIDAD_PROGRAMADA_P=:CANTIDAD_PROGRAMADA_P, CANTIDAD_EJECUTADA_P=:CANTIDAD_EJECUTADA_P, DESCRIPCION_META=:DESCRIPCION_META, DIMENSION=:DIMENSION, SECTOR=:SECTOR, PROGRAMA=:PROGRAMA, SUBPROGRAMA=:SUBPROGRAMA, META_BRUTA=:META_BRUTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_PROY_METAS.COMPANIA= :KEY_COMPANIA AND ES_PROY_METAS.COD_PROY= :KEY_COD_PROY AND ES_PROY_METAS.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_PROY_METAS.T_COMPONENTE= :KEY_T_COMPONENTE AND ES_PROY_METAS.COMPONENTE= :KEY_COMPONENTE AND ES_PROY_METAS.ACTIVIDAD= :KEY_ACTIVIDAD AND ES_PROY_METAS.ID_PLAN_P= :KEY_ID_PLAN_P AND ES_PROY_METAS.VIGENCIA_PLAN_P= :KEY_VIGENCIA_PLAN_P AND ES_PROY_METAS.VIGENCIA_META_P= :KEY_VIGENCIA_META_P</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN_P" sqlType="STRING"/>
		<param name="VIGENCIA_META_P" sqlType="STRING"/>
		<param name="PONDERACION_META" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA_P" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADA_P" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>
		<param name="DIMENSION" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="SUBPROGRAMA" sqlType="STRING"/>
		<param name="META_BRUTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_PROY" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_T_COMPONENTE" sqlType="STRING"/>
		<param name="KEY_COMPONENTE" sqlType="STRING"/>
		<param name="KEY_ACTIVIDAD" sqlType="STRING"/>
		<param name="KEY_ID_PLAN_P" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_PLAN_P" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_META_P" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esproymetas">
		<call-query href="updateEsproymetas">
			<with-param name="ID_PLAN_P" query-param="ID_PLAN_P"/>
			<with-param name="VIGENCIA_PLAN_P" query-param="VIGENCIA_PLAN_P"/>
			<with-param name="VIGENCIA_META_P" query-param="VIGENCIA_META_P"/>
			<with-param name="PONDERACION_META" query-param="PONDERACION_META"/>
			<with-param name="VALOR_PROGRAMADO_META" query-param="VALOR_PROGRAMADO_META"/>
			<with-param name="VALOR_EJECUTADO_META" query-param="VALOR_EJECUTADO_META"/>
			<with-param name="CANTIDAD_PROGRAMADA_P" query-param="CANTIDAD_PROGRAMADA_P"/>
			<with-param name="CANTIDAD_EJECUTADA_P" query-param="CANTIDAD_EJECUTADA_P"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="DIMENSION" query-param="DIMENSION"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
			<with-param name="SUBPROGRAMA" query-param="SUBPROGRAMA"/>
			<with-param name="META_BRUTA" query-param="META_BRUTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_PROY" query-param="KEY_COD_PROY"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_T_COMPONENTE" query-param="KEY_T_COMPONENTE"/>
			<with-param name="KEY_COMPONENTE" query-param="KEY_COMPONENTE"/>
			<with-param name="KEY_ACTIVIDAD" query-param="KEY_ACTIVIDAD"/>
			<with-param name="KEY_ID_PLAN_P" query-param="KEY_ID_PLAN_P"/>
			<with-param name="KEY_VIGENCIA_PLAN_P" query-param="KEY_VIGENCIA_PLAN_P"/>
			<with-param name="KEY_VIGENCIA_META_P" query-param="KEY_VIGENCIA_META_P"/>

		</call-query>
	</resource>

</data>