	<query id="updateSaldosiniciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SALDOSINICIALES SET CODIGO=:CODIGO, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, AUXILIAR=:AUXILIAR, CENTRO_COSTO=:CENTRO_COSTO, REFERENCIA=:REFERENCIA, FUENTE_RECURSO=:FUENTE_RECURSO, SALDOINICIAL=:SALDOINICIAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SALDOSINICIALES.COMPANIA= :KEY_COMPANIA AND SALDOSINICIALES.ANO= :KEY_ANO AND SALDOSINICIALES.CODIGO= :KEY_CODIGO AND SALDOSINICIALES.TERCERO= :KEY_TERCERO AND SALDOSINICIALES.SUCURSAL= :KEY_SUCURSAL AND SALDOSINICIALES.AUXILIAR= :KEY_AUXILIAR AND SALDOSINICIALES.CENTRO_COSTO= :KEY_CENTRO_COSTO AND SALDOSINICIALES.REFERENCIA= :KEY_REFERENCIA AND SALDOSINICIALES.FUENTE_RECURSO= :KEY_FUENTE_RECURSO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
