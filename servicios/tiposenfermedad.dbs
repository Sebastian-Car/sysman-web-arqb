<data name="tiposenfermedad" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTiposenfermedadPagTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT TIPO_ENFERMEDADES.CODIGOEN, TIPO_ENFERMEDADES.NOMBRE_ENFERMEDAD FROM TIPO_ENFERMEDADES ORDER BY TIPO_ENFERMEDADES.CODIGOEN) INI WHERE (CASE WHEN CODIGOEN IS NULL THEN ' ' ELSE UPPER(CODIGOEN) END) LIKE UPPER(CONCAT(:CODIGOEN, '%')) AND (CASE WHEN NOMBRE_ENFERMEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ENFERMEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ENFERMEDAD), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOEN":"$CODIGOEN","NOMBRE_ENFERMEDAD":"$NOMBRE_ENFERMEDAD"}]}}		</result>
		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposenfermedad/todos/pag">
		<call-query href="getTiposenfermedadPagTodosQuery">
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposenfermedadNumTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT TIPO_ENFERMEDADES.CODIGOEN, TIPO_ENFERMEDADES.NOMBRE_ENFERMEDAD FROM TIPO_ENFERMEDADES ORDER BY TIPO_ENFERMEDADES.CODIGOEN) INI WHERE (CASE WHEN CODIGOEN IS NULL THEN ' ' ELSE UPPER(CODIGOEN) END) LIKE UPPER(CONCAT(:CODIGOEN, '%')) AND (CASE WHEN NOMBRE_ENFERMEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ENFERMEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ENFERMEDAD), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposenfermedad/todos/num">
		<call-query href="getTiposenfermedadNumTodosQuery">
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>

		</call-query>
	</resource>
	<query id="getTiposenfermedadPagCodigoYDescripcionFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT TIPO_ENFERMEDADES.CODIGOEN, TIPO_ENFERMEDADES.NOMBRE_ENFERMEDAD FROM TIPO_ENFERMEDADES WHERE TIPO_ENFERMEDADES.CODIGOEN &gt;= :ENFERMEDADINICIAL ORDER BY TIPO_ENFERMEDADES.CODIGOEN) INI WHERE (CASE WHEN CODIGOEN IS NULL THEN ' ' ELSE UPPER(CODIGOEN) END) LIKE UPPER(CONCAT(:CODIGOEN, '%')) AND (CASE WHEN NOMBRE_ENFERMEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ENFERMEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ENFERMEDAD), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOEN":"$CODIGOEN","NOMBRE_ENFERMEDAD":"$NOMBRE_ENFERMEDAD"}]}}		</result>
		<param name="ENFERMEDADINICIAL" sqlType="STRING"/>
		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposenfermedad/codigoydescripcionfinal/pag">
		<call-query href="getTiposenfermedadPagCodigoYDescripcionFinalQuery">
			<with-param name="ENFERMEDADINICIAL" query-param="ENFERMEDADINICIAL"/>
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposenfermedadNumCodigoYDescripcionFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT TIPO_ENFERMEDADES.CODIGOEN, TIPO_ENFERMEDADES.NOMBRE_ENFERMEDAD FROM TIPO_ENFERMEDADES WHERE TIPO_ENFERMEDADES.CODIGOEN &gt;= :ENFERMEDADINICIAL ORDER BY TIPO_ENFERMEDADES.CODIGOEN) INI WHERE (CASE WHEN CODIGOEN IS NULL THEN ' ' ELSE UPPER(CODIGOEN) END) LIKE UPPER(CONCAT(:CODIGOEN, '%')) AND (CASE WHEN NOMBRE_ENFERMEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ENFERMEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ENFERMEDAD), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ENFERMEDADINICIAL" sqlType="STRING"/>
		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposenfermedad/codigoydescripcionfinal/num">
		<call-query href="getTiposenfermedadNumCodigoYDescripcionFinalQuery">
			<with-param name="ENFERMEDADINICIAL" query-param="ENFERMEDADINICIAL"/>
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>

		</call-query>
	</resource>
	<query id="insertTiposenfermedad" keyColumns="CODIGOEN" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TIPO_ENFERMEDADES (CODIGOEN, NOMBRE_ENFERMEDAD, N_DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:CODIGOEN, :NOMBRE_ENFERMEDAD, :N_DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_CODIGOEN":"$CODIGOEN"}]}}		</result>
		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>
		<param name="N_DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tiposenfermedad">
		<call-query href="insertTiposenfermedad">
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>
			<with-param name="N_DESCRIPCION" query-param="N_DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTiposenfermedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TIPO_ENFERMEDADES WHERE TIPO_ENFERMEDADES.CODIGOEN= :KEY_CODIGOEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_CODIGOEN" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tiposenfermedad">
		<call-query href="deleteTiposenfermedad">
			<with-param name="KEY_CODIGOEN" query-param="KEY_CODIGOEN"/>

		</call-query>
	</resource>
	<query id="getTiposenfermedadPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TIPO_ENFERMEDADES.CODIGOEN, TIPO_ENFERMEDADES.NOMBRE_ENFERMEDAD, TIPO_ENFERMEDADES.N_DESCRIPCION FROM TIPO_ENFERMEDADES) INI WHERE (CASE WHEN CODIGOEN IS NULL THEN ' ' ELSE UPPER(CODIGOEN) END) LIKE UPPER(CONCAT(:CODIGOEN, '%')) AND (CASE WHEN NOMBRE_ENFERMEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ENFERMEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ENFERMEDAD), '%')) AND (CASE WHEN N_DESCRIPCION IS NULL THEN ' ' ELSE UPPER(N_DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:N_DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOEN":"$CODIGOEN","NOMBRE_ENFERMEDAD":"$NOMBRE_ENFERMEDAD","N_DESCRIPCION":"$N_DESCRIPCION"}]}}		</result>
		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>
		<param name="N_DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tiposenfermedad">
		<call-query href="getTiposenfermedadPaginaQuery">
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>
			<with-param name="N_DESCRIPCION" query-param="N_DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTiposenfermedadNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TIPO_ENFERMEDADES.CODIGOEN, TIPO_ENFERMEDADES.NOMBRE_ENFERMEDAD, TIPO_ENFERMEDADES.N_DESCRIPCION FROM TIPO_ENFERMEDADES) INI WHERE (CASE WHEN CODIGOEN IS NULL THEN ' ' ELSE UPPER(CODIGOEN) END) LIKE UPPER(CONCAT(:CODIGOEN, '%')) AND (CASE WHEN NOMBRE_ENFERMEDAD IS NULL THEN ' ' ELSE UPPER(NOMBRE_ENFERMEDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_ENFERMEDAD), '%')) AND (CASE WHEN N_DESCRIPCION IS NULL THEN ' ' ELSE UPPER(N_DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:N_DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>
		<param name="N_DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tiposenfermedad/numero">
		<call-query href="getTiposenfermedadNumeroQuery">
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>
			<with-param name="N_DESCRIPCION" query-param="N_DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateTiposenfermedad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TIPO_ENFERMEDADES SET CODIGOEN=:CODIGOEN, NOMBRE_ENFERMEDAD=:NOMBRE_ENFERMEDAD, N_DESCRIPCION=:N_DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TIPO_ENFERMEDADES.CODIGOEN= :KEY_CODIGOEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOEN" sqlType="STRING"/>
		<param name="NOMBRE_ENFERMEDAD" sqlType="STRING"/>
		<param name="N_DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_CODIGOEN" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tiposenfermedad">
		<call-query href="updateTiposenfermedad">
			<with-param name="CODIGOEN" query-param="CODIGOEN"/>
			<with-param name="NOMBRE_ENFERMEDAD" query-param="NOMBRE_ENFERMEDAD"/>
			<with-param name="N_DESCRIPCION" query-param="N_DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_CODIGOEN" query-param="KEY_CODIGOEN"/>

		</call-query>
	</resource>

</data>