<data name="rolusuario" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getRolusuarioPagUsuariodependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  USUARIO, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(TRIM(NOMBRE1),' '), TRIM(NOMBRE2)),' '),TRIM(APELLIDO1)),' '),TRIM(APELLIDO2)) NOMBRE_USUARIO,DEPENDENCIA  FROM ROL_USUARIO LEFT JOIN USUARIO ON USUARIO.CODIGO = ROL_USUARIO.USUARIO WHERE COMPANIA = :COMPANIA AND CODIGO_ROL = :ROL) WHERE (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN NOMBRE_USUARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_USUARIO) END)  LIKE UPPER( '%' || :NOMBRE_USUARIO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"USUARIO":"$USUARIO","NOMBRE_USUARIO":"$NOMBRE_USUARIO","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ROL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NOMBRE_USUARIO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="rolusuario/usuariodependencia/pag">
		<call-query href="getRolusuarioPagUsuariodependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ROL" query-param="ROL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NOMBRE_USUARIO" query-param="NOMBRE_USUARIO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRolusuarioNumUsuariodependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  USUARIO, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(TRIM(NOMBRE1),' '), TRIM(NOMBRE2)),' '),TRIM(APELLIDO1)),' '),TRIM(APELLIDO2)) NOMBRE_USUARIO,DEPENDENCIA  FROM ROL_USUARIO LEFT JOIN USUARIO ON USUARIO.CODIGO = ROL_USUARIO.USUARIO WHERE COMPANIA = :COMPANIA AND CODIGO_ROL = :ROL) WHERE (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN NOMBRE_USUARIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_USUARIO) END)  LIKE UPPER( '%' || :NOMBRE_USUARIO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ROL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NOMBRE_USUARIO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="rolusuario/usuariodependencia/num">
		<call-query href="getRolusuarioNumUsuariodependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ROL" query-param="ROL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NOMBRE_USUARIO" query-param="NOMBRE_USUARIO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getRolusuarioPagLlaveporrolQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA , CODIGO_ROL, USUARIO , DEPENDENCIA  FROM ROL_USUARIO WHERE COMPANIA = :COMPANIA AND CODIGO_ROL = :ROL AND USUARIO NOT IN(:USUARIO_TRAMITE)) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO_ROL IS NULL THEN ' ' ELSE UPPER(CODIGO_ROL) END)  LIKE UPPER(:CODIGO_ROL || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_ROL":"$CODIGO_ROL","USUARIO":"$USUARIO","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ROL" sqlType="STRING"/>
		<param name="USUARIO_TRAMITE" sqlType="STRING"/>
		<param name="CODIGO_ROL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="rolusuario/llaveporrol/pag">
		<call-query href="getRolusuarioPagLlaveporrolQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ROL" query-param="ROL"/>
			<with-param name="USUARIO_TRAMITE" query-param="USUARIO_TRAMITE"/>
			<with-param name="CODIGO_ROL" query-param="CODIGO_ROL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRolusuarioNumLlaveporrolQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA , CODIGO_ROL, USUARIO , DEPENDENCIA  FROM ROL_USUARIO WHERE COMPANIA = :COMPANIA AND CODIGO_ROL = :ROL AND USUARIO NOT IN(:USUARIO_TRAMITE)) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN CODIGO_ROL IS NULL THEN ' ' ELSE UPPER(CODIGO_ROL) END)  LIKE UPPER(:CODIGO_ROL || '%')  AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END)  LIKE UPPER( '%' || :USUARIO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ROL" sqlType="STRING"/>
		<param name="USUARIO_TRAMITE" sqlType="STRING"/>
		<param name="CODIGO_ROL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="rolusuario/llaveporrol/num">
		<call-query href="getRolusuarioNumLlaveporrolQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ROL" query-param="ROL"/>
			<with-param name="USUARIO_TRAMITE" query-param="USUARIO_TRAMITE"/>
			<with-param name="CODIGO_ROL" query-param="CODIGO_ROL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getRolusuarioPagCodnombreusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT RU.USUARIO CAMPO1, CONCAT(U.NOMBRE1,CONCAT(' ',CONCAT(U.NOMBRE2,CONCAT(' ',CONCAT(U.APELLIDO1,CONCAT(' ',U.APELLIDO2) ) ) ) ) ) CAMPO2 FROM NODO_RACI NR INNER JOIN ROL_USUARIO RU ON NR.COMPANIA = RU.COMPANIA AND NR.CODIGO_ROL = RU.CODIGO_ROL INNER JOIN USUARIO U ON RU.USUARIO = U.CODIGO WHERE NR.COMPANIA =:COMPANIA AND NR.CODIGO_NODO =:NODO AND NR.CODIGO_PROCESO =:PROCESO AND NR.CODIGO_RACI =:RACI) INI WHERE (CASE WHEN CAMPO1 IS NULL THEN ' ' ELSE UPPER(CAMPO1) END) LIKE UPPER(CONCAT(CONCAT('%',:CAMPO1), '%')) AND (CASE WHEN CAMPO2 IS NULL THEN ' ' ELSE UPPER(CAMPO2) END) LIKE UPPER(CONCAT(CONCAT('%',:CAMPO2), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CAMPO1":"$CAMPO1","CAMPO2":"$CAMPO2"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="RACI" sqlType="STRING"/>
		<param name="CAMPO1" sqlType="STRING"/>
		<param name="CAMPO2" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="rolusuario/codnombreusuario/pag">
		<call-query href="getRolusuarioPagCodnombreusuarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="RACI" query-param="RACI"/>
			<with-param name="CAMPO1" query-param="CAMPO1"/>
			<with-param name="CAMPO2" query-param="CAMPO2"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRolusuarioNumCodnombreusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT RU.USUARIO CAMPO1, CONCAT(U.NOMBRE1,CONCAT(' ',CONCAT(U.NOMBRE2,CONCAT(' ',CONCAT(U.APELLIDO1,CONCAT(' ',U.APELLIDO2) ) ) ) ) ) CAMPO2 FROM NODO_RACI NR INNER JOIN ROL_USUARIO RU ON NR.COMPANIA = RU.COMPANIA AND NR.CODIGO_ROL = RU.CODIGO_ROL INNER JOIN USUARIO U ON RU.USUARIO = U.CODIGO WHERE NR.COMPANIA =:COMPANIA AND NR.CODIGO_NODO =:NODO AND NR.CODIGO_PROCESO =:PROCESO AND NR.CODIGO_RACI =:RACI) INI WHERE (CASE WHEN CAMPO1 IS NULL THEN ' ' ELSE UPPER(CAMPO1) END) LIKE UPPER(CONCAT(CONCAT('%',:CAMPO1), '%')) AND (CASE WHEN CAMPO2 IS NULL THEN ' ' ELSE UPPER(CAMPO2) END) LIKE UPPER(CONCAT(CONCAT('%',:CAMPO2), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NODO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="RACI" sqlType="STRING"/>
		<param name="CAMPO1" sqlType="STRING"/>
		<param name="CAMPO2" sqlType="STRING"/>

	</query>
	<resource method="GET" path="rolusuario/codnombreusuario/num">
		<call-query href="getRolusuarioNumCodnombreusuarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NODO" query-param="NODO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="RACI" query-param="RACI"/>
			<with-param name="CAMPO1" query-param="CAMPO1"/>
			<with-param name="CAMPO2" query-param="CAMPO2"/>

		</call-query>
	</resource>
	<query id="insertRolusuario" keyColumns="COMPANIA,CODIGO_ROL,DEPENDENCIA,USUARIO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ROL_USUARIO (COMPANIA, CODIGO_ROL, DEPENDENCIA, USUARIO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO_ROL, :DEPENDENCIA, :USUARIO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO_ROL":"$CODIGO_ROL","KEY_DEPENDENCIA":"$DEPENDENCIA","KEY_USUARIO":"$USUARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_ROL" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="rolusuario">
		<call-query href="insertRolusuario">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_ROL" query-param="CODIGO_ROL"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteRolusuario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ROL_USUARIO WHERE ROL_USUARIO.COMPANIA= :KEY_COMPANIA AND ROL_USUARIO.CODIGO_ROL= :KEY_CODIGO_ROL AND ROL_USUARIO.DEPENDENCIA= :KEY_DEPENDENCIA AND ROL_USUARIO.USUARIO= :KEY_USUARIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_ROL" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
		<param name="KEY_USUARIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="rolusuario">
		<call-query href="deleteRolusuario">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO_ROL" query-param="KEY_CODIGO_ROL"/>
			<with-param name="KEY_DEPENDENCIA" query-param="KEY_DEPENDENCIA"/>
			<with-param name="KEY_USUARIO" query-param="KEY_USUARIO"/>

		</call-query>
	</resource>
	<query id="getRolusuarioPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ROL_USUARIO.COMPANIA, ROL_USUARIO.CODIGO_ROL, USUARIO.CODIGO USUARIO, CONCAT(USUARIO.NOMBRE1,CONCAT(' ',CONCAT(USUARIO.NOMBRE2,CONCAT(' ',CONCAT(USUARIO.APELLIDO1,CONCAT(' ',USUARIO.APELLIDO2) ) ) ) ) ) NOMBRE, DEPENDENCIA.CODIGO DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA FROM ROL_USUARIO INNER JOIN DEPENDENCIA ON ROL_USUARIO.COMPANIA = DEPENDENCIA.COMPANIA AND ROL_USUARIO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN USUARIO ON ROL_USUARIO.USUARIO = USUARIO.CODIGO WHERE ROL_USUARIO.COMPANIA =:COMPANIA AND ROL_USUARIO.CODIGO_ROL =:CODIGO_ROL) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO_ROL IS NULL THEN ' ' ELSE UPPER(CODIGO_ROL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_ROL), '%')) AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:USUARIO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEPENDENCIA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO_ROL":"$CODIGO_ROL","USUARIO":"$USUARIO","NOMBRE":"$NOMBRE","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_ROL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="rolusuario">
		<call-query href="getRolusuarioPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_ROL" query-param="CODIGO_ROL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getRolusuarioNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ROL_USUARIO.COMPANIA, ROL_USUARIO.CODIGO_ROL, USUARIO.CODIGO USUARIO, CONCAT(USUARIO.NOMBRE1,CONCAT(' ',CONCAT(USUARIO.NOMBRE2,CONCAT(' ',CONCAT(USUARIO.APELLIDO1,CONCAT(' ',USUARIO.APELLIDO2) ) ) ) ) ) NOMBRE, DEPENDENCIA.CODIGO DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA FROM ROL_USUARIO INNER JOIN DEPENDENCIA ON ROL_USUARIO.COMPANIA = DEPENDENCIA.COMPANIA AND ROL_USUARIO.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN USUARIO ON ROL_USUARIO.USUARIO = USUARIO.CODIGO WHERE ROL_USUARIO.COMPANIA =:COMPANIA AND ROL_USUARIO.CODIGO_ROL =:CODIGO_ROL) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO_ROL IS NULL THEN ' ' ELSE UPPER(CODIGO_ROL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO_ROL), '%')) AND (CASE WHEN USUARIO IS NULL THEN ' ' ELSE UPPER(USUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:USUARIO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END) LIKE UPPER(CONCAT(:DEPENDENCIA, '%')) AND (CASE WHEN NOMBRE_DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEPENDENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_DEPENDENCIA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_ROL" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE_DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="rolusuario/numero">
		<call-query href="getRolusuarioNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO_ROL" query-param="CODIGO_ROL"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMBRE_DEPENDENCIA" query-param="NOMBRE_DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="updateRolusuario" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ROL_USUARIO SET COMPANIA=:COMPANIA, CODIGO_ROL=:CODIGO_ROL, DEPENDENCIA=:DEPENDENCIA, USUARIO=:USUARIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ROL_USUARIO.COMPANIA= :KEY_COMPANIA AND ROL_USUARIO.CODIGO_ROL= :KEY_CODIGO_ROL AND ROL_USUARIO.DEPENDENCIA= :KEY_DEPENDENCIA AND ROL_USUARIO.USUARIO= :KEY_USUARIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO_ROL" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_ROL" sqlType="STRING"/>
		<param name="KEY_DEPENDENCIA" sqlType="STRING"/>
