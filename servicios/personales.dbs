	<query id="getPersonalesPagQuinquenioPorEmpleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ID_DE_EMPLEADO,(TO_CHAR(FECHAQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAQUINQUENIO, ACTOQUINQUENIO,(TO_CHAR(FECHADELACTOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHADELACTOQUINQUENIO,(TO_CHAR(FECHAPAGOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOQUINQUENIO, TO_CHAR(FECHAPAGOQUINQUENIO, 'DD/MM/YYYY') FECHAQLB  FROM PERSONAL WHERE COMPANIA = :COMPANIA AND ID_DE_EMPLEADO IN (:CODIGO)) WHERE (CASE WHEN FECHAQUINQUENIO IS NULL THEN ' ' ELSE UPPER(FECHAQUINQUENIO) END)  LIKE UPPER( '%' || :FECHAQUINQUENIO || '%')  AND (CASE WHEN ACTOQUINQUENIO IS NULL THEN ' ' ELSE UPPER(ACTOQUINQUENIO) END)  LIKE UPPER( '%' || :ACTOQUINQUENIO || '%')  AND (CASE WHEN FECHADELACTOQUINQUENIO IS NULL THEN ' ' ELSE UPPER(FECHADELACTOQUINQUENIO) END)  LIKE UPPER( '%' || :FECHADELACTOQUINQUENIO || '%')  AND (CASE WHEN FECHAQLB IS NULL THEN ' ' ELSE UPPER(FECHAQLB) END)  LIKE UPPER( '%' || :FECHAQLB || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","FECHAQUINQUENIO":"$FECHAQUINQUENIO","ACTOQUINQUENIO":"$ACTOQUINQUENIO","FECHADELACTOQUINQUENIO":"$FECHADELACTOQUINQUENIO","FECHAPAGOQUINQUENIO":"$FECHAPAGOQUINQUENIO","FECHAQLB":"$FECHAQLB"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FECHAQUINQUENIO" sqlType="STRING"/>
		<param name="ACTOQUINQUENIO" sqlType="STRING"/>
		<param name="FECHADELACTOQUINQUENIO" sqlType="STRING"/>
		<param name="FECHAQLB" sqlType="STRING"/>
