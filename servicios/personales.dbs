			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="CARGO" query-param="CARGO"/>

		</call-query>
	</resource>
	<query id="getPersonalesListacategoriajiQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA  FROM PERSONAL INNER JOIN CATEGORIA ON PERSONAL.ID_DE_CATEGORIA = CATEGORIA.ID_DE_CATEGORIA AND PERSONAL.ESCALAFON = CATEGORIA.ESCALAFON WHERE CATEGORIA.COMPANIA = :COMPANIA AND CATEGORIA.ESCALAFON = :ESCALAFONJEFE AND CATEGORIA.ANO = EXTRACT(YEAR FROM SYSDATE) GROUP BY CATEGORIA.ID_DE_CATEGORIA, CATEGORIA.NOMBRE_CATEGORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESCALAFONJEFE" sqlType="STRING"/>

