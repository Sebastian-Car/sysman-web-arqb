	<query id="getPersonalesIdEmpleadoConHistoricoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERSONAL.ID_DE_EMPLEADO, PERSONAL.SUCURSAL, PERSONAL.ID_DE_CARGO, JEFE_DIRECTO.NUMERO_DCTO JEFE_DIRECTO, JEFE_DIRECTO.SUCURSAL SUCURSAL_JEFE_DIRECTO  FROM PERSONAL INNER JOIN HISTORICOS ON PERSONAL.COMPANIA = HISTORICOS.COMPANIA AND PERSONAL.ID_DE_EMPLEADO = HISTORICOS.ID_DE_EMPLEADO LEFT JOIN PERSONAL JEFE_DIRECTO ON PERSONAL.COMPANIA = JEFE_DIRECTO.COMPANIA AND PERSONAL.JEFE_DIRECTO = JEFE_DIRECTO.ID_DE_EMPLEADO WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.NUMERO_DCTO =:NUMERO_DCTO AND HISTORICOS.ANO =:ANO AND HISTORICOS.MES =:MES AND HISTORICOS.PERIODO =:PERIODO AND HISTORICOS.ID_DE_PROCESO =:PROCESO ORDER BY PERSONAL.ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","SUCURSAL":"$SUCURSAL","ID_DE_CARGO":"$ID_DE_CARGO","JEFE_DIRECTO":"$JEFE_DIRECTO","SUCURSAL_JEFE_DIRECTO":"$SUCURSAL_JEFE_DIRECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/idempleadoconhistorico">
		<call-query href="getPersonalesIdEmpleadoConHistoricoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="PROCESO" query-param="PROCESO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagSubgrillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  P.COMPANIA, P.ID_DE_EMPLEADO, P.NOMBRECOMPLETO, CASE WHEN P.FECHA_FINAL IS NULL THEN TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365),'DD/MM/YYYY') ELSE TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1),'DD/MM/YYYY') END FECHA_INICIO_PROGRAMAR, CASE WHEN P.FECHA_FINAL IS NULL THEN TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365) + TRUNC((SYSDATE - TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')))/365) * 365,'DD/MM/YYYY') ELSE TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1) + TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1))/365) * 365,'DD/MM/YYYY') END FECHA_FINAL_PROGRAMAR, CASE WHEN P.FECHA_FINAL IS NULL THEN TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365))/365) ELSE TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1))/365) END ANIOS_ACUMULADOS, SUM (CASE WHEN H.ID_DE_CONCEPTO IN (356,357,359) THEN H.VALOR ELSE 0 END) LICENCIAS  FROM HISTORICOS H INNER JOIN PERSONAL P ON H.COMPANIA = P.COMPANIA AND H.ID_DE_EMPLEADO = P.ID_DE_EMPLEADO WHERE P.COMPANIA = :COMPANIA AND (SYSDATE - TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY'))) &gt;= 365 AND P.ID_DE_EMPLEADO NOT IN 0 AND P.ESTADO_ACTUAL IN (1) AND ( CASE WHEN P.FECHA_FINAL IS NULL THEN TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365))/365) ELSE TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1))/365) END ) &gt; 0 GROUP BY P.COMPANIA, P.ID_DE_EMPLEADO, P.NOMBRECOMPLETO, P.FECHA_DE_INGRESO, P.FECHA_FINAL ORDER BY ANIOS_ACUMULADOS DESC) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER( '%' || :ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN FECHA_INICIO_PROGRAMAR IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO_PROGRAMAR) END)  LIKE UPPER( '%' || :FECHA_INICIO_PROGRAMAR || '%')  AND (CASE WHEN FECHA_FINAL_PROGRAMAR IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL_PROGRAMAR) END)  LIKE UPPER( '%' || :FECHA_FINAL_PROGRAMAR || '%')  AND (CASE WHEN ANIOS_ACUMULADOS IS NULL THEN ' ' ELSE UPPER(ANIOS_ACUMULADOS) END)  LIKE UPPER( '%' || :ANIOS_ACUMULADOS || '%')  AND (CASE WHEN LICENCIAS IS NULL THEN ' ' ELSE UPPER(LICENCIAS) END)  LIKE UPPER( '%' || :LICENCIAS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","FECHA_INICIO_PROGRAMAR":"$FECHA_INICIO_PROGRAMAR","FECHA_FINAL_PROGRAMAR":"$FECHA_FINAL_PROGRAMAR","ANIOS_ACUMULADOS":"$ANIOS_ACUMULADOS(type:integer)","LICENCIAS":"$LICENCIAS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FECHA_INICIO_PROGRAMAR" sqlType="STRING"/>
		<param name="FECHA_FINAL_PROGRAMAR" sqlType="STRING"/>
		<param name="ANIOS_ACUMULADOS" sqlType="STRING"/>
		<param name="LICENCIAS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/subgrilla/pag">
