	<query id="getPersonalesPagGetpersonalcuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT P.NOMBRECOMPLETO ,P.NUMERO_DCTO ,P.ESTADO_ACTUAL ,(CASE P.GENERACUNE WHEN 0 THEN 'false' ELSE 'true' END) GENERACUNE,P.CODIGOPOSTAL ,CASE P.SUBTIPO_NIE042 WHEN '00' THEN 'No Aplica' WHEN '01' THEN 'Dependiente' ELSE NULL END STIPO_NIE042 ,(CASE P.ALTORIESGOPENSION WHEN 0 THEN 'false' ELSE 'true' END) ALTORIESGOPENSION,CASE P.TIPOCONTRATO_NIE061 WHEN '1' THEN 'Termino Fijo' WHEN '2' THEN 'Término Indefinido' WHEN '3' THEN 'Obra o Labor' WHEN '4' THEN 'Aprendizaje' WHEN '5' THEN 'Prácticas o Pasantías' ELSE NULL END TCONTRATO_NIE061 ,M.NOMBRE MEDIOPAGONIE, B.NOMBRE BANCO , P.CUENTA , CASE P.TIPOCUENTA WHEN 'A' THEN 'Ahorro' WHEN 'C' THEN 'Corriente' WHEN 'R' THEN 'Crédito Rotativo' WHEN 'O' THEN 'Otros Pagos' WHEN 'D' THEN 'Daviplata' WHEN 'M' THEN 'Tarjeta Prepago Maestro' ELSE NULL END TIPOCUENTA ,P.ID_DE_EMPLEADO, P.COMPANIA ,P.TIPO_VINCULACION_NIE041 , TV.NOMBRE TIPOVINCULACIONNIE ,P.TIPOCONTRATO_NIE061 ,P.MEDIODEPAGO_NIE065 ,P.SUBTIPO_NIE042 FROM PERSONAL P INNER JOIN COMPANIA C ON P.COMPANIA = C.CODIGO LEFT JOIN TIPO_VINCULACION TV ON P.TIPO_VINCULACION_NIE041 = TV.CODIGO LEFT JOIN BANCOS_NOMINA B ON P.COMPANIA = B.COMPANIA AND P.BANCO = B.BANCO LEFT JOIN MEDIOS_DE_PAGO M ON P.COMPANIA = M.COMPANIA AND P.MEDIODEPAGO_NIE065 = M.CODIGO WHERE ( (P.ESTADO_ACTUAL = 1 OR P.ESTADO_ACTUAL = 2 ) OR (P.ESTADO_ACTUAL = 3 AND TO_DATE(TO_CHAR(P.FECHA_DE_RETIRO,'DD/MM/YYYY'),'DD/MM/YYYY') &gt;= TO_DATE('30/06/2021','DD/MM/YYYY')) ) AND C.GENERA_CUNE NOT IN (0) AND P.COMPANIA =:COMPANIA ORDER BY P.NOMBRECOMPLETO, P.NUMERO_DCTO) INI WHERE (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN ESTADO_ACTUAL IS NULL THEN ' ' ELSE UPPER(ESTADO_ACTUAL) END) LIKE UPPER(CONCAT(:ESTADO_ACTUAL, '%')) AND (CASE WHEN GENERACUNE IS NULL THEN ' ' ELSE UPPER(GENERACUNE) END) LIKE UPPER(CONCAT(:GENERACUNE, '%')) AND (CASE WHEN CODIGOPOSTAL IS NULL THEN ' ' ELSE UPPER(CODIGOPOSTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOPOSTAL), '%')) AND (CASE WHEN STIPO_NIE042 IS NULL THEN ' ' ELSE UPPER(STIPO_NIE042) END) LIKE UPPER(CONCAT(:STIPO_NIE042, '%')) AND (CASE WHEN ALTORIESGOPENSION IS NULL THEN ' ' ELSE UPPER(ALTORIESGOPENSION) END) LIKE UPPER(CONCAT(:ALTORIESGOPENSION, '%')) AND (CASE WHEN TCONTRATO_NIE061 IS NULL THEN ' ' ELSE UPPER(TCONTRATO_NIE061) END) LIKE UPPER(CONCAT(:TCONTRATO_NIE061, '%')) AND (CASE WHEN MEDIOPAGONIE IS NULL THEN ' ' ELSE UPPER(MEDIOPAGONIE) END) LIKE UPPER(CONCAT(:MEDIOPAGONIE, '%')) AND (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END) LIKE UPPER(CONCAT(CONCAT('%',:BANCO), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA), '%')) AND (CASE WHEN TIPOCUENTA IS NULL THEN ' ' ELSE UPPER(TIPOCUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCUENTA), '%')) AND (CASE WHEN TIPOVINCULACIONNIE IS NULL THEN ' ' ELSE UPPER(TIPOVINCULACIONNIE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOVINCULACIONNIE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRECOMPLETO":"$NOMBRECOMPLETO","NUMERO_DCTO":"$NUMERO_DCTO","ESTADO_ACTUAL":"$ESTADO_ACTUAL","GENERACUNE":"$GENERACUNE(type:boolean)","CODIGOPOSTAL":"$CODIGOPOSTAL","STIPO_NIE042":"$STIPO_NIE042","ALTORIESGOPENSION":"$ALTORIESGOPENSION(type:boolean)","TCONTRATO_NIE061":"$TCONTRATO_NIE061","MEDIOPAGONIE":"$MEDIOPAGONIE","BANCO":"$BANCO","CUENTA":"$CUENTA","TIPOCUENTA":"$TIPOCUENTA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","COMPANIA":"$COMPANIA","TIPO_VINCULACION_NIE041":"$TIPO_VINCULACION_NIE041(type:integer)","TIPOVINCULACIONNIE":"$TIPOVINCULACIONNIE","TIPOCONTRATO_NIE061":"$TIPOCONTRATO_NIE061","MEDIODEPAGO_NIE065":"$MEDIODEPAGO_NIE065","SUBTIPO_NIE042":"$SUBTIPO_NIE042"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="ESTADO_ACTUAL" sqlType="STRING"/>
		<param name="GENERACUNE" sqlType="STRING"/>
		<param name="CODIGOPOSTAL" sqlType="STRING"/>
		<param name="STIPO_NIE042" sqlType="STRING"/>
		<param name="ALTORIESGOPENSION" sqlType="STRING"/>
		<param name="TCONTRATO_NIE061" sqlType="STRING"/>
		<param name="MEDIOPAGONIE" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="TIPOCUENTA" sqlType="STRING"/>
		<param name="TIPOVINCULACIONNIE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
