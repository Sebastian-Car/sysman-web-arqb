		</call-query>
	</resource>

		<query id="getPersonalesListadocorreodianporanoQuery"  useConfig="sysmandsunist">
		<sql>SELECT s.NUMERO_DCTO, s.ID_DE_EMPLEADO, s.NOMBRECOMPLETO, s.EMAIL_CORPORATIVO, s.EMAIL_PERSONAL, s.ENVIO_CORREO_DIAN FROM ( SELECT PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO, EMAIL_CORPORATIVO, EMAIL_PERSONAL, CASE WHEN TO_NUMBER(:ID_DE_EMPLEADO) = 0 THEN CASE WHEN NVL(ENVIO_CORREO_DIAN.ENVIO_CORREO_DIAN,'0') = 0 THEN 'NO' ELSE 'SI' END ELSE 'NO' END AS ENVIO_CORREO_DIAN FROM PERSONAL LEFT JOIN ENVIO_CORREO_DIAN ON ENVIO_CORREO_DIAN.COMPANIA = PERSONAL.COMPANIA AND ENVIO_CORREO_DIAN.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO AND ENVIO_CORREO_DIAN.ANO = TO_NUMBER(EXTRACT(YEAR FROM TO_DATE(TO_CHAR(CONCAT('01/01/',:ANO)),'DD/MM/YYYY'))) WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO NOT IN (0) AND (PERSONAL.ESTADO_ACTUAL = :ESTADO OR (PERSONAL.ESTADO_ACTUAL=3 AND FECHA_DE_RETIRO &gt;= TO_DATE(:FECHA,'DD/MM/YYYY'))) AND PERSONAL.ID_DE_EMPLEADO = CASE WHEN (:ID_DE_EMPLEADO) = 0 THEN PERSONAL.ID_DE_EMPLEADO ELSE TO_NUMBER(:ID_DE_EMPLEADO) END ) s WHERE s.ENVIO_CORREO_DIAN = 'NO' ORDER BY s.NOMBRECOMPLETO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO","EMAIL_PERSONAL":"$EMAIL_PERSONAL","ENVIO_CORREO_DIAN":"$ENVIO_CORREO_DIAN"}]}}		</result>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/listadocorreodianporano">
		<call-query href="getPersonalesListadocorreodianporanoQuery">
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHA" query-param="FECHA"/>

		</call-query>
	</resource>
	<query id="getPersonalesDatosreformapensionalQuery"  useConfig="sysmandsunist">
		<sql>SELECT P.ID_DE_EMPLEADO ID, P.NUMERO_DCTO DOCUMENTO, P.NOMBRECOMPLETO NOMBRE, E.NOMBRE ESTADO, TRIM(CONCAT(CONCAT(P.FONDO_ACCAI, ' '), VF.NOMBRE_DEL_FONDO)) FONDO, TO_CHAR(FECHAFONDOACCAI, 'DD/MM/YYYY') FECHA, CASE WHEN REGIMEN_TRANSICION NOT IN ( 0 ) THEN 'SI' ELSE 'NO' END REGIMEN, TO_CHAR(P.FECHA_DE_RETIRO,'DD/MM/YYYY') FECHA_DE_RETIRO, TRIM(CONCAT(CONCAT(P.ID_DEL_FONDO, ' '), F.NOMBRE_DEL_FONDO)) FONDO_DE_PENSION FROM PERSONAL P INNER JOIN ESTADO_ACTUAL E ON P.ESTADO_ACTUAL = E.CODIGO LEFT JOIN V_FONDO_DE_PENSIONES VF ON VF.COMPANIA = P.COMPANIA AND VF.ID_DEL_FONDO = P.FONDO_ACCAI LEFT JOIN V_FONDO_DE_PENSIONES F ON F.COMPANIA = P.COMPANIA AND F.ID_DEL_FONDO = P.ID_DEL_FONDO WHERE P.COMPANIA = :COMPANIA AND ID_DE_EMPLEADO NOT IN (0) AND P.ESTADO_ACTUAL IN (1,3) AND (P.FECHA_DE_RETIRO IS NULL OR P.FECHA_DE_RETIRO &gt;= TO_DATE('01/01/2025', 'DD/MM/YYYY')) ORDER BY ESTADO, NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID(type:integer)","DOCUMENTO":"$DOCUMENTO","NOMBRE":"$NOMBRE","ESTADO":"$ESTADO","FONDO":"$FONDO","FECHA":"$FECHA","REGIMEN":"$REGIMEN","FECHA_DE_RETIRO":"$FECHA_DE_RETIRO","FONDO_DE_PENSION":"$FONDO_DE_PENSION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/datosreformapensional">
		<call-query href="getPersonalesDatosreformapensionalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
<query id="getPersonalesProcesoretencionportablaQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE WHEN COUNT(0) &gt; 0 THEN 'true' ELSE 'false' END) VALOR FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ESTADO_ACTUAL IN (1) AND PROCESORETENCION IN (2)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/procesoretencionportabla">
		<call-query href="getPersonalesProcesoretencionportablaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagRetiradosporfechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, ( SELECT NOMBRE FROM ESTADO_ACTUAL WHERE CODIGO = PERSONAL.ESTADO_ACTUAL ) ESTADO_ACTUAL, TO_CHAR(PERSONAL.FECHATERCONTRATO, 'DD/MM/YYYY') FECHATERCONTRATO FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ESTADO_ACTUAL &lt;&gt; :ESTADO AND PERSONAL.FECHATERCONTRATO &gt;= TO_DATE(:FECHAINICIO, 'DD/MM/YYYY') AND PERSONAL.FECHATERCONTRATO &lt;= TO_DATE(:FECHAFIN, 'DD/MM/YYYY') ORDER BY PERSONAL.FECHATERCONTRATO DESC) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN ESTADO_ACTUAL IS NULL THEN ' ' ELSE UPPER(ESTADO_ACTUAL) END) LIKE UPPER(CONCAT(:ESTADO_ACTUAL, '%')) AND (CASE WHEN FECHATERCONTRATO IS NULL THEN ' ' ELSE UPPER(FECHATERCONTRATO) END) LIKE UPPER(CONCAT(:FECHATERCONTRATO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","ESTADO_ACTUAL":"$ESTADO_ACTUAL","FECHATERCONTRATO":"$FECHATERCONTRATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="ESTADO_ACTUAL" sqlType="STRING"/>
		<param name="FECHATERCONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/retiradosporfecha/pag">
		<call-query href="getPersonalesPagRetiradosporfechaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="ESTADO_ACTUAL" query-param="ESTADO_ACTUAL"/>
			<with-param name="FECHATERCONTRATO" query-param="FECHATERCONTRATO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumRetiradosporfechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, ( SELECT NOMBRE FROM ESTADO_ACTUAL WHERE CODIGO = PERSONAL.ESTADO_ACTUAL ) ESTADO_ACTUAL, TO_CHAR(PERSONAL.FECHATERCONTRATO, 'DD/MM/YYYY') FECHATERCONTRATO FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ESTADO_ACTUAL &lt;&gt; :ESTADO AND PERSONAL.FECHATERCONTRATO &gt;= TO_DATE(:FECHAINICIO, 'DD/MM/YYYY') AND PERSONAL.FECHATERCONTRATO &lt;= TO_DATE(:FECHAFIN, 'DD/MM/YYYY') ORDER BY PERSONAL.FECHATERCONTRATO DESC) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN ESTADO_ACTUAL IS NULL THEN ' ' ELSE UPPER(ESTADO_ACTUAL) END) LIKE UPPER(CONCAT(:ESTADO_ACTUAL, '%')) AND (CASE WHEN FECHATERCONTRATO IS NULL THEN ' ' ELSE UPPER(FECHATERCONTRATO) END) LIKE UPPER(CONCAT(:FECHATERCONTRATO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="ESTADO_ACTUAL" sqlType="STRING"/>
		<param name="FECHATERCONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/retiradosporfecha/num">
		<call-query href="getPersonalesNumRetiradosporfechaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="ESTADO_ACTUAL" query-param="ESTADO_ACTUAL"/>
			<with-param name="FECHATERCONTRATO" query-param="FECHATERCONTRATO"/>

		</call-query>
	</resource>
	<query id="getPersonalesInfbecpQuery"  useConfig="sysmandsunist">
		<sql>SELECT TMP.ID_DE_EMPLEADO, P.NUMERO_DCTO, P.NOMBRECOMPLETO, CARGOS.NOMBRE_DEL_CARGO, TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY') FECHA_DE_INGRESO, TMP.SBM, TMP.GR, TMP.PT, TO_CHAR(P.FECHA_CUMPLIMIENTO_BONIFICACIO,'DD/MM/YYYY') FECHA_CUMPLIMIENTO_BONIFICACIO, TMP.DIASLNRBASP, TMP.PORCBASP, TMP.SOBRESUELDO, TMP.AUXT, TMP.AUXA, TMP.PA, P.ID_DE_TIPO, TMP.BASP, TMP.EXTRAS,(TO_CHAR(TMP.FECHAINIPS,'DD/MM/YYYY HH24:MI:SS')) FECHAINIPS, TMP.DIASLNRPS, TMP.PS,(TO_CHAR(TMP.FECHAINIPSV,'DD/MM/YYYY HH24:MI:SS')) FECHAINIPSV, TMP.DIASLNRPV, TMP.DIASTOTV, TMP.PV,(TO_CHAR(TMP.FECHAINIPSN,'DD/MM/YYYY HH24:MI:SS')) FECHAINIPSN, TMP.DIASLNRPN, P.REGIMEN, TMP.PN,(TO_CHAR(TMP.FECHAINIPSCES,'DD/MM/YYYY HH24:MI:SS')) FECHAINIPSCES, TMP.DIASLNRCES, TMP.ANTICIPOS FROM TMP_INF_BECPNOM TMP INNER JOIN PERSONAL P ON TMP.COMPANIA = P.COMPANIA AND TMP.ID_DE_EMPLEADO = P.ID_DE_EMPLEADO INNER JOIN CARGOS ON P.COMPANIA = CARGOS.COMPANIA AND P.ID_DE_CARGO = CARGOS.ID_DE_CARGO ORDER BY TMP.ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","FECHA_DE_INGRESO":"$FECHA_DE_INGRESO","SBM":"$SBM","GR":"$GR","PT":"$PT","FECHA_CUMPLIMIENTO_BONIFICACIO":"$FECHA_CUMPLIMIENTO_BONIFICACIO","DIASLNRBASP":"$DIASLNRBASP","PORCBASP":"$PORCBASP","SOBRESUELDO":"$SOBRESUELDO","AUXT":"$AUXT","AUXA":"$AUXA","PA":"$PA","ID_DE_TIPO":"$ID_DE_TIPO","BASP":"$BASP","EXTRAS":"$EXTRAS","FECHAINIPS":"$FECHAINIPS","DIASLNRPS":"$DIASLNRPS","PS":"$PS","FECHAINIPSV":"$FECHAINIPSV","DIASLNRPV":"$DIASLNRPV","DIASTOTV":"$DIASTOTV","PV":"$PV","FECHAINIPSN":"$FECHAINIPSN","DIASLNRPN":"$DIASLNRPN","REGIMEN":"$REGIMEN(type:integer)","PN":"$PN","FECHAINIPSCES":"$FECHAINIPSCES","DIASLNRCES":"$DIASLNRCES","ANTICIPOS":"$ANTICIPOS"}]}}		</result>
 
	</query>
	<resource method="GET" path="personales/infbecp">
		<call-query href="getPersonalesInfbecpQuery">
 
		</call-query>
	</resource>
	<query id="deletePersonalesDeletetmpbecp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE TMP_INF_BECPNOM</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

 
	</query>
	<resource method="DELETE" path="personales/deletetmpbecp">
		<call-query href="deletePersonalesDeletetmpbecp">
 
		</call-query>
	</resource>	
</data>