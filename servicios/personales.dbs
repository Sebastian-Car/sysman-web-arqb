	<query id="updatePersonalesPersonalsiif" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET MEDIO_PAGO_SIIF=:MEDIO_PAGO_SIIF, NIVELSIIF=:NIVELSIIF, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PERSONAL.COMPANIA= :KEY_COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MEDIO_PAGO_SIIF" sqlType="STRING"/>
		<param name="NIVELSIIF" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="personales/personalsiif">
		<call-query href="updatePersonalesPersonalsiif">
			<with-param name="MEDIO_PAGO_SIIF" query-param="MEDIO_PAGO_SIIF"/>
			<with-param name="NIVELSIIF" query-param="NIVELSIIF"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getPersonalesEnvioDeCorreosQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT V_VOLANTES.ID_DE_EMPLEADO, V_VOLANTES.NUMERO_DCTO, V_VOLANTES.NOMBRECOMPLETO, PERSONAL.EMAIL_PERSONAL, PERSONAL.EMAIL_CORPORATIVO FROM PERSONAL INNER JOIN V_VOLANTES ON PERSONAL.COMPANIA = V_VOLANTES.COMPANIA AND PERSONAL.ID_DE_EMPLEADO = V_VOLANTES.ID_DE_EMPLEADO INNER JOIN personal_historico ON personal_historico.COMPANIA = V_VOLANTES.COMPANIA AND personal_historico.ID_DE_EMPLEADO = V_VOLANTES.ID_DE_EMPLEADO WHERE V_VOLANTES.COMPANIA = :COMPANIA AND V_VOLANTES.ID_DE_PROCESO = :ID_DE_PROCESO AND V_VOLANTES.ANO = :ANO AND V_VOLANTES.MES = :MES AND V_VOLANTES.PERIODO = :PERIODO AND V_VOLANTES.ID_DE_EMPLEADO = CASE WHEN (:ESTADO) IN (-1) THEN TO_NUMBER(:ID_DE_EMPLEADO) ELSE V_VOLANTES.ID_DE_EMPLEADO END AND personal_historico.ID_DE_PROCESO = :ID_DE_PROCESO AND personal_historico.ANO = :ANO AND personal_historico.MES = :MES AND personal_historico.PERIODO = :PERIODO AND personal_historico.envio_correo &lt;= CASE WHEN (:ESTADO) IN (-1) THEN 999 ELSE 0 END order by NOMBRECOMPLETO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","EMAIL_PERSONAL":"$EMAIL_PERSONAL","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
