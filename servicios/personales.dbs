	<query id="deletePersonales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PERSONAL WHERE PERSONAL.COMPANIA= :KEY_COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="personales">
		<call-query href="deletePersonales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERSONAL.COMPANIA, PERSONAL.ID_DE_TIPO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, ESTADO_ACTUAL.NOMBRE ESTADO  FROM PERSONAL INNER JOIN ESTADO_ACTUAL ON PERSONAL.ESTADO_ACTUAL = ESTADO_ACTUAL.CODIGO WHERE PERSONAL.COMPANIA = :COMPANIA AND ID_DE_EMPLEADO NOT IN (0) ORDER BY PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER( '%' || :NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_TIPO":"$ID_DE_TIPO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales">
		<call-query href="getPersonalesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PERSONAL.COMPANIA, PERSONAL.ID_DE_TIPO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, ESTADO_ACTUAL.NOMBRE ESTADO  FROM PERSONAL INNER JOIN ESTADO_ACTUAL ON PERSONAL.ESTADO_ACTUAL = ESTADO_ACTUAL.CODIGO WHERE PERSONAL.COMPANIA = :COMPANIA AND ID_DE_EMPLEADO NOT IN (0) ORDER BY PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER( '%' || :NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/numero">
		<call-query href="getPersonalesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getPersonalesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT PERSONAL.ID_DE_EMPLEADO, PERSONAL.APELLIDO1, NVL(PERSONAL.APELLIDO2,' ') APELLIDO2, PERSONAL.NOMBRES, PERSONAL.SEXO, PERSONAL.NUMERO_DCTO, PERSONAL.SUCURSAL, PERSONAL.DEPARTAMENTO_CED, PERSONAL.EXPEDIDA, PERSONAL.ESTADO_CIVIL,(TO_CHAR(PERSONAL.FECHANCTO,'DD/MM/YYYY HH24:MI:SS')) FECHANCTO,(TO_CHAR(PERSONAL.FECHA_DE_INGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHA_DE_INGRESO,(TO_CHAR(PERSONAL.INGRESO_DISTRITO,'DD/MM/YYYY HH24:MI:SS')) INGRESO_DISTRITO, PERSONAL.ID_CENTRO_DE_COSTO, PERSONAL.ID_DE_CARGO,(TO_CHAR(PERSONAL.FECHA_ULTSUELDO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ULTSUELDO, PERSONAL.ID_DEL_FONDO, PERSONAL.ESCALAFON, PERSONAL.ID_DE_CATEGORIA, PERSONAL.ANO,(TO_CHAR(PERSONAL.FECHA_DE_RETIRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_DE_RETIRO, PERSONAL.ID_DE_TIPO, PERSONAL.OBSERVACIONES, PERSONAL.CALZADO, PERSONAL.CAMISA, PERSONAL.PANTALON, PERSONAL.CHAQUETA, PERSONAL.FOTO, PERSONAL.FONDO_SALUD, PERSONAL.FONDO_CESANTIAS, PERSONAL.FONDO_RIESGOS,(TO_CHAR(PERSONAL.FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(PERSONAL.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(PERSONAL.INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(PERSONAL.FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE, PERSONAL.NUMEROPATRONAL, PERSONAL.ESTADO_ACTUAL, PERSONAL.BANCO, PERSONAL.CUENTA,(CASE PERSONAL.SINDICATO WHEN 0 THEN 'false' ELSE 'true' END) SINDICATO, PERSONAL.ANOS_CARGO, PERSONAL.DEPENDENCIA, PERSONAL.PRIMA_TECNICA, PERSONAL.PROCESORETENCION, PERSONAL.PERSONASCARGO, PERSONAL.CUPOSALUD,(TO_CHAR(PERSONAL.FECHACUPOSALUD,'DD/MM/YYYY HH24:MI:SS')) FECHACUPOSALUD, PERSONAL.CUPOSEDUCACION,(CASE PERSONAL.EMBARGADO WHEN 0 THEN 'false' ELSE 'true' END) EMBARGADO, PERSONAL.REGIMEN,(TO_CHAR(PERSONAL.FECHAFONDOSALUD,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOSALUD,(TO_CHAR(PERSONAL.FECHAFONDOPENSION,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOPENSION,(TO_CHAR(PERSONAL.FECHAFONDOCESANTIA,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOCESANTIA,(TO_CHAR(PERSONAL.FECHAFONDORIESGOS,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDORIESGOS, PERSONAL.TIPOCUENTA,(TO_CHAR(PERSONAL.FECHAQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAQUINQUENIO, PERSONAL.ACTOQUINQUENIO,(TO_CHAR(PERSONAL.FECHADELACTOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHADELACTOQUINQUENIO,(TO_CHAR(PERSONAL.FECHATERCONTRATO,'DD/MM/YYYY HH24:MI:SS')) FECHATERCONTRATO,(TO_CHAR(PERSONAL.INGRESODISTRITOREAL,'DD/MM/YYYY HH24:MI:SS')) INGRESODISTRITOREAL, PERSONAL.DIASINTERRUPCION, PERSONAL.NORESOLUCIONCARGO,(TO_CHAR(PERSONAL.FECHARESOLUCIONCARGO,'DD/MM/YYYY HH24:MI:SS')) FECHARESOLUCIONCARGO, PERSONAL.CERTIFICADOJUDICIAL, PERSONAL.LICENCIACONDUCCION, PERSONAL.RH, PERSONAL.GRUPOSANGINEO, PERSONAL.ENFERMEDCONGENITA, PERSONAL.MEDICOTRATANTE, PERSONAL.ALERGIAS, PERSONAL.MEDICINA_PREPAGADA, PERSONAL.CAJA_COMPENSACION,(TO_CHAR(PERSONAL.FECHAMEDICINA,'DD/MM/YYYY HH24:MI:SS')) FECHAMEDICINA,(TO_CHAR(PERSONAL.FECHACAJACOMPENSACION,'DD/MM/YYYY HH24:MI:SS')) FECHACAJACOMPENSACION, PERSONAL.GRUPOCONTABLE, PERSONAL.SEDE, PERSONAL.VALORXCANCELAR, PERSONAL.MESADA_PENSIONAL,(TO_CHAR(PERSONAL.FECHA_CAMBIO_MESADA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CAMBIO_MESADA, PERSONAL.RIESGO_PENSION, PERSONAL.SUSTITUTODE,(TO_CHAR(PERSONAL.F_INI_PENSION_AFP,'DD/MM/YYYY HH24:MI:SS')) F_INI_PENSION_AFP, PERSONAL.VR_PENSION_AFP, PERSONAL.VR_PENSION_EMPRESA, PERSONAL.FONDO_PENSION_VOL,(TO_CHAR(PERSONAL.FECHAFONDOPENSIONVOL,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOPENSIONVOL,(TO_CHAR(PERSONAL.FECHAPAGOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOQUINQUENIO,(TO_CHAR(PERSONAL.FECHAANTIGQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAANTIGQUINQUENIO, PERSONAL.DEPARTAMENTO_NAC, PERSONAL.PAIS_NAC, PERSONAL.PAIS_CED, PERSONAL.CIUDAD_NAC, PERSONAL.FONDO_SINDICATO, PERSONAL.PORC_SINDICATO, PERSONAL.DCTO_IDENTIDAD, PERSONAL.CAUSA_RETIRO, PERSONAL.DIRECCION, PERSONAL.TELEFONOS, PERSONAL.CODIGO_ESTABLECIMIENTO, PERSONAL.CIUDAD_CUENTA, PERSONAL.DE_CARRERA, PERSONAL.PAIS_HAB, PERSONAL.DEPARTAMENTO_HAB, PERSONAL.CIUDAD_HAB, PERSONAL.ESTRATO,(CASE PERSONAL.PROPIETARIO WHEN 0 