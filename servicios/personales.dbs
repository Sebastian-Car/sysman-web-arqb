	<query id="getPersonalesNombreCategoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CATEGORIA.NOMBRE_CATEGORIA NOMBRECATEGORIA  FROM PERSONAL INNER JOIN DEPENDENCIA_RESPONSABLE ON DEPENDENCIA_RESPONSABLE.COMPANIA = PERSONAL.COMPANIA AND DEPENDENCIA_RESPONSABLE.RESPONSABLE = PERSONAL.NUMERO_DCTO AND DEPENDENCIA_RESPONSABLE.SUCURSAL = PERSONAL.SUCURSAL INNER JOIN CATEGORIA ON PERSONAL.COMPANIA =CATEGORIA.COMPANIA AND PERSONAL.ESCALAFON =CATEGORIA.ESCALAFON AND PERSONAL.ID_DE_CATEGORIA = CATEGORIA.ID_DE_CATEGORIA AND PERSONAL.ANO = CATEGORIA.ANO WHERE PERSONAL.COMPANIA = :COMPANIA AND DEPENDENCIA_RESPONSABLE.DEPENDENCIA = :DEPENDENCIA AND CATEGORIA.ID_DE_CATEGORIA = :CATEGORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRECATEGORIA":"$NOMBRECATEGORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>

	</query>
