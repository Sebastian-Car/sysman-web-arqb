	<query id="getPersonalesCompaniaescalafonnombredependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PERSONAL.COMPANIA, PERSONAL.NUMERO_DCTO, PERSONAL.ESTADO_ACTUAL, PERSONAL.ESCALAFON, ESCALAFON.NOMBRE AS NOMBREES, PERSONAL.DEPENDENCIA, DEPENDENCIA.NOMBRE AS NOMBREDEP  FROM PERSONAL INNER JOIN ESCALAFON ON PERSONAL.COMPANIA = ESCALAFON.COMPANIA AND PERSONAL.ESCALAFON = ESCALAFON.CODIGO INNER JOIN DEPENDENCIA ON PERSONAL.COMPANIA = DEPENDENCIA.COMPANIA AND PERSONAL.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.NUMERO_DCTO = :NUMERO_DCTO AND PERSONAL.SUCURSAL = :SUCURSAL AND PERSONAL.ESTADO_ACTUAL IN ('1')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","ESTADO_ACTUAL":"$ESTADO_ACTUAL","ESCALAFON":"$ESCALAFON","NOMBREES":"$NOMBREES","DEPENDENCIA":"$DEPENDENCIA","NOMBREDEP":"$NOMBREDEP"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/companiaescalafonnombredependencia">
		<call-query href="getPersonalesCompaniaescalafonnombredependenciaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getPersonalesIdEmpleadoAnoConHistoricoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT PERSONAL.ID_DE_EMPLEADO, PERSONAL.SUCURSAL, PERSONAL.ID_DE_CARGO, JEFE_DIRECTO.NUMERO_DCTO JEFE_DIRECTO, JEFE_DIRECTO.SUCURSAL SUCURSAL_JEFE_DIRECTO  FROM PERSONAL LEFT JOIN PERSONAL JEFE_DIRECTO ON PERSONAL.COMPANIA = JEFE_DIRECTO.COMPANIA AND PERSONAL.JEFE_DIRECTO = JEFE_DIRECTO.ID_DE_EMPLEADO WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.NUMERO_DCTO =:NUMERO_DCTO ORDER BY PERSONAL.ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","SUCURSAL":"$SUCURSAL","ID_DE_CARGO":"$ID_DE_CARGO","JEFE_DIRECTO":"$JEFE_DIRECTO","SUCURSAL_JEFE_DIRECTO":"$SUCURSAL_JEFE_DIRECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>

	</query>
