	<query id="updatePersonalesActualizarInd_correccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE  PERSONAL SET MODIFIED_BY                   =:MODIFIED_BY,   DATE_MODIFIED                 =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), IND_CORRECCION = :IND_CORRECCION WHERE COMPANIA =:COMPANIA AND ESTADO_ACTUAL NOT IN (3)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="IND_CORRECCION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="personales/actualizarind_correccion">
		<call-query href="updatePersonalesActualizarInd_correccion">
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="IND_CORRECCION" query-param="IND_CORRECCION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="updatePersonalesCompaniaIdEmpleadoDespues" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET   FECHA_INICIO   =TO_DATE(:FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS'),   FECHA_FINAL    =TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'),   INICIO_DISFRUTE=TO_DATE(:INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS'),   FINAL_DISFRUTE =TO_DATE(:FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS') WHERE COMPANIA = :COMPANIA   AND ID_DE_EMPLEADO =:ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_INICIO" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="INICIO_DISFRUTE" sqlType="STRING"/>
		<param name="FINAL_DISFRUTE" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
