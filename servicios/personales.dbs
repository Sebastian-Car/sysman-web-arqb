	<query id="getPersonalesPagIddeempleadonumdctonomcompletoestadonomQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  P.ID_DE_EMPLEADO ,P.NUMERO_DCTO ,P.NOMBRECOMPLETO ,EA.NOMBRE ESTADO_NOM  FROM PERSONAL P INNER JOIN ESTADO_ACTUAL EA ON P.ESTADO_ACTUAL = EA.CODIGO WHERE P.COMPANIA = :COMPANIA AND P.ID_DE_EMPLEADO NOT IN (0) ORDER BY P.NUMERO_DCTO ,P.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END)  LIKE UPPER( '%' || :ESTADO_NOM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","ESTADO_NOM":"$ESTADO_NOM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

