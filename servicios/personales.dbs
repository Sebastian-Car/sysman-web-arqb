	<query id="getPersonalesPorIdDeEmpleadoSegunCedulaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  LISTAGG(ID_DE_EMPLEADO, ',') WITHIN GROUP (ORDER BY ID_DE_EMPLEADO) ID_DE_EMPLEADO  FROM PERSONAL WHERE COMPANIA = :COMPANIA AND NUMERO_DCTO = :NUMERO_DCTO AND ESTADO_ACTUAL NOT IN(3)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>

	</query>
