	<query id="updatePersonalesPutpersonalcune" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET NOMBRECOMPLETO=:NOMBRECOMPLETO, NUMERO_DCTO=:NUMERO_DCTO, ESTADO_ACTUAL=:ESTADO_ACTUAL, GENERACUNE=:GENERACUNE, CODIGOPOSTAL=:CODIGOPOSTAL, TIPO_VINCULACION_NIE041=:TIPO_VINCULACION_NIE041, SUBTIPO_NIE042=:SUBTIPO_NIE042, ALTORIESGOPENSION=:ALTORIESGOPENSION, TIPOCONTRATO_NIE061=:TIPOCONTRATO_NIE061, MEDIODEPAGO_NIE065=:MEDIODEPAGO_NIE065, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PERSONAL.COMPANIA= :KEY_COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

