	<query id="getPersonalesEvaluacionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT PERSONAL.NOMBRECOMPLETO NOMBREEMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.SUCURSAL, CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, ESCALAFON.CODIGO, ESCALAFON.NOMBRE FROM PERSONAL INNER JOIN CARGOS ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO INNER JOIN ESCALAFON ON PERSONAL.COMPANIA = ESCALAFON.COMPANIA AND PERSONAL.ESCALAFON = ESCALAFON.CODIGO WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.NUMERO_DCTO =:NUMERO_DCTO</sql>
