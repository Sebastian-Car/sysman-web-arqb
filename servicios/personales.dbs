	<query id="getPersonalesNumPersonalsiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PERSONAL.COMPANIA, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO NOMBRE, PERSONAL.NUMERO_DCTO, BANCOS_NOMINA.NOMBRE BANCO, PERSONAL.CUENTA, PERSONAL.MEDIO_PAGO_SIIF, CASE PERSONAL.MEDIO_PAGO_SIIF WHEN 'AC' THEN 'Abono en Cuenta' WHEN 'CH' THEN 'Cheque' WHEN 'GR' THEN 'Giro' WHEN 'TT' THEN 'Títulos' END NOMBRE_MEDIO_PAGO_SIIF, CASE PERSONAL.TIPOCUENTA WHEN 'A' THEN 'Ahorro' WHEN 'C' THEN 'Corriente' END TIPOCUENTA, PERSONAL.NIVELSIIF FROM PERSONAL INNER JOIN BANCOS_NOMINA ON PERSONAL.COMPANIA = BANCOS_NOMINA.COMPANIA AND PERSONAL.BANCO = BANCOS_NOMINA.BANCO WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.ID_DE_EMPLEADO NOT IN (0) AND ( PERSONAL.ESTADO_ACTUAL IN (1,2) OR ( PERSONAL.ESTADO_ACTUAL NOT IN (1) AND PERSONAL.FECHA_DE_RETIRO &gt;= TO_DATE('01/01/2014','DD/MM/YYYY') ) ) ORDER BY NOMBRE) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN BANCO IS NULL THEN ' ' ELSE UPPER(BANCO) END) LIKE UPPER(CONCAT(CONCAT('%',:BANCO), '%')) AND (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN NOMBRE_MEDIO_PAGO_SIIF IS NULL THEN ' ' ELSE UPPER(NOMBRE_MEDIO_PAGO_SIIF) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_MEDIO_PAGO_SIIF), '%')) AND (CASE WHEN TIPOCUENTA IS NULL THEN ' ' ELSE UPPER(TIPOCUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOCUENTA), '%')) AND (CASE WHEN NIVELSIIF IS NULL THEN ' ' ELSE UPPER(NIVELSIIF) END) LIKE UPPER(CONCAT(CONCAT('%',:NIVELSIIF), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBRE_MEDIO_PAGO_SIIF" sqlType="STRING"/>
		<param name="TIPOCUENTA" sqlType="STRING"/>
		<param name="NIVELSIIF" sqlType="STRING"/>

	</query>
