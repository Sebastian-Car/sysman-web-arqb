	<query id="updatePersonalesUpdateplanoempleados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET TELEFONOS=:TELEFONOS, DIRECCION=:DIRECCION, EMAIL_PERSONAL=:EMAIL_PERSONAL, NIVEL_EDUCATIVO_RNEC=:NIVEL_EDUCATIVO_RNEC, FILIACION_POLITICA_RNEC=:FILIACION_POLITICA_RNEC, TIPO_EMPLEADO_RNEC=:TIPO_EMPLEADO_RNEC, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE PERSONAL.COMPANIA= :KEY_COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TELEFONOS" sqlType="STRING"/>
		<param name="DIRECCION" sqlType="STRING"/>
		<param name="EMAIL_PERSONAL" sqlType="STRING"/>
		<param name="NIVEL_EDUCATIVO_RNEC" sqlType="STRING"/>
		<param name="FILIACION_POLITICA_RNEC" sqlType="STRING"/>
		<param name="TIPO_EMPLEADO_RNEC" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
