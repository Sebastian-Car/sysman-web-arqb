		<query id="getPersonalesPagEmpleadosactiosperacargoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  P.NUMERO_DCTO NUMERO_DCTO, P.NOMBRECOMPLETO NOMBRES, P.SUCURSAL, P.ID_DE_EMPLEADO CODIGO  FROM PERSONAL P WHERE P.COMPANIA = :COMPANIA AND P.ESTADO_ACTUAL = 1 AND P.ID_DE_EMPLEADO &lt;&gt; 0 ORDER BY TO_NUMBER(CODIGO)) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRES":"$NOMBRES","SUCURSAL":"$SUCURSAL","CODIGO":"$CODIGO(type:integer)"}]}}		</result>
