	<query id="getPersonalesPagListacentrodecostoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERSONAL.ID_CENTRO_DE_COSTO, CENTRO_COSTO.NOMBRE  FROM PERSONAL LEFT JOIN CENTRO_COSTO ON PERSONAL.COMPANIA = CENTRO_COSTO.COMPANIA AND PERSONAL.ID_CENTRO_DE_COSTO = CENTRO_COSTO.CODIGO WHERE CENTRO_COSTO.MOVIMIENTO &lt;&gt; 0 AND PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.ESTADO_ACTUAL IN (1) OR PERSONAL.ESTADO_ACTUAL IN (2) GROUP BY PERSONAL.ID_CENTRO_DE_COSTO, CENTRO_COSTO.NOMBRE, CENTRO_COSTO.COMPANIA ORDER BY CENTRO_COSTO.NOMBRE , ID_CENTRO_DE_COSTO) WHERE (CASE WHEN ID_CENTRO_DE_COSTO IS NULL THEN ' ' ELSE UPPER(ID_CENTRO_DE_COSTO) END)  LIKE UPPER(:ID_CENTRO_DE_COSTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_CENTRO_DE_COSTO":"$ID_CENTRO_DE_COSTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_CENTRO_DE_COSTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
