			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRERESPONSABLE" query-param="NOMBRERESPONSABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumEmpleadoincsucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PERSONAL.NUMERO_DCTO, PERSONAL.SUCURSAL, PERSONAL.ID_DE_EMPLEADO, (CONCAT(NOMBRES,CONCAT(' ',CONCAT(APELLIDO1, CONCAT(' ', APELLIDO2 ))))) NOMBRERESPONSABLE FROM PERSONAL WHERE COMPANIA =:COMPANIA ORDER BY NOMBRERESPONSABLE) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_EMPLEADO), '%')) AND (CASE WHEN NOMBRERESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRERESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRERESPONSABLE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRERESPONSABLE" sqlType="STRING"/>

	</query>
