	</resource>
	<query id="getPersonalesTodosporcalculonominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PERSONAL.COMPANIA,ID_DE_EMPLEADO,APELLIDO1,APELLIDO2,NOMBRES,SEXO,NUMERO_DCTO,SUCURSAL,DEPARTAMENTO_CED,EXPEDIDA,ESTADO_CIVIL,ID_CENTRO_DE_COSTO,ID_DE_CARGO,ID_DEL_FONDO,ESCALAFON,ID_DE_CATEGORIA, PERSONAL.ANO, ID_DE_TIPO,OBSERVACIONES,CALZADO,CAMISA,PANTALON,CHAQUETA,FOTO,FONDO_SALUD,FONDO_CESANTIAS,FONDO_RIESGOS,NUMEROPATRONAL,ESTADO_ACTUAL,BANCO,CUENTA,(CASE SINDICATO WHEN 0 THEN 'false' ELSE 'true' END) SINDICATO,ANOS_CARGO,DEPENDENCIA,PRIMA_TECNICA,PROCESORETENCION,PERSONASCARGO,CUPOSALUD,CUPOSEDUCACION,(CASE EMBARGADO WHEN 0 THEN 'false' ELSE 'true' END) EMBARGADO,REGIMEN,TIPOCUENTA,ACTOQUINQUENIO,DIASINTERRUPCION,NORESOLUCIONCARGO,CERTIFICADOJUDICIAL,LICENCIACONDUCCION,RH,GRUPOSANGINEO,ENFERMEDCONGENITA,MEDICOTRATANTE,ALERGIAS,MEDICINA_PREPAGADA,CAJA_COMPENSACION,GRUPOCONTABLE,SEDE,VALORXCANCELAR,MESADA_PENSIONAL,RIESGO_PENSION,SUSTITUTODE,VR_PENSION_AFP,VR_PENSION_EMPRESA,FONDO_PENSION_VOL,DEPARTAMENTO_NAC,PAIS_NAC,PAIS_CED,CIUDAD_NAC,FONDO_SINDICATO,PORC_SINDICATO,DCTO_IDENTIDAD,CAUSA_RETIRO,DIRECCION,TELEFONOS,CODIGO_ESTABLECIMIENTO,CIUDAD_CUENTA,DE_CARRERA,PAIS_HAB,DEPARTAMENTO_HAB,CIUDAD_HAB,ESTRATO,(CASE PROPIETARIO WHEN 0 THEN 'false' ELSE 'true' END) PROPIETARIO,LIBRETA_MILITAR,SALARIO_BASE_IBC,CUPOSALUD_ANTERIOR,CLASE_PENSIONADO,TIPO_SALARIO,PORCRETEFUENTE,HCONCEPTO,CUENTA_VIVIENDA,FONDO_AFC,CUENTA_VIVIENDA2,EGRESADO,(CASE SITUADO_S WHEN 0 THEN 'false' ELSE 'true' END) SITUADO_S,(CASE SITUADO_P WHEN 0 THEN 'false' ELSE 'true' END) SITUADO_P,(CASE SITUADO_R WHEN 0 THEN 'false' ELSE 'true' END) SITUADO_R,(CASE SITUADO_ISS WHEN 0 THEN 'false' ELSE 'true' END) SITUADO_ISS,GRUPOSALUD,GRUPOPENSION,GRUPORIESGOS,GRUPOINTEGRADO,CEDULA_TUTOR,APELLIDOS_TUTOR,NOMBRES_TUTOR,NUMERO_SENTENCIA,TIPOVINCULACION,AREAMISOADM,TIPOACTIVIDAD,SUBTIPOCOTIZANTE,(CASE EXTRANJERO_OBLIGADO WHEN 0 THEN 'false' ELSE 'true' END) EXTRANJERO_OBLIGADO,(CASE COLOMBIANO_RESIDENTE WHEN 0 THEN 'false' ELSE 'true' END) COLOMBIANO_RESIDENTE,APELLIDO1CAUSANTE,APELLIDO2CAUSANTE,NOMBRE1CAUSANTE,NOMBRE2CAUSANTE,DCTO_IDENTIDADCAUSANTE,TIPOPENSIONADO,(CASE PENSIONCOMPARTIDA WHEN 0 THEN 'false' ELSE 'true' END) PENSIONCOMPARTIDA,NUMERO_DCTOCAUSANTE,(CASE INDNOPATRONOSALUD WHEN 0 THEN 'false' ELSE 'true' END) INDNOPATRONOSALUD,(CASE INDNOPATRONOPENSION WHEN 0 THEN 'false' ELSE 'true' END) INDNOPATRONOPENSION,VALOR_CONTRATO,OTROSESTUDIOS,BARRIO,REDONDEAR,(CASE RETE_1470 WHEN 0 THEN 'false' ELSE 'true' END) RETE_1470,NUM_RESOLUCION_ING,EMAIL_PERSONAL,EMAIL_CORPORATIVO,TARJETA_PROFESIONAL,CURSOS,TIPOBACHILLERATO,HISTORIALABORAL,PRORROGAS,MESESPRORROGAS,SECTOR_SIA,(CASE DEPENDIENTES384 WHEN 0 THEN 'false' ELSE 'true' END) DEPENDIENTES384,(CASE DECLARANTES384 WHEN 0 THEN 'false' ELSE 'true' END) DECLARANTES384,ACTA_POSESION,(CASE IND_CORRECCION WHEN 0 THEN 'false' ELSE 'true' END) IND_CORRECCION,(CASE EXONERADO_APORTES WHEN 0 THEN 'false' ELSE 'true' END) EXONERADO_APORTES,(CASE RETE_MINIMA WHEN 0 THEN 'false' ELSE 'true' END) RETE_MINIMA,(CASE TIENE_SUBSIDIO WHEN 0 THEN 'false' ELSE 'true' END) TIENE_SUBSIDIO,(CASE MANEJA_POLIZA WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_POLIZA,N_POLIZA,ASEGURADORA,VLR_ASEG,TOTAL_DIAS_COMISION,COD_AUXILIAR,(CASE APLICA_0862 WHEN 0 THEN 'false' ELSE 'true' END) APLICA_0862,P_TIPO_DOC_AGR,P_TIPO_VINCULACION_AGR,P_TIPO_DOMINIO_AGR,SUI_TIPO_NOM,SUI_NIVEL,SUI_NOMBRAMIENTO,MEDIO_PAGO_SIIF,LICENCIAS_INTERECES,LICENCIAS_CESANTIAS,PAIS_LABORA,DEPARTAMENTO_LABORA,CIUDAD_LABORA,NIVELSIIF,SUI_COSTOGASTO,(CASE ASALARIADO_NOEMPLEADOS WHEN 0 THEN 'false' ELSE 'true' END) ASALARIADO_NOEMPLEADOS,NUMERO_RESOLUCION,TIPORET,CORREO_ENVIADO,RADICADO_RENUNCIA,CAUSA_RENUNCIA,TOPE_VEH_MENSUAL,TOPEVEHICULO,TIPO_CONTRATO,NUMERO_CONTRATO,(TO_CHAR(FECHA_VENCE,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCE,(TO_CHAR(FECHA_INICIO_COMISION,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_COMISION,(TO_CHAR(FECHA_FINAL_COMISION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_COMISION,(TO_CHAR(FECHA_INI_CESA,'DD/MM/YYYY HH24:MI:SS')) FECHA_INI_CESA,(TO_CHAR(FECHA_INI_INTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_INI_INTE,(TO_CHAR(FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION,(TO_CHAR(FECHA_RADICADO_RET,'DD/MM/YYYY HH24:MI:SS')) FECHA_RADICADO_RET,(TO_CHAR(FECHA_FINAL_CT,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_CT,(TO_CHAR(FECHA_INICIO_CT,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_CT,(TO_CHAR(FECHANCTO,'DD/MM/YYYY HH24:MI:SS')) FECHANCTO,(TO_CHAR(FECHA_DE_INGRESO,'DD/MM/YYYY HH24:MI:SS')) FECHA_DE_INGRESO,(TO_CHAR(INGRESO_DISTRITO,'DD/MM/YYYY HH24:MI:SS')) INGRESO_DISTRITO,(TO_CHAR(FECHA_ULTSUELDO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ULTSUELDO,(TO_CHAR(FECHA_DE_RETIRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_DE_RETIRO,(TO_CHAR(FECHA_INICIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(INICIO_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) INICIO_DISFRUTE,(TO_CHAR(FINAL_DISFRUTE,'DD/MM/YYYY HH24:MI:SS')) FINAL_DISFRUTE,(TO_CHAR(FECHACUPOSALUD,'DD/MM/YYYY HH24:MI:SS')) FECHACUPOSALUD,(TO_CHAR(FECHAFONDOSALUD,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOSALUD,(TO_CHAR(FECHAFONDOPENSION,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOPENSION,(TO_CHAR(FECHAFONDOCESANTIA,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOCESANTIA,(TO_CHAR(FECHAFONDORIESGOS,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDORIESGOS,(TO_CHAR(FECHAQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAQUINQUENIO,(TO_CHAR(FECHADELACTOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHADELACTOQUINQUENIO,(TO_CHAR(FECHATERCONTRATO,'DD/MM/YYYY HH24:MI:SS')) FECHATERCONTRATO,(TO_CHAR(INGRESODISTRITOREAL,'DD/MM/YYYY HH24:MI:SS')) INGRESODISTRITOREAL,(TO_CHAR(FECHARESOLUCIONCARGO,'DD/MM/YYYY HH24:MI:SS')) FECHARESOLUCIONCARGO,(TO_CHAR(FECHAMEDICINA,'DD/MM/YYYY HH24:MI:SS')) FECHAMEDICINA,(TO_CHAR(FECHACAJACOMPENSACION,'DD/MM/YYYY HH24:MI:SS')) FECHACAJACOMPENSACION,(TO_CHAR(FECHA_CAMBIO_MESADA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CAMBIO_MESADA,(TO_CHAR(F_INI_PENSION_AFP,'DD/MM/YYYY HH24:MI:SS')) F_INI_PENSION_AFP,(TO_CHAR(FECHAFONDOPENSIONVOL,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOPENSIONVOL,(TO_CHAR(FECHAPAGOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOQUINQUENIO,(TO_CHAR(FECHAANTIGQUINQUENIO,'DD/MM/YYYY HH24:MI:SS')) FECHAANTIGQUINQUENIO,(TO_CHAR(FECHA_AFC,'DD/MM/YYYY HH24:MI:SS')) FECHA_AFC,(TO_CHAR(FECHA_CUMPLIMIENTO_BONIFICACIO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CUMPLIMIENTO_BONIFICACIO,(TO_CHAR(FECHAINIPROGVAC,'DD/MM/YYYY HH24:MI:SS')) FECHAINIPROGVAC,(TO_CHAR(FECHAFINPROGVAC,'DD/MM/YYYY HH24:MI:SS')) FECHAFINPROGVAC,(TO_CHAR(FECHA_SUPERVIVIENCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_SUPERVIVIENCIA,(TO_CHAR(FECHA_VEN_SUPERVIVIENCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_VEN_SUPERVIVIENCIA,(TO_CHAR(FECHA_1470,'DD/MM/YYYY HH24:MI:SS')) FECHA_1470,(TO_CHAR(FECHA_RESOLUCION_ING,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION_ING,(TO_CHAR(FECHA_VEN_CONSTANCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_VEN_CONSTANCIA,(TO_CHAR(FECHA_CONSTANCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONSTANCIA,(TO_CHAR(FECHATARJETAPROF,'DD/MM/YYYY HH24:MI:SS')) FECHATARJETAPROF,(TO_CHAR(FECHA_GRADO,'DD/MM/YYYY HH24:MI:SS')) FECHA_GRADO,(TO_CHAR(FECHA_ANTICIPO_CESANTIAS,'DD/MM/YYYY HH24:MI:SS')) FECHA_ANTICIPO_CESANTIAS,(TO_CHAR(FECHATERCONTRATOANT,'DD/MM/YYYY HH24:MI:SS')) FECHATERCONTRATOANT,(TO_CHAR(FECHA_DEPENDIENTES384,'DD/MM/YYYY HH24:MI:SS')) FECHA_DEPENDIENTES384,(TO_CHAR(FECHA_DECLARANTES384,'DD/MM/YYYY HH24:MI:SS')) FECHA_DECLARANTES384,(TO_CHAR(FECHA_ACTA_POSESION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTA_POSESION,(TO_CHAR(FECHA_RETE_MINIMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_RETE_MINIMA,(TO_CHAR(FECHA_EXPEDICION_CEDULA,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION_CEDULA,NOMBRECOMPLETO,(TO_CHAR(PERIODOS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(PERIODOS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL,(CASE PERIODOS.ESTADO WHEN 0 THEN 'false' ELSE 'true' END) ESTADO,(CASE PERIODOS.ACUMULADO WHEN 0 THEN 'false' ELSE 'true' END) ACUMULADO,PERIODOS.DIAS,(CASE PERIODOS.DIFERIDOS WHEN 0 THEN 'false' ELSE 'true' END) DIFERIDOS FROM PERSONAL,PERIODOS WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO BETWEEN :EMPLEADOINI AND :EMPLEADOFIN AND PERSONAL.DEPENDENCIA BETWEEN :DEPENDENCIAINI AND :DEPENDENCIAFIN AND PERSONAL.ID_DE_TIPO BETWEEN :TIPOINI AND :TIPOFIN AND PERSONAL.ID_CENTRO_DE_COSTO BETWEEN :CENTROINI AND :CENTROFIN AND PERIODOS.COMPANIA=:COMPANIA AND PERIODOS.ID_DE_PROCESO=:PROCESO AND PERIODOS.ANO=:ANO AND PERIODOS.MES=:MES AND PERIODOS.PERIODO=:PERIODO AND ( PERSONAL.FECHA_DE_INGRESO &lt;= PERIODOS.FECHAFINAL AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 OR PERSONAL.FECHA_DE_RETIRO &gt;=PERIODOS.FECHAFINAL AND PERSONAL.FECHA_DE_INGRESO &lt;=PERIODOS.FECHAINICIO AND PERSONAL.ESTADO_ACTUAL = 3 ) ORDER BY ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRES":"$NOMBRES","SEXO":"$SEXO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","DEPARTAMENTO_CED":"$DEPARTAMENTO_CED","EXPEDIDA":"$EXPEDIDA","ESTADO_CIVIL":"$ESTADO_CIVIL","ID_CENTRO_DE_COSTO":"$ID_CENTRO_DE_COSTO","ID_DE_CARGO":"$ID_DE_CARGO","ID_DEL_FONDO":"$ID_DEL_FONDO","ESCALAFON":"$ESCALAFON","ID_DE_CATEGORIA":"$ID_DE_CATEGORIA","ANO":"$ANO(type:integer)","ID_DE_TIPO":"$ID_DE_TIPO","OBSERVACIONES":"$OBSERVACIONES","CALZADO":"$CALZADO","CAMISA":"$CAMISA","PANTALON":"$PANTALON","CHAQUETA":"$CHAQUETA","FOTO":"$FOTO","FONDO_SALUD":"$FONDO_SALUD","FONDO_CESANTIAS":"$FONDO_CESANTIAS","FONDO_RIESGOS":"$FONDO_RIESGOS","NUMEROPATRONAL":"$NUMEROPATRONAL","ESTADO_ACTUAL":"$ESTADO_ACTUAL","BANCO":"$BANCO","CUENTA":"$CUENTA","SINDICATO":"$SINDICATO(type:boolean)","ANOS_CARGO":"$ANOS_CARGO(type:integer)","DEPENDENCIA":"$DEPENDENCIA","PRIMA_TECNICA":"$PRIMA_TECNICA","PROCESORETENCION":"$PROCESORETENCION(type:integer)","PERSONASCARGO":"$PERSONASCARGO","CUPOSALUD":"$CUPOSALUD","CUPOSEDUCACION":"$CUPOSEDUCACION","EMBARGADO":"$EMBARGADO(type:boolean)","REGIMEN":"$REGIMEN(type:integer)","TIPOCUENTA":"$TIPOCUENTA","ACTOQUINQUENIO":"$ACTOQUINQUENIO","DIASINTERRUPCION":"$DIASINTERRUPCION","NORESOLUCIONCARGO":"$NORESOLUCIONCARGO","CERTIFICADOJUDICIAL":"$CERTIFICADOJUDICIAL","LICENCIACONDUCCION":"$LICENCIACONDUCCION","RH":"$RH","GRUPOSANGINEO":"$GRUPOSANGINEO","ENFERMEDCONGENITA":"$ENFERMEDCONGENITA","MEDICOTRATANTE":"$MEDICOTRATANTE","ALERGIAS":"$ALERGIAS","MEDICINA_PREPAGADA":"$MEDICINA_PREPAGADA","CAJA_COMPENSACION":"$CAJA_COMPENSACION","GRUPOCONTABLE":"$GRUPOCONTABLE","SEDE":"$SEDE","VALORXCANCELAR":"$VALORXCANCELAR","MESADA_PENSIONAL":"$MESADA_PENSIONAL","RIESGO_PENSION":"$RIESGO_PENSION","SUSTITUTODE":"$SUSTITUTODE","VR_PENSION_AFP":"$VR_PENSION_AFP","VR_PENSION_EMPRESA":"$VR_PENSION_EMPRESA","FONDO_PENSION_VOL":"$FONDO_PENSION_VOL","DEPARTAMENTO_NAC":"$DEPARTAMENTO_NAC","PAIS_NAC":"$PAIS_NAC","PAIS_CED":"$PAIS_CED","CIUDAD_NAC":"$CIUDAD_NAC","FONDO_SINDICATO":"$FONDO_SINDICATO","PORC_SINDICATO":"$PORC_SINDICATO","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","CAUSA_RETIRO":"$CAUSA_RETIRO","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS","CODIGO_ESTABLECIMIENTO":"$CODIGO_ESTABLECIMIENTO","CIUDAD_CUENTA":"$CIUDAD_CUENTA","DE_CARRERA":"$DE_CARRERA","PAIS_HAB":"$PAIS_HAB","DEPARTAMENTO_HAB":"$DEPARTAMENTO_HAB","CIUDAD_HAB":"$CIUDAD_HAB","ESTRATO":"$ESTRATO","PROPIETARIO":"$PROPIETARIO(type:boolean)","LIBRETA_MILITAR":"$LIBRETA_MILITAR","SALARIO_BASE_IBC":"$SALARIO_BASE_IBC","CUPOSALUD_ANTERIOR":"$CUPOSALUD_ANTERIOR","CLASE_PENSIONADO":"$CLASE_PENSIONADO","TIPO_SALARIO":"$TIPO_SALARIO","PORCRETEFUENTE":"$PORCRETEFUENTE","HCONCEPTO":"$HCONCEPTO","CUENTA_VIVIENDA":"$CUENTA_VIVIENDA","FONDO_AFC":"$FONDO_AFC","CUENTA_VIVIENDA2":"$CUENTA_VIVIENDA2","EGRESADO":"$EGRESADO","SITUADO_S":"$SITUADO_S(type:boolean)","SITUADO_P":"$SITUADO_P(type:boolean)","SITUADO_R":"$SITUADO_R(type:boolean)","SITUADO_ISS":"$SITUADO_ISS(type:boolean)","GRUPOSALUD":"$GRUPOSALUD","GRUPOPENSION":"$GRUPOPENSION","GRUPORIESGOS":"$GRUPORIESGOS","GRUPOINTEGRADO":"$GRUPOINTEGRADO","CEDULA_TUTOR":"$CEDULA_TUTOR","APELLIDOS_TUTOR":"$APELLIDOS_TUTOR","NOMBRES_TUTOR":"$NOMBRES_TUTOR","NUMERO_SENTENCIA":"$NUMERO_SENTENCIA","TIPOVINCULACION":"$TIPOVINCULACION(type:integer)","AREAMISOADM":"$AREAMISOADM","TIPOACTIVIDAD":"$TIPOACTIVIDAD","SUBTIPOCOTIZANTE":"$SUBTIPOCOTIZANTE(type:integer)","EXTRANJERO_OBLIGADO":"$EXTRANJERO_OBLIGADO(type:boolean)","COLOMBIANO_RESIDENTE":"$COLOMBIANO_RESIDENTE(type:boolean)","APELLIDO1CAUSANTE":"$APELLIDO1CAUSANTE","APELLIDO2CAUSANTE":"$APELLIDO2CAUSANTE","NOMBRE1CAUSANTE":"$NOMBRE1CAUSANTE","NOMBRE2CAUSANTE":"$NOMBRE2CAUSANTE","DCTO_IDENTIDADCAUSANTE":"$DCTO_IDENTIDADCAUSANTE","TIPOPENSIONADO":"$TIPOPENSIONADO(type:integer)","PENSIONCOMPARTIDA":"$PENSIONCOMPARTIDA(type:boolean)","NUM