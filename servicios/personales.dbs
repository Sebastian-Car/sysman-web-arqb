	<query id="getPersonalesPagEmpleadoincsucursalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PERSONAL.NUMERO_DCTO, PERSONAL.SUCURSAL, PERSONAL.ID_DE_EMPLEADO, (CONCAT(NOMBRES,CONCAT(' ',CONCAT(APELLIDO1, CONCAT(' ', APELLIDO2 ))))) NOMBRERESPONSABLE FROM PERSONAL WHERE COMPANIA =:COMPANIA ORDER BY NOMBRERESPONSABLE) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_EMPLEADO), '%')) AND (CASE WHEN NOMBRERESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMBRERESPONSABLE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRERESPONSABLE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRERESPONSABLE":"$NOMBRERESPONSABLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRERESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/empleadoincsucursal/pag">
