<data name="personales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPersonalesExisteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) PERSONAL  FROM PERSONAL WHERE COMPANIA = :COMPANIA AND TIPO_CONTRATO = :CLASEORDEN AND NUMERO_CONTRATO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PERSONAL":"$PERSONAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/existe">
		<call-query href="getPersonalesExisteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getPersonalesCantidadpersonalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) CANTIDAD  FROM PERSONAL WHERE COMPANIA = :COMPANIA AND TIPO_CONTRATO = :CLASEORDEN AND NUMERO_CONTRATO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/cantidadpersonal">
		<call-query href="getPersonalesCantidadpersonalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="updatePersonalesActualizarFondoriesgos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET FONDO_RIESGOS   = :FONDO_RIESGOS,   FECHAFONDORIESGOS = :FECHAFONDORIESGOS, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')  WHERE COMPANIA      = :COMPANIA AND ESTADO_ACTUAL = 1</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FONDO_RIESGOS" sqlType="STRING"/>
		<param name="FECHAFONDORIESGOS" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="personales/actualizarfondoriesgos">
		<call-query href="updatePersonalesActualizarFondoriesgos">
			<with-param name="FONDO_RIESGOS" query-param="FONDO_RIESGOS"/>
			<with-param name="FECHAFONDORIESGOS" query-param="FECHAFONDORIESGOS"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagIdNombrePorEstado3IniQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO &lt;&gt; '00000' AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 ORDER BY PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/idnombreporestado3ini/pag">
		<call-query href="getPersonalesPagIdNombrePorEstado3IniQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumIdNombrePorEstado3IniQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO &lt;&gt; '00000' AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 ORDER BY PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/idnombreporestado3ini/num">
		<call-query href="getPersonalesNumIdNombrePorEstado3IniQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagIdNombrePorEstado3FinQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO &lt;&gt; '00000' AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 AND PERSONAL.ID_DE_EMPLEADO &gt;= :EMPLEADO ORDER BY PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/idnombreporestado3fin/pag">
		<call-query href="getPersonalesPagIdNombrePorEstado3FinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPLEADO" query-param="EMPLEADO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumIdNombrePorEstado3FinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO &lt;&gt; '00000' AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 AND PERSONAL.ID_DE_EMPLEADO &gt;= :EMPLEADO ORDER BY PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/idnombreporestado3fin/num">
		<call-query href="getPersonalesNumIdNombrePorEstado3FinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="EMPLEADO" query-param="EMPLEADO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagTodosPorIdEmpleadoNombrecompletoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO FROM PERSONAL WHERE PERSONAL.ID_DE_EMPLEADO&lt;&gt;0 AND PERSONAL.COMPANIA =:COMPANIA AND ESTADO_ACTUAL IN (1,2) ORDER BY PERSONAL.ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/todosporidempleadonombrecompleto/pag">
		<call-query href="getPersonalesPagTodosPorIdEmpleadoNombrecompletoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumTodosPorIdEmpleadoNombrecompletoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO FROM PERSONAL WHERE PERSONAL.ID_DE_EMPLEADO&lt;&gt;0 AND PERSONAL.COMPANIA =:COMPANIA AND ESTADO_ACTUAL IN (1,2) ORDER BY PERSONAL.ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/todosporidempleadonombrecompleto/num">
		<call-query href="getPersonalesNumTodosPorIdEmpleadoNombrecompletoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>

		</call-query>
	</resource>
	<query id="insertPersonales" keyColumns="COMPANIA,ID_DE_EMPLEADO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PERSONAL (ID_DE_EMPLEADO, APELLIDO1, APELLIDO2, NOMBRES, SEXO, NUMERO_DCTO, SUCURSAL, DEPARTAMENTO_CED, EXPEDIDA, ESTADO_CIVIL, FECHANCTO, FECHA_DE_INGRESO, INGRESO_DISTRITO, ID_CENTRO_DE_COSTO, ID_DE_CARGO, FECHA_ULTSUELDO, ID_DEL_FONDO, ESCALAFON, ID_DE_CATEGORIA, ANO, FECHA_DE_RETIRO, ID_DE_TIPO, OBSERVACIONES, CALZADO, CAMISA, PANTALON, CHAQUETA, FOTO, FONDO_SALUD, FONDO_CESANTIAS, FONDO_RIESGOS, FECHA_INICIO, FECHA_FINAL, INICIO_DISFRUTE, FINAL_DISFRUTE, NUMEROPATRONAL, ESTADO_ACTUAL, BANCO, CUENTA, SINDICATO, ANOS_CARGO, DEPENDENCIA, PRIMA_TECNICA, PROCESORETENCION, PERSONASCARGO, CUPOSALUD, FECHACUPOSALUD, CUPOSEDUCACION, EMBARGADO, REGIMEN, FECHAFONDOSALUD, FECHAFONDOPENSION, FECHAFONDOCESANTIA, FECHAFONDORIESGOS, TIPOCUENTA, FECHAQUINQUENIO, ACTOQUINQUENIO, FECHADELACTOQUINQUENIO, FECHATERCONTRATO, INGRESODISTRITOREAL, DIASINTERRUPCION, NORESOLUCIONCARGO, FECHARESOLUCIONCARGO, CERTIFICADOJUDICIAL, LICENCIACONDUCCION, RH, GRUPOSANGINEO, ENFERMEDCONGENITA, MEDICOTRATANTE, ALERGIAS, MEDICINA_PREPAGADA, CAJA_COMPENSACION, FECHAMEDICINA, FECHACAJACOMPENSACION, GRUPOCONTABLE, SEDE, VALORXCANCELAR, MESADA_PENSIONAL, FECHA_CAMBIO_MESADA, RIESGO_PENSION, SUSTITUTODE, F_INI_PENSION_AFP, VR_PENSION_AFP, VR_PENSION_EMPRESA, FONDO_PENSION_VOL, FECHAFONDOPENSIONVOL, FECHAPAGOQUINQUENIO, FECHAANTIGQUINQUENIO, DEPARTAMENTO_NAC, PAIS_NAC, PAIS_CED, CIUDAD_NAC, FONDO_SINDICATO, PORC_SINDICATO, DCTO_IDENTIDAD, CAUSA_RETIRO, DIRECCION, TELEFONOS, CODIGO_ESTABLECIMIENTO, CIUDAD_CUENTA, DE_CARRERA, PAIS_HAB, DEPARTAMENTO_HAB, CIUDAD_HAB, ESTRATO, PROPIETARIO, LIBRETA_MILITAR, SALARIO_BASE_IBC, CUPOSALUD_ANTERIOR, CLASE_PENSIONADO, TIPO_PENSIONADO, TIPO_SALARIO, PORCRETEFUENTE, HCONCEPTO, CUENTA_VIVIENDA, FONDO_AFC, FECHA_AFC, CUENTA_VIVIENDA2, FECHA_CUMPLIMIENTO_BONIFICACIO, EGRESADO, SITUADO_S, SITUADO_P, SITUADO_R, SITUADO_ISS, GRUPOSALUD, GRUPOPENSION, GRUPORIESGOS, GRUPOINTEGRADO, CEDULA_TUTOR, APELLIDOS_TUTOR, NOMBRES_TUTOR, NUMERO_SENTENCIA, TIPOVINCULAC