	<query id="getPersonalesNumPersonalidempleadodctoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PERSONAL.ID_DE_EMPLEADO, PERSONAL.DCTO_IDENTIDAD, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO NOMBRE, PERSONAL.SUCURSAL  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN DCTO_IDENTIDAD IS NULL THEN ' ' ELSE UPPER(DCTO_IDENTIDAD) END)  LIKE UPPER( '%' || :DCTO_IDENTIDAD || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ))</sql>
