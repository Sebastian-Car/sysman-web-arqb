		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PERSONAL.ID_DE_EMPLEADO, NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1 ,CONCAT( ' ' ,CONCAT(NAT_DATOS_PERSONALES.APELLIDO2 ,CONCAT(' ' , NAT_DATOS_PERSONALES.NOMBRES)))) NOMBRECOMPLETO, NAT_DATOS_PERSONALES.SUCURSAL FROM PERSONAL INNER JOIN NAT_DATOS_PERSONALES ON PERSONAL.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND PERSONAL.NUMERO_DCTO = NAT_DATOS_PERSONALES.NUMERO_DCTO AND PERSONAL.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.ESTADO_ACTUAL NOT IN (3) AND PERSONAL.SUCURSAL NOT IN (999)) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
