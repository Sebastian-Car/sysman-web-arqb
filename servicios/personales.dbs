	<query id="updatePersonalesQuinquenioPorEmpleado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET FECHAQUINQUENIO=TO_DATE(:FECHAQUINQUENIO,'DD/MM/YYYY HH24:MI:SS'), ACTOQUINQUENIO=:ACTOQUINQUENIO, FECHADELACTOQUINQUENIO=TO_DATE(:FECHADELACTOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS'), FECHAPAGOQUINQUENIO=TO_DATE(:FECHAPAGOQUINQUENIO,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PERSONAL.COMPANIA= :KEY_COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAQUINQUENIO" sqlType="STRING"/>
		<param name="ACTOQUINQUENIO" sqlType="STRING"/>
		<param name="FECHADELACTOQUINQUENIO" sqlType="STRING"/>
		<param name="FECHAPAGOQUINQUENIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
