	<query id="getPersonalesNumSubgrillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  P.COMPANIA, P.ID_DE_EMPLEADO, P.NOMBRECOMPLETO, CASE WHEN P.FECHA_FINAL IS NULL THEN TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365),'DD/MM/YYYY') ELSE TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1),'DD/MM/YYYY') END FECHA_INICIO_PROGRAMAR, CASE WHEN P.FECHA_FINAL IS NULL THEN TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365) + TRUNC((SYSDATE - TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')))/365) * 365,'DD/MM/YYYY') ELSE TO_CHAR(PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1) + TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1))/365) * 365,'DD/MM/YYYY') END FECHA_FINAL_PROGRAMAR, CASE WHEN P.FECHA_FINAL IS NULL THEN TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365))/365) ELSE TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1))/365) END ANIOS_ACUMULADOS, SUM (CASE WHEN H.ID_DE_CONCEPTO IN (356,357,359) THEN H.VALOR ELSE 0 END) LICENCIAS  FROM HISTORICOS H INNER JOIN PERSONAL P ON H.COMPANIA = P.COMPANIA AND H.ID_DE_EMPLEADO = P.ID_DE_EMPLEADO WHERE P.COMPANIA = :COMPANIA AND (SYSDATE - TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY'))) &gt;= 365 AND P.ID_DE_EMPLEADO NOT IN 0 AND P.ESTADO_ACTUAL IN (1) AND ( CASE WHEN P.FECHA_FINAL IS NULL THEN TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_DE_INGRESO,'DD/MM/YYYY')),365))/365) ELSE TRUNC((SYSDATE - PCK_SYSMAN_UTL.FC_SUMARDIAS_FECHA(TO_DATE(TO_CHAR(P.FECHA_FINAL,'DD/MM/YYYY')),1))/365) END ) &gt; 0 GROUP BY P.COMPANIA, P.ID_DE_EMPLEADO, P.NOMBRECOMPLETO, P.FECHA_DE_INGRESO, P.FECHA_FINAL ORDER BY ANIOS_ACUMULADOS DESC) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER( '%' || :ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN FECHA_INICIO_PROGRAMAR IS NULL THEN ' ' ELSE UPPER(FECHA_INICIO_PROGRAMAR) END)  LIKE UPPER( '%' || :FECHA_INICIO_PROGRAMAR || '%')  AND (CASE WHEN FECHA_FINAL_PROGRAMAR IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL_PROGRAMAR) END)  LIKE UPPER( '%' || :FECHA_FINAL_PROGRAMAR || '%')  AND (CASE WHEN ANIOS_ACUMULADOS IS NULL THEN ' ' ELSE UPPER(ANIOS_ACUMULADOS) END)  LIKE UPPER( '%' || :ANIOS_ACUMULADOS || '%')  AND (CASE WHEN LICENCIAS IS NULL THEN ' ' ELSE UPPER(LICENCIAS) END)  LIKE UPPER( '%' || :LICENCIAS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="FECHA_INICIO_PROGRAMAR" sqlType="STRING"/>
		<param name="FECHA_FINAL_PROGRAMAR" sqlType="STRING"/>
		<param name="ANIOS_ACUMULADOS" sqlType="STRING"/>
		<param name="LICENCIAS" sqlType="STRING"/>

	</query>
