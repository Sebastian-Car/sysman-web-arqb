	<query id="getPersonalesPagEmpleadoporcompaniayestadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PER.ID_DE_EMPLEADO, PER.NOMBRECOMPLETO NOMBREEMPLEADO, PER.NUMERO_DCTO, PER.SUCURSAL, PER.COMPANIA, PER.ID_DE_CARGO, CARG.NOMBRE_DEL_CARGO NOMBRECARGO, PER.ESCALAFON, ESCA.NOMBRE NOMBREESCALAFON  FROM PERSONAL PER INNER JOIN ESCALAFON ESCA ON PER.COMPANIA = ESCA.COMPANIA AND PER.ESCALAFON = ESCA.CODIGO INNER JOIN CARGOS CARG ON PER.COMPANIA = CARG.COMPANIA AND PER.ID_DE_CARGO = CARG.ID_DE_CARGO WHERE PER.COMPANIA = :COMPANIA AND PER.ESTADO_ACTUAL NOT IN (3)) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBREEMPLEADO IS NULL THEN ' ' ELSE UPPER(NOMBREEMPLEADO) END)  LIKE UPPER( '%' || :NOMBREEMPLEADO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBREEMPLEADO":"$NOMBREEMPLEADO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","COMPANIA":"$COMPANIA","ID_DE_CARGO":"$ID_DE_CARGO","NOMBRECARGO":"$NOMBRECARGO","ESCALAFON":"$ESCALAFON","NOMBREESCALAFON":"$NOMBREESCALAFON"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBREEMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
