	<query id="getPersonalesPagListaempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES, PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO, TIPOS_DE_EMPLEADO.NOMBRE_TIPO, ESTADO_ACTUAL.NOMBRE  FROM PERSONAL INNER JOIN TIPOS_DE_EMPLEADO ON PERSONAL.COMPANIA = TIPOS_DE_EMPLEADO.COMPANIA AND TIPOS_DE_EMPLEADO.ID_DE_TIPO = PERSONAL.ID_DE_TIPO INNER JOIN ESTADO_ACTUAL ON ESTADO_ACTUAL.CODIGO = PERSONAL.ESTADO_ACTUAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO NOT IN (0) ORDER BY PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"APELLIDO1":"$APELLIDO1","APELLIDO2":"$APELLIDO2","NOMBRES":"$NOMBRES","NUMERO_DCTO":"$NUMERO_DCTO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","NOMBRE_TIPO":"$NOMBRE_TIPO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
