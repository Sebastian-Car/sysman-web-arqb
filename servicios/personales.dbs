	</resource>
	<query id="getPersonalesListadoPersonalMaestraQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT V_PERSONAL.NUMERO_DCTO CEDULA, CONCAT(V_PERSONAL.APELLIDO1 ,CONCAT( ' ' ,CONCAT( V_PERSONAL.APELLIDO2 , CONCAT(' ' , V_PERSONAL.NOMBRES)))) NOMBRE_EMPLEADO, TO_CHAR(V_PERSONAL.FECHA_DE_INGRESO,'DD/MM/YYYY') FECHA_DE_INGRESO, TO_CHAR(V_PERSONAL.FECHA_DE_RETIRO,'DD/MM/YYYY') FECHA_DE_RETIRO, V_PERSONAL.ID_CENTRO_DE_COSTO, V_PERSONAL.NOMBRE_CENTRO_DE_COSTO, V_PERSONAL.DEPENDENCIA, V_PERSONAL.NOMBRE_DEPENDENCIA, V_PERSONAL.ID_DE_CARGO, V_PERSONAL.NOMBRE_DE_CARGO, PATRONALES.FACTOR FACTOR_RIESGO, V_PERSONAL.BANCO ENTIDAD_BANCARIA, V_PERSONAL.NOMBRE_BANCO BANCO, BANCO.NIT NIT_BANCO, V_PERSONAL.CUENTA, V_PERSONAL.TIPOCUENTA, V_FONDO_DE_PENSIONES.NIT NIT_PENSION, V_PERSONAL.NOMBRE_FONDOPENSION NOMBRE_DEL_FONDO, V_FONDO_DE_SALUD.NIT NIT_SALUD, V_PERSONAL.NOMBRE_FONDOSALUD NOMBRE_FONDO_SALUD, V_FONDO_DE_RIESGOS.NIT NIT_RIESGOS, V_PERSONAL.NOMBRE_FONDORIESGOS NOMBRE_FONDO_RIESGOS, V_FONDO_DE_CESANTIAS.NIT NIT_CESANTIAS, V_PERSONAL.NOMBRE_FONDOCESANTIAS NOMBRE_FONDO_CESANTIAS, V_FONDO_DE_PENSION_AFC.NIT NIT_AFC, V_PERSONAL.NOMBRE_FONDOAFC NOMBRE_FONDO_AFC, V_FONDO_DE_PENSION_VOL.NIT NIT_VOL, V_PERSONAL.NOMBRE_FONDOPENSION_VOL NOMBRE_DEL_FONDO_VOL, V_FONDO_DE_SINDICATOS.NIT NIT_SINDICATO, V_PERSONAL.NOMBRE_FONDOSINDICATO NOMBRE_FONDO_SINDICATO, V_CAJA_COMPENSACION.NIT CAJA_COMPENSACION, V_PERSONAL.NOMBRE_CAJACOMPENSACION NOMBRE_CAJA, V_MEDICINA_PREPAGADA.NIT NIT_MEDICINA, V_PERSONAL.NOMBRE_MEDICINAPREPAGADA MEDICINA_PREPAGADA, V_PERSONAL.PROCESORETENCION, V_PERSONAL.SEXO, TO_CHAR(V_PERSONAL.FECHA_INICIO,'DD/MM/YYYY') FECHA_INICIO, TO_CHAR(V_PERSONAL.FECHA_FINAL,'DD/MM/YYYY') FECHA_FINAL, TO_CHAR(V_PERSONAL.INICIO_DISFRUTE,'DD/MM/YYYY') INICIO_DISFRUTE, TO_CHAR(V_PERSONAL.FINAL_DISFRUTE,'DD/MM/YYYY') FINAL_DISFRUTE, V_PERSONAL.REGIMEN, V_PERSONAL.RH, V_PERSONAL.GRUPOSANGINEO, V_PERSONAL.GRUPOCONTABLE, V_PERSONAL.NOMBRE_FORMANOMBRAMIENTO FORMA_NOMBRAMIENTO, V_PERSONAL.SALARIO_BASE_IBC, V_PERSONAL.CUENTA_VIVIENDA, V_PERSONAL.CUENTA_VIVIENDA2, TO_CHAR(V_PERSONAL.FECHA_CUMPLIMIENTO_BONIFICACIO,'DD/MM/YYYY') FECHA_CUMPLIMIENTO_BONIFICACIO, V_PERSONAL.TIPOVINCULACION, V_PERSONAL.AREAMISOADM, V_PERSONAL.EMAIL_PERSONAL, V_PERSONAL.EMAIL_CORPORATIVO, V_PERSONAL.ACTA_POSESION, TO_CHAR(V_PERSONAL.FECHA_ACTA_POSESION,'DD/MM/YYYY') FECHA_ACTA_POSESION, TO_CHAR(V_PERSONAL.FECHA_INICIO_COMISION,'DD/MM/YYYY') FECHA_INICIO_COMISION, TO_CHAR(V_PERSONAL.FECHA_FINAL_COMISION,'DD/MM/YYYY') FECHA_FINAL_COMISION, V_PERSONAL.TOTAL_DIAS_COMISION, TO_CHAR(V_PERSONAL.FECHA_EXPEDICION_CEDULA,'DD/MM/YYYY') FECHA_EXPEDICION_CEDULA, V_PERSONAL.NIVELSIIF, V_PERSONAL.DIRECCION, V_PERSONAL.TELEFONOS FROM V_PERSONAL INNER JOIN HISTORICOS ON HISTORICOS.COMPANIA = V_PERSONAL.COMPANIA AND HISTORICOS.ID_DE_EMPLEADO = V_PERSONAL.ID_DE_EMPLEADO INNER JOIN PATRONALES ON V_PERSONAL.COMPANIA = PATRONALES.COMPANIA AND V_PERSONAL.NUMEROPATRONAL = PATRONALES.SUCURSAL INNER JOIN BANCO ON V_PERSONAL.COMPANIA = BANCO.COMPANIA AND V_PERSONAL.BANCO = BANCO.BANCO INNER JOIN V_FONDO_DE_PENSIONES ON V_PERSONAL.COMPANIA = V_FONDO_DE_PENSIONES.COMPANIA AND V_PERSONAL.ID_DEL_FONDO = V_FONDO_DE_PENSIONES.ID_DEL_FONDO INNER JOIN V_FONDO_DE_SALUD ON V_PERSONAL.COMPANIA = V_FONDO_DE_SALUD.COMPANIA AND V_PERSONAL.FONDO_SALUD = V_FONDO_DE_SALUD.FONDO_SALUD INNER JOIN V_FONDO_DE_RIESGOS ON V_PERSONAL.COMPANIA = V_FONDO_DE_RIESGOS.COMPANIA AND V_PERSONAL.FONDO_RIESGOS = V_FONDO_DE_RIESGOS.FONDO_RIESGOS INNER JOIN V_FONDO_DE_CESANTIAS ON V_PERSONAL.COMPANIA = V_FONDO_DE_CESANTIAS.COMPANIA AND V_PERSONAL.FONDO_CESANTIAS = V_FONDO_DE_CESANTIAS.FONDO_CESANTIAS INNER JOIN V_FONDO_DE_PENSION_AFC ON V_PERSONAL.COMPANIA = V_FONDO_DE_PENSION_AFC.COMPANIA AND V_PERSONAL.FONDO_AFC = V_FONDO_DE_PENSION_AFC.FONDO_AFC INNER JOIN V_FONDO_DE_PENSION_VOL ON V_PERSONAL.COMPANIA = V_FONDO_DE_PENSION_VOL.COMPANIA AND V_PERSONAL.FONDO_PENSION_VOL = V_FONDO_DE_PENSION_VOL.ID_DEL_FONDO INNER JOIN V_FONDO_DE_SINDICATOS ON V_PERSONAL.COMPANIA = V_FONDO_DE_SINDICATOS.COMPANIA AND V_PERSONAL.FONDO_SINDICATO = V_FONDO_DE_SINDICATOS.FONDO_SINDICATO INNER JOIN V_CAJA_COMPENSACION ON V_PERSONAL.COMPANIA = V_CAJA_COMPENSACION.COMPANIA AND V_PERSONAL.CAJA_COMPENSACION = V_CAJA_COMPENSACION.CAJA_COMPENSACION INNER JOIN V_MEDICINA_PREPAGADA ON V_PERSONAL.COMPANIA = V_MEDICINA_PREPAGADA.COMPANIA AND V_PERSONAL.MEDICINA_PREPAGADA = V_MEDICINA_PREPAGADA.MEDICINA_PREPAGADA WHERE HISTORICOS.COMPANIA =:COMPANIA AND HISTORICOS.ID_DE_PROCESO =:ID_DE_PROCESO AND HISTORICOS.ANO =:ANO AND HISTORICOS.MES =:MES AND HISTORICOS.PERIODO =:PERIODO ORDER BY CONCAT(V_PERSONAL.APELLIDO1 ,CONCAT( ' ' ,CONCAT( V_PERSONAL.APELLIDO2 , CONCAT(' ' , V_PERSONAL.NOMBRES))))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CEDULA":"$CEDULA","NOMBRE_EMPLEADO":"$NOMBRE_EMPLEADO","FECHA_DE_INGRESO":"$FECHA_DE_INGRESO","FECHA_DE_RETIRO":"$FECHA_DE_RETIRO","ID_CENTRO_DE_COSTO":"$ID_CENTRO_DE_COSTO","NOMBRE_CENTRO_DE_COSTO":"$NOMBRE_CENTRO_DE_COSTO","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DE_CARGO":"$NOMBRE_DE_CARGO","FACTOR_RIESGO":"$FACTOR_RIESGO","ENTIDAD_BANCARIA":"$ENTIDAD_BANCARIA","BANCO":"$BANCO","NIT_BANCO":"$NIT_BANCO","CUENTA":"$CUENTA","TIPOCUENTA":"$TIPOCUENTA","NIT_PENSION":"$NIT_PENSION","NOMBRE_DEL_FONDO":"$NOMBRE_DEL_FONDO","NIT_SALUD":"$NIT_SALUD","NOMBRE_FONDO_SALUD":"$NOMBRE_FONDO_SALUD","NIT_RIESGOS":"$NIT_RIESGOS","NOMBRE_FONDO_RIESGOS":"$NOMBRE_FONDO_RIESGOS","NIT_CESANTIAS":"$NIT_CESANTIAS","NOMBRE_FONDO_CESANTIAS":"$NOMBRE_FONDO_CESANTIAS","NIT_AFC":"$NIT_AFC","NOMBRE_FONDO_AFC":"$NOMBRE_FONDO_AFC","NIT_VOL":"$NIT_VOL","NOMBRE_DEL_FONDO_VOL":"$NOMBRE_DEL_FONDO_VOL","NIT_SINDICATO":"$NIT_SINDICATO","NOMBRE_FONDO_SINDICATO":"$NOMBRE_FONDO_SINDICATO","CAJA_COMPENSACION":"$CAJA_COMPENSACION","NOMBRE_CAJA":"$NOMBRE_CAJA","NIT_MEDICINA":"$NIT_MEDICINA","MEDICINA_PREPAGADA":"$MEDICINA_PREPAGADA","PROCESORETENCION":"$PROCESORETENCION(type:integer)","SEXO":"$SEXO","FECHA_INICIO":"$FECHA_INICIO","FECHA_FINAL":"$FECHA_FINAL","INICIO_DISFRUTE":"$INICIO_DISFRUTE","FINAL_DISFRUTE":"$FINAL_DISFRUTE","REGIMEN":"$REGIMEN(type:integer)","RH":"$RH","GRUPOSANGINEO":"$GRUPOSANGINEO","GRUPOCONTABLE":"$GRUPOCONTABLE","FORMA_NOMBRAMIENTO":"$FORMA_NOMBRAMIENTO","SALARIO_BASE_IBC":"$SALARIO_BASE_IBC","CUENTA_VIVIENDA":"$CUENTA_VIVIENDA","CUENTA_VIVIENDA2":"$CUENTA_VIVIENDA2","FECHA_CUMPLIMIENTO_BONIFICACIO":"$FECHA_CUMPLIMIENTO_BONIFICACIO","TIPOVINCULACION":"$TIPOVINCULACION(type:integer)","AREAMISOADM":"$AREAMISOADM","EMAIL_PERSONAL":"$EMAIL_PERSONAL","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO","ACTA_POSESION":"$ACTA_POSESION","FECHA_ACTA_POSESION":"$FECHA_ACTA_POSESION","FECHA_INICIO_COMISION":"$FECHA_INICIO_COMISION","FECHA_FINAL_COMISION":"$FECHA_FINAL_COMISION","TOTAL_DIAS_COMISION":"$TOTAL_DIAS_COMISION","FECHA_EXPEDICION_CEDULA":"$FECHA_EXPEDICION_CEDULA","NIVELSIIF":"$NIVELSIIF","DIRECCION":"$DIRECCION","TELEFONOS":"$TELEFONOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
