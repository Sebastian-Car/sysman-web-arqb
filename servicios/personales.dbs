	<query id="getPersonalesPagCodigoYNombrePorNombramientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO NOMBRE, NAT_NOMBRAMIENTO.NO_NUME, PERSONAL.ID_DE_CARGO, PERSONAL.DEPENDENCIA, NAT_NOMBRAMIENTO.NO_SALARION FROM PERSONAL INNER JOIN NAT_NOMBRAMIENTO ON PERSONAL.NUMERO_DCTO = NAT_NOMBRAMIENTO.DP_NUMEDOCU WHERE PERSONAL.COMPANIA =:COMPANIA ORDER BY PERSONAL.ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NO_NUME IS NULL THEN ' ' ELSE UPPER(NO_NUME) END) LIKE UPPER(CONCAT(:NO_NUME, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRE":"$NOMBRE","NO_NUME":"$NO_NUME","ID_DE_CARGO":"$ID_DE_CARGO","DEPENDENCIA":"$DEPENDENCIA","NO_SALARION":"$NO_SALARION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NO_NUME" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
