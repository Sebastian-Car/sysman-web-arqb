			<with-param name="ID_DE_CARGO" query-param="ID_DE_CARGO"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagNombrecompletoyidQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT P.ID_DE_EMPLEADO, NOMBRECOMPLETO NOMCOMPLETO FROM PERSONAL P WHERE P.COMPANIA =:COMPANIA AND P.ID_DE_EMPLEADO &lt;&gt; 0 ORDER BY P.ID_DE_EMPLEADO ASC) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMCOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMCOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMCOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMCOMPLETO":"$NOMCOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMCOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/nombrecompletoyid/pag">
		<call-query href="getPersonalesPagNombrecompletoyidQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMCOMPLETO" query-param="NOMCOMPLETO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumNombrecompletoyidQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT P.ID_DE_EMPLEADO, NOMBRECOMPLETO NOMCOMPLETO FROM PERSONAL P WHERE P.COMPANIA =:COMPANIA AND P.ID_DE_EMPLEADO &lt;&gt; 0 ORDER BY P.ID_DE_EMPLEADO ASC) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMCOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMCOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMCOMPLETO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMCOMPLETO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/nombrecompletoyid/num">
		<call-query href="getPersonalesNumNombrecompletoyidQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMCOMPLETO" query-param="NOMCOMPLETO"/>

		</call-query>
	</resource>
