	<query id="getPersonalesPagPersonalPorEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, PERSONAL.SUCURSAL  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ESTADO_ACTUAL IN (:ESTADO) ORDER BY PERSONAL.NUMERO_DCTO) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","SUCURSAL":"$SUCURSAL"}]}}		</result>
