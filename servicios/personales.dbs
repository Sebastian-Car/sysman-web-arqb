			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CARGO_ACTUAL" query-param="CARGO_ACTUAL"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumTodosConNombrecarQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PERSONAL.NUMERO_DCTO, CONCAT(NOMBRES ,CONCAT( ' ' ,CONCAT( APELLIDO1 ,CONCAT(' ' ,APELLIDO2 )))) NOMBRE_COMPLETO, PERSONAL.SUCURSAL, CARGOS.NOMBRE_DEL_CARGO CARGO_ACTUAL, PERSONAL.ID_DE_EMPLEADO FROM PERSONAL LEFT JOIN CARGOS ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO WHERE PERSONAL.COMPANIA =:COMPANIA ORDER BY NOMBRE_COMPLETO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE_COMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRE_COMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_COMPLETO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN CARGO_ACTUAL IS NULL THEN ' ' ELSE UPPER(CARGO_ACTUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CARGO_ACTUAL), '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE_COMPLETO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CARGO_ACTUAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
