	<query id="getPersonalesPagGetempleadosbycompaniaandestadoactualnotin3Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO FROM PERSONAL WHERE PERSONAL.ID_DE_EMPLEADO &lt;&gt; '00000' AND PERSONAL.ESTADO_ACTUAL &lt;&gt; 3 AND PERSONAL.COMPANIA = :COMPANIA ORDER BY PERSONAL.ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
