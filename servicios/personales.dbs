A_SUPERVIVIENCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_SUPERVIVIENCIA,(TO_CHAR(PERSONAL.FECHA_VEN_SUPERVIVIENCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_VEN_SUPERVIVIENCIA,(TO_CHAR(PERSONAL.FECHA_1470,'DD/MM/YYYY HH24:MI:SS')) FECHA_1470,(CASE PERSONAL.RETE_1470 WHEN 0 THEN 'false' ELSE 'true' END) RETE_1470, PERSONAL.NUM_RESOLUCION_ING,(TO_CHAR(PERSONAL.FECHA_RESOLUCION_ING,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION_ING,(TO_CHAR(PERSONAL.FECHA_VEN_CONSTANCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_VEN_CONSTANCIA,(TO_CHAR(PERSONAL.FECHA_CONSTANCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONSTANCIA, PERSONAL.EMAIL_PERSONAL, PERSONAL.EMAIL_CORPORATIVO, PERSONAL.TARJETA_PROFESIONAL,(TO_CHAR(PERSONAL.FECHATARJETAPROF,'DD/MM/YYYY HH24:MI:SS')) FECHATARJETAPROF,(TO_CHAR(PERSONAL.FECHA_GRADO,'DD/MM/YYYY HH24:MI:SS')) FECHA_GRADO, PERSONAL.CURSOS, PERSONAL.TIPOBACHILLERATO,(TO_CHAR(PERSONAL.FECHA_ANTICIPO_CESANTIAS,'DD/MM/YYYY HH24:MI:SS')) FECHA_ANTICIPO_CESANTIAS, PERSONAL.HISTORIALABORAL,(TO_CHAR(PERSONAL.FECHATERCONTRATOANT,'DD/MM/YYYY HH24:MI:SS')) FECHATERCONTRATOANT, PERSONAL.PRORROGAS, PERSONAL.MESESPRORROGAS, PERSONAL.SECTOR_SIA,(CASE PERSONAL.DEPENDIENTES384 WHEN 0 THEN 'false' ELSE 'true' END) DEPENDIENTES384,(TO_CHAR(PERSONAL.FECHA_DEPENDIENTES384,'DD/MM/YYYY HH24:MI:SS')) FECHA_DEPENDIENTES384,(CASE PERSONAL.DECLARANTES384 WHEN 0 THEN 'false' ELSE 'true' END) DECLARANTES384,(TO_CHAR(PERSONAL.FECHA_DECLARANTES384,'DD/MM/YYYY HH24:MI:SS')) FECHA_DECLARANTES384, PERSONAL.ACTA_POSESION,(TO_CHAR(PERSONAL.FECHA_ACTA_POSESION,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTA_POSESION,(CASE PERSONAL.IND_CORRECCION WHEN 0 THEN 'false' ELSE 'true' END) IND_CORRECCION,(CASE PERSONAL.EXONERADO_APORTES WHEN 0 THEN 'false' ELSE 'true' END) EXONERADO_APORTES,(TO_CHAR(PERSONAL.FECHA_RETE_MINIMA,'DD/MM/YYYY HH24:MI:SS')) FECHA_RETE_MINIMA,(TO_CHAR(PERSONAL.FECHA_EXPEDICION_CEDULA,'DD/MM/YYYY HH24:MI:SS')) FECHA_EXPEDICION_CEDULA,(CASE PERSONAL.RETE_MINIMA WHEN 0 THEN 'false' ELSE 'true' END) RETE_MINIMA,(CASE PERSONAL.TIENE_SUBSIDIO WHEN 0 THEN 'false' ELSE 'true' END) TIENE_SUBSIDIO,(CASE PERSONAL.MANEJA_POLIZA WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_POLIZA, PERSONAL.N_POLIZA,(TO_CHAR(PERSONAL.FECHA_VENCE,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCE, PERSONAL.ASEGURADORA, PERSONAL.VLR_ASEG,(TO_CHAR(PERSONAL.FECHA_INICIO_COMISION,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIO_COMISION,(TO_CHAR(PERSONAL.FECHA_FINAL_COMISION,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL_COMISION, PERSONAL.TOTAL_DIAS_COMISION, PERSONAL.COD_AUXILIAR,(CASE PERSONAL.APLICA_0862 WHEN 0 THEN 'false' ELSE 'true' END) APLICA_0862, PERSONAL.P_TIPO_DOC_AGR, PERSONAL.P_TIPO_VINCULACION_AGR, PERSONAL.P_TIPO_DOMINIO_AGR, PERSONAL.SUI_TIPO_NOM, PERSONAL.SUI_NIVEL, PERSONAL.SUI_NOMBRAMIENTO, PERSONAL.MEDIO_PAGO_SIIF,(TO_CHAR(PERSONAL.FECHA_INI_CESA,'DD/MM/YYYY HH24:MI:SS')) FECHA_INI_CESA,(TO_CHAR(PERSONAL.FECHA_INI_INTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_INI_INTE, PERSONAL.LICENCIAS_INTERECES, PERSONAL.LICENCIAS_CESANTIAS, PERSONAL.PAIS_LABORA, PERSONAL.DEPARTAMENTO_LABORA, PERSONAL.CIUDAD_LABORA, PERSONAL.NIVELSIIF, PERSONAL.SUI_COSTOGASTO,(CASE PERSONAL.ASALARIADO_NOEMPLEADOS WHEN 0 THEN 'false' ELSE 'true' END) ASALARIADO_NOEMPLEADOS, PERSONAL.NUMERO_RESOLUCION,(TO_CHAR(PERSONAL.FECHA_RESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RESOLUCION, PERSONAL.TIPORET, PERSONAL.CORREO_ENVIADO, PERSONAL.RADICADO_RENUNCIA,(TO_CHAR(PERSONAL.FECHA_RADICADO_RET,'DD/MM/YYYY HH24:MI:SS')) FECHA_RADICADO_RET, PERSONAL.CAUSA_RENUNCIA, PERSONAL.COMPANIA, PERSONAL.CREATED_BY,(TO_CHAR(PERSONAL.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, PERSONAL.MODIFIED_BY,(TO_CHAR(PERSONAL.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, PERSONAL.NOMBRECOMPLETO,(TO_CHAR(PERSONAL.FRAD_EXT,'DD/MM/YYYY HH24:MI:SS')) FRAD_EXT, PERSONAL.ACTIVIDADES_ALTO_RIESGO, PERSONAL.PR_SECTOR, PERSONAL.PR_FUENTE_RECURSO, PERSONAL.CMACMO, PERSONAL.SERVICIO_ASOCIADO,(TO_CHAR(PERSONAL.FECHA_ACTIVACION_MESADA,'DD/MM/YYYY HH24:MI:SS')) FECHA_ACTIVACION_MESADA, PERSONAL.CAUSA_ACTIVACION_MESADA, PERSONAL.PORCENTAJE_IBC, PERSONAL.PORC_PERDIDA_CAPACIDAD_LABORAL, PERSONAL.PORC_PERDIDA_CAPAC_PERMANENTE, PERSONAL.PORC_PERDIDA_CAPAC_INVALIDEZ,(TO_CHAR(PERSONAL.FECHA_RETIRO_PENSION,'DD/MM/YYYY HH24:MI:SS')) FECHA_RETIRO_PENSION, PERSONAL.CAUSA_RETIRO_PENSION, PERSONAL.ESTADO_SUPERVIVENCIA_TITULAR,(TO_CHAR(PERSONAL.FECHA_FALLECIDO_TITULAR,'DD/MM/YYYY HH24:MI:SS')) FECHA_FALLECIDO_TITULAR, PERSONAL.ESTADO_SUPERVIVENCIA_CAUSANTE,(TO_CHAR(PERSONAL.FECHA_FALLECIDO_CAUSANTE,'DD/MM/YYYY HH24:MI:SS')) FECHA_FALLECIDO_CAUSANTE, PERSONAL.CARGO_ENCARGO, PERSONAL.REFERENCIA,(CASE PERSONAL.SINDICATO2 WHEN 0 THEN 'false' ELSE 'true' END) SINDICATO2, PERSONAL.FONDO_SINDICATO2, PERSONAL.PORC_SINDICATO2, AUXILIAR.NOMBRE NOMBREAUXILIAR, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA, CENTRO_COSTO.NOMBRE NOMBRECENTRO, ESTABLECIMIENTOS_DOCENTES.NOMBRE NOMBREESTABLECIMIENTO, REFERENCIA.NOMBRE NOMBREREFRENCIA, TIPO_ACTIVIDAD.NOMBRE NOMBRETIPO_ACTIVIDAD, CASE WHEN PERSONAL.ESTADO_ACTUAL = 2 THEN TIPO_VINCULACION.NOMBRE_PENSIONADO ELSE TIPO_VINCULACION.NOMBRE END NOMBRETIPO_VINCULACION, SUB_TIPOCOTIZANTE.NOMBRE NOMBRESUB_TIPOCOTIZANTE, CARGOS.NOMBRE_DEL_CARGO, GRUPO_CONTABLE.NOMBRE NOMBREGRUPOCONTABLE, TIPO_PENSIONADO.NOMBRE NOMBRETIPOPENSIONADO, PERSONAL.JEFE_DIRECTO, JEFEDIRECTO.NOMBRECOMPLETO NOMJEFEDIRECTO, PERSONAL.NUMERO_MANUAL, PERSONAL.VERSION_MANUAL, PERSONAL.FONDO_SINDICATO3, PERSONAL.PORC_SINDICATO3,(CASE PERSONAL.SINDICATO3 WHEN 0 THEN 'false' ELSE 'true' END) SINDICATO3, PERSONAL.FUENTE_DE_RECURSO, PERSONAL.OFICIO_RENUNCIA,(TO_CHAR(PERSONAL.FECHA_OFICIO_RENUNCIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_OFICIO_RENUNCIA, PERSONAL.PORCENTAJE_APORTECAJA, PERSONAL.PORCENTAJE_REAJUSTESALUD,(TO_CHAR(PERSONAL.FECHA_CONT_RETIRO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONT_RETIRO, PERSONAL.ID_DE_CARGOESCALERA,(CASE PERSONAL.NOMBRADO_ESCALERA_CK WHEN 0 THEN 'false' ELSE 'true' END) NOMBRADO_ESCALERA_CK,(CASE PERSONAL.ENCARGO_COMISION_CK WHEN 0 THEN 'false' ELSE 'true' END) ENCARGO_COMISION_CK,(TO_CHAR(PERSONAL.FECHA_NOMB_PROB_ENC_PROR,'DD/MM/YYYY HH24:MI:SS')) FECHA_NOMB_PROB_ENC_PROR,(CASE PERSONAL.TIENE_NOM_PL_TEMPORAL WHEN 0 THEN 'false' ELSE 'true' END) TIENE_NOM_PL_TEMPORAL, PERSONAL.ESCALAFON_TEMP, PERSONAL.ID_DE_CARGO_TEMPORAL,(TO_CHAR(PERSONAL.FECHA_NOMB_TEMP,'DD/MM/YYYY HH24:MI:SS')) FECHA_NOMB_TEMP, PERSONAL.PERFIL_TEMPORAL,(CASE PERSONAL.CARRERA_ADMIN_CK WHEN 0 THEN 'false' ELSE 'true' END) CARRERA_ADMIN_CK,(CASE PERSONAL.RESPONSABLE_UNI_CK WHEN 0 THEN 'false' ELSE 'true' END) RESPONSABLE_UNI_CK, PERSONAL.LOCALIDAD, PERSONAL.AFILIACION_POLITICA,(CASE PERSONAL.CABEZA_FAMILIA WHEN 0 THEN 'false' ELSE 'true' END) CABEZA_FAMILIA,(TO_CHAR(PERSONAL.FECHA_INSCRIPCION_CF,'DD/MM/YYYY HH24:MI:SS')) FECHA_INSCRIPCION_CF, PERSONAL.CARGO_INSCRITO, PERSONAL.FOLIO_INSCRIPCION, PERSONAL.RESOLUCION_INSCRIPCION, PERSONAL.ACTIVIDAD_ECONOMICA,(TO_CHAR(PERSONAL.HORA_ENTRADA,'DD/MM/YYYY HH24:MI:SS')) HORA_ENTRADA,(TO_CHAR(PERSONAL.HORA_SALIDA,'DD/MM/YYYY HH24:MI:SS')) HORA_SALIDA, PERSONAL.PERFIL_ACADEMICO,(TO_CHAR(PERSONAL.FECHA_RETIRO_DOS,'DD/MM/YYYY HH24:MI:SS')) FECHA_RETIRO_DOS, PERSONAL.ID_DE_EMPLEADO_ESCAL, PERSONAL.FORMA_VINCULACION, CARGOESC.NOMBRE_DEL_CARGO AS NOMBRECARGO, CARGOTEMP.NOMBRE_DEL_CARGO AS NOMBRECARGOTEMP,(CASE PERSONAL.APORTE_SALUD_PENSION WHEN 0 THEN 'false' ELSE 'true' END) APORTE_SALUD_PENSION, PERSONAL.VR_MESPENSION2421, PERSONAL.ID_CIIU, PERSONAL.DCTO_IDENTIDAD_DEPEN, PERSONAL.NUMERO_IDEN_DEPEN , PERSONAL.NOMBRES_DEPEN , PERSONAL.PARENTESCO_DEPEN, PERSONAL.MODALIDAD_PENSION,(CASE PERSONAL.SUI WHEN 0 THEN 'false' ELSE 'true' END) SUI ,(CASE PERSONAL.SABADO_HABIL WHEN 0 THEN 'false' ELSE 'true' END) SABADO_HABIL,PERSONAL.N_HIJOS, PERSONAL.SERVIDOR_PUBLICO,(CASE PERSONAL.PROGRAMA_JOVEN WHEN 0 THEN 'false' ELSE 'true' END) PROGRAMA_JOVEN,(CASE PERSONAL.DISCAPACIDAD WHEN 0 THEN 'false' ELSE 'true' END) DISCAPACIDAD, PERSONAL.TIPO_DISCAPACIDAD, PERSONAL.NIVEL_EDUCATIVO, PERSONAL.PROFESION, (TO_CHAR(PERSONAL.FECHAFONDOACCAI,'DD/MM/YYYY HH24:MI:SS')) FECHAFONDOACCAI, PERSONAL.FONDO_ACCAI,(CASE PERSONAL.REGIMEN_TRANSICION WHEN 0 THEN 'false' ELSE 'true' END) REGIMEN_TRANSICION, PERSONAL.OBSERVACION_RESIDENCIA,(CASE PERSONAL.AUXILIO_CONECTIVIDAD WHEN 0 THEN 'false' ELSE 'true' END) AUXILIO_CONECTIVIDAD   FROM PERSONAL LEFT JOIN AUXILIAR ON PERSONAL.COMPANIA = AUXILIAR.COMPANIA AND PERSONAL.ANO = AUXILIAR.ANO AND PERSONAL.COD_AUXILIAR = AUXILIAR.CODIGO LEFT JOIN DEPENDENCIA ON PERSONAL.COMPANIA = DEPENDENCIA.COMPANIA AND PERSONAL.DEPENDENCIA = DEPENDENCIA.CODIGO LEFT JOIN CENTRO_COSTO ON PERSONAL.COMPANIA = CENTRO_COSTO.COMPANIA AND PERSONAL.ANO = CENTRO_COSTO.ANO AND PERSONAL.ID_CENTRO_DE_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN ESTABLECIMIENTOS_DOCENTES ON PERSONAL.COMPANIA = ESTABLECIMIENTOS_DOCENTES.COMPANIA AND PERSONAL.CODIGO_ESTABLECIMIENTO = ESTABLECIMIENTOS_DOCENTES.CODIGO LEFT JOIN REFERENCIA ON PERSONAL.COMPANIA = REFERENCIA.COMPANIA AND PERSONAL.REFERENCIA = REFERENCIA.CODIGO AND PERSONAL.ANO = REFERENCIA.ANO LEFT JOIN TIPO_ACTIVIDAD ON PERSONAL.TIPOACTIVIDAD = TIPO_ACTIVIDAD.CODIGO LEFT JOIN TIPO_VINCULACION ON PERSONAL.TIPOVINCULACION = TIPO_VINCULACION.CODIGO LEFT JOIN SUB_TIPOCOTIZANTE ON PERSONAL.SUBTIPOCOTIZANTE = SUB_TIPOCOTIZANTE.CODIGO LEFT JOIN CARGOS ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.CARGO_ENCARGO = CARGOS.ID_DE_CARGO LEFT JOIN GRUPO_CONTABLE ON PERSONAL.GRUPOCONTABLE = GRUPO_CONTABLE.CODIGO LEFT JOIN TIPO_PENSIONADO ON PERSONAL.TIPOPENSIONADO = TIPO_PENSIONADO.CODIGO LEFT JOIN PERSONAL JEFEDIRECTO ON PERSONAL.COMPANIA = JEFEDIRECTO.COMPANIA AND PERSONAL.JEFE_DIRECTO = JEFEDIRECTO.ID_DE_EMPLEADO LEFT JOIN CARGOS CARGOESC ON PERSONAL.COMPANIA = CARGOESC.COMPANIA AND PERSONAL.ID_DE_CARGOESCALERA = CARGOESC.ID_DE_CARGO LEFT JOIN CARGOS CARGOTEMP ON PERSONAL.COMPANIA = CARGOTEMP.COMPANIA AND PERSONAL.ID_DE_CARGO_TEMPORAL = CARGOTEMP.ID_DE_CARGO WHERE PERSONAL.COMPANIA= :KEY_COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO</sql>
