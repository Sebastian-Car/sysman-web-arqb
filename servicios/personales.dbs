	<query id="getPersonalesPersonalSinTipoDeContratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(RPAD(NOMBRES,15,' ') ,CONCAT(RPAD(APELLIDO1,15,' ') ,CONCAT(RPAD(APELLIDO2,15,' ') ,ID_DE_EMPLEADO))) LINEA FROM ( SELECT SUM(CASE NVL(PERSONAL.DE_CARRERA,0) WHEN '0' THEN '1' ELSE '0' END) AS SINTIPOCONTRATO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO AS NOMBRE_COMPLETO, PERSONAL.NOMBRES, PERSONAL.APELLIDO2, PERSONAL.APELLIDO1 FROM PERSONAL INNER JOIN ( SELECT SUM(HISTORICOS.VALOR) AS SUMADEVALOR, PERSONAL.ID_DE_EMPLEADO, HISTORICOS.COMPANIA FROM HISTORICOS INNER JOIN PERSONAL ON ( HISTORICOS.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO ) AND ( HISTORICOS.COMPANIA = PERSONAL.COMPANIA ) WHERE HISTORICOS.ID_DE_CONCEPTO = 97 AND CONCAT(HISTORICOS.ANO , CONCAT(LPAD(HISTORICOS.MES,2,'0') , LPAD(HISTORICOS.PERIODO,2,'0') )) BETWEEN CONCAT(:ANO1 , CONCAT(LPAD(:MES1,2,'0') , LPAD(:PERIODO1,2,'0') )) AND CONCAT(:ANO2 , CONCAT(LPAD(:MES2,2,'0') , LPAD(:PERIODO2,2,'0'))) AND HISTORICOS.COMPANIA =:COMPANIA AND PERSONAL.COMPANIA =:COMPANIA GROUP BY PERSONAL.ID_DE_EMPLEADO, HISTORICOS.COMPANIA ) TOTAL_PERIODOS_PERSONAL ON ( PERSONAL.COMPANIA = TOTAL_PERIODOS_PERSONAL.COMPANIA ) AND ( PERSONAL.ID_DE_EMPLEADO = TOTAL_PERIODOS_PERSONAL.ID_DE_EMPLEADO ) GROUP BY PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRES, PERSONAL.APELLIDO2, PERSONAL.APELLIDO1, PERSONAL.NOMBRECOMPLETO ) C_CONTRATO WHERE SINTIPOCONTRATO = '1'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"LINEA":"$LINEA"}]}}		</result>
		<param name="ANO1" sqlType="STRING"/>
		<param name="MES1" sqlType="STRING"/>
		<param name="PERIODO1" sqlType="STRING"/>
		<param name="ANO2" sqlType="STRING"/>
		<param name="MES2" sqlType="STRING"/>
		<param name="PERIODO2" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
