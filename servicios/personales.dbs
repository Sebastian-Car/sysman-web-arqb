	<query id="getPersonalesPagPorCompaniaYIdempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, (NOMBRECOMPLETO) NOMBRE_COMP, CASE ESTADO_ACTUAL WHEN 1 THEN 'ACTIVO' WHEN 2 THEN 'PENSIONADO' WHEN 3 THEN 'RETIRADO' WHEN 5 THEN 'ACTIVO PARA AJUSTES' ELSE 'OTRO' END AS ESTADO_ACTUAL FROM PERSONAL WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.ID_DE_EMPLEADO &lt;&gt; '00000') INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE_COMP IS NULL THEN ' ' ELSE UPPER(NOMBRE_COMP) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_COMP), '%')) AND (CASE WHEN ESTADO_ACTUAL IS NULL THEN ' ' ELSE UPPER(ESTADO_ACTUAL) END) LIKE UPPER(CONCAT(:ESTADO_ACTUAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRE_COMP":"$NOMBRE_COMP","ESTADO_ACTUAL":"$ESTADO_ACTUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE_COMP" sqlType="STRING"/>
		<param name="ESTADO_ACTUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/porcompaniayidempleado/pag">
		<call-query href="getPersonalesPagPorCompaniaYIdempleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRE_COMP" query-param="NOMBRE_COMP"/>
			<with-param name="ESTADO_ACTUAL" query-param="ESTADO_ACTUAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumPorCompaniaYIdempleadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, (NOMBRECOMPLETO) NOMBRE_COMP, CASE ESTADO_ACTUAL WHEN 1 THEN 'ACTIVO' WHEN 2 THEN 'PENSIONADO' WHEN 3 THEN 'RETIRADO' WHEN 5 THEN 'ACTIVO PARA AJUSTES' ELSE 'OTRO' END AS ESTADO_ACTUAL FROM PERSONAL WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.ID_DE_EMPLEADO &lt;&gt; '00000') INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE_COMP IS NULL THEN ' ' ELSE UPPER(NOMBRE_COMP) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_COMP), '%')) AND (CASE WHEN ESTADO_ACTUAL IS NULL THEN ' ' ELSE UPPER(ESTADO_ACTUAL) END) LIKE UPPER(CONCAT(:ESTADO_ACTUAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE_COMP" sqlType="STRING"/>
		<param name="ESTADO_ACTUAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/porcompaniayidempleado/num">
		<call-query href="getPersonalesNumPorCompaniaYIdempleadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRE_COMP" query-param="NOMBRE_COMP"/>
			<with-param name="ESTADO_ACTUAL" query-param="ESTADO_ACTUAL"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagNombrecompletoPorCompaniaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERSONAL.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO NOMBRE, PERSONAL.SUCURSAL  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA ORDER BY PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
