	</resource>
	<query id="updatePersonalesCargoEncargo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET CARGO_ENCARGO          = :CARGO,   DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY              = :MODIFIED_BY WHERE PERSONAL.COMPANIA    = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CARGO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="personales/cargoencargo">
		<call-query href="updatePersonalesCargoEncargo">
			<with-param name="CARGO" query-param="CARGO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getPersonalesListaescalafonjiQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ESCALAFON.CODIGO ESCALAFON_JEFE_INMEDIATO, ESCALAFON.NOMBRE NOMBREESCALAFON, CARGOS.ID_DE_CARGO  FROM PERSONAL INNER JOIN CARGOS ON PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO AND PERSONAL.ESCALAFON = CARGOS.ESCALAFON INNER JOIN ESCALAFON ON CARGOS.ESCALAFON = ESCALAFON.CODIGO WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.DEPENDENCIA = :DEPENDENCIA GROUP BY ESCALAFON.CODIGO, ESCALAFON.NOMBRE, CARGOS.ID_DE_CARGO HAVING CARGOS.ID_DE_CARGO = :CARGO ORDER BY ESCALAFON.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESCALAFON_JEFE_INMEDIATO":"$ESCALAFON_JEFE_INMEDIATO","NOMBREESCALAFON":"$NOMBREESCALAFON","ID_DE_CARGO":"$ID_DE_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/listaescalafonji">
