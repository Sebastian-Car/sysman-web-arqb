	<query id="updatePersonalesUpdatepersonaleslicencia" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PERSONAL SET TOTAL_DIAS_COMISION=:TOTAL_DIAS_COMISION, FECHA_INICIO_COMISION=TO_DATE(:FECHA_INICIO_COMISION,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL_COMISION=TO_DATE(:FECHA_FINAL_COMISION,'DD/MM/YYYY HH24:MI:SS'), ESTADO_ACTUAL=:ESTADO_ACTUAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PERSONAL.COMPANIA= :KEY_COMPANIA AND PERSONAL.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TOTAL_DIAS_COMISION" sqlType="STRING"/>
		<param name="FECHA_INICIO_COMISION" sqlType="STRING"/>
		<param name="FECHA_FINAL_COMISION" sqlType="STRING"/>
		<param name="ESTADO_ACTUAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
