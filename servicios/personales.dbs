	<query id="getPersonalesManualPorIdQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO_MANUAL, VERSION_MANUAL  FROM PERSONAL WHERE COMPANIA = :COMPANIA AND ID_DE_EMPLEADO =:ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_MANUAL":"$NUMERO_MANUAL","VERSION_MANUAL":"$VERSION_MANUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/manualporid">
		<call-query href="getPersonalesManualPorIdQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagPersonalActyPenQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ID_DE_EMPLEADO, NUMERO_DCTO, NOMBRECOMPLETO NOMBRE FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND ESTADO_ACTUAL IN(1,2) AND ID_DE_EMPLEADO NOT IN (0) ORDER BY ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/personalactypen/pag">
		<call-query href="getPersonalesPagPersonalActyPenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumPersonalActyPenQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ID_DE_EMPLEADO, NUMERO_DCTO, NOMBRECOMPLETO NOMBRE FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND ESTADO_ACTUAL IN(1,2) AND ID_DE_EMPLEADO NOT IN (0) ORDER BY ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/personalactypen/num">
		<call-query href="getPersonalesNumPersonalActyPenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPersonalesCorreodeterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PERSONAL.EMAIL_CORPORATIVO  FROM TERCERO INNER JOIN PERSONAL ON TERCERO.COMPANIA = PERSONAL.COMPANIA AND TERCERO.NIT = PERSONAL.NUMERO_DCTO AND TERCERO.SUCURSAL = PERSONAL.SUCURSAL WHERE TERCERO.COMPANIA = :COMPANIA AND TERCERO.NIT = :NIT AND TERCERO.SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/correodetercero">
		<call-query href="getPersonalesCorreodeterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getPersonalesCorreoCertificadoIngresosQuery"  useConfig="sysmandsunist">
		<sql>SELECT PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO, EMAIL_CORPORATIVO, EMAIL_PERSONAL FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO NOT IN ( 0 ) AND (PERSONAL.ESTADO_ACTUAL = :ESTADO OR ( PERSONAL.ESTADO_ACTUAL=3 AND FECHA_DE_RETIRO &gt;= TO_DATE(:FECHA,'DD/MM/YYYY') ) ) AND PERSONAL.ID_DE_EMPLEADO = CASE WHEN ( :ID_DE_EMPLEADO ) = 0 THEN PERSONAL.ID_DE_EMPLEADO ELSE TO_NUMBER(:ID_DE_EMPLEADO) END ORDER BY PERSONAL.ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO","EMAIL_PERSONAL":"$EMAIL_PERSONAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/correocertificadoingresos">
		<call-query href="getPersonalesCorreoCertificadoIngresosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagTodosmenosretiradpsQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_DE_EMPLEADO, NUMERO_DCTO, NOMBRECOMPLETO NOMBRE, EMAIL_PERSONAL, EMAIL_CORPORATIVO  FROM PERSONAL WHERE COMPANIA =:COMPANIA AND ID_DE_EMPLEADO NOT IN(0) AND ESTADO_ACTUAL &lt;&gt;3 AND FECHA_DE_RETIRO IS NULL ORDER BY NOMBRECOMPLETO, ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN EMAIL_PERSONAL IS NULL THEN ' ' ELSE UPPER(EMAIL_PERSONAL) END)  LIKE UPPER( '%' || :EMAIL_PERSONAL || '%')  AND (CASE WHEN EMAIL_CORPORATIVO IS NULL THEN ' ' ELSE UPPER(EMAIL_CORPORATIVO) END)  LIKE UPPER( '%' || :EMAIL_CORPORATIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","EMAIL_PERSONAL":"$EMAIL_PERSONAL","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="EMAIL_PERSONAL" sqlType="STRING"/>
		<param name="EMAIL_CORPORATIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/todosmenosretiradps/pag">
		<call-query href="getPersonalesPagTodosmenosretiradpsQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="EMAIL_PERSONAL" query-param="EMAIL_PERSONAL"/>
			<with-param name="EMAIL_CORPORATIVO" query-param="EMAIL_CORPORATIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPersonalesNumTodosmenosretiradpsQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID_DE_EMPLEADO, NUMERO_DCTO, NOMBRECOMPLETO NOMBRE, EMAIL_PERSONAL, EMAIL_CORPORATIVO  FROM PERSONAL WHERE COMPANIA =:COMPANIA AND ID_DE_EMPLEADO NOT IN(0) AND ESTADO_ACTUAL &lt;&gt;3 AND FECHA_DE_RETIRO IS NULL ORDER BY NOMBRECOMPLETO, ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN EMAIL_PERSONAL IS NULL THEN ' ' ELSE UPPER(EMAIL_PERSONAL) END)  LIKE UPPER( '%' || :EMAIL_PERSONAL || '%')  AND (CASE WHEN EMAIL_CORPORATIVO IS NULL THEN ' ' ELSE UPPER(EMAIL_CORPORATIVO) END)  LIKE UPPER( '%' || :EMAIL_CORPORATIVO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="EMAIL_PERSONAL" sqlType="STRING"/>
		<param name="EMAIL_CORPORATIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="personales/todosmenosretiradps/num">
		<call-query href="getPersonalesNumTodosmenosretiradpsQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="EMAIL_PERSONAL" query-param="EMAIL_PERSONAL"/>
			<with-param name="EMAIL_CORPORATIVO" query-param="EMAIL_CORPORATIVO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagCargarlistaplanoempleadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,ID_DE_EMPLEADO, NUMERO_DCTO, CONCAT(CONCAT(CONCAT(CONCAT(APELLIDO1, ' '), APELLIDO2 ), ' '), NOMBRES) MOMBRE_EMPLEADO, TELEFONOS, DIRECCION, EMAIL_PERSONAL, NIVEL_EDUCATIVO_RNEC, NIVEL_EDUCATIVO_RNEC.NOMBRE NOMBRE_NIVEL_EDUCATIVO, FILIACION_POLITICA_RNEC, FILIACION_POLITICA_RNEC.NOMBRE NOMBRE_FILIACION_POLITICA, TIPO_EMPLEADO_RNEC, TIPO_EMPLEADO_RNEC.TIPO_EMPRESA NOMBRE_TIPO_EMPLEADO  FROM PERSONAL INNER JOIN NIVEL_EDUCATIVO_RNEC ON PERSONAL.NIVEL_EDUCATIVO_RNEC = NIVEL_EDUCATIVO_RNEC.CODIGO INNER JOIN FILIACION_POLITICA_RNEC ON PERSONAL.FILIACION_POLITICA_RNEC = FILIACION_POLITICA_RNEC.CODIGO INNER JOIN TIPO_EMPLEADO_RNEC ON PERSONAL.TIPO_EMPLEADO_RNEC = TIPO_EMPLEADO_RNEC.CODIGO WHERE COMPANIA = '001' AND ESTADO_ACTUAL IN (1) AND ID_DE_EMPLEADO NOT IN (0) ORDER BY CONCAT(CONCAT(CONCAT(CONCAT(APELLIDO1, ' '), APELLIDO2 ), ' '), NOMBRES)) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN MOMBRE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(MOMBRE_EMPLEADO) END)  LIKE UPPER( '%' || :MOMBRE_EMPLEADO || '%')  AND (CASE WHEN TELEFONOS IS NULL THEN ' ' ELSE UPPER(TELEFONOS) END)  LIKE UPPER(:TELEFONOS || '%')  AND (CASE WHEN DIRECCION IS NULL THEN ' ' ELSE UPPER(DIRECCION) END)  LIKE UPPER( '%' || :DIRECCION || '%')  AND (CASE WHEN EMAIL_PERSONAL IS NULL THEN ' ' ELSE UPPER(EMAIL_PERSONAL) END)  LIKE UPPER( '%' || :EMAIL_PERSONAL || '%')  AND (CASE WHEN NIVEL_EDUCATIVO_RNEC IS NULL THEN ' ' ELSE UPPER(NIVEL_EDUCATIVO_RNEC) END)  LIKE UPPER( '%' || :NIVEL_EDUCATIVO_RNEC || '%')  AND (CASE WHEN NOMBRE_NIVEL_EDUCATIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_NIVEL_EDUCATIVO) END)  LIKE UPPER( '%' || :NOMBRE_NIVEL_EDUCATIVO || '%')  AND (CASE WHEN FILIACION_POLITICA_RNEC IS NULL THEN ' ' ELSE UPPER(FILIACION_POLITICA_RNEC) END)  LIKE UPPER( '%' || :FILIACION_POLITICA_RNEC || '%')  AND (CASE WHEN NOMBRE_FILIACION_POLITICA IS NULL THEN ' ' ELSE UPPER(NOMBRE_FILIACION_POLITICA) END)  LIKE UPPER( '%' || :NOMBRE_FILIACION_POLITICA || '%')  AND (CASE WHEN TIPO_EMPLEADO_RNEC IS NULL THEN ' ' ELSE UPPER(TIPO_EMPLEADO_RNEC) END)  LIKE UPPER( '%' || :TIPO_EMPLEADO_RNEC || '%')  AND (CASE WHEN NOMBRE_TIPO_EMPLEADO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO_EMPLEADO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO_EMPLEADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","MOMBRE_EMPLEADO":"$MOMBRE_EMPLEADO","TELEFONOS":"$TELEFONOS","DIRECCION":"$DIRECCION","EMAIL_PERSONAL":"$EMAIL_PERSONAL","NIVEL_EDUCATIVO_RNEC":"$NIVEL_EDUCATIVO_RNEC","NOMBRE_NIVEL_EDUCATIVO":"$NOMBRE_NIVEL_EDUCATIVO","FILIACION_POLITICA_RNEC":"$FILIACION_POLITICA_RNEC","NOMBRE_FILIACION_POLITICA":"$NOMBRE_FILIACION_POLITICA","TIPO_EMPLEADO_RNEC":"$TIPO_EMPLEADO_RNEC","NOMBRE_TIPO_EMPLEADO":"$NOMBRE_TIPO_EMPLEADO"}]}}		</result>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="MOMBRE_EMPLEADO" sqlType="STRING"/>
		<param name="TELEFONOS" sqlType="STRING"/>
