		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERSONAL.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO NOMBRE, PERSONAL.EMAIL_PERSONAL, PERSONAL.EMAIL_CORPORATIVO  FROM PERSONAL WHERE COMPANIA =:COMPANIA AND ID_DE_EMPLEADO NOT IN(0) AND TRUNC(FECHA_DE_INGRESO) &lt;= TRUNC(TO_DATE(:FECHAFIN,'DD/MM/YYYY HH24:MI:SS')) AND ((ESTADO_ACTUAL &lt;&gt;3 AND FECHA_DE_RETIRO IS NULL) OR (ESTADO_ACTUAL IN(1,2,3) AND TRUNC(FECHA_DE_RETIRO) &gt;=TRUNC(TO_DATE(:FECHAINI,'DD/MM/YYYY HH24:MI:SS')) ) ) ORDER BY PERSONAL.NOMBRECOMPLETO, PERSONAL.ID_DE_EMPLEADO) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN EMAIL_PERSONAL IS NULL THEN ' ' ELSE UPPER(EMAIL_PERSONAL) END)  LIKE UPPER( '%' || :EMAIL_PERSONAL || '%')  AND (CASE WHEN EMAIL_CORPORATIVO IS NULL THEN ' ' ELSE UPPER(EMAIL_CORPORATIVO) END)  LIKE UPPER( '%' || :EMAIL_CORPORATIVO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","EMAIL_PERSONAL":"$EMAIL_PERSONAL","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="EMAIL_PERSONAL" sqlType="STRING"/>
		<param name="EMAIL_CORPORATIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
