	<query id="getPersonalesNumTerceroporestadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO, TIPOS_DE_EMPLEADO.NOMBRE_TIPO, ESTADO_ACTUAL.NOMBRE, PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES  FROM PERSONAL INNER JOIN TIPOS_DE_EMPLEADO ON PERSONAL.COMPANIA = TIPOS_DE_EMPLEADO.COMPANIA AND TIPOS_DE_EMPLEADO.ID_DE_TIPO = PERSONAL.ID_DE_TIPO INNER JOIN ESTADO_ACTUAL ON ESTADO_ACTUAL.CODIGO = PERSONAL.ESTADO_ACTUAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ID_DE_EMPLEADO NOT IN (0) AND (PERSONAL.ESTADO_ACTUAL = :ESTADO OR (PERSONAL.ESTADO_ACTUAL=3 AND FECHA_DE_RETIRO&gt;=TO_DATE(:FECHA,'DD/MM/YYYY'))) ORDER BY PERSONAL.APELLIDO1, PERSONAL.APELLIDO2, PERSONAL.NOMBRES) WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
