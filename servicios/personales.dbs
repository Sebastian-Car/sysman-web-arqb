	<query id="getPersonalesPagListadependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT PERSONAL.DEPENDENCIA, DEPENDENCIA.NOMBRE  FROM PERSONAL LEFT JOIN DEPENDENCIA ON PERSONAL.COMPANIA = DEPENDENCIA.COMPANIA AND PERSONAL.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE (PERSONAL.COMPANIA) =:COMPANIA GROUP BY PERSONAL.DEPENDENCIA, DEPENDENCIA.NOMBRE, DEPENDENCIA.COMPANIA, PERSONAL.ESTADO_ACTUAL HAVING (DEPENDENCIA.COMPANIA) =:COMPANIA AND PERSONAL.ESTADO_ACTUAL IN (1) OR PERSONAL.ESTADO_ACTUAL IN (2) ORDER BY DEPENDENCIA.NOMBRE, DEPENDENCIA) WHERE (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEPENDENCIA":"$DEPENDENCIA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
