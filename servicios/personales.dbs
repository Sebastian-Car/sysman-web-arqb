	<query id="getPersonalesDatoscargopersonalQuery"  useConfig="sysmandsunist">
		<sql>SELECT PERSONAL.COMPANIA, PERSONAL.NUMERO_DCTO, PERSONAL.SUCURSAL, PERSONAL.ID_DE_EMPLEADO, ( CONCAT( PERSONAL.NOMBRES ,CONCAT( ' ' ,CONCAT( PERSONAL.APELLIDO1 , CONCAT( ' ' , PERSONAL.APELLIDO2 ))))) NOMBRECOMPLETO, DEPENDENCIA.NOMBRE NOMBREDEPENDENCIA, CARGOS.ID_DE_CARGO, CARGOS.NOMBRE_DEL_CARGO, PERSONAL.JEFE_DIRECTO, JEFE.EMAIL_CORPORATIVO, ( CONCAT( JEFE.NOMBRES ,CONCAT( ' ' ,CONCAT( JEFE.APELLIDO1 , CONCAT( ' ' , JEFE.APELLIDO2 ))))) NOMBRECOMPLETOJEFE, JEFE.ID_DE_CARGO CARGOJEFE, CARGOSJEFE.NOMBRE_DEL_CARGO NOMBRECARGOJEFE, JEFE.NUMERO_DCTO DOCUMENTOJEFE, JEFE.SUCURSAL SUCURSALJEFE, PERSONAL.EMAIL_CORPORATIVO EMAIL_SOLICITANTE FROM PERSONAL INNER JOIN CARGOS ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO LEFT JOIN PERSONAL JEFE ON PERSONAL.COMPANIA = JEFE.COMPANIA AND PERSONAL.JEFE_DIRECTO = JEFE.ID_DE_EMPLEADO LEFT JOIN CARGOS CARGOSJEFE ON JEFE.COMPANIA = CARGOSJEFE.COMPANIA AND JEFE.ID_DE_CARGO = CARGOSJEFE.ID_DE_CARGO INNER JOIN DEPENDENCIA ON PERSONAL.COMPANIA = DEPENDENCIA.COMPANIA AND PERSONAL.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.NUMERO_DCTO =:NUMERO_DCTO AND PERSONAL.ESTADO_ACTUAL NOT IN (3) ORDER BY PERSONAL.ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","ID_DE_CARGO":"$ID_DE_CARGO","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO","JEFE_DIRECTO":"$JEFE_DIRECTO(type:integer)","EMAIL_CORPORATIVO":"$EMAIL_CORPORATIVO","NOMBRECOMPLETOJEFE":"$NOMBRECOMPLETOJEFE","CARGOJEFE":"$CARGOJEFE","NOMBRECARGOJEFE":"$NOMBRECARGOJEFE","DOCUMENTOJEFE":"$DOCUMENTOJEFE","SUCURSALJEFE":"$SUCURSALJEFE","EMAIL_SOLICITANTE":"$EMAIL_SOLICITANTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>

	</query>
