	<query id="getPersonalesPagTodosConNombrecarQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PERSONAL.NUMERO_DCTO, CONCAT(NOMBRES ,CONCAT( ' ' ,CONCAT( APELLIDO1 ,CONCAT(' ' ,APELLIDO2 )))) NOMBRE_COMPLETO, PERSONAL.SUCURSAL, CARGOS.NOMBRE_DEL_CARGO CARGO_ACTUAL, PERSONAL.ID_DE_EMPLEADO FROM PERSONAL LEFT JOIN CARGOS ON PERSONAL.COMPANIA = CARGOS.COMPANIA AND PERSONAL.ID_DE_CARGO = CARGOS.ID_DE_CARGO WHERE PERSONAL.COMPANIA =:COMPANIA ORDER BY NOMBRE_COMPLETO) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE_COMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRE_COMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_COMPLETO), '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN CARGO_ACTUAL IS NULL THEN ' ' ELSE UPPER(CARGO_ACTUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CARGO_ACTUAL), '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE_COMPLETO":"$NOMBRE_COMPLETO","SUCURSAL":"$SUCURSAL","CARGO_ACTUAL":"$CARGO_ACTUAL","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE_COMPLETO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CARGO_ACTUAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/todosconnombrecar/pag">
