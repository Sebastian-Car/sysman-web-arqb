			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>

		</call-query>
	</resource>
	<query id="getPersonalesPagEmpleadoporcompaniaysucursalyestadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PERSONAL.ID_DE_EMPLEADO, NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1 ,CONCAT( ' ' ,CONCAT(NAT_DATOS_PERSONALES.APELLIDO2 ,CONCAT(' ' , NAT_DATOS_PERSONALES.NOMBRES)))) NOMBRECOMPLETO, NAT_DATOS_PERSONALES.SUCURSAL FROM PERSONAL INNER JOIN NAT_DATOS_PERSONALES ON PERSONAL.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND PERSONAL.NUMERO_DCTO = NAT_DATOS_PERSONALES.NUMERO_DCTO AND PERSONAL.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE PERSONAL.COMPANIA =:COMPANIA AND PERSONAL.ESTADO_ACTUAL NOT IN (3) AND PERSONAL.SUCURSAL NOT IN (999)) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="personales/empleadoporcompaniaysucursalyestado/pag">
