	<query id="getPersonalesPagIdEstadoPorCiaEstadoFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERSONAL.ID_DE_EMPLEADO, PERSONAL.NOMBRECOMPLETO, (SELECT NOMBRE FROM ESTADO_ACTUAL WHERE CODIGO = PERSONAL.ESTADO_ACTUAL ) ESTADO_ACTUAL, TO_CHAR(PERSONAL.FECHATERCONTRATO, 'DD/MM/YYYY') FECHATERCONTRATO  FROM PERSONAL WHERE PERSONAL.COMPANIA = :COMPANIA AND PERSONAL.ESTADO_ACTUAL &lt;&gt; :ESTADO AND PERSONAL.FECHATERCONTRATO &lt;= TO_DATE(:FECHA, 'DD/MM/YYYY') ORDER BY PERSONAL.FECHATERCONTRATO DESC) WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN ESTADO_ACTUAL IS NULL THEN ' ' ELSE UPPER(ESTADO_ACTUAL) END)  LIKE UPPER(:ESTADO_ACTUAL || '%')  AND (CASE WHEN FECHATERCONTRATO IS NULL THEN ' ' ELSE UPPER(FECHATERCONTRATO) END)  LIKE UPPER( '%' || :FECHATERCONTRATO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRECOMPLETO":"$NOMBRECOMPLETO","ESTADO_ACTUAL":"$ESTADO_ACTUAL","FECHATERCONTRATO":"$FECHATERCONTRATO"}]}}		</result>
