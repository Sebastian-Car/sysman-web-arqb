<data name="valorizacionesdevolutivos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertValorizacionesdevolutivos" keyColumns="COMPANIA,ELEMENTO,SERIE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VALORIZACIONDEVOLUTIVO (COMPANIA, PERIODO, AVALUO, FECHAAVALUO, VALORIZACION, FECHAVALORIZACION, DESCRIPCION, ELEMENTO, SERIE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, TO_DATE(:PERIODO,'DD/MM/YYYY HH24:MI:SS'), :AVALUO, TO_DATE(:FECHAAVALUO,'DD/MM/YYYY HH24:MI:SS'), :VALORIZACION, TO_DATE(:FECHAVALORIZACION,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, :ELEMENTO, :SERIE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ELEMENTO":"$ELEMENTO","KEY_SERIE":"$SERIE","KEY_PERIODO":"$PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param defaultValue="0" name="AVALUO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAAVALUO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORIZACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAVALORIZACION" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param defaultValue="0" name="SERIE" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="valorizacionesdevolutivos">
		<call-query href="insertValorizacionesdevolutivos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="FECHAAVALUO" query-param="FECHAAVALUO"/>
			<with-param name="VALORIZACION" query-param="VALORIZACION"/>
			<with-param name="FECHAVALORIZACION" query-param="FECHAVALORIZACION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteValorizacionesdevolutivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VALORIZACIONDEVOLUTIVO WHERE VALORIZACIONDEVOLUTIVO.COMPANIA= :KEY_COMPANIA AND VALORIZACIONDEVOLUTIVO.ELEMENTO= :KEY_ELEMENTO AND VALORIZACIONDEVOLUTIVO.SERIE= :KEY_SERIE AND VALORIZACIONDEVOLUTIVO.PERIODO= TO_DATE(:KEY_PERIODO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="valorizacionesdevolutivos">
		<call-query href="deleteValorizacionesdevolutivos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>

		</call-query>
	</resource>
	<query id="getValorizacionesdevolutivosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA,(TO_CHAR(PERIODO,'DD/MM/YYYY HH24:MI:SS')) PERIODO, AVALUO,(TO_CHAR(FECHAAVALUO,'DD/MM/YYYY HH24:MI:SS')) FECHAAVALUO, VALORIZACION,(TO_CHAR(FECHAVALORIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHAVALORIZACION, DESCRIPCION, ELEMENTO, SERIE  FROM VALORIZACIONDEVOLUTIVO WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND SERIE = :SERIE) WHERE (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN FECHAAVALUO IS NULL THEN ' ' ELSE UPPER(FECHAAVALUO) END)  LIKE UPPER( '%' || :FECHAAVALUO || '%')  AND (CASE WHEN VALORIZACION IS NULL THEN ' ' ELSE UPPER(VALORIZACION) END)  LIKE UPPER( '%' || :VALORIZACION || '%')  AND (CASE WHEN FECHAVALORIZACION IS NULL THEN ' ' ELSE UPPER(FECHAVALORIZACION) END)  LIKE UPPER( '%' || :FECHAVALORIZACION || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PERIODO":"$PERIODO","AVALUO":"$AVALUO","FECHAAVALUO":"$FECHAAVALUO","VALORIZACION":"$VALORIZACION","FECHAVALORIZACION":"$FECHAVALORIZACION","DESCRIPCION":"$DESCRIPCION","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="FECHAAVALUO" sqlType="STRING"/>
		<param name="VALORIZACION" sqlType="STRING"/>
		<param name="FECHAVALORIZACION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="valorizacionesdevolutivos">
		<call-query href="getValorizacionesdevolutivosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="FECHAAVALUO" query-param="FECHAAVALUO"/>
			<with-param name="VALORIZACION" query-param="VALORIZACION"/>
			<with-param name="FECHAVALORIZACION" query-param="FECHAVALORIZACION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getValorizacionesdevolutivosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA,(TO_CHAR(PERIODO,'DD/MM/YYYY HH24:MI:SS')) PERIODO, AVALUO,(TO_CHAR(FECHAAVALUO,'DD/MM/YYYY HH24:MI:SS')) FECHAAVALUO, VALORIZACION,(TO_CHAR(FECHAVALORIZACION,'DD/MM/YYYY HH24:MI:SS')) FECHAVALORIZACION, DESCRIPCION, ELEMENTO, SERIE  FROM VALORIZACIONDEVOLUTIVO WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND SERIE = :SERIE) WHERE (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN AVALUO IS NULL THEN ' ' ELSE UPPER(AVALUO) END)  LIKE UPPER( '%' || :AVALUO || '%')  AND (CASE WHEN FECHAAVALUO IS NULL THEN ' ' ELSE UPPER(FECHAAVALUO) END)  LIKE UPPER( '%' || :FECHAAVALUO || '%')  AND (CASE WHEN VALORIZACION IS NULL THEN ' ' ELSE UPPER(VALORIZACION) END)  LIKE UPPER( '%' || :VALORIZACION || '%')  AND (CASE WHEN FECHAVALORIZACION IS NULL THEN ' ' ELSE UPPER(FECHAVALORIZACION) END)  LIKE UPPER( '%' || :FECHAVALORIZACION || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="FECHAAVALUO" sqlType="STRING"/>
		<param name="VALORIZACION" sqlType="STRING"/>
		<param name="FECHAVALORIZACION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="valorizacionesdevolutivos/numero">
		<call-query href="getValorizacionesdevolutivosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="FECHAAVALUO" query-param="FECHAAVALUO"/>
			<with-param name="VALORIZACION" query-param="VALORIZACION"/>
			<with-param name="FECHAVALORIZACION" query-param="FECHAVALORIZACION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateValorizacionesdevolutivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VALORIZACIONDEVOLUTIVO SET PERIODO=TO_DATE(:PERIODO,'DD/MM/YYYY HH24:MI:SS'), AVALUO=:AVALUO, FECHAAVALUO=TO_DATE(:FECHAAVALUO,'DD/MM/YYYY HH24:MI:SS'), VALORIZACION=:VALORIZACION, FECHAVALORIZACION=TO_DATE(:FECHAVALORIZACION,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VALORIZACIONDEVOLUTIVO.COMPANIA= :KEY_COMPANIA AND VALORIZACIONDEVOLUTIVO.ELEMENTO= :KEY_ELEMENTO AND VALORIZACIONDEVOLUTIVO.SERIE= :KEY_SERIE AND VALORIZACIONDEVOLUTIVO.PERIODO= TO_DATE(:KEY_PERIODO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PERIODO" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="FECHAAVALUO" sqlType="STRING"/>
		<param name="VALORIZACION" sqlType="STRING"/>
		<param name="FECHAVALORIZACION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="valorizacionesdevolutivos">
		<call-query href="updateValorizacionesdevolutivos">
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="FECHAAVALUO" query-param="FECHAAVALUO"/>
			<with-param name="VALORIZACION" query-param="VALORIZACION"/>
			<with-param name="FECHAVALORIZACION" query-param="FECHAVALORIZACION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>

		</call-query>
	</resource>

</data>