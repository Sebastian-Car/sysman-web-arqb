<data name="sfdetallecotizacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfdetallecotizacionConsultatotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(NVL(SUM(VALOR_BASE),0), '99,999,999,999,999,990.90') TVALBASE, TO_CHAR(NVL(SUM(VALOR_IVA),0), '99,999,999,999,999,990.90') TIVA, TO_CHAR(NVL(SUM(VALOR_RETE),0), '99,999,999,999,999,990.90') TRETE, TO_CHAR(NVL(SUM(VALOR_ICA),0), '99,999,999,999,999,990.90') TICA, TO_CHAR(NVL(SUM(VALOR_DESCUENTO),0), '99,999,999,999,999,990.90') TDES, TO_CHAR(NVL(SUM(VALOR_NETO),0), '99,999,999,999,999,990.90') TNET, TO_CHAR(NVL(SUM(VALOR_UNITARIO),0), '99,999,999,999,999,990.90') TUNIT  FROM SF_DETALLE_COTIZACION WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TVALBASE":"$TVALBASE","TIVA":"$TIVA","TRETE":"$TRETE","TICA":"$TICA","TDES":"$TDES","TNET":"$TNET","TUNIT":"$TUNIT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecotizacion/consultatotales">
		<call-query href="getSfdetallecotizacionConsultatotalesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecotizacionTotalparacotizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT IMF.AREA CANTIDAD, NVL(SUM(VALOR_BASE), 0) VALOR_BASE, NVL(SUM(VALOR_NETO), 0) VALOR_NETO, NVL(SUM(VALOR_UNITARIO), 0) VALOR_UNITARIO FROM SF_DETALLE_COTIZACION SFDC INNER JOIN INMUEBLE_FACTURACION IMF ON (INMUEBLE = CODIGOINMUEBLE) WHERE SFDC.COMPANIA = :COMPANIA AND SFDC.TIPO = :TIPO AND NUMERO = :NUMERO GROUP BY IMF.AREA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD(type:double)","VALOR_BASE":"$VALOR_BASE(type:double)","VALOR_NETO":"$VALOR_NETO(type:double)","VALOR_UNITARIO":"$VALOR_UNITARIO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecotizacion/totalparacotizacion">
		<call-query href="getSfdetallecotizacionTotalparacotizacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecotizacionGetlistasinpaginarQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_DETALLE_COTIZACION.COMPANIA, SF_DETALLE_COTIZACION.TIPO, SF_DETALLE_COTIZACION.NUMERO, SF_DETALLE_COTIZACION.CONCEPTO, SF_DETALLE_COTIZACION.TARIFA, SF_DETALLE_COTIZACION.CANTIDAD, SF_DETALLE_COTIZACION.VALOR_BASE, SF_DETALLE_COTIZACION.VALOR_IVA, SF_DETALLE_COTIZACION.VALOR_RETE, SF_DETALLE_COTIZACION.VALOR_ICA, SF_DETALLE_COTIZACION.VALOR_DESCUENTO, SF_DETALLE_COTIZACION.VALOR_NETO, SF_DETALLE_COTIZACION.VALOR_COMPRA, SF_DETALLE_COTIZACION.VALOR_UTILIDAD, SF_DETALLE_COTIZACION.TERCERO, SF_DETALLE_COTIZACION.SUCURSAL, SF_DETALLE_COTIZACION.CENTRO_COSTO, SF_DETALLE_COTIZACION.AUXILIAR, SF_DETALLE_COTIZACION.VALOR_UNITARIO, SF_DETALLE_COTIZACION.CREATED_BY,(TO_CHAR(SF_DETALLE_COTIZACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_DETALLE_COTIZACION.MODIFIED_BY,(TO_CHAR(SF_DETALLE_COTIZACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TERCERO.NUMEROLISTA,SF_DETALLE_COTIZACION.INMUEBLE FROM SF_DETALLE_COTIZACION INNER JOIN TERCERO ON (TERCERO.NIT = SF_DETALLE_COTIZACION.TERCERO) WHERE SF_DETALLE_COTIZACION.COMPANIA = :COMPANIA AND SF_DETALLE_COTIZACION.TIPO = :TIPO AND SF_DETALLE_COTIZACION.NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","CONCEPTO":"$CONCEPTO","TARIFA":"$TARIFA","CANTIDAD":"$CANTIDAD","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_ICA":"$VALOR_ICA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_NETO":"$VALOR_NETO","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_UTILIDAD":"$VALOR_UTILIDAD","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VALOR_UNITARIO":"$VALOR_UNITARIO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NUMEROLISTA":"$NUMEROLISTA","INMUEBLE":"$INMUEBLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecotizacion/getlistasinpaginar">
		<call-query href="getSfdetallecotizacionGetlistasinpaginarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecotizacionGetexistedetalleconconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT MAX(INMUEBLE) CONSEC, COUNT(NUMERO) EXISTE FROM SF_DETALLE_COTIZACION WHERE COMPANIA = :COMPANIA AND NUMERO = :NUMERO AND CONCEPTO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSEC":"$CONSEC","EXISTE":"$EXISTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecotizacion/getexistedetalleconconcepto">
		<call-query href="getSfdetallecotizacionGetexistedetalleconconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="insertSfdetallecotizacion" keyColumns="COMPANIA,TIPO,NUMERO,CONCEPTO,INMUEBLE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_DETALLE_COTIZACION (COMPANIA, TIPO, NUMERO, CONCEPTO, TARIFA, CANTIDAD, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_ICA, VALOR_DESCUENTO, VALOR_NETO, VALOR_COMPRA, VALOR_UTILIDAD, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, VALOR_UNITARIO, CREATED_BY, DATE_CREATED, INMUEBLE, TIPO_INMUEBLE) VALUES (:COMPANIA, :TIPO, :NUMERO, :CONCEPTO, :TARIFA, :CANTIDAD, :VALOR_BASE, :VALOR_IVA, :VALOR_RETE, :VALOR_ICA, :VALOR_DESCUENTO, :VALOR_NETO, :VALOR_COMPRA, :VALOR_UTILIDAD, :TERCERO, :SUCURSAL, :CENTRO_COSTO, :AUXILIAR, :VALOR_UNITARIO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :INMUEBLE, :TIPO_INMUEBLE)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_CONCEPTO":"$CONCEPTO","KEY_INMUEBLE":"$INMUEBLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="" name="TARIFA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_BASE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_IVA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_RETE" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_ICA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_NETO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_COMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UTILIDAD" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_UNITARIO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="INMUEBLE" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_INMUEBLE" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfdetallecotizacion">
		<call-query href="insertSfdetallecotizacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="VALOR_IVA" query-param="VALOR_IVA"/>
			<with-param name="VALOR_RETE" query-param="VALOR_RETE"/>
			<with-param name="VALOR_ICA" query-param="VALOR_ICA"/>
			<with-param name="VALOR_DESCUENTO" query-param="VALOR_DESCUENTO"/>
			<with-param name="VALOR_NETO" query-param="VALOR_NETO"/>
			<with-param name="VALOR_COMPRA" query-param="VALOR_COMPRA"/>
			<with-param name="VALOR_UTILIDAD" query-param="VALOR_UTILIDAD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="VALOR_UNITARIO" query-param="VALOR_UNITARIO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="INMUEBLE" query-param="INMUEBLE"/>
			<with-param name="TIPO_INMUEBLE" query-param="TIPO_INMUEBLE"/>

		</call-query>
	</resource>
	<query id="deleteSfdetallecotizacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_DETALLE_COTIZACION WHERE SF_DETALLE_COTIZACION.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_COTIZACION.TIPO= :KEY_TIPO AND SF_DETALLE_COTIZACION.NUMERO= :KEY_NUMERO AND SF_DETALLE_COTIZACION.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_COTIZACION.INMUEBLE= :KEY_INMUEBLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_INMUEBLE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfdetallecotizacion">
		<call-query href="deleteSfdetallecotizacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_INMUEBLE" query-param="KEY_INMUEBLE"/>

		</call-query>
	</resource>
	<query id="getSfdetallecotizacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SF_DETALLE_COTIZACION.COMPANIA, SF_DETALLE_COTIZACION.TIPO, SF_DETALLE_COTIZACION.NUMERO, SF_DETALLE_COTIZACION.CONCEPTO, SF_DETALLE_COTIZACION.TARIFA, SF_DETALLE_COTIZACION.CANTIDAD, SF_DETALLE_COTIZACION.VALOR_BASE, SF_DETALLE_COTIZACION.VALOR_IVA, SF_DETALLE_COTIZACION.VALOR_RETE, SF_DETALLE_COTIZACION.VALOR_ICA, SF_DETALLE_COTIZACION.VALOR_DESCUENTO, SF_DETALLE_COTIZACION.VALOR_NETO, SF_DETALLE_COTIZACION.VALOR_COMPRA, SF_DETALLE_COTIZACION.VALOR_UTILIDAD, SF_DETALLE_COTIZACION.TERCERO, SF_DETALLE_COTIZACION.SUCURSAL, SF_DETALLE_COTIZACION.CENTRO_COSTO, SF_DETALLE_COTIZACION.AUXILIAR, SF_DETALLE_COTIZACION.VALOR_UNITARIO, SF_DETALLE_COTIZACION.CREATED_BY,(TO_CHAR(SF_DETALLE_COTIZACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_DETALLE_COTIZACION.MODIFIED_BY,(TO_CHAR(SF_DETALLE_COTIZACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TERCERO.NUMEROLISTA,SF_DETALLE_COTIZACION.INMUEBLE, SF_DETALLE_COTIZACION.TIPO_INMUEBLE, INMUEBLE_FACTURACION.DENOMINACION FROM SF_DETALLE_COTIZACION INNER JOIN TERCERO ON (TERCERO.NIT = SF_DETALLE_COTIZACION.TERCERO) LEFT JOIN INMUEBLE_FACTURACION ON SF_DETALLE_COTIZACION.COMPANIA = INMUEBLE_FACTURACION.COMPANIA AND SF_DETALLE_COTIZACION.TIPO_INMUEBLE = INMUEBLE_FACTURACION.TIPO AND SF_DETALLE_COTIZACION.INMUEBLE = INMUEBLE_FACTURACION.CODIGOINMUEBLE) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END) LIKE UPPER(CONCAT(:TARIFA, '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(:CANTIDAD, '%')) AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END) LIKE UPPER(CONCAT(:VALOR_BASE, '%')) AND (CASE WHEN VALOR_IVA IS NULL THEN ' ' ELSE UPPER(VALOR_IVA) END) LIKE UPPER(CONCAT(:VALOR_IVA, '%')) AND (CASE WHEN VALOR_RETE IS NULL THEN ' ' ELSE UPPER(VALOR_RETE) END) LIKE UPPER(CONCAT(:VALOR_RETE, '%')) AND (CASE WHEN VALOR_ICA IS NULL THEN ' ' ELSE UPPER(VALOR_ICA) END) LIKE UPPER(CONCAT(:VALOR_ICA, '%')) AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END) LIKE UPPER(CONCAT(:VALOR_DESCUENTO, '%')) AND (CASE WHEN VALOR_NETO IS NULL THEN ' ' ELSE UPPER(VALOR_NETO) END) LIKE UPPER(CONCAT(:VALOR_NETO, '%')) AND (CASE WHEN VALOR_COMPRA IS NULL THEN ' ' ELSE UPPER(VALOR_COMPRA) END) LIKE UPPER(CONCAT(:VALOR_COMPRA, '%')) AND (CASE WHEN VALOR_UTILIDAD IS NULL THEN ' ' ELSE UPPER(VALOR_UTILIDAD) END) LIKE UPPER(CONCAT(:VALOR_UTILIDAD, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN VALOR_UNITARIO IS NULL THEN ' ' ELSE UPPER(VALOR_UNITARIO) END) LIKE UPPER(CONCAT(:VALOR_UNITARIO, '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(:CREATED_BY, '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(:DATE_CREATED, '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(:MODIFIED_BY, '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(:DATE_MODIFIED, '%')) AND (CASE WHEN NUMEROLISTA IS NULL THEN ' ' ELSE UPPER(NUMEROLISTA) END) LIKE UPPER(CONCAT(:NUMEROLISTA, '%')) AND (CASE WHEN INMUEBLE IS NULL THEN ' ' ELSE UPPER(INMUEBLE) END) LIKE UPPER(CONCAT(:INMUEBLE, '%')) AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END) LIKE UPPER(CONCAT(:DENOMINACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","CONCEPTO":"$CONCEPTO","TARIFA":"$TARIFA","CANTIDAD":"$CANTIDAD","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_ICA":"$VALOR_ICA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_NETO":"$VALOR_NETO","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_UTILIDAD":"$VALOR_UTILIDAD","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VALOR_UNITARIO":"$VALOR_UNITARIO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NUMEROLISTA":"$NUMEROLISTA","INMUEBLE":"$INMUEBLE","TIPO_INMUEBLE":"$TIPO_INMUEBLE(type:integer)","DENOMINACION":"$DENOMINACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_NETO" sqlType="STRING"/>
		<param name="VALOR_COMPRA" sqlType="STRING"/>
		<param name="VALOR_UTILIDAD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="VALOR_UNITARIO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="NUMEROLISTA" sqlType="STRING"/>
		<param name="INMUEBLE" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfdetallecotizacion">
		<call-query href="getSfdetallecotizacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="TARIFA" query-param="TARIFA"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="VALOR_IVA" query-param="VALOR_IVA"/>
			<with-param name="VALOR_RETE" query-param="VALOR_RETE"/>
			<with-param name="VALOR_ICA" query-param="VALOR_ICA"/>
			<with-param name="VALOR_DESCUENTO" query-param="VALOR_DESCUENTO"/>
			<with-param name="VALOR_NETO" query-param="VALOR_NETO"/>
			<with-param name="VALOR_COMPRA" query-param="VALOR_COMPRA"/>
			<with-param name="VALOR_UTILIDAD" query-param="VALOR_UTILIDAD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="VALOR_UNITARIO" query-param="VALOR_UNITARIO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="NUMEROLISTA" query-param="NUMEROLISTA"/>
			<with-param name="INMUEBLE" query-param="INMUEBLE"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfdetallecotizacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_DETALLE_COTIZACION.COMPANIA, SF_DETALLE_COTIZACION.TIPO, SF_DETALLE_COTIZACION.NUMERO, SF_DETALLE_COTIZACION.CONCEPTO, SF_DETALLE_COTIZACION.TARIFA, SF_DETALLE_COTIZACION.CANTIDAD, SF_DETALLE_COTIZACION.VALOR_BASE, SF_DETALLE_COTIZACION.VALOR_IVA, SF_DETALLE_COTIZACION.VALOR_RETE, SF_DETALLE_COTIZACION.VALOR_ICA, SF_DETALLE_COTIZACION.VALOR_DESCUENTO, SF_DETALLE_COTIZACION.VALOR_NETO, SF_DETALLE_COTIZACION.VALOR_COMPRA, SF_DETALLE_COTIZACION.VALOR_UTILIDAD, SF_DETALLE_COTIZACION.TERCERO, SF_DETALLE_COTIZACION.SUCURSAL, SF_DETALLE_COTIZACION.CENTRO_COSTO, SF_DETALLE_COTIZACION.AUXILIAR, SF_DETALLE_COTIZACION.VALOR_UNITARIO, SF_DETALLE_COTIZACION.CREATED_BY,(TO_CHAR(SF_DETALLE_COTIZACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_DETALLE_COTIZACION.MODIFIED_BY,(TO_CHAR(SF_DETALLE_COTIZACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, TERCERO.NUMEROLISTA,SF_DETALLE_COTIZACION.INMUEBLE, SF_DETALLE_COTIZACION.TIPO_INMUEBLE, INMUEBLE_FACTURACION.DENOMINACION FROM SF_DETALLE_COTIZACION INNER JOIN TERCERO ON (TERCERO.NIT = SF_DETALLE_COTIZACION.TERCERO) LEFT JOIN INMUEBLE_FACTURACION ON SF_DETALLE_COTIZACION.COMPANIA = INMUEBLE_FACTURACION.COMPANIA AND SF_DETALLE_COTIZACION.TIPO_INMUEBLE = INMUEBLE_FACTURACION.TIPO AND SF_DETALLE_COTIZACION.INMUEBLE = INMUEBLE_FACTURACION.CODIGOINMUEBLE) INI WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(:CONCEPTO, '%')) AND (CASE WHEN TARIFA IS NULL THEN ' ' ELSE UPPER(TARIFA) END) LIKE UPPER(CONCAT(:TARIFA, '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(:CANTIDAD, '%')) AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END) LIKE UPPER(CONCAT(:VALOR_BASE, '%')) AND (CASE WHEN VALOR_IVA IS NULL THEN ' ' ELSE UPPER(VALOR_IVA) END) LIKE UPPER(CONCAT(:VALOR_IVA, '%')) AND (CASE WHEN VALOR_RETE IS NULL THEN ' ' ELSE UPPER(VALOR_RETE) END) LIKE UPPER(CONCAT(:VALOR_RETE, '%')) AND (CASE WHEN VALOR_ICA IS NULL THEN ' ' ELSE UPPER(VALOR_ICA) END) LIKE UPPER(CONCAT(:VALOR_ICA, '%')) AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END) LIKE UPPER(CONCAT(:VALOR_DESCUENTO, '%')) AND (CASE WHEN VALOR_NETO IS NULL THEN ' ' ELSE UPPER(VALOR_NETO) END) LIKE UPPER(CONCAT(:VALOR_NETO, '%')) AND (CASE WHEN VALOR_COMPRA IS NULL THEN ' ' ELSE UPPER(VALOR_COMPRA) END) LIKE UPPER(CONCAT(:VALOR_COMPRA, '%')) AND (CASE WHEN VALOR_UTILIDAD IS NULL THEN ' ' ELSE UPPER(VALOR_UTILIDAD) END) LIKE UPPER(CONCAT(:VALOR_UTILIDAD, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN VALOR_UNITARIO IS NULL THEN ' ' ELSE UPPER(VALOR_UNITARIO) END) LIKE UPPER(CONCAT(:VALOR_UNITARIO, '%')) AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END) LIKE UPPER(CONCAT(:CREATED_BY, '%')) AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END) LIKE UPPER(CONCAT(:DATE_CREATED, '%')) AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END) LIKE UPPER(CONCAT(:MODIFIED_BY, '%')) AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END) LIKE UPPER(CONCAT(:DATE_MODIFIED, '%')) AND (CASE WHEN NUMEROLISTA IS NULL THEN ' ' ELSE UPPER(NUMEROLISTA) END) LIKE UPPER(CONCAT(:NUMEROLISTA, '%')) AND (CASE WHEN INMUEBLE IS NULL THEN ' ' ELSE UPPER(INMUEBLE) END) LIKE UPPER(CONCAT(:INMUEBLE, '%')) AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END) LIKE UPPER(CONCAT(:DENOMINACION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_NETO" sqlType="STRING"/>
		<param name="VALOR_COMPRA" sqlType="STRING"/>
		<param name="VALOR_UTILIDAD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="VALOR_UNITARIO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="NUMEROLISTA" sqlType="STRING"/>
		<param name="INMUEBLE" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>

	</query>
