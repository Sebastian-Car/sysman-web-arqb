			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_INMUEBLE" query-param="KEY_INMUEBLE"/>

		</call-query>
	</resource>
	<query id="updateSfdetallecotizacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_COTIZACION SET CONCEPTO=:CONCEPTO, TARIFA=:TARIFA, CANTIDAD=:CANTIDAD, VALOR_BASE=:VALOR_BASE, VALOR_IVA=:VALOR_IVA, VALOR_RETE=:VALOR_RETE, VALOR_ICA=:VALOR_ICA, VALOR_DESCUENTO=:VALOR_DESCUENTO, VALOR_NETO=:VALOR_NETO, VALOR_COMPRA=:VALOR_COMPRA, VALOR_UTILIDAD=:VALOR_UTILIDAD, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, VALOR_UNITARIO=:VALOR_UNITARIO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), INMUEBLE=:INMUEBLE, TIPO_INMUEBLE=:TIPO_INMUEBLE WHERE SF_DETALLE_COTIZACION.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_COTIZACION.TIPO= :KEY_TIPO AND SF_DETALLE_COTIZACION.NUMERO= :KEY_NUMERO AND SF_DETALLE_COTIZACION.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_COTIZACION.INMUEBLE= :KEY_INMUEBLE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="TARIFA" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_NETO" sqlType="STRING"/>
		<param name="VALOR_COMPRA" sqlType="STRING"/>
