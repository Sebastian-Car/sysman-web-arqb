	<query id="getSfdetallecotizacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, TIPO, NUMERO, CONCEPTO, TARIFA, CANTIDAD, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_ICA, VALOR_DESCUENTO, VALOR_NETO, VALOR_COMPRA, VALOR_UTILIDAD, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR, VALOR_UNITARIO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SF_DETALLE_COTIZACION WHERE SF_DETALLE_COTIZACION.COMPANIA= :KEY_COMPANIA AND SF_DETALLE_COTIZACION.TIPO= :KEY_TIPO AND SF_DETALLE_COTIZACION.NUMERO= :KEY_NUMERO AND SF_DETALLE_COTIZACION.CONCEPTO= :KEY_CONCEPTO AND SF_DETALLE_COTIZACION.INMUEBLE= :KEY_INMUEBLE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","CONCEPTO":"$CONCEPTO","TARIFA":"$TARIFA","CANTIDAD":"$CANTIDAD","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_ICA":"$VALOR_ICA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_NETO":"$VALOR_NETO","VALOR_COMPRA":"$VALOR_COMPRA","VALOR_UTILIDAD":"$VALOR_UTILIDAD","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","VALOR_UNITARIO":"$VALOR_UNITARIO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_INMUEBLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallecotizacion/data">
