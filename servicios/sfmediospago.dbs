<data name="sfmediospago" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfmediospagoCodigoYDescripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO,DESCRIPCION FROM SF_MEDIO_PAGO WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfmediospago/codigoydescripcion">
		<call-query href="getSfmediospagoCodigoYDescripcionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>