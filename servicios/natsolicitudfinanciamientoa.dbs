	<query id="insertNatsolicitudfinanciamientoa" keyColumns="COMPANIA,DP_NUMEDOCU,SUCURSAL,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_SOLICITUD_FINANCIAMIENTO_A (COMPANIA, SUCURSAL, ID_DE_EMPLEADO, DP_NUMEDOCU, FECHASOLICITUD, CONSECUTIVO, CONTROLFINANCIAENTIDAD, PUNTAJEULTIMAEVALUACION, CONTROLSANCION, MODALIDADSOLICITADA, NOMBREPROGRAMA, NOMBREESTABLECIMIENTO, ULTIMOPROMEDIO, VALORSOLICITADO, ANOSANTIGUEDAD, MESESANTIGUEDAD, DIASANTIGUEDAD, RELACIONCARGO, RELACIONFUNCIONES, VALORTOTAL, VALORAFINANCIAR, ANEXAMATRICULA, PROSPINSTITUTO, PROSPUNIVERSIDAD, ANEXAFORMULARIO, OBSERVACIONES, FECHAAPROBACIONCOMITE, NUMEROACTAAPROBACION, DURACIONPROGRAMA, SEMESTREACURSAR, HORARIO, FECHAMATRICULA, CALIFANTIGUEDAD, CALIFNOTAS, CALIFFUNCARGO, CALIFFUNSECRETARIA, PUNTAJETOTAL, ANEXANOTAS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :SUCURSAL, :ID_DE_EMPLEADO, :DP_NUMEDOCU, TO_DATE(:FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), :CONSECUTIVO, :CONTROLFINANCIAENTIDAD, :PUNTAJEULTIMAEVALUACION, :CONTROLSANCION, :MODALIDADSOLICITADA, :NOMBREPROGRAMA, :NOMBREESTABLECIMIENTO, :ULTIMOPROMEDIO, :VALORSOLICITADO, :ANOSANTIGUEDAD, :MESESANTIGUEDAD, :DIASANTIGUEDAD, :RELACIONCARGO, :RELACIONFUNCIONES, :VALORTOTAL, :VALORAFINANCIAR, :ANEXAMATRICULA, :PROSPINSTITUTO, :PROSPUNIVERSIDAD, :ANEXAFORMULARIO, :OBSERVACIONES, TO_DATE(:FECHAAPROBACIONCOMITE,'DD/MM/YYYY HH24:MI:SS'), :NUMEROACTAAPROBACION, :DURACIONPROGRAMA, :SEMESTREACURSAR, :HORARIO, TO_DATE(:FECHAMATRICULA,'DD/MM/YYYY HH24:MI:SS'), :CALIFANTIGUEDAD, :CALIFNOTAS, :CALIFFUNCARGO, :CALIFFUNSECRETARIA, :PUNTAJETOTAL, :ANEXANOTAS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DP_NUMEDOCU":"$DP_NUMEDOCU","KEY_SUCURSAL":"$SUCURSAL","KEY_FECHASOLICITUD":"$FECHASOLICITUD","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="FECHASOLICITUD" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="CONTROLFINANCIAENTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="PUNTAJEULTIMAEVALUACION" sqlType="STRING"/>
		<param defaultValue="0" name="CONTROLSANCION" sqlType="STRING"/>
		<param defaultValue="" name="MODALIDADSOLICITADA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBREPROGRAMA" sqlType="STRING"/>
		<param defaultValue="" name="NOMBREESTABLECIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="ULTIMOPROMEDIO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORSOLICITADO" sqlType="STRING"/>
		<param defaultValue="" name="ANOSANTIGUEDAD" sqlType="STRING"/>
		<param defaultValue="" name="MESESANTIGUEDAD" sqlType="STRING"/>
		<param defaultValue="" name="DIASANTIGUEDAD" sqlType="STRING"/>
		<param defaultValue="0" name="RELACIONCARGO" sqlType="STRING"/>
		<param defaultValue="0" name="RELACIONFUNCIONES" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORAFINANCIAR" sqlType="STRING"/>
		<param defaultValue="0" name="ANEXAMATRICULA" sqlType="STRING"/>
		<param defaultValue="0" name="PROSPINSTITUTO" sqlType="STRING"/>
		<param defaultValue="0" name="PROSPUNIVERSIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="ANEXAFORMULARIO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="" name="FECHAAPROBACIONCOMITE" sqlType="STRING"/>
		<param defaultValue="" name="NUMEROACTAAPROBACION" sqlType="STRING"/>
		<param defaultValue="" name="DURACIONPROGRAMA" sqlType="STRING"/>
		<param defaultValue="" name="SEMESTREACURSAR" sqlType="STRING"/>
