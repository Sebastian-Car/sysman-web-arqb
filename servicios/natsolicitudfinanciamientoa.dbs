	<query id="updateNatsolicitudfinanciamientoa" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_SOLICITUD_FINANCIAMIENTO_A SET DP_NUMEDOCU=:DP_NUMEDOCU, FECHASOLICITUD=TO_DATE(:FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS'), CONSECUTIVO=:CONSECUTIVO, CONTROLFINANCIAENTIDAD=:CONTROLFINANCIAENTIDAD, PUNTAJEULTIMAEVALUACION=:PUNTAJEULTIMAEVALUACION, CONTROLSANCION=:CONTROLSANCION, MODALIDADSOLICITADA=:MODALIDADSOLICITADA, NOMBREPROGRAMA=:NOMBREPROGRAMA, NOMBREESTABLECIMIENTO=:NOMBREESTABLECIMIENTO, ULTIMOPROMEDIO=:ULTIMOPROMEDIO, VALORSOLICITADO=:VALORSOLICITADO, ANOSANTIGUEDAD=:ANOSANTIGUEDAD, MESESANTIGUEDAD=:MESESANTIGUEDAD, DIASANTIGUEDAD=:DIASANTIGUEDAD, RELACIONCARGO=:RELACIONCARGO, RELACIONFUNCIONES=:RELACIONFUNCIONES, VALORTOTAL=:VALORTOTAL, VALORAFINANCIAR=:VALORAFINANCIAR, ANEXAMATRICULA=:ANEXAMATRICULA, PROSPINSTITUTO=:PROSPINSTITUTO, PROSPUNIVERSIDAD=:PROSPUNIVERSIDAD, ANEXAFORMULARIO=:ANEXAFORMULARIO, OBSERVACIONES=:OBSERVACIONES, FECHAAPROBACIONCOMITE=TO_DATE(:FECHAAPROBACIONCOMITE,'DD/MM/YYYY HH24:MI:SS'), NUMEROACTAAPROBACION=:NUMEROACTAAPROBACION, DURACIONPROGRAMA=:DURACIONPROGRAMA, SEMESTREACURSAR=:SEMESTREACURSAR, HORARIO=:HORARIO, FECHAMATRICULA=TO_DATE(:FECHAMATRICULA,'DD/MM/YYYY HH24:MI:SS'), CALIFANTIGUEDAD=:CALIFANTIGUEDAD, CALIFNOTAS=:CALIFNOTAS, CALIFFUNCARGO=:CALIFFUNCARGO, CALIFFUNSECRETARIA=:CALIFFUNSECRETARIA, PUNTAJETOTAL=:PUNTAJETOTAL, ANEXANOTAS=:ANEXANOTAS, COMPANIA=:COMPANIA, SUCURSAL=:SUCURSAL, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA= :KEY_COMPANIA AND NAT_SOLICITUD_FINANCIAMIENTO_A.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_SOLICITUD_FINANCIAMIENTO_A.SUCURSAL= :KEY_SUCURSAL AND NAT_SOLICITUD_FINANCIAMIENTO_A.FECHASOLICITUD= TO_DATE(:KEY_FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')  AND NAT_SOLICITUD_FINANCIAMIENTO_A.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
