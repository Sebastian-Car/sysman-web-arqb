		<param defaultValue="0" name="CALIFANTIGUEDAD" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFNOTAS" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFFUNCARGO" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFFUNSECRETARIA" sqlType="STRING"/>
		<param defaultValue="0" name="PUNTAJETOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="ANEXANOTAS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
