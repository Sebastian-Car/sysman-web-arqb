	<query id="deleteNatsolicitudfinanciamientoa" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_SOLICITUD_FINANCIAMIENTO_A WHERE NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA= :KEY_COMPANIA AND NAT_SOLICITUD_FINANCIAMIENTO_A.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_SOLICITUD_FINANCIAMIENTO_A.SUCURSAL= :KEY_SUCURSAL AND NAT_SOLICITUD_FINANCIAMIENTO_A.FECHASOLICITUD= TO_DATE(:KEY_FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')  AND NAT_SOLICITUD_FINANCIAMIENTO_A.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DP_NUMEDOCU" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_FECHASOLICITUD" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natsolicitudfinanciamientoa">
		<call-query href="deleteNatsolicitudfinanciamientoa">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DP_NUMEDOCU" query-param="KEY_DP_NUMEDOCU"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_FECHASOLICITUD" query-param="KEY_FECHASOLICITUD"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getNatsolicitudfinanciamientoaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA, NAT_SOLICITUD_FINANCIAMIENTO_A.SUCURSAL, NAT_SOLICITUD_FINANCIAMIENTO_A.DP_NUMEDOCU,(TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD, NAT_SOLICITUD_FINANCIAMIENTO_A.CONSECUTIVO,(TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.FECHAMATRICULA,'DD/MM/YYYY HH24:MI:SS')) FECHAMATRICULA, TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.ID_DE_EMPLEADO) ID_DE_EMPLEADO  FROM NAT_SOLICITUD_FINANCIAMIENTO_A WHERE NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA = :COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN FECHASOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHASOLICITUD) END)  LIKE UPPER(:FECHASOLICITUD || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHAMATRICULA IS NULL THEN ' ' ELSE UPPER(FECHAMATRICULA) END)  LIKE UPPER(:FECHAMATRICULA || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","DP_NUMEDOCU":"$DP_NUMEDOCU","FECHASOLICITUD":"$FECHASOLICITUD","CONSECUTIVO":"$CONSECUTIVO","FECHAMATRICULA":"$FECHAMATRICULA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="FECHASOLICITUD" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHAMATRICULA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natsolicitudfinanciamientoa">
		<call-query href="getNatsolicitudfinanciamientoaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="FECHASOLICITUD" query-param="FECHASOLICITUD"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHAMATRICULA" query-param="FECHAMATRICULA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatsolicitudfinanciamientoaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA, NAT_SOLICITUD_FINANCIAMIENTO_A.SUCURSAL, NAT_SOLICITUD_FINANCIAMIENTO_A.DP_NUMEDOCU,(TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD, NAT_SOLICITUD_FINANCIAMIENTO_A.CONSECUTIVO,(TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.FECHAMATRICULA,'DD/MM/YYYY HH24:MI:SS')) FECHAMATRICULA, TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.ID_DE_EMPLEADO) ID_DE_EMPLEADO  FROM NAT_SOLICITUD_FINANCIAMIENTO_A WHERE NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA = :COMPANIA) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN DP_NUMEDOCU IS NULL THEN ' ' ELSE UPPER(DP_NUMEDOCU) END)  LIKE UPPER(:DP_NUMEDOCU || '%')  AND (CASE WHEN FECHASOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHASOLICITUD) END)  LIKE UPPER(:FECHASOLICITUD || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHAMATRICULA IS NULL THEN ' ' ELSE UPPER(FECHAMATRICULA) END)  LIKE UPPER(:FECHAMATRICULA || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DP_NUMEDOCU" sqlType="STRING"/>
		<param name="FECHASOLICITUD" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHAMATRICULA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natsolicitudfinanciamientoa/numero">
		<call-query href="getNatsolicitudfinanciamientoaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DP_NUMEDOCU" query-param="DP_NUMEDOCU"/>
			<with-param name="FECHASOLICITUD" query-param="FECHASOLICITUD"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHAMATRICULA" query-param="FECHAMATRICULA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getNatsolicitudfinanciamientoaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT NAT_SOLICITUD_FINANCIAMIENTO_A.DP_NUMEDOCU,(TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHASOLICITUD, NAT_SOLICITUD_FINANCIAMIENTO_A.CONSECUTIVO, NAT_DATOS_PERSONALES.NUMERO_DCTO, CONCAT(APELLIDO1,CONCAT(' ',CONCAT(APELLIDO1,CONCAT(' ',NOMBRES) ) ) ) NOMBRES,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.CONTROLFINANCIAENTIDAD WHEN 0 THEN 'false' ELSE 'true' END) CONTROLFINANCIAENTIDAD, NAT_SOLICITUD_FINANCIAMIENTO_A.PUNTAJEULTIMAEVALUACION,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.CONTROLSANCION WHEN 0 THEN 'false' ELSE 'true' END) CONTROLSANCION, NAT_SOLICITUD_FINANCIAMIENTO_A.MODALIDADSOLICITADA, NAT_SOLICITUD_FINANCIAMIENTO_A.NOMBREPROGRAMA, NAT_SOLICITUD_FINANCIAMIENTO_A.NOMBREESTABLECIMIENTO, NAT_SOLICITUD_FINANCIAMIENTO_A.ULTIMOPROMEDIO, NAT_SOLICITUD_FINANCIAMIENTO_A.VALORSOLICITADO, NAT_SOLICITUD_FINANCIAMIENTO_A.ANOSANTIGUEDAD, NAT_SOLICITUD_FINANCIAMIENTO_A.MESESANTIGUEDAD, NAT_SOLICITUD_FINANCIAMIENTO_A.DIASANTIGUEDAD,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.RELACIONCARGO WHEN 0 THEN 'false' ELSE 'true' END) RELACIONCARGO,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.RELACIONFUNCIONES WHEN 0 THEN 'false' ELSE 'true' END) RELACIONFUNCIONES, NAT_SOLICITUD_FINANCIAMIENTO_A.VALORTOTAL, NAT_SOLICITUD_FINANCIAMIENTO_A.VALORAFINANCIAR,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.ANEXAMATRICULA WHEN 0 THEN 'false' ELSE 'true' END) ANEXAMATRICULA,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.PROSPINSTITUTO WHEN 0 THEN 'false' ELSE 'true' END) PROSPINSTITUTO,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.PROSPUNIVERSIDAD WHEN 0 THEN 'false' ELSE 'true' END) PROSPUNIVERSIDAD,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.ANEXAFORMULARIO WHEN 0 THEN 'false' ELSE 'true' END) ANEXAFORMULARIO, NAT_SOLICITUD_FINANCIAMIENTO_A.OBSERVACIONES,(TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.FECHAAPROBACIONCOMITE,'DD/MM/YYYY HH24:MI:SS')) FECHAAPROBACIONCOMITE, NAT_SOLICITUD_FINANCIAMIENTO_A.NUMEROACTAAPROBACION, NAT_SOLICITUD_FINANCIAMIENTO_A.DURACIONPROGRAMA, NAT_SOLICITUD_FINANCIAMIENTO_A.SEMESTREACURSAR, NAT_SOLICITUD_FINANCIAMIENTO_A.HORARIO,(TO_CHAR(NAT_SOLICITUD_FINANCIAMIENTO_A.FECHAMATRICULA,'DD/MM/YYYY HH24:MI:SS')) FECHAMATRICULA, NAT_SOLICITUD_FINANCIAMIENTO_A.CALIFANTIGUEDAD, NAT_SOLICITUD_FINANCIAMIENTO_A.CALIFNOTAS, NAT_SOLICITUD_FINANCIAMIENTO_A.CALIFFUNCARGO, NAT_SOLICITUD_FINANCIAMIENTO_A.CALIFFUNSECRETARIA, NAT_SOLICITUD_FINANCIAMIENTO_A.PUNTAJETOTAL,(CASE NAT_SOLICITUD_FINANCIAMIENTO_A.ANEXANOTAS WHEN 0 THEN 'false' ELSE 'true' END) ANEXANOTAS, NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA, NAT_SOLICITUD_FINANCIAMIENTO_A.SUCURSAL, EXTRACT(DAY FROM(FECHAMATRICULA - FECHASOLICITUD) ) DIASANTICIPACION, NAT_SOLICITUD_FINANCIAMIENTO_A.ID_DE_EMPLEADO FROM NAT_SOLICITUD_FINANCIAMIENTO_A INNER JOIN NAT_DATOS_PERSONALES ON NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA = NAT_DATOS_PERSONALES.COMPANIA AND NAT_SOLICITUD_FINANCIAMIENTO_A.DP_NUMEDOCU = NAT_DATOS_PERSONALES.NUMERO_DCTO AND NAT_SOLICITUD_FINANCIAMIENTO_A.SUCURSAL = NAT_DATOS_PERSONALES.SUCURSAL WHERE NAT_SOLICITUD_FINANCIAMIENTO_A.COMPANIA= :KEY_COMPANIA AND NAT_SOLICITUD_FINANCIAMIENTO_A.DP_NUMEDOCU= :KEY_DP_NUMEDOCU AND NAT_SOLICITUD_FINANCIAMIENTO_A.SUCURSAL= :KEY_SUCURSAL AND NAT_SOLICITUD_FINANCIAMIENTO_A.FECHASOLICITUD= TO_DATE(:KEY_FECHASOLICITUD,'DD/MM/YYYY HH24:MI:SS') AND NAT_SOLICITUD_FINANCIAMIENTO_A.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DP_NUMEDOCU":"$DP_NUMEDOCU","FECHASOLICITUD":"$FECHASOLICITUD","CONSECUTIVO":"$CONSECUTIVO","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRES":"$NOMBRES","CONTROLFINANCIAENTIDAD":"$CONTROLFINANCIAENTIDAD(type:boolean)","PUNTAJEULTIMAEVALUACION":"$PUNTAJEULTIMAEVALUACION","CONTROLSANCION":"$CONTROLSANCION(type:boolean)","MODALIDADSOLICITADA":"$MODALIDADSOLICITADA","NOMBREPROGRAMA":"$NOMBREPROGRAMA","NOMBREESTABLECIMIENTO":"$NOMBREESTABLECIMIENTO","ULTIMOPROMEDIO":"$ULTIMOPROMEDIO","VALORSOLICITADO":"$VALORSOLICITADO","ANOSANTIGUEDAD":"$ANOSANTIGUEDAD(type:integer)","MESESANTIGUEDAD":"$MESESANTIGUEDAD(type:integer)","DIASANTIGUEDAD":"$DIASANTIGUEDAD(type:integer)","RELACIONCARGO":"$RELACIONCARGO(type:boolean)","RELACIONFUNCIONES":"$RELACIONFUNCIONES(type:boolean)","VALORTOTAL":"$VALORTOTAL","VALORAFINANCIAR":"$VALORAFINANCIAR","ANEXAMATRICULA":"$ANEXAMATRICULA(type:boolean)","PROSPINSTITUTO":"$PROSPINSTITUTO(type:boolean)","PROSPUNIVERSIDAD":"$PROSPUNIVERSIDAD(type:boolean)","ANEXAFORMULARIO":"$ANEXAFORMULARIO(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","FECHAAPROBACIONCOMITE":"$FECHAAPROBACIONCOMITE","NUMEROACTAAPROBACION":"$NUMEROACTAAPROBACION","DURACIONPROGRAMA":"$DURACIONPROGRAMA","SEMESTREACURSAR":"$SEMESTREACURSAR","HORARIO":"$HORARIO","FECHAMATRICULA":"$FECHAMATRICULA","CALIFANTIGUEDAD":"$CALIFANTIGUEDAD","CALIFNOTAS":"$CALIFNOTAS","CALIFFUNCARGO":"$CALIFFUNCARGO","CALIFFUNSECRETARIA":"$CALIFFUNSECRETARIA","PUNTAJETOTAL":"$PUNTAJETOTAL","ANEXANOTAS":"$ANEXANOTAS(type:boolean)","COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","DIASANTICIPACION":"$DIASANTICIPACION(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)"}]}}		</result>
