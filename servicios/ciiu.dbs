		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ID_CIIU, CLASE_RIESGO, COD_CIIU, COD_SUBACTIVIDAD FROM CIIU WHERE COMPANIA = :COMPANIA AND ACTIVO != 0 ORDER BY 1) INI WHERE (CASE WHEN ID_CIIU IS NULL THEN ' ' ELSE UPPER(ID_CIIU) END) LIKE UPPER(CONCAT(:ID_CIIU, '%')) AND (CASE WHEN CLASE_RIESGO IS NULL THEN ' ' ELSE UPPER(CLASE_RIESGO) END) LIKE UPPER(CONCAT(:CLASE_RIESGO, '%')) AND (CASE WHEN COD_CIIU IS NULL THEN ' ' ELSE UPPER(COD_CIIU) END) LIKE UPPER(CONCAT(:COD_CIIU, '%')) AND (CASE WHEN COD_SUBACTIVIDAD IS NULL THEN ' ' ELSE UPPER(COD_SUBACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_SUBACTIVIDAD), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_CIIU":"$ID_CIIU(type:integer)","CLASE_RIESGO":"$CLASE_RIESGO","COD_CIIU":"$COD_CIIU","COD_SUBACTIVIDAD":"$COD_SUBACTIVIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_CIIU" sqlType="STRING"/>
		<param name="CLASE_RIESGO" sqlType="STRING"/>
		<param name="COD_CIIU" sqlType="STRING"/>
		<param name="COD_SUBACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

