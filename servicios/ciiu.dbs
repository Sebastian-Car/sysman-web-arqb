	</resource>
	<query id="getCiiuNumGetcodciiuQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ID_CIIU, CLASE_RIESGO, COD_CIIU, COD_SUBACTIVIDAD FROM CIIU WHERE COMPANIA = :COMPANIA AND ACTIVO != 0 ORDER BY 1) INI WHERE (CASE WHEN ID_CIIU IS NULL THEN ' ' ELSE UPPER(ID_CIIU) END) LIKE UPPER(CONCAT(:ID_CIIU, '%')) AND (CASE WHEN CLASE_RIESGO IS NULL THEN ' ' ELSE UPPER(CLASE_RIESGO) END) LIKE UPPER(CONCAT(:CLASE_RIESGO, '%')) AND (CASE WHEN COD_CIIU IS NULL THEN ' ' ELSE UPPER(COD_CIIU) END) LIKE UPPER(CONCAT(:COD_CIIU, '%')) AND (CASE WHEN COD_SUBACTIVIDAD IS NULL THEN ' ' ELSE UPPER(COD_SUBACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_SUBACTIVIDAD), '%')) ) A) FIN</sql>
