<data name="ciiu" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCiiuPagGetciiuQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ID_CIIU, CLASE_RIESGO, COD_CIIU, COD_SUBACTIVIDAD, DESCRIPCION FROM CIIU WHERE COMPANIA = :COMPANIA AND ACTIVO != 0 ORDER BY 1) INI WHERE (CASE WHEN ID_CIIU IS NULL THEN ' ' ELSE UPPER(ID_CIIU) END) LIKE UPPER(CONCAT(:ID_CIIU, '%')) AND (CASE WHEN CLASE_RIESGO IS NULL THEN ' ' ELSE UPPER(CLASE_RIESGO) END) LIKE UPPER(CONCAT(:CLASE_RIESGO, '%')) AND (CASE WHEN COD_CIIU IS NULL THEN ' ' ELSE UPPER(COD_CIIU) END) LIKE UPPER(CONCAT(:COD_CIIU, '%')) AND (CASE WHEN COD_SUBACTIVIDAD IS NULL THEN ' ' ELSE UPPER(COD_SUBACTIVIDAD) END) LIKE UPPER(CONCAT(:COD_SUBACTIVIDAD, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_CIIU":"$ID_CIIU(type:integer)","CLASE_RIESGO":"$CLASE_RIESGO","COD_CIIU":"$COD_CIIU","COD_SUBACTIVIDAD":"$COD_SUBACTIVIDAD","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_CIIU" sqlType="STRING"/>
		<param name="CLASE_RIESGO" sqlType="STRING"/>
		<param name="COD_CIIU" sqlType="STRING"/>
		<param name="COD_SUBACTIVIDAD" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ciiu/getciiu/pag">
		<call-query href="getCiiuPagGetciiuQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_CIIU" query-param="ID_CIIU"/>
			<with-param name="CLASE_RIESGO" query-param="CLASE_RIESGO"/>
			<with-param name="COD_CIIU" query-param="COD_CIIU"/>
			<with-param name="COD_SUBACTIVIDAD" query-param="COD_SUBACTIVIDAD"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCiiuNumGetciiuQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ID_CIIU, CLASE_RIESGO, COD_CIIU, COD_SUBACTIVIDAD, DESCRIPCION FROM CIIU WHERE COMPANIA = :COMPANIA AND ACTIVO != 0 ORDER BY 1) INI WHERE (CASE WHEN ID_CIIU IS NULL THEN ' ' ELSE UPPER(ID_CIIU) END) LIKE UPPER(CONCAT(:ID_CIIU, '%')) AND (CASE WHEN CLASE_RIESGO IS NULL THEN ' ' ELSE UPPER(CLASE_RIESGO) END) LIKE UPPER(CONCAT(:CLASE_RIESGO, '%')) AND (CASE WHEN COD_CIIU IS NULL THEN ' ' ELSE UPPER(COD_CIIU) END) LIKE UPPER(CONCAT(:COD_CIIU, '%')) AND (CASE WHEN COD_SUBACTIVIDAD IS NULL THEN ' ' ELSE UPPER(COD_SUBACTIVIDAD) END) LIKE UPPER(CONCAT(:COD_SUBACTIVIDAD, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_CIIU" sqlType="STRING"/>
		<param name="CLASE_RIESGO" sqlType="STRING"/>
		<param name="COD_CIIU" sqlType="STRING"/>
		<param name="COD_SUBACTIVIDAD" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ciiu/getciiu/num">
		<call-query href="getCiiuNumGetciiuQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_CIIU" query-param="ID_CIIU"/>
			<with-param name="CLASE_RIESGO" query-param="CLASE_RIESGO"/>
			<with-param name="COD_CIIU" query-param="COD_CIIU"/>
			<with-param name="COD_SUBACTIVIDAD" query-param="COD_SUBACTIVIDAD"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
