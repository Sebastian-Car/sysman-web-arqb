<data name="sftipoconcepto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSftipoconceptoListatipoconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGO, NOMBRE FROM SF_TIPO_CONCEPTO WHERE ARRENDAMIENTO IN (:VALOR)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="VALOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftipoconcepto/listatipoconcepto">
		<call-query href="getSftipoconceptoListatipoconceptoQuery">
			<with-param name="VALOR" query-param="VALOR"/>

		</call-query>
	</resource>

</data>