	<query id="deleteFinanciablesdenomina" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FINANCIABLES_DE_NOMINA WHERE FINANCIABLES_DE_NOMINA.COMPANIA= :KEY_COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND FINANCIABLES_DE_NOMINA.ANO= :KEY_ANO AND FINANCIABLES_DE_NOMINA.MES= :KEY_MES AND FINANCIABLES_DE_NOMINA.PERIODO= :KEY_PERIODO AND FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="INTEGER"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_MES" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="INTEGER"/>

	</query>
