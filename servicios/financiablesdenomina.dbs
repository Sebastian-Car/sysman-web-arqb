	<query id="updateFinanciablesdenomina" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FINANCIABLES_DE_NOMINA SET COMPANIA=:COMPANIA, ID_DE_PROCESO=:ID_DE_PROCESO, ANO=:ANO, MES=:MES, PERIODO=:PERIODO, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, ID_DE_CONCEPTO=:ID_DE_CONCEPTO, MONTO_INICIAL=:MONTO_INICIAL, NUMERO_DE_CUOTAS=:NUMERO_DE_CUOTAS, SALDO=:SALDO, VALOR_CUOTA=:VALOR_CUOTA, CUOTAFIJA=:CUOTAFIJA, OBSERVACIONES=:OBSERVACIONES, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), VALDESCUENTO=:VALDESCUENTO, INDPREPARADO=:INDPREPARADO, PERIODOCOBRO=:PERIODOCOBRO, NLIBRANZA=:NLIBRANZA, FECHA_LIBRANZA=TO_DATE(:FECHA_LIBRANZA,'DD/MM/YYYY HH24:MI:SS'), FECHAFIN=TO_DATE(:FECHAFIN,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FINANCIABLES_DE_NOMINA.COMPANIA= :KEY_COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND FINANCIABLES_DE_NOMINA.ANO= :KEY_ANO AND FINANCIABLES_DE_NOMINA.MES= :KEY_MES AND FINANCIABLES_DE_NOMINA.PERIODO= :KEY_PERIODO AND FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

