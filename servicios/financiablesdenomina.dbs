			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getFinanciablesdenominaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT FINANCIABLES_DE_NOMINA.COMPANIA, FINANCIABLES_DE_NOMINA.ID_DE_PROCESO, FINANCIABLES_DE_NOMINA.ANO, FINANCIABLES_DE_NOMINA.PERIODO, FINANCIABLES_DE_NOMINA.MES, FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO NUMERO_DCTO, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBREEMPLEADO, FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, FINANCIABLES_DE_NOMINA.MONTO_INICIAL, FINANCIABLES_DE_NOMINA.NUMERO_DE_CUOTAS, FINANCIABLES_DE_NOMINA.SALDO, FINANCIABLES_DE_NOMINA.VALOR_CUOTA FROM FINANCIABLES_DE_NOMINA INNER JOIN CONCEPTOS ON FINANCIABLES_DE_NOMINA.COMPANIA = CONCEPTOS.COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO INNER JOIN PERSONAL ON FINANCIABLES_DE_NOMINA.COMPANIA = PERSONAL.COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN TERCERO ON PERSONAL.COMPANIA = TERCERO.COMPANIA AND PERSONAL.NUMERO_DCTO = TERCERO.NIT AND PERSONAL.SUCURSAL = TERCERO.SUCURSAL WHERE FINANCIABLES_DE_NOMINA.COMPANIA =:COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_PROCESO =:PROCESO AND FINANCIABLES_DE_NOMINA.ANO =:ANO AND FINANCIABLES_DE_NOMINA.MES =:MES AND FINANCIABLES_DE_NOMINA.PERIODO =:PERIODO ORDER BY FINANCIABLES_DE_NOMINA.ID_DE_PROCESO, FINANCIABLES_DE_NOMINA.ANO, FINANCIABLES_DE_NOMINA.MES, FINANCIABLES_DE_NOMINA.PERIODO, FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBREEMPLEADO IS NULL THEN ' ' ELSE UPPER(NOMBREEMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREEMPLEADO), '%')) AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN MONTO_INICIAL IS NULL THEN ' ' ELSE UPPER(MONTO_INICIAL) END) LIKE UPPER(CONCAT(:MONTO_INICIAL, '%')) AND (CASE WHEN NUMERO_DE_CUOTAS IS NULL THEN ' ' ELSE UPPER(NUMERO_DE_CUOTAS) END) LIKE UPPER(CONCAT(:NUMERO_DE_CUOTAS, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN VALOR_CUOTA IS NULL THEN ' ' ELSE UPPER(VALOR_CUOTA) END) LIKE UPPER(CONCAT(:VALOR_CUOTA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO(type:integer)","MES":"$MES(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NUMERO_DCTO":"$NUMERO_DCTO","NOMBREEMPLEADO":"$NOMBREEMPLEADO","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","MONTO_INICIAL":"$MONTO_INICIAL","NUMERO_DE_CUOTAS":"$NUMERO_DE_CUOTAS","SALDO":"$SALDO","VALOR_CUOTA":"$VALOR_CUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBREEMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="MONTO_INICIAL" sqlType="STRING"/>
		<param name="NUMERO_DE_CUOTAS" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="VALOR_CUOTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="financiablesdenomina">
		<call-query href="getFinanciablesdenominaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBREEMPLEADO" query-param="NOMBREEMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="MONTO_INICIAL" query-param="MONTO_INICIAL"/>
			<with-param name="NUMERO_DE_CUOTAS" query-param="NUMERO_DE_CUOTAS"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="VALOR_CUOTA" query-param="VALOR_CUOTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFinanciablesdenominaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT FINANCIABLES_DE_NOMINA.COMPANIA, FINANCIABLES_DE_NOMINA.ID_DE_PROCESO, FINANCIABLES_DE_NOMINA.ANO, FINANCIABLES_DE_NOMINA.PERIODO, FINANCIABLES_DE_NOMINA.MES, FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO, PERSONAL.NUMERO_DCTO NUMERO_DCTO, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBREEMPLEADO, FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, FINANCIABLES_DE_NOMINA.MONTO_INICIAL, FINANCIABLES_DE_NOMINA.NUMERO_DE_CUOTAS, FINANCIABLES_DE_NOMINA.SALDO, FINANCIABLES_DE_NOMINA.VALOR_CUOTA FROM FINANCIABLES_DE_NOMINA INNER JOIN CONCEPTOS ON FINANCIABLES_DE_NOMINA.COMPANIA = CONCEPTOS.COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO INNER JOIN PERSONAL ON FINANCIABLES_DE_NOMINA.COMPANIA = PERSONAL.COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN TERCERO ON PERSONAL.COMPANIA = TERCERO.COMPANIA AND PERSONAL.NUMERO_DCTO = TERCERO.NIT AND PERSONAL.SUCURSAL = TERCERO.SUCURSAL WHERE FINANCIABLES_DE_NOMINA.COMPANIA =:COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_PROCESO =:PROCESO AND FINANCIABLES_DE_NOMINA.ANO =:ANO AND FINANCIABLES_DE_NOMINA.MES =:MES AND FINANCIABLES_DE_NOMINA.PERIODO =:PERIODO ORDER BY FINANCIABLES_DE_NOMINA.ID_DE_PROCESO, FINANCIABLES_DE_NOMINA.ANO, FINANCIABLES_DE_NOMINA.MES, FINANCIABLES_DE_NOMINA.PERIODO, FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO) INI WHERE (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBREEMPLEADO IS NULL THEN ' ' ELSE UPPER(NOMBREEMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREEMPLEADO), '%')) AND (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN MONTO_INICIAL IS NULL THEN ' ' ELSE UPPER(MONTO_INICIAL) END) LIKE UPPER(CONCAT(:MONTO_INICIAL, '%')) AND (CASE WHEN NUMERO_DE_CUOTAS IS NULL THEN ' ' ELSE UPPER(NUMERO_DE_CUOTAS) END) LIKE UPPER(CONCAT(:NUMERO_DE_CUOTAS, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN VALOR_CUOTA IS NULL THEN ' ' ELSE UPPER(VALOR_CUOTA) END) LIKE UPPER(CONCAT(:VALOR_CUOTA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBREEMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="MONTO_INICIAL" sqlType="STRING"/>
		<param name="NUMERO_DE_CUOTAS" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="VALOR_CUOTA" sqlType="STRING"/>

	</query>
