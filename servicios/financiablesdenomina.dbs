	<query id="getFinanciablesdenominaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT FINANCIABLES_DE_NOMINA.COMPANIA, ID_DE_PROCESO, FINANCIABLES_DE_NOMINA.ANO, MES, PERIODO, FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO, ID_DE_CONCEPTO, MONTO_INICIAL, NUMERO_DE_CUOTAS, SALDO, VALOR_CUOTA,(CASE CUOTAFIJA WHEN 0 THEN 'false' ELSE 'true' END) CUOTAFIJA, FINANCIABLES_DE_NOMINA.OBSERVACIONES,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, VALDESCUENTO,(CASE INDPREPARADO WHEN 0 THEN 'false' ELSE 'true' END) INDPREPARADO, PERIODOCOBRO, NLIBRANZA,(TO_CHAR(FECHA_LIBRANZA,'DD/MM/YYYY HH24:MI:SS')) FECHA_LIBRANZA,(TO_CHAR(FECHAFIN,'DD/MM/YYYY HH24:MI:SS')) FECHAFIN,(TO_CHAR(FINANCIABLES_DE_NOMINA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, FINANCIABLES_DE_NOMINA.CREATED_BY,(TO_CHAR(FINANCIABLES_DE_NOMINA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, FINANCIABLES_DE_NOMINA.MODIFIED_BY, PERSONAL.NUMERO_DCTO, CONCAT(TERCERO.APELLIDO1,CONCAT(' ',CONCAT(TERCERO.APELLIDO2,CONCAT(' ',CONCAT(TERCERO.NOMBRE1,CONCAT(' ',TERCERO.NOMBRE2) ) ) ) ) ) NOMBREEMPLEADO FROM FINANCIABLES_DE_NOMINA INNER JOIN PERSONAL ON FINANCIABLES_DE_NOMINA.COMPANIA = PERSONAL.COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO = PERSONAL.ID_DE_EMPLEADO LEFT JOIN TERCERO ON PERSONAL.COMPANIA = TERCERO.COMPANIA AND PERSONAL.NUMERO_DCTO = TERCERO.NIT AND PERSONAL.SUCURSAL = TERCERO.SUCURSAL WHERE FINANCIABLES_DE_NOMINA.COMPANIA= :KEY_COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND FINANCIABLES_DE_NOMINA.ANO= :KEY_ANO AND FINANCIABLES_DE_NOMINA.MES= :KEY_MES AND FINANCIABLES_DE_NOMINA.PERIODO= :KEY_PERIODO AND FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","MONTO_INICIAL":"$MONTO_INICIAL","NUMERO_DE_CUOTAS":"$NUMERO_DE_CUOTAS","SALDO":"$SALDO","VALOR_CUOTA":"$VALOR_CUOTA","CUOTAFIJA":"$CUOTAFIJA(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","FECHA":"$FECHA","VALDESCUENTO":"$VALDESCUENTO","INDPREPARADO":"$INDPREPARADO(type:boolean)","PERIODOCOBRO":"$PERIODOCOBRO(type:integer)","NLIBRANZA":"$NLIBRANZA","FECHA_LIBRANZA":"$FECHA_LIBRANZA","FECHAFIN":"$FECHAFIN","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","NUMERO_DCTO":"$NUMERO_DCTO","NOMBREEMPLEADO":"$NOMBREEMPLEADO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="financiablesdenomina/data">
