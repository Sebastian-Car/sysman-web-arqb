	<query id="insertFinanciablesdenomina" keyColumns="COMPANIA,ID_DE_PROCESO,ANO,MES,PERIODO,ID_DE_EMPLEADO,ID_DE_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FINANCIABLES_DE_NOMINA (COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO, MONTO_INICIAL, NUMERO_DE_CUOTAS, SALDO, VALOR_CUOTA, CUOTAFIJA, OBSERVACIONES, FECHA, VALDESCUENTO, INDPREPARADO, PERIODOCOBRO, NLIBRANZA, FECHA_LIBRANZA, FECHAFIN, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_PROCESO, :ANO, :MES, :PERIODO, :ID_DE_EMPLEADO, :ID_DE_CONCEPTO, :MONTO_INICIAL, :NUMERO_DE_CUOTAS, :SALDO, :VALOR_CUOTA, :CUOTAFIJA, :OBSERVACIONES, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :VALDESCUENTO, :INDPREPARADO, :PERIODOCOBRO, :NLIBRANZA, TO_DATE(:FECHA_LIBRANZA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_PERIODO":"$PERIODO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
