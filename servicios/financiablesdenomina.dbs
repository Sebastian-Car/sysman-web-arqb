<data name="financiablesdenomina" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFinanciablesdenominaTodosporaniocalculonominaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  F.COMPANIA, F.ID_DE_PROCESO, F.ANO, F.MES, F.PERIODO, F.ID_DE_EMPLEADO, F.ID_DE_CONCEPTO, F.MONTO_INICIAL, F.NUMERO_DE_CUOTAS, F.SALDO, F.VALOR_CUOTA,(CASE F.CUOTAFIJA WHEN 0 THEN 'false' ELSE 'true' END) CUOTAFIJA, F.OBSERVACIONES, F.INTERES, F.VALDESCUENTO,(CASE F.INDPREPARADO WHEN 0 THEN 'false' ELSE 'true' END) INDPREPARADO, F.PERIODOCOBRO, F.NLIBRANZA, F.TOTAL_CUOTAS,(TO_CHAR(F.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(F.FECHAFIN,'DD/MM/YYYY HH24:MI:SS')) FECHAFIN,(TO_CHAR(F.FECHA_LIBRANZA,'DD/MM/YYYY HH24:MI:SS')) FECHA_LIBRANZA,(CASE C.PERMITE_DUPLICAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_DUPLICAR FROM FINANCIABLES_DE_NOMINA F INNER JOIN CONCEPTOS C ON ( F.COMPANIA = C.COMPANIA) AND (F.ID_DE_CONCEPTO = C.ID_DE_CONCEPTO) WHERE F.COMPANIA = :COMPANIA AND F.ID_DE_PROCESO =:PROCESO AND F.ANO = :ANO AND F.MES = :MES AND F.PERIODO = :PERIODO AND F.ID_DE_EMPLEADO BETWEEN :EMPLEADOINI AND :EMPLEADOFIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","ANO":"$ANO(type:integer)","MES":"$MES(type:integer)","PERIODO":"$PERIODO(type:integer)","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","MONTO_INICIAL":"$MONTO_INICIAL","NUMERO_DE_CUOTAS":"$NUMERO_DE_CUOTAS","SALDO":"$SALDO","VALOR_CUOTA":"$VALOR_CUOTA","CUOTAFIJA":"$CUOTAFIJA(type:boolean)","OBSERVACIONES":"$OBSERVACIONES","INTERES":"$INTERES","VALDESCUENTO":"$VALDESCUENTO","INDPREPARADO":"$INDPREPARADO(type:boolean)","PERIODOCOBRO":"$PERIODOCOBRO(type:integer)","NLIBRANZA":"$NLIBRANZA","TOTAL_CUOTAS":"$TOTAL_CUOTAS","FECHA":"$FECHA","FECHAFIN":"$FECHAFIN","FECHA_LIBRANZA":"$FECHA_LIBRANZA","PERMITE_DUPLICAR":"$PERMITE_DUPLICAR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="EMPLEADOINI" sqlType="STRING"/>
		<param name="EMPLEADOFIN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="financiablesdenomina/todosporaniocalculonomina">
		<call-query href="getFinanciablesdenominaTodosporaniocalculonominaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="EMPLEADOINI" query-param="EMPLEADOINI"/>
			<with-param name="EMPLEADOFIN" query-param="EMPLEADOFIN"/>

		</call-query>
	</resource>
	<query id="updateFinanciablesdenominaDuplicarfinancalculo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FINANCIABLES_DE_NOMINA SET VALDESCUENTO = :VALOR WHERE FINANCIABLES_DE_NOMINA.COMPANIA= :KEY_COMPANIA AND FINANCIABLES_DE_NOMINA.ID_DE_PROCESO= :KEY_ID_DE_PROCESO AND FINANCIABLES_DE_NOMINA.ANO= :KEY_ANO AND FINANCIABLES_DE_NOMINA.MES= :KEY_MES AND FINANCIABLES_DE_NOMINA.PERIODO= :KEY_PERIODO AND FINANCIABLES_DE_NOMINA.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND FINANCIABLES_DE_NOMINA.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_PROCESO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_MES" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="financiablesdenomina/duplicarfinancalculo">
		<call-query href="updateFinanciablesdenominaDuplicarfinancalculo">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_PROCESO" query-param="KEY_ID_DE_PROCESO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_MES" query-param="KEY_MES"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="insertFinanciablesdenominaFinanciabledesdeexel" keyColumns="COMPANIA,ID_DE_PROCESO,ANO,MES,PERIODO,ID_DE_EMPLEADO,ID_DE_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FINANCIABLES_DE_NOMINA (COMPANIA, ID_DE_PROCESO, ANO, MES, PERIODO, ID_DE_EMPLEADO, ID_DE_CONCEPTO, MONTO_INICIAL, NUMERO_DE_CUOTAS, SALDO, VALOR_CUOTA, CUOTAFIJA, OBSERVACIONES, INTERES, VALDESCUENTO, INDPREPARADO, PERIODOCOBRO, NLIBRANZA, TOTAL_CUOTAS, FECHA, FECHAFIN, FECHA_LIBRANZA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_PROCESO, :ANO, :MES, :PERIODO, :ID_DE_EMPLEADO, :ID_DE_CONCEPTO, :MONTO_INICIAL, :NUMERO_DE_CUOTAS, :SALDO, :VALOR_CUOTA, :CUOTAFIJA, :OBSERVACIONES, :INTERES, :VALDESCUENTO, :INDPREPARADO, :PERIODOCOBRO, :NLIBRANZA, :TOTAL_CUOTAS, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAFIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_LIBRANZA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_PROCESO":"$ID_DE_PROCESO(type:integer)","KEY_ANO":"$ANO(type:integer)","KEY_MES":"$MES(type:integer)","KEY_PERIODO":"$PERIODO(type:integer)","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
