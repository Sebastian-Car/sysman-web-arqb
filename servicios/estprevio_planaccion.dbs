			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstprevio_planaccionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ESTPREVIO_PLANACCION.VIGENCIA, BP_PLAN_INDICATIVO.DESCRIPCION "ACTIVIDAD_PLAN_INDICATIVO", BP_PLAN_INDICATIVO.CODIGOBPIM "FICHA_BPIN", ESTPREVIO_PLANACCION.ID_PLAN, BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO "SALDO_ITEM", ESTPREVIO_PLANACCION.PLAN_INDICATIVO, ESTPREVIO_PLANACCION.COMPANIA, ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PI, ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV, ESTPREVIO_PLANACCION.CODIGO_PAV, ESTPREVIO_PLANACCION.COD_ESTUDIO, ESTPREVIO_PLANACCION.VIGENCIA_PAV, ESTPREVIO_PLANACCION.CREATED_BY, ESTPREVIO_PLANACCION.MODIFIED_BY,(TO_CHAR(ESTPREVIO_PLANACCION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(ESTPREVIO_PLANACCION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM ESTPREVIO_PLANACCION INNER JOIN BP_PLAN_INDICATIVO ON ESTPREVIO_PLANACCION.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND ESTPREVIO_PLANACCION.PLAN_INDICATIVO = BP_PLAN_INDICATIVO.ID AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PI = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL INNER JOIN BP_PLAN_ADQUISICIONES_VIGENCIA ON ESTPREVIO_PLANACCION.COMPANIA = BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL AND ESTPREVIO_PLANACCION.ID_PLAN = BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN AND ESTPREVIO_PLANACCION.CODIGO_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO AND ESTPREVIO_PLANACCION.VIGENCIA_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND ESTPREVIO_PLANACCION.COD_ESTUDIO = :ESTUDIO) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN ACTIVIDAD_PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD_PLAN_INDICATIVO) END)  LIKE UPPER( '%' || :ACTIVIDAD_PLAN_INDICATIVO || '%')  AND (CASE WHEN FICHA_BPIN IS NULL THEN ' ' ELSE UPPER(FICHA_BPIN) END)  LIKE UPPER(:FICHA_BPIN || '%')  AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN SALDO_ITEM IS NULL THEN ' ' ELSE UPPER(SALDO_ITEM) END)  LIKE UPPER(:SALDO_ITEM || '%')  AND (CASE WHEN PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(PLAN_INDICATIVO) END)  LIKE UPPER( '%' || :PLAN_INDICATIVO || '%')  AND (CASE WHEN VIGENCIA_INICIAL_PI IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL_PI) END)  LIKE UPPER( '%' || :VIGENCIA_INICIAL_PI || '%')  AND (CASE WHEN VIGENCIA_INICIAL_PAV IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL_PAV) END)  LIKE UPPER( '%' || :VIGENCIA_INICIAL_PAV || '%')  AND (CASE WHEN CODIGO_PAV IS NULL THEN ' ' ELSE UPPER(CODIGO_PAV) END)  LIKE UPPER( '%' || :CODIGO_PAV || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER( '%' || :COD_ESTUDIO || '%')  AND (CASE WHEN VIGENCIA_PAV IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PAV) END)  LIKE UPPER( '%' || :VIGENCIA_PAV || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER( '%' || :DATE_MODIFIED || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ACTIVIDAD_PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="FICHA_BPIN" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="SALDO_ITEM" sqlType="STRING"/>
		<param name="PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL_PI" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL_PAV" sqlType="STRING"/>
		<param name="CODIGO_PAV" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA_PAV" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estprevio_planaccion/numero">
		<call-query href="getEstprevio_planaccionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTUDIO" query-param="ESTUDIO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ACTIVIDAD_PLAN_INDICATIVO" query-param="ACTIVIDAD_PLAN_INDICATIVO"/>
			<with-param name="FICHA_BPIN" query-param="FICHA_BPIN"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="SALDO_ITEM" query-param="SALDO_ITEM"/>
			<with-param name="PLAN_INDICATIVO" query-param="PLAN_INDICATIVO"/>
			<with-param name="VIGENCIA_INICIAL_PI" query-param="VIGENCIA_INICIAL_PI"/>
