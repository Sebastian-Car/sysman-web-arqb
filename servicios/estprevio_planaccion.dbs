<data name="estprevio_planaccion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEstprevio_planaccion" keyColumns="COMPANIA,COD_ESTUDIO,VIGENCIA_INICIAL_PAV,ID_PLAN,CODIGO_PAV,VIGENCIA_PAV" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ESTPREVIO_PLANACCION (COMPANIA, VIGENCIA, PLAN_INDICATIVO, VIGENCIA_INICIAL_PI, VIGENCIA_INICIAL_PAV, ID_PLAN, CODIGO_PAV, COD_ESTUDIO, VIGENCIA_PAV, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :VIGENCIA, :PLAN_INDICATIVO, :VIGENCIA_INICIAL_PI, :VIGENCIA_INICIAL_PAV, :ID_PLAN, :CODIGO_PAV, :COD_ESTUDIO, :VIGENCIA_PAV, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO","KEY_VIGENCIA_INICIAL_PAV":"$VIGENCIA_INICIAL_PAV(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_CODIGO_PAV":"$CODIGO_PAV(type:integer)","KEY_VIGENCIA_PAV":"$VIGENCIA_PAV(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL_PI" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL_PAV" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO_PAV" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA_PAV" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="estprevio_planaccion">
		<call-query href="insertEstprevio_planaccion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PLAN_INDICATIVO" query-param="PLAN_INDICATIVO"/>
			<with-param name="VIGENCIA_INICIAL_PI" query-param="VIGENCIA_INICIAL_PI"/>
			<with-param name="VIGENCIA_INICIAL_PAV" query-param="VIGENCIA_INICIAL_PAV"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="CODIGO_PAV" query-param="CODIGO_PAV"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="VIGENCIA_PAV" query-param="VIGENCIA_PAV"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteEstprevio_planaccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ESTPREVIO_PLANACCION WHERE ESTPREVIO_PLANACCION.COMPANIA= :KEY_COMPANIA AND ESTPREVIO_PLANACCION.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV= :KEY_VIGENCIA_INICIAL_PAV AND ESTPREVIO_PLANACCION.ID_PLAN= :KEY_ID_PLAN AND ESTPREVIO_PLANACCION.CODIGO_PAV= :KEY_CODIGO_PAV AND ESTPREVIO_PLANACCION.VIGENCIA_PAV= :KEY_VIGENCIA_PAV</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL_PAV" sqlType="INTEGER"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO_PAV" sqlType="INTEGER"/>
		<param name="KEY_VIGENCIA_PAV" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="estprevio_planaccion">
		<call-query href="deleteEstprevio_planaccion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_VIGENCIA_INICIAL_PAV" query-param="KEY_VIGENCIA_INICIAL_PAV"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO_PAV" query-param="KEY_CODIGO_PAV"/>
			<with-param name="KEY_VIGENCIA_PAV" query-param="KEY_VIGENCIA_PAV"/>

		</call-query>
	</resource>
	<query id="getEstprevio_planaccionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ESTPREVIO_PLANACCION.VIGENCIA, BP_PLAN_INDICATIVO.DESCRIPCION "ACTIVIDAD_PLAN_INDICATIVO", BP_PLAN_INDICATIVO.CODIGOBPIM "FICHA_BPIN", ESTPREVIO_PLANACCION.ID_PLAN, BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO "SALDO_ITEM", ESTPREVIO_PLANACCION.PLAN_INDICATIVO, ESTPREVIO_PLANACCION.COMPANIA, ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PI, ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV, ESTPREVIO_PLANACCION.CODIGO_PAV, ESTPREVIO_PLANACCION.COD_ESTUDIO, ESTPREVIO_PLANACCION.VIGENCIA_PAV, ESTPREVIO_PLANACCION.CREATED_BY, ESTPREVIO_PLANACCION.MODIFIED_BY,(TO_CHAR(ESTPREVIO_PLANACCION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(ESTPREVIO_PLANACCION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM ESTPREVIO_PLANACCION INNER JOIN BP_PLAN_INDICATIVO ON ESTPREVIO_PLANACCION.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND ESTPREVIO_PLANACCION.PLAN_INDICATIVO = BP_PLAN_INDICATIVO.ID AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PI = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL INNER JOIN BP_PLAN_ADQUISICIONES_VIGENCIA ON ESTPREVIO_PLANACCION.COMPANIA = BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL AND ESTPREVIO_PLANACCION.ID_PLAN = BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN AND ESTPREVIO_PLANACCION.CODIGO_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO AND ESTPREVIO_PLANACCION.VIGENCIA_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA WHERE BP_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND ESTPREVIO_PLANACCION.COD_ESTUDIO = :ESTUDIO) WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%')  AND (CASE WHEN ACTIVIDAD_PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD_PLAN_INDICATIVO) END)  LIKE UPPER( '%' || :ACTIVIDAD_PLAN_INDICATIVO || '%')  AND (CASE WHEN FICHA_BPIN IS NULL THEN ' ' ELSE UPPER(FICHA_BPIN) END)  LIKE UPPER(:FICHA_BPIN || '%')  AND (CASE WHEN ID_PLAN IS NULL THEN ' ' ELSE UPPER(ID_PLAN) END)  LIKE UPPER(:ID_PLAN || '%')  AND (CASE WHEN SALDO_ITEM IS NULL THEN ' ' ELSE UPPER(SALDO_ITEM) END)  LIKE UPPER(:SALDO_ITEM || '%')  AND (CASE WHEN PLAN_INDICATIVO IS NULL THEN ' ' ELSE UPPER(PLAN_INDICATIVO) END)  LIKE UPPER( '%' || :PLAN_INDICATIVO || '%')  AND (CASE WHEN VIGENCIA_INICIAL_PI IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL_PI) END)  LIKE UPPER( '%' || :VIGENCIA_INICIAL_PI || '%')  AND (CASE WHEN VIGENCIA_INICIAL_PAV IS NULL THEN ' ' ELSE UPPER(VIGENCIA_INICIAL_PAV) END)  LIKE UPPER( '%' || :VIGENCIA_INICIAL_PAV || '%')  AND (CASE WHEN CODIGO_PAV IS NULL THEN ' ' ELSE UPPER(CODIGO_PAV) END)  LIKE UPPER( '%' || :CODIGO_PAV || '%')  AND (CASE WHEN COD_ESTUDIO IS NULL THEN ' ' ELSE UPPER(COD_ESTUDIO) END)  LIKE UPPER( '%' || :COD_ESTUDIO || '%')  AND (CASE WHEN VIGENCIA_PAV IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PAV) END)  LIKE UPPER( '%' || :VIGENCIA_PAV || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER( '%' || :DATE_MODIFIED || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VIGENCIA":"$VIGENCIA(type:integer)","ACTIVIDAD_PLAN_INDICATIVO":"$ACTIVIDAD_PLAN_INDICATIVO","FICHA_BPIN":"$FICHA_BPIN","ID_PLAN":"$ID_PLAN","SALDO_ITEM":"$SALDO_ITEM","PLAN_INDICATIVO":"$PLAN_INDICATIVO","COMPANIA":"$COMPANIA","VIGENCIA_INICIAL_PI":"$VIGENCIA_INICIAL_PI(type:integer)","VIGENCIA_INICIAL_PAV":"$VIGENCIA_INICIAL_PAV(type:integer)","CODIGO_PAV":"$CODIGO_PAV(type:integer)","COD_ESTUDIO":"$COD_ESTUDIO","VIGENCIA_PAV":"$VIGENCIA_PAV(type:integer)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ACTIVIDAD_PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="FICHA_BPIN" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="SALDO_ITEM" sqlType="STRING"/>
		<param name="PLAN_INDICATIVO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL_PI" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL_PAV" sqlType="STRING"/>
		<param name="CODIGO_PAV" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA_PAV" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estprevio_planaccion">
		<call-query href="getEstprevio_planaccionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTUDIO" query-param="ESTUDIO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ACTIVIDAD_PLAN_INDICATIVO" query-param="ACTIVIDAD_PLAN_INDICATIVO"/>
			<with-param name="FICHA_BPIN" query-param="FICHA_BPIN"/>
