	</resource>
	<query id="getEstprevio_planaccionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ESTPREVIO_PLANACCION.COMPANIA, ESTPREVIO_PLANACCION.VIGENCIA, ESTPREVIO_PLANACCION.PLAN_INDICATIVO, BP_PLAN_INDICATIVO.DESCRIPCION "ACTIVIDAD_PLAN_INDICATIVO", BP_PLAN_INDICATIVO.CODIGOBPIM "FICHA_BPIN", ESTPREVIO_PLANACCION.ID_PLAN, BP_PLAN_ADQUISICIONES.DESCRIPCION "NOMBRE_PLAN_ADQUISICION", BP_PLAN_ADQUISICIONES_VIGENCIA.VALOR_ESTIMADO "SALDO_ITEM", ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PI, ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV, ESTPREVIO_PLANACCION.CODIGO_PAV, ESTPREVIO_PLANACCION.COD_ESTUDIO, ESTPREVIO_PLANACCION.VIGENCIA_PAV, ESTPREVIO_PLANACCION.CREATED_BY, ESTPREVIO_PLANACCION.MODIFIED_BY,(TO_CHAR(ESTPREVIO_PLANACCION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(ESTPREVIO_PLANACCION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM ESTPREVIO_PLANACCION INNER JOIN BP_PLAN_INDICATIVO ON ESTPREVIO_PLANACCION.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND ESTPREVIO_PLANACCION.PLAN_INDICATIVO = BP_PLAN_INDICATIVO.ID AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PI = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL INNER JOIN BP_PLAN_ADQUISICIONES_VIGENCIA ON ESTPREVIO_PLANACCION.COMPANIA = BP_PLAN_ADQUISICIONES_VIGENCIA.COMPANIA AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA_INICIAL AND ESTPREVIO_PLANACCION.ID_PLAN = BP_PLAN_ADQUISICIONES_VIGENCIA.ID_PLAN AND ESTPREVIO_PLANACCION.CODIGO_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.CODIGO AND ESTPREVIO_PLANACCION.VIGENCIA_PAV = BP_PLAN_ADQUISICIONES_VIGENCIA.VIGENCIA INNER JOIN BP_PLAN_ADQUISICIONES ON ESTPREVIO_PLANACCION.COMPANIA = BP_PLAN_ADQUISICIONES.COMPANIA AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV = BP_PLAN_ADQUISICIONES.VIGENCIA_INICIAL AND ESTPREVIO_PLANACCION.ID_PLAN = BP_PLAN_ADQUISICIONES.ID_PLAN AND ESTPREVIO_PLANACCION.CODIGO_PAV = BP_PLAN_ADQUISICIONES.CODIGO WHERE ESTPREVIO_PLANACCION.COMPANIA= :KEY_COMPANIA AND ESTPREVIO_PLANACCION.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ESTPREVIO_PLANACCION.VIGENCIA_INICIAL_PAV= :KEY_VIGENCIA_INICIAL_PAV AND ESTPREVIO_PLANACCION.ID_PLAN= :KEY_ID_PLAN AND ESTPREVIO_PLANACCION.CODIGO_PAV= :KEY_CODIGO_PAV AND ESTPREVIO_PLANACCION.VIGENCIA_PAV= :KEY_VIGENCIA_PAV</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA":"$VIGENCIA(type:integer)","PLAN_INDICATIVO":"$PLAN_INDICATIVO","ACTIVIDAD_PLAN_INDICATIVO":"$ACTIVIDAD_PLAN_INDICATIVO","FICHA_BPIN":"$FICHA_BPIN","ID_PLAN":"$ID_PLAN","NOMBRE_PLAN_ADQUISICION":"$NOMBRE_PLAN_ADQUISICION","SALDO_ITEM":"$SALDO_ITEM","VIGENCIA_INICIAL_PI":"$VIGENCIA_INICIAL_PI(type:integer)","VIGENCIA_INICIAL_PAV":"$VIGENCIA_INICIAL_PAV(type:integer)","CODIGO_PAV":"$CODIGO_PAV(type:integer)","COD_ESTUDIO":"$COD_ESTUDIO","VIGENCIA_PAV":"$VIGENCIA_PAV(type:integer)","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_INICIAL_PAV" sqlType="STRING"/>
		<param name="KEY_ID_PLAN" sqlType="STRING"/>
		<param name="KEY_CODIGO_PAV" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_PAV" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estprevio_planaccion/data">
		<call-query href="getEstprevio_planaccionRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_VIGENCIA_INICIAL_PAV" query-param="KEY_VIGENCIA_INICIAL_PAV"/>
			<with-param name="KEY_ID_PLAN" query-param="KEY_ID_PLAN"/>
			<with-param name="KEY_CODIGO_PAV" query-param="KEY_CODIGO_PAV"/>
			<with-param name="KEY_VIGENCIA_PAV" query-param="KEY_VIGENCIA_PAV"/>

		</call-query>
	</resource>

</data>