<data name="vigenciasCuipo" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVigenciascuipoPagGetvigenciascuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE NOMBRE_CUIPO FROM VIGENCIAS_CUIPO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE_CUIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CUIPO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE_CUIPO":"$NOMBRE_CUIPO"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_CUIPO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vigenciascuipo/getvigenciascuipo/pag">
		<call-query href="getVigenciascuipoPagGetvigenciascuipoQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_CUIPO" query-param="NOMBRE_CUIPO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVigenciascuipoNumGetvigenciascuipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE NOMBRE_CUIPO FROM VIGENCIAS_CUIPO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE_CUIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CUIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CUIPO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_CUIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vigenciascuipo/getvigenciascuipo/num">
		<call-query href="getVigenciascuipoNumGetvigenciascuipoQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_CUIPO" query-param="NOMBRE_CUIPO"/>

		</call-query>
	</resource>

</data>