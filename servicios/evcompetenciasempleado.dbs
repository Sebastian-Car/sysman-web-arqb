		</call-query>
	</resource>
	<query id="getEvcompetenciasempleadoRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  EV_COMPETENCIAS_EMPLEADO.COMPANIA, EV_COMPETENCIAS_EMPLEADO.ID_COMPETENCIA, EV_COMPETENCIAS_EMPLEADO.TIPO_COMPETENCIA, EV_COMPETENCIAS_EMPLEADO.CONSECUTIVO, EV_COMPETENCIAS_EMPLEADO.NUMERO_MANUAL, EV_COMPETENCIAS_EMPLEADO.VERSION, EV_COMPETENCIAS_EMPLEADO.ID_EMPLEADO, EV_COMPETENCIAS_EMPLEADO.DEPENDENCIA, EVC.NOMBRE NOMBRETIPOCOMPETENCIA, DEP.NOMBRE NOMBREDEPENDENCIA, PER.NOMBRECOMPLETO NOMBREEMPLEADO  FROM EV_COMPETENCIAS_EMPLEADO INNER JOIN EV_TIPO_COMPETENCIAS EVC ON EV_COMPETENCIAS_EMPLEADO.COMPANIA = EVC.COMPANIA AND EV_COMPETENCIAS_EMPLEADO.TIPO_COMPETENCIA = EVC.CODIGO INNER JOIN DEPENDENCIA DEP ON EV_COMPETENCIAS_EMPLEADO.COMPANIA = DEP.COMPANIA AND EV_COMPETENCIAS_EMPLEADO.DEPENDENCIA = DEP.CODIGO INNER JOIN PERSONAL PER ON EV_COMPETENCIAS_EMPLEADO.ID_EMPLEADO = PER.ID_DE_EMPLEADO WHERE EV_COMPETENCIAS_EMPLEADO.COMPANIA= :KEY_COMPANIA AND EV_COMPETENCIAS_EMPLEADO.ID_COMPETENCIA= :KEY_ID_COMPETENCIA AND EV_COMPETENCIAS_EMPLEADO.TIPO_COMPETENCIA= :KEY_TIPO_COMPETENCIA AND EV_COMPETENCIAS_EMPLEADO.CONSECUTIVO= :KEY_CONSECUTIVO AND EV_COMPETENCIAS_EMPLEADO.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_COMPETENCIAS_EMPLEADO.VERSION= :KEY_VERSION AND EV_COMPETENCIAS_EMPLEADO.ID_EMPLEADO= :KEY_ID_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_COMPETENCIA":"$ID_COMPETENCIA(type:long)","TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","NUMERO_MANUAL":"$NUMERO_MANUAL","VERSION":"$VERSION","ID_EMPLEADO":"$ID_EMPLEADO(type:integer)","DEPENDENCIA":"$DEPENDENCIA","NOMBRETIPOCOMPETENCIA":"$NOMBRETIPOCOMPETENCIA","NOMBREDEPENDENCIA":"$NOMBREDEPENDENCIA","NOMBREEMPLEADO":"$NOMBREEMPLEADO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_COMPETENCIA" sqlType="STRING"/>
		<param name="KEY_TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_NUMERO_MANUAL" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_ID_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcompetenciasempleado/data">
		<call-query href="getEvcompetenciasempleadoRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_COMPETENCIA" query-param="KEY_ID_COMPETENCIA"/>
			<with-param name="KEY_TIPO_COMPETENCIA" query-param="KEY_TIPO_COMPETENCIA"/>
