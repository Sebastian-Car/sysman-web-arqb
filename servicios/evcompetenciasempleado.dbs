			<with-param name="ID_COMPETENCIA" query-param="ID_COMPETENCIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="TIPO_COMPETENCIA" query-param="TIPO_COMPETENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvcompetenciasempleadoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EVC.DEPENDENCIA, EVC.NUMERO_MANUAL,EVC.VERSION, PER.NOMBRECOMPLETO NOMBREPERSONA, DEP.NOMBRE NOMBREDEPENDENCIA, EVT.NOMBRE NOMBRETCOMPETENCIA, EVC.CARGO, EVC.CATEGORIA, EVC.COMPANIA, EVC.CONSECUTIVO, EVC.DESCRIPCION, EVC.ESCALAFON, EVC.ID_COMPETENCIA, EVC.ID_EMPLEADO, EVC.TIPO_COMPETENCIA  FROM EV_COMPETENCIAS_EMPLEADO EVC LEFT JOIN DEPENDENCIA DEP ON EVC.COMPANIA = DEP.COMPANIA AND EVC.DEPENDENCIA = DEP.CODIGO INNER JOIN PERSONAL PER ON EVC.COMPANIA = PER.COMPANIA AND EVC.ID_EMPLEADO = PER.ID_DE_EMPLEADO INNER JOIN EV_TIPO_COMPETENCIAS EVT ON EVC.COMPANIA = EVT.COMPANIA AND EVC.TIPO_COMPETENCIA = EVT.CODIGO WHERE EVC.COMPANIA = :COMPANIA) WHERE (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER(:DEPENDENCIA || '%')  AND (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER(:VERSION || '%')  AND (CASE WHEN NOMBREPERSONA IS NULL THEN ' ' ELSE UPPER(NOMBREPERSONA) END)  LIKE UPPER( '%' || :NOMBREPERSONA || '%')  AND (CASE WHEN NOMBREDEPENDENCIA IS NULL THEN ' ' ELSE UPPER(NOMBREDEPENDENCIA) END)  LIKE UPPER( '%' || :NOMBREDEPENDENCIA || '%')  AND (CASE WHEN NOMBRETCOMPETENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRETCOMPETENCIA) END)  LIKE UPPER( '%' || :NOMBRETCOMPETENCIA || '%')  AND (CASE WHEN CATEGORIA IS NULL THEN ' ' ELSE UPPER(CATEGORIA) END)  LIKE UPPER( '%' || :CATEGORIA || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER( '%' || :CONSECUTIVO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN ESCALAFON IS NULL THEN ' ' ELSE UPPER(ESCALAFON) END)  LIKE UPPER( '%' || :ESCALAFON || '%')  AND (CASE WHEN ID_COMPETENCIA IS NULL THEN ' ' ELSE UPPER(ID_COMPETENCIA) END)  LIKE UPPER( '%' || :ID_COMPETENCIA || '%')  AND (CASE WHEN ID_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_EMPLEADO) END)  LIKE UPPER( '%' || :ID_EMPLEADO || '%')  AND (CASE WHEN TIPO_COMPETENCIA IS NULL THEN ' ' ELSE UPPER(TIPO_COMPETENCIA) END)  LIKE UPPER( '%' || :TIPO_COMPETENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="NOMBREPERSONA" sqlType="STRING"/>
		<param name="NOMBREDEPENDENCIA" sqlType="STRING"/>
		<param name="NOMBRETCOMPETENCIA" sqlType="STRING"/>
		<param name="CATEGORIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESCALAFON" sqlType="STRING"/>
		<param name="ID_COMPETENCIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="TIPO_COMPETENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcompetenciasempleado/numero">
		<call-query href="getEvcompetenciasempleadoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
