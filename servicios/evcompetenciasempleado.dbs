			<with-param name="KEY_ID_EMPLEADO" query-param="KEY_ID_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="updateEvcompetenciasempleado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_COMPETENCIAS_EMPLEADO SET CONSECUTIVO=:CONSECUTIVO, DEPENDENCIA=:DEPENDENCIA, ID_COMPETENCIA=:ID_COMPETENCIA, ID_EMPLEADO=:ID_EMPLEADO, NUMERO_MANUAL=:NUMERO_MANUAL, TIPO_COMPETENCIA=:TIPO_COMPETENCIA, VERSION=:VERSION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_COMPETENCIAS_EMPLEADO.COMPANIA= :KEY_COMPANIA AND EV_COMPETENCIAS_EMPLEADO.ID_COMPETENCIA= :KEY_ID_COMPETENCIA AND EV_COMPETENCIAS_EMPLEADO.TIPO_COMPETENCIA= :KEY_TIPO_COMPETENCIA AND EV_COMPETENCIAS_EMPLEADO.CONSECUTIVO= :KEY_CONSECUTIVO AND EV_COMPETENCIAS_EMPLEADO.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_COMPETENCIAS_EMPLEADO.VERSION= :KEY_VERSION AND EV_COMPETENCIAS_EMPLEADO.ID_EMPLEADO= :KEY_ID_EMPLEADO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
