			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturaNumNumeroconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT NRO_CONVOCATORIA, TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA  FROM NAT_APERTURA WHERE COMPANIA =:COMPANIA AND NAT_APERTURA.CERRADA != (0)) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/numeroconvocatoria/num">
