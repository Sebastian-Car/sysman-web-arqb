	<query id="updateNatapertura" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_APERTURA SET NRO_CONVOCATORIA=:NRO_CONVOCATORIA, CLASE=:CLASE, FECHA_CONVOCATORIA=TO_DATE(:FECHA_CONVOCATORIA,'DD/MM/YYYY HH24:MI:SS'), NOTAS=:NOTAS, CODIGOCARGO=:CODIGOCARGO, GRADOCARGO=:GRADOCARGO, UBICACIONORGANICA=:UBICACIONORGANICA, SUELDO=:SUELDO, PLAZAS=:PLAZAS, DENOMINACION=:DENOMINACION, REQUISITOEDUCACION=:REQUISITOEDUCACION, REQUISITOEXPERIENCIA=:REQUISITOEXPERIENCIA, REQUISITOEQUIVALENCIAS=:REQUISITOEQUIVALENCIAS, REQUISITOEQUIEXPERIENCIA=:REQUISITOEQUIEXPERIENCIA, OBSERVACIONESREQUISITOS=:OBSERVACIONESREQUISITOS, LUGAR_INSCRIPCION=:LUGAR_INSCRIPCION, FECHAINICIOINSCRIPCION=TO_DATE(:FECHAINICIOINSCRIPCION,'DD/MM/YYYY HH24:MI:SS'), FECHACIERREINSCRIPCION=TO_DATE(:FECHACIERREINSCRIPCION,'DD/MM/YYYY HH24:MI:SS'), HORA_ATENCION=:HORA_ATENCION, PUBLICACION=TO_DATE(:PUBLICACION,'DD/MM/YYYY HH24:MI:SS'), FECHA_CONCURSO=TO_DATE(:FECHA_CONCURSO,'DD/MM/YYYY HH24:MI:SS'), HORA_CONCURSO=:HORA_CONCURSO, FECHA_ENVIO_CORREO=TO_DATE(:FECHA_ENVIO_CORREO,'DD/MM/YYYY HH24:MI:SS'), LUGAR_CONCURSO=:LUGAR_CONCURSO, FECHA_CONCURSO_FIN=TO_DATE(:FECHA_CONCURSO_FIN,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA=:DEPENDENCIA, MANUAL=:MANUAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_APERTURA.COMPANIA= :KEY_COMPANIA AND NAT_APERTURA.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

