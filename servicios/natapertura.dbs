		<param name="REQUISITOEQUIEXPERIENCIA" sqlType="STRING"/>
		<param name="OBSERVACIONESREQUISITOS" sqlType="STRING"/>
		<param name="LUGAR_INSCRIPCION" sqlType="STRING"/>
		<param name="FECHAINICIOINSCRIPCION" sqlType="STRING"/>
		<param name="FECHACIERREINSCRIPCION" sqlType="STRING"/>
		<param name="HORA_ATENCION" sqlType="STRING"/>
		<param name="PUBLICACION" sqlType="STRING"/>
		<param name="FECHA_CONCURSO" sqlType="STRING"/>
		<param name="HORA_CONCURSO" sqlType="STRING"/>
		<param name="FECHA_ENVIO_CORREO" sqlType="STRING"/>
