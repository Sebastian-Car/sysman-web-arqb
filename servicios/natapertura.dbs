<data name="natapertura" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNataperturaPagNumerofechaconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT NRO_CONVOCATORIA, TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA  FROM NAT_APERTURA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura/numerofechaconvocatoria/pag">
		<call-query href="getNataperturaPagNumerofechaconvocatoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturaNumNumerofechaconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT NRO_CONVOCATORIA, TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA  FROM NAT_APERTURA WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/numerofechaconvocatoria/num">
		<call-query href="getNataperturaNumNumerofechaconvocatoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>

		</call-query>
	</resource>
	<query id="getNataperturaPagFechaConvocatoriaCargosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA,(TO_CHAR(NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONVOCATORIA, NAT_HVCARGOS.DENOMINACION  FROM NAT_APERTURA INNER JOIN NAT_HVCARGOS ON NAT_APERTURA.CODIGOCARGO = NAT_HVCARGOS.CODIGO AND NAT_APERTURA.GRADOCARGO = NAT_HVCARGOS.GRADO AND NAT_APERTURA.FECHACARGO = NAT_HVCARGOS.FECHACREACION WHERE NAT_APERTURA.COMPANIA = :COMPANIA ORDER BY NAT_APERTURA.NRO_CONVOCATORIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA","DENOMINACION":"$DENOMINACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura/fechaconvocatoriacargos/pag">
		<call-query href="getNataperturaPagFechaConvocatoriaCargosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturaNumFechaConvocatoriaCargosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA,(TO_CHAR(NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONVOCATORIA, NAT_HVCARGOS.DENOMINACION  FROM NAT_APERTURA INNER JOIN NAT_HVCARGOS ON NAT_APERTURA.CODIGOCARGO = NAT_HVCARGOS.CODIGO AND NAT_APERTURA.GRADOCARGO = NAT_HVCARGOS.GRADO AND NAT_APERTURA.FECHACARGO = NAT_HVCARGOS.FECHACREACION WHERE NAT_APERTURA.COMPANIA = :COMPANIA ORDER BY NAT_APERTURA.NRO_CONVOCATORIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/fechaconvocatoriacargos/num">
		<call-query href="getNataperturaNumFechaConvocatoriaCargosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>

		</call-query>
	</resource>
	<query id="getNataperturaPagNataperturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, CARGOS.NOMBRE_DEL_CARGO  FROM NAT_APERTURA INNER JOIN NAT_RELACION_PRUEBAS ON NAT_RELACION_PRUEBAS.COMPANIA = NAT_APERTURA.COMPANIA AND NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA = NAT_APERTURA.NRO_CONVOCATORIA INNER JOIN CARGOS ON NAT_APERTURA.COMPANIA = CARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = CARGOS.ID_DE_CARGO WHERE NAT_APERTURA.COMPANIA =:COMPANIA ORDER BY NAT_APERTURA.NRO_CONVOCATORIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA","NOMBRE_DEL_CARGO":"$NOMBRE_DEL_CARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura/natapertura/pag">
		<call-query href="getNataperturaPagNataperturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturaNumNataperturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, CARGOS.NOMBRE_DEL_CARGO  FROM NAT_APERTURA INNER JOIN NAT_RELACION_PRUEBAS ON NAT_RELACION_PRUEBAS.COMPANIA = NAT_APERTURA.COMPANIA AND NAT_RELACION_PRUEBAS.NRO_CONVOCATORIA = NAT_APERTURA.NRO_CONVOCATORIA INNER JOIN CARGOS ON NAT_APERTURA.COMPANIA = CARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = CARGOS.ID_DE_CARGO WHERE NAT_APERTURA.COMPANIA =:COMPANIA ORDER BY NAT_APERTURA.NRO_CONVOCATORIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%')  AND (CASE WHEN NOMBRE_DEL_CARGO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_CARGO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_CARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="NOMBRE_DEL_CARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/natapertura/num">
		<call-query href="getNataperturaNumNataperturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="NOMBRE_DEL_CARGO" query-param="NOMBRE_DEL_CARGO"/>

		</call-query>
	</resource>
	<query id="getNataperturaPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR( NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, CARGOS.NOMBRE_DEL_CARGO DENOMINACION,(CASE NAT_APERTURA.CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA FROM NAT_APERTURA INNER JOIN CARGOS ON NAT_APERTURA.COMPANIA = CARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = CARGOS.ID_DE_CARGO WHERE NAT_APERTURA.COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%')  AND (CASE WHEN CERRADA IS NULL THEN ' ' ELSE UPPER(CERRADA) END)  LIKE UPPER( '%' || :CERRADA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA","DENOMINACION":"$DENOMINACION","CERRADA":"$CERRADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="CERRADA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura/todosporcompania/pag">
		<call-query href="getNataperturaPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="CERRADA" query-param="CERRADA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturaNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR( NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, CARGOS.NOMBRE_DEL_CARGO DENOMINACION,(CASE NAT_APERTURA.CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA FROM NAT_APERTURA INNER JOIN CARGOS ON NAT_APERTURA.COMPANIA = CARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = CARGOS.ID_DE_CARGO WHERE NAT_APERTURA.COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%')  AND (CASE WHEN CERRADA IS NULL THEN ' ' ELSE UPPER(CERRADA) END)  LIKE UPPER( '%' || :CERRADA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="CERRADA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/todosporcompania/num">
		<call-query href="getNataperturaNumTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="CERRADA" query-param="CERRADA"/>

		</call-query>
	</resource>
	<query id="getNataperturaPagNroFechaNomcargoPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR( NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, NAT_HVCARGOS.DENOMINACION  FROM NAT_APERTURA INNER JOIN NAT_HVCARGOS ON NAT_APERTURA.COMPANIA = NAT_HVCARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = NAT_HVCARGOS.CODIGO AND NAT_APERTURA.GRADOCARGO = NAT_HVCARGOS.GRADO AND NAT_APERTURA.FECHACARGO = NAT_HVCARGOS.DATE_CREATED WHERE NAT_HVCARGOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER(:FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA","DENOMINACION":"$DENOMINACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura/nrofechanomcargoporcia/pag">
		<call-query href="getNataperturaPagNroFechaNomcargoPorCiaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertNatapertura" keyColumns="COMPANIA,NRO_CONVOCATORIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_APERTURA (COMPANIA, NRO_CONVOCATORIA, CLASE, FECHA_CONVOCATORIA, NOTAS, CODIGOCARGO, GRADOCARGO, UBICACIONORGANICA, SUELDO, PLAZAS, REQUISITOEDUCACION, REQUISITOEXPERIENCIA, REQUISITOEQUIVALENCIAS, REQUISITOEQUIEXPERIENCIA, OBSERVACIONESREQUISITOS, LUGAR_INSCRIPCION, FECHAINICIOINSCRIPCION, FECHACIERREINSCRIPCION, HORA_ATENCION, PUBLICACION, FECHA_CONCURSO, HORA_CONCURSO, LUGAR_CONCURSO, FECHA_CONCURSO_FIN, DEPENDENCIA, DENOMINACION, MANUAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NRO_CONVOCATORIA, :CLASE, TO_DATE(:FECHA_CONVOCATORIA,'DD/MM/YYYY HH24:MI:SS'), :NOTAS, :CODIGOCARGO, :GRADOCARGO, :UBICACIONORGANICA, :SUELDO, :PLAZAS, :REQUISITOEDUCACION, :REQUISITOEXPERIENCIA, :REQUISITOEQUIVALENCIAS, :REQUISITOEQUIEXPERIENCIA, :OBSERVACIONESREQUISITOS, :LUGAR_INSCRIPCION, TO_DATE(:FECHAINICIOINSCRIPCION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHACIERREINSCRIPCION,'DD/MM/YYYY HH24:MI:SS'), :HORA_ATENCION, TO_DATE(:PUBLICACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_CONCURSO,'DD/MM/YYYY HH24:MI:SS'), :HORA_CONCURSO, :LUGAR_CONCURSO, TO_DATE(:FECHA_CONCURSO_FIN,'DD/MM/YYYY HH24:MI:SS'), :DEPENDENCIA, :DENOMINACION, :MANUAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NRO_CONVOCATORIA":"$NRO_CONVOCATORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param defaultValue="" name="CLASE" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param defaultValue="" name="NOTAS" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCARGO" sqlType="STRING"/>
		<param defaultValue="" name="GRADOCARGO" sqlType="STRING"/>
		<param defaultValue="" name="UBICACIONORGANICA" sqlType="STRING"/>
		<param defaultValue="0" name="SUELDO" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZAS" sqlType="STRING"/>
		<param defaultValue="" name="REQUISITOEDUCACION" sqlType="STRING"/>
		<param defaultValue="" name="REQUISITOEXPERIENCIA" sqlType="STRING"/>
		<param defaultValue="" name="REQUISITOEQUIVALENCIAS" sqlType="STRING"/>
		<param defaultValue="" name="REQUISITOEQUIEXPERIENCIA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONESREQUISITOS" sqlType="STRING"/>
		<param defaultValue="" name="LUGAR_INSCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINICIOINSCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHACIERREINSCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="HORA_ATENCION" sqlType="STRING"/>
		<param defaultValue="" name="PUBLICACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CONCURSO" sqlType="STRING"/>
		<param defaultValue="" name="HORA_CONCURSO" sqlType="STRING"/>
		<param defaultValue="" name="LUGAR_CONCURSO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CONCURSO_FIN" sqlType="STRING"/>
		<param defaultValue="" name="DEPENDENCIA" sqlType="STRING"/>
