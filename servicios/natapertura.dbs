		</call-query>
	</resource>
	<query id="getNataperturaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NRO_CONVOCATORIA,(CASE CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA, NAT_CLASES_DE_CONVOCATORIA.NOMBRE CLASE,(TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONVOCATORIA, DENOMINACION, NOTAS  FROM NAT_APERTURA LEFT JOIN NAT_CLASES_DE_CONVOCATORIA ON NAT_APERTURA.CLASE = NAT_CLASES_DE_CONVOCATORIA.CONVOCATORIA WHERE NAT_APERTURA.COMPANIA= :COMPANIA ORDER BY TO_NUMBER(NRO_CONVOCATORIA)) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER(:DENOMINACION || '%')  AND (CASE WHEN NOTAS IS NULL THEN ' ' ELSE UPPER(NOTAS) END)  LIKE UPPER( '%' || :NOTAS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","CERRADA":"$CERRADA(type:boolean)","CLASE":"$CLASE","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA","DENOMINACION":"$DENOMINACION","NOTAS":"$NOTAS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="NOTAS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura">
		<call-query href="getNataperturaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="NOTAS" query-param="NOTAS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NRO_CONVOCATORIA,(CASE CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA, NAT_CLASES_DE_CONVOCATORIA.NOMBRE CLASE,(TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONVOCATORIA, DENOMINACION, NOTAS  FROM NAT_APERTURA LEFT JOIN NAT_CLASES_DE_CONVOCATORIA ON NAT_APERTURA.CLASE = NAT_CLASES_DE_CONVOCATORIA.CONVOCATORIA WHERE NAT_APERTURA.COMPANIA= :COMPANIA ORDER BY TO_NUMBER(NRO_CONVOCATORIA)) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER(:DENOMINACION || '%')  AND (CASE WHEN NOTAS IS NULL THEN ' ' ELSE UPPER(NOTAS) END)  LIKE UPPER( '%' || :NOTAS || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="NOTAS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/numero">
		<call-query href="getNataperturaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
