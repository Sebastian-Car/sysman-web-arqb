	<query id="getNataperturaNumNroFechaNomcargoPorCiaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR( NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, NAT_HVCARGOS.DENOMINACION  FROM NAT_APERTURA INNER JOIN NAT_HVCARGOS ON NAT_APERTURA.COMPANIA = NAT_HVCARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = NAT_HVCARGOS.CODIGO AND NAT_APERTURA.GRADOCARGO = NAT_HVCARGOS.GRADO AND NAT_APERTURA.FECHACARGO = NAT_HVCARGOS.DATE_CREATED WHERE NAT_HVCARGOS.COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER(:FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>

	</query>
