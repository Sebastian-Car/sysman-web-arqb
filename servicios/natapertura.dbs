			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>

		</call-query>
	</resource>
	<query id="getNataperturaPagNataperturacerradaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR( NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, CARGOS.NOMBRE_DEL_CARGO DENOMINACION,(CASE CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA FROM NAT_APERTURA INNER JOIN CARGOS ON NAT_APERTURA.COMPANIA = CARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = CARGOS.ID_DE_CARGO WHERE NAT_APERTURA.COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER(:FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%')  AND (CASE WHEN CERRADA IS NULL THEN ' ' ELSE UPPER(CERRADA) END)  LIKE UPPER(:CERRADA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA","DENOMINACION":"$DENOMINACION","CERRADA":"$CERRADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="CERRADA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura/nataperturacerrada/pag">
		<call-query href="getNataperturaPagNataperturacerradaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="CERRADA" query-param="CERRADA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNataperturaNumNataperturacerradaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NAT_APERTURA.NRO_CONVOCATORIA, TO_CHAR( NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA, CARGOS.NOMBRE_DEL_CARGO DENOMINACION,(CASE CERRADA WHEN 0 THEN 'false' ELSE 'true' END) CERRADA FROM NAT_APERTURA INNER JOIN CARGOS ON NAT_APERTURA.COMPANIA = CARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = CARGOS.ID_DE_CARGO WHERE NAT_APERTURA.COMPANIA = :COMPANIA) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER(:FECHA_CONVOCATORIA || '%')  AND (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER( '%' || :DENOMINACION || '%')  AND (CASE WHEN CERRADA IS NULL THEN ' ' ELSE UPPER(CERRADA) END)  LIKE UPPER(:CERRADA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="CERRADA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/nataperturacerrada/num">
		<call-query href="getNataperturaNumNataperturacerradaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NRO_CONVOCATORIA" query-param="NRO_CONVOCATORIA"/>
			<with-param name="FECHA_CONVOCATORIA" query-param="FECHA_CONVOCATORIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="CERRADA" query-param="CERRADA"/>

		</call-query>
	</resource>
	<query id="getNataperturaCargarseleccionarmanualQuery"  useConfig="sysmandsunist">
		<sql>SELECT  REQUISITOEDUCACION, REQUISITOEXPERIENCIA, REQUISITOEQUIVALENCIAS, REQUISITOEQUIEXPERIENCIA, OBSERVACIONESREQUISITOS  FROM NAT_APERTURA WHERE COMPANIA = :COMPANIA AND NRO_CONVOCATORIA =:NRO_CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"REQUISITOEDUCACION":"$REQUISITOEDUCACION","REQUISITOEXPERIENCIA":"$REQUISITOEXPERIENCIA","REQUISITOEQUIVALENCIAS":"$REQUISITOEQUIVALENCIAS","REQUISITOEQUIEXPERIENCIA":"$REQUISITOEQUIEXPERIENCIA","OBSERVACIONESREQUISITOS":"$OBSERVACIONESREQUISITOS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natapertura/cargarseleccionarmanual">
