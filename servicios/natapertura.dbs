			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="NOTAS" query-param="NOTAS"/>

		</call-query>
	</resource>
	<query id="getNataperturaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NAT_APERTURA.COMPANIA, NAT_APERTURA.NRO_CONVOCATORIA, NAT_APERTURA.CLASE,(TO_CHAR(NAT_APERTURA.FECHA_CONVOCATORIA,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONVOCATORIA, NAT_APERTURA.NOTAS, NAT_APERTURA.CODIGOCARGO, NAT_APERTURA.GRADOCARGO, NAT_APERTURA.UBICACIONORGANICA, NAT_APERTURA.SUELDO, NAT_APERTURA.PLAZAS, NAT_APERTURA.REQUISITOEDUCACION, NAT_APERTURA.REQUISITOEXPERIENCIA, NAT_APERTURA.REQUISITOEQUIVALENCIAS, NAT_APERTURA.REQUISITOEQUIEXPERIENCIA, NAT_APERTURA.OBSERVACIONESREQUISITOS, NAT_APERTURA.LUGAR_INSCRIPCION,(TO_CHAR(NAT_APERTURA.FECHAINICIOINSCRIPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIOINSCRIPCION,(TO_CHAR(NAT_APERTURA.FECHACIERREINSCRIPCION,'DD/MM/YYYY HH24:MI:SS')) FECHACIERREINSCRIPCION, NAT_APERTURA.HORA_ATENCION,(TO_CHAR(NAT_APERTURA.PUBLICACION,'DD/MM/YYYY HH24:MI:SS')) PUBLICACION,(TO_CHAR(NAT_APERTURA.FECHA_CONCURSO,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONCURSO, NAT_APERTURA.HORA_CONCURSO,(TO_CHAR(NAT_APERTURA.FECHA_ENVIO_CORREO,'DD/MM/YYYY HH24:MI:SS')) FECHA_ENVIO_CORREO, NAT_APERTURA.LUGAR_CONCURSO,(TO_CHAR(FECHA_CONCURSO_FIN,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONCURSO_FIN, NAT_APERTURA.CREATED_BY, NAT_APERTURA.MODIFIED_BY,(TO_CHAR(NAT_APERTURA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(NAT_APERTURA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, NAT_APERTURA.DENOMINACION, CARGOS.NOMBRE_DEL_CARGO NOMBRE_CATEGORIA, CARGOS.DENOMINACION DENOMINACION_CARGOS, NAT_APERTURA.DEPENDENCIA, DEPENDENCIA.NOMBRE NOMBRE_DEPENDENCIA, NAT_APERTURA.MANUAL  FROM NAT_APERTURA LEFT JOIN CARGOS ON NAT_APERTURA.COMPANIA = CARGOS.COMPANIA AND NAT_APERTURA.CODIGOCARGO = CARGOS.ID_DE_CARGO LEFT JOIN DEPENDENCIA ON NAT_APERTURA.COMPANIA = DEPENDENCIA.COMPANIA AND NAT_APERTURA.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE NAT_APERTURA.COMPANIA= :KEY_COMPANIA AND NAT_APERTURA.NRO_CONVOCATORIA= :KEY_NRO_CONVOCATORIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","CLASE":"$CLASE","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA","NOTAS":"$NOTAS","CODIGOCARGO":"$CODIGOCARGO","GRADOCARGO":"$GRADOCARGO","UBICACIONORGANICA":"$UBICACIONORGANICA","SUELDO":"$SUELDO","PLAZAS":"$PLAZAS","REQUISITOEDUCACION":"$REQUISITOEDUCACION","REQUISITOEXPERIENCIA":"$REQUISITOEXPERIENCIA","REQUISITOEQUIVALENCIAS":"$REQUISITOEQUIVALENCIAS","REQUISITOEQUIEXPERIENCIA":"$REQUISITOEQUIEXPERIENCIA","OBSERVACIONESREQUISITOS":"$OBSERVACIONESREQUISITOS","LUGAR_INSCRIPCION":"$LUGAR_INSCRIPCION","FECHAINICIOINSCRIPCION":"$FECHAINICIOINSCRIPCION","FECHACIERREINSCRIPCION":"$FECHACIERREINSCRIPCION","HORA_ATENCION":"$HORA_ATENCION","PUBLICACION":"$PUBLICACION","FECHA_CONCURSO":"$FECHA_CONCURSO","HORA_CONCURSO":"$HORA_CONCURSO","FECHA_ENVIO_CORREO":"$FECHA_ENVIO_CORREO","LUGAR_CONCURSO":"$LUGAR_CONCURSO","FECHA_CONCURSO_FIN":"$FECHA_CONCURSO_FIN","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","DENOMINACION":"$DENOMINACION","NOMBRE_CATEGORIA":"$NOMBRE_CATEGORIA","DENOMINACION_CARGOS":"$DENOMINACION_CARGOS","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","MANUAL":"$MANUAL"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NRO_CONVOCATORIA" sqlType="STRING"/>

	</query>
