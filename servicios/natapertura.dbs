	<query id="getNataperturaPagNumeroconvocatoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT NRO_CONVOCATORIA, TO_CHAR(FECHA_CONVOCATORIA,'DD/MM/YYYY') FECHA_CONVOCATORIA  FROM NAT_APERTURA WHERE COMPANIA =:COMPANIA AND NAT_APERTURA.CERRADA != (0)) WHERE (CASE WHEN NRO_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(NRO_CONVOCATORIA) END)  LIKE UPPER(:NRO_CONVOCATORIA || '%')  AND (CASE WHEN FECHA_CONVOCATORIA IS NULL THEN ' ' ELSE UPPER(FECHA_CONVOCATORIA) END)  LIKE UPPER( '%' || :FECHA_CONVOCATORIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NRO_CONVOCATORIA":"$NRO_CONVOCATORIA","FECHA_CONVOCATORIA":"$FECHA_CONVOCATORIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NRO_CONVOCATORIA" sqlType="STRING"/>
		<param name="FECHA_CONVOCATORIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natapertura/numeroconvocatoria/pag">
