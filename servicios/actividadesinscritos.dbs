<data name="actividadesinscritos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertActividadesinscritos" keyColumns="COMPANIA,IDEVENTO,TIPOEVENTO,NUMERO_DCTO,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_ACTIVIDADESINSCRITOS (COMPANIA, IDEVENTO, TIPOEVENTO, NUMERO_DCTO, SUCURSAL, ASISTIO, CALIFICACION, FECHAINICIAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :IDEVENTO, :TIPOEVENTO, :NUMERO_DCTO, :SUCURSAL, :ASISTIO, :CALIFICACION, TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDEVENTO":"$IDEVENTO","KEY_TIPOEVENTO":"$TIPOEVENTO","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="ASISTIO" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINICIAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="actividadesinscritos">
		<call-query href="insertActividadesinscritos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ASISTIO" query-param="ASISTIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteActividadesinscritos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_ACTIVIDADESINSCRITOS WHERE NAT_ACTIVIDADESINSCRITOS.COMPANIA= :KEY_COMPANIA AND NAT_ACTIVIDADESINSCRITOS.IDEVENTO= :KEY_IDEVENTO AND NAT_ACTIVIDADESINSCRITOS.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_ACTIVIDADESINSCRITOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_ACTIVIDADESINSCRITOS.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="actividadesinscritos">
		<call-query href="deleteActividadesinscritos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getActividadesinscritosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT * FROM ( SELECT I.COMPANIA, I.IDEVENTO, I.TIPOEVENTO, TO_CHAR(I.FECHAINICIAL,'DD/MM/YYYY') FECHAINICIAL, I.NUMERO_DCTO NUMERO_DCTO, T.NOMBRE NOMBRE, A.NOMBREEVENTO, I.SUCURSAL, ( CASE I.ASISTIO WHEN 0 THEN 'false' ELSE 'true' END ) ASISTIO, I.CALIFICACION, ( CASE I.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END ) BENEFICIARIO FROM NAT_ACTIVIDADESINSCRITOS I INNER JOIN TERCERO T ON I.COMPANIA = T.COMPANIA AND I.NUMERO_DCTO = T.NIT AND I.SUCURSAL = T.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS A ON I.COMPANIA = A.COMPANIA AND I.IDEVENTO = A.IDEVENTO AND I.TIPOEVENTO = A.TIPOEVENTO WHERE I.COMPANIA =:COMPANIA AND I.TIPOEVENTO =:TIPOEVENTO UNION ALL SELECT I.COMPANIA, I.IDEVENTO, I.TIPOEVENTO, TO_CHAR(I.FECHAINICIAL,'DD/MM/YYYY') FECHAINICIAL, F.IDENTIFICACION NUMERO_DCTO, TO_CHAR(CONCAT( F.NOMBRE , CONCAT(F.APELLIDO1 , F.APELLIDO2))) NOMBRE, A.NOMBREEVENTO, I.SUCURSAL, ( CASE I.ASISTIO WHEN 0 THEN 'false' ELSE 'true' END ) ASISTIO, I.CALIFICACION, ( CASE I.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END ) BENEFICIARIO FROM NAT_ACTIVIDADESINSCRITOS I INNER JOIN FAMILIARES F ON I.COMPANIA = F.COMPANIA AND I.NUMERO_DCTO = F.IDENTIFICACION AND I.SUCURSAL = F.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS A ON I.COMPANIA = A.COMPANIA AND I.IDEVENTO = A.IDEVENTO AND I.TIPOEVENTO = A.TIPOEVENTO WHERE I.COMPANIA =:COMPANIA AND I.TIPOEVENTO =:TIPOEVENTO AND I.BENEFICIARIO NOT IN (0) )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREEVENTO), '%')) AND (CASE WHEN ASISTIO IS NULL THEN ' ' ELSE UPPER(ASISTIO) END) LIKE UPPER(CONCAT(:ASISTIO, '%')) AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END) LIKE UPPER(CONCAT(:CALIFICACION, '%')) AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END) LIKE UPPER(CONCAT(:BENEFICIARIO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","FECHAINICIAL":"$FECHAINICIAL","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRE":"$NOMBRE","NOMBREEVENTO":"$NOMBREEVENTO","SUCURSAL":"$SUCURSAL","ASISTIO":"$ASISTIO","CALIFICACION":"$CALIFICACION(type:integer)","BENEFICIARIO":"$BENEFICIARIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="ASISTIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="actividadesinscritos">
		<call-query href="getActividadesinscritosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREEVENTO" query-param="NOMBREEVENTO"/>
			<with-param name="ASISTIO" query-param="ASISTIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getActividadesinscritosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT * FROM ( SELECT I.COMPANIA, I.IDEVENTO, I.TIPOEVENTO, TO_CHAR(I.FECHAINICIAL,'DD/MM/YYYY') FECHAINICIAL, I.NUMERO_DCTO NUMERO_DCTO, T.NOMBRE NOMBRE, A.NOMBREEVENTO, I.SUCURSAL, ( CASE I.ASISTIO WHEN 0 THEN 'false' ELSE 'true' END ) ASISTIO, I.CALIFICACION, ( CASE I.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END ) BENEFICIARIO FROM NAT_ACTIVIDADESINSCRITOS I INNER JOIN TERCERO T ON I.COMPANIA = T.COMPANIA AND I.NUMERO_DCTO = T.NIT AND I.SUCURSAL = T.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS A ON I.COMPANIA = A.COMPANIA AND I.IDEVENTO = A.IDEVENTO AND I.TIPOEVENTO = A.TIPOEVENTO WHERE I.COMPANIA =:COMPANIA AND I.TIPOEVENTO =:TIPOEVENTO UNION ALL SELECT I.COMPANIA, I.IDEVENTO, I.TIPOEVENTO, TO_CHAR(I.FECHAINICIAL,'DD/MM/YYYY') FECHAINICIAL, F.IDENTIFICACION NUMERO_DCTO, TO_CHAR(CONCAT( F.NOMBRE , CONCAT(F.APELLIDO1 , F.APELLIDO2))) NOMBRE, A.NOMBREEVENTO, I.SUCURSAL, ( CASE I.ASISTIO WHEN 0 THEN 'false' ELSE 'true' END ) ASISTIO, I.CALIFICACION, ( CASE I.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END ) BENEFICIARIO FROM NAT_ACTIVIDADESINSCRITOS I INNER JOIN FAMILIARES F ON I.COMPANIA = F.COMPANIA AND I.NUMERO_DCTO = F.IDENTIFICACION AND I.SUCURSAL = F.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS A ON I.COMPANIA = A.COMPANIA AND I.IDEVENTO = A.IDEVENTO AND I.TIPOEVENTO = A.TIPOEVENTO WHERE I.COMPANIA =:COMPANIA AND I.TIPOEVENTO =:TIPOEVENTO AND I.BENEFICIARIO NOT IN (0) )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBREEVENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREEVENTO), '%')) AND (CASE WHEN ASISTIO IS NULL THEN ' ' ELSE UPPER(ASISTIO) END) LIKE UPPER(CONCAT(:ASISTIO, '%')) AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END) LIKE UPPER(CONCAT(:CALIFICACION, '%')) AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END) LIKE UPPER(CONCAT(:BENEFICIARIO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREEVENTO" sqlType="STRING"/>
		<param name="ASISTIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="actividadesinscritos/numero">
		<call-query href="getActividadesinscritosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREEVENTO" query-param="NOMBREEVENTO"/>
			<with-param name="ASISTIO" query-param="ASISTIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>

		</call-query>
	</resource>
	<query id="getActividadesinscritosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, IDEVENTO, TIPOEVENTO, NUMERO_DCTO, SUCURSAL,(CASE ASISTIO WHEN 0 THEN 'false' ELSE 'true' END) ASISTIO,(TO_CHAR(FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIAL,(CASE BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, CALIFICACION  FROM NAT_ACTIVIDADESINSCRITOS WHERE NAT_ACTIVIDADESINSCRITOS.COMPANIA= :KEY_COMPANIA AND NAT_ACTIVIDADESINSCRITOS.IDEVENTO= :KEY_IDEVENTO AND NAT_ACTIVIDADESINSCRITOS.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_ACTIVIDADESINSCRITOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_ACTIVIDADESINSCRITOS.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","ASISTIO":"$ASISTIO(type:boolean)","FECHAINICIAL":"$FECHAINICIAL","BENEFICIARIO":"$BENEFICIARIO(type:boolean)","CALIFICACION":"$CALIFICACION(type:integer)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="actividadesinscritos/data">
		<call-query href="getActividadesinscritosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateActividadesinscritos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_ACTIVIDADESINSCRITOS SET IDEVENTO=:IDEVENTO, ASISTIO=:ASISTIO, CALIFICACION=:CALIFICACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_ACTIVIDADESINSCRITOS.COMPANIA= :KEY_COMPANIA AND NAT_ACTIVIDADESINSCRITOS.IDEVENTO= :KEY_IDEVENTO AND NAT_ACTIVIDADESINSCRITOS.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_ACTIVIDADESINSCRITOS.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_ACTIVIDADESINSCRITOS.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="ASISTIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="actividadesinscritos">
		<call-query href="updateActividadesinscritos">
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="ASISTIO" query-param="ASISTIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>