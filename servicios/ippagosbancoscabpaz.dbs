<data name="ippagosbancoscabpaz" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertIppagosbancoscabpaz" keyColumns="COMPANIA,PAG_BAN,PAQUETE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_PAGOS_BANCOSCAB_PAZ (COMPANIA, PREFEC, PAG_BAN, PAQUETE, NROCUPONES, VLREPORTADO, NROCUPONESACU, VLACUMULADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, TO_DATE(:PREFEC,'DD/MM/YYYY HH24:MI:SS'), :PAG_BAN, :PAQUETE, :NROCUPONES, :VLREPORTADO, :NROCUPONESACU, :VLACUMULADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PREFEC":"$PREFEC","KEY_PAG_BAN":"$PAG_BAN","KEY_PAQUETE":"$PAQUETE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREFEC" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>
		<param name="PAQUETE" sqlType="STRING"/>
		<param defaultValue="0" name="NROCUPONES" sqlType="STRING"/>
		<param defaultValue="0" name="VLREPORTADO" sqlType="STRING"/>
		<param defaultValue="0" name="NROCUPONESACU" sqlType="STRING"/>
		<param defaultValue="0" name="VLACUMULADO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ippagosbancoscabpaz">
		<call-query href="insertIppagosbancoscabpaz">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREFEC" query-param="PREFEC"/>
			<with-param name="PAG_BAN" query-param="PAG_BAN"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="NROCUPONES" query-param="NROCUPONES"/>
			<with-param name="VLREPORTADO" query-param="VLREPORTADO"/>
			<with-param name="NROCUPONESACU" query-param="NROCUPONESACU"/>
			<with-param name="VLACUMULADO" query-param="VLACUMULADO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteIppagosbancoscabpaz" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM IP_PAGOS_BANCOSCAB_PAZ WHERE IP_PAGOS_BANCOSCAB_PAZ.COMPANIA= :KEY_COMPANIA AND IP_PAGOS_BANCOSCAB_PAZ.PREFEC= TO_DATE(:KEY_PREFEC,'DD/MM/YYYY HH24:MI:SS')  AND IP_PAGOS_BANCOSCAB_PAZ.PAG_BAN= :KEY_PAG_BAN AND IP_PAGOS_BANCOSCAB_PAZ.PAQUETE= :KEY_PAQUETE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PREFEC" sqlType="STRING"/>
		<param name="KEY_PAG_BAN" sqlType="STRING"/>
		<param name="KEY_PAQUETE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="ippagosbancoscabpaz">
		<call-query href="deleteIppagosbancoscabpaz">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PREFEC" query-param="KEY_PREFEC"/>
			<with-param name="KEY_PAG_BAN" query-param="KEY_PAG_BAN"/>
			<with-param name="KEY_PAQUETE" query-param="KEY_PAQUETE"/>

		</call-query>
	</resource>
	<query id="getIppagosbancoscabpazPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA ,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, TO_CHAR(PREFEC,'DD/MM/YYYY') PREFEC2 , PAG_BAN , PAQUETE , NROCUPONES , TO_CHAR(VLREPORTADO,'$999,999,999,999,999,999.00')VLREPORTADO , NROCUPONESACU , TO_CHAR(VLACUMULADO,'$999,999,999,999,999,999.00')VLACUMULADO  FROM IP_PAGOS_BANCOSCAB_PAZ WHERE COMPANIA = :COMPANIA ORDER BY IP_PAGOS_BANCOSCAB_PAZ.PREFEC DESC, PAG_BAN DESC,PAQUETE DESC) WHERE (CASE WHEN PREFEC2 IS NULL THEN ' ' ELSE UPPER(PREFEC2) END)  LIKE UPPER( '%' || :PREFEC2 || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER(:PAG_BAN || '%')  AND (CASE WHEN PAQUETE IS NULL THEN ' ' ELSE UPPER(PAQUETE) END)  LIKE UPPER(:PAQUETE || '%')  AND (CASE WHEN NROCUPONES IS NULL THEN ' ' ELSE UPPER(NROCUPONES) END)  LIKE UPPER(:NROCUPONES || '%')  AND (CASE WHEN VLREPORTADO IS NULL THEN ' ' ELSE UPPER(VLREPORTADO) END)  LIKE UPPER(:VLREPORTADO || '%')  AND (CASE WHEN NROCUPONESACU IS NULL THEN ' ' ELSE UPPER(NROCUPONESACU) END)  LIKE UPPER(:NROCUPONESACU || '%')  AND (CASE WHEN VLACUMULADO IS NULL THEN ' ' ELSE UPPER(VLACUMULADO) END)  LIKE UPPER(:VLACUMULADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PREFEC":"$PREFEC","PREFEC2":"$PREFEC2","PAG_BAN":"$PAG_BAN","PAQUETE":"$PAQUETE","NROCUPONES":"$NROCUPONES","VLREPORTADO":"$VLREPORTADO","NROCUPONESACU":"$NROCUPONESACU","VLACUMULADO":"$VLACUMULADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREFEC2" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>
		<param name="PAQUETE" sqlType="STRING"/>
		<param name="NROCUPONES" sqlType="STRING"/>
		<param name="VLREPORTADO" sqlType="STRING"/>
		<param name="NROCUPONESACU" sqlType="STRING"/>
		<param name="VLACUMULADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ippagosbancoscabpaz">
		<call-query href="getIppagosbancoscabpazPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREFEC2" query-param="PREFEC2"/>
			<with-param name="PAG_BAN" query-param="PAG_BAN"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="NROCUPONES" query-param="NROCUPONES"/>
			<with-param name="VLREPORTADO" query-param="VLREPORTADO"/>
			<with-param name="NROCUPONESACU" query-param="NROCUPONESACU"/>
			<with-param name="VLACUMULADO" query-param="VLACUMULADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIppagosbancoscabpazNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA ,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, TO_CHAR(PREFEC,'DD/MM/YYYY') PREFEC2 , PAG_BAN , PAQUETE , NROCUPONES , TO_CHAR(VLREPORTADO,'$999,999,999,999,999,999.00')VLREPORTADO , NROCUPONESACU , TO_CHAR(VLACUMULADO,'$999,999,999,999,999,999.00')VLACUMULADO  FROM IP_PAGOS_BANCOSCAB_PAZ WHERE COMPANIA = :COMPANIA ORDER BY IP_PAGOS_BANCOSCAB_PAZ.PREFEC DESC, PAG_BAN DESC,PAQUETE DESC) WHERE (CASE WHEN PREFEC2 IS NULL THEN ' ' ELSE UPPER(PREFEC2) END)  LIKE UPPER( '%' || :PREFEC2 || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER(:PAG_BAN || '%')  AND (CASE WHEN PAQUETE IS NULL THEN ' ' ELSE UPPER(PAQUETE) END)  LIKE UPPER(:PAQUETE || '%')  AND (CASE WHEN NROCUPONES IS NULL THEN ' ' ELSE UPPER(NROCUPONES) END)  LIKE UPPER(:NROCUPONES || '%')  AND (CASE WHEN VLREPORTADO IS NULL THEN ' ' ELSE UPPER(VLREPORTADO) END)  LIKE UPPER(:VLREPORTADO || '%')  AND (CASE WHEN NROCUPONESACU IS NULL THEN ' ' ELSE UPPER(NROCUPONESACU) END)  LIKE UPPER(:NROCUPONESACU || '%')  AND (CASE WHEN VLACUMULADO IS NULL THEN ' ' ELSE UPPER(VLACUMULADO) END)  LIKE UPPER(:VLACUMULADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREFEC2" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>
		<param name="PAQUETE" sqlType="STRING"/>
		<param name="NROCUPONES" sqlType="STRING"/>
		<param name="VLREPORTADO" sqlType="STRING"/>
		<param name="NROCUPONESACU" sqlType="STRING"/>
		<param name="VLACUMULADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosbancoscabpaz/numero">
		<call-query href="getIppagosbancoscabpazNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREFEC2" query-param="PREFEC2"/>
			<with-param name="PAG_BAN" query-param="PAG_BAN"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="NROCUPONES" query-param="NROCUPONES"/>
			<with-param name="VLREPORTADO" query-param="VLREPORTADO"/>
			<with-param name="NROCUPONESACU" query-param="NROCUPONESACU"/>
			<with-param name="VLACUMULADO" query-param="VLACUMULADO"/>

		</call-query>
	</resource>
	<query id="getIppagosbancoscabpazRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,(TO_CHAR(PREFEC,'DD/MM/YYYY HH24:MI:SS')) PREFEC, PAG_BAN, PAQUETE, NROCUPONES, VLREPORTADO, NROCUPONESACU, VLACUMULADO,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CREATED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, MODIFIED_BY  FROM IP_PAGOS_BANCOSCAB_PAZ WHERE IP_PAGOS_BANCOSCAB_PAZ.COMPANIA= :KEY_COMPANIA AND IP_PAGOS_BANCOSCAB_PAZ.PREFEC= TO_DATE(:KEY_PREFEC,'DD/MM/YYYY HH24:MI:SS') AND IP_PAGOS_BANCOSCAB_PAZ.PAG_BAN= :KEY_PAG_BAN AND IP_PAGOS_BANCOSCAB_PAZ.PAQUETE= :KEY_PAQUETE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PREFEC":"$PREFEC","PAG_BAN":"$PAG_BAN","PAQUETE":"$PAQUETE","NROCUPONES":"$NROCUPONES","VLREPORTADO":"$VLREPORTADO","NROCUPONESACU":"$NROCUPONESACU","VLACUMULADO":"$VLACUMULADO","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PREFEC" sqlType="STRING"/>
		<param name="KEY_PAG_BAN" sqlType="STRING"/>
		<param name="KEY_PAQUETE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ippagosbancoscabpaz/data">
		<call-query href="getIppagosbancoscabpazRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PREFEC" query-param="KEY_PREFEC"/>
			<with-param name="KEY_PAG_BAN" query-param="KEY_PAG_BAN"/>
			<with-param name="KEY_PAQUETE" query-param="KEY_PAQUETE"/>

		</call-query>
	</resource>
	<query id="updateIppagosbancoscabpaz" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_PAGOS_BANCOSCAB_PAZ SET PREFEC=TO_DATE(:PREFEC,'DD/MM/YYYY HH24:MI:SS'), PAG_BAN=:PAG_BAN, PAQUETE=:PAQUETE, NROCUPONES=:NROCUPONES, VLREPORTADO=:VLREPORTADO, NROCUPONESACU=:NROCUPONESACU, VLACUMULADO=:VLACUMULADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_PAGOS_BANCOSCAB_PAZ.COMPANIA= :KEY_COMPANIA AND IP_PAGOS_BANCOSCAB_PAZ.PREFEC= TO_DATE(:KEY_PREFEC,'DD/MM/YYYY HH24:MI:SS')  AND IP_PAGOS_BANCOSCAB_PAZ.PAG_BAN= :KEY_PAG_BAN AND IP_PAGOS_BANCOSCAB_PAZ.PAQUETE= :KEY_PAQUETE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PREFEC" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>
		<param name="PAQUETE" sqlType="STRING"/>
		<param name="NROCUPONES" sqlType="STRING"/>
		<param name="VLREPORTADO" sqlType="STRING"/>
		<param name="NROCUPONESACU" sqlType="STRING"/>
		<param name="VLACUMULADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PREFEC" sqlType="STRING"/>
		<param name="KEY_PAG_BAN" sqlType="STRING"/>
		<param name="KEY_PAQUETE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ippagosbancoscabpaz">
		<call-query href="updateIppagosbancoscabpaz">
			<with-param name="PREFEC" query-param="PREFEC"/>
			<with-param name="PAG_BAN" query-param="PAG_BAN"/>
			<with-param name="PAQUETE" query-param="PAQUETE"/>
			<with-param name="NROCUPONES" query-param="NROCUPONES"/>
			<with-param name="VLREPORTADO" query-param="VLREPORTADO"/>
			<with-param name="NROCUPONESACU" query-param="NROCUPONESACU"/>
			<with-param name="VLACUMULADO" query-param="VLACUMULADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PREFEC" query-param="KEY_PREFEC"/>
			<with-param name="KEY_PAG_BAN" query-param="KEY_PAG_BAN"/>
			<with-param name="KEY_PAQUETE" query-param="KEY_PAQUETE"/>

		</call-query>
	</resource>

</data>