<data name="detallesplanossql" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDetallesplanossqlPagImpresionPlanosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, GRUPO, CODIGO ,SECUENCIA,DESCRIPCION  FROM DETALLE_PLANOS_SQL WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN SECUENCIA IS NULL THEN ' ' ELSE UPPER(SECUENCIA) END)  LIKE UPPER( '%' || :SECUENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","GRUPO":"$GRUPO","CODIGO":"$CODIGO","SECUENCIA":"$SECUENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallesplanossql/impresionplanos/pag">
		<call-query href="getDetallesplanossqlPagImpresionPlanosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetallesplanossqlNumImpresionPlanosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, GRUPO, CODIGO ,SECUENCIA,DESCRIPCION  FROM DETALLE_PLANOS_SQL WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN SECUENCIA IS NULL THEN ' ' ELSE UPPER(SECUENCIA) END)  LIKE UPPER( '%' || :SECUENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplanossql/impresionplanos/num">
		<call-query href="getDetallesplanossqlNumImpresionPlanosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertDetallesplanossql" keyColumns="COMPANIA,GRUPO,CODIGO,SECUENCIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO DETALLE_PLANOS_SQL (COMPANIA, GRUPO, CODIGO, SECUENCIA, NIVEL, SSQL, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :GRUPO, :CODIGO, :SECUENCIA, :NIVEL, :SSQL, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_GRUPO":"$GRUPO","KEY_CODIGO":"$CODIGO","KEY_SECUENCIA":"$SECUENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param defaultValue="" name="SSQL" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detallesplanossql">
		<call-query href="insertDetallesplanossql">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="SSQL" query-param="SSQL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDetallesplanossql" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM DETALLE_PLANOS_SQL WHERE DETALLE_PLANOS_SQL.COMPANIA= :KEY_COMPANIA AND DETALLE_PLANOS_SQL.GRUPO= :KEY_GRUPO AND DETALLE_PLANOS_SQL.CODIGO= :KEY_CODIGO AND DETALLE_PLANOS_SQL.SECUENCIA= :KEY_SECUENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_SECUENCIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="detallesplanossql">
		<call-query href="deleteDetallesplanossql">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_SECUENCIA" query-param="KEY_SECUENCIA"/>

		</call-query>
	</resource>
	<query id="getDetallesplanossqlPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, GRUPO, CODIGO ,SECUENCIA,DESCRIPCION  FROM DETALLE_PLANOS_SQL WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN GRUPO IS NULL THEN ' ' ELSE UPPER(GRUPO) END)  LIKE UPPER( '%' || :GRUPO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN SECUENCIA IS NULL THEN ' ' ELSE UPPER(SECUENCIA) END)  LIKE UPPER( '%' || :SECUENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","GRUPO":"$GRUPO","CODIGO":"$CODIGO","SECUENCIA":"$SECUENCIA","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="detallesplanossql">
		<call-query href="getDetallesplanossqlPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDetallesplanossqlNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, GRUPO, CODIGO ,SECUENCIA,DESCRIPCION  FROM DETALLE_PLANOS_SQL WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN GRUPO IS NULL THEN ' ' ELSE UPPER(GRUPO) END)  LIKE UPPER( '%' || :GRUPO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN SECUENCIA IS NULL THEN ' ' ELSE UPPER(SECUENCIA) END)  LIKE UPPER( '%' || :SECUENCIA || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplanossql/numero">
		<call-query href="getDetallesplanossqlNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getDetallesplanossqlRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, GRUPO, CODIGO, SECUENCIA,NIVEL,SSQL,DESCRIPCION  FROM DETALLE_PLANOS_SQL WHERE DETALLE_PLANOS_SQL.COMPANIA= :KEY_COMPANIA AND DETALLE_PLANOS_SQL.GRUPO= :KEY_GRUPO AND DETALLE_PLANOS_SQL.CODIGO= :KEY_CODIGO AND DETALLE_PLANOS_SQL.SECUENCIA= :KEY_SECUENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","GRUPO":"$GRUPO","CODIGO":"$CODIGO","SECUENCIA":"$SECUENCIA","NIVEL":"$NIVEL(type:integer)","SSQL":"$SSQL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_SECUENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detallesplanossql/data">
		<call-query href="getDetallesplanossqlRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_SECUENCIA" query-param="KEY_SECUENCIA"/>

		</call-query>
	</resource>
	<query id="updateDetallesplanossql" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE DETALLE_PLANOS_SQL SET COMPANIA=:COMPANIA, GRUPO=:GRUPO, CODIGO=:CODIGO, SECUENCIA=:SECUENCIA, NIVEL=:NIVEL, SSQL=:SSQL, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE DETALLE_PLANOS_SQL.COMPANIA= :KEY_COMPANIA AND DETALLE_PLANOS_SQL.GRUPO= :KEY_GRUPO AND DETALLE_PLANOS_SQL.CODIGO= :KEY_CODIGO AND DETALLE_PLANOS_SQL.SECUENCIA= :KEY_SECUENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="NIVEL" sqlType="STRING"/>
		<param name="SSQL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_SECUENCIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detallesplanossql">
		<call-query href="updateDetallesplanossql">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="NIVEL" query-param="NIVEL"/>
			<with-param name="SSQL" query-param="SSQL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_SECUENCIA" query-param="KEY_SECUENCIA"/>

		</call-query>
	</resource>

</data>