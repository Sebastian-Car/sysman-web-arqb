<data name="sfdetallesabono" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateSfdetallesabonoActualizarPagosAbonos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_ABONO SET FECHA_PAGO   =TO_DATE(:FECHAPAGO,'DD/MM/YYYY HH24:MI:SS'),   ANODOC         = :ANODOC,   TIPODOC        = :TIPODOC,   NRODOC         = :NRODOC,   BANCO_PAGO     = :BANCO_PAGO,   ESTADO         = :ESTADO ,   DATE_MODIFIED  =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY    = :MODIFIED_BY WHERE COMPANIA   = :COMPANIA AND TIPO_ABONO   = :TIPO_ABONO AND CODIGO_ABONO = :CODIGO_ABONO AND CUOTA        = :CUOTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="ANODOC" sqlType="STRING"/>
		<param name="TIPODOC" sqlType="STRING"/>
		<param name="NRODOC" sqlType="STRING"/>
		<param name="BANCO_PAGO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_ABONO" sqlType="STRING"/>
		<param name="CODIGO_ABONO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfdetallesabono/actualizarpagosabonos">
		<call-query href="updateSfdetallesabonoActualizarPagosAbonos">
			<with-param name="FECHAPAGO" query-param="FECHAPAGO"/>
			<with-param name="ANODOC" query-param="ANODOC"/>
			<with-param name="TIPODOC" query-param="TIPODOC"/>
			<with-param name="NRODOC" query-param="NRODOC"/>
			<with-param name="BANCO_PAGO" query-param="BANCO_PAGO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_ABONO" query-param="TIPO_ABONO"/>
			<with-param name="CODIGO_ABONO" query-param="CODIGO_ABONO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>

		</call-query>
	</resource>
	<query id="getSfdetallesabonoTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(CAPITAL) CAPITAL, SUM(INTERES) INTERES, SUM(INT_RECARGO) INT_RECARGO, SUM(TOTAL_CUOTA) TOTAL_CUOTA, SUM(INT_FINANCIACION) INT_FINANCIACION FROM SF_DETALLE_ABONO WHERE COMPANIA =:COMPANIA AND TIPO_ABONO = :TIPOCOBRO AND CODIGO_ABONO = :CODIGOCOBRO AND ESTADO IN ('R','A')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CAPITAL":"$CAPITAL","INTERES":"$INTERES","INT_RECARGO":"$INT_RECARGO","TOTAL_CUOTA":"$TOTAL_CUOTA","INT_FINANCIACION":"$INT_FINANCIACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGOCOBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallesabono/totales">
		<call-query href="getSfdetallesabonoTotalesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGOCOBRO" query-param="CODIGOCOBRO"/>

		</call-query>
	</resource>
	<query id="updateSfdetallesabonoActualizarCodruta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_DETALLE_ABONO SET CODIGORUTA=:CODIGORUTA,MODIFIED_BY = :MODIFIED_BY, DATE_MODIFIED = :DATE_MODIFIED WHERE COMPANIA = :COMPANIA AND TIPO_ABONO =:TIPO AND CODIGO_ABONO = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfdetallesabono/actualizarcodruta">
		<call-query href="updateSfdetallesabonoActualizarCodruta">
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSfdetallesabonoReadAbonosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CUOTA,(TO_CHAR(FECHACUOTA,'DD/MM/YYYY HH24:MI:SS')) FECHACUOTA, CAPITAL, INTERES, INT_FINANCIACION, INT_RECARGO, TOTAL_CUOTA, NRODOC,(TO_CHAR(FECHA_PAGO,'DD/MM/YYYY HH24:MI:SS')) FECHA_PAGO, BANCO_PAGO  FROM SF_DETALLE_ABONO WHERE COMPANIA = :COMPANIA AND TIPO_ABONO =:TIPO AND CODIGO_ABONO = :CODIGO AND ESTADO NOT IN ('X') ORDER BY CUOTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUOTA":"$CUOTA(type:integer)","FECHACUOTA":"$FECHACUOTA","CAPITAL":"$CAPITAL","INTERES":"$INTERES","INT_FINANCIACION":"$INT_FINANCIACION","INT_RECARGO":"$INT_RECARGO","TOTAL_CUOTA":"$TOTAL_CUOTA","NRODOC":"$NRODOC(type:long)","FECHA_PAGO":"$FECHA_PAGO","BANCO_PAGO":"$BANCO_PAGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallesabono/readabonos">
		<call-query href="getSfdetallesabonoReadAbonosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getSfdetallesabonoPagAmortizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_DETALLE_ABONO.CUOTA, (SF_ABONOS.DEUDA_TOTAL - SF_ABONOS.CUOTA_INICIAL) - CASE WHEN CUOTA = 1 THEN 0 ELSE SUM(SF_DETALLE_ABONO.CAPITAL ) OVER (ORDER BY CUOTA ROWS UNBOUNDED PRECEDING)-SF_DETALLE_ABONO.CAPITAL END DEUDA_PARCIAL, SF_DETALLE_ABONO.TOTAL_CUOTA, SF_DETALLE_ABONO.INT_FINANCIACION, SF_DETALLE_ABONO.CAPITAL  FROM SF_DETALLE_ABONO INNER JOIN SF_ABONOS ON SF_DETALLE_ABONO.COMPANIA = SF_ABONOS.COMPANIA AND SF_DETALLE_ABONO.TIPO_ABONO = SF_ABONOS.TIPO AND SF_DETALLE_ABONO.CODIGO_ABONO = SF_ABONOS.CODIGO WHERE SF_DETALLE_ABONO.COMPANIA = :COMPANIA AND SF_DETALLE_ABONO.TIPO_ABONO = :TIPO AND SF_DETALLE_ABONO.CODIGO_ABONO = :CODIGO AND SF_DETALLE_ABONO.CUOTA &lt;&gt;0) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN DEUDA_PARCIAL IS NULL THEN ' ' ELSE UPPER(DEUDA_PARCIAL) END)  LIKE UPPER(:DEUDA_PARCIAL || '%')  AND (CASE WHEN TOTAL_CUOTA IS NULL THEN ' ' ELSE UPPER(TOTAL_CUOTA) END)  LIKE UPPER(:TOTAL_CUOTA || '%')  AND (CASE WHEN INT_FINANCIACION IS NULL THEN ' ' ELSE UPPER(INT_FINANCIACION) END)  LIKE UPPER(:INT_FINANCIACION || '%')  AND (CASE WHEN CAPITAL IS NULL THEN ' ' ELSE UPPER(CAPITAL) END)  LIKE UPPER(:CAPITAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUOTA":"$CUOTA(type:integer)","DEUDA_PARCIAL":"$DEUDA_PARCIAL","TOTAL_CUOTA":"$TOTAL_CUOTA","INT_FINANCIACION":"$INT_FINANCIACION","CAPITAL":"$CAPITAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="DEUDA_PARCIAL" sqlType="STRING"/>
		<param name="TOTAL_CUOTA" sqlType="STRING"/>
		<param name="INT_FINANCIACION" sqlType="STRING"/>
		<param name="CAPITAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfdetallesabono/amortizacion/pag">
		<call-query href="getSfdetallesabonoPagAmortizacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>
			<with-param name="DEUDA_PARCIAL" query-param="DEUDA_PARCIAL"/>
			<with-param name="TOTAL_CUOTA" query-param="TOTAL_CUOTA"/>
			<with-param name="INT_FINANCIACION" query-param="INT_FINANCIACION"/>
			<with-param name="CAPITAL" query-param="CAPITAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfdetallesabonoNumAmortizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_DETALLE_ABONO.CUOTA, (SF_ABONOS.DEUDA_TOTAL - SF_ABONOS.CUOTA_INICIAL) - CASE WHEN CUOTA = 1 THEN 0 ELSE SUM(SF_DETALLE_ABONO.CAPITAL ) OVER (ORDER BY CUOTA ROWS UNBOUNDED PRECEDING)-SF_DETALLE_ABONO.CAPITAL END DEUDA_PARCIAL, SF_DETALLE_ABONO.TOTAL_CUOTA, SF_DETALLE_ABONO.INT_FINANCIACION, SF_DETALLE_ABONO.CAPITAL  FROM SF_DETALLE_ABONO INNER JOIN SF_ABONOS ON SF_DETALLE_ABONO.COMPANIA = SF_ABONOS.COMPANIA AND SF_DETALLE_ABONO.TIPO_ABONO = SF_ABONOS.TIPO AND SF_DETALLE_ABONO.CODIGO_ABONO = SF_ABONOS.CODIGO WHERE SF_DETALLE_ABONO.COMPANIA = :COMPANIA AND SF_DETALLE_ABONO.TIPO_ABONO = :TIPO AND SF_DETALLE_ABONO.CODIGO_ABONO = :CODIGO AND SF_DETALLE_ABONO.CUOTA &lt;&gt;0) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN DEUDA_PARCIAL IS NULL THEN ' ' ELSE UPPER(DEUDA_PARCIAL) END)  LIKE UPPER(:DEUDA_PARCIAL || '%')  AND (CASE WHEN TOTAL_CUOTA IS NULL THEN ' ' ELSE UPPER(TOTAL_CUOTA) END)  LIKE UPPER(:TOTAL_CUOTA || '%')  AND (CASE WHEN INT_FINANCIACION IS NULL THEN ' ' ELSE UPPER(INT_FINANCIACION) END)  LIKE UPPER(:INT_FINANCIACION || '%')  AND (CASE WHEN CAPITAL IS NULL THEN ' ' ELSE UPPER(CAPITAL) END)  LIKE UPPER(:CAPITAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="DEUDA_PARCIAL" sqlType="STRING"/>
		<param name="TOTAL_CUOTA" sqlType="STRING"/>
		<param name="INT_FINANCIACION" sqlType="STRING"/>
		<param name="CAPITAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallesabono/amortizacion/num">
		<call-query href="getSfdetallesabonoNumAmortizacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>
			<with-param name="DEUDA_PARCIAL" query-param="DEUDA_PARCIAL"/>
			<with-param name="TOTAL_CUOTA" query-param="TOTAL_CUOTA"/>
			<with-param name="INT_FINANCIACION" query-param="INT_FINANCIACION"/>
			<with-param name="CAPITAL" query-param="CAPITAL"/>

		</call-query>
	</resource>
	<query id="getSfdetallesabonoCantidadCuotasRecaudadasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) PAGADAS  FROM SF_DETALLE_ABONO WHERE COMPANIA =:COMPANIA AND TIPO_ABONO =:TIPO AND CODIGO_ABONO =:CODIGO AND ESTADO IN ('R')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAGADAS":"$PAGADAS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfdetallesabono/cantidadcuotasrecaudadas">
		<call-query href="getSfdetallesabonoCantidadCuotasRecaudadasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>

</data>