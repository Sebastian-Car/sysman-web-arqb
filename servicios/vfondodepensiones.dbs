<data name="vfondodepensiones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVfondodepensionesTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ID_DEL_FONDO, NOMBRE_DEL_FONDO  FROM V_FONDO_DE_PENSIONES WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DEL_FONDO":"$ID_DEL_FONDO","NOMBRE_DEL_FONDO":"$NOMBRE_DEL_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vfondodepensiones/todosporcompania">
		<call-query href="getVfondodepensionesTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getVfondodepensionesPagTodosporcompaniagrandeQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID_DEL_FONDO, NOMBRE_DEL_FONDO  FROM V_FONDO_DE_PENSIONES WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_DEL_FONDO IS NULL THEN ' ' ELSE UPPER(ID_DEL_FONDO) END)  LIKE UPPER(:ID_DEL_FONDO || '%')  AND (CASE WHEN NOMBRE_DEL_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_FONDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DEL_FONDO":"$ID_DEL_FONDO","NOMBRE_DEL_FONDO":"$NOMBRE_DEL_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DEL_FONDO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_FONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vfondodepensiones/todosporcompaniagrande/pag">
		<call-query href="getVfondodepensionesPagTodosporcompaniagrandeQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DEL_FONDO" query-param="ID_DEL_FONDO"/>
			<with-param name="NOMBRE_DEL_FONDO" query-param="NOMBRE_DEL_FONDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVfondodepensionesNumTodosporcompaniagrandeQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID_DEL_FONDO, NOMBRE_DEL_FONDO  FROM V_FONDO_DE_PENSIONES WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN ID_DEL_FONDO IS NULL THEN ' ' ELSE UPPER(ID_DEL_FONDO) END)  LIKE UPPER(:ID_DEL_FONDO || '%')  AND (CASE WHEN NOMBRE_DEL_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_DEL_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_DEL_FONDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DEL_FONDO" sqlType="STRING"/>
		<param name="NOMBRE_DEL_FONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vfondodepensiones/todosporcompaniagrande/num">
		<call-query href="getVfondodepensionesNumTodosporcompaniagrandeQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DEL_FONDO" query-param="ID_DEL_FONDO"/>
			<with-param name="NOMBRE_DEL_FONDO" query-param="NOMBRE_DEL_FONDO"/>

		</call-query>
	</resource>

</data>