<data name="natclasenovedadvacaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNatclasenovedadvacacionesClasenovedadvacacionesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO CODNOVED, NOVEDAD_VACACIONES  FROM NAT_CLASE_NOVEDAD_VACACIONES ORDER BY NOVEDAD_VACACIONES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODNOVED":"$CODNOVED","NOVEDAD_VACACIONES":"$NOVEDAD_VACACIONES"}]}}		</result>
 
	</query>
	<resource method="GET" path="natclasenovedadvacaciones/clasenovedadvacaciones">
		<call-query href="getNatclasenovedadvacacionesClasenovedadvacacionesQuery">
 
		</call-query>
	</resource>

</data>