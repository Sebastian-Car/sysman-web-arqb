<data name="variableproponente" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVariableproponenteTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT VARIABLE_PROPONENTE.CODIGO, CONCAT( VARIABLE_PROPONENTE.CODIGO , CONCAT( ' ' , VARIABLE_PROPONENTE.DESCRIPCION )) DESCRIPCION FROM VARIABLE_PROPONENTE WHERE VARIABLE_PROPONENTE.COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="variableproponente/todosporcompania">
		<call-query href="getVariableproponenteTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertVariableproponente" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VARIABLE_PROPONENTE (CODIGO, DESCRIPCION, TIPO, VRPREDETERMINADO, ESCONSTANTE, ORDEN, COMPANIA, DATE_CREATED, CREATED_BY) VALUES (:CODIGO, :DESCRIPCION, :TIPO, :VRPREDETERMINADO, :ESCONSTANTE, :ORDEN, :COMPANIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="VRPREDETERMINADO" sqlType="STRING"/>
		<param defaultValue="0" name="ESCONSTANTE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="variableproponente">
		<call-query href="insertVariableproponente">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="VRPREDETERMINADO" query-param="VRPREDETERMINADO"/>
			<with-param name="ESCONSTANTE" query-param="ESCONSTANTE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVariableproponente" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VARIABLE_PROPONENTE WHERE VARIABLE_PROPONENTE.COMPANIA= :KEY_COMPANIA AND VARIABLE_PROPONENTE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="variableproponente">
		<call-query href="deleteVariableproponente">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getVariableproponentePaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VARIABLE_PROPONENTE.CODIGO, VARIABLE_PROPONENTE.DESCRIPCION, VARIABLE_PROPONENTE.TIPO, CASE VARIABLE_PROPONENTE.TIPO WHEN '1' THEN 'Texto' WHEN '3' THEN 'Numérico' WHEN '4' THEN 'Fecha' WHEN '5' THEN 'Fórmula' WHEN '6' THEN 'Hora' END NOMBRETIPO, VARIABLE_PROPONENTE.VRPREDETERMINADO,(CASE VARIABLE_PROPONENTE.ESCONSTANTE WHEN 0 THEN 'false' ELSE 'true' END) ESCONSTANTE, VARIABLE_PROPONENTE.ORDEN, VARIABLE_PROPONENTE.COMPANIA  FROM VARIABLE_PROPONENTE WHERE VARIABLE_PROPONENTE.COMPANIA = :COMPANIA ORDER BY TO_NUMBER(VARIABLE_PROPONENTE.CODIGO)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END)  LIKE UPPER( '%' || :NOMBRETIPO || '%')  AND (CASE WHEN VRPREDETERMINADO IS NULL THEN ' ' ELSE UPPER(VRPREDETERMINADO) END)  LIKE UPPER( '%' || :VRPREDETERMINADO || '%')  AND (CASE WHEN ESCONSTANTE IS NULL THEN ' ' ELSE UPPER(ESCONSTANTE) END)  LIKE UPPER(:ESCONSTANTE || '%')  AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END)  LIKE UPPER(:ORDEN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","TIPO":"$TIPO","NOMBRETIPO":"$NOMBRETIPO","VRPREDETERMINADO":"$VRPREDETERMINADO","ESCONSTANTE":"$ESCONSTANTE(type:boolean)","ORDEN":"$ORDEN(type:integer)","COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="VRPREDETERMINADO" sqlType="STRING"/>
		<param name="ESCONSTANTE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="variableproponente">
		<call-query href="getVariableproponentePaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="VRPREDETERMINADO" query-param="VRPREDETERMINADO"/>
			<with-param name="ESCONSTANTE" query-param="ESCONSTANTE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVariableproponenteNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VARIABLE_PROPONENTE.CODIGO, VARIABLE_PROPONENTE.DESCRIPCION, VARIABLE_PROPONENTE.TIPO, CASE VARIABLE_PROPONENTE.TIPO WHEN '1' THEN 'Texto' WHEN '3' THEN 'Numérico' WHEN '4' THEN 'Fecha' WHEN '5' THEN 'Fórmula' WHEN '6' THEN 'Hora' END NOMBRETIPO, VARIABLE_PROPONENTE.VRPREDETERMINADO,(CASE VARIABLE_PROPONENTE.ESCONSTANTE WHEN 0 THEN 'false' ELSE 'true' END) ESCONSTANTE, VARIABLE_PROPONENTE.ORDEN, VARIABLE_PROPONENTE.COMPANIA  FROM VARIABLE_PROPONENTE WHERE VARIABLE_PROPONENTE.COMPANIA = :COMPANIA ORDER BY TO_NUMBER(VARIABLE_PROPONENTE.CODIGO)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END)  LIKE UPPER( '%' || :NOMBRETIPO || '%')  AND (CASE WHEN VRPREDETERMINADO IS NULL THEN ' ' ELSE UPPER(VRPREDETERMINADO) END)  LIKE UPPER( '%' || :VRPREDETERMINADO || '%')  AND (CASE WHEN ESCONSTANTE IS NULL THEN ' ' ELSE UPPER(ESCONSTANTE) END)  LIKE UPPER(:ESCONSTANTE || '%')  AND (CASE WHEN ORDEN IS NULL THEN ' ' ELSE UPPER(ORDEN) END)  LIKE UPPER(:ORDEN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="VRPREDETERMINADO" sqlType="STRING"/>
		<param name="ESCONSTANTE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="variableproponente/numero">
		<call-query href="getVariableproponenteNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="VRPREDETERMINADO" query-param="VRPREDETERMINADO"/>
			<with-param name="ESCONSTANTE" query-param="ESCONSTANTE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>

		</call-query>
	</resource>
	<query id="updateVariableproponente" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VARIABLE_PROPONENTE SET CODIGO=:CODIGO, DESCRIPCION=:DESCRIPCION, TIPO=:TIPO, VRPREDETERMINADO=:VRPREDETERMINADO, ESCONSTANTE=:ESCONSTANTE, ORDEN=:ORDEN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VARIABLE_PROPONENTE.COMPANIA= :KEY_COMPANIA AND VARIABLE_PROPONENTE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="VRPREDETERMINADO" sqlType="STRING"/>
		<param name="ESCONSTANTE" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="variableproponente">
		<call-query href="updateVariableproponente">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="VRPREDETERMINADO" query-param="VRPREDETERMINADO"/>
			<with-param name="ESCONSTANTE" query-param="ESCONSTANTE"/>
			<with-param name="ORDEN" query-param="ORDEN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>