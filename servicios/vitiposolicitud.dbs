<data name="vitiposolicitud" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVitiposolicitudPagCodigoYDescripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VI_TIPOSOLICITUD.CODTIPO, VI_TIPOSOLICITUD.DESCRIPCION  FROM VI_TIPOSOLICITUD WHERE VI_TIPOSOLICITUD.COMPANIA = :COMPANIA ORDER BY VI_TIPOSOLICITUD.CODTIPO) WHERE (CASE WHEN CODTIPO IS NULL THEN ' ' ELSE UPPER(CODTIPO) END)  LIKE UPPER(:CODTIPO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODTIPO":"$CODTIPO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODTIPO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vitiposolicitud/codigoydescripcion/pag">
		<call-query href="getVitiposolicitudPagCodigoYDescripcionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODTIPO" query-param="CODTIPO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVitiposolicitudNumCodigoYDescripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VI_TIPOSOLICITUD.CODTIPO, VI_TIPOSOLICITUD.DESCRIPCION  FROM VI_TIPOSOLICITUD WHERE VI_TIPOSOLICITUD.COMPANIA = :COMPANIA ORDER BY VI_TIPOSOLICITUD.CODTIPO) WHERE (CASE WHEN CODTIPO IS NULL THEN ' ' ELSE UPPER(CODTIPO) END)  LIKE UPPER(:CODTIPO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODTIPO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vitiposolicitud/codigoydescripcion/num">
		<call-query href="getVitiposolicitudNumCodigoYDescripcionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODTIPO" query-param="CODTIPO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertVitiposolicitud" keyColumns="COMPANIA,CODTIPO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VI_TIPOSOLICITUD (COMPANIA, CODTIPO, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODTIPO, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODTIPO":"$CODTIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODTIPO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vitiposolicitud">
		<call-query href="insertVitiposolicitud">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODTIPO" query-param="CODTIPO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVitiposolicitud" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VI_TIPOSOLICITUD WHERE VI_TIPOSOLICITUD.COMPANIA= :KEY_COMPANIA AND VI_TIPOSOLICITUD.CODTIPO= :KEY_CODTIPO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODTIPO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vitiposolicitud">
		<call-query href="deleteVitiposolicitud">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODTIPO" query-param="KEY_CODTIPO"/>

		</call-query>
	</resource>
	<query id="getVitiposolicitudPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA ,CODTIPO ,DESCRIPCION  FROM VI_TIPOSOLICITUD WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODTIPO IS NULL THEN ' ' ELSE UPPER(CODTIPO) END)  LIKE UPPER(:CODTIPO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODTIPO":"$CODTIPO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODTIPO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vitiposolicitud">
		<call-query href="getVitiposolicitudPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODTIPO" query-param="CODTIPO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVitiposolicitudNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA ,CODTIPO ,DESCRIPCION  FROM VI_TIPOSOLICITUD WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN CODTIPO IS NULL THEN ' ' ELSE UPPER(CODTIPO) END)  LIKE UPPER(:CODTIPO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODTIPO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vitiposolicitud/numero">
		<call-query href="getVitiposolicitudNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODTIPO" query-param="CODTIPO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="updateVitiposolicitud" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_TIPOSOLICITUD SET DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VI_TIPOSOLICITUD.COMPANIA= :KEY_COMPANIA AND VI_TIPOSOLICITUD.CODTIPO= :KEY_CODTIPO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODTIPO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vitiposolicitud">
		<call-query href="updateVitiposolicitud">
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODTIPO" query-param="KEY_CODTIPO"/>

		</call-query>
	</resource>

</data>