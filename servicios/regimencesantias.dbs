<data name="regimencesantias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getRegimencesantiasTodosLosRegiminescesantiasQuery"  useConfig="sysmandsunist">
		<sql>SELECT  REGIMEN_CESANTIAS.CODIGO, REGIMEN_CESANTIAS.NOMBRE  FROM REGIMEN_CESANTIAS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="regimencesantias/todoslosregiminescesantias">
		<call-query href="getRegimencesantiasTodosLosRegiminescesantiasQuery">
 
		</call-query>
	</resource>

</data>