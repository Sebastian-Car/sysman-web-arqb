			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getReexpresarvidautilPagRegistroreexpresionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT R.COMPANIA, R.ELEMENTO, R.NOMBRELARGO, R.SERIE, R.NIIF_VALOR_TOTAL, R.NIIF_VLRLIBROS,(TO_CHAR(R.FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS')) FECHACAMBIO, R.VIDAUTIL, R.DETERIORO,(TO_CHAR(R.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, R.ORIGEN FROM REEXPRESARVIDAUTIL R INNER JOIN ( SELECT COMPANIA, ELEMENTO, APLICA_REEXPRESION FROM DEVOLUTIVO WHERE APLICA_REEXPRESION NOT IN (0) GROUP BY COMPANIA, ELEMENTO, APLICA_REEXPRESION ) D ON R.COMPANIA = D.COMPANIA AND R.ELEMENTO = D.ELEMENTO WHERE R.COMPANIA = :COMPANIA ORDER BY R.ELEMENTO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN NIIF_VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_TOTAL) END) LIKE UPPER(CONCAT(:NIIF_VALOR_TOTAL, '%')) AND (CASE WHEN NIIF_VLRLIBROS IS NULL THEN ' ' ELSE UPPER(NIIF_VLRLIBROS) END) LIKE UPPER(CONCAT(:NIIF_VLRLIBROS, '%')) AND (CASE WHEN FECHACAMBIO IS NULL THEN ' ' ELSE UPPER(FECHACAMBIO) END) LIKE UPPER(CONCAT(:FECHACAMBIO, '%')) AND (CASE WHEN VIDAUTIL IS NULL THEN ' ' ELSE UPPER(VIDAUTIL) END) LIKE UPPER(CONCAT(:VIDAUTIL, '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(:DETERIORO, '%')) AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END) LIKE UPPER(CONCAT(:HORA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","SERIE":"$SERIE","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS","FECHACAMBIO":"$FECHACAMBIO","VIDAUTIL":"$VIDAUTIL","DETERIORO":"$DETERIORO","HORA":"$HORA","ORIGEN":"$ORIGEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param name="VIDAUTIL" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="reexpresarvidautil/registroreexpresion/pag">
		<call-query href="getReexpresarvidautilPagRegistroreexpresionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="NIIF_VALOR_TOTAL" query-param="NIIF_VALOR_TOTAL"/>
			<with-param name="NIIF_VLRLIBROS" query-param="NIIF_VLRLIBROS"/>
			<with-param name="FECHACAMBIO" query-param="FECHACAMBIO"/>
			<with-param name="VIDAUTIL" query-param="VIDAUTIL"/>
			<with-param name="DETERIORO" query-param="DETERIORO"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getReexpresarvidautilNumRegistroreexpresionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT R.COMPANIA, R.ELEMENTO, R.NOMBRELARGO, R.SERIE, R.NIIF_VALOR_TOTAL, R.NIIF_VLRLIBROS,(TO_CHAR(R.FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS')) FECHACAMBIO, R.VIDAUTIL, R.DETERIORO,(TO_CHAR(R.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, R.ORIGEN FROM REEXPRESARVIDAUTIL R INNER JOIN ( SELECT COMPANIA, ELEMENTO, APLICA_REEXPRESION FROM DEVOLUTIVO WHERE APLICA_REEXPRESION NOT IN (0) GROUP BY COMPANIA, ELEMENTO, APLICA_REEXPRESION ) D ON R.COMPANIA = D.COMPANIA AND R.ELEMENTO = D.ELEMENTO WHERE R.COMPANIA = :COMPANIA ORDER BY R.ELEMENTO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN NIIF_VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_TOTAL) END) LIKE UPPER(CONCAT(:NIIF_VALOR_TOTAL, '%')) AND (CASE WHEN NIIF_VLRLIBROS IS NULL THEN ' ' ELSE UPPER(NIIF_VLRLIBROS) END) LIKE UPPER(CONCAT(:NIIF_VLRLIBROS, '%')) AND (CASE WHEN FECHACAMBIO IS NULL THEN ' ' ELSE UPPER(FECHACAMBIO) END) LIKE UPPER(CONCAT(:FECHACAMBIO, '%')) AND (CASE WHEN VIDAUTIL IS NULL THEN ' ' ELSE UPPER(VIDAUTIL) END) LIKE UPPER(CONCAT(:VIDAUTIL, '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(:DETERIORO, '%')) AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END) LIKE UPPER(CONCAT(:HORA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param name="VIDAUTIL" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reexpresarvidautil/registroreexpresion/num">
		<call-query href="getReexpresarvidautilNumRegistroreexpresionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
