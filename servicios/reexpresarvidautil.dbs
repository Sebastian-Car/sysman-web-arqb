	<query id="deleteReexpresarvidautil" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM REEXPRESARVIDAUTIL WHERE REEXPRESARVIDAUTIL.COMPANIA= :KEY_COMPANIA AND REEXPRESARVIDAUTIL.ELEMENTO= :KEY_ELEMENTO AND REEXPRESARVIDAUTIL.SERIE= :KEY_SERIE AND REEXPRESARVIDAUTIL.FECHACAMBIO= TO_DATE(:KEY_FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>
		<param name="KEY_FECHACAMBIO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="reexpresarvidautil">
		<call-query href="deleteReexpresarvidautil">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>
			<with-param name="KEY_FECHACAMBIO" query-param="KEY_FECHACAMBIO"/>

		</call-query>
	</resource>
	<query id="getReexpresarvidautilPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ELEMENTO, SERIE, TO_CHAR(FECHACAMBIO) FECHACAMBIO, VIDAUTIL, DETERIORO FROM REEXPRESARVIDAUTIL WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND SERIE = :SERIE) INI WHERE (CASE WHEN FECHACAMBIO IS NULL THEN ' ' ELSE UPPER(FECHACAMBIO) END) LIKE UPPER(CONCAT(:FECHACAMBIO, '%')) AND (CASE WHEN VIDAUTIL IS NULL THEN ' ' ELSE UPPER(VIDAUTIL) END) LIKE UPPER(CONCAT(:VIDAUTIL, '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(:DETERIORO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","FECHACAMBIO":"$FECHACAMBIO","VIDAUTIL":"$VIDAUTIL","DETERIORO":"$DETERIORO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param name="VIDAUTIL" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="reexpresarvidautil">
		<call-query href="getReexpresarvidautilPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHACAMBIO" query-param="FECHACAMBIO"/>
			<with-param name="VIDAUTIL" query-param="VIDAUTIL"/>
			<with-param name="DETERIORO" query-param="DETERIORO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getReexpresarvidautilNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ELEMENTO, SERIE, TO_CHAR(FECHACAMBIO) FECHACAMBIO, VIDAUTIL, DETERIORO FROM REEXPRESARVIDAUTIL WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND SERIE = :SERIE) INI WHERE (CASE WHEN FECHACAMBIO IS NULL THEN ' ' ELSE UPPER(FECHACAMBIO) END) LIKE UPPER(CONCAT(:FECHACAMBIO, '%')) AND (CASE WHEN VIDAUTIL IS NULL THEN ' ' ELSE UPPER(VIDAUTIL) END) LIKE UPPER(CONCAT(:VIDAUTIL, '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(:DETERIORO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param name="VIDAUTIL" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reexpresarvidautil/numero">
		<call-query href="getReexpresarvidautilNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHACAMBIO" query-param="FECHACAMBIO"/>
			<with-param name="VIDAUTIL" query-param="VIDAUTIL"/>
			<with-param name="DETERIORO" query-param="DETERIORO"/>

		</call-query>
	</resource>
	<query id="updateReexpresarvidautil" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE REEXPRESARVIDAUTIL SET COMPANIA=:COMPANIA, ELEMENTO=:ELEMENTO, SERIE=:SERIE, FECHACAMBIO=TO_DATE(:FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS'), VIDAUTIL=:VIDAUTIL, DETERIORO=:DETERIORO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE REEXPRESARVIDAUTIL.COMPANIA= :KEY_COMPANIA AND REEXPRESARVIDAUTIL.ELEMENTO= :KEY_ELEMENTO AND REEXPRESARVIDAUTIL.SERIE= :KEY_SERIE AND REEXPRESARVIDAUTIL.FECHACAMBIO= TO_DATE(:KEY_FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

