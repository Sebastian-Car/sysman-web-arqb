<data name="reexpresarvidautil" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getReexpresarvidautilPagRegistrodeterioroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT R.COMPANIA, R.ELEMENTO, R.NOMBRELARGO, R.SERIE, R.NIIF_VALOR_TOTAL, R.NIIF_VLRLIBROS,(TO_CHAR(R.FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS')) FECHACAMBIO, R.VIDAUTIL, R.DETERIORO,(TO_CHAR(R.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, R.ORIGEN FROM REEXPRESARVIDAUTIL R INNER JOIN DEVOLUTIVO D ON R.COMPANIA = D.COMPANIA AND R.ELEMENTO = D.ELEMENTO WHERE R.COMPANIA = :COMPANIA AND D.APLICA_DETERIORO NOT IN (0) Group by R.COMPANIA, R.ELEMENTO, R.NOMBRELARGO, R.SERIE, R.NIIF_VALOR_TOTAL, R.NIIF_VLRLIBROS, R.FECHACAMBIO, R.VIDAUTIL, R.DETERIORO, R.HORA, R.ORIGEN ORDER BY R.ELEMENTO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN NIIF_VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_TOTAL) END) LIKE UPPER(CONCAT(:NIIF_VALOR_TOTAL, '%')) AND (CASE WHEN NIIF_VLRLIBROS IS NULL THEN ' ' ELSE UPPER(NIIF_VLRLIBROS) END) LIKE UPPER(CONCAT(:NIIF_VLRLIBROS, '%')) AND (CASE WHEN FECHACAMBIO IS NULL THEN ' ' ELSE UPPER(FECHACAMBIO) END) LIKE UPPER(CONCAT(:FECHACAMBIO, '%')) AND (CASE WHEN VIDAUTIL IS NULL THEN ' ' ELSE UPPER(VIDAUTIL) END) LIKE UPPER(CONCAT(:VIDAUTIL, '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(:DETERIORO, '%')) AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END) LIKE UPPER(CONCAT(:HORA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","SERIE":"$SERIE","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS","FECHACAMBIO":"$FECHACAMBIO","VIDAUTIL":"$VIDAUTIL","DETERIORO":"$DETERIORO","HORA":"$HORA","ORIGEN":"$ORIGEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param name="VIDAUTIL" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="reexpresarvidautil/registrodeterioro/pag">
		<call-query href="getReexpresarvidautilPagRegistrodeterioroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="NIIF_VALOR_TOTAL" query-param="NIIF_VALOR_TOTAL"/>
			<with-param name="NIIF_VLRLIBROS" query-param="NIIF_VLRLIBROS"/>
			<with-param name="FECHACAMBIO" query-param="FECHACAMBIO"/>
			<with-param name="VIDAUTIL" query-param="VIDAUTIL"/>
			<with-param name="DETERIORO" query-param="DETERIORO"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getReexpresarvidautilNumRegistrodeterioroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT R.COMPANIA, R.ELEMENTO, R.NOMBRELARGO, R.SERIE, R.NIIF_VALOR_TOTAL, R.NIIF_VLRLIBROS,(TO_CHAR(R.FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS')) FECHACAMBIO, R.VIDAUTIL, R.DETERIORO,(TO_CHAR(R.HORA,'DD/MM/YYYY HH24:MI:SS')) HORA, R.ORIGEN FROM REEXPRESARVIDAUTIL R INNER JOIN DEVOLUTIVO D ON R.COMPANIA = D.COMPANIA AND R.ELEMENTO = D.ELEMENTO WHERE R.COMPANIA = :COMPANIA AND D.APLICA_DETERIORO NOT IN (0) Group by R.COMPANIA, R.ELEMENTO, R.NOMBRELARGO, R.SERIE, R.NIIF_VALOR_TOTAL, R.NIIF_VLRLIBROS, R.FECHACAMBIO, R.VIDAUTIL, R.DETERIORO, R.HORA, R.ORIGEN ORDER BY R.ELEMENTO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN NIIF_VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_TOTAL) END) LIKE UPPER(CONCAT(:NIIF_VALOR_TOTAL, '%')) AND (CASE WHEN NIIF_VLRLIBROS IS NULL THEN ' ' ELSE UPPER(NIIF_VLRLIBROS) END) LIKE UPPER(CONCAT(:NIIF_VLRLIBROS, '%')) AND (CASE WHEN FECHACAMBIO IS NULL THEN ' ' ELSE UPPER(FECHACAMBIO) END) LIKE UPPER(CONCAT(:FECHACAMBIO, '%')) AND (CASE WHEN VIDAUTIL IS NULL THEN ' ' ELSE UPPER(VIDAUTIL) END) LIKE UPPER(CONCAT(:VIDAUTIL, '%')) AND (CASE WHEN DETERIORO IS NULL THEN ' ' ELSE UPPER(DETERIORO) END) LIKE UPPER(CONCAT(:DETERIORO, '%')) AND (CASE WHEN HORA IS NULL THEN ' ' ELSE UPPER(HORA) END) LIKE UPPER(CONCAT(:HORA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param name="VIDAUTIL" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reexpresarvidautil/registrodeterioro/num">
		<call-query href="getReexpresarvidautilNumRegistrodeterioroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="NIIF_VALOR_TOTAL" query-param="NIIF_VALOR_TOTAL"/>
			<with-param name="NIIF_VLRLIBROS" query-param="NIIF_VLRLIBROS"/>
			<with-param name="FECHACAMBIO" query-param="FECHACAMBIO"/>
			<with-param name="VIDAUTIL" query-param="VIDAUTIL"/>
			<with-param name="DETERIORO" query-param="DETERIORO"/>
			<with-param name="HORA" query-param="HORA"/>

		</call-query>
	</resource>
	<query id="updateReexpresarvidautilUpdateregistrodeterioro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE REEXPRESARVIDAUTIL SET ELEMENTO=:ELEMENTO, NOMBRELARGO=:NOMBRELARGO, SERIE=:SERIE, NIIF_VALOR_TOTAL=:NIIF_VALOR_TOTAL, NIIF_VLRLIBROS=:NIIF_VLRLIBROS, FECHACAMBIO=TO_DATE(:FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS'), VIDAUTIL=:VIDAUTIL, DETERIORO=:DETERIORO, HORA=TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), ORIGEN=:ORIGEN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE REEXPRESARVIDAUTIL.COMPANIA= :KEY_COMPANIA AND REEXPRESARVIDAUTIL.ELEMENTO= :KEY_ELEMENTO AND REEXPRESARVIDAUTIL.SERIE= :KEY_SERIE AND REEXPRESARVIDAUTIL.FECHACAMBIO= TO_DATE(:KEY_FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param name="VIDAUTIL" sqlType="STRING"/>
		<param name="DETERIORO" sqlType="STRING"/>
		<param name="HORA" sqlType="STRING"/>
		<param name="ORIGEN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>
		<param name="KEY_FECHACAMBIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="reexpresarvidautil/updateregistrodeterioro">
		<call-query href="updateReexpresarvidautilUpdateregistrodeterioro">
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="NIIF_VALOR_TOTAL" query-param="NIIF_VALOR_TOTAL"/>
			<with-param name="NIIF_VLRLIBROS" query-param="NIIF_VLRLIBROS"/>
			<with-param name="FECHACAMBIO" query-param="FECHACAMBIO"/>
			<with-param name="VIDAUTIL" query-param="VIDAUTIL"/>
			<with-param name="DETERIORO" query-param="DETERIORO"/>
			<with-param name="HORA" query-param="HORA"/>
			<with-param name="ORIGEN" query-param="ORIGEN"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>
			<with-param name="KEY_FECHACAMBIO" query-param="KEY_FECHACAMBIO"/>

		</call-query>
	</resource>
	<query id="getReexpresarvidautilSumaDeteriorosQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(DETERIORO),0) SUMA_DETERIORO FROM REEXPRESARVIDAUTIL WHERE COMPANIA =:COMPANIA AND ELEMENTO =:ELEMENTO AND SERIE =:SERIE AND FECHACAMBIO &lt;=:FECHA_CAMBIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMA_DETERIORO":"$SUMA_DETERIORO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHA_CAMBIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reexpresarvidautil/sumadeterioros">
		<call-query href="getReexpresarvidautilSumaDeteriorosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="FECHA_CAMBIO" query-param="FECHA_CAMBIO"/>

		</call-query>
	</resource>
	<query id="getReexpresarvidautilValanteriordetQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ELEMENTO, SERIE, TO_CHAR(FECHACAMBIO, 'DD/MM/YYYY') FECHACAMBIO, VIDAUTIL, DETERIORO, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(HORA, 'HH24:MI:SS')) HORA, NIIF_VLRLIBROS, NIIF_VALOR_TOTAL FROM REEXPRESARVIDAUTIL WHERE COMPANIA = :COMPANIA AND ELEMENTO = :ELEMENTO AND SERIE = :SERIE AND FECHACAMBIO = TO_DATE(:FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","FECHACAMBIO":"$FECHACAMBIO","VIDAUTIL":"$VIDAUTIL","DETERIORO":"$DETERIORO","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","HORA":"$HORA","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="reexpresarvidautil/valanteriordet">
		<call-query href="getReexpresarvidautilValanteriordetQuery">
