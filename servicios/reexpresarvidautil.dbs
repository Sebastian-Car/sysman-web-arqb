	<query id="insertReexpresarvidautil" keyColumns="COMPANIA,ELEMENTO,SERIE" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO REEXPRESARVIDAUTIL (COMPANIA, ELEMENTO, NOMBRELARGO, SERIE, NIIF_VALOR_TOTAL, NIIF_VLRLIBROS, FECHACAMBIO, VIDAUTIL, DETERIORO, HORA, ORIGEN, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ELEMENTO, :NOMBRELARGO, :SERIE, :NIIF_VALOR_TOTAL, :NIIF_VLRLIBROS, TO_DATE(:FECHACAMBIO,'DD/MM/YYYY HH24:MI:SS'), :VIDAUTIL, :DETERIORO, TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), :ORIGEN, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ELEMENTO":"$ELEMENTO","KEY_SERIE":"$SERIE","KEY_FECHACAMBIO":"$FECHACAMBIO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRELARGO" sqlType="STRING"/>
		<param defaultValue="0" name="SERIE" sqlType="STRING"/>
		<param defaultValue="" name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param defaultValue="" name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="FECHACAMBIO" sqlType="STRING"/>
		<param defaultValue="" name="VIDAUTIL" sqlType="STRING"/>
		<param defaultValue="0" name="DETERIORO" sqlType="STRING"/>
		<param defaultValue="" name="HORA" sqlType="STRING"/>
		<param defaultValue="" name="ORIGEN" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="reexpresarvidautil">
