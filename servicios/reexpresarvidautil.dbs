		</call-query>
	</resource>
	<query id="getReexpresarvidautilTipoelementodetQuery"  useConfig="sysmandsunist">
		<sql>SELECT TIPOELEMENTO FROM TIPOMOVIMIENTO WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOELEMENTO":"$TIPOELEMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
