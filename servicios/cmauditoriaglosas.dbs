	<query id="deleteCmauditoriaglosas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CM_AUDITORIA_GLOSAS WHERE CM_AUDITORIA_GLOSAS.COMPANIA= :KEY_COMPANIA AND CM_AUDITORIA_GLOSAS.CONSECUTIVO_ARCHIVO= :KEY_CONSECUTIVO_ARCHIVO AND CM_AUDITORIA_GLOSAS.CONSECUTIVO_FACTURA= :KEY_CONSECUTIVO_FACTURA AND CM_AUDITORIA_GLOSAS.NUM_FACTURA= :KEY_NUM_FACTURA AND CM_AUDITORIA_GLOSAS.COD_PREST_SERV_SALUD= :KEY_COD_PREST_SERV_SALUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_ARCHIVO" sqlType="INTEGER"/>
		<param name="KEY_CONSECUTIVO_FACTURA" sqlType="INTEGER"/>
		<param name="KEY_NUM_FACTURA" sqlType="STRING"/>
		<param name="KEY_COD_PREST_SERV_SALUD" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="cmauditoriaglosas">
		<call-query href="deleteCmauditoriaglosas">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CONSECUTIVO_ARCHIVO" query-param="KEY_CONSECUTIVO_ARCHIVO"/>
			<with-param name="KEY_CONSECUTIVO_FACTURA" query-param="KEY_CONSECUTIVO_FACTURA"/>
			<with-param name="KEY_NUM_FACTURA" query-param="KEY_NUM_FACTURA"/>
			<with-param name="KEY_COD_PREST_SERV_SALUD" query-param="KEY_COD_PREST_SERV_SALUD"/>

		</call-query>
	</resource>
	<query id="getCmauditoriaglosasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA,CONSECUTIVO_ARCHIVO, CONSECUTIVO_FACTURA, NUM_FACTURA, COD_PREST_SERV_SALUD, NUM_IDENTIF_PRESTADOR, VALOR_NETO_A_PAGAR_ENTI_CONTR FROM CM_AUDITORIA_GLOSAS WHERE COMPANIA =:COMPANIA AND CONSECUTIVO_ARCHIVO =:CONSECUTIVO) INI WHERE (CASE WHEN CONSECUTIVO_FACTURA IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_FACTURA) END) LIKE UPPER(CONCAT(:CONSECUTIVO_FACTURA, '%')) AND (CASE WHEN NUM_FACTURA IS NULL THEN ' ' ELSE UPPER(NUM_FACTURA) END) LIKE UPPER(CONCAT(:NUM_FACTURA, '%')) AND (CASE WHEN COD_PREST_SERV_SALUD IS NULL THEN ' ' ELSE UPPER(COD_PREST_SERV_SALUD) END) LIKE UPPER(CONCAT(:COD_PREST_SERV_SALUD, '%')) AND (CASE WHEN NUM_IDENTIF_PRESTADOR IS NULL THEN ' ' ELSE UPPER(NUM_IDENTIF_PRESTADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NUM_IDENTIF_PRESTADOR), '%')) AND (CASE WHEN VALOR_NETO_A_PAGAR_ENTI_CONTR IS NULL THEN ' ' ELSE UPPER(VALOR_NETO_A_PAGAR_ENTI_CONTR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_NETO_A_PAGAR_ENTI_CONTR), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO_ARCHIVO":"$CONSECUTIVO_ARCHIVO(type:integer)","CONSECUTIVO_FACTURA":"$CONSECUTIVO_FACTURA(type:integer)","NUM_FACTURA":"$NUM_FACTURA","COD_PREST_SERV_SALUD":"$COD_PREST_SERV_SALUD","NUM_IDENTIF_PRESTADOR":"$NUM_IDENTIF_PRESTADOR","VALOR_NETO_A_PAGAR_ENTI_CONTR":"$VALOR_NETO_A_PAGAR_ENTI_CONTR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="NUM_FACTURA" sqlType="STRING"/>
		<param name="COD_PREST_SERV_SALUD" sqlType="STRING"/>
		<param name="NUM_IDENTIF_PRESTADOR" sqlType="STRING"/>
		<param name="VALOR_NETO_A_PAGAR_ENTI_CONTR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cmauditoriaglosas">
		<call-query href="getCmauditoriaglosasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONSECUTIVO_FACTURA" query-param="CONSECUTIVO_FACTURA"/>
			<with-param name="NUM_FACTURA" query-param="NUM_FACTURA"/>
			<with-param name="COD_PREST_SERV_SALUD" query-param="COD_PREST_SERV_SALUD"/>
			<with-param name="NUM_IDENTIF_PRESTADOR" query-param="NUM_IDENTIF_PRESTADOR"/>
			<with-param name="VALOR_NETO_A_PAGAR_ENTI_CONTR" query-param="VALOR_NETO_A_PAGAR_ENTI_CONTR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCmauditoriaglosasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA,CONSECUTIVO_ARCHIVO, CONSECUTIVO_FACTURA, NUM_FACTURA, COD_PREST_SERV_SALUD, NUM_IDENTIF_PRESTADOR, VALOR_NETO_A_PAGAR_ENTI_CONTR FROM CM_AUDITORIA_GLOSAS WHERE COMPANIA =:COMPANIA AND CONSECUTIVO_ARCHIVO =:CONSECUTIVO) INI WHERE (CASE WHEN CONSECUTIVO_FACTURA IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO_FACTURA) END) LIKE UPPER(CONCAT(:CONSECUTIVO_FACTURA, '%')) AND (CASE WHEN NUM_FACTURA IS NULL THEN ' ' ELSE UPPER(NUM_FACTURA) END) LIKE UPPER(CONCAT(:NUM_FACTURA, '%')) AND (CASE WHEN COD_PREST_SERV_SALUD IS NULL THEN ' ' ELSE UPPER(COD_PREST_SERV_SALUD) END) LIKE UPPER(CONCAT(:COD_PREST_SERV_SALUD, '%')) AND (CASE WHEN NUM_IDENTIF_PRESTADOR IS NULL THEN ' ' ELSE UPPER(NUM_IDENTIF_PRESTADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NUM_IDENTIF_PRESTADOR), '%')) AND (CASE WHEN VALOR_NETO_A_PAGAR_ENTI_CONTR IS NULL THEN ' ' ELSE UPPER(VALOR_NETO_A_PAGAR_ENTI_CONTR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_NETO_A_PAGAR_ENTI_CONTR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="NUM_FACTURA" sqlType="STRING"/>
		<param name="COD_PREST_SERV_SALUD" sqlType="STRING"/>
		<param name="NUM_IDENTIF_PRESTADOR" sqlType="STRING"/>
		<param name="VALOR_NETO_A_PAGAR_ENTI_CONTR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmauditoriaglosas/numero">
		<call-query href="getCmauditoriaglosasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONSECUTIVO_FACTURA" query-param="CONSECUTIVO_FACTURA"/>
			<with-param name="NUM_FACTURA" query-param="NUM_FACTURA"/>
			<with-param name="COD_PREST_SERV_SALUD" query-param="COD_PREST_SERV_SALUD"/>
			<with-param name="NUM_IDENTIF_PRESTADOR" query-param="NUM_IDENTIF_PRESTADOR"/>
			<with-param name="VALOR_NETO_A_PAGAR_ENTI_CONTR" query-param="VALOR_NETO_A_PAGAR_ENTI_CONTR"/>

		</call-query>
	</resource>
    <query id="getCmauditoriaglosasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CONSECUTIVO_ARCHIVO, CONSECUTIVO_FACTURA, NUM_FACTURA, COD_PREST_SERV_SALUD, NUM_IDENTIF_PRESTADOR, VALOR_NETO_A_PAGAR_ENTI_CONTR, VALOR_OBJECION, CODIGO_GLOSA, GLOSA_ACEPTADA_IPS, OBSERVACION_CONCILIACION, VALOR_ACEPTADO_PAGADOR, TOTAL_APROBADO_PAGAR, VALOR_A_FAVOR_IPS,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(CASE DEVOLUCION_FACTURA WHEN 0 THEN 'false' ELSE 'true' END) DEVOLUCION_FACTURA FROM CM_AUDITORIA_GLOSAS WHERE CM_AUDITORIA_GLOSAS.COMPANIA= :KEY_COMPANIA AND CM_AUDITORIA_GLOSAS.CONSECUTIVO_ARCHIVO= :KEY_CONSECUTIVO_ARCHIVO AND CM_AUDITORIA_GLOSAS.CONSECUTIVO_FACTURA= :KEY_CONSECUTIVO_FACTURA AND CM_AUDITORIA_GLOSAS.NUM_FACTURA= :KEY_NUM_FACTURA AND CM_AUDITORIA_GLOSAS.COD_PREST_SERV_SALUD= :KEY_COD_PREST_SERV_SALUD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO_ARCHIVO":"$CONSECUTIVO_ARCHIVO(type:integer)","CONSECUTIVO_FACTURA":"$CONSECUTIVO_FACTURA(type:integer)","NUM_FACTURA":"$NUM_FACTURA","COD_PREST_SERV_SALUD":"$COD_PREST_SERV_SALUD","NUM_IDENTIF_PRESTADOR":"$NUM_IDENTIF_PRESTADOR","VALOR_NETO_A_PAGAR_ENTI_CONTR":"$VALOR_NETO_A_PAGAR_ENTI_CONTR","VALOR_OBJECION":"$VALOR_OBJECION","CODIGO_GLOSA":"$CODIGO_GLOSA","GLOSA_ACEPTADA_IPS":"$GLOSA_ACEPTADA_IPS","OBSERVACION_CONCILIACION":"$OBSERVACION_CONCILIACION","VALOR_ACEPTADO_PAGADOR":"$VALOR_ACEPTADO_PAGADOR","TOTAL_APROBADO_PAGAR":"$TOTAL_APROBADO_PAGAR","VALOR_A_FAVOR_IPS":"$VALOR_A_FAVOR_IPS","FECHA":"$FECHA","DEVOLUCION_FACTURA":"$DEVOLUCION_FACTURA(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="KEY_NUM_FACTURA" sqlType="STRING"/>
		<param name="KEY_COD_PREST_SERV_SALUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmauditoriaglosas/data">
