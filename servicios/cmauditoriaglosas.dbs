<data name="cmauditoriaglosas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="updateCmauditoriaglosasActvaloraceptadopagador" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_AUDITORIA_GLOSAS SET VALOR_ACEPTADO_PAGADOR = :VALOR WHERE COMPANIA = :COMPANIA AND CONSECUTIVO_ARCHIVO = :CONSECUTIVO AND CONSECUTIVO_FACTURA = :FACTURA AND NUM_FACTURA = :NUMERO AND COD_PREST_SERV_SALUD = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmauditoriaglosas/actvaloraceptadopagador">
		<call-query href="updateCmauditoriaglosasActvaloraceptadopagador">
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FACTURA" query-param="FACTURA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
<query id="insertCmauditoriaglosas" keyColumns="COMPANIA,CONSECUTIVO_ARCHIVO,CONSECUTIVO_FACTURA,NUM_FACTURA,COD_PREST_SERV_SALUD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CM_AUDITORIA_GLOSAS (COMPANIA, CONSECUTIVO_ARCHIVO, CONSECUTIVO_FACTURA, NUM_FACTURA, COD_PREST_SERV_SALUD, NUM_IDENTIF_PRESTADOR, VALOR_NETO_A_PAGAR_ENTI_CONTR, VALOR_OBJECION, CODIGO_GLOSA, GLOSA_ACEPTADA_IPS, OBSERVACION_CONCILIACION, VALOR_ACEPTADO_PAGADOR, TOTAL_APROBADO_PAGAR, VALOR_A_FAVOR_IPS, FECHA, DEVOLUCION_FACTURA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONSECUTIVO_ARCHIVO, :CONSECUTIVO_FACTURA, :NUM_FACTURA, :COD_PREST_SERV_SALUD, :NUM_IDENTIF_PRESTADOR, :VALOR_NETO_A_PAGAR_ENTI_CONTR, :VALOR_OBJECION, :CODIGO_GLOSA, :GLOSA_ACEPTADA_IPS, :OBSERVACION_CONCILIACION, :VALOR_ACEPTADO_PAGADOR, :TOTAL_APROBADO_PAGAR, :VALOR_A_FAVOR_IPS, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :DEVOLUCION_FACTURA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO_ARCHIVO":"$CONSECUTIVO_ARCHIVO(type:integer)","KEY_CONSECUTIVO_FACTURA":"$CONSECUTIVO_FACTURA(type:integer)","KEY_NUM_FACTURA":"$NUM_FACTURA","KEY_COD_PREST_SERV_SALUD":"$COD_PREST_SERV_SALUD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="NUM_FACTURA" sqlType="STRING"/>
		<param name="COD_PREST_SERV_SALUD" sqlType="STRING"/>
		<param name="NUM_IDENTIF_PRESTADOR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_NETO_A_PAGAR_ENTI_CONTR" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_OBJECION" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_GLOSA" sqlType="STRING"/>
		<param defaultValue="0" name="GLOSA_ACEPTADA_IPS" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION_CONCILIACION" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_ACEPTADO_PAGADOR" sqlType="STRING"/>
		<param defaultValue="0" name="TOTAL_APROBADO_PAGAR" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_A_FAVOR_IPS" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="0" name="DEVOLUCION_FACTURA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cmauditoriaglosas">
		<call-query href="insertCmauditoriaglosas">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO_ARCHIVO" query-param="CONSECUTIVO_ARCHIVO"/>
			<with-param name="CONSECUTIVO_FACTURA" query-param="CONSECUTIVO_FACTURA"/>
