	<query id="updateCmauditoriaglosas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_AUDITORIA_GLOSAS SET CONSECUTIVO_ARCHIVO=:CONSECUTIVO_ARCHIVO, CONSECUTIVO_FACTURA=:CONSECUTIVO_FACTURA, NUM_FACTURA=:NUM_FACTURA, COD_PREST_SERV_SALUD=:COD_PREST_SERV_SALUD, NUM_IDENTIF_PRESTADOR=:NUM_IDENTIF_PRESTADOR, VALOR_NETO_A_PAGAR_ENTI_CONTR=:VALOR_NETO_A_PAGAR_ENTI_CONTR, VALOR_OBJECION=:VALOR_OBJECION, CODIGO_GLOSA=:CODIGO_GLOSA, GLOSA_ACEPTADA_IPS=:GLOSA_ACEPTADA_IPS, OBSERVACION_CONCILIACION=:OBSERVACION_CONCILIACION, VALOR_ACEPTADO_PAGADOR=:VALOR_ACEPTADO_PAGADOR, TOTAL_APROBADO_PAGAR=:TOTAL_APROBADO_PAGAR, VALOR_A_FAVOR_IPS=:VALOR_A_FAVOR_IPS, FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), DEVOLUCION_FACTURA=:DEVOLUCION_FACTURA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CM_AUDITORIA_GLOSAS.COMPANIA= :KEY_COMPANIA AND CM_AUDITORIA_GLOSAS.CONSECUTIVO_ARCHIVO= :KEY_CONSECUTIVO_ARCHIVO AND CM_AUDITORIA_GLOSAS.CONSECUTIVO_FACTURA= :KEY_CONSECUTIVO_FACTURA AND CM_AUDITORIA_GLOSAS.NUM_FACTURA= :KEY_NUM_FACTURA AND CM_AUDITORIA_GLOSAS.COD_PREST_SERV_SALUD= :KEY_COD_PREST_SERV_SALUD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="NUM_FACTURA" sqlType="STRING"/>
