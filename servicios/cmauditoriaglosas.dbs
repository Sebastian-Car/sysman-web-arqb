			<with-param name="VALOR_ACEPTADO_PAGADOR" query-param="VALOR_ACEPTADO_PAGADOR"/>
			<with-param name="TOTAL_APROBADO_PAGAR" query-param="TOTAL_APROBADO_PAGAR"/>
			<with-param name="VALOR_A_FAVOR_IPS" query-param="VALOR_A_FAVOR_IPS"/>
			<with-param name="FECHA" query-param="FECHA"/>
