		<param name="KEY_CONSECUTIVO_ARCHIVO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO_FACTURA" sqlType="STRING"/>
		<param name="KEY_NUM_FACTURA" sqlType="STRING"/>
		<param name="KEY_COD_PREST_SERV_SALUD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmauditoriaglosas">
		<call-query href="updateCmauditoriaglosas">
			<with-param name="CONSECUTIVO_ARCHIVO" query-param="CONSECUTIVO_ARCHIVO"/>
			<with-param name="CONSECUTIVO_FACTURA" query-param="CONSECUTIVO_FACTURA"/>
			<with-param name="NUM_FACTURA" query-param="NUM_FACTURA"/>
			<with-param name="COD_PREST_SERV_SALUD" query-param="COD_PREST_SERV_SALUD"/>
			<with-param name="NUM_IDENTIF_PRESTADOR" query-param="NUM_IDENTIF_PRESTADOR"/>
			<with-param name="VALOR_NETO_A_PAGAR_ENTI_CONTR" query-param="VALOR_NETO_A_PAGAR_ENTI_CONTR"/>
			<with-param name="VALOR_OBJECION" query-param="VALOR_OBJECION"/>
			<with-param name="CODIGO_GLOSA" query-param="CODIGO_GLOSA"/>
			<with-param name="GLOSA_ACEPTADA_IPS" query-param="GLOSA_ACEPTADA_IPS"/>
			<with-param name="OBSERVACION_CONCILIACION" query-param="OBSERVACION_CONCILIACION"/>
			<with-param name="VALOR_ACEPTADO_PAGADOR" query-param="VALOR_ACEPTADO_PAGADOR"/>
			<with-param name="TOTAL_APROBADO_PAGAR" query-param="TOTAL_APROBADO_PAGAR"/>
			<with-param name="VALOR_A_FAVOR_IPS" query-param="VALOR_A_FAVOR_IPS"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DEVOLUCION_FACTURA" query-param="DEVOLUCION_FACTURA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
