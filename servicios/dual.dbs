	<query id="getDualOrdenesentidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DECODE(ROWNUM, 1, 'N' ,2 ,'D' ,3 ,'M') CODIGO, DECODE(ROWNUM, 1, 'Nacional', 2, 'Departamental', 3, 'Municipal') DESCRIPCION  FROM DUAL CONNECT BY ROWNUM &lt;=3</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
 
	</query>
