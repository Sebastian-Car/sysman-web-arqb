	<query id="getDualInformesDeCircularUnicaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ROWNUM CODIGO , DECODE(ROWNUM , 1 ,'1.INFORME ARCHIVO TIPO 029' , 2 ,'2. INFORME ARCHIVO TIPO 030' , 3 ,'3. INFORME ARCHIVO TIPO 045' , 4 ,'4. INFORME ARCHIVO TIPO 048', 5 , '5. INFORME ARCHIVO TIPO 049', 6 ,'6. INFORME ARCHIVO TIPO 050', 7 ,'7. INFORME ARCHIVO TIPO 051', 8,'8. INFORME ARCHIVO TIPO 052', 9,'9. INFORME ARCHIVO TIPO 053', 10,'10. INFORME ARCHIVO TIPO 313', 11,'11. INFORME ARCHIVO TIPO 314', 12,'12. INFORME ARCHIVO TIPO 343', 13,'13. CUENTAS POR PAGAR PRESTACION DE SERVICIOS') NOMBRE  FROM DUAL CONNECT BY ROWNUM &lt;= 13</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
 
