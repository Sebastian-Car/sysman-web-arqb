	<query id="getDualListadode0anQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CASE WHEN :INICIA_EN_CERO = -1 THEN (ROWNUM-1) ELSE CASE WHEN :INICIA_EN_DOS = -1 THEN ROWNUM +1 ELSE ROWNUM END END SERIE  FROM DUAL CONNECT BY ROWNUM &lt;= CASE WHEN :INICIA_EN_CERO = -1 THEN TO_NUMBER(:FINAL + 1) ELSE CASE WHEN :INICIA_EN_DOS = -1 THEN TO_NUMBER(:FINAL -1) ELSE TO_NUMBER(:FINAL) END END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE(type:integer)"}]}}		</result>
		<param name="INICIA_EN_CERO" sqlType="STRING"/>
		<param name="INICIA_EN_DOS" sqlType="STRING"/>
		<param name="FINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dual/listadode0an">
		<call-query href="getDualListadode0anQuery">
			<with-param name="INICIA_EN_CERO" query-param="INICIA_EN_CERO"/>
			<with-param name="INICIA_EN_DOS" query-param="INICIA_EN_DOS"/>
			<with-param name="FINAL" query-param="FINAL"/>

		</call-query>
	</resource>
	<query id="getDualRangoDeEdadQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(EDAD) EDAD FROM( SELECT LEVEL EDAD FROM DUAL CONNECT BY LEVEL &lt;=80) WHERE EDAD BETWEEN 18 AND 80</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EDAD":"$EDAD"}]}}		</result>
 
	</query>
	<resource method="GET" path="dual/rangodeedad">
		<call-query href="getDualRangoDeEdadQuery">
 
		</call-query>
	</resource>
	<query id="getDualRangoDeEdadFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT TO_CHAR(EDAD) EDAD FROM( SELECT LEVEL EDAD FROM DUAL CONNECT BY LEVEL &lt;=80) WHERE EDAD &gt;=:EDADINICIAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EDAD":"$EDAD"}]}}		</result>
		<param name="EDADINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dual/rangodeedadfinal">
		<call-query href="getDualRangoDeEdadFinalQuery">
			<with-param name="EDADINICIAL" query-param="EDADINICIAL"/>

		</call-query>
	</resource>
	<query id="getDualCabecerainformesiifQuery"  useConfig="sysmandsunist">
		<sql>SELECT :CONSECUTIVO CONSECUTIVO, :FECHA_CONTABLE FECHA_CONTABLE, :TIPO_DOCUMENTO TIPO_DOCUMENTO, :NUMERO_DOCUMENTO NUMERO_DOCUMENTO, :DESCRIPCION DESCRIPCION FROM DUAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","FECHA_CONTABLE":"$FECHA_CONTABLE","TIPO_DOCUMENTO":"$TIPO_DOCUMENTO","NUMERO_DOCUMENTO":"$NUMERO_DOCUMENTO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA_CONTABLE" sqlType="STRING"/>
		<param name="TIPO_DOCUMENTO" sqlType="STRING"/>
		<param name="NUMERO_DOCUMENTO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dual/cabecerainformesiif">
		<call-query href="getDualCabecerainformesiifQuery">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA_CONTABLE" query-param="FECHA_CONTABLE"/>
			<with-param name="TIPO_DOCUMENTO" query-param="TIPO_DOCUMENTO"/>
			<with-param name="NUMERO_DOCUMENTO" query-param="NUMERO_DOCUMENTO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getDualPagListaDeudaPrediosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT '' ANO, '' TOTAL FROM DUAL) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO","TOTAL":"$TOTAL"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dual/listadeudapredios/pag">
		<call-query href="getDualPagListaDeudaPrediosQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDualNumListaDeudaPrediosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT '' ANO, '' TOTAL FROM DUAL) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dual/listadeudapredios/num">
		<call-query href="getDualNumListaDeudaPrediosQuery">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>

		</call-query>
	</resource>

</data>