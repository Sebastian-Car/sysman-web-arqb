<data name="apiservicios" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getApiserviciosConsultaserviciosQuery"  useConfig="sysmanirisst">
		<sql>SELECT CONCAT(S.URL,U.URL) URL FROM API_SERVICIOS U INNER JOIN API_SERVIDORES S ON U.SERVIDOR = S.ID WHERE U.NOMBRE = :NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"URL":"$URL"}]}}		</result>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="apiservicios/consultaservicios">
		<call-query href="getApiserviciosConsultaserviciosQuery">
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>

</data>