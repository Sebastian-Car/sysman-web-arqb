	<query id="getInventariosDetallePlanPorMesDepAnoNumQuery"  useConfig="sysmandsunist">
		<sql>SELECT DETALLE_PLAN_COMPRAS.COMPANIA, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, DETALLE_PLAN_COMPRAS.CANTIDAD, DETALLE_PLAN_COMPRAS.CONSECUTIVO_PC,(CASE DETALLE_PLAN_COMPRAS.ENVIAR_CERT WHEN 0 THEN 'false' ELSE 'true' END) ENVIAR_CERT, DETALLE_PLAN_COMPRAS.MES,DETALLE_PLAN_COMPRAS.RUBRO FROM INVENTARIO INNER JOIN DETALLE_PLAN_COMPRAS ON INVENTARIO.COMPANIA = DETALLE_PLAN_COMPRAS.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DETALLE_PLAN_COMPRAS.CODIGO WHERE DETALLE_PLAN_COMPRAS.COMPANIA =:COMPANIA AND DETALLE_PLAN_COMPRAS.ANO =:ANO AND DETALLE_PLAN_COMPRAS.MES =:MES AND DETALLE_PLAN_COMPRAS.DEPENDENCIA =:DEPENDENCIA ORDER BY INVENTARIO.CODIGOELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","CANTIDAD":"$CANTIDAD","CONSECUTIVO_PC":"$CONSECUTIVO_PC(type:integer)","ENVIAR_CERT":"$ENVIAR_CERT(type:boolean)","MES":"$MES(type:integer)","RUBRO":"$RUBRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/detalleplanpormesdepanonum">
		<call-query href="getInventariosDetallePlanPorMesDepAnoNumQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>

		</call-query>
	</resource>
	<query id="getInventariosPagElemsConMovimMaxValorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGOELEMENTO, NOMBRELARGO, UNIDAD, (CASE WHEN VLRUNITARIOPROM &gt; (CASE WHEN PRECIOREPOSICION &gt; PRECIOULTCOMPRA THEN PRECIOREPOSICION ELSE PRECIOULTCOMPRA END) THEN VLRUNITARIOPROM ELSE (CASE WHEN PRECIOREPOSICION &gt; PRECIOULTCOMPRA THEN PRECIOREPOSICION ELSE PRECIOULTCOMPRA END) END) MAXVALOR  FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND TIENEMOVIMIENTO NOT IN 0 ORDER BY CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","UNIDAD":"$UNIDAD","MAXVALOR":"$MAXVALOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/elemsconmovimmaxvalor/pag">
		<call-query href="getInventariosPagElemsConMovimMaxValorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumElemsConMovimMaxValorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGOELEMENTO, NOMBRELARGO, UNIDAD, (CASE WHEN VLRUNITARIOPROM &gt; (CASE WHEN PRECIOREPOSICION &gt; PRECIOULTCOMPRA THEN PRECIOREPOSICION ELSE PRECIOULTCOMPRA END) THEN VLRUNITARIOPROM ELSE (CASE WHEN PRECIOREPOSICION &gt; PRECIOULTCOMPRA THEN PRECIOREPOSICION ELSE PRECIOULTCOMPRA END) END) MAXVALOR  FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND TIENEMOVIMIENTO NOT IN 0 ORDER BY CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/elemsconmovimmaxvalor/num">
		<call-query href="getInventariosNumElemsConMovimMaxValorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>

		</call-query>
	</resource>
	<query id="getInventariosVerificarConceptoEnInventarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VLRUNITARIOPROM, EXISTENCIA  FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND CODIGOELEMENTO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLRUNITARIOPROM":"$VLRUNITARIOPROM","EXISTENCIA":"$EXISTENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/verificarconceptoeninventario">
