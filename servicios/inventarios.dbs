		</call-query>
	</resource>
	<query id="getInventariosPagElementosPorTipoMovimientoYActivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO, EXISTENCIA, UNIDAD, TIPO, VLRUNITARIOPROM, PRECIOULTCOMPRA, IDENTIFICADOR, SERIE,REFERENCIA,(CASE PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO FROM INVENTARIO, (SELECT LISTAGG(TIPO,',') WITHIN GROUP(ORDER BY TIPO) TIPOS FROM (SELECT DISTINCT TIPO FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND TIPO NOT IN ('C'))) TIPOSINV WHERE COMPANIA = :COMPANIA AND INSTR( CASE WHEN :IND_TRASPASO IN(0) THEN :TIPO ELSE PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(TIPOSINV.TIPOS) END , TIPO , 1 ) &gt; 0 AND TIENEMOVIMIENTO NOT IN(0) AND INACTIVO IN (0) ORDER BY CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","EXISTENCIA":"$EXISTENCIA","UNIDAD":"$UNIDAD","TIPO":"$TIPO","VLRUNITARIOPROM":"$VLRUNITARIOPROM","PRECIOULTCOMPRA":"$PRECIOULTCOMPRA","IDENTIFICADOR":"$IDENTIFICADOR","SERIE":"$SERIE","REFERENCIA":"$REFERENCIA","PIDE_VENCIMIENTO":"$PIDE_VENCIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IND_TRASPASO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/elementosportipomovimientoyactivos/pag">
		<call-query href="getInventariosPagElementosPorTipoMovimientoYActivosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IND_TRASPASO" query-param="IND_TRASPASO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="EXISTENCIA" query-param="EXISTENCIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumElementosPorTipoMovimientoYActivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO, EXISTENCIA, UNIDAD, TIPO, VLRUNITARIOPROM, PRECIOULTCOMPRA, IDENTIFICADOR, SERIE,REFERENCIA,(CASE PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO FROM INVENTARIO, (SELECT LISTAGG(TIPO,',') WITHIN GROUP(ORDER BY TIPO) TIPOS FROM (SELECT DISTINCT TIPO FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND TIPO NOT IN ('C'))) TIPOSINV WHERE COMPANIA = :COMPANIA AND INSTR( CASE WHEN :IND_TRASPASO IN(0) THEN :TIPO ELSE PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(TIPOSINV.TIPOS) END , TIPO , 1 ) &gt; 0 AND TIENEMOVIMIENTO NOT IN(0) AND INACTIVO IN (0) ORDER BY CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IND_TRASPASO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/elementosportipomovimientoyactivos/num">
		<call-query href="getInventariosNumElementosPorTipoMovimientoYActivosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IND_TRASPASO" query-param="IND_TRASPASO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="EXISTENCIA" query-param="EXISTENCIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>

		</call-query>
	</resource>
	<query id="getInventariosPagTodosConMovimientoYTipoNotInQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO, UNIDAD, TIPO FROM INVENTARIO WHERE COMPANIA =:COMPANIA AND NOT INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:TIPO,' ','') ),CONCAT( '',CONCAT(TIPO, '')),1) &gt; 0 AND TIENEMOVIMIENTO NOT IN ( 0 ) ORDER BY CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","UNIDAD":"$UNIDAD","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
