	<query id="getInventariosPagPlacaNoAnuladaPorElementoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DEVOLUTIVO.SERIE, DEVOLUTIVO.DESCRIPCION  FROM INVENTARIO INNER JOIN DEVOLUTIVO ON INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO AND INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.CODIGOELEMENTO = :CODIGOELEMENTO AND DEVOLUTIVO.PLACAANULADA = 0 ORDER BY INVENTARIO.CODIGOELEMENTO) WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER(:SERIE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
