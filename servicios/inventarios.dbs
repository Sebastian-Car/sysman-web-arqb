	<query id="getInventariosPagNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGOELEMENTO CODIGOELEMENTOANT, NOMBRECORTO  FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND TIPO = 'C' ORDER BY NOMBRECORTO) WHERE (CASE WHEN CODIGOELEMENTOANT IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTOANT) END)  LIKE UPPER(:CODIGOELEMENTOANT || '%')  AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END)  LIKE UPPER( '%' || :NOMBRECORTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTOANT":"$CODIGOELEMENTOANT","NOMBRECORTO":"$NOMBRECORTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTOANT" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

