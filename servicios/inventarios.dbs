	<query id="getInventariosPagTodosUnidadPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO NOMBREINVENTARIO, INVENTARIO.UNIDAD  FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA ORDER BY INVENTARIO.COMPANIA, INVENTARIO.CODIGOELEMENTO) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBREINVENTARIO IS NULL THEN ' ' ELSE UPPER(NOMBREINVENTARIO) END)  LIKE UPPER( '%' || :NOMBREINVENTARIO || '%')  AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER( '%' || :UNIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBREINVENTARIO":"$NOMBREINVENTARIO","UNIDAD":"$UNIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBREINVENTARIO" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
