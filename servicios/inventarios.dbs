			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getInventariosCodigoMaximoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MAX(INVENTARIO.CODIGOELEMENTO) ULTIMO  FROM INVENTARIO GROUP BY LENGTH(CODIGOELEMENTO), INVENTARIO.COMPANIA, INVENTARIO.PREDECESOR HAVING LENGTH(CODIGOELEMENTO)= LENGTH(:CODIGO) AND INVENTARIO.COMPANIA= :COMPANIA AND INVENTARIO.PREDECESOR = :PREDECESOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ULTIMO":"$ULTIMO"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/codigomaximo">
		<call-query href="getInventariosCodigoMaximoQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>

		</call-query>
	</resource>
	<query id="getInventariosPredecesorQuery"  useConfig="sysmandsunist">
		<sql>SELECT INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, NVL(INVENTARIO.TIPO,'D') TIPO,(CASE INVENTARIO.TIENEMOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) TIENEMOVIMIENTO, INVENTARIO.IDENTIFICADOR FROM INVENTARIO WHERE CODIGOELEMENTO = :CODIGO AND COMPANIA = :COMPANIA ORDER BY COMPANIA, CODIGOELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","TIPO":"$TIPO","TIENEMOVIMIENTO":"$TIENEMOVIMIENTO(type:boolean)","IDENTIFICADOR":"$IDENTIFICADOR"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/predecesor">
		<call-query href="getInventariosPredecesorQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getInventariosTodosPorCompaniaCodinventarioTipoMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  INVENTARIO.NOMBRELARGO  FROM INVENTARIO WHERE INVENTARIO.CODIGOELEMENTO=:CODINVENTARIO AND INVENTARIO.COMPANIA =:COMPANIA AND INVENTARIO.TIPO ='N' AND INVENTARIO.TIENEMOVIMIENTO NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
