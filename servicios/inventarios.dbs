	<query id="getInventariosNumElementosvlracumceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT I.CODIGOELEMENTO, I.NOMBRELARGO FROM INVENTARIO I WHERE I.COMPANIA = :COMPANIA AND INSTR( PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS( REPLACE(:TIPOELEMENTO, ' ', '') ), I.TIPO, 1 ) &gt; 0 AND I.TIENEMOVIMIENTO &lt;&gt; 0 AND ( EXISTS ( SELECT 1 FROM DEPRECIAR DP WHERE DP.COMPANIA = I.COMPANIA AND DP.ELEMENTO = I.CODIGOELEMENTO AND DP.NIIF_VLRACUMULADO = 0 ) OR EXISTS ( SELECT 1 FROM DEVOLUTIVO D WHERE D.COMPANIA = I.COMPANIA AND D.ELEMENTO = I.CODIGOELEMENTO AND D.APLICA_NIIF = -1 AND D.NIIF_VIDA_UTIL &gt; 0 AND D.PLACAANULADA = 0 AND NOT EXISTS ( SELECT 1 FROM DEPRECIAR DP WHERE DP.COMPANIA = D.COMPANIA AND DP.ELEMENTO = D.ELEMENTO AND DP.SERIE = D.SERIE ) ) ) ORDER BY I.CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOELEMENTO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
