	<query id="deleteInventarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM INVENTARIO WHERE INVENTARIO.COMPANIA= :KEY_COMPANIA AND INVENTARIO.CODIGOELEMENTO= :KEY_CODIGOELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="inventarios">
		<call-query href="deleteInventarios">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>

		</call-query>
	</resource>
	<query id="getInventariosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA,CODIGOELEMENTO, CODIGOCUBS, NOMBRECORTO, CASE WHEN TIPO='D' THEN 'Devolutivo' WHEN TIPO='N' THEN 'Inmuebles' WHEN TIPO='C' THEN 'Consumo' WHEN TIPO='S' THEN 'Servicios' WHEN TIPO='M' THEN 'Consumo Controlado' WHEN TIPO='E' THEN 'Elementos Recibidos en Comodato' END TIPO, PREDECESOR,(CASE TIENEMOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) TIENEMOVIMIENTO FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA ORDER BY INVENTARIO.CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(:CODIGOCUBS, '%')) AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECORTO), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN PREDECESOR IS NULL THEN ' ' ELSE UPPER(PREDECESOR) END) LIKE UPPER(CONCAT(:PREDECESOR, '%')) AND (CASE WHEN TIENEMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIENEMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIENEMOVIMIENTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","CODIGOCUBS":"$CODIGOCUBS","NOMBRECORTO":"$NOMBRECORTO","TIPO":"$TIPO","PREDECESOR":"$PREDECESOR","TIENEMOVIMIENTO":"$TIENEMOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>
		<param name="TIENEMOVIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios">
		<call-query href="getInventariosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="NOMBRECORTO" query-param="NOMBRECORTO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>
			<with-param name="TIENEMOVIMIENTO" query-param="TIENEMOVIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA,CODIGOELEMENTO, CODIGOCUBS, NOMBRECORTO, CASE WHEN TIPO='D' THEN 'Devolutivo' WHEN TIPO='N' THEN 'Inmuebles' WHEN TIPO='C' THEN 'Consumo' WHEN TIPO='S' THEN 'Servicios' WHEN TIPO='M' THEN 'Consumo Controlado' WHEN TIPO='E' THEN 'Elementos Recibidos en Comodato' END TIPO, PREDECESOR,(CASE TIENEMOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) TIENEMOVIMIENTO FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA ORDER BY INVENTARIO.CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(:CODIGOCUBS, '%')) AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECORTO), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN PREDECESOR IS NULL THEN ' ' ELSE UPPER(PREDECESOR) END) LIKE UPPER(CONCAT(:PREDECESOR, '%')) AND (CASE WHEN TIENEMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIENEMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIENEMOVIMIENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>
		<param name="TIENEMOVIMIENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/numero">
		<call-query href="getInventariosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="NOMBRECORTO" query-param="NOMBRECORTO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="PREDECESOR" query-param="PREDECESOR"/>
			<with-param name="TIENEMOVIMIENTO" query-param="TIENEMOVIMIENTO"/>

		</call-query>
	</resource>
	<query id="getInventariosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT INVENTARIO.COMPANIA, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.NOMBRECORTO,(CASE INVENTARIO.TIENEMOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) TIENEMOVIMIENTO, INVENTARIO.TIPO, INVENTARIO.REFERENCIA, INVENTARIO.UNIDAD, INVENTARIO.MEDIDA, INVENTARIO.MARCA, INVENTARIO.LOCALIZACION, INVENTARIO.PORCIMPUESTO, INVENTARIO.PROVULTCOMPRA,(TO_CHAR(INVENTARIO.FECHAULTCOMPRA,'DD/MM/YYYY HH24:MI:SS')) FECHAULTCOMPRA, INVENTARIO.PRECIOULTCOMPRA, INVENTARIO.EXISTENCIA, INVENTARIO.VALORTOTAL, INVENTARIO.CANTRESERVADA, INVENTARIO.CANTCOMPORLLEGAR, INVENTARIO.CANTPEDENTREGA, INVENTARIO.CANTAPROXCOMPRA, INVENTARIO.VLRUNITARIOPROM,(TO_CHAR(INVENTARIO.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO, INVENTARIO.OPTIMOPEDIDO, INVENTARIO.CANTIDADMINIMA, INVENTARIO.CANTIDADMAXIMA, INVENTARIO.CANTCONTEO1, INVENTARIO.CANTCONTEO2, INVENTARIO.CANTCONTEO3,(TO_CHAR(INVENTARIO.FECHAULTMOV,'DD/MM/YYYY HH24:MI:SS')) FECHAULTMOV, INVENTARIO.CANTULTMOV, INVENTARIO.FACTOR, INVENTARIO.PROMEDIOVENTAS, INVENTARIO.DIASPROMEDIO, INVENTARIO.DIASHUBOCONSUMO, INVENTARIO.DIASDEMORAPEDIDO, INVENTARIO.DIASPARAPEDIR, INVENTARIO.PRECIOREPOSICION, INVENTARIO.CUENTAACTIVO, INVENTARIO.PREDECESOR, INVENTARIO.TIPOACTIVO, SERIE, INVENTARIO.CODIGOANTERIOR, INVENTARIO.DESCRIPCION, INVENTARIO.IDENTIFICADOR, INVENTARIO.CANTINSERVIBLE, INVENTARIO.CUENTAACTIVOI, INVENTARIO.CUENTAACTIVOS, INVENTARIO.DURACIONCAMBIOTM, INVENTARIO.DURACIONCAMBIOKM, INVENTARIO.UNIDAD_TIEMPO, INVENTARIO.CUENTAACTIVOR, ESTADOS, INVENTARIO.CUBS,(CASE INVENTARIO.INACTIVO WHEN 0 THEN 'false' ELSE 'true' END) INACTIVO, INVENTARIO.CODIGOCUBS,(CASE INVENTARIO.REQUIEREMANEJOAMBIENTAL WHEN 0 THEN 'false' ELSE 'true' END) REQUIEREMANEJOAMBIENTAL, INVENTARIO.CONSECUTIVO_PC, INVENTARIO.IMG_ELEMENTO, INVENTARIO.COMERCIALIZADO, INVENTARIO.CANAL_DISTRIBUCION, INVENTARIO.CODIGO_CUM, INVENTARIO.CREATED_BY,(TO_CHAR(INVENTARIO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, INVENTARIO.MODIFIED_BY,(TO_CHAR(INVENTARIO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(CASE INVENTARIO.IND_SST WHEN 0 THEN 'false' ELSE 'true' END) IND_SST, INVENTARIO.CODIGO_ALMACEN, ALMACEN.NOMBRE NOMBRE_ALMACEN,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO, INVENTARIO.PORC_VALOR_RESIDUAL,(CASE INVENTARIO.DIGITOS_AGRUPACION_INVENTARIO WHEN 0 THEN 'false' ELSE 'true' END) DIGITOS_AGRUPACION_INVENTARIO FROM INVENTARIO LEFT JOIN ALMACEN ON INVENTARIO.COMPANIA = ALMACEN.COMPANIA AND INVENTARIO.CODIGO_ALMACEN = ALMACEN.CODIGO WHERE INVENTARIO.COMPANIA= :KEY_COMPANIA AND INVENTARIO.CODIGOELEMENTO= :KEY_CODIGOELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","NOMBRECORTO":"$NOMBRECORTO","TIENEMOVIMIENTO":"$TIENEMOVIMIENTO(type:boolean)","TIPO":"$TIPO","REFERENCIA":"$REFERENCIA","UNIDAD":"$UNIDAD","MEDIDA":"$MEDIDA","MARCA":"$MARCA","LOCALIZACION":"$LOCALIZACION","PORCIMPUESTO":"$PORCIMPUESTO","PROVULTCOMPRA":"$PROVULTCOMPRA","FECHAULTCOMPRA":"$FECHAULTCOMPRA","PRECIOULTCOMPRA":"$PRECIOULTCOMPRA","EXISTENCIA":"$EXISTENCIA","VALORTOTAL":"$VALORTOTAL","CANTRESERVADA":"$CANTRESERVADA","CANTCOMPORLLEGAR":"$CANTCOMPORLLEGAR","CANTPEDENTREGA":"$CANTPEDENTREGA","CANTAPROXCOMPRA":"$CANTAPROXCOMPRA","VLRUNITARIOPROM":"$VLRUNITARIOPROM","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO","OPTIMOPEDIDO":"$OPTIMOPEDIDO","CANTIDADMINIMA":"$CANTIDADMINIMA","CANTIDADMAXIMA":"$CANTIDADMAXIMA","CANTCONTEO1":"$CANTCONTEO1","CANTCONTEO2":"$CANTCONTEO2","CANTCONTEO3":"$CANTCONTEO3","FECHAULTMOV":"$FECHAULTMOV","CANTULTMOV":"$CANTULTMOV","FACTOR":"$FACTOR","PROMEDIOVENTAS":"$PROMEDIOVENTAS","DIASPROMEDIO":"$DIASPROMEDIO","DIASHUBOCONSUMO":"$DIASHUBOCONSUMO","DIASDEMORAPEDIDO":"$DIASDEMORAPEDIDO","DIASPARAPEDIR":"$DIASPARAPEDIR","PRECIOREPOSICION":"$PRECIOREPOSICION","CUENTAACTIVO":"$CUENTAACTIVO","PREDECESOR":"$PREDECESOR","TIPOACTIVO":"$TIPOACTIVO","SERIE":"$SERIE","CODIGOANTERIOR":"$CODIGOANTERIOR","DESCRIPCION":"$DESCRIPCION","IDENTIFICADOR":"$IDENTIFICADOR","CANTINSERVIBLE":"$CANTINSERVIBLE","CUENTAACTIVOI":"$CUENTAACTIVOI","CUENTAACTIVOS":"$CUENTAACTIVOS","DURACIONCAMBIOTM":"$DURACIONCAMBIOTM","DURACIONCAMBIOKM":"$DURACIONCAMBIOKM","UNIDAD_TIEMPO":"$UNIDAD_TIEMPO","CUENTAACTIVOR":"$CUENTAACTIVOR","ESTADOS":"$ESTADOS","CUBS":"$CUBS","INACTIVO":"$INACTIVO(type:boolean)","CODIGOCUBS":"$CODIGOCUBS","REQUIEREMANEJOAMBIENTAL":"$REQUIEREMANEJOAMBIENTAL(type:boolean)","CONSECUTIVO_PC":"$CONSECUTIVO_PC","IMG_ELEMENTO":"$IMG_ELEMENTO","COMERCIALIZADO":"$COMERCIALIZADO","CANAL_DISTRIBUCION":"$CANAL_DISTRIBUCION","CODIGO_CUM":"$CODIGO_CUM","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","IND_SST":"$IND_SST(type:boolean)","CODIGO_ALMACEN":"$CODIGO_ALMACEN","NOMBRE_ALMACEN":"$NOMBRE_ALMACEN","PIDE_VENCIMIENTO":"$PIDE_VENCIMIENTO(type:boolean)","PORC_VALOR_RESIDUAL":"$PORC_VALOR_RESIDUAL(type:integer)","DIGITOS_AGRUPACION_INVENTARIO":"$DIGITOS_AGRUPACION_INVENTARIO(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/data">
		<call-query href="getInventariosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>

		</call-query>
	</resource>
<query id="updateInventarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVENTARIO SET COMPANIA=:COMPANIA, CODIGOELEMENTO=:CODIGOELEMENTO, NOMBRELARGO=:NOMBRELARGO, NOMBRECORTO=:NOMBRECORTO, TIENEMOVIMIENTO=:TIENEMOVIMIENTO, TIPO=:TIPO, REFERENCIA=:REFERENCIA, UNIDAD=:UNIDAD, MEDIDA=:MEDIDA, MARCA=:MARCA, LOCALIZACION=:LOCALIZACION, PORCIMPUESTO=:PORCIMPUESTO, PROVULTCOMPRA=:PROVULTCOMPRA, FECHAULTCOMPRA=TO_DATE(:FECHAULTCOMPRA,'DD/MM/YYYY HH24:MI:SS'), PRECIOULTCOMPRA=:PRECIOULTCOMPRA, EXISTENCIA=:EXISTENCIA, VALORTOTAL=:VALORTOTAL, CANTRESERVADA=:CANTRESERVADA, CANTCOMPORLLEGAR=:CANTCOMPORLLEGAR, CANTPEDENTREGA=:CANTPEDENTREGA, CANTAPROXCOMPRA=:CANTAPROXCOMPRA, VLRUNITARIOPROM=:VLRUNITARIOPROM, FECHAVENCIMIENTO=TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), OPTIMOPEDIDO=:OPTIMOPEDIDO, CANTIDADMINIMA=:CANTIDADMINIMA, CANTIDADMAXIMA=:CANTIDADMAXIMA, CANTCONTEO1=:CANTCONTEO1, CANTCONTEO2=:CANTCONTEO2, CANTCONTEO3=:CANTCONTEO3, FECHAULTMOV=TO_DATE(:FECHAULTMOV,'DD/MM/YYYY HH24:MI:SS'), CANTULTMOV=:CANTULTMOV, FACTOR=:FACTOR, PROMEDIOVENTAS=:PROMEDIOVENTAS, DIASPROMEDIO=:DIASPROMEDIO, DIASHUBOCONSUMO=:DIASHUBOCONSUMO, DIASDEMORAPEDIDO=:DIASDEMORAPEDIDO, DIASPARAPEDIR=:DIASPARAPEDIR, PRECIOREPOSICION=:PRECIOREPOSICION, CUENTAACTIVO=:CUENTAACTIVO, PREDECESOR=:PREDECESOR, TIPOACTIVO=:TIPOACTIVO, SERIE=:SERIE, CODIGOANTERIOR=:CODIGOANTERIOR, DESCRIPCION=:DESCRIPCION, IDENTIFICADOR=:IDENTIFICADOR, CANTINSERVIBLE=:CANTINSERVIBLE, CUENTAACTIVOI=:CUENTAACTIVOI, CUENTAACTIVOS=:CUENTAACTIVOS, DURACIONCAMBIOTM=:DURACIONCAMBIOTM, DURACIONCAMBIOKM=:DURACIONCAMBIOKM, UNIDAD_TIEMPO=:UNIDAD_TIEMPO, CUENTAACTIVOR=:CUENTAACTIVOR, ESTADOS=:ESTADOS, CUBS=:CUBS, INACTIVO=:INACTIVO, CODIGOCUBS=:CODIGOCUBS, REQUIEREMANEJOAMBIENTAL=:REQUIEREMANEJOAMBIENTAL, CONSECUTIVO_PC=:CONSECUTIVO_PC, IMG_ELEMENTO=:IMG_ELEMENTO, COMERCIALIZADO=:COMERCIALIZADO, CANAL_DISTRIBUCION=:CANAL_DISTRIBUCION, CODIGO_CUM=:CODIGO_CUM, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), IND_SST=:IND_SST, CODIGO_ALMACEN=:CODIGO_ALMACEN, PIDE_VENCIMIENTO=:PIDE_VENCIMIENTO, PORC_VALOR_RESIDUAL=:PORC_VALOR_RESIDUAL, DIGITOS_AGRUPACION_INVENTARIO=:DIGITOS_AGRUPACION_INVENTARIO WHERE INVENTARIO.COMPANIA= :KEY_COMPANIA AND INVENTARIO.CODIGOELEMENTO= :KEY_CODIGOELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

