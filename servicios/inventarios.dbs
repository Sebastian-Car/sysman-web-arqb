	<query id="getInventariosExisteElementoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM INVENTARIO LEFT JOIN D_MOVIMIENTO ON INVENTARIO.CODIGOELEMENTO = D_MOVIMIENTO.ELEMENTO AND INVENTARIO.COMPANIA = D_MOVIMIENTO.COMPANIA WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.CODIGOELEMENTO= :CODIGO AND D_MOVIMIENTO.ELEMENTO IS NOT NULL AND TIPOMOVIMIENTO NOT IN ('EDI','SII')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
