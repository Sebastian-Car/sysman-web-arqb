	<query id="getInventariosElementosCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) CUENTA  FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND SUBSTR(INVENTARIO.CODIGOELEMENTO,0,LENGTH(:CODIGO)) =:CODIGO AND INVENTARIO.CODIGOELEMENTO &lt;&gt; :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
