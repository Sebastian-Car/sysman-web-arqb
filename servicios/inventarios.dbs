	<query id="getInventariosNumElementopepsidiQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ROW_NUMBER() OVER(ORDER BY INVENTARIO.CODIGOELEMENTO,MOVIMIENTO.NUMERO) RN, MOVIMIENTO.CODIGOPROYECTO PROYECTO, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, D_MOVIMIENTO.SALDO_PEPS EXISTENCIA, MOVIMIENTO.TIPOMOVIMIENTO, MOVIMIENTO.NUMERO, CONCAT(CONCAT(MOVIMIENTO.TIPOMOVASOCIADO,' '),MOVIMIENTO.MOVASOCIADO) CONTRATO, INVENTARIO.IDENTIFICADOR, INVENTARIO.SERIE, D_MOVIMIENTO.VALORUNITARIO,MOVIMIENTO.TIPOMOVASOCIADO,MOVIMIENTO.MOVASOCIADO,MOVIMIENTO.OPERACION,MOVIMIENTO.AUX_ALMACEN,MOVIMIENTO.RUEDA FROM D_MOVIMIENTO LEFT JOIN INVENTARIO ON D_MOVIMIENTO.COMPANIA = INVENTARIO.COMPANIA AND D_MOVIMIENTO.ELEMENTO = INVENTARIO.CODIGOELEMENTO LEFT JOIN MOVIMIENTO ON D_MOVIMIENTO.COMPANIA = MOVIMIENTO.COMPANIA AND D_MOVIMIENTO.TIPOMOVIMIENTO = MOVIMIENTO.TIPOMOVIMIENTO AND D_MOVIMIENTO.MOVIMIENTO = MOVIMIENTO.NUMERO LEFT JOIN TIPOMOVIMIENTO ON MOVIMIENTO.COMPANIA = TIPOMOVIMIENTO.COMPANIA AND MOVIMIENTO.TIPOMOVIMIENTO = TIPOMOVIMIENTO.CODIGO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO NOT IN(0) AND INVENTARIO.INACTIVO IN(0) AND TIPOMOVIMIENTO.CLASE IN('E') AND TIPOMOVIMIENTO.TIPOELEMENTO IN('C') AND D_MOVIMIENTO.SALDO_PEPS &gt; 0 AND MOVIMIENTO.CODIGOPROYECTO = :PROYECTO ORDER BY INVENTARIO.CODIGOELEMENTO,MOVIMIENTO.NUMERO) INI WHERE (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(:PROYECTO, '%')) AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) AND (CASE WHEN TIPOMOVIMIENTO IS NULL THEN ' ' ELSE UPPER(TIPOMOVIMIENTO) END) LIKE UPPER(CONCAT(:TIPOMOVIMIENTO, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CONTRATO IS NULL THEN ' ' ELSE UPPER(CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO), '%')) AND (CASE WHEN TIPOMOVASOCIADO IS NULL THEN ' ' ELSE UPPER(TIPOMOVASOCIADO) END) LIKE UPPER(CONCAT(:TIPOMOVASOCIADO, '%')) AND (CASE WHEN MOVASOCIADO IS NULL THEN ' ' ELSE UPPER(MOVASOCIADO) END) LIKE UPPER(CONCAT(CONCAT('%',:MOVASOCIADO), '%')) AND (CASE WHEN OPERACION IS NULL THEN ' ' ELSE UPPER(OPERACION) END) LIKE UPPER(CONCAT(:OPERACION, '%')) AND (CASE WHEN AUX_ALMACEN IS NULL THEN ' ' ELSE UPPER(AUX_ALMACEN) END) LIKE UPPER(CONCAT(:AUX_ALMACEN, '%')) AND (CASE WHEN RUEDA IS NULL THEN ' ' ELSE UPPER(RUEDA) END) LIKE UPPER(CONCAT(:RUEDA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
		<param name="TIPOMOVIMIENTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONTRATO" sqlType="STRING"/>
		<param name="TIPOMOVASOCIADO" sqlType="STRING"/>
		<param name="MOVASOCIADO" sqlType="STRING"/>
		<param name="OPERACION" sqlType="STRING"/>
		<param name="AUX_ALMACEN" sqlType="STRING"/>
		<param name="RUEDA" sqlType="STRING"/>							

	</query>
