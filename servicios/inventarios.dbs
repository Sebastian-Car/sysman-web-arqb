	<query id="getInventariosPagInventarioDeterioroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.EXISTENCIA, INVENTARIO.TIPO, INVENTARIO.VLRUNITARIOPROM, INVENTARIO.PRECIOULTCOMPRA, INVENTARIO.IDENTIFICADOR, INVENTARIO.UNIDAD FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIPO IN ('D', 'M','N') AND INVENTARIO.TIENEMOVIMIENTO NOT IN(0) AND INVENTARIO.INACTIVO IN (0)) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN VLRUNITARIOPROM IS NULL THEN ' ' ELSE UPPER(VLRUNITARIOPROM) END) LIKE UPPER(CONCAT(:VLRUNITARIOPROM, '%')) AND (CASE WHEN PRECIOULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PRECIOULTCOMPRA) END) LIKE UPPER(CONCAT(CONCAT('%',:PRECIOULTCOMPRA), '%')) AND (CASE WHEN IDENTIFICADOR IS NULL THEN ' ' ELSE UPPER(IDENTIFICADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:IDENTIFICADOR), '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:UNIDAD), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","EXISTENCIA":"$EXISTENCIA","TIPO":"$TIPO","VLRUNITARIOPROM":"$VLRUNITARIOPROM","PRECIOULTCOMPRA":"$PRECIOULTCOMPRA","IDENTIFICADOR":"$IDENTIFICADOR","UNIDAD":"$UNIDAD"}]}}		</result>
