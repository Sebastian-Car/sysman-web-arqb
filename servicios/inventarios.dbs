			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getInventariosListadoInterfazAlmacenQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGOELEMENTO, NOMBRECORTO, NOMBRELARGO, DESCRIPCION,(CASE TIENEMOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) TIENEMOVIMIENTO, PREDECESOR, REFERENCIA, UNIDAD, MEDIDA, MARCA, CUENTAACTIVO, CUENTAACTIVOI, CUENTAACTIVOS, CUENTAACTIVOR, CUENTAACTIVOC, NIIF_CUENTAACTIVO, NIIF_CUENTAACTIVOI, NIIF_CUENTAACTIVOS, NIIF_CUENTAACTIVOR,TIPO, CUENTAACTIVONEXP,CUENTAACTIVOMAN,NIIF_CUENTAACTIVONEXP,NIIF_CUENTAACTIVOMAN FROM INVENTARIO WHERE COMPANIA = :KEY_COMPANIA AND CODIGOELEMENTO = :KEY_CODIGOELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRECORTO":"$NOMBRECORTO","NOMBRELARGO":"$NOMBRELARGO","DESCRIPCION":"$DESCRIPCION","TIENEMOVIMIENTO":"$TIENEMOVIMIENTO(type:boolean)","PREDECESOR":"$PREDECESOR","REFERENCIA":"$REFERENCIA","UNIDAD":"$UNIDAD","MEDIDA":"$MEDIDA","MARCA":"$MARCA","CUENTAACTIVO":"$CUENTAACTIVO","CUENTAACTIVOI":"$CUENTAACTIVOI","CUENTAACTIVOS":"$CUENTAACTIVOS","CUENTAACTIVOR":"$CUENTAACTIVOR","CUENTAACTIVOC":"$CUENTAACTIVOC","NIIF_CUENTAACTIVO":"$NIIF_CUENTAACTIVO","NIIF_CUENTAACTIVOI":"$NIIF_CUENTAACTIVOI","NIIF_CUENTAACTIVOS":"$NIIF_CUENTAACTIVOS","NIIF_CUENTAACTIVOR":"$NIIF_CUENTAACTIVOR","TIPO":"$TIPO","CUENTAACTIVONEXP":"$CUENTAACTIVONEXP","CUENTAACTIVOMAN":"$CUENTAACTIVOMAN","NIIF_CUENTAACTIVONEXP":"$NIIF_CUENTAACTIVONEXP","NIIF_CUENTAACTIVOMAN":"$NIIF_CUENTAACTIVOMAN"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/listadointerfazalmacen">
		<call-query href="getInventariosListadoInterfazAlmacenQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGOELEMENTO" query-param="KEY_CODIGOELEMENTO"/>

		</call-query>
	</resource>
	<query id="updateInventariosInterfazAlmacen" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVENTARIO SET CODIGOELEMENTO=:CODIGOELEMENTO, NOMBRECORTO=:NOMBRECORTO, NOMBRELARGO=:NOMBRELARGO, DESCRIPCION=:DESCRIPCION, TIENEMOVIMIENTO=:TIENEMOVIMIENTO, PREDECESOR=:PREDECESOR, REFERENCIA=:REFERENCIA, UNIDAD=:UNIDAD, MEDIDA=:MEDIDA, MARCA=:MARCA, CUENTAACTIVO=:CUENTAACTIVO, CUENTAACTIVOI=:CUENTAACTIVOI, CUENTAACTIVOS=:CUENTAACTIVOS, CUENTAACTIVOR=:CUENTAACTIVOR, CUENTAACTIVOC=:CUENTAACTIVOC, CUENTAACTIVONEXP=:CUENTAACTIVONEXP, CUENTAACTIVOMAN=:CUENTAACTIVOMAN, NIIF_CUENTAACTIVO=:NIIF_CUENTAACTIVO, NIIF_CUENTAACTIVOI=:NIIF_CUENTAACTIVOI, NIIF_CUENTAACTIVOS=:NIIF_CUENTAACTIVOS, NIIF_CUENTAACTIVOR=:NIIF_CUENTAACTIVOR, NIIF_CUENTAACTIVONEXP=:NIIF_CUENTAACTIVONEXP, NIIF_CUENTAACTIVOMAN=:NIIF_CUENTAACTIVOMAN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE INVENTARIO.COMPANIA= :KEY_COMPANIA AND INVENTARIO.CODIGOELEMENTO= :KEY_CODIGOELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="TIENEMOVIMIENTO" sqlType="STRING"/>
		<param name="PREDECESOR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="MEDIDA" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="CUENTAACTIVO" sqlType="STRING"/>
		<param name="CUENTAACTIVOI" sqlType="STRING"/>
		<param name="CUENTAACTIVOS" sqlType="STRING"/>
		<param name="CUENTAACTIVOR" sqlType="STRING"/>
		<param name="CUENTAACTIVOC" sqlType="STRING"/>
		<param name="CUENTAACTIVONEXP" sqlType="STRING"/>
		<param name="CUENTAACTIVOMAN" sqlType="STRING"/>
		<param name="NIIF_CUENTAACTIVO" sqlType="STRING"/>
		<param name="NIIF_CUENTAACTIVOI" sqlType="STRING"/>
		<param name="NIIF_CUENTAACTIVOS" sqlType="STRING"/>
		<param name="NIIF_CUENTAACTIVOR" sqlType="STRING"/>
		<param name="NIIF_CUENTAACTIVONEXP" sqlType="STRING"/>
		<param name="NIIF_CUENTAACTIVOMAN" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGOELEMENTO" sqlType="STRING"/>

	</query>
