	<query id="getInventariosValorUnitarioPromedioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT I.VLRUNITARIOPROM  FROM INVENTARIO I INNER JOIN D_MOVIMIENTO D ON I.COMPANIA = D.COMPANIA AND I.CODIGOELEMENTO = D.ELEMENTO INNER JOIN TIPOMOVIMIENTO T ON D.COMPANIA = T.COMPANIA AND D.TIPOMOVIMIENTO = T.CODIGO WHERE I.COMPANIA = :COMPANIA AND I.CODIGOELEMENTO = :CODIGOELEMENTO AND I.TIPO = :TIPO AND I.TIENEMOVIMIENTO NOT IN (0) AND I.INACTIVO IN (0) AND T.CLASE IN ('E') AND T.TIPOELEMENTO IN ('C')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLRUNITARIOPROM":"$VLRUNITARIOPROM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/valorunitariopromedio">
