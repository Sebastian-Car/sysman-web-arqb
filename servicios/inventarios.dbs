<data name="inventarios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getInventariosValorPorElementoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CASE WHEN PRECIOREPOSICION &gt; VLRUNITARIOPROM THEN PRECIOREPOSICION ELSE VLRUNITARIOPROM END AS VALOR  FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND CODIGOELEMENTO = :ELEMENTO ORDER BY COMPANIA, CODIGOELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/valorporelemento">
		<call-query href="getInventariosValorPorElementoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>

		</call-query>
	</resource>
	<query id="getInventariosPagTodosPorNombreCodigoEnDneQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO FROM INVENTARIO WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','') ),CONCAT('',CONCAT(TIPO,'') ),1) &gt; 0 ORDER BY COMPANIA, CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/todospornombrecodigoendne/pag">
		<call-query href="getInventariosPagTodosPorNombreCodigoEnDneQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumTodosPorNombreCodigoEnDneQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO FROM INVENTARIO WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','') ),CONCAT('',CONCAT(TIPO,'') ),1) &gt; 0 ORDER BY COMPANIA, CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/todospornombrecodigoendne/num">
		<call-query href="getInventariosNumTodosPorNombreCodigoEnDneQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>

		</call-query>
	</resource>
	<query id="getInventariosPagTodosPorNombreCodigoEnDneMayorIgualCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO FROM INVENTARIO WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','') ),CONCAT( '',CONCAT( TIPO, '')),1) &gt; 0 AND CODIGOELEMENTO &gt;=:ELEMENTOINICIAL ORDER BY COMPANIA, CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ELEMENTOINICIAL" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/todospornombrecodigoendnemayorigualcodigo/pag">
		<call-query href="getInventariosPagTodosPorNombreCodigoEnDneMayorIgualCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ELEMENTOINICIAL" query-param="ELEMENTOINICIAL"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumTodosPorNombreCodigoEnDneMayorIgualCodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO FROM INVENTARIO WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CLASE,' ','') ),CONCAT( '',CONCAT( TIPO, '')),1) &gt; 0 AND CODIGOELEMENTO &gt;=:ELEMENTOINICIAL ORDER BY COMPANIA, CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ELEMENTOINICIAL" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/todospornombrecodigoendnemayorigualcodigo/num">
		<call-query href="getInventariosNumTodosPorNombreCodigoEnDneMayorIgualCodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ELEMENTOINICIAL" query-param="ELEMENTOINICIAL"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>

		</call-query>
	</resource>
	<query id="getInventariosPagNombreLargoMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.VLRUNITARIOPROM  FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO NOT IN(0) AND INVENTARIO.INACTIVO = 0 ORDER BY INVENTARIO.CODIGOELEMENTO, INVENTARIO.UNIDAD) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN VLRUNITARIOPROM IS NULL THEN ' ' ELSE UPPER(VLRUNITARIOPROM) END)  LIKE UPPER(:VLRUNITARIOPROM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","VLRUNITARIOPROM":"$VLRUNITARIOPROM(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="VLRUNITARIOPROM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/nombrelargomovimiento/pag">
		<call-query href="getInventariosPagNombreLargoMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="VLRUNITARIOPROM" query-param="VLRUNITARIOPROM"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumNombreLargoMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.VLRUNITARIOPROM  FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO NOT IN(0) AND INVENTARIO.INACTIVO = 0 ORDER BY INVENTARIO.CODIGOELEMENTO, INVENTARIO.UNIDAD) WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END)  LIKE UPPER(:CODIGOELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%')  AND (CASE WHEN VLRUNITARIOPROM IS NULL THEN ' ' ELSE UPPER(VLRUNITARIOPROM) END)  LIKE UPPER( '%' || :VLRUNITARIOPROM || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="VLRUNITARIOPROM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/nombrelargomovimiento/num">
		<call-query href="getInventariosNumNombreLargoMovimientoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="VLRUNITARIOPROM" query-param="VLRUNITARIOPROM"/>

		</call-query>
	</resource>
	<query id="getInventariosPagTodosConPrecioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT INVENTARIO.NOMBRELARGO, TO_CHAR(INVENTARIO.CODIGOELEMENTO) CODIGOELEMENTO, INVENTARIO.UNIDAD, TO_NUMBER(CASE WHEN INVENTARIO.PRECIOREPOSICION&lt;INVENTARIO.VLRUNITARIOPROM THEN INVENTARIO.VLRUNITARIOPROM ELSE INVENTARIO.PRECIOREPOSICION END) PRECIO, INVENTARIO.CODIGOCUBS,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO, INVENTARIO.REFERENCIA FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO &lt;&gt; 0 AND INVENTARIO.TIPO &lt;&gt; ' ' AND INVENTARIO.INACTIVO = 0 ORDER BY INVENTARIO.NOMBRELARGO) INI WHERE (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) AND (CASE WHEN PRECIO IS NULL THEN ' ' ELSE UPPER(PRECIO) END) LIKE UPPER(CONCAT(:PRECIO, '%')) AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(:CODIGOCUBS, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRELARGO":"$NOMBRELARGO","CODIGOELEMENTO":"$CODIGOELEMENTO","UNIDAD":"$UNIDAD","PRECIO":"$PRECIO","CODIGOCUBS":"$CODIGOCUBS","PIDE_VENCIMIENTO":"$PIDE_VENCIMIENTO(type:boolean)","REFERENCIA":"$REFERENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PRECIO" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/todosconprecio/pag">
		<call-query href="getInventariosPagTodosConPrecioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PRECIO" query-param="PRECIO"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumTodosConPrecioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT INVENTARIO.NOMBRELARGO, TO_CHAR(INVENTARIO.CODIGOELEMENTO) CODIGOELEMENTO, INVENTARIO.UNIDAD, TO_NUMBER(CASE WHEN INVENTARIO.PRECIOREPOSICION&lt;INVENTARIO.VLRUNITARIOPROM THEN INVENTARIO.VLRUNITARIOPROM ELSE INVENTARIO.PRECIOREPOSICION END) PRECIO, INVENTARIO.CODIGOCUBS,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO, INVENTARIO.REFERENCIA FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO &lt;&gt; 0 AND INVENTARIO.TIPO &lt;&gt; ' ' AND INVENTARIO.INACTIVO = 0 ORDER BY INVENTARIO.NOMBRELARGO) INI WHERE (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) AND (CASE WHEN PRECIO IS NULL THEN ' ' ELSE UPPER(PRECIO) END) LIKE UPPER(CONCAT(:PRECIO, '%')) AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(:CODIGOCUBS, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PRECIO" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/todosconprecio/num">
		<call-query href="getInventariosNumTodosConPrecioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="PRECIO" query-param="PRECIO"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>

		</call-query>
	</resource>
<query id="insertInventarios" keyColumns="COMPANIA,CODIGOELEMENTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
	   <sql>INSERT INTO INVENTARIO (COMPANIA, CODIGOELEMENTO, NOMBRELARGO, NOMBRECORTO, TIENEMOVIMIENTO, TIPO, REFERENCIA, UNIDAD, MEDIDA, MARCA, LOCALIZACION, PORCIMPUESTO, PROVULTCOMPRA, FECHAULTCOMPRA, PRECIOULTCOMPRA, EXISTENCIA, VALORTOTAL, CANTRESERVADA, CANTCOMPORLLEGAR, CANTPEDENTREGA, CANTAPROXCOMPRA, VLRUNITARIOPROM, FECHAVENCIMIENTO, OPTIMOPEDIDO, CANTIDADMINIMA, CANTIDADMAXIMA, CANTCONTEO1, CANTCONTEO2, CANTCONTEO3, FECHAULTMOV, CANTULTMOV, FACTOR, PROMEDIOVENTAS, DIASPROMEDIO, DIASHUBOCONSUMO, DIASDEMORAPEDIDO, DIASPARAPEDIR, PRECIOREPOSICION, CUENTAACTIVO, PREDECESOR, TIPOACTIVO, SERIE, CODIGOANTERIOR, DESCRIPCION, IDENTIFICADOR, CANTINSERVIBLE, CUENTAACTIVOI, CUENTAACTIVOS, DURACIONCAMBIOTM, DURACIONCAMBIOKM, UNIDAD_TIEMPO, CUENTAACTIVOR, ESTADOS, CUBS, INACTIVO, CODIGOCUBS, REQUIEREMANEJOAMBIENTAL, CONSECUTIVO_PC, IMG_ELEMENTO, COMERCIALIZADO, CANAL_DISTRIBUCION, CODIGO_CUM, CREATED_BY, DATE_CREATED, IND_SST, CODIGO_ALMACEN, PIDE_VENCIMIENTO, PORC_VALOR_RESIDUAL, DIGITOS_AGRUPACION_INVENTARIO) VALUES (:COMPANIA, :CODIGOELEMENTO, :NOMBRELARGO, :NOMBRECORTO, :TIENEMOVIMIENTO, :TIPO, :REFERENCIA, :UNIDAD, :MEDIDA, :MARCA, :LOCALIZACION, :PORCIMPUESTO, :PROVULTCOMPRA, TO_DATE(:FECHAULTCOMPRA,'DD/MM/YYYY HH24:MI:SS'), :PRECIOULTCOMPRA, :EXISTENCIA, :VALORTOTAL, :CANTRESERVADA, :CANTCOMPORLLEGAR, :CANTPEDENTREGA, :CANTAPROXCOMPRA, :VLRUNITARIOPROM, TO_DATE(:FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :OPTIMOPEDIDO, :CANTIDADMINIMA, :CANTIDADMAXIMA, :CANTCONTEO1, :CANTCONTEO2, :CANTCONTEO3, TO_DATE(:FECHAULTMOV,'DD/MM/YYYY HH24:MI:SS'), :CANTULTMOV, :FACTOR, :PROMEDIOVENTAS, :DIASPROMEDIO, :DIASHUBOCONSUMO, :DIASDEMORAPEDIDO, :DIASPARAPEDIR, :PRECIOREPOSICION, :CUENTAACTIVO, :PREDECESOR, :TIPOACTIVO, :SERIE, :CODIGOANTERIOR, :DESCRIPCION, :IDENTIFICADOR, :CANTINSERVIBLE, :CUENTAACTIVOI, :CUENTAACTIVOS, :DURACIONCAMBIOTM, :DURACIONCAMBIOKM, :UNIDAD_TIEMPO, :CUENTAACTIVOR, :ESTADOS, :CUBS, :INACTIVO, :CODIGOCUBS, :REQUIEREMANEJOAMBIENTAL, :CONSECUTIVO_PC, :IMG_ELEMENTO, :COMERCIALIZADO, :CANAL_DISTRIBUCION, :CODIGO_CUM, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :IND_SST, :CODIGO_ALMACEN, :PIDE_VENCIMIENTO, :PORC_VALOR_RESIDUAL, :DIGITOS_AGRUPACION_INVENTARIO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGOELEMENTO":"$CODIGOELEMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param defaultValue="0" name="TIENEMOVIMIENTO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param defaultValue="" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD" sqlType="STRING"/>
		<param defaultValue="" name="MEDIDA" sqlType="STRING"/>
		<param defaultValue="" name="MARCA" sqlType="STRING"/>
		<param defaultValue="" name="LOCALIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIMPUESTO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="PROVULTCOMPRA" sqlType="STRING"/>
		<param defaultValue="" name="FECHAULTCOMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="PRECIOULTCOMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="EXISTENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="CANTRESERVADA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTCOMPORLLEGAR" sqlType="STRING"/>
		<param defaultValue="0" name="CANTPEDENTREGA" sqlType="STRING"/>
		<param defaultValue="0" name="CANTAPROXCOMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="VLRUNITARIOPROM" sqlType="STRING"/>
