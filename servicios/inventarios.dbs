	<query id="getInventariosNumGetelementolotefuenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ROW_NUMBER() OVER(ORDER BY INVENTARIO.CODIGOELEMENTO ) ROWIDCON, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, V_MOVIMIENTO_VENCIMIENTO.FUENTEDERECURSO, CASE WHEN (V_MOVIMIENTO_VENCIMIENTO.LOTE) = '-1.-' THEN '' ELSE V_MOVIMIENTO_VENCIMIENTO.LOTE END AS LOTE, NVL(V_MOVIMIENTO_VENCIMIENTO.SALDO, 0) EXISTENCIA, INVENTARIO.UNIDAD, INVENTARIO.TIPO, INVENTARIO.VLRUNITARIOPROM, INVENTARIO.PRECIOULTCOMPRA, INVENTARIO.IDENTIFICADOR, INVENTARIO.SERIE, INVENTARIO.REFERENCIA,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO,(TO_CHAR(V_MOVIMIENTO_VENCIMIENTO.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO FROM INVENTARIO LEFT JOIN (SELECT EXISTENCIAS.COMPANIA, EXISTENCIAS.ELEMENTO, EXISTENCIAS.LOTE, EXISTENCIAS.FUENTEDERECURSO, EXISTENCIAS.FECHA_VENCIMIENTO FECHAVENCIMIENTO, SUM(EXISTENCIAS.ENTRADA) ENTRADAS, SUM(NVL(EXISTENCIAS.SALIDA, 0)) SALIDAS, SUM(EXISTENCIAS.ENTRADA) - SUM(NVL(EXISTENCIAS.SALIDA, 0)) SALDO FROM (SELECT ENTRADAS.COMPANIA, ENTRADAS.ELEMENTO, ENTRADAS.LOTE, ENTRADAS.FUENTEDERECURSO, ENTRADAS.ENTRADA, ENTRADAS.FECHA_VENCIMIENTO, SALIDAS.SALIDA FROM V_D_MOV_ENTRADAS ENTRADAS LEFT JOIN V_D_MOV_SALIDAS SALIDAS ON ENTRADAS.COMPANIA = SALIDAS.COMPANIA AND ENTRADAS.ELEMENTO = SALIDAS.ELEMENTO AND ENTRADAS.LOTE = SALIDAS.LOTE AND ENTRADAS.FUENTEDERECURSO = SALIDAS.FUENTEDERECURSO ) EXISTENCIAS GROUP BY EXISTENCIAS.COMPANIA, EXISTENCIAS.ELEMENTO, EXISTENCIAS.LOTE, EXISTENCIAS.FUENTEDERECURSO, EXISTENCIAS.FECHA_VENCIMIENTO ) V_MOVIMIENTO_VENCIMIENTO ON INVENTARIO.COMPANIA = V_MOVIMIENTO_VENCIMIENTO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = V_MOVIMIENTO_VENCIMIENTO.ELEMENTO, (SELECT LISTAGG(TIPO, ',') WITHIN GROUP(ORDER BY TIPO ) TIPOS FROM (SELECT DISTINCT INVENTARIO.TIPO FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIPO NOT IN ( 'C' ) ) ) TIPOSINV WHERE INVENTARIO.COMPANIA = :COMPANIA AND INSTR(CASE WHEN :IND_TRASPASO IN(0) THEN :TIPO ELSE PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(TIPOSINV.TIPOS) END, TIPO, 1) &gt; 0 AND INVENTARIO.TIENEMOVIMIENTO NOT IN ( 0 ) AND INVENTARIO.INACTIVO IN ( 0 ) ORDER BY INVENTARIO.CODIGOELEMENTO, V_MOVIMIENTO_VENCIMIENTO.LOTE) INI WHERE (CASE WHEN ROWIDCON IS NULL THEN ' ' ELSE UPPER(ROWIDCON) END) LIKE UPPER(CONCAT(:ROWIDCON, '%')) AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN FUENTEDERECURSO IS NULL THEN ' ' ELSE UPPER(FUENTEDERECURSO) END) LIKE UPPER(CONCAT(:FUENTEDERECURSO, '%')) AND (CASE WHEN LOTE IS NULL THEN ' ' ELSE UPPER(LOTE) END) LIKE UPPER(CONCAT(:LOTE, '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN VLRUNITARIOPROM IS NULL THEN ' ' ELSE UPPER(VLRUNITARIOPROM) END) LIKE UPPER(CONCAT(:VLRUNITARIOPROM, '%')) AND (CASE WHEN PRECIOULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PRECIOULTCOMPRA) END) LIKE UPPER(CONCAT(:PRECIOULTCOMPRA, '%')) AND (CASE WHEN IDENTIFICADOR IS NULL THEN ' ' ELSE UPPER(IDENTIFICADOR) END) LIKE UPPER(CONCAT(:IDENTIFICADOR, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN PIDE_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(PIDE_VENCIMIENTO) END) LIKE UPPER(CONCAT(:PIDE_VENCIMIENTO, '%')) AND (CASE WHEN FECHAVENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAVENCIMIENTO) END) LIKE UPPER(CONCAT(:FECHAVENCIMIENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IND_TRASPASO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ROWIDCON" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="FUENTEDERECURSO" sqlType="STRING"/>
		<param name="LOTE" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
