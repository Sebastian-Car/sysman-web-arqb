	<query id="getInventariosPorseriecodigoelementoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DEVOLUTIVO.RESPONSABLE NIT, CONCAT(TERCERO.NOMBRE1,CONCAT(' ',CONCAT(TERCERO.NOMBRE2,CONCAT(' ',CONCAT(TERCERO.APELLIDO1,CONCAT(' ',TERCERO.APELLIDO2) ) ) ) ) ) NOMBRE FROM INVENTARIO INNER JOIN DEVOLUTIVO ON INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO INNER JOIN RESPONSABLE ON DEVOLUTIVO.COMPANIA = RESPONSABLE.COMPANIA AND DEVOLUTIVO.RESPONSABLE = RESPONSABLE.CEDULA AND DEVOLUTIVO.SUCURSAL_RESPONSABLE = RESPONSABLE.SUCURSAL INNER JOIN TERCERO ON TERCERO.COMPANIA = RESPONSABLE.COMPANIA AND TERCERO.NIT = RESPONSABLE.CEDULA AND TERCERO.SUCURSAL = RESPONSABLE.SUCURSAL WHERE INVENTARIO.COMPANIA =:COMPANIA AND INVENTARIO.CODIGOELEMENTO =:CODIGOELEMENTO AND DEVOLUTIVO.SERIE =:SERIE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/porseriecodigoelemento">
		<call-query href="getInventariosPorseriecodigoelementoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>

		</call-query>
	</resource>
	<query id="getInventariosPagCodigosunspscpornombrelargoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT Inventario.CodigoCUBS, Inventario.NombreLargo, Inventario.Unidad, CASE WHEN PrecioReposicion&lt;VlrUnitarioProm THEN VlrUnitarioProm ELSE PrecioReposicion END VALOR FROM Inventario WHERE Inventario.CodigoCUBS Is NOT Null AND Inventario.Compania=:COMPANIA AND Inventario.TieneMovimiento&lt;&gt;0 AND Inventario.INACTIVO=0 ORDER BY Inventario.CodigoElemento) INI WHERE (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(:CODIGOCUBS, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOCUBS":"$CODIGOCUBS","NOMBRELARGO":"$NOMBRELARGO","UNIDAD":"$UNIDAD","VALOR":"$VALOR(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/codigosunspscpornombrelargo/pag">
		<call-query href="getInventariosPagCodigosunspscpornombrelargoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumCodigosunspscpornombrelargoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT Inventario.CodigoCUBS, Inventario.NombreLargo, Inventario.Unidad, CASE WHEN PrecioReposicion&lt;VlrUnitarioProm THEN VlrUnitarioProm ELSE PrecioReposicion END VALOR FROM Inventario WHERE Inventario.CodigoCUBS Is NOT Null AND Inventario.Compania=:COMPANIA AND Inventario.TieneMovimiento&lt;&gt;0 AND Inventario.INACTIVO=0 ORDER BY Inventario.CodigoElemento) INI WHERE (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(:CODIGOCUBS, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/codigosunspscpornombrelargo/num">
		<call-query href="getInventariosNumCodigosunspscpornombrelargoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="VALOR" query-param="VALOR"/>

		</call-query>
	</resource>
	<query id="getInventariosPagPortiponconmovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.TIPO, INVENTARIO.VLRUNITARIOPROM, INVENTARIO.PRECIOULTCOMPRA, INVENTARIO.IDENTIFICADOR, INVENTARIO.UNIDAD,(CASE INVENTARIO.TIENEMOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) TIENEMOVIMIENTO FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO NOT IN (0) AND INVENTARIO.TIPO = 'N' ORDER BY INVENTARIO.CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(:NOMBRELARGO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","TIPO":"$TIPO","VLRUNITARIOPROM":"$VLRUNITARIOPROM","PRECIOULTCOMPRA":"$PRECIOULTCOMPRA","IDENTIFICADOR":"$IDENTIFICADOR","UNIDAD":"$UNIDAD","TIENEMOVIMIENTO":"$TIENEMOVIMIENTO(type:boolean)"}]}}		</result>
