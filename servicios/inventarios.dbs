	<query id="getInventariosPagInventarioSerieQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT * FROM( SELECT DEVOLUTIVO.SERIE, DEVOLUTIVO.ELEMENTO, INVENTARIO.NOMBRELARGO, DEVOLUTIVO.NIIF_VALOR_TOTAL, NVL(DEPRECIAR.NIIF_VLRLIBROS,0) NIIF_VLRLIBROS, RANK() OVER(ORDER BY DEPRECIAR.PERIODO DESC ) RANK, DEVOLUTIVO.ORIGEN FROM INVENTARIO INNER JOIN DEVOLUTIVO ON INVENTARIO.COMPANIA = DEVOLUTIVO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = DEVOLUTIVO.ELEMENTO LEFT JOIN DEPRECIAR ON DEVOLUTIVO.COMPANIA = DEPRECIAR.COMPANIA AND DEVOLUTIVO.ELEMENTO = DEPRECIAR.ELEMENTO AND DEVOLUTIVO.SERIE = DEPRECIAR.SERIE WHERE DEVOLUTIVO.COMPANIA =:COMPANIA AND DEVOLUTIVO.ELEMENTO =:ELEMENTO AND DEVOLUTIVO.PLACAANULADA IN (0) AND INVENTARIO.TIPO IN ('D','M','N') AND DEVOLUTIVO.APLICA_DETERIORO NOT IN (0) ) WHERE RANK = 1) INI WHERE (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(CONCAT('%',:SERIE), '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN NIIF_VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(NIIF_VALOR_TOTAL) END) LIKE UPPER(CONCAT(CONCAT('%',:NIIF_VALOR_TOTAL), '%')) AND (CASE WHEN NIIF_VLRLIBROS IS NULL THEN ' ' ELSE UPPER(NIIF_VLRLIBROS) END) LIKE UPPER(CONCAT(CONCAT('%',:NIIF_VLRLIBROS), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SERIE":"$SERIE","ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","NIIF_VALOR_TOTAL":"$NIIF_VALOR_TOTAL","NIIF_VLRLIBROS":"$NIIF_VLRLIBROS(type:double)","RANK":"$RANK(type:double)","ORIGEN":"$ORIGEN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="NIIF_VALOR_TOTAL" sqlType="STRING"/>
		<param name="NIIF_VLRLIBROS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
