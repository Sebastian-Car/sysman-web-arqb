	<query id="getInventariosNumEntradasauxQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ROW_NUMBER() OVER(ORDER BY INVENTARIO.CODIGOELEMENTO) RN, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO_BODEGA.PROYECTO PROYECTO, INVENTARIO_BODEGA.FUENTEDERECURSO, INVENTARIO_BODEGA.REFERENCIA REFERENCIA, INVENTARIO_BODEGA.AUXILIAR, INVENTARIO_BODEGA.CENTRODECOSTO, INVENTARIO_BODEGA.LOTE, INVENTARIO_BODEGA.BODEGA BODEGA, INVENTARIO_BODEGA.CANTIDAD EXISTENCIA, INVENTARIO_BODEGA.VLRUNITARIO VALORUNITARIO, INVENTARIO.IDENTIFICADOR FROM INVENTARIO_BODEGA INNER JOIN INVENTARIO ON INVENTARIO.COMPANIA = INVENTARIO_BODEGA.COMPANIA AND INVENTARIO.CODIGOELEMENTO = INVENTARIO_BODEGA.ELEMENTO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIENEMOVIMIENTO NOT IN(0) AND INVENTARIO.INACTIVO IN (0) AND INVENTARIO_BODEGA.PROYECTO = :PROYECTO AND INVENTARIO_BODEGA.FUENTEDERECURSO = :FUENTER AND INVENTARIO_BODEGA.REFERENCIA = :REFERENCIA AND INVENTARIO_BODEGA.AUXILIAR = :AUXILIAR AND INVENTARIO_BODEGA.CENTRODECOSTO = :CENTRODECOSTO AND INVENTARIO_BODEGA.BODEGA = :BODEGA AND INVENTARIO_BODEGA.CANTIDAD &gt; 0 ORDER BY INVENTARIO.CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(:PROYECTO, '%')) AND (CASE WHEN FUENTEDERECURSO IS NULL THEN ' ' ELSE UPPER(FUENTEDERECURSO) END) LIKE UPPER(CONCAT(:FUENTEDERECURSO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN CENTRODECOSTO IS NULL THEN ' ' ELSE UPPER(CENTRODECOSTO) END) LIKE UPPER(CONCAT(:CENTRODECOSTO, '%')) AND (CASE WHEN LOTE IS NULL THEN ' ' ELSE UPPER(LOTE) END) LIKE UPPER(CONCAT(:LOTE, '%')) AND (CASE WHEN BODEGA IS NULL THEN ' ' ELSE UPPER(BODEGA) END) LIKE UPPER(CONCAT(:BODEGA, '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTER" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="CENTRODECOSTO" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>								 
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="FUENTEDERECURSO" sqlType="STRING"/>
		<param name="LOTE" sqlType="STRING"/>										 
		<param name="EXISTENCIA" sqlType="STRING"/>

	</query>
