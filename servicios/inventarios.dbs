			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="NIIF_VALOR_TOTAL" query-param="NIIF_VALOR_TOTAL"/>
			<with-param name="NIIF_VLRLIBROS" query-param="NIIF_VLRLIBROS"/>

		</call-query>
	</resource>

	<query id="getInventariosPagGetelementolotefuenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ROW_NUMBER() OVER(ORDER BY INVENTARIO.CODIGOELEMENTO ) ROWIDCON, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO, V_MOVIMIENTO_VENCIMIENTO.FUENTEDERECURSO, CASE WHEN (V_MOVIMIENTO_VENCIMIENTO.LOTE) = '-1.-' THEN '' ELSE V_MOVIMIENTO_VENCIMIENTO.LOTE END AS LOTE, NVL(V_MOVIMIENTO_VENCIMIENTO.SALDO, 0) EXISTENCIA, INVENTARIO.UNIDAD, INVENTARIO.TIPO, INVENTARIO.VLRUNITARIOPROM, INVENTARIO.PRECIOULTCOMPRA, INVENTARIO.IDENTIFICADOR, INVENTARIO.SERIE, INVENTARIO.REFERENCIA,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO,(TO_CHAR(V_MOVIMIENTO_VENCIMIENTO.FECHAVENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHAVENCIMIENTO FROM INVENTARIO LEFT JOIN (SELECT EXISTENCIAS.COMPANIA, EXISTENCIAS.ELEMENTO, EXISTENCIAS.LOTE, EXISTENCIAS.FUENTEDERECURSO, EXISTENCIAS.FECHA_VENCIMIENTO FECHAVENCIMIENTO, SUM(EXISTENCIAS.ENTRADA) ENTRADAS, SUM(NVL(EXISTENCIAS.SALIDA, 0)) SALIDAS, SUM(EXISTENCIAS.ENTRADA) - SUM(NVL(EXISTENCIAS.SALIDA, 0)) SALDO FROM (SELECT ENTRADAS.COMPANIA, ENTRADAS.ELEMENTO, ENTRADAS.LOTE, ENTRADAS.FUENTEDERECURSO, ENTRADAS.ENTRADA, ENTRADAS.FECHA_VENCIMIENTO, SALIDAS.SALIDA FROM V_D_MOV_ENTRADAS ENTRADAS LEFT JOIN V_D_MOV_SALIDAS SALIDAS ON ENTRADAS.COMPANIA = SALIDAS.COMPANIA AND ENTRADAS.ELEMENTO = SALIDAS.ELEMENTO AND ENTRADAS.LOTE = SALIDAS.LOTE AND ENTRADAS.FUENTEDERECURSO = SALIDAS.FUENTEDERECURSO ) EXISTENCIAS GROUP BY EXISTENCIAS.COMPANIA, EXISTENCIAS.ELEMENTO, EXISTENCIAS.LOTE, EXISTENCIAS.FUENTEDERECURSO, EXISTENCIAS.FECHA_VENCIMIENTO ) V_MOVIMIENTO_VENCIMIENTO ON INVENTARIO.COMPANIA = V_MOVIMIENTO_VENCIMIENTO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = V_MOVIMIENTO_VENCIMIENTO.ELEMENTO, (SELECT LISTAGG(TIPO, ',') WITHIN GROUP(ORDER BY TIPO ) TIPOS FROM (SELECT DISTINCT INVENTARIO.TIPO FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.TIPO NOT IN ( 'C' ) ) ) TIPOSINV WHERE INVENTARIO.COMPANIA = :COMPANIA AND INSTR(CASE WHEN :IND_TRASPASO IN(0) THEN :TIPO ELSE PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(TIPOSINV.TIPOS) END, TIPO, 1) &gt; 0 AND INVENTARIO.TIENEMOVIMIENTO NOT IN ( 0 ) AND INVENTARIO.INACTIVO IN ( 0 ) ORDER BY INVENTARIO.CODIGOELEMENTO, V_MOVIMIENTO_VENCIMIENTO.LOTE) INI WHERE (CASE WHEN ROWIDCON IS NULL THEN ' ' ELSE UPPER(ROWIDCON) END) LIKE UPPER(CONCAT(:ROWIDCON, '%')) AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN FUENTEDERECURSO IS NULL THEN ' ' ELSE UPPER(FUENTEDERECURSO) END) LIKE UPPER(CONCAT(:FUENTEDERECURSO, '%')) AND (CASE WHEN LOTE IS NULL THEN ' ' ELSE UPPER(LOTE) END) LIKE UPPER(CONCAT(:LOTE, '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(:TIPO, '%')) AND (CASE WHEN VLRUNITARIOPROM IS NULL THEN ' ' ELSE UPPER(VLRUNITARIOPROM) END) LIKE UPPER(CONCAT(:VLRUNITARIOPROM, '%')) AND (CASE WHEN PRECIOULTCOMPRA IS NULL THEN ' ' ELSE UPPER(PRECIOULTCOMPRA) END) LIKE UPPER(CONCAT(:PRECIOULTCOMPRA, '%')) AND (CASE WHEN IDENTIFICADOR IS NULL THEN ' ' ELSE UPPER(IDENTIFICADOR) END) LIKE UPPER(CONCAT(:IDENTIFICADOR, '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN PIDE_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(PIDE_VENCIMIENTO) END) LIKE UPPER(CONCAT(:PIDE_VENCIMIENTO, '%')) AND (CASE WHEN FECHAVENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHAVENCIMIENTO) END) LIKE UPPER(CONCAT(:FECHAVENCIMIENTO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ROWIDCON":"$ROWIDCON(type:integer)","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","FUENTEDERECURSO":"$FUENTEDERECURSO","LOTE":"$LOTE","EXISTENCIA":"$EXISTENCIA(type:double)","UNIDAD":"$UNIDAD","TIPO":"$TIPO","VLRUNITARIOPROM":"$VLRUNITARIOPROM","PRECIOULTCOMPRA":"$PRECIOULTCOMPRA","IDENTIFICADOR":"$IDENTIFICADOR","SERIE":"$SERIE","REFERENCIA":"$REFERENCIA","PIDE_VENCIMIENTO":"$PIDE_VENCIMIENTO(type:boolean)","FECHAVENCIMIENTO":"$FECHAVENCIMIENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IND_TRASPASO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ROWIDCON" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="FUENTEDERECURSO" sqlType="STRING"/>
		<param name="LOTE" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="VLRUNITARIOPROM" sqlType="STRING"/>
		<param name="PRECIOULTCOMPRA" sqlType="STRING"/>
		<param name="IDENTIFICADOR" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="PIDE_VENCIMIENTO" sqlType="STRING"/>
		<param name="FECHAVENCIMIENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inventarios/getelementolotefuente/pag">
		<call-query href="getInventariosPagGetelementolotefuenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IND_TRASPASO" query-param="IND_TRASPASO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ROWIDCON" query-param="ROWIDCON"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="FUENTEDERECURSO" query-param="FUENTEDERECURSO"/>
			<with-param name="LOTE" query-param="LOTE"/>
			<with-param name="EXISTENCIA" query-param="EXISTENCIA"/>
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="VLRUNITARIOPROM" query-param="VLRUNITARIOPROM"/>
			<with-param name="PRECIOULTCOMPRA" query-param="PRECIOULTCOMPRA"/>
			<with-param name="IDENTIFICADOR" query-param="IDENTIFICADOR"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="PIDE_VENCIMIENTO" query-param="PIDE_VENCIMIENTO"/>
			<with-param name="FECHAVENCIMIENTO" query-param="FECHAVENCIMIENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
