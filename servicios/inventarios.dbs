			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="TIPO" query-param="TIPO"/>

		</call-query>
	</resource>
	<query id="updateInventariosPorElementoDesdeDetalleOrdenDeCompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE INVENTARIO SET CANTCOMPORLLEGAR = CANTCOMPORLLEGAR + :DIFERENCIA, MODIFIED_BY = :MODIFIED_BY,    DATE_MODIFIED = :DATE_MODIFIED  WHERE COMPANIA = :COMPANIA AND CODIGOELEMENTO = :CODIGOELEMENTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DIFERENCIA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="inventarios/porelementodesdedetalleordendecompra">
		<call-query href="updateInventariosPorElementoDesdeDetalleOrdenDeCompra">
