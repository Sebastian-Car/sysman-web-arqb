	<query id="getInventariosPagElementosportipomovimientocyactivosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRELARGO, EXISTENCIA, UNIDAD, TIPO, VLRUNITARIOPROM, PRECIOULTCOMPRA, IDENTIFICADOR, SERIE FROM INVENTARIO, (SELECT LISTAGG(TIPO,',') WITHIN GROUP(ORDER BY TIPO) TIPOS FROM (SELECT DISTINCT TIPO FROM INVENTARIO WHERE COMPANIA = :COMPANIA )) TIPOSINV WHERE COMPANIA = :COMPANIA AND INSTR( CASE WHEN :IND_TRASPASO IN(0) THEN :TIPO ELSE PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(TIPOSINV.TIPOS) END , TIPO , 1 ) &gt; 0 AND TIENEMOVIMIENTO NOT IN(0) AND INACTIVO IN (0) ORDER BY CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(:EXISTENCIA, '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","EXISTENCIA":"$EXISTENCIA","UNIDAD":"$UNIDAD","TIPO":"$TIPO","VLRUNITARIOPROM":"$VLRUNITARIOPROM","PRECIOULTCOMPRA":"$PRECIOULTCOMPRA","IDENTIFICADOR":"$IDENTIFICADOR","SERIE":"$SERIE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IND_TRASPASO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
