			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ELEMENTOINI" query-param="ELEMENTOINI"/>
			<with-param name="CODIGOELEMENTO" query-param="CODIGOELEMENTO"/>
			<with-param name="NOMBRECORTO" query-param="NOMBRECORTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInventariosNumElementosportipofinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRECORTO FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND TIENEMOVIMIENTO NOT IN(0) AND CODIGOELEMENTO &gt;= :ELEMENTOINI ORDER BY CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECORTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ELEMENTOINI" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>

	</query>
