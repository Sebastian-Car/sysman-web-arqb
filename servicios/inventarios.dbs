	<query id="getInventariosPagElementosportipofinQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGOELEMENTO, NOMBRECORTO FROM INVENTARIO WHERE COMPANIA = :COMPANIA AND TIPO = :TIPO AND TIENEMOVIMIENTO NOT IN(0) AND CODIGOELEMENTO &gt;= :ELEMENTOINI ORDER BY CODIGOELEMENTO) INI WHERE (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(:CODIGOELEMENTO, '%')) AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECORTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRECORTO":"$NOMBRECORTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ELEMENTOINI" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
