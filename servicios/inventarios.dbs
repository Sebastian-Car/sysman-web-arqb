			<query id="getInventariosValidarinformeamortizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(( SELECT 1 FROM INVENTARIO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO.CODIGOELEMENTO BETWEEN :ELEMENTOINICIAL AND :ELEMENTOFINAL AND INVENTARIO.DIGITOS_AGRUPACION_INVENTARIO = - 1 AND ROWNUM = 1 ), 0) AS RESULTADO FROM DUAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESULTADO":"$RESULTADO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTOINICIAL" sqlType="STRING"/>
		<param name="ELEMENTOFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inventarios/validarinformeamortizacion">
		<call-query href="getInventariosValidarinformeamortizacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTOINICIAL" query-param="ELEMENTOINICIAL"/>
			<with-param name="ELEMENTOFINAL" query-param="ELEMENTOFINAL"/>

		</call-query>
	</resource>
	<query id="getInventariosPagTodosporconsumoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ROW_NUMBER() OVER(ORDER BY INVENTARIO.CODIGOELEMENTO ) ROWIDCON, INVENTARIO.CODIGOELEMENTO, INVENTARIO.NOMBRELARGO,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO, V_MOVIMIENTO_VENCIMIENTO.FUENTEDERECURSO, NVL(V_MOVIMIENTO_VENCIMIENTO.SALDO, 0) EXISTENCIA, INVENTARIO_BODEGA.BODEGA FROM INVENTARIO LEFT JOIN INVENTARIO_BODEGA ON INVENTARIO.COMPANIA = INVENTARIO_BODEGA.COMPANIA AND INVENTARIO.CODIGOELEMENTO = INVENTARIO_BODEGA.ELEMENTO LEFT JOIN ( SELECT EXISTENCIAS.COMPANIA, EXISTENCIAS.ELEMENTO, EXISTENCIAS.LOTE, EXISTENCIAS.FUENTEDERECURSO, SUM(EXISTENCIAS.ENTRADA) ENTRADAS, SUM(NVL(EXISTENCIAS.SALIDA, 0)) SALIDAS, SUM(EXISTENCIAS.ENTRADA) - SUM(NVL(EXISTENCIAS.SALIDA, 0)) SALDO FROM (SELECT ENTRADAS.COMPANIA, ENTRADAS.ELEMENTO, ENTRADAS.LOTE, ENTRADAS.FUENTEDERECURSO, ENTRADAS.ENTRADA, ENTRADAS.FECHA_VENCIMIENTO, SALIDAS.SALIDA FROM V_D_MOV_ENTRADAS ENTRADAS LEFT JOIN V_D_MOV_SALIDAS SALIDAS ON ENTRADAS.COMPANIA = SALIDAS.COMPANIA AND ENTRADAS.ELEMENTO = SALIDAS.ELEMENTO AND ENTRADAS.LOTE = SALIDAS.LOTE AND ENTRADAS.FUENTEDERECURSO = SALIDAS.FUENTEDERECURSO ) EXISTENCIAS GROUP BY EXISTENCIAS.COMPANIA, EXISTENCIAS.ELEMENTO, EXISTENCIAS.LOTE, EXISTENCIAS.FUENTEDERECURSO) V_MOVIMIENTO_VENCIMIENTO ON INVENTARIO.COMPANIA = V_MOVIMIENTO_VENCIMIENTO.COMPANIA AND INVENTARIO.CODIGOELEMENTO = V_MOVIMIENTO_VENCIMIENTO.ELEMENTO WHERE INVENTARIO.COMPANIA = :COMPANIA AND INVENTARIO_BODEGA.BODEGA = :BODEGA AND TIPO IN('C') AND INVENTARIO.INACTIVO IN ( 0 ) ORDER BY INVENTARIO.CODIGOELEMENTO, V_MOVIMIENTO_VENCIMIENTO.LOTE) INI WHERE (CASE WHEN ROWIDCON IS NULL THEN ' ' ELSE UPPER(ROWIDCON) END) LIKE UPPER(CONCAT(:ROWIDCON, '%')) AND (CASE WHEN CODIGOELEMENTO IS NULL THEN ' ' ELSE UPPER(CODIGOELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOELEMENTO), '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN PIDE_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(PIDE_VENCIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:PIDE_VENCIMIENTO), '%')) AND (CASE WHEN FUENTEDERECURSO IS NULL THEN ' ' ELSE UPPER(FUENTEDERECURSO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUENTEDERECURSO), '%')) AND (CASE WHEN EXISTENCIA IS NULL THEN ' ' ELSE UPPER(EXISTENCIA) END) LIKE UPPER(CONCAT(CONCAT('%',:EXISTENCIA), '%')) AND (CASE WHEN BODEGA IS NULL THEN ' ' ELSE UPPER(BODEGA) END) LIKE UPPER(CONCAT(CONCAT('%',:BODEGA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ROWIDCON":"$ROWIDCON(type:integer)","CODIGOELEMENTO":"$CODIGOELEMENTO","NOMBRELARGO":"$NOMBRELARGO","PIDE_VENCIMIENTO":"$PIDE_VENCIMIENTO(type:boolean)","FUENTEDERECURSO":"$FUENTEDERECURSO","EXISTENCIA":"$EXISTENCIA(type:integer)","BODEGA":"$BODEGA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="BODEGA" sqlType="STRING"/>
		<param name="ROWIDCON" sqlType="STRING"/>
		<param name="CODIGOELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PIDE_VENCIMIENTO" sqlType="STRING"/>
		<param name="FUENTEDERECURSO" sqlType="STRING"/>
		<param name="EXISTENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
