	<query id="getVidetalleviaticosListaporaprobadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VI_AREAMISIONAL.CODAMISIONAL, NVL(VI_AREAMISIONAL.DESCRIPCION,' ') DESCRIPCION  FROM VI_DETALLE_VIATICOS SOLICITUDPERSONAL INNER JOIN VI_VIATICOS SOLICITUD ON SOLICITUDPERSONAL.COMPANIA = SOLICITUD.COMPANIA AND SOLICITUDPERSONAL.NUMERO = SOLICITUD.CODSOLICITUD INNER JOIN PERSONAL ON SOLICITUDPERSONAL.COMPANIA = PERSONAL.COMPANIA AND SOLICITUDPERSONAL.TERCERO = PERSONAL.NUMERO_DCTO INNER JOIN DEPENDENCIA ON SOLICITUD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUD.MISIONAL = DEPENDENCIA.CODIGO INNER JOIN VI_AREAMISIONAL ON DEPENDENCIA.COMPANIA = VI_AREAMISIONAL.COMPANIA AND DEPENDENCIA.CODAMISIONAL = VI_AREAMISIONAL.CODAMISIONAL WHERE SOLICITUD.COMPANIA = :COMPANIA AND SOLICITUD.APROBADO NOT IN (0) ORDER BY CODAMISIONAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODAMISIONAL":"$CODAMISIONAL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/listaporaprobado">
		<call-query href="getVidetalleviaticosListaporaprobadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosListaporaprobadofinQuery"  useConfig="sysmandsunist">
		<sql>SELECT  VI_AREAMISIONAL.CODAMISIONAL, NVL(VI_AREAMISIONAL.DESCRIPCION, ' ') DESCRIPCION  FROM VI_DETALLE_VIATICOS SOLICITUDPERSONAL INNER JOIN VI_VIATICOS SOLICITUD ON SOLICITUDPERSONAL.COMPANIA = SOLICITUD.COMPANIA AND SOLICITUDPERSONAL.NUMERO = SOLICITUD.CODSOLICITUD INNER JOIN PERSONAL ON SOLICITUDPERSONAL.COMPANIA = PERSONAL.COMPANIA AND SOLICITUDPERSONAL.TERCERO = PERSONAL.NUMERO_DCTO INNER JOIN DEPENDENCIA ON SOLICITUD.COMPANIA = DEPENDENCIA.COMPANIA AND SOLICITUD.MISIONAL = DEPENDENCIA.CODIGO INNER JOIN VI_AREAMISIONAL ON DEPENDENCIA.COMPANIA = VI_AREAMISIONAL.COMPANIA AND DEPENDENCIA.CODAMISIONAL = VI_AREAMISIONAL.CODAMISIONAL WHERE SOLICITUD.COMPANIA = :COMPANIA AND SOLICITUD.APROBADO NOT IN (0) AND VI_AREAMISIONAL.CODAMISIONAL &gt;= :CODIGOINICIAL ORDER BY CODAMISIONAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODAMISIONAL":"$CODAMISIONAL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/listaporaprobadofin">
		<call-query href="getVidetalleviaticosListaporaprobadofinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosTotalesGrillaPorCiaCodQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(VI_DETALLE_VIATICOS.VALDIASPER) VALDIASPER, SUM(VI_DETALLE_VIATICOS.VALDIASSINPER) VALDIASSINPER, SUM(VI_DETALLE_VIATICOS.TOTAL) TOTAL, SUM(VI_DETALLE_VIATICOS.VALOR_ABONADO) VALOR_ABONADO, SUM(VI_DETALLE_VIATICOS.SALDO) SALDO  FROM VI_DETALLE_VIATICOS WHERE VI_DETALLE_VIATICOS.COMPANIA = :COMPANIA AND VI_DETALLE_VIATICOS.NUMERO =:CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALDIASPER":"$VALDIASPER(type:integer)","VALDIASSINPER":"$VALDIASSINPER(type:integer)","TOTAL":"$TOTAL(type:integer)","VALOR_ABONADO":"$VALOR_ABONADO(type:integer)","SALDO":"$SALDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/totalesgrillaporciacod">
		<call-query href="getVidetalleviaticosTotalesGrillaPorCiaCodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosCantidadDetalleSolicitudQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CANTIDAD  FROM VI_DETALLE_VIATICOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_VIATICO = :TIPO_VIATICO AND NUMERO = :CODSOLICITUD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_VIATICO" sqlType="STRING"/>
		<param name="CODSOLICITUD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/cantidaddetallesolicitud">
		<call-query href="getVidetalleviaticosCantidadDetalleSolicitudQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_VIATICO" query-param="TIPO_VIATICO"/>
			<with-param name="CODSOLICITUD" query-param="CODSOLICITUD"/>

		</call-query>
	</resource>

