		</call-query>
	</resource>
	<query id="updateVidetalleviaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VI_DETALLE_VIATICOS SET ANO=:ANO, COMPANIA=:COMPANIA, CONCEPTO=:CONCEPTO, CONSECUTIVO=:CONSECUTIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), DESCRIPCION=:DESCRIPCION, MODIFIED_BY=:MODIFIED_BY, NUMDIASPER=:NUMDIASPER, NUMDIASSINPER=:NUMDIASSINPER, NUMERO=:NUMERO, RUBRO=:RUBRO, SALDO=:SALDO, SUCURSAL=:SUCURSAL, TERCERO=:TERCERO, TIPO_VIATICO=:TIPO_VIATICO, TOTAL=:TOTAL, VALDIASPER=:VALDIASPER, VALDIASSINPER=:VALDIASSINPER, VALOR_ABONADO=:VALOR_ABONADO WHERE VI_DETALLE_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_DETALLE_VIATICOS.ANO= :KEY_ANO AND VI_DETALLE_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_DETALLE_VIATICOS.NUMERO= :KEY_NUMERO AND VI_DETALLE_VIATICOS.TERCERO= :KEY_TERCERO AND VI_DETALLE_VIATICOS.SUCURSAL= :KEY_SUCURSAL AND VI_DETALLE_VIATICOS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="NUMDIASPER" sqlType="STRING"/>
		<param name="NUMDIASSINPER" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="TIPO_VIATICO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="VALDIASPER" sqlType="STRING"/>
		<param name="VALDIASSINPER" sqlType="STRING"/>
		<param name="VALOR_ABONADO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
