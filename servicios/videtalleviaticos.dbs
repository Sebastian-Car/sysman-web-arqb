<data name="videtalleviaticos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVidetalleviaticosPagViaticosporfuncionarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) ) FUNCIONARIO, TO_CHAR(LAST_VALUE(PERSONAL.FECHA_DE_INGRESO) OVER( ORDER BY PERSONAL.FECHA_DE_INGRESO ),'DD/MM/YYYY') ULTIMO FROM VI_VIATICOS VIATICO INNER JOIN VI_DETALLE_VIATICOS DETALLE ON VIATICO.COMPANIA = DETALLE.COMPANIA AND VIATICO.ANO = DETALLE.ANO AND VIATICO.CODSOLICITUD = DETALLE.NUMERO INNER JOIN PERSONAL ON DETALLE.COMPANIA = PERSONAL.COMPANIA AND DETALLE.TERCERO = PERSONAL.NUMERO_DCTO WHERE VIATICO.COMPANIA =:COMPANIA ORDER BY PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN FUNCIONARIO IS NULL THEN ' ' ELSE UPPER(FUNCIONARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUNCIONARIO), '%')) AND (CASE WHEN ULTIMO IS NULL THEN ' ' ELSE UPPER(ULTIMO) END) LIKE UPPER(CONCAT(CONCAT('%',:ULTIMO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","FUNCIONARIO":"$FUNCIONARIO","ULTIMO":"$ULTIMO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="FUNCIONARIO" sqlType="STRING"/>
		<param name="ULTIMO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="videtalleviaticos/viaticosporfuncionario/pag">
		<call-query href="getVidetalleviaticosPagViaticosporfuncionarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="FUNCIONARIO" query-param="FUNCIONARIO"/>
			<with-param name="ULTIMO" query-param="ULTIMO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosNumViaticosporfuncionarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) ) FUNCIONARIO, TO_CHAR(LAST_VALUE(PERSONAL.FECHA_DE_INGRESO) OVER( ORDER BY PERSONAL.FECHA_DE_INGRESO ),'DD/MM/YYYY') ULTIMO FROM VI_VIATICOS VIATICO INNER JOIN VI_DETALLE_VIATICOS DETALLE ON VIATICO.COMPANIA = DETALLE.COMPANIA AND VIATICO.ANO = DETALLE.ANO AND VIATICO.CODSOLICITUD = DETALLE.NUMERO INNER JOIN PERSONAL ON DETALLE.COMPANIA = PERSONAL.COMPANIA AND DETALLE.TERCERO = PERSONAL.NUMERO_DCTO WHERE VIATICO.COMPANIA =:COMPANIA ORDER BY PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN FUNCIONARIO IS NULL THEN ' ' ELSE UPPER(FUNCIONARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUNCIONARIO), '%')) AND (CASE WHEN ULTIMO IS NULL THEN ' ' ELSE UPPER(ULTIMO) END) LIKE UPPER(CONCAT(CONCAT('%',:ULTIMO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="FUNCIONARIO" sqlType="STRING"/>
		<param name="ULTIMO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/viaticosporfuncionario/num">
		<call-query href="getVidetalleviaticosNumViaticosporfuncionarioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="FUNCIONARIO" query-param="FUNCIONARIO"/>
			<with-param name="ULTIMO" query-param="ULTIMO"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosPagViaticosporfuncionariomayoracodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) ) FUNCIONARIO, TO_CHAR(LAST_VALUE(PERSONAL.FECHA_DE_INGRESO) OVER( ORDER BY PERSONAL.FECHA_DE_INGRESO ),'DD/MM/YYYY') ULTIMO FROM VI_VIATICOS VIATICO INNER JOIN VI_DETALLE_VIATICOS DETALLE ON VIATICO.COMPANIA = DETALLE.COMPANIA AND VIATICO.ANO = DETALLE.ANO AND VIATICO.CODSOLICITUD = DETALLE.NUMERO INNER JOIN PERSONAL ON DETALLE.COMPANIA = PERSONAL.COMPANIA AND DETALLE.TERCERO = PERSONAL.NUMERO_DCTO WHERE VIATICO.COMPANIA =:COMPANIA AND PERSONAL.NUMERO_DCTO &gt;=:CODIGOINICIAL ORDER BY PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN FUNCIONARIO IS NULL THEN ' ' ELSE UPPER(FUNCIONARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUNCIONARIO), '%')) AND (CASE WHEN ULTIMO IS NULL THEN ' ' ELSE UPPER(ULTIMO) END) LIKE UPPER(CONCAT(CONCAT('%',:ULTIMO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO_DCTO":"$NUMERO_DCTO","FUNCIONARIO":"$FUNCIONARIO","ULTIMO":"$ULTIMO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="FUNCIONARIO" sqlType="STRING"/>
		<param name="ULTIMO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="videtalleviaticos/viaticosporfuncionariomayoracod/pag">
		<call-query href="getVidetalleviaticosPagViaticosporfuncionariomayoracodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="FUNCIONARIO" query-param="FUNCIONARIO"/>
			<with-param name="ULTIMO" query-param="ULTIMO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosNumViaticosporfuncionariomayoracodQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) ) FUNCIONARIO, TO_CHAR(LAST_VALUE(PERSONAL.FECHA_DE_INGRESO) OVER( ORDER BY PERSONAL.FECHA_DE_INGRESO ),'DD/MM/YYYY') ULTIMO FROM VI_VIATICOS VIATICO INNER JOIN VI_DETALLE_VIATICOS DETALLE ON VIATICO.COMPANIA = DETALLE.COMPANIA AND VIATICO.ANO = DETALLE.ANO AND VIATICO.CODSOLICITUD = DETALLE.NUMERO INNER JOIN PERSONAL ON DETALLE.COMPANIA = PERSONAL.COMPANIA AND DETALLE.TERCERO = PERSONAL.NUMERO_DCTO WHERE VIATICO.COMPANIA =:COMPANIA AND PERSONAL.NUMERO_DCTO &gt;=:CODIGOINICIAL ORDER BY PERSONAL.NUMERO_DCTO, CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',CONCAT(PERSONAL.APELLIDO2,CONCAT(' ',PERSONAL.NOMBRES) ) ) )) INI WHERE (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END) LIKE UPPER(CONCAT(:NUMERO_DCTO, '%')) AND (CASE WHEN FUNCIONARIO IS NULL THEN ' ' ELSE UPPER(FUNCIONARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FUNCIONARIO), '%')) AND (CASE WHEN ULTIMO IS NULL THEN ' ' ELSE UPPER(ULTIMO) END) LIKE UPPER(CONCAT(CONCAT('%',:ULTIMO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="FUNCIONARIO" sqlType="STRING"/>
		<param name="ULTIMO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/viaticosporfuncionariomayoracod/num">
