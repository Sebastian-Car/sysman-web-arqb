	<query id="getVidetalleviaticosTotalDeViaticoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(TOTAL,0) TOTAL  FROM VI_DETALLE_VIATICOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPO_VIATICO = :TIPOVIATICO AND TERCERO = :TERCERO AND SUCURSAL = :SUCURSAL AND CONCEPTO = :CONCEPTO AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOVIATICO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/totaldeviatico">
		<call-query href="getVidetalleviaticosTotalDeViaticoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOVIATICO" query-param="TIPOVIATICO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="insertVidetalleviaticos" keyColumns="COMPANIA,ANO,TIPO_VIATICO,NUMERO,TERCERO,SUCURSAL,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VI_DETALLE_VIATICOS (ANO, COMPANIA, COMPROBANTE_CNT, COMPROBANTE_PPTAL, CONCEPTO, CREATED_BY, DATE_CREATED, DESCRIPCION, NUMDIASPER, NUMDIASSINPER, NUMERO, RUBRO, SALDO, SALDO_PRESUPUESTAL, SUCURSAL, TERCERO, TIPO_CPTE_CNT, TIPO_CPTE_PPTAL, TIPO_VIATICO, TOTAL, VALDIASPER, VALDIASSINPER, VALOR_ABONADO, CONSECUTIVO) VALUES (:ANO, :COMPANIA, :COMPROBANTE_CNT, :COMPROBANTE_PPTAL, :CONCEPTO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :DESCRIPCION, :NUMDIASPER, :NUMDIASSINPER, :NUMERO, :RUBRO, :SALDO, :SALDO_PRESUPUESTAL, :SUCURSAL, :TERCERO, :TIPO_CPTE_CNT, :TIPO_CPTE_PPTAL, :TIPO_VIATICO, :TOTAL, :VALDIASPER, :VALDIASSINPER, :VALOR_ABONADO, :CONSECUTIVO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO_VIATICO":"$TIPO_VIATICO","KEY_NUMERO":"$NUMERO(type:long)","KEY_TERCERO":"$TERCERO","KEY_SUCURSAL":"$SUCURSAL","KEY_CONCEPTO":"$CONCEPTO"}]}}		</result>
		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="" name="COMPROBANTE_CNT" sqlType="STRING"/>
		<param defaultValue="" name="COMPROBANTE_PPTAL" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="NUMDIASPER" sqlType="STRING"/>
		<param defaultValue="0" name="NUMDIASSINPER" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="RUBRO" sqlType="STRING"/>
		<param defaultValue="0" name="SALDO" sqlType="STRING"/>
		<param defaultValue="0" name="SALDO_PRESUPUESTAL" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CPTE_CNT" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_CPTE_PPTAL" sqlType="STRING"/>
		<param name="TIPO_VIATICO" sqlType="STRING"/>
		<param defaultValue="0" name="TOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALDIASPER" sqlType="STRING"/>
		<param defaultValue="0" name="VALDIASSINPER" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_ABONADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="POST" path="videtalleviaticos">
		<call-query href="insertVidetalleviaticos">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COMPROBANTE_CNT" query-param="COMPROBANTE_CNT"/>
			<with-param name="COMPROBANTE_PPTAL" query-param="COMPROBANTE_PPTAL"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="NUMDIASPER" query-param="NUMDIASPER"/>
			<with-param name="NUMDIASSINPER" query-param="NUMDIASSINPER"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="SALDO_PRESUPUESTAL" query-param="SALDO_PRESUPUESTAL"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="TIPO_CPTE_CNT" query-param="TIPO_CPTE_CNT"/>
			<with-param name="TIPO_CPTE_PPTAL" query-param="TIPO_CPTE_PPTAL"/>
			<with-param name="TIPO_VIATICO" query-param="TIPO_VIATICO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="VALDIASPER" query-param="VALDIASPER"/>
			<with-param name="VALDIASSINPER" query-param="VALDIASSINPER"/>
			<with-param name="VALOR_ABONADO" query-param="VALOR_ABONADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="deleteVidetalleviaticos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VI_DETALLE_VIATICOS WHERE VI_DETALLE_VIATICOS.COMPANIA= :KEY_COMPANIA AND VI_DETALLE_VIATICOS.ANO= :KEY_ANO AND VI_DETALLE_VIATICOS.TIPO_VIATICO= :KEY_TIPO_VIATICO AND VI_DETALLE_VIATICOS.NUMERO= :KEY_NUMERO AND VI_DETALLE_VIATICOS.TERCERO= :KEY_TERCERO AND VI_DETALLE_VIATICOS.SUCURSAL= :KEY_SUCURSAL AND VI_DETALLE_VIATICOS.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO_VIATICO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="videtalleviaticos">
		<call-query href="deleteVidetalleviaticos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO_VIATICO" query-param="KEY_TIPO_VIATICO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT VI_DETALLE_VIATICOS.COMPANIA , VI_DETALLE_VIATICOS.ANO , VI_DETALLE_VIATICOS.NUMERO , VI_DETALLE_VIATICOS.DESCRIPCION , VI_DETALLE_VIATICOS.SUCURSAL , VI_DETALLE_VIATICOS.TIPO_VIATICO , VI_DETALLE_VIATICOS.CONSECUTIVO, VI_DETALLE_VIATICOS.TERCERO , PERSONAL.NOMBRECOMPLETO NOMBREPERSONA, VI_DETALLE_VIATICOS.CONCEPTO , VI_DETALLE_VIATICOS.RUBRO , VI_DETALLE_VIATICOS.NUMDIASSINPER , VI_DETALLE_VIATICOS.NUMDIASPER , VI_DETALLE_VIATICOS.VALDIASSINPER , VI_DETALLE_VIATICOS.VALDIASPER , VI_DETALLE_VIATICOS.TOTAL , VI_DETALLE_VIATICOS.VALOR_ABONADO , VI_DETALLE_VIATICOS.SALDO  FROM VI_DETALLE_VIATICOS LEFT JOIN PERSONAL ON VI_DETALLE_VIATICOS.COMPANIA = PERSONAL.COMPANIA AND VI_DETALLE_VIATICOS.TERCERO = PERSONAL.NUMERO_DCTO AND VI_DETALLE_VIATICOS.SUCURSAL = PERSONAL.SUCURSAL WHERE VI_DETALLE_VIATICOS.COMPANIA = :COMPANIA AND VI_DETALLE_VIATICOS.NUMERO = :CODIGO) WHERE (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBREPERSONA IS NULL THEN ' ' ELSE UPPER(NOMBREPERSONA) END)  LIKE UPPER( '%' || :NOMBREPERSONA || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN RUBRO IS NULL THEN ' ' ELSE UPPER(RUBRO) END)  LIKE UPPER(:RUBRO || '%')  AND (CASE WHEN NUMDIASSINPER IS NULL THEN ' ' ELSE UPPER(NUMDIASSINPER) END)  LIKE UPPER(:NUMDIASSINPER || '%')  AND (CASE WHEN NUMDIASPER IS NULL THEN ' ' ELSE UPPER(NUMDIASPER) END)  LIKE UPPER(:NUMDIASPER || '%')  AND (CASE WHEN VALDIASSINPER IS NULL THEN ' ' ELSE UPPER(VALDIASSINPER) END)  LIKE UPPER( '%' || :VALDIASSINPER || '%')  AND (CASE WHEN VALDIASPER IS NULL THEN ' ' ELSE UPPER(VALDIASPER) END)  LIKE UPPER( '%' || :VALDIASPER || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%')  AND (CASE WHEN VALOR_ABONADO IS NULL THEN ' ' ELSE UPPER(VALOR_ABONADO) END)  LIKE UPPER( '%' || :VALOR_ABONADO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER( '%' || :SALDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION","SUCURSAL":"$SUCURSAL","TIPO_VIATICO":"$TIPO_VIATICO","CONSECUTIVO":"$CONSECUTIVO(type:integer)","TERCERO":"$TERCERO","NOMBREPERSONA":"$NOMBREPERSONA","CONCEPTO":"$CONCEPTO","RUBRO":"$RUBRO","NUMDIASSINPER":"$NUMDIASSINPER(type:integer)","NUMDIASPER":"$NUMDIASPER(type:integer)","VALDIASSINPER":"$VALDIASSINPER","VALDIASPER":"$VALDIASPER","TOTAL":"$TOTAL","VALOR_ABONADO":"$VALOR_ABONADO","SALDO":"$SALDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBREPERSONA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="NUMDIASSINPER" sqlType="STRING"/>
		<param name="NUMDIASPER" sqlType="STRING"/>
		<param name="VALDIASSINPER" sqlType="STRING"/>
		<param name="VALDIASPER" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="VALOR_ABONADO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="videtalleviaticos">
		<call-query href="getVidetalleviaticosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBREPERSONA" query-param="NOMBREPERSONA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="RUBRO" query-param="RUBRO"/>
			<with-param name="NUMDIASSINPER" query-param="NUMDIASSINPER"/>
			<with-param name="NUMDIASPER" query-param="NUMDIASPER"/>
			<with-param name="VALDIASSINPER" query-param="VALDIASSINPER"/>
			<with-param name="VALDIASPER" query-param="VALDIASPER"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="VALOR_ABONADO" query-param="VALOR_ABONADO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVidetalleviaticosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT VI_DETALLE_VIATICOS.COMPANIA , VI_DETALLE_VIATICOS.ANO , VI_DETALLE_VIATICOS.NUMERO , VI_DETALLE_VIATICOS.DESCRIPCION , VI_DETALLE_VIATICOS.SUCURSAL , VI_DETALLE_VIATICOS.TIPO_VIATICO , VI_DETALLE_VIATICOS.CONSECUTIVO, VI_DETALLE_VIATICOS.TERCERO , PERSONAL.NOMBRECOMPLETO NOMBREPERSONA, VI_DETALLE_VIATICOS.CONCEPTO , VI_DETALLE_VIATICOS.RUBRO , VI_DETALLE_VIATICOS.NUMDIASSINPER , VI_DETALLE_VIATICOS.NUMDIASPER , VI_DETALLE_VIATICOS.VALDIASSINPER , VI_DETALLE_VIATICOS.VALDIASPER , VI_DETALLE_VIATICOS.TOTAL , VI_DETALLE_VIATICOS.VALOR_ABONADO , VI_DETALLE_VIATICOS.SALDO  FROM VI_DETALLE_VIATICOS LEFT JOIN PERSONAL ON VI_DETALLE_VIATICOS.COMPANIA = PERSONAL.COMPANIA AND VI_DETALLE_VIATICOS.TERCERO = PERSONAL.NUMERO_DCTO AND VI_DETALLE_VIATICOS.SUCURSAL = PERSONAL.SUCURSAL WHERE VI_DETALLE_VIATICOS.COMPANIA = :COMPANIA AND VI_DETALLE_VIATICOS.NUMERO = :CODIGO) WHERE (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBREPERSONA IS NULL THEN ' ' ELSE UPPER(NOMBREPERSONA) END)  LIKE UPPER( '%' || :NOMBREPERSONA || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN RUBRO IS NULL THEN ' ' ELSE UPPER(RUBRO) END)  LIKE UPPER(:RUBRO || '%')  AND (CASE WHEN NUMDIASSINPER IS NULL THEN ' ' ELSE UPPER(NUMDIASSINPER) END)  LIKE UPPER(:NUMDIASSINPER || '%')  AND (CASE WHEN NUMDIASPER IS NULL THEN ' ' ELSE UPPER(NUMDIASPER) END)  LIKE UPPER(:NUMDIASPER || '%')  AND (CASE WHEN VALDIASSINPER IS NULL THEN ' ' ELSE UPPER(VALDIASSINPER) END)  LIKE UPPER( '%' || :VALDIASSINPER || '%')  AND (CASE WHEN VALDIASPER IS NULL THEN ' ' ELSE UPPER(VALDIASPER) END)  LIKE UPPER( '%' || :VALDIASPER || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%')  AND (CASE WHEN VALOR_ABONADO IS NULL THEN ' ' ELSE UPPER(VALOR_ABONADO) END)  LIKE UPPER( '%' || :VALOR_ABONADO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER( '%' || :SALDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBREPERSONA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>
		<param name="NUMDIASSINPER" sqlType="STRING"/>
		<param name="NUMDIASPER" sqlType="STRING"/>
		<param name="VALDIASSINPER" sqlType="STRING"/>
		<param name="VALDIASPER" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="VALOR_ABONADO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="videtalleviaticos/numero">
		<call-query href="getVidetalleviaticosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
