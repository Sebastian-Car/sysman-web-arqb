<data name="sftempdetallecuota" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSftempdetallecuotaPagDistribucioncuotasporconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TDC.COMPANIA ,TDC.TIPO_AP ,TDC.CODIGO_AP ,TDC.CUOTA ,TDC.ANO ,TDC.TIPOFACT ,TDC.NROFACT ,TDC.CONCEPTO ,C.NOMBRE CONCEPTO_NOM ,TDC.VALOR_BASE ,TDC.VALOR_IVA ,TDC.VALOR_RETE ,TDC.VALOR_DESCUENTO ,TDC.VALOR_ICA ,TDC.TOTAL_CUOTA  FROM SF_TEMP_DETALLE_CUOTA TDC INNER JOIN SF_CONCEPTOS C ON TDC.COMPANIA = C.COMPANIA AND TDC.ANO = C.ANO AND TDC.TIPO_AP = C.TIPOCOBRO AND TDC.CONCEPTO = C.CODIGO WHERE TDC.COMPANIA = :COMPANIA AND TDC.TIPO_AP = :TIPO AND TDC.CODIGO_AP = :CODIGO AND TDC.CUOTA = :MI_CUOTA) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN CONCEPTO_NOM IS NULL THEN ' ' ELSE UPPER(CONCEPTO_NOM) END)  LIKE UPPER( '%' || :CONCEPTO_NOM || '%')  AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END)  LIKE UPPER(:VALOR_BASE || '%')  AND (CASE WHEN VALOR_IVA IS NULL THEN ' ' ELSE UPPER(VALOR_IVA) END)  LIKE UPPER(:VALOR_IVA || '%')  AND (CASE WHEN VALOR_RETE IS NULL THEN ' ' ELSE UPPER(VALOR_RETE) END)  LIKE UPPER(:VALOR_RETE || '%')  AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END)  LIKE UPPER(:VALOR_DESCUENTO || '%')  AND (CASE WHEN VALOR_ICA IS NULL THEN ' ' ELSE UPPER(VALOR_ICA) END)  LIKE UPPER(:VALOR_ICA || '%')  AND (CASE WHEN TOTAL_CUOTA IS NULL THEN ' ' ELSE UPPER(TOTAL_CUOTA) END)  LIKE UPPER(:TOTAL_CUOTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_AP":"$TIPO_AP","CODIGO_AP":"$CODIGO_AP(type:long)","CUOTA":"$CUOTA(type:integer)","ANO":"$ANO(type:integer)","TIPOFACT":"$TIPOFACT","NROFACT":"$NROFACT(type:long)","CONCEPTO":"$CONCEPTO","CONCEPTO_NOM":"$CONCEPTO_NOM","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_ICA":"$VALOR_ICA","TOTAL_CUOTA":"$TOTAL_CUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MI_CUOTA" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CONCEPTO_NOM" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="TOTAL_CUOTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sftempdetallecuota/distribucioncuotasporconcepto/pag">
		<call-query href="getSftempdetallecuotaPagDistribucioncuotasporconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MI_CUOTA" query-param="MI_CUOTA"/>
			<with-param name="CUOTA" query-param="CUOTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CONCEPTO_NOM" query-param="CONCEPTO_NOM"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="VALOR_IVA" query-param="VALOR_IVA"/>
			<with-param name="VALOR_RETE" query-param="VALOR_RETE"/>
			<with-param name="VALOR_DESCUENTO" query-param="VALOR_DESCUENTO"/>
			<with-param name="VALOR_ICA" query-param="VALOR_ICA"/>
			<with-param name="TOTAL_CUOTA" query-param="TOTAL_CUOTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSftempdetallecuotaNumDistribucioncuotasporconceptoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  TDC.COMPANIA ,TDC.TIPO_AP ,TDC.CODIGO_AP ,TDC.CUOTA ,TDC.ANO ,TDC.TIPOFACT ,TDC.NROFACT ,TDC.CONCEPTO ,C.NOMBRE CONCEPTO_NOM ,TDC.VALOR_BASE ,TDC.VALOR_IVA ,TDC.VALOR_RETE ,TDC.VALOR_DESCUENTO ,TDC.VALOR_ICA ,TDC.TOTAL_CUOTA  FROM SF_TEMP_DETALLE_CUOTA TDC INNER JOIN SF_CONCEPTOS C ON TDC.COMPANIA = C.COMPANIA AND TDC.ANO = C.ANO AND TDC.TIPO_AP = C.TIPOCOBRO AND TDC.CONCEPTO = C.CODIGO WHERE TDC.COMPANIA = :COMPANIA AND TDC.TIPO_AP = :TIPO AND TDC.CODIGO_AP = :CODIGO AND TDC.CUOTA = :MI_CUOTA) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN CONCEPTO_NOM IS NULL THEN ' ' ELSE UPPER(CONCEPTO_NOM) END)  LIKE UPPER( '%' || :CONCEPTO_NOM || '%')  AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END)  LIKE UPPER(:VALOR_BASE || '%')  AND (CASE WHEN VALOR_IVA IS NULL THEN ' ' ELSE UPPER(VALOR_IVA) END)  LIKE UPPER(:VALOR_IVA || '%')  AND (CASE WHEN VALOR_RETE IS NULL THEN ' ' ELSE UPPER(VALOR_RETE) END)  LIKE UPPER(:VALOR_RETE || '%')  AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END)  LIKE UPPER(:VALOR_DESCUENTO || '%')  AND (CASE WHEN VALOR_ICA IS NULL THEN ' ' ELSE UPPER(VALOR_ICA) END)  LIKE UPPER(:VALOR_ICA || '%')  AND (CASE WHEN TOTAL_CUOTA IS NULL THEN ' ' ELSE UPPER(TOTAL_CUOTA) END)  LIKE UPPER(:TOTAL_CUOTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MI_CUOTA" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CONCEPTO_NOM" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="TOTAL_CUOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftempdetallecuota/distribucioncuotasporconcepto/num">
		<call-query href="getSftempdetallecuotaNumDistribucioncuotasporconceptoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MI_CUOTA" query-param="MI_CUOTA"/>
			<with-param name="CUOTA" query-param="CUOTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CONCEPTO_NOM" query-param="CONCEPTO_NOM"/>
			<with-param name="VALOR_BASE" query-param="VALOR_BASE"/>
			<with-param name="VALOR_IVA" query-param="VALOR_IVA"/>
			<with-param name="VALOR_RETE" query-param="VALOR_RETE"/>
			<with-param name="VALOR_DESCUENTO" query-param="VALOR_DESCUENTO"/>
			<with-param name="VALOR_ICA" query-param="VALOR_ICA"/>
			<with-param name="TOTAL_CUOTA" query-param="TOTAL_CUOTA"/>

		</call-query>
	</resource>
	<query id="getSftempdetallecuotaSumatoriaporcuotaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(TDC.VALOR_BASE ) BASE_SUM ,SUM(TDC.VALOR_IVA ) IVA_SUM ,SUM(TDC.VALOR_RETE ) RETE_SUM ,SUM(TDC.VALOR_DESCUENTO) DESCUENTO_SUM ,SUM(TDC.VALOR_ICA ) ICA_SUM ,SUM(TDC.TOTAL_CUOTA ) CUOTA_SUM  FROM SF_TEMP_DETALLE_CUOTA TDC INNER JOIN SF_CONCEPTOS C ON TDC.COMPANIA = C.COMPANIA AND TDC.ANO = C.ANO AND TDC.TIPO_AP = C.TIPOCOBRO AND TDC.CONCEPTO = C.CODIGO WHERE TDC.COMPANIA = :COMPANIA AND TDC.TIPO_AP = :TIPO AND TDC.CODIGO_AP = :CODIGO AND TDC.CUOTA = :MI_CUOTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BASE_SUM":"$BASE_SUM(type:integer)","IVA_SUM":"$IVA_SUM(type:integer)","RETE_SUM":"$RETE_SUM(type:integer)","DESCUENTO_SUM":"$DESCUENTO_SUM(type:integer)","ICA_SUM":"$ICA_SUM(type:integer)","CUOTA_SUM":"$CUOTA_SUM(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MI_CUOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sftempdetallecuota/sumatoriaporcuota">
		<call-query href="getSftempdetallecuotaSumatoriaporcuotaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MI_CUOTA" query-param="MI_CUOTA"/>

		</call-query>
	</resource>

</data>