	<query id="getTramitesPagTramites/tramitesprocesofecha/pagQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TRAMITES.NUMERO, PROCESOS.NOMBRE FROM TRAMITES INNER JOIN DEPENDENCIA ON TRAMITES.COMPANIA = DEPENDENCIA.COMPANIA AND TRAMITES.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TIPOTRAMITES ON TRAMITES.COMPANIA = TIPOTRAMITES.COMPANIA AND TRAMITES.PROCESOS = TIPOTRAMITES.PROCESOS AND TRAMITES.TIPO_TRAMITE = TIPOTRAMITES.TIPOTRAMITE INNER JOIN PROCESOS ON TIPOTRAMITES.COMPANIA = PROCESOS.COMPANIA AND TIPOTRAMITES.PROCESOS = PROCESOS.CODIGO WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND GESTION_DOCUMENTAL NOT IN (0) AND NUMERACION_UNICA NOT IN (0) AND FECHA_REAL BETWEEN :FECHAINICIAL AND :FECHAFINAL and DEPENDENCIA.CODIGO BETWEEN :DEPENDENCIAINICIAL AND :DEPENDENCIAFINAL and PROCESOS.CODIGO BETWEEN :PROCESOINICIAL and :PROCESOFINAL ORDER BY TRAMITES.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="DEPENDENCIAINICIAL" sqlType="STRING"/>
		<param name="DEPENDENCIAFINAL" sqlType="STRING"/>
		<param name="PROCESOINICIAL" sqlType="STRING"/>
		<param name="PROCESOFINAL" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
