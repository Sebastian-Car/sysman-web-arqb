	<query id="getTramitesPagTramites/tramitesprocesofechaini/pagQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PROCESOS.CODIGO, PROCESOS.NOMBRE FROM TRAMITES INNER JOIN DEPENDENCIA ON TRAMITES.COMPANIA = DEPENDENCIA.COMPANIA AND TRAMITES.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TIPOTRAMITES ON TRAMITES.COMPANIA = TIPOTRAMITES.COMPANIA AND TRAMITES.PROCESOS = TIPOTRAMITES.PROCESOS AND TRAMITES.TIPO_TRAMITE = TIPOTRAMITES.TIPOTRAMITE INNER JOIN PROCESOS ON TIPOTRAMITES.COMPANIA = PROCESOS.COMPANIA AND TIPOTRAMITES.PROCESOS = PROCESOS.CODIGO WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND GESTION_DOCUMENTAL NOT IN (0) AND NUMERACION_UNICA NOT IN (0) AND FECHA_REAL BETWEEN :FECHAINICIAL AND :FECHAFINAL AND DEPENDENCIA.CODIGO BETWEEN :DEPENDENCIAINICIAL AND :DEPENDENCIAFINAL AND PROCESOS.CODIGO &gt;= :NUMERO ORDER BY DEPENDENCIA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
