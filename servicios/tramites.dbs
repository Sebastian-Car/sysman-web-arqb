			<with-param name="DEPENDENCIA_NOM" query-param="DEPENDENCIA_NOM"/>
			<with-param name="RESPONSABLE_ACT" query-param="RESPONSABLE_ACT"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE_TERCERO" query-param="NOMBRE_TERCERO"/>
			<with-param name="FECHA_RADICADO" query-param="FECHA_RADICADO"/>
			<with-param name="NODO_A_NOM" query-param="NODO_A_NOM"/>
			<with-param name="FECHA_PASE" query-param="FECHA_PASE"/>
			<with-param name="FECHA_LIMITE_ETAPA" query-param="FECHA_LIMITE_ETAPA"/>
			<with-param name="FECHA_LIMITE_PROCESO" query-param="FECHA_LIMITE_PROCESO"/>
			<with-param name="DURACION_D_HABIL" query-param="DURACION_D_HABIL"/>
			<with-param name="DURACION_D_CALENDARIO" query-param="DURACION_D_CALENDARIO"/>
			<with-param name="COLOR" query-param="COLOR"/>
			<with-param name="PRORROGA" query-param="PRORROGA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTramitesNumMonitortramitesadmindepQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT T.COMPANIA, T.PROCESOS, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE PROCESO_NOM, T.DEPENDENCIA, D.NOMBRE DEPENDENCIA_NOM, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(U.NOMBRE1, ' '), U.NOMBRE2), ' '), U.APELLIDO1), ' '), U.APELLIDO2) RESPONSABLE_ACT , PT.DOCUMENTO TERCERO, PT.NOMBRE NOMBRE_TERCERO, TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY') FECHA_RADICADO, N.NOMBRE NODO_A_NOM, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA_PASE, TO_CHAR(PT.ESTIMADO_FECHA, 'DD/MM/YYYY') FECHA_LIMITE_ETAPA, /*TO_CHAR(MAX(PT2.ESTIMADO_FECHA), 'DD/MM/YYYY') */ TO_CHAR(PCK_SYSMAN_UTL.FC_FECHAFINALHABIL(UN_COMPANIA =&gt; T.COMPANIA, UN_FECHA =&gt; TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY'), UN_DIAS =&gt; CASE WHEN SUM(PT2.ESTIMADO_DIAS) = 0 THEN 1 ELSE SUM(PT2.ESTIMADO_DIAS) END ), 'DD/MM/YYYY') FECHA_LIMITE_PROCESO, PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') DURACION_D_HABIL, CASE WHEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') = TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) THEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) + 1 ELSE TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) END DURACION_D_CALENDARIO, CASE WHEN ROUND(PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') / PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA , TO_DATE(TO_CHAR(T.FECHA_REAL, 'dd/mm/yyyy'), 'dd/mm/yyyy'), MAX(TO_DATE(TO_CHAR(PT2.ESTIMADO_FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY' )), '0'), 2) &lt; 0.5 THEN '#00CC66' WHEN ROUND(PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') / PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA , TO_DATE(TO_CHAR(T.FECHA_REAL, 'dd/mm/yyyy'), 'dd/mm/yyyy'), MAX(TO_DATE(TO_CHAR(PT2.ESTIMADO_FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY' )), '0'), 2) &gt;= 0.50 AND ROUND(PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') / PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA , TO_DATE(TO_CHAR(T.FECHA_REAL, 'dd/mm/yyyy'), 'dd/mm/yyyy'), MAX(TO_DATE(TO_CHAR(PT2.ESTIMADO_FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')), '0'), 2) &lt; 0.8 THEN '#3399FF' WHEN ROUND(PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') / PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA , TO_DATE(TO_CHAR(T.FECHA_REAL, 'dd/mm/yyyy'), 'dd/mm/yyyy'), MAX(TO_DATE(TO_CHAR(PT2.ESTIMADO_FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY' )), '0'), 2) &gt;= 0.8 AND ROUND(PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') / PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA , TO_DATE(TO_CHAR(T.FECHA_REAL, 'dd/mm/yyyy'), 'dd/mm/yyyy'), MAX(TO_DATE(TO_CHAR(PT2.ESTIMADO_FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY')), '0'), 2) &lt; 1 THEN '#FFFF33' ELSE '#FF0000' END COLOR,(CASE N.PRORROGA WHEN 0 THEN 'false' ELSE 'true' END) PRORROGA FROM TRAMITES T INNER JOIN PROCESOS P ON P.COMPANIA = T.COMPANIA AND P.CODIGO = T.PROCESOS LEFT JOIN PROCEDENCIA_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.PROCEDENCIA = PT.CODIGO LEFT JOIN NODOS N ON T.COMPANIA = N.COMPANIA AND T.PROCESOS = N.CODIGO_PROCESO AND T.NODO_ACTUAL = N.CODIGO LEFT JOIN USUARIO U ON U.CODIGO = T.USUARIO_INTERNO LEFT JOIN DEPENDENCIA D ON T.COMPANIA = D.COMPANIA AND T.DEPENDENCIA = D.CODIGO INNER JOIN PROYECCIONES_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.TIPO_TRAMITE = PT.TIPO_TRAMITE AND T.PROCESOS = PT.PROCESO AND T.NUMERO = PT.TRAMITE AND T.NODO_ACTUAL = PT.NODO INNER JOIN PROYECCIONES_TRAMITE PT2 ON T.COMPANIA = PT2.COMPANIA AND T.TIPO_TRAMITE = PT2.TIPO_TRAMITE AND T.PROCESOS = PT2.PROCESO AND T.NUMERO = PT2.TRAMITE WHERE T.COMPANIA = :COMPANIA AND TO_CHAR(T.FECHA_REAL, 'YYYY') = :ANIO AND T.FECHA_REAL BETWEEN TO_DATE(:FECHAINI,'DD/MM/YYYY') AND TO_DATE(:FECHAFIN,'DD/MM/YYYY') AND P.MONITOR_ADMIN NOT IN ( 0 ) AND N.NODO_FINAL IN ( 0 ) AND T.DEPENDENCIA LIKE CONCAT(NVL(:DEPENDENCIA, '.'), '%') AND T.ESTADO = 4 GROUP BY T.PROCESOS, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE, T.DEPENDENCIA, D.NOMBRE, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(U.NOMBRE1, ' '), U.NOMBRE2), ' '), U.APELLIDO1), ' '), U.APELLIDO2), PT.DOCUMENTO, PT.NOMBRE, T.FECHA_REAL, N.NOMBRE, T.FECHA, PT.ESTIMADO_FECHA, T.COMPANIA, T.FECHA, N.PRORROGA ORDER BY T.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN DEPENDENCIA_NOM IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:DEPENDENCIA_NOM), '%')) AND (CASE WHEN RESPONSABLE_ACT IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_ACT) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE_ACT), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN FECHA_RADICADO IS NULL THEN ' ' ELSE UPPER(FECHA_RADICADO) END) LIKE UPPER(CONCAT(:FECHA_RADICADO, '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN FECHA_PASE IS NULL THEN ' ' ELSE UPPER(FECHA_PASE) END) LIKE UPPER(CONCAT(:FECHA_PASE, '%')) AND (CASE WHEN FECHA_LIMITE_ETAPA IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE_ETAPA) END) LIKE UPPER(CONCAT(:FECHA_LIMITE_ETAPA, '%')) AND (CASE WHEN FECHA_LIMITE_PROCESO IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE_PROCESO) END) LIKE UPPER(CONCAT(:FECHA_LIMITE_PROCESO, '%')) AND (CASE WHEN DURACION_D_HABIL IS NULL THEN ' ' ELSE UPPER(DURACION_D_HABIL) END) LIKE UPPER(CONCAT(:DURACION_D_HABIL, '%')) AND (CASE WHEN DURACION_D_CALENDARIO IS NULL THEN ' ' ELSE UPPER(DURACION_D_CALENDARIO) END) LIKE UPPER(CONCAT(:DURACION_D_CALENDARIO, '%')) AND (CASE WHEN COLOR IS NULL THEN ' ' ELSE UPPER(COLOR) END) LIKE UPPER(CONCAT(:COLOR, '%')) AND (CASE WHEN PRORROGA IS NULL THEN ' ' ELSE UPPER(PRORROGA) END) LIKE UPPER(CONCAT(:PRORROGA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="DEPENDENCIA_NOM" sqlType="STRING"/>
		<param name="RESPONSABLE_ACT" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="FECHA_RADICADO" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="FECHA_PASE" sqlType="STRING"/>
		<param name="FECHA_LIMITE_ETAPA" sqlType="STRING"/>
		<param name="FECHA_LIMITE_PROCESO" sqlType="STRING"/>
		<param name="DURACION_D_HABIL" sqlType="STRING"/>
		<param name="DURACION_D_CALENDARIO" sqlType="STRING"/>
		<param name="COLOR" sqlType="STRING"/>
		<param name="PRORROGA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/monitortramitesadmindep/num">
		<call-query href="getTramitesNumMonitortramitesadmindepQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PROCESO_NOM" query-param="PROCESO_NOM"/>
			<with-param name="DEPENDENCIA_NOM" query-param="DEPENDENCIA_NOM"/>
			<with-param name="RESPONSABLE_ACT" query-param="RESPONSABLE_ACT"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE_TERCERO" query-param="NOMBRE_TERCERO"/>
			<with-param name="FECHA_RADICADO" query-param="FECHA_RADICADO"/>
			<with-param name="NODO_A_NOM" query-param="NODO_A_NOM"/>
			<with-param name="FECHA_PASE" query-param="FECHA_PASE"/>
			<with-param name="FECHA_LIMITE_ETAPA" query-param="FECHA_LIMITE_ETAPA"/>
			<with-param name="FECHA_LIMITE_PROCESO" query-param="FECHA_LIMITE_PROCESO"/>
			<with-param name="DURACION_D_HABIL" query-param="DURACION_D_HABIL"/>
			<with-param name="DURACION_D_CALENDARIO" query-param="DURACION_D_CALENDARIO"/>
			<with-param name="COLOR" query-param="COLOR"/>
