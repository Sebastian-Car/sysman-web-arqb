	<query id="getTramitesNumNumdescfechanomestadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  T.NUMERO , T.DESCRIPCION , TO_CHAR(T.FECHA,'DD/MM/YYYY') FECHA , TI.NOMBRE ESTADO_NOM  FROM TRAMITES T INNER JOIN TIPOS TI ON T.ESTADO = TI.ID WHERE T.COMPANIA = :COMPANIA AND T.PROCESOS = :PROCESO AND T.TIPO_TRAMITE = :TIPO_TRAMITE) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END)  LIKE UPPER( '%' || :ESTADO_NOM || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
