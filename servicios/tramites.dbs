	</resource>
	<query id="insertTramites" keyColumns="COMPANIA,PROCESOS,TIPO_TRAMITE,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TRAMITES (COMPANIA, PROCESOS, TIPO_TRAMITE, NUMERO, USUARIO_INTERNO, USUARIO_EXTERNO, PROCEDENCIA, DESTINO, CIUDAD_ORIGEN, PAIS_ORIGEN, DEPARTAMENTO_ORIGEN, DIRECCION_PROCEDENCIA, DIRECCION_DESTINO, REFERENCIA, REFERENCIA1, TIPO_REFERENCIA, TIPO_REFERENCIA1, MODULO, DESCRIPCION, ESTADO, FECHA_REAL, HORA, FECHA, NODO_ORIGEN, NODO_ACTUAL, CODIGO_CALIDAD, SERIE_DOCUMENTAL, DESC_NODO_ACTUAL, CONTRATO_NUM, CANTIDAD_ANEXOS, CANTIDAD_OFICIOS, CLASE_ANEXOS, CORRESPONDENCIA, TIPO_MEDIO, TIPO_POBLACION, DEPENDENCIA, VULNERABILIDAD, OCUPACION, ESCOLARIDAD, RANGO_EDAD, TIPO_PERSONA, DESC_TIPO_POBLACION, DESC_OCUPACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :PROCESOS, :TIPO_TRAMITE, :NUMERO, :USUARIO_INTERNO, :USUARIO_EXTERNO, :PROCEDENCIA, :DESTINO, :CIUDAD_ORIGEN, :PAIS_ORIGEN, :DEPARTAMENTO_ORIGEN, :DIRECCION_PROCEDENCIA, :DIRECCION_DESTINO, :REFERENCIA, :REFERENCIA1, :TIPO_REFERENCIA, :TIPO_REFERENCIA1, :MODULO, :DESCRIPCION, :ESTADO, TO_DATE(:FECHA_REAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :NODO_ORIGEN, :NODO_ACTUAL, :CODIGO_CALIDAD, :SERIE_DOCUMENTAL, :DESC_NODO_ACTUAL, :CONTRATO_NUM, :CANTIDAD_ANEXOS, :CANTIDAD_OFICIOS, :CLASE_ANEXOS, :CORRESPONDENCIA, :TIPO_MEDIO, :TIPO_POBLACION, :DEPENDENCIA, :VULNERABILIDAD, :OCUPACION, :ESCOLARIDAD, :RANGO_EDAD, :TIPO_PERSONA, :DESC_TIPO_POBLACION, :DESC_OCUPACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROCESOS":"$PROCESOS","KEY_TIPO_TRAMITE":"$TIPO_TRAMITE","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESOS" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="USUARIO_INTERNO" sqlType="STRING"/>
		<param name="USUARIO_EXTERNO" sqlType="STRING"/>
		<param defaultValue="" name="PROCEDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="DESTINO" sqlType="STRING"/>
		<param name="CIUDAD_ORIGEN" sqlType="STRING"/>
		<param name="PAIS_ORIGEN" sqlType="STRING"/>
		<param name="DEPARTAMENTO_ORIGEN" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION_PROCEDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="DIRECCION_DESTINO" sqlType="STRING"/>
		<param defaultValue="" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="REFERENCIA1" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_REFERENCIA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_REFERENCIA1" sqlType="STRING"/>
		<param defaultValue="" name="MODULO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="4" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="SYSDATE" name="FECHA_REAL" sqlType="STRING"/>
		<param defaultValue="" name="HORA" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
