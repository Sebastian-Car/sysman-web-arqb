	<query id="getTramitesPagMonitortramites1Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT T.COMPANIA, T.PROCESOS, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE PROCESO_NOM, TT.NOMBRE TIPOTRAMITE_NOM, N_ORIGEN.NOMBRE NODO_O_NOM, N_ACTUAL.NOMBRE NODO_A_NOM, T.DESCRIPCION, TI.NOMBRE ESTADO_NOM, PT.DOCUMENTO TERCERO, PT.NOMBRE NOMBRE_TERCERO, TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY') FECHA_RADICADO, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, TO_CHAR(PCK_SYSMAN_UTL.FC_FECHAFINALHABIL(UN_COMPANIA =&gt; T.COMPANIA, UN_FECHA =&gt; TO_DATE(TO_CHAR(T.FECHA, 'DD/MM/YYYY'), 'DD/MM/YYYY' ), UN_DIAS =&gt; CASE WHEN SUM(PT1.ESTIMADO_DIAS) = 0 THEN 1 ELSE SUM(PT1.ESTIMADO_DIAS) END ), 'DD/MM/YYYY') FECHA_LIMITE_ESTIMADO, TO_CHAR(PCK_SYSMAN_UTL.FC_FECHAFINALHABIL(UN_COMPANIA =&gt; T.COMPANIA, UN_FECHA =&gt; TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY'), UN_DIAS =&gt; CASE WHEN SUM(PT1.ESTIMADO_DIAS) = 0 THEN 1 ELSE SUM(PT1.ESTIMADO_DIAS) END ), 'DD/MM/YYYY') FECHA_LIMITE, EXTRACT(DAY FROM(SYSDATE - T.FECHA)) AS DIAS_TRANSCURRIDOS, CASE WHEN N_ORIGEN.TIEMPO_MAXIMO = 0 AND ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) &lt; 0 THEN '#FF0000' WHEN N_ORIGEN.TIEMPO_MAXIMO = 0 AND ( EXTRACT(DAY FROM (SYSDATE - T.FECHA)) * 100 ) &gt;= 0 THEN '#00CC66' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &gt;= ( N_ORIGEN.TIEMPO_MAXIMO * 100 ) / N_ORIGEN .TIEMPO_MAXIMO THEN '#FF0000' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &lt; ( N_ORIGEN.TIEMPO_MAXIMO * 100 ) / N_ORIGEN .TIEMPO_MAXIMO AND ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &gt;= ( N_ORIGEN.TIEMPO_MAXIMO * 80) / N_ORIGEN .TIEMPO_MAXIMO THEN '#FFFF33' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &lt; ( N_ORIGEN.TIEMPO_MAXIMO * 80 ) / N_ORIGEN .TIEMPO_MAXIMO AND ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &gt;= ( N_ORIGEN.TIEMPO_MAXIMO * 50 ) / N_ORIGEN .TIEMPO_MAXIMO THEN '#3399FF' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &lt; ( N_ORIGEN.TIEMPO_MAXIMO * 50 ) / N_ORIGEN .TIEMPO_MAXIMO THEN '#00CC66' END COLOR, T.USUARIO_INTERNO, T.CONTRATO_NUM FROM TRAMITES T INNER JOIN PROCESOS P ON T.COMPANIA = P.COMPANIA AND T.PROCESOS = P.CODIGO LEFT JOIN PROCEDENCIA_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.PROCEDENCIA = PT.CODIGO INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE INNER JOIN NODOS N_ORIGEN ON T.COMPANIA = N_ORIGEN.COMPANIA AND T.PROCESOS = N_ORIGEN.CODIGO_PROCESO AND T.NODO_ORIGEN = N_ORIGEN.CODIGO INNER JOIN NODOS N_ACTUAL ON T.COMPANIA = N_ACTUAL.COMPANIA AND T.PROCESOS = N_ACTUAL.CODIGO_PROCESO AND T.NODO_ACTUAL = N_ACTUAL.CODIGO INNER JOIN TIPOS TI ON T.ESTADO = TI.ID INNER JOIN PROYECCIONES_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.PROCESOS = PT.PROCESO AND T.NODO_ACTUAL = PT.NODO AND T.NUMERO = PT.TRAMITE AND T.TIPO_TRAMITE = PT.TIPO_TRAMITE INNER JOIN PROYECCIONES_TRAMITE PT1 ON T.COMPANIA = PT1.COMPANIA AND T.TIPO_TRAMITE = PT1.TIPO_TRAMITE AND T.PROCESOS = PT1.PROCESO AND T.NUMERO = PT1.TRAMITE AND T.NODO_ACTUAL = PT1.NODO WHERE T.COMPANIA = :COMPANIA AND T.USUARIO_INTERNO = :USUARIO_INTERNO AND T.ESTADO = 4 GROUP BY T.COMPANIA, T.PROCESOS, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE, TT.NOMBRE, N_ORIGEN.NOMBRE, N_ACTUAL.NOMBRE, T.DESCRIPCION, TI.NOMBRE, PT.DOCUMENTO, PT.NOMBRE, TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), T.FECHA, EXTRACT(DAY FROM(SYSDATE - T.FECHA)), CASE WHEN N_ORIGEN.TIEMPO_MAXIMO = 0 AND ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) &lt; 0 THEN '#FF0000' WHEN N_ORIGEN.TIEMPO_MAXIMO = 0 AND ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) &gt;= 0 THEN '#00CC66' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &gt;= ( N_ORIGEN.TIEMPO_MAXIMO * 100 ) / N_ORIGEN .TIEMPO_MAXIMO THEN '#FF0000' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &lt; ( N_ORIGEN.TIEMPO_MAXIMO * 100 ) / N_ORIGEN .TIEMPO_MAXIMO AND ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &gt;= ( N_ORIGEN.TIEMPO_MAXIMO * 80 ) / N_ORIGEN.TIEMPO_MAXIMO THEN '#FFFF33' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &lt; ( N_ORIGEN.TIEMPO_MAXIMO * 80 ) / N_ORIGEN .TIEMPO_MAXIMO AND ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &gt;= ( N_ORIGEN.TIEMPO_MAXIMO * 50 ) / N_ORIGEN.TIEMPO_MAXIMO THEN '#3399FF' WHEN ( EXTRACT(DAY FROM(SYSDATE - T.FECHA)) * 100 ) / N_ORIGEN.TIEMPO_MAXIMO &lt; ( N_ORIGEN.TIEMPO_MAXIMO * 50 ) / N_ORIGEN .TIEMPO_MAXIMO THEN '#00CC66' END, T.USUARIO_INTERNO, T.CONTRATO_NUM, PT.ESTIMADO_FECHA ORDER BY T.NUMERO DESC) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN TIPOTRAMITE_NOM IS NULL THEN ' ' ELSE UPPER(TIPOTRAMITE_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOTRAMITE_NOM), '%')) AND (CASE WHEN NODO_O_NOM IS NULL THEN ' ' ELSE UPPER(NODO_O_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_O_NOM), '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO_NOM), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN FECHA_RADICADO IS NULL THEN ' ' ELSE UPPER(FECHA_RADICADO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_RADICADO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN FECHA_LIMITE_ESTIMADO IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE_ESTIMADO) END) LIKE UPPER(CONCAT(:FECHA_LIMITE_ESTIMADO, '%')) AND (CASE WHEN FECHA_LIMITE IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE) END) LIKE UPPER(CONCAT(:FECHA_LIMITE, '%')) AND (CASE WHEN DIAS_TRANSCURRIDOS IS NULL THEN ' ' ELSE UPPER(DIAS_TRANSCURRIDOS) END) LIKE UPPER(CONCAT(CONCAT('%',:DIAS_TRANSCURRIDOS), '%')) AND (CASE WHEN CONTRATO_NUM IS NULL THEN ' ' ELSE UPPER(CONTRATO_NUM) END) LIKE UPPER(CONCAT(CONCAT('%',:CONTRATO_NUM), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCESOS":"$PROCESOS","TIPO_TRAMITE":"$TIPO_TRAMITE","NUMERO":"$NUMERO(type:long)","PROCESO_NOM":"$PROCESO_NOM","TIPOTRAMITE_NOM":"$TIPOTRAMITE_NOM","NODO_O_NOM":"$NODO_O_NOM","NODO_A_NOM":"$NODO_A_NOM","DESCRIPCION":"$DESCRIPCION","ESTADO_NOM":"$ESTADO_NOM","TERCERO":"$TERCERO","NOMBRE_TERCERO":"$NOMBRE_TERCERO","FECHA_RADICADO":"$FECHA_RADICADO","FECHA":"$FECHA","FECHA_LIMITE_ESTIMADO":"$FECHA_LIMITE_ESTIMADO","FECHA_LIMITE":"$FECHA_LIMITE","DIAS_TRANSCURRIDOS":"$DIAS_TRANSCURRIDOS(type:integer)","COLOR":"$COLOR","USUARIO_INTERNO":"$USUARIO_INTERNO","CONTRATO_NUM":"$CONTRATO_NUM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="USUARIO_INTERNO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="TIPOTRAMITE_NOM" sqlType="STRING"/>
		<param name="NODO_O_NOM" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="FECHA_RADICADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="FECHA_LIMITE_ESTIMADO" sqlType="STRING"/>
		<param name="FECHA_LIMITE" sqlType="STRING"/>
		<param name="DIAS_TRANSCURRIDOS" sqlType="STRING"/>
		<param name="CONTRATO_NUM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
