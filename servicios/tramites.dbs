		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT TRAMITES.NUMERO, PROCESOS.NOMBRE PROCESO, NODO_O.NOMBRE ETAPA_O, NODO_A.NOMBRE ETAPA_A  FROM TRAMITES INNER JOIN PROCESOS ON PROCESOS.COMPANIA = TRAMITES.COMPANIA AND PROCESOS.CODIGO = TRAMITES.PROCESOS INNER JOIN NODOS NODO_O ON NODO_O.COMPANIA = TRAMITES.COMPANIA AND NODO_O.CODIGO_PROCESO = TRAMITES.PROCESOS AND NODO_O.CODIGO = TRAMITES.NODO_ORIGEN INNER JOIN NODOS NODO_A ON NODO_A.COMPANIA = TRAMITES.COMPANIA AND NODO_A.CODIGO_PROCESO = TRAMITES.PROCESOS AND NODO_A.CODIGO = TRAMITES.NODO_ORIGEN WHERE TRAMITES.COMPANIA = :COMPANIA ORDER BY TRAMITES.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN PROCESO IS NULL THEN ' ' ELSE UPPER(PROCESO) END)  LIKE UPPER( '%' || :PROCESO || '%')  AND (CASE WHEN ETAPA_O IS NULL THEN ' ' ELSE UPPER(ETAPA_O) END)  LIKE UPPER( '%' || :ETAPA_O || '%')  AND (CASE WHEN ETAPA_A IS NULL THEN ' ' ELSE UPPER(ETAPA_A) END)  LIKE UPPER( '%' || :ETAPA_A || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","PROCESO":"$PROCESO","ETAPA_O":"$ETAPA_O","ETAPA_A":"$ETAPA_A"}]}}		</result>
