	<query id="getTramitesNumTramites/tramitesprocedenciafechaini/pagQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PROCESOS.CODIGO, PROCESOS.NOMBRE FROM TRAMITES INNER JOIN DEPENDENCIA ON TRAMITES.COMPANIA = DEPENDENCIA.COMPANIA AND TRAMITES.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN TIPOTRAMITES ON TRAMITES.COMPANIA = TIPOTRAMITES.COMPANIA AND TRAMITES.PROCESOS = TIPOTRAMITES.PROCESOS AND TRAMITES.TIPO_TRAMITE = TIPOTRAMITES.TIPOTRAMITE INNER JOIN PROCESOS ON TIPOTRAMITES.COMPANIA = PROCESOS.COMPANIA AND TIPOTRAMITES.PROCESOS = PROCESOS.CODIGO WHERE DEPENDENCIA.COMPANIA = :COMPANIA AND GESTION_DOCUMENTAL NOT IN (0) AND NUMERACION_UNICA NOT IN (0) AND FECHA_REAL BETWEEN :FECHAINICIAL AND :FECHAFINAL and DEPENDENCIA.CODIGO BETWEEN :DEPENDENCIAINICIAL AND :DEPENDENCIAFINAL ORDER BY DEPENDENCIA.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
