	<query id="getTramitesPagTramitesconmenuasigQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  T.NUMERO , T.DESCRIPCION , TO_CHAR(T.FECHA,'DD/MM/YYYY') FECHA , TI.NOMBRE ESTADO_NOM , DT.CONSECUTIVO DETALLE, T.NODO_ACTUAL  FROM TRAMITES T INNER JOIN TIPOS TI ON T.ESTADO = TI.ID INNER JOIN D_TRAMITES DT ON T.COMPANIA = DT.COMPANIA AND T.TIPO_TRAMITE = DT.TIPO_TRAMITE AND T.PROCESOS = DT.PROCESOS AND T.NUMERO = DT.NUMERO WHERE T.COMPANIA = :COMPANIA AND T.PROCESOS = :PROCESO AND T.TIPO_TRAMITE = :TIPO_TRAMITE AND DT.ESTADO IN(:ESTADO) AND DT.MENU IS NOT NULL AND T.USUARIO_INTERNO IN(:USUARIO)) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END)  LIKE UPPER( '%' || :ESTADO_NOM || '%')  AND (CASE WHEN DETALLE IS NULL THEN ' ' ELSE UPPER(DETALLE) END)  LIKE UPPER(:DETALLE || '%')  AND (CASE WHEN NODO_ACTUAL IS NULL THEN ' ' ELSE UPPER(NODO_ACTUAL) END)  LIKE UPPER(:NODO_ACTUAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)","DESCRIPCION":"$DESCRIPCION","FECHA":"$FECHA","ESTADO_NOM":"$ESTADO_NOM","DETALLE":"$DETALLE(type:long)","NODO_ACTUAL":"$NODO_ACTUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="DETALLE" sqlType="STRING"/>
		<param name="NODO_ACTUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
