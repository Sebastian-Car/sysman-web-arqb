	<query id="getTramitesTodosporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TRAMITES.NUMERO  FROM TRAMITES WHERE TRAMITES.COMPANIA = :COMPANIA AND TRAMITES.NUMERO &gt;= :NUMERO ORDER BY TRAMITES.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/todosporcompania">
		<call-query href="getTramitesTodosporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getTramitesGenerarutasQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT('TRAMITE',' - '),T.NUMERO),'/'),TT.PROCESOS),' - '),P.NOMBRE),'/'),T.NODO_ORIGEN), ' - '),N.NOMBRE) AS RUTAS FROM TRAMITES T INNER JOIN TIPOTRAMITES TT ON TT.COMPANIA = T.COMPANIA AND TT.PROCESOS = T.PROCESOS AND TT.TIPOTRAMITE = T.TIPO_TRAMITE INNER JOIN PROCESOS P ON P.COMPANIA = T.COMPANIA AND P.CODIGO = T.PROCESOS INNER JOIN NODOS N ON N.COMPANIA = T.COMPANIA AND N.CODIGO_PROCESO = T.PROCESOS AND N.CODIGO = T.NODO_ORIGEN WHERE T.COMPANIA = :COMPANIA AND NUMERO = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUTAS":"$RUTAS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/generarutas">
		<call-query href="getTramitesGenerarutasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getTramitesCantidadtramitesQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT COUNT(TRAMITES.NUMERO) CANTIDAD FROM TRAMITES INNER JOIN ( SELECT DISTINCT D_TRAMITES.COMPANIA, D_TRAMITES.PROCESOS, D_TRAMITES.TIPO_TRAMITE, D_TRAMITES.NUMERO TRAMITE FROM D_TRAMITES ) RS ON TRAMITES.COMPANIA = RS.COMPANIA AND TRAMITES.PROCESOS = RS.PROCESOS AND TRAMITES.TIPO_TRAMITE = RS.TIPO_TRAMITE AND TRAMITES.NUMERO = RS.TRAMITE INNER JOIN ( SELECT DISTINCT COMPANIA, CODIGO_PROCESO, TIPO_TRAMITE, NUMERO_TRAMITE, CODIGO_NODO FROM D_TRAMITE_VARIABLES) DTV ON RS.COMPANIA = DTV.COMPANIA AND RS.PROCESOS = DTV.CODIGO_PROCESO AND RS.TIPO_TRAMITE = DTV.TIPO_TRAMITE AND RS.TRAMITE = DTV.NUMERO_TRAMITE WHERE TRAMITES.COMPANIA = :COMPANIA AND TRAMITES.PROCESOS = :PROCESO AND DTV.CODIGO_NODO = :ETAPA AND TRAMITES.NUMERO BETWEEN :TRAMITEINI AND :TRAMITEFIN AND TRAMITES.USUARIO_INTERNO = :USUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANTIDAD":"$CANTIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ETAPA" sqlType="STRING"/>
		<param name="TRAMITEINI" sqlType="STRING"/>
		<param name="TRAMITEFIN" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/cantidadtramites">
		<call-query href="getTramitesCantidadtramitesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ETAPA" query-param="ETAPA"/>
			<with-param name="TRAMITEINI" query-param="TRAMITEINI"/>
			<with-param name="TRAMITEFIN" query-param="TRAMITEFIN"/>
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="getTramitesNumerodetramitesQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT TRAMITES.NUMERO FROM TRAMITES INNER JOIN D_TRAMITES DT ON TRAMITES.COMPANIA = DT.COMPANIA AND TRAMITES.PROCESOS = DT.PROCESOS AND TRAMITES.TIPO_TRAMITE = DT.TIPO_TRAMITE AND TRAMITES.NUMERO = DT.NUMERO INNER JOIN D_TRAMITE_VARIABLES DTV ON DT.COMPANIA = DTV.COMPANIA AND DT.PROCESOS = DTV.CODIGO_PROCESO AND DT.TIPO_TRAMITE = DTV.TIPO_TRAMITE AND DT.CONSECUTIVO = DTV.CONSECUTIVO_TRAMITE AND DT.NUMERO = DTV.NUMERO_TRAMITE WHERE TRAMITES.COMPANIA = :COMPANIA AND TRAMITES.PROCESOS = :PROCESO AND DTV.CODIGO_NODO = :ETAPA AND TRAMITES.NUMERO BETWEEN :TRAMITEINI AND :TRAMITEFIN AND TRAMITES.USUARIO_INTERNO = :USUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ETAPA" sqlType="STRING"/>
		<param name="TRAMITEINI" sqlType="STRING"/>
		<param name="TRAMITEFIN" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/numerodetramites">
		<call-query href="getTramitesNumerodetramitesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="ETAPA" query-param="ETAPA"/>
			<with-param name="TRAMITEINI" query-param="TRAMITEINI"/>
			<with-param name="TRAMITEFIN" query-param="TRAMITEFIN"/>
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="getTramitesPagTramitepornivelusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT T.COMPANIA, T.PROCESOS, P.NOMBRE PROCESO_NOM, T.TIPO_TRAMITE, TT.NOMBRE TIPOTRAMITE_NOM, T.NUMERO, N_ORIGEN.NOMBRE NODO_O_NOM, N_ACTUAL.NOMBRE NODO_A_NOM, T.ESTADO, TI.NOMBRE ESTADO_NOM, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, ( SELECT NOMBRE FROM TIPOS WHERE ID = CASE WHEN :USUARIO_INTERNO IN ( SELECT RU.USUARIO FROM NODO_RACI NR INNER JOIN ROL_USUARIO RU ON NR.COMPANIA = RU.COMPANIA AND NR.CODIGO_ROL = RU.CODIGO_ROL WHERE NR.COMPANIA = T.COMPANIA AND NR.CODIGO_PROCESO = T.PROCESOS AND NR.CODIGO_NODO = T.NODO_ACTUAL AND NR.CODIGO_RACI = 9 ) THEN 9 ELSE 10 END ) RACI_NOM, T.CONTRATO_NUM FROM TRAMITES T INNER JOIN PROCESOS P ON T.COMPANIA = P.COMPANIA AND T.PROCESOS = P.CODIGO INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE INNER JOIN NODOS N_ORIGEN ON T.COMPANIA = N_ORIGEN.COMPANIA AND T.PROCESOS = N_ORIGEN.CODIGO_PROCESO AND T.NODO_ORIGEN = N_ORIGEN.CODIGO INNER JOIN NODOS N_ACTUAL ON T.COMPANIA = N_ACTUAL.COMPANIA AND T.PROCESOS = N_ACTUAL.CODIGO_PROCESO AND T.NODO_ACTUAL = N_ACTUAL.CODIGO INNER JOIN TIPOS TI ON T.ESTADO = TI.ID WHERE T.COMPANIA = :COMPANIA AND T.ESTADO = :ESTADO ORDER BY T.NUMERO DESC) INI WHERE (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN TIPOTRAMITE_NOM IS NULL THEN ' ' ELSE UPPER(TIPOTRAMITE_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOTRAMITE_NOM), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NODO_O_NOM IS NULL THEN ' ' ELSE UPPER(NODO_O_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_O_NOM), '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO_NOM), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN RACI_NOM IS NULL THEN ' ' ELSE UPPER(RACI_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:RACI_NOM), '%')) AND (CASE WHEN CONTRATO_NUM IS NULL THEN ' ' ELSE UPPER(CONTRATO_NUM) END) LIKE UPPER(CONCAT(:CONTRATO_NUM, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCESOS":"$PROCESOS","PROCESO_NOM":"$PROCESO_NOM","TIPO_TRAMITE":"$TIPO_TRAMITE","TIPOTRAMITE_NOM":"$TIPOTRAMITE_NOM","NUMERO":"$NUMERO(type:long)","NODO_O_NOM":"$NODO_O_NOM","NODO_A_NOM":"$NODO_A_NOM","ESTADO":"$ESTADO(type:integer)","ESTADO_NOM":"$ESTADO_NOM","FECHA":"$FECHA","RACI_NOM":"$RACI_NOM","CONTRATO_NUM":"$CONTRATO_NUM"}]}}		</result>
		<param name="USUARIO_INTERNO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="TIPOTRAMITE_NOM" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NODO_O_NOM" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RACI_NOM" sqlType="STRING"/>
		<param name="CONTRATO_NUM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tramites/tramitepornivelusuario/pag">
