		</call-query>
	</resource>
	<query id="getTramitesPagMonitortramitesadminQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, PROCESOS, NOM_TIPO_TRAMITE, TIPO_TRAMITE, NUMERO, PROCESO_NOM, DEPENDENCIA, DEPENDENCIA_NOM, RESPONSABLE_ACT, TERCERO, NOMBRE_TERCERO, FECHA_RADICADO, NODO_A_NOM, FECHA_PASE, CASE WHEN PRORROGA IN ( 0 ) THEN FECHA_LIMITE_ETAPA ELSE '' END FECHA_LIMITE_ETAPA, CASE WHEN PRORROGA IN ( 0 ) THEN FECHA_LIMITE_PROCESO ELSE '' END FECHA_LIMITE_PROCESO, DURACION_D_HABIL, DURACION_D_CALENDARIO, CASE WHEN PRORROGA IN ( 0 ) THEN PCK_WORKFLOW.FC_CALCULAR_COLOR(COMPANIA, FECHA_RADICADO, FECHA_LIMITE_PROCESO) ELSE '' END COLOR, CASE WHEN PRORROGA IN ( 0 ) THEN CASE WHEN FECHA_LIMITE_PROCESO &lt; SYSDATE THEN CONCAT('-', PCK_SYSMAN_UTL.FC_DIASHABIL(COMPANIA, FECHA_LIMITE_PROCESO, SYSDATE, 0)) ELSE CONCAT('+', PCK_SYSMAN_UTL.FC_DIASHABIL(COMPANIA, SYSDATE, FECHA_LIMITE_PROCESO, 0)) END ELSE '' END DIAS_VENCER,(CASE PRORROGA WHEN 0 THEN 'false' ELSE 'true' END) PRORROGA, CASE WHEN PRORROGA NOT IN (0) THEN PCK_SYSMAN_UTL.FC_DIASHABIL(COMPANIA, FECHA_PRORROGA, SYSDATE, 0) ELSE DIAS_PRORROGA END DIAS_PRORROGA,(TO_CHAR(FECHA_PRORROGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_PRORROGA FROM ( SELECT T.COMPANIA, T.PROCESOS, TT.NOMBRE NOM_TIPO_TRAMITE, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE PROCESO_NOM, T.DEPENDENCIA, D.NOMBRE DEPENDENCIA_NOM, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(U.NOMBRE1, ' '), U.NOMBRE2), ' '), U.APELLIDO1), ' '), U.APELLIDO2) RESPONSABLE_ACT , PT.DOCUMENTO TERCERO, PT.NOMBRE NOMBRE_TERCERO, TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY') FECHA_RADICADO, N.NOMBRE NODO_A_NOM, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA_PASE, TO_CHAR(PCK_SYSMAN_UTL.FC_FECHAFINALHABIL(UN_COMPANIA =&gt; T.COMPANIA, UN_FECHA =&gt; TO_DATE(TO_CHAR(T.FECHA, 'DD/MM/YYYY' ), 'DD/MM/YYYY'), UN_DIAS =&gt; (CASE WHEN SUM(PT1.ESTIMADO_DIAS) = 0 THEN 1 ELSE SUM(PT1.ESTIMADO_DIAS) END) + T.DIAS_PRORROGA ), 'DD/MM/YYYY') FECHA_LIMITE_ETAPA, TO_CHAR(PCK_SYSMAN_UTL.FC_FECHAFINALHABIL(UN_COMPANIA =&gt; T.COMPANIA, UN_FECHA =&gt; TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY' ), 'DD/MM/YYYY'), UN_DIAS =&gt; (CASE WHEN SUM(N_DIAS.TIEMPO_ESTIMADO) = 0 THEN 1 ELSE SUM(N_DIAS.TIEMPO_ESTIMADO) END) + T.DIAS_PRORROGA ), 'DD/MM/YYYY') FECHA_LIMITE_PROCESO, PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') DURACION_D_HABIL, CASE WHEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') = TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) THEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) + 1 ELSE TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) END DURACION_D_CALENDARIO, N.PRORROGA, T.FECHA_PRORROGA, T.DIAS_PRORROGA FROM TRAMITES T INNER JOIN PROCESOS P ON P.COMPANIA = T.COMPANIA AND P.CODIGO = T.PROCESOS LEFT JOIN PROCEDENCIA_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.PROCEDENCIA = PT.CODIGO INNER JOIN NODOS N ON T.COMPANIA = N.COMPANIA AND T.PROCESOS = N.CODIGO_PROCESO AND T.NODO_ACTUAL = N.CODIGO LEFT JOIN USUARIO U ON U.CODIGO = T.USUARIO_INTERNO LEFT JOIN DEPENDENCIA D ON T.COMPANIA = D.COMPANIA AND SUBSTR(T.DEPENDENCIA, 0, PCK_SYSMAN_UTL.FC_PAR(:COMPANIA, 'LONGITUD PREDECESOR DEPENDENCIAS ALMACEN' , 35, SYSDATE)) = D.CODIGO INNER JOIN PROYECCIONES_TRAMITE PT1 ON T.COMPANIA = PT1.COMPANIA AND T.TIPO_TRAMITE = PT1.TIPO_TRAMITE AND T.PROCESOS = PT1.PROCESO AND T.NUMERO = PT1.TRAMITE AND T.NODO_ACTUAL = PT1.NODO INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE INNER JOIN ( SELECT NODOS.COMPANIA, NODOS.CODIGO_PROCESO, SUM(TIEMPO_ESTIMADO) AS TIEMPO_ESTIMADO FROM NODOS INNER JOIN PROCESOS ON NODOS.COMPANIA = PROCESOS.COMPANIA AND NODOS.CODIGO_PROCESO = PROCESOS.CODIGO GROUP BY NODOS.COMPANIA, CODIGO_PROCESO ) N_DIAS ON T.COMPANIA = N_DIAS.COMPANIA AND T.PROCESOS = N_DIAS.CODIGO_PROCESO WHERE T.COMPANIA = :COMPANIA AND TO_CHAR(T.FECHA_REAL, 'YYYY') = :ANIO AND T.FECHA_REAL BETWEEN TO_DATE(:FECHAINI,'DD/MM/YYYY') AND TO_DATE(:FECHAFIN,'DD/MM/YYYY') AND P.MONITOR_ADMIN NOT IN ( 0 ) AND N.NODO_FINAL IN ( 0 ) AND T.ESTADO = 4 GROUP BY T.COMPANIA, T.PROCESOS, TT.NOMBRE, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE, T.DEPENDENCIA, D.NOMBRE, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(U.NOMBRE1, ' '), U.NOMBRE2), ' '), U.APELLIDO1), ' ' ), U.APELLIDO2), PT.DOCUMENTO, PT.NOMBRE, T.FECHA_REAL, N.NOMBRE, T.FECHA, CASE WHEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') = TO_DATE(TO_CHAR(T.FECHA_REAL , 'DD/MM/YYYY'), 'DD/MM/YYYY') THEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL , 'DD/MM/YYYY'), 'DD/MM/YYYY') + 1 ELSE TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL , 'DD/MM/YYYY'), 'DD/MM/YYYY') END, N.PRORROGA, T.FECHA_PRORROGA, T.DIAS_PRORROGA ORDER BY T.NUMERO ) CONS) INI WHERE (CASE WHEN NOM_TIPO_TRAMITE IS NULL THEN ' ' ELSE UPPER(NOM_TIPO_TRAMITE) END) LIKE UPPER(CONCAT(:NOM_TIPO_TRAMITE, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN DEPENDENCIA_NOM IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA_NOM) END) LIKE UPPER(CONCAT(:DEPENDENCIA_NOM, '%')) AND (CASE WHEN RESPONSABLE_ACT IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_ACT) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE_ACT), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN FECHA_RADICADO IS NULL THEN ' ' ELSE UPPER(FECHA_RADICADO) END) LIKE UPPER(CONCAT(:FECHA_RADICADO, '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN FECHA_PASE IS NULL THEN ' ' ELSE UPPER(FECHA_PASE) END) LIKE UPPER(CONCAT(:FECHA_PASE, '%')) AND (CASE WHEN FECHA_LIMITE_ETAPA IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE_ETAPA) END) LIKE UPPER(CONCAT(:FECHA_LIMITE_ETAPA, '%')) AND (CASE WHEN FECHA_PRORROGA IS NULL THEN ' ' ELSE UPPER(FECHA_PRORROGA) END) LIKE UPPER(CONCAT(:FECHA_PRORROGA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCESOS":"$PROCESOS","NOM_TIPO_TRAMITE":"$NOM_TIPO_TRAMITE","TIPO_TRAMITE":"$TIPO_TRAMITE","NUMERO":"$NUMERO(type:long)","PROCESO_NOM":"$PROCESO_NOM","DEPENDENCIA":"$DEPENDENCIA","DEPENDENCIA_NOM":"$DEPENDENCIA_NOM","RESPONSABLE_ACT":"$RESPONSABLE_ACT","TERCERO":"$TERCERO","NOMBRE_TERCERO":"$NOMBRE_TERCERO","FECHA_RADICADO":"$FECHA_RADICADO","NODO_A_NOM":"$NODO_A_NOM","FECHA_PASE":"$FECHA_PASE","FECHA_LIMITE_ETAPA":"$FECHA_LIMITE_ETAPA","FECHA_LIMITE_PROCESO":"$FECHA_LIMITE_PROCESO","DURACION_D_HABIL":"$DURACION_D_HABIL(type:integer)","DURACION_D_CALENDARIO":"$DURACION_D_CALENDARIO(type:integer)","COLOR":"$COLOR","DIAS_VENCER":"$DIAS_VENCER","PRORROGA":"$PRORROGA(type:boolean)","DIAS_PRORROGA":"$DIAS_PRORROGA(type:integer)","FECHA_PRORROGA":"$FECHA_PRORROGA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="NOM_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="DEPENDENCIA_NOM" sqlType="STRING"/>
		<param name="RESPONSABLE_ACT" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="FECHA_RADICADO" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="FECHA_PASE" sqlType="STRING"/>
		<param name="FECHA_LIMITE_ETAPA" sqlType="STRING"/>
		<param name="FECHA_PRORROGA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tramites/monitortramitesadmin/pag">
		<call-query href="getTramitesPagMonitortramitesadminQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="FECHAINI" query-param="FECHAINI"/>
			<with-param name="FECHAFIN" query-param="FECHAFIN"/>
			<with-param name="NOM_TIPO_TRAMITE" query-param="NOM_TIPO_TRAMITE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PROCESO_NOM" query-param="PROCESO_NOM"/>
			<with-param name="DEPENDENCIA_NOM" query-param="DEPENDENCIA_NOM"/>
			<with-param name="RESPONSABLE_ACT" query-param="RESPONSABLE_ACT"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRE_TERCERO" query-param="NOMBRE_TERCERO"/>
			<with-param name="FECHA_RADICADO" query-param="FECHA_RADICADO"/>
			<with-param name="NODO_A_NOM" query-param="NODO_A_NOM"/>
			<with-param name="FECHA_PASE" query-param="FECHA_PASE"/>
			<with-param name="FECHA_LIMITE_ETAPA" query-param="FECHA_LIMITE_ETAPA"/>
			<with-param name="FECHA_PRORROGA" query-param="FECHA_PRORROGA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTramitesNumMonitortramitesadminQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, PROCESOS, NOM_TIPO_TRAMITE, TIPO_TRAMITE, NUMERO, PROCESO_NOM, DEPENDENCIA, DEPENDENCIA_NOM, RESPONSABLE_ACT, TERCERO, NOMBRE_TERCERO, FECHA_RADICADO, NODO_A_NOM, FECHA_PASE, CASE WHEN PRORROGA IN ( 0 ) THEN FECHA_LIMITE_ETAPA ELSE '' END FECHA_LIMITE_ETAPA, CASE WHEN PRORROGA IN ( 0 ) THEN FECHA_LIMITE_PROCESO ELSE '' END FECHA_LIMITE_PROCESO, DURACION_D_HABIL, DURACION_D_CALENDARIO, CASE WHEN PRORROGA IN ( 0 ) THEN PCK_WORKFLOW.FC_CALCULAR_COLOR(COMPANIA, FECHA_RADICADO, FECHA_LIMITE_PROCESO) ELSE '' END COLOR, CASE WHEN PRORROGA IN ( 0 ) THEN CASE WHEN FECHA_LIMITE_PROCESO &lt; SYSDATE THEN CONCAT('-', PCK_SYSMAN_UTL.FC_DIASHABIL(COMPANIA, FECHA_LIMITE_PROCESO, SYSDATE, 0)) ELSE CONCAT('+', PCK_SYSMAN_UTL.FC_DIASHABIL(COMPANIA, SYSDATE, FECHA_LIMITE_PROCESO, 0)) END ELSE '' END DIAS_VENCER,(CASE PRORROGA WHEN 0 THEN 'false' ELSE 'true' END) PRORROGA, CASE WHEN PRORROGA NOT IN (0) THEN PCK_SYSMAN_UTL.FC_DIASHABIL(COMPANIA, FECHA_PRORROGA, SYSDATE, 0) ELSE DIAS_PRORROGA END DIAS_PRORROGA,(TO_CHAR(FECHA_PRORROGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_PRORROGA FROM ( SELECT T.COMPANIA, T.PROCESOS, TT.NOMBRE NOM_TIPO_TRAMITE, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE PROCESO_NOM, T.DEPENDENCIA, D.NOMBRE DEPENDENCIA_NOM, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(U.NOMBRE1, ' '), U.NOMBRE2), ' '), U.APELLIDO1), ' '), U.APELLIDO2) RESPONSABLE_ACT , PT.DOCUMENTO TERCERO, PT.NOMBRE NOMBRE_TERCERO, TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY') FECHA_RADICADO, N.NOMBRE NODO_A_NOM, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA_PASE, TO_CHAR(PCK_SYSMAN_UTL.FC_FECHAFINALHABIL(UN_COMPANIA =&gt; T.COMPANIA, UN_FECHA =&gt; TO_DATE(TO_CHAR(T.FECHA, 'DD/MM/YYYY' ), 'DD/MM/YYYY'), UN_DIAS =&gt; (CASE WHEN SUM(PT1.ESTIMADO_DIAS) = 0 THEN 1 ELSE SUM(PT1.ESTIMADO_DIAS) END) + T.DIAS_PRORROGA ), 'DD/MM/YYYY') FECHA_LIMITE_ETAPA, TO_CHAR(PCK_SYSMAN_UTL.FC_FECHAFINALHABIL(UN_COMPANIA =&gt; T.COMPANIA, UN_FECHA =&gt; TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY' ), 'DD/MM/YYYY'), UN_DIAS =&gt; (CASE WHEN SUM(N_DIAS.TIEMPO_ESTIMADO) = 0 THEN 1 ELSE SUM(N_DIAS.TIEMPO_ESTIMADO) END) + T.DIAS_PRORROGA ), 'DD/MM/YYYY') FECHA_LIMITE_PROCESO, PCK_SYSMAN_UTL.FC_DIASHABIL(T.COMPANIA, T.FECHA_REAL, CURRENT_DATE, '0') DURACION_D_HABIL, CASE WHEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') = TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) THEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) + 1 ELSE TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL, 'DD/MM/YYYY'), 'DD/MM/YYYY' ) END DURACION_D_CALENDARIO, N.PRORROGA, T.FECHA_PRORROGA, T.DIAS_PRORROGA FROM TRAMITES T INNER JOIN PROCESOS P ON P.COMPANIA = T.COMPANIA AND P.CODIGO = T.PROCESOS LEFT JOIN PROCEDENCIA_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.PROCEDENCIA = PT.CODIGO INNER JOIN NODOS N ON T.COMPANIA = N.COMPANIA AND T.PROCESOS = N.CODIGO_PROCESO AND T.NODO_ACTUAL = N.CODIGO LEFT JOIN USUARIO U ON U.CODIGO = T.USUARIO_INTERNO LEFT JOIN DEPENDENCIA D ON T.COMPANIA = D.COMPANIA AND SUBSTR(T.DEPENDENCIA, 0, PCK_SYSMAN_UTL.FC_PAR(:COMPANIA, 'LONGITUD PREDECESOR DEPENDENCIAS ALMACEN' , 35, SYSDATE)) = D.CODIGO INNER JOIN PROYECCIONES_TRAMITE PT1 ON T.COMPANIA = PT1.COMPANIA AND T.TIPO_TRAMITE = PT1.TIPO_TRAMITE AND T.PROCESOS = PT1.PROCESO AND T.NUMERO = PT1.TRAMITE AND T.NODO_ACTUAL = PT1.NODO INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE INNER JOIN ( SELECT NODOS.COMPANIA, NODOS.CODIGO_PROCESO, SUM(TIEMPO_ESTIMADO) AS TIEMPO_ESTIMADO FROM NODOS INNER JOIN PROCESOS ON NODOS.COMPANIA = PROCESOS.COMPANIA AND NODOS.CODIGO_PROCESO = PROCESOS.CODIGO GROUP BY NODOS.COMPANIA, CODIGO_PROCESO ) N_DIAS ON T.COMPANIA = N_DIAS.COMPANIA AND T.PROCESOS = N_DIAS.CODIGO_PROCESO WHERE T.COMPANIA = :COMPANIA AND TO_CHAR(T.FECHA_REAL, 'YYYY') = :ANIO AND T.FECHA_REAL BETWEEN TO_DATE(:FECHAINI,'DD/MM/YYYY') AND TO_DATE(:FECHAFIN,'DD/MM/YYYY') AND P.MONITOR_ADMIN NOT IN ( 0 ) AND N.NODO_FINAL IN ( 0 ) AND T.ESTADO = 4 GROUP BY T.COMPANIA, T.PROCESOS, TT.NOMBRE, T.TIPO_TRAMITE, T.NUMERO, P.NOMBRE, T.DEPENDENCIA, D.NOMBRE, CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(U.NOMBRE1, ' '), U.NOMBRE2), ' '), U.APELLIDO1), ' ' ), U.APELLIDO2), PT.DOCUMENTO, PT.NOMBRE, T.FECHA_REAL, N.NOMBRE, T.FECHA, CASE WHEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') = TO_DATE(TO_CHAR(T.FECHA_REAL , 'DD/MM/YYYY'), 'DD/MM/YYYY') THEN TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL , 'DD/MM/YYYY'), 'DD/MM/YYYY') + 1 ELSE TO_DATE(TO_CHAR(CURRENT_DATE, 'DD/MM/YYYY'), 'DD/MM/YYYY') - TO_DATE(TO_CHAR(T.FECHA_REAL , 'DD/MM/YYYY'), 'DD/MM/YYYY') END, N.PRORROGA, T.FECHA_PRORROGA, T.DIAS_PRORROGA ORDER BY T.NUMERO ) CONS) INI WHERE (CASE WHEN NOM_TIPO_TRAMITE IS NULL THEN ' ' ELSE UPPER(NOM_TIPO_TRAMITE) END) LIKE UPPER(CONCAT(:NOM_TIPO_TRAMITE, '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN DEPENDENCIA_NOM IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA_NOM) END) LIKE UPPER(CONCAT(:DEPENDENCIA_NOM, '%')) AND (CASE WHEN RESPONSABLE_ACT IS NULL THEN ' ' ELSE UPPER(RESPONSABLE_ACT) END) LIKE UPPER(CONCAT(CONCAT('%',:RESPONSABLE_ACT), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRE_TERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TERCERO), '%')) AND (CASE WHEN FECHA_RADICADO IS NULL THEN ' ' ELSE UPPER(FECHA_RADICADO) END) LIKE UPPER(CONCAT(:FECHA_RADICADO, '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN FECHA_PASE IS NULL THEN ' ' ELSE UPPER(FECHA_PASE) END) LIKE UPPER(CONCAT(:FECHA_PASE, '%')) AND (CASE WHEN FECHA_LIMITE_ETAPA IS NULL THEN ' ' ELSE UPPER(FECHA_LIMITE_ETAPA) END) LIKE UPPER(CONCAT(:FECHA_LIMITE_ETAPA, '%')) AND (CASE WHEN FECHA_PRORROGA IS NULL THEN ' ' ELSE UPPER(FECHA_PRORROGA) END) LIKE UPPER(CONCAT(:FECHA_PRORROGA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="FECHAINI" sqlType="STRING"/>
		<param name="FECHAFIN" sqlType="STRING"/>
		<param name="NOM_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="DEPENDENCIA_NOM" sqlType="STRING"/>
		<param name="RESPONSABLE_ACT" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRE_TERCERO" sqlType="STRING"/>
		<param name="FECHA_RADICADO" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="FECHA_PASE" sqlType="STRING"/>
		<param name="FECHA_LIMITE_ETAPA" sqlType="STRING"/>
		<param name="FECHA_PRORROGA" sqlType="STRING"/>

	</query>
