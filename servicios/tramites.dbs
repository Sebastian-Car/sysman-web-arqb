			<with-param name="OCUPACION" query-param="OCUPACION"/>
			<with-param name="ESCOLARIDAD" query-param="ESCOLARIDAD"/>
			<with-param name="RANGO_EDAD" query-param="RANGO_EDAD"/>
			<with-param name="TIPO_PERSONA" query-param="TIPO_PERSONA"/>
			<with-param name="DESC_TIPO_POBLACION" query-param="DESC_TIPO_POBLACION"/>
			<with-param name="DESC_OCUPACION" query-param="DESC_OCUPACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTramites" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TRAMITES WHERE TRAMITES.COMPANIA= :KEY_COMPANIA AND TRAMITES.PROCESOS= :KEY_PROCESOS AND TRAMITES.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND TRAMITES.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCESOS" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tramites">
		<call-query href="deleteTramites">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCESOS" query-param="KEY_PROCESOS"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
<query id="getTramitesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT T.COMPANIA, T.PROCESOS, P.NOMBRE PROCESO_NOM, T.TIPO_TRAMITE, TT.NOMBRE TIPOTRAMITE_NOM, T.NUMERO, N_ORIGEN.NOMBRE NODO_O_NOM, N_ACTUAL.NOMBRE NODO_A_NOM, T.ESTADO, TI.NOMBRE ESTADO_NOM, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, ( SELECT NOMBRE FROM TIPOS WHERE ID = CASE WHEN :USUARIO_INTERNO IN ( SELECT RU.USUARIO FROM NODO_RACI NR INNER JOIN ROL_USUARIO RU ON NR.COMPANIA = RU.COMPANIA AND NR.CODIGO_ROL = RU.CODIGO_ROL WHERE NR.COMPANIA = T.COMPANIA AND NR.CODIGO_PROCESO = T.PROCESOS AND NR.CODIGO_NODO = T.NODO_ACTUAL AND NR.CODIGO_RACI = 9 ) THEN 9 ELSE 10 END ) RACI_NOM, T.CONTRATO_NUM FROM TRAMITES T INNER JOIN PROCESOS P ON T.COMPANIA = P.COMPANIA AND T.PROCESOS = P.CODIGO INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE INNER JOIN NODOS N_ORIGEN ON T.COMPANIA = N_ORIGEN.COMPANIA AND T.PROCESOS = N_ORIGEN.CODIGO_PROCESO AND T.NODO_ORIGEN = N_ORIGEN.CODIGO INNER JOIN NODOS N_ACTUAL ON T.COMPANIA = N_ACTUAL.COMPANIA AND T.PROCESOS = N_ACTUAL.CODIGO_PROCESO AND T.NODO_ACTUAL = N_ACTUAL.CODIGO INNER JOIN TIPOS TI ON T.ESTADO = TI.ID LEFT JOIN PROYECCIONES_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.PROCESOS = PT.PROCESO AND T.NODO_ACTUAL = PT.NODO AND T.NUMERO = PT.TRAMITE AND T.TIPO_TRAMITE = PT.TIPO_TRAMITE WHERE T.COMPANIA = :COMPANIA AND T.USUARIO_INTERNO = :USUARIO_INTERNO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:ESTADO,' ','') ),CONCAT( '',CONCAT( TO_CHAR(T.ESTADO), '')),1) &gt; 0 AND N_ORIGEN.CODIGO = N_ACTUAL.CODIGO ORDER BY T.NUMERO DESC) INI WHERE (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN TIPOTRAMITE_NOM IS NULL THEN ' ' ELSE UPPER(TIPOTRAMITE_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOTRAMITE_NOM), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NODO_O_NOM IS NULL THEN ' ' ELSE UPPER(NODO_O_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_O_NOM), '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO_NOM), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN RACI_NOM IS NULL THEN ' ' ELSE UPPER(RACI_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:RACI_NOM), '%')) AND (CASE WHEN CONTRATO_NUM IS NULL THEN ' ' ELSE UPPER(CONTRATO_NUM) END) LIKE UPPER(CONCAT(:CONTRATO_NUM, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCESOS":"$PROCESOS","PROCESO_NOM":"$PROCESO_NOM","TIPO_TRAMITE":"$TIPO_TRAMITE","TIPOTRAMITE_NOM":"$TIPOTRAMITE_NOM","NUMERO":"$NUMERO(type:long)","NODO_O_NOM":"$NODO_O_NOM","NODO_A_NOM":"$NODO_A_NOM","ESTADO":"$ESTADO(type:integer)","ESTADO_NOM":"$ESTADO_NOM","FECHA":"$FECHA","RACI_NOM":"$RACI_NOM","CONTRATO_NUM":"$CONTRATO_NUM"}]}}		</result>
		<param name="USUARIO_INTERNO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="TIPOTRAMITE_NOM" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NODO_O_NOM" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RACI_NOM" sqlType="STRING"/>
		<param name="CONTRATO_NUM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tramites">
		<call-query href="getTramitesPaginaQuery">
			<with-param name="USUARIO_INTERNO" query-param="USUARIO_INTERNO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PROCESO_NOM" query-param="PROCESO_NOM"/>
			<with-param name="TIPOTRAMITE_NOM" query-param="TIPOTRAMITE_NOM"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="NODO_O_NOM" query-param="NODO_O_NOM"/>
			<with-param name="NODO_A_NOM" query-param="NODO_A_NOM"/>
			<with-param name="ESTADO_NOM" query-param="ESTADO_NOM"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="RACI_NOM" query-param="RACI_NOM"/>
			<with-param name="CONTRATO_NUM" query-param="CONTRATO_NUM"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTramitesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT T.COMPANIA, T.PROCESOS, P.NOMBRE PROCESO_NOM, T.TIPO_TRAMITE, TT.NOMBRE TIPOTRAMITE_NOM, T.NUMERO, N_ORIGEN.NOMBRE NODO_O_NOM, N_ACTUAL.NOMBRE NODO_A_NOM, T.ESTADO, TI.NOMBRE ESTADO_NOM, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, ( SELECT NOMBRE FROM TIPOS WHERE ID = CASE WHEN :USUARIO_INTERNO IN ( SELECT RU.USUARIO FROM NODO_RACI NR INNER JOIN ROL_USUARIO RU ON NR.COMPANIA = RU.COMPANIA AND NR.CODIGO_ROL = RU.CODIGO_ROL WHERE NR.COMPANIA = T.COMPANIA AND NR.CODIGO_PROCESO = T.PROCESOS AND NR.CODIGO_NODO = T.NODO_ACTUAL AND NR.CODIGO_RACI = 9 ) THEN 9 ELSE 10 END ) RACI_NOM, T.CONTRATO_NUM FROM TRAMITES T INNER JOIN PROCESOS P ON T.COMPANIA = P.COMPANIA AND T.PROCESOS = P.CODIGO INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE INNER JOIN NODOS N_ORIGEN ON T.COMPANIA = N_ORIGEN.COMPANIA AND T.PROCESOS = N_ORIGEN.CODIGO_PROCESO AND T.NODO_ORIGEN = N_ORIGEN.CODIGO INNER JOIN NODOS N_ACTUAL ON T.COMPANIA = N_ACTUAL.COMPANIA AND T.PROCESOS = N_ACTUAL.CODIGO_PROCESO AND T.NODO_ACTUAL = N_ACTUAL.CODIGO INNER JOIN TIPOS TI ON T.ESTADO = TI.ID LEFT JOIN PROYECCIONES_TRAMITE PT ON T.COMPANIA = PT.COMPANIA AND T.PROCESOS = PT.PROCESO AND T.NODO_ACTUAL = PT.NODO AND T.NUMERO = PT.TRAMITE AND T.TIPO_TRAMITE = PT.TIPO_TRAMITE WHERE T.COMPANIA = :COMPANIA AND T.USUARIO_INTERNO = :USUARIO_INTERNO AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:ESTADO,' ','') ),CONCAT( '',CONCAT( TO_CHAR(T.ESTADO), '')),1) &gt; 0 AND N_ORIGEN.CODIGO = N_ACTUAL.CODIGO ORDER BY T.NUMERO DESC) INI WHERE (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN TIPOTRAMITE_NOM IS NULL THEN ' ' ELSE UPPER(TIPOTRAMITE_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOTRAMITE_NOM), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NODO_O_NOM IS NULL THEN ' ' ELSE UPPER(NODO_O_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_O_NOM), '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO_NOM), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN RACI_NOM IS NULL THEN ' ' ELSE UPPER(RACI_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:RACI_NOM), '%')) AND (CASE WHEN CONTRATO_NUM IS NULL THEN ' ' ELSE UPPER(CONTRATO_NUM) END) LIKE UPPER(CONCAT(:CONTRATO_NUM, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="USUARIO_INTERNO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="TIPOTRAMITE_NOM" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NODO_O_NOM" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RACI_NOM" sqlType="STRING"/>
		<param name="CONTRATO_NUM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/numero">
