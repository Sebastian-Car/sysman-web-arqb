		<param defaultValue="" name="CONTRATO_NUM" sqlType="STRING"/>
		<param defaultValue="" name="CANTIDAD_ANEXOS" sqlType="STRING"/>
		<param defaultValue="" name="CANTIDAD_OFICIOS" sqlType="STRING"/>
