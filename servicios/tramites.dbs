	<query id="getTramitesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT TRAMITES.COMPANIA, TRAMITES.PROCESOS, TRAMITES.TIPO_TRAMITE, TRAMITES.NUMERO, TRAMITES.USUARIO_INTERNO, TRAMITES.USUARIO_EXTERNO, TRAMITES.PROCEDENCIA, TRAMITES.DESTINO, TRAMITES.CIUDAD_ORIGEN, TRAMITES.PAIS_ORIGEN, TRAMITES.DEPARTAMENTO_ORIGEN, PROCEDENCIA_TRAMITE.DIRECCION DIRECCION_PROCEDENCIA, TRAMITES.DIRECCION_DESTINO, TRAMITES.REFERENCIA, TRAMITES.REFERENCIA1, TRAMITES.TIPO_REFERENCIA, TRAMITES.TIPO_REFERENCIA1, TRAMITES.MODULO, TRAMITES.DESCRIPCION, TRAMITES.ESTADO, ( TO_CHAR(TRAMITES.FECHA_REAL, 'DD/MM/YYYY HH24:MI:SS') ) FECHA_REAL, ( TO_CHAR(TRAMITES.HORA, 'DD/MM/YYYY HH24:MI:SS') ) HORA, ( TO_CHAR(TRAMITES.FECHA, 'DD/MM/YYYY HH24:MI:SS') ) FECHA, TRAMITES.NODO_ORIGEN, N_ORIGEN.NOMBRE NODO_O_NOM, TRAMITES.NODO_ACTUAL, N_ACTUAL.NOMBRE NODO_A_NOM, TRAMITES.CODIGO_CALIDAD, TRAMITES.SERIE_DOCUMENTAL, SD.NOMBRE SERIE_DOCUMENTAL_NOM, ( CASE N_ACTUAL.NODO_FINAL WHEN 0 THEN 'false' ELSE 'true' END ) NODO_FINAL, TRAMITES.DESC_NODO_ACTUAL, TRAMITES.CONTRATO_NUM, ( TO_CHAR(TRAMITES.DATE_CREATED, 'DD/MM/YYYY HH24:MI:SS') ) DATE_CREATED, TRAMITES.CREATED_BY, TRAMITES.MODIFIED_BY, ( TO_CHAR(TRAMITES.DATE_MODIFIED, 'DD/MM/YYYY HH24:MI:SS') ) DATE_MODIFIED, TRAMITES.CANTIDAD_ANEXOS, TRAMITES.CANTIDAD_OFICIOS, TRAMITES.CLASE_ANEXOS, TRAMITES.CORRESPONDENCIA, ( TO_CHAR(PT.ESTIMADO_FECHA, 'DD/MM/YYYY HH24:MI:SS') ) FECHA_LIMITE, TRAMITES.TIPO_MEDIO, TIPO_MEDIO.NOMBRE AS TIPO_MEDIO_NOM, TRAMITES.TIPO_POBLACION, PROCEDENCIA_TRAMITE.NOMBRE NOMBRE_PROCEDENCIA, PROCEDENCIA_TRAMITE.DOCUMENTO NIT_PROCEDENCIA, TRAMITES.DEPENDENCIA, DEPENDENCIA.NOMBRE AS NOMBRE_DEPENDENCIA, URLSERVICIO.URL, ( CASE N_ACTUAL.ENVIA_CORREO WHEN 0 THEN 'false' ELSE 'true' END ) ENVIA_CORREO, ( CASE N_ACTUAL.PROCEDENCIA_AUT WHEN 0 THEN 'false' ELSE 'true' END ) PROCEDENCIA_AUT, ( CASE N_ACTUAL.RECEPCION_CORRES WHEN 0 THEN 'false' ELSE 'true' END ) RECEPCION_CORRES, ( CASE N_ACTUAL.ENVIO_CORRES WHEN 0 THEN 'false' ELSE 'true' END ) ENVIO_CORRES,TRAMITES.OCUPACION, TRAMITES.VULNERABILIDAD, TRAMITES.ESCOLARIDAD, TRAMITES.RANGO_EDAD, TRAMITES.TIPO_PERSONA, TRAMITES.DESC_TIPO_POBLACION, TRAMITES.DESC_OCUPACION,(CASE N_ACTUAL.PRORROGA WHEN 0 THEN 'false' ELSE 'true' END) PRORROGA,(TO_CHAR(TRAMITES.FECHA_PRORROGA,'DD/MM/YYYY HH24:MI:SS')) FECHA_PRORROGA FROM TRAMITES INNER JOIN NODOS N_ORIGEN ON TRAMITES.COMPANIA = N_ORIGEN.COMPANIA AND TRAMITES.PROCESOS = N_ORIGEN.CODIGO_PROCESO AND TRAMITES.NODO_ORIGEN = N_ORIGEN.CODIGO LEFT JOIN DEPENDENCIA ON TRAMITES.COMPANIA = DEPENDENCIA.COMPANIA AND TRAMITES.DEPENDENCIA = DEPENDENCIA.CODIGO INNER JOIN NODOS N_ACTUAL ON TRAMITES.COMPANIA = N_ACTUAL.COMPANIA AND TRAMITES.PROCESOS = N_ACTUAL.CODIGO_PROCESO AND TRAMITES.NODO_ACTUAL = N_ACTUAL.CODIGO LEFT JOIN SERIEDOCUMENTAL SD ON TRAMITES.COMPANIA = SD.COMPANIA AND TRAMITES.SERIE_DOCUMENTAL = SD.CODIGO LEFT JOIN PROYECCIONES_TRAMITE PT ON TRAMITES.COMPANIA = PT.COMPANIA AND TRAMITES.PROCESOS = PT.PROCESO AND TRAMITES.NODO_ACTUAL = PT.NODO AND TRAMITES.NUMERO = PT.TRAMITE AND TRAMITES.TIPO_TRAMITE = PT.TIPO_TRAMITE LEFT JOIN PROCEDENCIA_TRAMITE ON PROCEDENCIA_TRAMITE.COMPANIA = TRAMITES.COMPANIA AND PROCEDENCIA_TRAMITE.CODIGO = TRAMITES.PROCEDENCIA INNER JOIN PROCESOS ON TRAMITES.COMPANIA = PROCESOS.COMPANIA AND TRAMITES.PROCESOS = PROCESOS.CODIGO LEFT JOIN URLSERVICIO ON PROCESOS.COMPANIA = URLSERVICIO.COMPANIA AND PROCESOS.TRAE_DEUDA = URLSERVICIO.CODIGO LEFT JOIN TIPO_MEDIO ON TRAMITES.COMPANIA = TIPO_MEDIO.COMPANIA AND TRAMITES.TIPO_MEDIO = TIPO_MEDIO.CODIGO WHERE TRAMITES.COMPANIA= :KEY_COMPANIA AND TRAMITES.PROCESOS= :KEY_PROCESOS AND TRAMITES.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND TRAMITES.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCESOS":"$PROCESOS","TIPO_TRAMITE":"$TIPO_TRAMITE","NUMERO":"$NUMERO(type:long)","USUARIO_INTERNO":"$USUARIO_INTERNO","USUARIO_EXTERNO":"$USUARIO_EXTERNO","PROCEDENCIA":"$PROCEDENCIA","DESTINO":"$DESTINO","CIUDAD_ORIGEN":"$CIUDAD_ORIGEN","PAIS_ORIGEN":"$PAIS_ORIGEN","DEPARTAMENTO_ORIGEN":"$DEPARTAMENTO_ORIGEN","DIRECCION_PROCEDENCIA":"$DIRECCION_PROCEDENCIA","DIRECCION_DESTINO":"$DIRECCION_DESTINO","REFERENCIA":"$REFERENCIA","REFERENCIA1":"$REFERENCIA1","TIPO_REFERENCIA":"$TIPO_REFERENCIA(type:integer)","TIPO_REFERENCIA1":"$TIPO_REFERENCIA1(type:integer)","MODULO":"$MODULO","DESCRIPCION":"$DESCRIPCION","ESTADO":"$ESTADO(type:integer)","FECHA_REAL":"$FECHA_REAL","HORA":"$HORA","FECHA":"$FECHA","NODO_ORIGEN":"$NODO_ORIGEN","NODO_O_NOM":"$NODO_O_NOM","NODO_ACTUAL":"$NODO_ACTUAL","NODO_A_NOM":"$NODO_A_NOM","CODIGO_CALIDAD":"$CODIGO_CALIDAD","SERIE_DOCUMENTAL":"$SERIE_DOCUMENTAL","SERIE_DOCUMENTAL_NOM":"$SERIE_DOCUMENTAL_NOM","NODO_FINAL":"$NODO_FINAL","DESC_NODO_ACTUAL":"$DESC_NODO_ACTUAL","CONTRATO_NUM":"$CONTRATO_NUM","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CANTIDAD_ANEXOS":"$CANTIDAD_ANEXOS(type:integer)","CANTIDAD_OFICIOS":"$CANTIDAD_OFICIOS(type:integer)","CLASE_ANEXOS":"$CLASE_ANEXOS","CORRESPONDENCIA":"$CORRESPONDENCIA(type:integer)","FECHA_LIMITE":"$FECHA_LIMITE","TIPO_MEDIO":"$TIPO_MEDIO(type:long)","TIPO_MEDIO_NOM":"$TIPO_MEDIO_NOM","TIPO_POBLACION":"$TIPO_POBLACION(type:long)","NOMBRE_PROCEDENCIA":"$NOMBRE_PROCEDENCIA","NIT_PROCEDENCIA":"$NIT_PROCEDENCIA","DEPENDENCIA":"$DEPENDENCIA","NOMBRE_DEPENDENCIA":"$NOMBRE_DEPENDENCIA","URL":"$URL","ENVIA_CORREO":"$ENVIA_CORREO","PROCEDENCIA_AUT":"$PROCEDENCIA_AUT","RECEPCION_CORRES":"$RECEPCION_CORRES(type:boolean)","ENVIO_CORRES":"$ENVIO_CORRES(type:boolean)","OCUPACION":"$OCUPACION(type:long)","VULNERABILIDAD":"$VULNERABILIDAD(type:long)","ESCOLARIDAD":"$ESCOLARIDAD(type:long)","RANGO_EDAD":"$RANGO_EDAD(type:long)","TIPO_PERSONA":"$TIPO_PERSONA(type:long)","DESC_TIPO_POBLACION":"$DESC_TIPO_POBLACION","DESC_OCUPACION":"$DESC_OCUPACION","PRORROGA":"$PRORROGA(type:boolean)","FECHA_PRORROGA":"$FECHA_PRORROGA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCESOS" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/data">
		<call-query href="getTramitesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCESOS" query-param="KEY_PROCESOS"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
<query id="updateTramites" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TRAMITES SET PROCESOS=:PROCESOS, TIPO_TRAMITE=:TIPO_TRAMITE, NUMERO=:NUMERO, USUARIO_INTERNO=:USUARIO_INTERNO, USUARIO_EXTERNO=:USUARIO_EXTERNO, PROCEDENCIA=:PROCEDENCIA, DESTINO=:DESTINO, CIUDAD_ORIGEN=:CIUDAD_ORIGEN, PAIS_ORIGEN=:PAIS_ORIGEN, DEPARTAMENTO_ORIGEN=:DEPARTAMENTO_ORIGEN, DIRECCION_PROCEDENCIA=:DIRECCION_PROCEDENCIA, DIRECCION_DESTINO=:DIRECCION_DESTINO, REFERENCIA=:REFERENCIA, REFERENCIA1=:REFERENCIA1, TIPO_REFERENCIA=:TIPO_REFERENCIA, TIPO_REFERENCIA1=:TIPO_REFERENCIA1, MODULO=:MODULO, DESCRIPCION=:DESCRIPCION, ESTADO=:ESTADO, FECHA_REAL=TO_DATE(:FECHA_REAL,'DD/MM/YYYY HH24:MI:SS'), HORA=TO_DATE(:HORA,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), NODO_ACTUAL=:NODO_ACTUAL, CODIGO_CALIDAD=:CODIGO_CALIDAD, SERIE_DOCUMENTAL=:SERIE_DOCUMENTAL, DESC_NODO_ACTUAL=:DESC_NODO_ACTUAL, CONTRATO_NUM=:CONTRATO_NUM, CANTIDAD_ANEXOS=:CANTIDAD_ANEXOS, CANTIDAD_OFICIOS=:CANTIDAD_OFICIOS, CLASE_ANEXOS=:CLASE_ANEXOS, CORRESPONDENCIA=:CORRESPONDENCIA, TIPO_MEDIO=:TIPO_MEDIO, TIPO_POBLACION=:TIPO_POBLACION, DEPENDENCIA=:DEPENDENCIA, VULNERABILIDAD=:VULNERABILIDAD, OCUPACION=:OCUPACION, ESCOLARIDAD=:ESCOLARIDAD, RANGO_EDAD=:RANGO_EDAD, TIPO_PERSONA=:TIPO_PERSONA, DESC_TIPO_POBLACION=:DESC_TIPO_POBLACION, DESC_OCUPACION=:DESC_OCUPACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TRAMITES.COMPANIA= :KEY_COMPANIA AND TRAMITES.PROCESOS= :KEY_PROCESOS AND TRAMITES.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND TRAMITES.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="PROCESOS" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="USUARIO_INTERNO" sqlType="STRING"/>
