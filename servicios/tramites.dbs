	<query id="getTramitesTramitesporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT TRAMITES.NUMERO FROM TRAMITES WHERE TRAMITES.COMPANIA = :COMPANIA ORDER BY TRAMITES.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:long)"}]}}		</result>
