	<query id="getTramitesProcesosportramiteQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT P.CODIGO, CONCAT('(',CONCAT(P.CODIGO,CONCAT(') ',P.NOMBRE) ) ) NOMBRE FROM TRAMITES T INNER JOIN PROCESOS P ON T.COMPANIA = P.COMPANIA AND T.PROCESOS = P.CODIGO WHERE T.COMPANIA =:COMPANIA AND T.ESTADO =:ESTADO AND T.USUARIO_INTERNO =:USUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramites/procesosportramite">
		<call-query href="getTramitesProcesosportramiteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>

		</call-query>
	</resource>
	<query id="getTramitesTipostramiteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT TT.TIPOTRAMITE , TT.NOMBRE  FROM TRAMITES T INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE WHERE T.COMPANIA = :COMPANIA AND T.PROCESOS = :PROCESO AND T.ESTADO = :ESTADO AND T.USUARIO_INTERNO = :USUARIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOTRAMITE":"$TIPOTRAMITE","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>

	</query>
