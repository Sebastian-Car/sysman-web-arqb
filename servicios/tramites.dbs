	</resource>
	<query id="getTramitesNumTramitepornivelusuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT T.COMPANIA, T.PROCESOS, P.NOMBRE PROCESO_NOM, T.TIPO_TRAMITE, TT.NOMBRE TIPOTRAMITE_NOM, T.NUMERO, N_ORIGEN.NOMBRE NODO_O_NOM, N_ACTUAL.NOMBRE NODO_A_NOM, T.ESTADO, TI.NOMBRE ESTADO_NOM, TO_CHAR(T.FECHA, 'DD/MM/YYYY') FECHA, ( SELECT NOMBRE FROM TIPOS WHERE ID = CASE WHEN :USUARIO_INTERNO IN ( SELECT RU.USUARIO FROM NODO_RACI NR INNER JOIN ROL_USUARIO RU ON NR.COMPANIA = RU.COMPANIA AND NR.CODIGO_ROL = RU.CODIGO_ROL WHERE NR.COMPANIA = T.COMPANIA AND NR.CODIGO_PROCESO = T.PROCESOS AND NR.CODIGO_NODO = T.NODO_ACTUAL AND NR.CODIGO_RACI = 9 ) THEN 9 ELSE 10 END ) RACI_NOM, T.CONTRATO_NUM FROM TRAMITES T INNER JOIN PROCESOS P ON T.COMPANIA = P.COMPANIA AND T.PROCESOS = P.CODIGO INNER JOIN TIPOTRAMITES TT ON T.COMPANIA = TT.COMPANIA AND T.PROCESOS = TT.PROCESOS AND T.TIPO_TRAMITE = TT.TIPOTRAMITE INNER JOIN NODOS N_ORIGEN ON T.COMPANIA = N_ORIGEN.COMPANIA AND T.PROCESOS = N_ORIGEN.CODIGO_PROCESO AND T.NODO_ORIGEN = N_ORIGEN.CODIGO INNER JOIN NODOS N_ACTUAL ON T.COMPANIA = N_ACTUAL.COMPANIA AND T.PROCESOS = N_ACTUAL.CODIGO_PROCESO AND T.NODO_ACTUAL = N_ACTUAL.CODIGO INNER JOIN TIPOS TI ON T.ESTADO = TI.ID WHERE T.COMPANIA = :COMPANIA AND T.ESTADO = :ESTADO ORDER BY T.NUMERO DESC) INI WHERE (CASE WHEN PROCESO_NOM IS NULL THEN ' ' ELSE UPPER(PROCESO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:PROCESO_NOM), '%')) AND (CASE WHEN TIPOTRAMITE_NOM IS NULL THEN ' ' ELSE UPPER(TIPOTRAMITE_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPOTRAMITE_NOM), '%')) AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN NODO_O_NOM IS NULL THEN ' ' ELSE UPPER(NODO_O_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_O_NOM), '%')) AND (CASE WHEN NODO_A_NOM IS NULL THEN ' ' ELSE UPPER(NODO_A_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:NODO_A_NOM), '%')) AND (CASE WHEN ESTADO_NOM IS NULL THEN ' ' ELSE UPPER(ESTADO_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO_NOM), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN RACI_NOM IS NULL THEN ' ' ELSE UPPER(RACI_NOM) END) LIKE UPPER(CONCAT(CONCAT('%',:RACI_NOM), '%')) AND (CASE WHEN CONTRATO_NUM IS NULL THEN ' ' ELSE UPPER(CONTRATO_NUM) END) LIKE UPPER(CONCAT(:CONTRATO_NUM, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="USUARIO_INTERNO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PROCESO_NOM" sqlType="STRING"/>
		<param name="TIPOTRAMITE_NOM" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="NODO_O_NOM" sqlType="STRING"/>
		<param name="NODO_A_NOM" sqlType="STRING"/>
		<param name="ESTADO_NOM" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="RACI_NOM" sqlType="STRING"/>
		<param name="CONTRATO_NUM" sqlType="STRING"/>

	</query>
