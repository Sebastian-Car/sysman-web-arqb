<data name="dparametrosplanos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="deleteDparametrosplanosTodosPorPlano" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_PARAMETROS_PLANOS WHERE D_PARAMETROS_PLANOS.COMPANIA= :COMPANIA AND D_PARAMETROS_PLANOS.GRUPO= :GRUPO AND D_PARAMETROS_PLANOS.CODIGO= :CODIGO AND D_PARAMETROS_PLANOS.SECUENCIA= :SECUENCIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dparametrosplanos/todosporplano">
		<call-query href="deleteDparametrosplanosTodosPorPlano">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>

		</call-query>
	</resource>
	<query id="getDparametrosplanosPagConfiguracionParametrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_PARAMETROS_PLANOS.COMPANIA, D_PARAMETROS_PLANOS.GRUPO, D_PARAMETROS_PLANOS.CODIGO, D_PARAMETROS_PLANOS.SECUENCIA, D_PARAMETROS_PLANOS.CODIGO_PARAMETRO, D_PARAMETROS_PLANOS.ETIQUETA_PARAMETRO, CASE D_PARAMETROS_PLANOS.TIPO_PARAMETRO WHEN 'S' THEN 'STRING' WHEN 'N' THEN 'NUMBER' WHEN 'D' THEN 'DATE' WHEN 'C' THEN 'CLOB' END TIPO, TIPO_PARAMETRO, FILTROS.N_COLUMNAS, FILTROS.URL, FILTROS.NOMBRE_ENCABEZADOS, CASE FILTROS.N_COLUMNAS WHEN 2 THEN D_PARAMETROS_PLANOS.VALOR_FILTRO ELSE '' END VALOR_FILTRODOS, CASE FILTROS.N_COLUMNAS WHEN 3 THEN D_PARAMETROS_PLANOS.VALOR_FILTRO ELSE '' END VALOR_FILTROTRES, CASE FILTROS.N_COLUMNAS WHEN 4 THEN D_PARAMETROS_PLANOS.VALOR_FILTRO ELSE '' END VALOR_FILTROCUATRO,(TO_CHAR(D_PARAMETROS_PLANOS.VALOR_FILTRO_FECHA,'DD/MM/YYYY HH24:MI:SS')) VALOR_FILTRO_FECHA, D_PARAMETROS_PLANOS.CODIGO_FILTRO, D_PARAMETROS_PLANOS.VALOR_DEFECTO,(CASE D_PARAMETROS_PLANOS.PORDEFECTO WHEN 0 THEN 'false' ELSE 'true' END) PORDEFECTO FROM D_PARAMETROS_PLANOS INNER JOIN FILTROS ON D_PARAMETROS_PLANOS.CODIGO_FILTRO = FILTROS.CODIGO_FILTRO WHERE D_PARAMETROS_PLANOS.COMPANIA = :COMPANIA AND D_PARAMETROS_PLANOS.GRUPO = :GRUPO AND D_PARAMETROS_PLANOS.CODIGO = :CODIGO AND D_PARAMETROS_PLANOS.SECUENCIA = :SECUENCIA AND D_PARAMETROS_PLANOS.PORDEFECTO IN (0) ORDER BY D_PARAMETROS_PLANOS.CODIGO_PARAMETRO) WHERE (CASE WHEN CODIGO_PARAMETRO IS NULL THEN ' ' ELSE UPPER(CODIGO_PARAMETRO) END)  LIKE UPPER(:CODIGO_PARAMETRO || '%')  AND (CASE WHEN ETIQUETA_PARAMETRO IS NULL THEN ' ' ELSE UPPER(ETIQUETA_PARAMETRO) END)  LIKE UPPER( '%' || :ETIQUETA_PARAMETRO || '%')  AND (CASE WHEN VALOR_FILTRODOS IS NULL THEN ' ' ELSE UPPER(VALOR_FILTRODOS) END)  LIKE UPPER( '%' || :VALOR_FILTRODOS || '%')  AND (CASE WHEN VALOR_FILTROTRES IS NULL THEN ' ' ELSE UPPER(VALOR_FILTROTRES) END)  LIKE UPPER( '%' || :VALOR_FILTROTRES || '%')  AND (CASE WHEN VALOR_FILTROCUATRO IS NULL THEN ' ' ELSE UPPER(VALOR_FILTROCUATRO) END)  LIKE UPPER( '%' || :VALOR_FILTROCUATRO || '%')  AND (CASE WHEN VALOR_FILTRO_FECHA IS NULL THEN ' ' ELSE UPPER(VALOR_FILTRO_FECHA) END)  LIKE UPPER( '%' || :VALOR_FILTRO_FECHA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","GRUPO":"$GRUPO","CODIGO":"$CODIGO","SECUENCIA":"$SECUENCIA","CODIGO_PARAMETRO":"$CODIGO_PARAMETRO","ETIQUETA_PARAMETRO":"$ETIQUETA_PARAMETRO","TIPO":"$TIPO","TIPO_PARAMETRO":"$TIPO_PARAMETRO","N_COLUMNAS":"$N_COLUMNAS(type:integer)","URL":"$URL","NOMBRE_ENCABEZADOS":"$NOMBRE_ENCABEZADOS","VALOR_FILTRODOS":"$VALOR_FILTRODOS","VALOR_FILTROTRES":"$VALOR_FILTROTRES","VALOR_FILTROCUATRO":"$VALOR_FILTROCUATRO","VALOR_FILTRO_FECHA":"$VALOR_FILTRO_FECHA","CODIGO_FILTRO":"$CODIGO_FILTRO","VALOR_DEFECTO":"$VALOR_DEFECTO","PORDEFECTO":"$PORDEFECTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="VALOR_FILTRODOS" sqlType="STRING"/>
		<param name="VALOR_FILTROTRES" sqlType="STRING"/>
		<param name="VALOR_FILTROCUATRO" sqlType="STRING"/>
		<param name="VALOR_FILTRO_FECHA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dparametrosplanos/configuracionparametros/pag">
		<call-query href="getDparametrosplanosPagConfiguracionParametrosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="VALOR_FILTRODOS" query-param="VALOR_FILTRODOS"/>
			<with-param name="VALOR_FILTROTRES" query-param="VALOR_FILTROTRES"/>
			<with-param name="VALOR_FILTROCUATRO" query-param="VALOR_FILTROCUATRO"/>
			<with-param name="VALOR_FILTRO_FECHA" query-param="VALOR_FILTRO_FECHA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDparametrosplanosNumConfiguracionParametrosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_PARAMETROS_PLANOS.COMPANIA, D_PARAMETROS_PLANOS.GRUPO, D_PARAMETROS_PLANOS.CODIGO, D_PARAMETROS_PLANOS.SECUENCIA, D_PARAMETROS_PLANOS.CODIGO_PARAMETRO, D_PARAMETROS_PLANOS.ETIQUETA_PARAMETRO, CASE D_PARAMETROS_PLANOS.TIPO_PARAMETRO WHEN 'S' THEN 'STRING' WHEN 'N' THEN 'NUMBER' WHEN 'D' THEN 'DATE' WHEN 'C' THEN 'CLOB' END TIPO, TIPO_PARAMETRO, FILTROS.N_COLUMNAS, FILTROS.URL, FILTROS.NOMBRE_ENCABEZADOS, CASE FILTROS.N_COLUMNAS WHEN 2 THEN D_PARAMETROS_PLANOS.VALOR_FILTRO ELSE '' END VALOR_FILTRODOS, CASE FILTROS.N_COLUMNAS WHEN 3 THEN D_PARAMETROS_PLANOS.VALOR_FILTRO ELSE '' END VALOR_FILTROTRES, CASE FILTROS.N_COLUMNAS WHEN 4 THEN D_PARAMETROS_PLANOS.VALOR_FILTRO ELSE '' END VALOR_FILTROCUATRO,(TO_CHAR(D_PARAMETROS_PLANOS.VALOR_FILTRO_FECHA,'DD/MM/YYYY HH24:MI:SS')) VALOR_FILTRO_FECHA, D_PARAMETROS_PLANOS.CODIGO_FILTRO, D_PARAMETROS_PLANOS.VALOR_DEFECTO,(CASE D_PARAMETROS_PLANOS.PORDEFECTO WHEN 0 THEN 'false' ELSE 'true' END) PORDEFECTO FROM D_PARAMETROS_PLANOS INNER JOIN FILTROS ON D_PARAMETROS_PLANOS.CODIGO_FILTRO = FILTROS.CODIGO_FILTRO WHERE D_PARAMETROS_PLANOS.COMPANIA = :COMPANIA AND D_PARAMETROS_PLANOS.GRUPO = :GRUPO AND D_PARAMETROS_PLANOS.CODIGO = :CODIGO AND D_PARAMETROS_PLANOS.SECUENCIA = :SECUENCIA AND D_PARAMETROS_PLANOS.PORDEFECTO IN (0) ORDER BY D_PARAMETROS_PLANOS.CODIGO_PARAMETRO) WHERE (CASE WHEN CODIGO_PARAMETRO IS NULL THEN ' ' ELSE UPPER(CODIGO_PARAMETRO) END)  LIKE UPPER(:CODIGO_PARAMETRO || '%')  AND (CASE WHEN ETIQUETA_PARAMETRO IS NULL THEN ' ' ELSE UPPER(ETIQUETA_PARAMETRO) END)  LIKE UPPER( '%' || :ETIQUETA_PARAMETRO || '%')  AND (CASE WHEN VALOR_FILTRODOS IS NULL THEN ' ' ELSE UPPER(VALOR_FILTRODOS) END)  LIKE UPPER( '%' || :VALOR_FILTRODOS || '%')  AND (CASE WHEN VALOR_FILTROTRES IS NULL THEN ' ' ELSE UPPER(VALOR_FILTROTRES) END)  LIKE UPPER( '%' || :VALOR_FILTROTRES || '%')  AND (CASE WHEN VALOR_FILTROCUATRO IS NULL THEN ' ' ELSE UPPER(VALOR_FILTROCUATRO) END)  LIKE UPPER( '%' || :VALOR_FILTROCUATRO || '%')  AND (CASE WHEN VALOR_FILTRO_FECHA IS NULL THEN ' ' ELSE UPPER(VALOR_FILTRO_FECHA) END)  LIKE UPPER( '%' || :VALOR_FILTRO_FECHA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="VALOR_FILTRODOS" sqlType="STRING"/>
		<param name="VALOR_FILTROTRES" sqlType="STRING"/>
		<param name="VALOR_FILTROCUATRO" sqlType="STRING"/>
		<param name="VALOR_FILTRO_FECHA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dparametrosplanos/configuracionparametros/num">
		<call-query href="getDparametrosplanosNumConfiguracionParametrosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="VALOR_FILTRODOS" query-param="VALOR_FILTRODOS"/>
			<with-param name="VALOR_FILTROTRES" query-param="VALOR_FILTROTRES"/>
			<with-param name="VALOR_FILTROCUATRO" query-param="VALOR_FILTROCUATRO"/>
			<with-param name="VALOR_FILTRO_FECHA" query-param="VALOR_FILTRO_FECHA"/>

		</call-query>
	</resource>
	<query id="insertDparametrosplanos" keyColumns="COMPANIA,GRUPO,CODIGO,SECUENCIA,CODIGO_PARAMETRO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_PARAMETROS_PLANOS (COMPANIA, GRUPO, CODIGO, SECUENCIA, CODIGO_PARAMETRO, NOMBRE_PARAMETRO, TIPO_PARAMETRO, ETIQUETA_PARAMETRO, CODIGO_FILTRO, VALOR_DEFECTO, PORDEFECTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :GRUPO, :CODIGO, :SECUENCIA, :CODIGO_PARAMETRO, :NOMBRE_PARAMETRO, :TIPO_PARAMETRO, :ETIQUETA_PARAMETRO, :CODIGO_FILTRO, :VALOR_DEFECTO, :PORDEFECTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_GRUPO":"$GRUPO","KEY_CODIGO":"$CODIGO","KEY_SECUENCIA":"$SECUENCIA","KEY_CODIGO_PARAMETRO":"$CODIGO_PARAMETRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="NOMBRE_PARAMETRO" sqlType="STRING"/>
		<param name="TIPO_PARAMETRO" sqlType="STRING"/>
		<param defaultValue="" name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_FILTRO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR_DEFECTO" sqlType="STRING"/>
		<param defaultValue="0" name="PORDEFECTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dparametrosplanos">
		<call-query href="insertDparametrosplanos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="NOMBRE_PARAMETRO" query-param="NOMBRE_PARAMETRO"/>
			<with-param name="TIPO_PARAMETRO" query-param="TIPO_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="CODIGO_FILTRO" query-param="CODIGO_FILTRO"/>
			<with-param name="VALOR_DEFECTO" query-param="VALOR_DEFECTO"/>
			<with-param name="PORDEFECTO" query-param="PORDEFECTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDparametrosplanos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_PARAMETROS_PLANOS WHERE D_PARAMETROS_PLANOS.COMPANIA= :KEY_COMPANIA AND D_PARAMETROS_PLANOS.GRUPO= :KEY_GRUPO AND D_PARAMETROS_PLANOS.CODIGO= :KEY_CODIGO AND D_PARAMETROS_PLANOS.SECUENCIA= :KEY_SECUENCIA AND D_PARAMETROS_PLANOS.CODIGO_PARAMETRO= :KEY_CODIGO_PARAMETRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_SECUENCIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PARAMETRO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dparametrosplanos">
		<call-query href="deleteDparametrosplanos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_SECUENCIA" query-param="KEY_SECUENCIA"/>
			<with-param name="KEY_CODIGO_PARAMETRO" query-param="KEY_CODIGO_PARAMETRO"/>

		</call-query>
	</resource>
	<query id="getDparametrosplanosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_PARAMETROS_PLANOS.COMPANIA, D_PARAMETROS_PLANOS.GRUPO, D_PARAMETROS_PLANOS.CODIGO, D_PARAMETROS_PLANOS.SECUENCIA, D_PARAMETROS_PLANOS.CODIGO_PARAMETRO, D_PARAMETROS_PLANOS.NOMBRE_PARAMETRO, D_PARAMETROS_PLANOS.TIPO_PARAMETRO, CASE D_PARAMETROS_PLANOS.TIPO_PARAMETRO WHEN 'D' THEN 'Date' WHEN 'N' THEN 'Numeric' WHEN 'S' THEN 'String' WHEN 'C' THEN 'Clob' END NOMBRE_TIPO, D_PARAMETROS_PLANOS.ETIQUETA_PARAMETRO, D_PARAMETROS_PLANOS.CODIGO_FILTRO, D_PARAMETROS_PLANOS.VALOR_DEFECTO,(CASE D_PARAMETROS_PLANOS.PORDEFECTO WHEN 0 THEN 'false' ELSE 'true' END) PORDEFECTO, FILTROS.NOMBRE_FILTRO, D_PARAMETROS_PLANOS.VALOR_FILTRO,(TO_CHAR(D_PARAMETROS_PLANOS.VALOR_FILTRO_FECHA,'DD/MM/YYYY HH24:MI:SS')) VALOR_FILTRO_FECHA FROM D_PARAMETROS_PLANOS LEFT JOIN FILTROS ON D_PARAMETROS_PLANOS.CODIGO_FILTRO = FILTROS.CODIGO_FILTRO WHERE D_PARAMETROS_PLANOS.COMPANIA = :COMPANIA AND D_PARAMETROS_PLANOS.GRUPO = :GRUPO AND D_PARAMETROS_PLANOS.CODIGO = :CODIGO AND D_PARAMETROS_PLANOS.SECUENCIA = :SECUENCIA ORDER BY D_PARAMETROS_PLANOS.CODIGO_PARAMETRO) WHERE (CASE WHEN CODIGO_PARAMETRO IS NULL THEN ' ' ELSE UPPER(CODIGO_PARAMETRO) END)  LIKE UPPER(:CODIGO_PARAMETRO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%')  AND (CASE WHEN ETIQUETA_PARAMETRO IS NULL THEN ' ' ELSE UPPER(ETIQUETA_PARAMETRO) END)  LIKE UPPER( '%' || :ETIQUETA_PARAMETRO || '%')  AND (CASE WHEN VALOR_DEFECTO IS NULL THEN ' ' ELSE UPPER(VALOR_DEFECTO) END)  LIKE UPPER(:VALOR_DEFECTO || '%')  AND (CASE WHEN PORDEFECTO IS NULL THEN ' ' ELSE UPPER(PORDEFECTO) END)  LIKE UPPER( '%' || :PORDEFECTO || '%')  AND (CASE WHEN NOMBRE_FILTRO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FILTRO) END)  LIKE UPPER( '%' || :NOMBRE_FILTRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","GRUPO":"$GRUPO","CODIGO":"$CODIGO","SECUENCIA":"$SECUENCIA","CODIGO_PARAMETRO":"$CODIGO_PARAMETRO","NOMBRE_PARAMETRO":"$NOMBRE_PARAMETRO","TIPO_PARAMETRO":"$TIPO_PARAMETRO","NOMBRE_TIPO":"$NOMBRE_TIPO","ETIQUETA_PARAMETRO":"$ETIQUETA_PARAMETRO","CODIGO_FILTRO":"$CODIGO_FILTRO","VALOR_DEFECTO":"$VALOR_DEFECTO","PORDEFECTO":"$PORDEFECTO(type:boolean)","NOMBRE_FILTRO":"$NOMBRE_FILTRO","VALOR_FILTRO":"$VALOR_FILTRO","VALOR_FILTRO_FECHA":"$VALOR_FILTRO_FECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="VALOR_DEFECTO" sqlType="STRING"/>
		<param name="PORDEFECTO" sqlType="STRING"/>
		<param name="NOMBRE_FILTRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dparametrosplanos">
		<call-query href="getDparametrosplanosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="VALOR_DEFECTO" query-param="VALOR_DEFECTO"/>
			<with-param name="PORDEFECTO" query-param="PORDEFECTO"/>
			<with-param name="NOMBRE_FILTRO" query-param="NOMBRE_FILTRO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDparametrosplanosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_PARAMETROS_PLANOS.COMPANIA, D_PARAMETROS_PLANOS.GRUPO, D_PARAMETROS_PLANOS.CODIGO, D_PARAMETROS_PLANOS.SECUENCIA, D_PARAMETROS_PLANOS.CODIGO_PARAMETRO, D_PARAMETROS_PLANOS.NOMBRE_PARAMETRO, D_PARAMETROS_PLANOS.TIPO_PARAMETRO, CASE D_PARAMETROS_PLANOS.TIPO_PARAMETRO WHEN 'D' THEN 'Date' WHEN 'N' THEN 'Numeric' WHEN 'S' THEN 'String' WHEN 'C' THEN 'Clob' END NOMBRE_TIPO, D_PARAMETROS_PLANOS.ETIQUETA_PARAMETRO, D_PARAMETROS_PLANOS.CODIGO_FILTRO, D_PARAMETROS_PLANOS.VALOR_DEFECTO,(CASE D_PARAMETROS_PLANOS.PORDEFECTO WHEN 0 THEN 'false' ELSE 'true' END) PORDEFECTO, FILTROS.NOMBRE_FILTRO, D_PARAMETROS_PLANOS.VALOR_FILTRO,(TO_CHAR(D_PARAMETROS_PLANOS.VALOR_FILTRO_FECHA,'DD/MM/YYYY HH24:MI:SS')) VALOR_FILTRO_FECHA FROM D_PARAMETROS_PLANOS LEFT JOIN FILTROS ON D_PARAMETROS_PLANOS.CODIGO_FILTRO = FILTROS.CODIGO_FILTRO WHERE D_PARAMETROS_PLANOS.COMPANIA = :COMPANIA AND D_PARAMETROS_PLANOS.GRUPO = :GRUPO AND D_PARAMETROS_PLANOS.CODIGO = :CODIGO AND D_PARAMETROS_PLANOS.SECUENCIA = :SECUENCIA ORDER BY D_PARAMETROS_PLANOS.CODIGO_PARAMETRO) WHERE (CASE WHEN CODIGO_PARAMETRO IS NULL THEN ' ' ELSE UPPER(CODIGO_PARAMETRO) END)  LIKE UPPER(:CODIGO_PARAMETRO || '%')  AND (CASE WHEN NOMBRE_TIPO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO) END)  LIKE UPPER( '%' || :NOMBRE_TIPO || '%')  AND (CASE WHEN ETIQUETA_PARAMETRO IS NULL THEN ' ' ELSE UPPER(ETIQUETA_PARAMETRO) END)  LIKE UPPER( '%' || :ETIQUETA_PARAMETRO || '%')  AND (CASE WHEN VALOR_DEFECTO IS NULL THEN ' ' ELSE UPPER(VALOR_DEFECTO) END)  LIKE UPPER(:VALOR_DEFECTO || '%')  AND (CASE WHEN PORDEFECTO IS NULL THEN ' ' ELSE UPPER(PORDEFECTO) END)  LIKE UPPER( '%' || :PORDEFECTO || '%')  AND (CASE WHEN NOMBRE_FILTRO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FILTRO) END)  LIKE UPPER( '%' || :NOMBRE_FILTRO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="NOMBRE_TIPO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="VALOR_DEFECTO" sqlType="STRING"/>
		<param name="PORDEFECTO" sqlType="STRING"/>
		<param name="NOMBRE_FILTRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dparametrosplanos/numero">
		<call-query href="getDparametrosplanosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="NOMBRE_TIPO" query-param="NOMBRE_TIPO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="VALOR_DEFECTO" query-param="VALOR_DEFECTO"/>
			<with-param name="PORDEFECTO" query-param="PORDEFECTO"/>
			<with-param name="NOMBRE_FILTRO" query-param="NOMBRE_FILTRO"/>

		</call-query>
	</resource>
	<query id="updateDparametrosplanos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_PARAMETROS_PLANOS SET GRUPO=:GRUPO, CODIGO=:CODIGO, SECUENCIA=:SECUENCIA, CODIGO_PARAMETRO=:CODIGO_PARAMETRO, TIPO_PARAMETRO=:TIPO_PARAMETRO, ETIQUETA_PARAMETRO=:ETIQUETA_PARAMETRO, CODIGO_FILTRO=:CODIGO_FILTRO, VALOR_DEFECTO=:VALOR_DEFECTO, PORDEFECTO=:PORDEFECTO, VALOR_FILTRO=:VALOR_FILTRO, VALOR_FILTRO_FECHA=TO_DATE(:VALOR_FILTRO_FECHA,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_PARAMETROS_PLANOS.COMPANIA= :KEY_COMPANIA AND D_PARAMETROS_PLANOS.GRUPO= :KEY_GRUPO AND D_PARAMETROS_PLANOS.CODIGO= :KEY_CODIGO AND D_PARAMETROS_PLANOS.SECUENCIA= :KEY_SECUENCIA AND D_PARAMETROS_PLANOS.CODIGO_PARAMETRO= :KEY_CODIGO_PARAMETRO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="GRUPO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="SECUENCIA" sqlType="STRING"/>
		<param name="CODIGO_PARAMETRO" sqlType="STRING"/>
		<param name="TIPO_PARAMETRO" sqlType="STRING"/>
		<param name="ETIQUETA_PARAMETRO" sqlType="STRING"/>
		<param name="CODIGO_FILTRO" sqlType="STRING"/>
		<param name="VALOR_DEFECTO" sqlType="STRING"/>
		<param name="PORDEFECTO" sqlType="STRING"/>
		<param name="VALOR_FILTRO" sqlType="STRING"/>
		<param name="VALOR_FILTRO_FECHA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_GRUPO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_SECUENCIA" sqlType="STRING"/>
		<param name="KEY_CODIGO_PARAMETRO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="dparametrosplanos">
		<call-query href="updateDparametrosplanos">
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="SECUENCIA" query-param="SECUENCIA"/>
			<with-param name="CODIGO_PARAMETRO" query-param="CODIGO_PARAMETRO"/>
			<with-param name="TIPO_PARAMETRO" query-param="TIPO_PARAMETRO"/>
			<with-param name="ETIQUETA_PARAMETRO" query-param="ETIQUETA_PARAMETRO"/>
			<with-param name="CODIGO_FILTRO" query-param="CODIGO_FILTRO"/>
			<with-param name="VALOR_DEFECTO" query-param="VALOR_DEFECTO"/>
			<with-param name="PORDEFECTO" query-param="PORDEFECTO"/>
			<with-param name="VALOR_FILTRO" query-param="VALOR_FILTRO"/>
			<with-param name="VALOR_FILTRO_FECHA" query-param="VALOR_FILTRO_FECHA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_GRUPO" query-param="KEY_GRUPO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_SECUENCIA" query-param="KEY_SECUENCIA"/>
			<with-param name="KEY_CODIGO_PARAMETRO" query-param="KEY_CODIGO_PARAMETRO"/>

		</call-query>
	</resource>

</data>