	<query id="updateSstcronograma" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SST_CRONOGRAMA SET CODIGO_ACTIVIDAD=:CODIGO_ACTIVIDAD, FECHA_TRANSACCION=TO_DATE(:FECHA_TRANSACCION,'DD/MM/YYYY HH24:MI:SS'), FECHA_INICIAL=TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), HORA_INICIAL=TO_DATE(:HORA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), HORA_FINAL=TO_DATE(:HORA_FINAL,'DD/MM/YYYY HH24:MI:SS'), RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, DURACION=:DURACION, DESCRIPCION=:DESCRIPCION, COSTO_ESTIMADO=:COSTO_ESTIMADO, FECHA_EJECUCION=TO_DATE(:FECHA_EJECUCION,'DD/MM/YYYY HH24:MI:SS'), COBERTURA=:COBERTURA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SST_CRONOGRAMA.COMPANIA= :KEY_COMPANIA AND SST_CRONOGRAMA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="FECHA_TRANSACCION" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="HORA_INICIAL" sqlType="STRING"/>
		<param name="HORA_FINAL" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DURACION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COSTO_ESTIMADO" sqlType="STRING"/>
		<param name="FECHA_EJECUCION" sqlType="STRING"/>
		<param name="COBERTURA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
