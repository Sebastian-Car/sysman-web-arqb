			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>

		</call-query>
	</resource>
	<query id="getSstcronogramaPagResponsablefinQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT TO_NUMBER( SST_CRONOGRAMA.RESPONSABLE)RESPONSABLE, PERSONAL.NOMBRECOMPLETO NOMBRES, SST_CRONOGRAMA.CODIGO_ACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN PERSONAL ON SST_CRONOGRAMA.COMPANIA = PERSONAL.COMPANIA AND SST_CRONOGRAMA.RESPONSABLE = PERSONAL.NUMERO_DCTO AND SST_CRONOGRAMA.SUCURSAL = PERSONAL.SUCURSAL WHERE SST_CRONOGRAMA.COMPANIA =:COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD BETWEEN :ACTIVIDADI AND :ACTIVIDADF AND SST_CRONOGRAMA.RESPONSABLE &gt;= :REPONSABLEI ORDER BY TO_NUMBER( SST_CRONOGRAMA.RESPONSABLE)) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END)  LIKE UPPER( '%' || :CODIGO_ACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE(type:integer)","NOMBRES":"$NOMBRES","CODIGO_ACTIVIDAD":"$CODIGO_ACTIVIDAD(type:integer)"}]}}		</result>
