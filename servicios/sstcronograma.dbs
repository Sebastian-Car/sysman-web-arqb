	<query id="getSstcronogramaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SST_CRONOGRAMA.COMPANIA, SST_CRONOGRAMA.CONSECUTIVO, SST_CRONOGRAMA.CODIGO_ACTIVIDAD,(TO_CHAR(SST_CRONOGRAMA.FECHA_TRANSACCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_TRANSACCION,(TO_CHAR(SST_CRONOGRAMA.FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(SST_CRONOGRAMA.FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL,(TO_CHAR(SST_CRONOGRAMA.HORA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) HORA_INICIAL,(TO_CHAR(SST_CRONOGRAMA.HORA_FINAL,'DD/MM/YYYY HH24:MI:SS')) HORA_FINAL, SST_CRONOGRAMA.RESPONSABLE, SST_CRONOGRAMA.SUCURSAL, SST_CRONOGRAMA.DURACION, SST_CRONOGRAMA.DESCRIPCION, SST_CRONOGRAMA.COSTO_ESTIMADO,(TO_CHAR(SST_CRONOGRAMA.FECHA_EJECUCION,'DD/MM/YYYY HH24:MI:SS')) FECHA_EJECUCION, SST_CRONOGRAMA.CREATED_BY,(TO_CHAR(SST_CRONOGRAMA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SST_CRONOGRAMA.MODIFIED_BY,(TO_CHAR(SST_CRONOGRAMA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD, CONCAT(PERSONAL.NOMBRES,CONCAT(' ',CONCAT(PERSONAL.APELLIDO1,CONCAT(' ',PERSONAL.APELLIDO2) ) ) ) NOMBRERESPONSABLE, PERSONAL.NUMERO_DCTO, PERSONAL.ID_DE_EMPLEADO, SST_CRONOGRAMA.COBERTURA FROM SST_CRONOGRAMA INNER JOIN SST_TIPO_ACTIVIDAD ON SST_CRONOGRAMA.COMPANIA = SST_TIPO_ACTIVIDAD.COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD = SST_TIPO_ACTIVIDAD.CODIGO INNER JOIN PERSONAL ON SST_CRONOGRAMA.COMPANIA = PERSONAL.COMPANIA AND SST_CRONOGRAMA.RESPONSABLE = PERSONAL.NUMERO_DCTO WHERE SST_CRONOGRAMA.COMPANIA= :KEY_COMPANIA AND SST_CRONOGRAMA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","CODIGO_ACTIVIDAD":"$CODIGO_ACTIVIDAD(type:integer)","FECHA_TRANSACCION":"$FECHA_TRANSACCION","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","HORA_INICIAL":"$HORA_INICIAL","HORA_FINAL":"$HORA_FINAL","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","DURACION":"$DURACION(type:integer)","DESCRIPCION":"$DESCRIPCION","COSTO_ESTIMADO":"$COSTO_ESTIMADO","FECHA_EJECUCION":"$FECHA_EJECUCION","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","NOMBRERESPONSABLE":"$NOMBRERESPONSABLE","NUMERO_DCTO":"$NUMERO_DCTO","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","COBERTURA":"$COBERTURA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
