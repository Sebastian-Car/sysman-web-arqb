			<with-param name="ACTIVIDADI" query-param="ACTIVIDADI"/>
			<with-param name="ACTIVIDADF" query-param="ACTIVIDADF"/>
			<with-param name="REPONSABLEI" query-param="REPONSABLEI"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertSstcronograma" keyColumns="COMPANIA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SST_CRONOGRAMA (COMPANIA, CONSECUTIVO, CODIGO_ACTIVIDAD, FECHA_TRANSACCION, FECHA_INICIAL, FECHA_FINAL, HORA_INICIAL, HORA_FINAL, RESPONSABLE, SUCURSAL, DURACION, DESCRIPCION, COSTO_ESTIMADO, FECHA_EJECUCION, COBERTURA, TIPO_TRANSACCION, CONSECUTIVO_TRANSACCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONSECUTIVO, :CODIGO_ACTIVIDAD, TO_DATE(:FECHA_TRANSACCION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_FINAL,'DD/MM/YYYY HH24:MI:SS'), :RESPONSABLE, :SUCURSAL, :DURACION, :DESCRIPCION, :COSTO_ESTIMADO, TO_DATE(:FECHA_EJECUCION,'DD/MM/YYYY HH24:MI:SS'), :COBERTURA, :TIPO_TRANSACCION, :CONSECUTIVO_TRANSACCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="FECHA_TRANSACCION" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="HORA_INICIAL" sqlType="STRING"/>
		<param name="HORA_FINAL" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="DURACION" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="COSTO_ESTIMADO" sqlType="STRING"/>
		<param name="FECHA_EJECUCION" sqlType="STRING"/>
		<param defaultValue="" name="COBERTURA" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param defaultValue="" name="CONSECUTIVO_TRANSACCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sstcronograma">
		<call-query href="insertSstcronograma">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="FECHA_TRANSACCION" query-param="FECHA_TRANSACCION"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="HORA_INICIAL" query-param="HORA_INICIAL"/>
			<with-param name="HORA_FINAL" query-param="HORA_FINAL"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DURACION" query-param="DURACION"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COSTO_ESTIMADO" query-param="COSTO_ESTIMADO"/>
			<with-param name="FECHA_EJECUCION" query-param="FECHA_EJECUCION"/>
			<with-param name="COBERTURA" query-param="COBERTURA"/>
