	<query id="getSstcronogramaNumResponsablefinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT TO_NUMBER( SST_CRONOGRAMA.RESPONSABLE)RESPONSABLE, PERSONAL.NOMBRECOMPLETO NOMBRES, SST_CRONOGRAMA.CODIGO_ACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN PERSONAL ON SST_CRONOGRAMA.COMPANIA = PERSONAL.COMPANIA AND SST_CRONOGRAMA.RESPONSABLE = PERSONAL.NUMERO_DCTO AND SST_CRONOGRAMA.SUCURSAL = PERSONAL.SUCURSAL WHERE SST_CRONOGRAMA.COMPANIA =:COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD BETWEEN :ACTIVIDADI AND :ACTIVIDADF AND SST_CRONOGRAMA.RESPONSABLE &gt;= :REPONSABLEI ORDER BY TO_NUMBER( SST_CRONOGRAMA.RESPONSABLE)) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END)  LIKE UPPER( '%' || :CODIGO_ACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACTIVIDADI" sqlType="STRING"/>
		<param name="ACTIVIDADF" sqlType="STRING"/>
		<param name="REPONSABLEI" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstcronograma/responsablefin/num">
		<call-query href="getSstcronogramaNumResponsablefinQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACTIVIDADI" query-param="ACTIVIDADI"/>
			<with-param name="ACTIVIDADF" query-param="ACTIVIDADF"/>
			<with-param name="REPONSABLEI" query-param="REPONSABLEI"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="getSstcronogramaPagResponsableinilQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT TO_NUMBER(SST_CRONOGRAMA.RESPONSABLE) RESPONSABLE, PERSONAL.NOMBRECOMPLETO NOMBRES, SST_CRONOGRAMA.CODIGO_ACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN PERSONAL ON SST_CRONOGRAMA.COMPANIA = PERSONAL.COMPANIA AND SST_CRONOGRAMA.RESPONSABLE = PERSONAL.NUMERO_DCTO AND SST_CRONOGRAMA.SUCURSAL = PERSONAL.SUCURSAL WHERE SST_CRONOGRAMA.COMPANIA = :COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD BETWEEN :ACTIVIDADI AND :ACTIVIDADF ORDER BY TO_NUMBER(SST_CRONOGRAMA.RESPONSABLE)) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END)  LIKE UPPER( '%' || :CODIGO_ACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE(type:integer)","NOMBRES":"$NOMBRES","CODIGO_ACTIVIDAD":"$CODIGO_ACTIVIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACTIVIDADI" sqlType="STRING"/>
		<param name="ACTIVIDADF" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sstcronograma/responsableinil/pag">
		<call-query href="getSstcronogramaPagResponsableinilQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ACTIVIDADI" query-param="ACTIVIDADI"/>
			<with-param name="ACTIVIDADF" query-param="ACTIVIDADF"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="NOMBRES" query-param="NOMBRES"/>
			<with-param name="CODIGO_ACTIVIDAD" query-param="CODIGO_ACTIVIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSstcronogramaNumResponsableinilQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT TO_NUMBER(SST_CRONOGRAMA.RESPONSABLE) RESPONSABLE, PERSONAL.NOMBRECOMPLETO NOMBRES, SST_CRONOGRAMA.CODIGO_ACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN PERSONAL ON SST_CRONOGRAMA.COMPANIA = PERSONAL.COMPANIA AND SST_CRONOGRAMA.RESPONSABLE = PERSONAL.NUMERO_DCTO AND SST_CRONOGRAMA.SUCURSAL = PERSONAL.SUCURSAL WHERE SST_CRONOGRAMA.COMPANIA = :COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD BETWEEN :ACTIVIDADI AND :ACTIVIDADF ORDER BY TO_NUMBER(SST_CRONOGRAMA.RESPONSABLE)) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%')  AND (CASE WHEN CODIGO_ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(CODIGO_ACTIVIDAD) END)  LIKE UPPER( '%' || :CODIGO_ACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACTIVIDADI" sqlType="STRING"/>
		<param name="ACTIVIDADF" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODIGO_ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sstcronograma/responsableinil/num">
