	<query id="getSstcronogramaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SST_CRONOGRAMA.COMPANIA, SST_CRONOGRAMA.CONSECUTIVO, SST_CRONOGRAMA.CODIGO_ACTIVIDAD, TO_CHAR(SST_CRONOGRAMA.FECHA_TRANSACCION,'DD/MM/YYYY') FECHA_TRANSACCION, TO_CHAR(SST_CRONOGRAMA.FECHA_INICIAL,'DD/MM/YYYY') FECHA_INICIAL, TO_CHAR(SST_CRONOGRAMA.FECHA_FINAL,'DD/MM/YYYY') FECHA_FINAL, SST_CRONOGRAMA.COSTO_ESTIMADO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN SST_TIPO_ACTIVIDAD ON SST_CRONOGRAMA.COMPANIA = SST_TIPO_ACTIVIDAD.COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD = SST_TIPO_ACTIVIDAD.CODIGO AND SST_CRONOGRAMA.TIPO_TRANSACCION = SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION WHERE SST_CRONOGRAMA.COMPANIA = :COMPANIA AND SST_CRONOGRAMA.TIPO_TRANSACCION = :TIPO_TRANSACCION) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA_TRANSACCION IS NULL THEN ' ' ELSE UPPER(FECHA_TRANSACCION) END)  LIKE UPPER( '%' || :FECHA_TRANSACCION || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER( '%' || :FECHA_INICIAL || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN COSTO_ESTIMADO IS NULL THEN ' ' ELSE UPPER(COSTO_ESTIMADO) END)  LIKE UPPER( '%' || :COSTO_ESTIMADO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
