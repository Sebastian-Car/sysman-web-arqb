	<query id="getSstcronogramaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SST_CRONOGRAMA.COMPANIA, SST_CRONOGRAMA.CONSECUTIVO, SST_CRONOGRAMA.CODIGO_ACTIVIDAD, TO_CHAR(SST_CRONOGRAMA.FECHA_TRANSACCION,'DD/MM/YYYY') FECHA_TRANSACCION, TO_CHAR(SST_CRONOGRAMA.FECHA_INICIAL,'DD/MM/YYYY') FECHA_INICIAL, TO_CHAR(SST_CRONOGRAMA.FECHA_FINAL,'DD/MM/YYYY') FECHA_FINAL, SST_CRONOGRAMA.COSTO_ESTIMADO, SST_TIPO_ACTIVIDAD.NOMBRE NOMBREACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN SST_TIPO_ACTIVIDAD ON SST_CRONOGRAMA.COMPANIA = SST_TIPO_ACTIVIDAD.COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD = SST_TIPO_ACTIVIDAD.CODIGO AND SST_CRONOGRAMA.TIPO_TRANSACCION = SST_TIPO_ACTIVIDAD.TIPO_TRANSACCION WHERE SST_CRONOGRAMA.COMPANIA = :COMPANIA AND SST_CRONOGRAMA.TIPO_TRANSACCION = :TIPO_TRANSACCION) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN FECHA_TRANSACCION IS NULL THEN ' ' ELSE UPPER(FECHA_TRANSACCION) END)  LIKE UPPER( '%' || :FECHA_TRANSACCION || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER( '%' || :FECHA_INICIAL || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER( '%' || :FECHA_FINAL || '%')  AND (CASE WHEN COSTO_ESTIMADO IS NULL THEN ' ' ELSE UPPER(COSTO_ESTIMADO) END)  LIKE UPPER( '%' || :COSTO_ESTIMADO || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","CODIGO_ACTIVIDAD":"$CODIGO_ACTIVIDAD(type:integer)","FECHA_TRANSACCION":"$FECHA_TRANSACCION","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","COSTO_ESTIMADO":"$COSTO_ESTIMADO","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA_TRANSACCION" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="COSTO_ESTIMADO" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
