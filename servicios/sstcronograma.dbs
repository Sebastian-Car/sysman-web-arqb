	<query id="getSstcronogramaPagRespFinNomCodActIniFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SST_CRONOGRAMA.RESPONSABLE, PERSONAL.NOMBRECOMPLETO NOMBRES, SST_CRONOGRAMA.CODIGO_ACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN PERSONAL ON SST_CRONOGRAMA.COMPANIA = PERSONAL.COMPANIA AND SST_CRONOGRAMA.RESPONSABLE = PERSONAL.NUMERO_DCTO AND SST_CRONOGRAMA.SUCURSAL = PERSONAL.SUCURSAL WHERE SST_CRONOGRAMA.COMPANIA = :COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD BETWEEN :ACTIVIDADI AND :ACTIVIDADF AND SST_CRONOGRAMA.RESPONSABLE = :REPONSABLEI ORDER BY SST_CRONOGRAMA.RESPONSABLE) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RESPONSABLE":"$RESPONSABLE","NOMBRES":"$NOMBRES","CODIGO_ACTIVIDAD":"$CODIGO_ACTIVIDAD(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ACTIVIDADI" sqlType="STRING"/>
		<param name="ACTIVIDADF" sqlType="STRING"/>
		<param name="REPONSABLEI" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
