	<query id="getSstcronogramaNumRespNomCodActIniFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT SST_CRONOGRAMA.RESPONSABLE, PERSONAL.NOMBRECOMPLETO NOMBRES, SST_CRONOGRAMA.CODIGO_ACTIVIDAD  FROM SST_CRONOGRAMA INNER JOIN PERSONAL ON SST_CRONOGRAMA.COMPANIA = PERSONAL.COMPANIA AND SST_CRONOGRAMA.RESPONSABLE = PERSONAL.NUMERO_DCTO AND SST_CRONOGRAMA.SUCURSAL = PERSONAL.SUCURSAL WHERE SST_CRONOGRAMA.COMPANIA = :COMPANIA AND SST_CRONOGRAMA.CODIGO_ACTIVIDAD BETWEEN :ACTIVIDADI AND :ACTIVIDADF ORDER BY SST_CRONOGRAMA.RESPONSABLE) WHERE (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END)  LIKE UPPER( '%' || :NOMBRES || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
