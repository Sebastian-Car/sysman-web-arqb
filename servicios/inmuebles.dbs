<data name="inmuebles" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getInmueblesPagListadodeinmueblesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DENOMINACION, NOMBRE_INMUEBLE  FROM INMUEBLES WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER(:DENOMINACION || '%')  AND (CASE WHEN NOMBRE_INMUEBLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_INMUEBLE) END)  LIKE UPPER( '%' || :NOMBRE_INMUEBLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DENOMINACION":"$DENOMINACION","NOMBRE_INMUEBLE":"$NOMBRE_INMUEBLE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="NOMBRE_INMUEBLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="inmuebles/listadodeinmuebles/pag">
		<call-query href="getInmueblesPagListadodeinmueblesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="NOMBRE_INMUEBLE" query-param="NOMBRE_INMUEBLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getInmueblesNumListadodeinmueblesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DENOMINACION, NOMBRE_INMUEBLE  FROM INMUEBLES WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN DENOMINACION IS NULL THEN ' ' ELSE UPPER(DENOMINACION) END)  LIKE UPPER(:DENOMINACION || '%')  AND (CASE WHEN NOMBRE_INMUEBLE IS NULL THEN ' ' ELSE UPPER(NOMBRE_INMUEBLE) END)  LIKE UPPER( '%' || :NOMBRE_INMUEBLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DENOMINACION" sqlType="STRING"/>
		<param name="NOMBRE_INMUEBLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="inmuebles/listadodeinmuebles/num">
		<call-query href="getInmueblesNumListadodeinmueblesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DENOMINACION" query-param="DENOMINACION"/>
			<with-param name="NOMBRE_INMUEBLE" query-param="NOMBRE_INMUEBLE"/>

		</call-query>
	</resource>

</data>