<data name="estipocontratos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEstipocontratosTipoContratosPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_TIPOCONTRATO.COD_T_CONTRATO, ES_TIPOCONTRATO.NOMBRE  FROM ES_TIPOCONTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_T_CONTRATO":"$COD_T_CONTRATO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="estipocontratos/tipocontratospornombre">
		<call-query href="getEstipocontratosTipoContratosPorNombreQuery">
 
		</call-query>
	</resource>
	<query id="getEstipocontratosCodtcontratoynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COD_T_CONTRATO, NOMBRE  FROM ES_TIPOCONTRATO WHERE COMPANIA = :COMPANIA ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_T_CONTRATO":"$COD_T_CONTRATO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estipocontratos/codtcontratoynombre">
		<call-query href="getEstipocontratosCodtcontratoynombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosPagCodtcontratoynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COD_T_CONTRATO, NOMBRE  FROM ES_TIPOCONTRATO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END)  LIKE UPPER(:COD_T_CONTRATO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_T_CONTRATO":"$COD_T_CONTRATO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estipocontratos/codtcontratoynombre/pag">
		<call-query href="getEstipocontratosPagCodtcontratoynombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosNumCodtcontratoynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COD_T_CONTRATO, NOMBRE  FROM ES_TIPOCONTRATO WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END)  LIKE UPPER(:COD_T_CONTRATO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estipocontratos/codtcontratoynombre/num">
		<call-query href="getEstipocontratosNumCodtcontratoynombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosCodtnombreaplicacritQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COD_T_CONTRATO, NOMBRE  FROM ES_TIPOCONTRATO WHERE COMPANIA = :COMPANIA AND APLICA_CRITERIOS NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_T_CONTRATO":"$COD_T_CONTRATO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estipocontratos/codtnombreaplicacrit">
		<call-query href="getEstipocontratosCodtnombreaplicacritQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosPagGrillaPrecontractualQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ES_TIPOCONTRATO.COMPANIA, ES_TIPOCONTRATO.COD_T_CONTRATO, CONCAT(ES_TIPOCONTRATO.CODIGOCONTRATO ,CONCAT( ' - ' , ES_TIPOCONTRATO.NOMBRE)) MODALIDAD, ES_TIPOCONTRATO.FUNDAMENTACION FROM ES_TIPOCONTRATO WHERE ES_TIPOCONTRATO.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END) LIKE UPPER(CONCAT(:COD_T_CONTRATO, '%')) AND (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:MODALIDAD), '%')) AND (CASE WHEN FUNDAMENTACION IS NULL THEN ' ' ELSE UPPER(FUNDAMENTACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FUNDAMENTACION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_T_CONTRATO":"$COD_T_CONTRATO","MODALIDAD":"$MODALIDAD","FUNDAMENTACION":"$FUNDAMENTACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="FUNDAMENTACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estipocontratos/grillaprecontractual/pag">
		<call-query href="getEstipocontratosPagGrillaPrecontractualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="FUNDAMENTACION" query-param="FUNDAMENTACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosNumGrillaPrecontractualQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ES_TIPOCONTRATO.COMPANIA, ES_TIPOCONTRATO.COD_T_CONTRATO, CONCAT(ES_TIPOCONTRATO.CODIGOCONTRATO ,CONCAT( ' - ' , ES_TIPOCONTRATO.NOMBRE)) MODALIDAD, ES_TIPOCONTRATO.FUNDAMENTACION FROM ES_TIPOCONTRATO WHERE ES_TIPOCONTRATO.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END) LIKE UPPER(CONCAT(:COD_T_CONTRATO, '%')) AND (CASE WHEN MODALIDAD IS NULL THEN ' ' ELSE UPPER(MODALIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:MODALIDAD), '%')) AND (CASE WHEN FUNDAMENTACION IS NULL THEN ' ' ELSE UPPER(FUNDAMENTACION) END) LIKE UPPER(CONCAT(CONCAT('%',:FUNDAMENTACION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="MODALIDAD" sqlType="STRING"/>
		<param name="FUNDAMENTACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estipocontratos/grillaprecontractual/num">
		<call-query href="getEstipocontratosNumGrillaPrecontractualQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="MODALIDAD" query-param="MODALIDAD"/>
			<with-param name="FUNDAMENTACION" query-param="FUNDAMENTACION"/>

		</call-query>
	</resource>
	<query id="updateEstipocontratosModalidadPrecontratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_TIPOCONTRATO SET FUNDAMENTACION=:FUNDAMENTACION, COMPANIA=:COMPANIA, COD_T_CONTRATO=:COD_T_CONTRATO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_TIPOCONTRATO.COMPANIA= :KEY_COMPANIA AND ES_TIPOCONTRATO.COD_T_CONTRATO= :KEY_COD_T_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FUNDAMENTACION" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_T_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="estipocontratos/modalidadprecontratos">
		<call-query href="updateEstipocontratosModalidadPrecontratos">
			<with-param name="FUNDAMENTACION" query-param="FUNDAMENTACION"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_T_CONTRATO" query-param="KEY_COD_T_CONTRATO"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosFundamentacionPorCotratoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_TIPOCONTRATO.FUNDAMENTACION  FROM ES_TIPOCONTRATO WHERE ES_TIPOCONTRATO.COMPANIA = :COMPANIA AND ES_TIPOCONTRATO.COD_T_CONTRATO= :COD_T_CONTRATO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FUNDAMENTACION":"$FUNDAMENTACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estipocontratos/fundamentacionporcotrato">
		<call-query href="getEstipocontratosFundamentacionPorCotratoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>

		</call-query>
	</resource>
	<query id="insertEstipocontratos" keyColumns="COMPANIA,COD_T_CONTRATO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_TIPOCONTRATO (COMPANIA, COD_T_CONTRATO, NOMBRE, CODIGOCONTRATO, APLICA_CRITERIOS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_T_CONTRATO, :NOMBRE, :CODIGOCONTRATO, :APLICA_CRITERIOS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_T_CONTRATO":"$COD_T_CONTRATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCONTRATO" sqlType="STRING"/>
		<param defaultValue="0" name="APLICA_CRITERIOS" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="estipocontratos">
		<call-query href="insertEstipocontratos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGOCONTRATO" query-param="CODIGOCONTRATO"/>
			<with-param name="APLICA_CRITERIOS" query-param="APLICA_CRITERIOS"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEstipocontratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_TIPOCONTRATO WHERE ES_TIPOCONTRATO.COMPANIA= :KEY_COMPANIA AND ES_TIPOCONTRATO.COD_T_CONTRATO= :KEY_COD_T_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_T_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="estipocontratos">
		<call-query href="deleteEstipocontratos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_T_CONTRATO" query-param="KEY_COD_T_CONTRATO"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, COD_T_CONTRATO, NOMBRE, CODIGOCONTRATO,(CASE APLICA_CRITERIOS WHEN 0 THEN 'false' ELSE 'true' END) APLICA_CRITERIOS FROM ES_TIPOCONTRATO WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_T_CONTRATO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGOCONTRATO IS NULL THEN ' ' ELSE UPPER(CODIGOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCONTRATO), '%')) AND (CASE WHEN APLICA_CRITERIOS IS NULL THEN ' ' ELSE UPPER(APLICA_CRITERIOS) END) LIKE UPPER(CONCAT(:APLICA_CRITERIOS, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_T_CONTRATO":"$COD_T_CONTRATO","NOMBRE":"$NOMBRE","CODIGOCONTRATO":"$CODIGOCONTRATO","APLICA_CRITERIOS":"$APLICA_CRITERIOS(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOCONTRATO" sqlType="STRING"/>
		<param name="APLICA_CRITERIOS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estipocontratos">
		<call-query href="getEstipocontratosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGOCONTRATO" query-param="CODIGOCONTRATO"/>
			<with-param name="APLICA_CRITERIOS" query-param="APLICA_CRITERIOS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, COD_T_CONTRATO, NOMBRE, CODIGOCONTRATO,(CASE APLICA_CRITERIOS WHEN 0 THEN 'false' ELSE 'true' END) APLICA_CRITERIOS FROM ES_TIPOCONTRATO WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:COD_T_CONTRATO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGOCONTRATO IS NULL THEN ' ' ELSE UPPER(CODIGOCONTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCONTRATO), '%')) AND (CASE WHEN APLICA_CRITERIOS IS NULL THEN ' ' ELSE UPPER(APLICA_CRITERIOS) END) LIKE UPPER(CONCAT(:APLICA_CRITERIOS, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOCONTRATO" sqlType="STRING"/>
		<param name="APLICA_CRITERIOS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estipocontratos/numero">
		<call-query href="getEstipocontratosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGOCONTRATO" query-param="CODIGOCONTRATO"/>
			<with-param name="APLICA_CRITERIOS" query-param="APLICA_CRITERIOS"/>

		</call-query>
	</resource>
	<query id="updateEstipocontratos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_TIPOCONTRATO SET COD_T_CONTRATO=:COD_T_CONTRATO, NOMBRE=:NOMBRE, CODIGOCONTRATO=:CODIGOCONTRATO, APLICA_CRITERIOS=:APLICA_CRITERIOS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_TIPOCONTRATO.COMPANIA= :KEY_COMPANIA AND ES_TIPOCONTRATO.COD_T_CONTRATO= :KEY_COD_T_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOCONTRATO" sqlType="STRING"/>
		<param name="APLICA_CRITERIOS" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_T_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="estipocontratos">
		<call-query href="updateEstipocontratos">
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGOCONTRATO" query-param="CODIGOCONTRATO"/>
			<with-param name="APLICA_CRITERIOS" query-param="APLICA_CRITERIOS"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_T_CONTRATO" query-param="KEY_COD_T_CONTRATO"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COD_T_CONTRATO,NOMBRE  FROM ES_TIPOCONTRATO WHERE ES_TIPOCONTRATO.COMPANIA = :COMPANIA) WHERE (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END)  LIKE UPPER(:COD_T_CONTRATO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COD_T_CONTRATO":"$COD_T_CONTRATO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estipocontratos/todosporcompania/pag">
		<call-query href="getEstipocontratosPagTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_T_CONTRATO" query-param="COD_T_CONTRATO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEstipocontratosNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COD_T_CONTRATO,NOMBRE  FROM ES_TIPOCONTRATO WHERE ES_TIPOCONTRATO.COMPANIA = :COMPANIA) WHERE (CASE WHEN COD_T_CONTRATO IS NULL THEN ' ' ELSE UPPER(COD_T_CONTRATO) END)  LIKE UPPER(:COD_T_CONTRATO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_T_CONTRATO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="estipocontratos/todosporcompania/num">
		<call-query href="getEstipocontratosNumTodosPorCompaniaQuery">
