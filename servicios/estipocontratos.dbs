	<query id="getEstipocontratosPagCodnompordependenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT ES_ESTPREVIO.COD_ESTUDIO ESTUDIOPREVIO, ES_TIPOCONTRATO.CODIGOCONTRATO, ES_ESTPREVIO.NOMBRE_ESTUDIO, TO_CHAR(ES_ESTPREVIO.FECHA, 'YYYY') VIGENCIA  FROM ES_TIPOCONTRATO INNER JOIN ES_ESTPREVIO ON ES_TIPOCONTRATO.COMPANIA = ES_ESTPREVIO.COMPANIA AND ES_TIPOCONTRATO.COD_T_CONTRATO = ES_ESTPREVIO.TIPO_CONTRATO LEFT JOIN TRANSACCION ON ES_ESTPREVIO.COMPANIA = TRANSACCION.COMPANIA AND ES_ESTPREVIO.COD_ESTUDIO = TRANSACCION.ESTUDIOPREVIO WHERE ES_ESTPREVIO.COMPANIA = :COMPANIA AND ES_TIPOCONTRATO.CODIGOCONTRATO = :TIPO_CONTRATO AND ES_ESTPREVIO.DEPENDENCIA = :DEPENDENCIA AND ES_ESTPREVIO.VOBO NOT IN(0) ORDER BY COD_ESTUDIO) WHERE (CASE WHEN ESTUDIOPREVIO IS NULL THEN ' ' ELSE UPPER(ESTUDIOPREVIO) END)  LIKE UPPER(:ESTUDIOPREVIO || '%')  AND (CASE WHEN NOMBRE_ESTUDIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_ESTUDIO) END)  LIKE UPPER( '%' || :NOMBRE_ESTUDIO || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ESTUDIOPREVIO":"$ESTUDIOPREVIO","CODIGOCONTRATO":"$CODIGOCONTRATO","NOMBRE_ESTUDIO":"$NOMBRE_ESTUDIO","VIGENCIA":"$VIGENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="ESTUDIOPREVIO" sqlType="STRING"/>
		<param name="NOMBRE_ESTUDIO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="estipocontratos/codnompordependencia/pag">
