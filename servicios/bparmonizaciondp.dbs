	<query id="deleteBparmonizaciondp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_ARMONIZACIONPD WHERE BP_ARMONIZACIONPD.COMPANIA= :KEY_COMPANIA AND BP_ARMONIZACIONPD.VIGENCIA_PLAN= :KEY_VIGENCIA_PLAN AND BP_ARMONIZACIONPD.VIGENCIA_META= :KEY_VIGENCIA_META AND BP_ARMONIZACIONPD.ID_META= :KEY_ID_META AND BP_ARMONIZACIONPD.VIGENCIA_RUBRO= :KEY_VIGENCIA_RUBRO AND BP_ARMONIZACIONPD.ID_RUBRO= :KEY_ID_RUBRO AND BP_ARMONIZACIONPD.FUENTE= :KEY_FUENTE AND BP_ARMONIZACIONPD.CENTROCOSTO= :KEY_CENTROCOSTO AND BP_ARMONIZACIONPD.REFERENCIA= :KEY_REFERENCIA AND BP_ARMONIZACIONPD.AUXILIARGENERAL= :KEY_AUXILIARGENERAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
