<data name="bparmonizaciondp" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBparmonizaciondpPagIdrubrofuenterQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT V_RESUMENPPTO_BASE.ID ID, V_RESUMENPPTO_BASE.CODIGO CODIGO, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO, V_RESUMENPPTO_BASE.AUXILIAR, V_RESUMENPPTO_BASE.REFERENCIA, V_RESUMENPPTO_BASE.CENTRO_COSTO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD + V_RESUMENPPTO_BASE.REINTEGRO) SALDO, SUM(V_RESUMENPPTO_BASE.REINTEGRO) REINTEGRO, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD - V_RESUMENPPTO_BASE.COMPROMISOSACUM) SALDODIS, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) TOTALDIS,PLAN_PRESUPUESTAL.CLASECLASIFICADOR FROM V_RESUMENPPTO_BASE INNER JOIN PLAN_PRESUPUESTAL ON V_RESUMENPPTO_BASE.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND V_RESUMENPPTO_BASE.ANO = PLAN_PRESUPUESTAL.ANO AND V_RESUMENPPTO_BASE.CODIGO = PLAN_PRESUPUESTAL.CODIGO INNER JOIN BP_PROYECTOSRUBROS ON V_RESUMENPPTO_BASE.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND V_RESUMENPPTO_BASE.CODIGO = BP_PROYECTOSRUBROS.RUBROPPTALES AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_FUE NOT IN ( 0 ) THEN BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO ELSE '99999999999999999999' END INNER JOIN FUENTE_RECURSOS ON V_RESUMENPPTO_BASE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = FUENTE_RECURSOS.ANO AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO INNER JOIN BP_ARMONIZACIONPD ON BP_PROYECTOSRUBROS.COMPANIA = BP_ARMONIZACIONPD.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = BP_ARMONIZACIONPD.VIGENCIA_RUBRO AND BP_PROYECTOSRUBROS.RUBROPPTALES = BP_ARMONIZACIONPD.ID_RUBRO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = BP_ARMONIZACIONPD.FUENTE WHERE V_RESUMENPPTO_BASE.COMPANIA = :COMPANIA AND V_RESUMENPPTO_BASE.ANO = :VIGENCIA AND V_RESUMENPPTO_BASE.DESTINO IN ( 'I', 'L' ) AND V_RESUMENPPTO_BASE.NATURALEZA IN ( 'D' ) AND V_RESUMENPPTO_BASE.MES &lt;= TO_CHAR(SYSDATE, 'MM') AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = :FUENTE AND BP_ARMONIZACIONPD.ID_META = :ID_META GROUP BY V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.CODIGO, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO, V_RESUMENPPTO_BASE.AUXILIAR, V_RESUMENPPTO_BASE.REFERENCIA, V_RESUMENPPTO_BASE.CENTRO_COSTO,PLAN_PRESUPUESTAL.CLASECLASIFICADOR) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FUENTERECURSOSRUBRO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBRO) END) LIKE UPPER(CONCAT(:FUENTERECURSOSRUBRO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN REINTEGRO IS NULL THEN ' ' ELSE UPPER(REINTEGRO) END) LIKE UPPER(CONCAT(:REINTEGRO, '%')) AND (CASE WHEN SALDODIS IS NULL THEN ' ' ELSE UPPER(SALDODIS) END) LIKE UPPER(CONCAT(:SALDODIS, '%')) AND (CASE WHEN TOTALDIS IS NULL THEN ' ' ELSE UPPER(TOTALDIS) END) LIKE UPPER(CONCAT(:TOTALDIS, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","FUENTERECURSOSRUBRO":"$FUENTERECURSOSRUBRO","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","CENTRO_COSTO":"$CENTRO_COSTO","SALDO":"$SALDO","REINTEGRO":"$REINTEGRO","SALDODIS":"$SALDODIS","TOTALDIS":"$TOTALDIS","CLASECLASIFICADOR":"$CLASECLASIFICADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ID_META" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="REINTEGRO" sqlType="STRING"/>
		<param name="SALDODIS" sqlType="STRING"/>
		<param name="TOTALDIS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bparmonizaciondp/idrubrofuenter/pag">
		<call-query href="getBparmonizaciondpPagIdrubrofuenterQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="ID_META" query-param="ID_META"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FUENTERECURSOSRUBRO" query-param="FUENTERECURSOSRUBRO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="REINTEGRO" query-param="REINTEGRO"/>
			<with-param name="SALDODIS" query-param="SALDODIS"/>
			<with-param name="TOTALDIS" query-param="TOTALDIS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBparmonizaciondpNumIdrubrofuenterQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT V_RESUMENPPTO_BASE.ID ID, V_RESUMENPPTO_BASE.CODIGO CODIGO, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO, V_RESUMENPPTO_BASE.AUXILIAR, V_RESUMENPPTO_BASE.REFERENCIA, V_RESUMENPPTO_BASE.CENTRO_COSTO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD + V_RESUMENPPTO_BASE.REINTEGRO) SALDO, SUM(V_RESUMENPPTO_BASE.REINTEGRO) REINTEGRO, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD - V_RESUMENPPTO_BASE.COMPROMISOSACUM) SALDODIS, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) TOTALDIS,PLAN_PRESUPUESTAL.CLASECLASIFICADOR FROM V_RESUMENPPTO_BASE INNER JOIN PLAN_PRESUPUESTAL ON V_RESUMENPPTO_BASE.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND V_RESUMENPPTO_BASE.ANO = PLAN_PRESUPUESTAL.ANO AND V_RESUMENPPTO_BASE.CODIGO = PLAN_PRESUPUESTAL.CODIGO INNER JOIN BP_PROYECTOSRUBROS ON V_RESUMENPPTO_BASE.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND V_RESUMENPPTO_BASE.CODIGO = BP_PROYECTOSRUBROS.RUBROPPTALES AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = CASE WHEN PLAN_PRESUPUESTAL.MAN_AUX_FUE NOT IN ( 0 ) THEN BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO ELSE '99999999999999999999' END INNER JOIN FUENTE_RECURSOS ON V_RESUMENPPTO_BASE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = FUENTE_RECURSOS.ANO AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = FUENTE_RECURSOS.CODIGO INNER JOIN BP_ARMONIZACIONPD ON BP_PROYECTOSRUBROS.COMPANIA = BP_ARMONIZACIONPD.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = BP_ARMONIZACIONPD.VIGENCIA_RUBRO AND BP_PROYECTOSRUBROS.RUBROPPTALES = BP_ARMONIZACIONPD.ID_RUBRO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = BP_ARMONIZACIONPD.FUENTE WHERE V_RESUMENPPTO_BASE.COMPANIA = :COMPANIA AND V_RESUMENPPTO_BASE.ANO = :VIGENCIA AND V_RESUMENPPTO_BASE.DESTINO IN ( 'I', 'L' ) AND V_RESUMENPPTO_BASE.NATURALEZA IN ( 'D' ) AND V_RESUMENPPTO_BASE.MES &lt;= TO_CHAR(SYSDATE, 'MM') AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = :FUENTE AND BP_ARMONIZACIONPD.ID_META = :ID_META GROUP BY V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.CODIGO, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO, V_RESUMENPPTO_BASE.AUXILIAR, V_RESUMENPPTO_BASE.REFERENCIA, V_RESUMENPPTO_BASE.CENTRO_COSTO,PLAN_PRESUPUESTAL.CLASECLASIFICADOR) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FUENTERECURSOSRUBRO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBRO) END) LIKE UPPER(CONCAT(:FUENTERECURSOSRUBRO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) AND (CASE WHEN REINTEGRO IS NULL THEN ' ' ELSE UPPER(REINTEGRO) END) LIKE UPPER(CONCAT(:REINTEGRO, '%')) AND (CASE WHEN SALDODIS IS NULL THEN ' ' ELSE UPPER(SALDODIS) END) LIKE UPPER(CONCAT(:SALDODIS, '%')) AND (CASE WHEN TOTALDIS IS NULL THEN ' ' ELSE UPPER(TOTALDIS) END) LIKE UPPER(CONCAT(:TOTALDIS, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ID_META" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="REINTEGRO" sqlType="STRING"/>
		<param name="SALDODIS" sqlType="STRING"/>
		<param name="TOTALDIS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bparmonizaciondp/idrubrofuenter/num">
		<call-query href="getBparmonizaciondpNumIdrubrofuenterQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="ID_META" query-param="ID_META"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FUENTERECURSOSRUBRO" query-param="FUENTERECURSOSRUBRO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="REINTEGRO" query-param="REINTEGRO"/>
