	<query id="updateBparmonizaciondp" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_ARMONIZACIONPD SET ID_META=:ID_META, ID_RUBRO=:ID_RUBRO, FUENTE=:FUENTE, CENTROCOSTO=:CENTROCOSTO, REFERENCIA=:REFERENCIA, AUXILIARGENERAL=:AUXILIARGENERAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_ARMONIZACIONPD.COMPANIA= :KEY_COMPANIA AND BP_ARMONIZACIONPD.VIGENCIA_PLAN= :KEY_VIGENCIA_PLAN AND BP_ARMONIZACIONPD.VIGENCIA_META= :KEY_VIGENCIA_META AND BP_ARMONIZACIONPD.ID_META= :KEY_ID_META AND BP_ARMONIZACIONPD.VIGENCIA_RUBRO= :KEY_VIGENCIA_RUBRO AND BP_ARMONIZACIONPD.ID_RUBRO= :KEY_ID_RUBRO AND BP_ARMONIZACIONPD.FUENTE= :KEY_FUENTE AND BP_ARMONIZACIONPD.CENTROCOSTO= :KEY_CENTROCOSTO AND BP_ARMONIZACIONPD.REFERENCIA= :KEY_REFERENCIA AND BP_ARMONIZACIONPD.AUXILIARGENERAL= :KEY_AUXILIARGENERAL</sql>
