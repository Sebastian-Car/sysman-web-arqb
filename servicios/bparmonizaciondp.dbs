	<query id="getBparmonizaciondpPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BP_ARMONIZACIONPD.COMPANIA, BP_ARMONIZACIONPD.VIGENCIA_PLAN, BP_ARMONIZACIONPD.VIGENCIA_META, BP_ARMONIZACIONPD.ID_META, BP_PLAN_INDICATIVO_METAS.DESCRIPCION DESCRIPCION_PLAN_IND, BP_ARMONIZACIONPD.FUENTE, BP_ARMONIZACIONPD.CENTROCOSTO, BP_ARMONIZACIONPD.REFERENCIA, BP_ARMONIZACIONPD.AUXILIARGENERAL, BP_ARMONIZACIONPD.VIGENCIA_RUBRO, BP_ARMONIZACIONPD.ID_RUBRO, BP_RUBRO_INVERSION_DET.DESCRIPCION DESCRIPCION_RUBRO FROM BP_ARMONIZACIONPD LEFT JOIN BP_PLAN_INDICATIVO_METAS ON BP_ARMONIZACIONPD.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA AND BP_ARMONIZACIONPD.ID_META = BP_PLAN_INDICATIVO_METAS.ID_PLAN AND BP_ARMONIZACIONPD.VIGENCIA_PLAN= BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN AND BP_ARMONIZACIONPD.VIGENCIA_META= BP_PLAN_INDICATIVO_METAS.VIGENCIA_META LEFT JOIN BP_RUBRO_INVERSION_DET ON BP_ARMONIZACIONPD.COMPANIA = BP_RUBRO_INVERSION_DET.COMPANIA AND BP_ARMONIZACIONPD.ID_RUBRO = BP_RUBRO_INVERSION_DET.RUBRO AND BP_ARMONIZACIONPD.VIGENCIA_RUBRO =BP_RUBRO_INVERSION_DET.VIGENCIA WHERE BP_ARMONIZACIONPD.COMPANIA = :COMPANIA AND BP_ARMONIZACIONPD.VIGENCIA_META = :ANO) INI WHERE (CASE WHEN ID_META IS NULL THEN ' ' ELSE UPPER(ID_META) END) LIKE UPPER(CONCAT(:ID_META, '%')) AND (CASE WHEN DESCRIPCION_PLAN_IND IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_PLAN_IND) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_PLAN_IND), '%')) AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END) LIKE UPPER(CONCAT(:FUENTE, '%')) AND (CASE WHEN CENTROCOSTO IS NULL THEN ' ' ELSE UPPER(CENTROCOSTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CENTROCOSTO), '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN AUXILIARGENERAL IS NULL THEN ' ' ELSE UPPER(AUXILIARGENERAL) END) LIKE UPPER(CONCAT(:AUXILIARGENERAL, '%')) AND (CASE WHEN ID_RUBRO IS NULL THEN ' ' ELSE UPPER(ID_RUBRO) END) LIKE UPPER(CONCAT(:ID_RUBRO, '%')) AND (CASE WHEN DESCRIPCION_RUBRO IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_RUBRO) END) LIKE UPPER(CONCAT(:DESCRIPCION_RUBRO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","VIGENCIA_META":"$VIGENCIA_META(type:integer)","ID_META":"$ID_META","DESCRIPCION_PLAN_IND":"$DESCRIPCION_PLAN_IND","FUENTE":"$FUENTE","CENTROCOSTO":"$CENTROCOSTO","REFERENCIA":"$REFERENCIA","AUXILIARGENERAL":"$AUXILIARGENERAL","VIGENCIA_RUBRO":"$VIGENCIA_RUBRO(type:integer)","ID_RUBRO":"$ID_RUBRO","DESCRIPCION_RUBRO":"$DESCRIPCION_RUBRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID_META" sqlType="STRING"/>
		<param name="DESCRIPCION_PLAN_IND" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CENTROCOSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIARGENERAL" sqlType="STRING"/>
		<param name="ID_RUBRO" sqlType="STRING"/>
		<param name="DESCRIPCION_RUBRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bparmonizaciondp">
		<call-query href="getBparmonizaciondpPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="ID_META" query-param="ID_META"/>
			<with-param name="DESCRIPCION_PLAN_IND" query-param="DESCRIPCION_PLAN_IND"/>
