	<query id="getBparmonizaciondpGetsaldorubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD + V_RESUMENPPTO_BASE.REINTEGRO) SALDO FROM V_RESUMENPPTO_BASE INNER JOIN BP_PROYECTOSRUBROS ON V_RESUMENPPTO_BASE.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND V_RESUMENPPTO_BASE.CODIGO = BP_PROYECTOSRUBROS.RUBROPPTALES AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO INNER JOIN FUENTE_RECURSOS ON V_RESUMENPPTO_BASE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = FUENTE_RECURSOS.ANO AND V_RESUMENPPTO_BASE.FUENTE_RECURSO= FUENTE_RECURSOS.CODIGO INNER JOIN BP_ARMONIZACIONPD ON BP_PROYECTOSRUBROS.COMPANIA=BP_ARMONIZACIONPD.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA=BP_ARMONIZACIONPD.VIGENCIA_RUBRO AND BP_PROYECTOSRUBROS.RUBROPPTALES=BP_ARMONIZACIONPD.ID_RUBRO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO=BP_ARMONIZACIONPD.FUENTE WHERE V_RESUMENPPTO_BASE.COMPANIA = :COMPANIA AND V_RESUMENPPTO_BASE.ANO = :VIGENCIA AND V_RESUMENPPTO_BASE.DESTINO IN ('I','L') AND V_RESUMENPPTO_BASE.NATURALEZA IN('D') AND V_RESUMENPPTO_BASE.MES &lt;= TO_CHAR(SYSDATE, 'MM') AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = :FUENTE AND BP_ARMONIZACIONPD.ID_META = :ID_META GROUP BY V_RESUMENPPTO_BASE.CODIGO, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALDO":"$SALDO(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ID_META" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bparmonizaciondp/getsaldorubro">
		<call-query href="getBparmonizaciondpGetsaldorubroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="ID_META" query-param="ID_META"/>

		</call-query>
	</resource>
	<query id="getBparmonizaciondpGetsaldorubroconauxiliaresQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD + V_RESUMENPPTO_BASE.REINTEGRO) SALDO FROM V_RESUMENPPTO_BASE INNER JOIN BP_PROYECTOSRUBROS ON V_RESUMENPPTO_BASE.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND V_RESUMENPPTO_BASE.CODIGO = BP_PROYECTOSRUBROS.RUBROPPTALES AND V_RESUMENPPTO_BASE.FUENTE_RECURSO = BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO AND V_RESUMENPPTO_BASE.REFERENCIA = BP_PROYECTOSRUBROS.REFERENCIA AND V_RESUMENPPTO_BASE.CENTRO_COSTO = BP_PROYECTOSRUBROS.CENTRO_COSTO AND V_RESUMENPPTO_BASE.AUXILIAR = BP_PROYECTOSRUBROS.AUXILIAR INNER JOIN FUENTE_RECURSOS ON V_RESUMENPPTO_BASE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = FUENTE_RECURSOS.ANO AND V_RESUMENPPTO_BASE.FUENTE_RECURSO= FUENTE_RECURSOS.CODIGO WHERE V_RESUMENPPTO_BASE.COMPANIA = :COMPANIA AND V_RESUMENPPTO_BASE.ANO = :VIGENCIA AND V_RESUMENPPTO_BASE.DESTINO IN ('I','L') AND V_RESUMENPPTO_BASE.NATURALEZA IN('D') AND V_RESUMENPPTO_BASE.MES &lt;= TO_CHAR(SYSDATE, 'MM') AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = :FUENTE AND BP_PROYECTOSRUBROS.CENTRO_COSTO = :CENTRO_COSTO AND BP_PROYECTOSRUBROS.REFERENCIA = :REFERENCIA AND BP_PROYECTOSRUBROS.AUXILIAR = :AUXILIAR AND BP_PROYECTOSRUBROS.RUBROPPTALES = :RUBRO GROUP BY V_RESUMENPPTO_BASE.CODIGO, V_RESUMENPPTO_BASE.NOMBRE, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALDO":"$SALDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="RUBRO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bparmonizaciondp/getsaldorubroconauxiliares">
		<call-query href="getBparmonizaciondpGetsaldorubroconauxiliaresQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="RUBRO" query-param="RUBRO"/>

		</call-query>
	</resource>
	<query id="insertBparmonizaciondp" keyColumns="COMPANIA,VIGENCIA_PLAN,VIGENCIA_META,ID_META,VIGENCIA_RUBRO,ID_RUBRO,FUENTE,CENTROCOSTO,REFERENCIA,AUXILIARGENERAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_ARMONIZACIONPD (COMPANIA, VIGENCIA_PLAN, VIGENCIA_META, ID_META, VIGENCIA_RUBRO, ID_RUBRO, FUENTE, CENTROCOSTO, REFERENCIA, AUXILIARGENERAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :VIGENCIA_PLAN, :VIGENCIA_META, :ID_META, :VIGENCIA_RUBRO, :ID_RUBRO, :FUENTE, :CENTROCOSTO, :REFERENCIA, :AUXILIARGENERAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_VIGENCIA_PLAN":"$VIGENCIA_PLAN(type:integer)","KEY_VIGENCIA_META":"$VIGENCIA_META(type:integer)","KEY_ID_META":"$ID_META","KEY_VIGENCIA_RUBRO":"$VIGENCIA_RUBRO(type:integer)","KEY_ID_RUBRO":"$ID_RUBRO","KEY_FUENTE":"$FUENTE","KEY_CENTROCOSTO":"$CENTROCOSTO","KEY_REFERENCIA":"$REFERENCIA","KEY_AUXILIARGENERAL":"$AUXILIARGENERAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA_META" sqlType="STRING"/>
		<param name="ID_META" sqlType="STRING"/>
		<param name="VIGENCIA_RUBRO" sqlType="STRING"/>
		<param name="ID_RUBRO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="FUENTE" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTROCOSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIARGENERAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bparmonizaciondp">
		<call-query href="insertBparmonizaciondp">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_PLAN" query-param="VIGENCIA_PLAN"/>
			<with-param name="VIGENCIA_META" query-param="VIGENCIA_META"/>
