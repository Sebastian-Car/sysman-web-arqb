<data name="vigenciasappui" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVigenciasappuiPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO,NOMBRE_APPUI FROM VIGENCIAS_APPUI) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE_APPUI IS NULL THEN ' ' ELSE UPPER(NOMBRE_APPUI) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_APPUI), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE_APPUI":"$NOMBRE_APPUI"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_APPUI" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vigenciasappui">
		<call-query href="getVigenciasappuiPaginaQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_APPUI" query-param="NOMBRE_APPUI"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVigenciasappuiNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO,NOMBRE_APPUI FROM VIGENCIAS_APPUI) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE_APPUI IS NULL THEN ' ' ELSE UPPER(NOMBRE_APPUI) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_APPUI), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_APPUI" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vigenciasappui/numero">
		<call-query href="getVigenciasappuiNumeroQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_APPUI" query-param="NOMBRE_APPUI"/>

		</call-query>
	</resource>
</data>