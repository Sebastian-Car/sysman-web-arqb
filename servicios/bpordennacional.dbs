<data name="bpordennacional" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBpordennacional" keyColumns="COMPANIA,COD_PLAN,VIGENCIA,ACUERDO,PILAR,INICIATIVA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_ORDENNACIONAL (COMPANIA, COD_PLAN, VIGENCIA, ACUERDO, PILAR, INICIATIVA, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :COD_PLAN, :VIGENCIA, :ACUERDO, :PILAR, :INICIATIVA, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_PLAN":"$COD_PLAN","KEY_VIGENCIA":"$VIGENCIA(type:integer)","KEY_ACUERDO":"$ACUERDO(type:integer)","KEY_PILAR":"$PILAR(type:integer)","KEY_INICIATIVA":"$INICIATIVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param name="ACUERDO" sqlType="STRING"/>
		<param name="PILAR" sqlType="STRING"/>
		<param name="INICIATIVA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpordennacional">
		<call-query href="insertBpordennacional">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ACUERDO" query-param="ACUERDO"/>
			<with-param name="PILAR" query-param="PILAR"/>
			<with-param name="INICIATIVA" query-param="INICIATIVA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteBpordennacional" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_ORDENNACIONAL WHERE BP_ORDENNACIONAL.COMPANIA= :KEY_COMPANIA AND BP_ORDENNACIONAL.COD_PLAN= :KEY_COD_PLAN AND BP_ORDENNACIONAL.VIGENCIA= :KEY_VIGENCIA AND BP_ORDENNACIONAL.ACUERDO= :KEY_ACUERDO AND BP_ORDENNACIONAL.PILAR= :KEY_PILAR AND BP_ORDENNACIONAL.INICIATIVA= :KEY_INICIATIVA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_PLAN" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>
		<param name="KEY_ACUERDO" sqlType="INTEGER"/>
		<param name="KEY_PILAR" sqlType="INTEGER"/>
		<param name="KEY_INICIATIVA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpordennacional">
		<call-query href="deleteBpordennacional">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_PLAN" query-param="KEY_COD_PLAN"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_ACUERDO" query-param="KEY_ACUERDO"/>
			<with-param name="KEY_PILAR" query-param="KEY_PILAR"/>
			<with-param name="KEY_INICIATIVA" query-param="KEY_INICIATIVA"/>

		</call-query>
	</resource>
	<query id="getBpordennacionalPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT BP_ORDENNACIONAL.COMPANIA, BP_ORDENNACIONAL.COD_PLAN, BP_ORDENNACIONAL.VIGENCIA, BP_ORDENNACIONAL.ACUERDO, BP_ORDENNACIONAL.PILAR, BP_ORDENNACIONAL.INICIATIVA, ACUERDO_PAZ.NOMBRE NOM_ACUERDO, PILARES.DESCRIPCION DESC_PILAR, INICIATIVAS.DESCRIPCION DESC_INICIATIVA FROM BP_ORDENNACIONAL INNER JOIN ACUERDO_PAZ ON BP_ORDENNACIONAL.COMPANIA = ACUERDO_PAZ.COMPANIA AND BP_ORDENNACIONAL.ACUERDO = ACUERDO_PAZ.COD_ACUERDO INNER JOIN PILARES ON BP_ORDENNACIONAL.COMPANIA = PILARES.COMPANIA AND BP_ORDENNACIONAL.PILAR = PILARES.COD_PILAR AND BP_ORDENNACIONAL.ACUERDO = PILARES.ACUERDO INNER JOIN INICIATIVAS ON BP_ORDENNACIONAL.COMPANIA = INICIATIVAS.COMPANIA AND BP_ORDENNACIONAL.INICIATIVA = INICIATIVAS.INICIATIVA AND BP_ORDENNACIONAL.PILAR = INICIATIVAS.PILAR AND BP_ORDENNACIONAL.ACUERDO = INICIATIVAS.ACUERDO WHERE BP_ORDENNACIONAL.COMPANIA = :COMPANIA AND BP_ORDENNACIONAL.VIGENCIA = :VIGENCIA AND BP_ORDENNACIONAL.COD_PLAN = :COD_PLAN) INI WHERE (CASE WHEN NOM_ACUERDO IS NULL THEN ' ' ELSE UPPER(NOM_ACUERDO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_ACUERDO), '%')) AND (CASE WHEN DESC_PILAR IS NULL THEN ' ' ELSE UPPER(DESC_PILAR) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_PILAR), '%')) AND (CASE WHEN DESC_INICIATIVA IS NULL THEN ' ' ELSE UPPER(DESC_INICIATIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_INICIATIVA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PLAN":"$COD_PLAN","VIGENCIA":"$VIGENCIA(type:integer)","ACUERDO":"$ACUERDO(type:integer)","PILAR":"$PILAR(type:integer)","INICIATIVA":"$INICIATIVA","NOM_ACUERDO":"$NOM_ACUERDO","DESC_PILAR":"$DESC_PILAR","DESC_INICIATIVA":"$DESC_INICIATIVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param name="NOM_ACUERDO" sqlType="STRING"/>
		<param name="DESC_PILAR" sqlType="STRING"/>
		<param name="DESC_INICIATIVA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpordennacional">
		<call-query href="getBpordennacionalPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="NOM_ACUERDO" query-param="NOM_ACUERDO"/>
			<with-param name="DESC_PILAR" query-param="DESC_PILAR"/>
			<with-param name="DESC_INICIATIVA" query-param="DESC_INICIATIVA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpordennacionalNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT BP_ORDENNACIONAL.COMPANIA, BP_ORDENNACIONAL.COD_PLAN, BP_ORDENNACIONAL.VIGENCIA, BP_ORDENNACIONAL.ACUERDO, BP_ORDENNACIONAL.PILAR, BP_ORDENNACIONAL.INICIATIVA, ACUERDO_PAZ.NOMBRE NOM_ACUERDO, PILARES.DESCRIPCION DESC_PILAR, INICIATIVAS.DESCRIPCION DESC_INICIATIVA FROM BP_ORDENNACIONAL INNER JOIN ACUERDO_PAZ ON BP_ORDENNACIONAL.COMPANIA = ACUERDO_PAZ.COMPANIA AND BP_ORDENNACIONAL.ACUERDO = ACUERDO_PAZ.COD_ACUERDO INNER JOIN PILARES ON BP_ORDENNACIONAL.COMPANIA = PILARES.COMPANIA AND BP_ORDENNACIONAL.PILAR = PILARES.COD_PILAR AND BP_ORDENNACIONAL.ACUERDO = PILARES.ACUERDO INNER JOIN INICIATIVAS ON BP_ORDENNACIONAL.COMPANIA = INICIATIVAS.COMPANIA AND BP_ORDENNACIONAL.INICIATIVA = INICIATIVAS.INICIATIVA AND BP_ORDENNACIONAL.PILAR = INICIATIVAS.PILAR AND BP_ORDENNACIONAL.ACUERDO = INICIATIVAS.ACUERDO WHERE BP_ORDENNACIONAL.COMPANIA = :COMPANIA AND BP_ORDENNACIONAL.VIGENCIA = :VIGENCIA AND BP_ORDENNACIONAL.COD_PLAN = :COD_PLAN) INI WHERE (CASE WHEN NOM_ACUERDO IS NULL THEN ' ' ELSE UPPER(NOM_ACUERDO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_ACUERDO), '%')) AND (CASE WHEN DESC_PILAR IS NULL THEN ' ' ELSE UPPER(DESC_PILAR) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_PILAR), '%')) AND (CASE WHEN DESC_INICIATIVA IS NULL THEN ' ' ELSE UPPER(DESC_INICIATIVA) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_INICIATIVA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="COD_PLAN" sqlType="STRING"/>
		<param name="NOM_ACUERDO" sqlType="STRING"/>
		<param name="DESC_PILAR" sqlType="STRING"/>
		<param name="DESC_INICIATIVA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpordennacional/numero">
		<call-query href="getBpordennacionalNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="COD_PLAN" query-param="COD_PLAN"/>
			<with-param name="NOM_ACUERDO" query-param="NOM_ACUERDO"/>
			<with-param name="DESC_PILAR" query-param="DESC_PILAR"/>
			<with-param name="DESC_INICIATIVA" query-param="DESC_INICIATIVA"/>

		</call-query>
	</resource>

</data>