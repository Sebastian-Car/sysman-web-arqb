<data name="sfcuentasauxtercero" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfcuentasauxterceroExisteCuentaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  'X' EXISTE  FROM SF_CUENTAS_AUXTERCERO WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND TIPOCOBRO = :TIPOCOBRO AND CUENTA = :CUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"EXISTE":"$EXISTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcuentasauxtercero/existecuenta">
		<call-query href="getSfcuentasauxterceroExisteCuentaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="insertSfcuentasauxtercero" keyColumns="COMPANIA,ANO,TIPOCOBRO,CONCEPTO,CUENTA,TERCERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_CUENTAS_AUXTERCERO (COMPANIA, ANO, TIPOCOBRO, CONCEPTO, CUENTA, TERCERO, SUCURSAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPOCOBRO, :CONCEPTO, :CUENTA, :TERCERO, :SUCURSAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_CONCEPTO":"$CONCEPTO","KEY_CUENTA":"$CUENTA","KEY_TERCERO":"$TERCERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sfcuentasauxtercero">
		<call-query href="insertSfcuentasauxtercero">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSfcuentasauxtercero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SF_CUENTAS_AUXTERCERO WHERE SF_CUENTAS_AUXTERCERO.COMPANIA= :KEY_COMPANIA AND SF_CUENTAS_AUXTERCERO.ANO= :KEY_ANO AND SF_CUENTAS_AUXTERCERO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CUENTAS_AUXTERCERO.CONCEPTO= :KEY_CONCEPTO AND SF_CUENTAS_AUXTERCERO.CUENTA= :KEY_CUENTA AND SF_CUENTAS_AUXTERCERO.TERCERO= :KEY_TERCERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sfcuentasauxtercero">
		<call-query href="deleteSfcuentasauxtercero">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>

		</call-query>
	</resource>
	<query id="getSfcuentasauxterceroPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SF_CUENTAS_AUXTERCERO.COMPANIA, SF_CUENTAS_AUXTERCERO.ANO, SF_CUENTAS_AUXTERCERO.TIPOCOBRO, SF_CUENTAS_AUXTERCERO.CONCEPTO, SF_CUENTAS_AUXTERCERO.SUCURSAL, SF_CUENTAS_AUXTERCERO.CUENTA, V_PLAN_CONTABLE.NOMBRE NOMBRECUENTA, SF_CUENTAS_AUXTERCERO.TERCERO, TERCERO.NOMBRE NOMBRETERCERO  FROM SF_CUENTAS_AUXTERCERO LEFT JOIN V_PLAN_CONTABLE ON V_PLAN_CONTABLE.COMPANIA = SF_CUENTAS_AUXTERCERO.COMPANIA AND V_PLAN_CONTABLE.ANO = SF_CUENTAS_AUXTERCERO.ANO AND V_PLAN_CONTABLE.ID = SF_CUENTAS_AUXTERCERO.CUENTA LEFT JOIN TERCERO ON TERCERO.COMPANIA = SF_CUENTAS_AUXTERCERO.COMPANIA AND TERCERO.NIT = SF_CUENTAS_AUXTERCERO.TERCERO AND TERCERO.SUCURSAL = SF_CUENTAS_AUXTERCERO.SUCURSAL WHERE SF_CUENTAS_AUXTERCERO.COMPANIA = :COMPANIA AND SF_CUENTAS_AUXTERCERO.ANO = :ANO AND SF_CUENTAS_AUXTERCERO.TIPOCOBRO = :TIPOCOBRO AND SF_CUENTAS_AUXTERCERO.CONCEPTO = :CONCEPTO) WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END)  LIKE UPPER(:CUENTA || '%')  AND (CASE WHEN NOMBRECUENTA IS NULL THEN ' ' ELSE UPPER(NOMBRECUENTA) END)  LIKE UPPER( '%' || :NOMBRECUENTA || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPOCOBRO":"$TIPOCOBRO","CONCEPTO":"$CONCEPTO","SUCURSAL":"$SUCURSAL","CUENTA":"$CUENTA","NOMBRECUENTA":"$NOMBRECUENTA","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBRECUENTA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcuentasauxtercero">
		<call-query href="getSfcuentasauxterceroPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NOMBRECUENTA" query-param="NOMBRECUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfcuentasauxterceroNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SF_CUENTAS_AUXTERCERO.COMPANIA, SF_CUENTAS_AUXTERCERO.ANO, SF_CUENTAS_AUXTERCERO.TIPOCOBRO, SF_CUENTAS_AUXTERCERO.CONCEPTO, SF_CUENTAS_AUXTERCERO.SUCURSAL, SF_CUENTAS_AUXTERCERO.CUENTA, V_PLAN_CONTABLE.NOMBRE NOMBRECUENTA, SF_CUENTAS_AUXTERCERO.TERCERO, TERCERO.NOMBRE NOMBRETERCERO  FROM SF_CUENTAS_AUXTERCERO LEFT JOIN V_PLAN_CONTABLE ON V_PLAN_CONTABLE.COMPANIA = SF_CUENTAS_AUXTERCERO.COMPANIA AND V_PLAN_CONTABLE.ANO = SF_CUENTAS_AUXTERCERO.ANO AND V_PLAN_CONTABLE.ID = SF_CUENTAS_AUXTERCERO.CUENTA LEFT JOIN TERCERO ON TERCERO.COMPANIA = SF_CUENTAS_AUXTERCERO.COMPANIA AND TERCERO.NIT = SF_CUENTAS_AUXTERCERO.TERCERO AND TERCERO.SUCURSAL = SF_CUENTAS_AUXTERCERO.SUCURSAL WHERE SF_CUENTAS_AUXTERCERO.COMPANIA = :COMPANIA AND SF_CUENTAS_AUXTERCERO.ANO = :ANO AND SF_CUENTAS_AUXTERCERO.TIPOCOBRO = :TIPOCOBRO AND SF_CUENTAS_AUXTERCERO.CONCEPTO = :CONCEPTO) WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END)  LIKE UPPER(:CUENTA || '%')  AND (CASE WHEN NOMBRECUENTA IS NULL THEN ' ' ELSE UPPER(NOMBRECUENTA) END)  LIKE UPPER( '%' || :NOMBRECUENTA || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END)  LIKE UPPER( '%' || :NOMBRETERCERO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBRECUENTA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcuentasauxtercero/numero">
		<call-query href="getSfcuentasauxterceroNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NOMBRECUENTA" query-param="NOMBRECUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>

		</call-query>
	</resource>
	<query id="updateSfcuentasauxtercero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_CUENTAS_AUXTERCERO SET CUENTA=:CUENTA, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_CUENTAS_AUXTERCERO.COMPANIA= :KEY_COMPANIA AND SF_CUENTAS_AUXTERCERO.ANO= :KEY_ANO AND SF_CUENTAS_AUXTERCERO.TIPOCOBRO= :KEY_TIPOCOBRO AND SF_CUENTAS_AUXTERCERO.CONCEPTO= :KEY_CONCEPTO AND SF_CUENTAS_AUXTERCERO.CUENTA= :KEY_CUENTA AND SF_CUENTAS_AUXTERCERO.TERCERO= :KEY_TERCERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CUENTA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>
		<param name="KEY_TERCERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfcuentasauxtercero">
		<call-query href="updateSfcuentasauxtercero">
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>
			<with-param name="KEY_TERCERO" query-param="KEY_TERCERO"/>

		</call-query>
	</resource>

</data>