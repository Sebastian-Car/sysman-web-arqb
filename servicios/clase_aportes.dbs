<data name="clase_aportes" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getClase_aportesNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASE_APORTES.CLASEAPORTE, CLASE_APORTES.NOMBRE  FROM CLASE_APORTES WHERE CLASE_APORTES.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEAPORTE":"$CLASEAPORTE","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="clase_aportes/nombre">
		<call-query href="getClase_aportesNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>

</data>