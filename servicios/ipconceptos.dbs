			<with-param name="ESCAPITALABACU" query-param="ESCAPITALABACU"/>
			<with-param name="ESINTERESABACU" query-param="ESINTERESABACU"/>

		</call-query>
	</resource>
	<query id="updateIpconceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE IP_CONCEPTOS SET NOMBRE=:NOMBRE, FORMULA=:FORMULA, APLICAINTERES=:APLICAINTERES, PRIORIDAD=:PRIORIDAD, MINIMO=:MINIMO, MINIMO1=:MINIMO1, ENCABEZADO=:ENCABEZADO, ESCAPITALVIGENCIA=:ESCAPITALVIGENCIA, ESINTERESVIGENCIA=:ESINTERESVIGENCIA, VIGANT=:VIGANT, VIGDFR=:VIGDFR, VER_RESOL=:VER_RESOL, ESCAPITALABACU=:ESCAPITALABACU, ESINTERESABACU=:ESINTERESABACU, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE IP_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND IP_CONCEPTOS.ANO= :KEY_ANO AND IP_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FORMULA" sqlType="STRING"/>
		<param name="APLICAINTERES" sqlType="STRING"/>
		<param name="PRIORIDAD" sqlType="STRING"/>
		<param name="MINIMO" sqlType="STRING"/>
		<param name="MINIMO1" sqlType="STRING"/>
		<param name="ENCABEZADO" sqlType="STRING"/>
		<param name="ESCAPITALVIGENCIA" sqlType="STRING"/>
		<param name="ESINTERESVIGENCIA" sqlType="STRING"/>
		<param name="VIGANT" sqlType="STRING"/>
		<param name="VIGDFR" sqlType="STRING"/>
		<param name="VER_RESOL" sqlType="STRING"/>
		<param name="ESCAPITALABACU" sqlType="STRING"/>
		<param name="ESINTERESABACU" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="ipconceptos">
		<call-query href="updateIpconceptos">
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FORMULA" query-param="FORMULA"/>
			<with-param name="APLICAINTERES" query-param="APLICAINTERES"/>
			<with-param name="PRIORIDAD" query-param="PRIORIDAD"/>
			<with-param name="MINIMO" query-param="MINIMO"/>
			<with-param name="MINIMO1" query-param="MINIMO1"/>
			<with-param name="ENCABEZADO" query-param="ENCABEZADO"/>
			<with-param name="ESCAPITALVIGENCIA" query-param="ESCAPITALVIGENCIA"/>
			<with-param name="ESINTERESVIGENCIA" query-param="ESINTERESVIGENCIA"/>
			<with-param name="VIGANT" query-param="VIGANT"/>
			<with-param name="VIGDFR" query-param="VIGDFR"/>
			<with-param name="VER_RESOL" query-param="VER_RESOL"/>
			<with-param name="ESCAPITALABACU" query-param="ESCAPITALABACU"/>
			<with-param name="ESINTERESABACU" query-param="ESINTERESABACU"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="insertIpconceptosPrepararAnioSiguiente" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>INSERT INTO IP_CONCEPTOS   (COMPANIA,ANO,CODIGO,NOMBRE,VALOR,SUMAORESTA,PORCENTAJE,CAUSACIONDB,CAUSACIONCR,RECAUDODB,TABLAAMODIFICAR,CAMPOAMODIFICAR,RECAUDOCR,FORMULA_COPIA,MINIMO,MINIMO1,APLICAINTERES,PRIORIDAD,INFORMATIVO,ESCAPITALVIGENCIA,ESINTERESVIGENCIA,PRORATIAR,ENCABEZADO,FORMULA,VIGANT,VIGDFR,VERINF_TOTALCERO,CAUSACIONDBNULA,CAUSACIONCRNULA,VER_RESOL,FUENTE,CTA_CRD_SUPERNUM,CTA_DBT_SUPERNUM,PRIORIDAD_ABON_EN_ACU,COD_CENTRO_COSTO,ESCAPITALABACU,ESINTERESABACU,NIVEL,FORMULA1,DATE_CREATED,CREATED_BY) SELECT IP_CONCEPTOS.COMPANIA,:ANIOFINAL,IP_CONCEPTOS.CODIGO,IP_CONCEPTOS.NOMBRE,VALOR,SUMAORESTA,PORCENTAJE,CAUSACIONDB,CAUSACIONCR,PLAN_CONTABLE.CODIGO,TABLAAMODIFICAR,CAMPOAMODIFICAR,P1.CODIGO,FORMULA_COPIA,MINIMO,MINIMO1,APLICAINTERES,PRIORIDAD,INFORMATIVO,ESCAPITALVIGENCIA,ESINTERESVIGENCIA,PRORATIAR,ENCABEZADO,FORMULA,VIGANT,VIGDFR,VERINF_TOTALCERO,CAUSACIONDBNULA,CAUSACIONCRNULA,VER_RESOL,IP_CONCEPTOS.FUENTE,CTA_CRD_SUPERNUM,CTA_DBT_SUPERNUM,PRIORIDAD_ABON_EN_ACU,COD_CENTRO_COSTO,ESCAPITALABACU,ESINTERESABACU,NIVEL,FORMULA1,SYSDATE,:CREATED_BY FROM IP_CONCEPTOS LEFT JOIN PLAN_CONTABLE ON IP_CONCEPTOS.COMPANIA   = PLAN_CONTABLE.COMPANIA AND IP_CONCEPTOS.ANO       = :ANIOFINAL AND IP_CONCEPTOS.RECAUDOCR = PLAN_CONTABLE.CODIGO LEFT JOIN PLAN_CONTABLE P1 ON IP_CONCEPTOS.COMPANIA   = P1.COMPANIA AND IP_CONCEPTOS.ANO       = :ANIOFINAL AND IP_CONCEPTOS.RECAUDODB = P1.CODIGO WHERE IP_CONCEPTOS.ANO     = :ANIOINICIAL AND IP_CONCEPTOS.COMPANIA = :COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANIOFINAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="ANIOINICIAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="POST" path="ipconceptos/prepararaniosiguiente">
		<call-query href="insertIpconceptosPrepararAnioSiguiente">
			<with-param name="ANIOFINAL" query-param="ANIOFINAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="ANIOINICIAL" query-param="ANIOINICIAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getIpconceptosPagCodigoYNombrePorCompaniaYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  IP_CONCEPTOS.COMPANIA, IP_CONCEPTOS.ANO, IP_CONCEPTOS.CODIGO, IP_CONCEPTOS.NOMBRE  FROM IP_CONCEPTOS WHERE IP_CONCEPTOS.COMPANIA = :COMPANIA AND IP_CONCEPTOS.ANO = :ANO ORDER BY IP_CONCEPTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipconceptos/codigoynombreporcompaniayanio/pag">
		<call-query href="getIpconceptosPagCodigoYNombrePorCompaniaYAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpconceptosNumCodigoYNombrePorCompaniaYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  IP_CONCEPTOS.COMPANIA, IP_CONCEPTOS.ANO, IP_CONCEPTOS.CODIGO, IP_CONCEPTOS.NOMBRE  FROM IP_CONCEPTOS WHERE IP_CONCEPTOS.COMPANIA = :COMPANIA AND IP_CONCEPTOS.ANO = :ANO ORDER BY IP_CONCEPTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipconceptos/codigoynombreporcompaniayanio/num">
		<call-query href="getIpconceptosNumCodigoYNombrePorCompaniaYAnioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getIpconceptosNomconceptosexcedentesporcobrarQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, INITCAP(NOMBRE) NOMBRE  FROM IP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND ( CODIGO BETWEEN 1 AND 4 OR CODIGO BETWEEN 13 AND 20)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipconceptos/nomconceptosexcedentesporcobrar">
		<call-query href="getIpconceptosNomconceptosexcedentesporcobrarQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>

</data>