	<query id="updateBpplanindejecutadocontrato" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPPLANINDEJECUTADO_CONTRATO SET COMPANIA=:COMPANIA, CLASEORDEN_N=:CLASEORDEN_N, ORDENDECOMPRA_N=:ORDENDECOMPRA_N, PROYECTO=:PROYECTO, CONSECUTIVO=:CONSECUTIVO, ID_PLAN_N=:ID_PLAN_N, VIGENCIA_META_N=:VIGENCIA_META_N, AUXILIAR=:AUXILIAR, COMPONENTE=:COMPONENTE, VALOR_EJECUTADO_META=:VALOR_EJECUTADO_META, CANTIDAD_EJECUTADO_META=:CANTIDAD_EJECUTADO_META, DESCRIPCION=:DESCRIPCION, NOVEDAD_N=:NOVEDAD_N, VIGENCIA_PLAN_N=:VIGENCIA_PLAN_N, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BPPLANINDEJECUTADO_CONTRATO.COMPANIA= :KEY_COMPANIA AND BPPLANINDEJECUTADO_CONTRATO.CLASEORDEN_N= :KEY_CLASEORDEN_N AND BPPLANINDEJECUTADO_CONTRATO.ORDENDECOMPRA_N= :KEY_ORDENDECOMPRA_N AND BPPLANINDEJECUTADO_CONTRATO.NOVEDAD_N= :KEY_NOVEDAD_N AND BPPLANINDEJECUTADO_CONTRATO.PROYECTO= :KEY_PROYECTO AND BPPLANINDEJECUTADO_CONTRATO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

