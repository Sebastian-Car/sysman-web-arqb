	<query id="deleteBpplanindejecutadocontrato" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BPPLANINDEJECUTADO_CONTRATO WHERE BPPLANINDEJECUTADO_CONTRATO.COMPANIA= :KEY_COMPANIA AND BPPLANINDEJECUTADO_CONTRATO.CLASEORDEN_N= :KEY_CLASEORDEN_N AND BPPLANINDEJECUTADO_CONTRATO.ORDENDECOMPRA_N= :KEY_ORDENDECOMPRA_N AND BPPLANINDEJECUTADO_CONTRATO.NOVEDAD_N= :KEY_NOVEDAD_N AND BPPLANINDEJECUTADO_CONTRATO.PROYECTO= :KEY_PROYECTO AND BPPLANINDEJECUTADO_CONTRATO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN_N" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA_N" sqlType="STRING"/>
		<param name="KEY_NOVEDAD_N" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
