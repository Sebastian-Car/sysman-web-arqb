	<query id="getBpplanindejecutadocontratoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BPPLANINDEJECUTADO_CONTRATO.COMPANIA, BPPLANINDEJECUTADO_CONTRATO.CLASEORDEN_N, BPPLANINDEJECUTADO_CONTRATO.ORDENDECOMPRA_N, BPPLANINDEJECUTADO_CONTRATO.PROYECTO, BPPLANINDEJECUTADO_CONTRATO.CONSECUTIVO, BPPLANINDEJECUTADO_CONTRATO.ID_PLAN_N, BPPLANINDEJECUTADO_CONTRATO.VIGENCIA_META_N, BPPLANINDEJECUTADO_CONTRATO.AUXILIAR, BPPLANINDEJECUTADO_CONTRATO.COMPONENTE, BPPLANINDEJECUTADO_CONTRATO.VALOR_EJECUTADO_META, BPPLANINDEJECUTADO_CONTRATO.CANTIDAD_EJECUTADO_META, BPPLANINDEJECUTADO_CONTRATO.DESCRIPCION, AUXILIAR.NOMBRE NOMBREPROYECTO, BPPLANINDEJECUTADO_CONTRATO.NOVEDAD_N, BPPLANINDEJECUTADO_CONTRATO.VIGENCIA_PLAN_N  FROM BPPLANINDEJECUTADO_CONTRATO INNER JOIN AUXILIAR ON AUXILIAR.CODIGO = BPPLANINDEJECUTADO_CONTRATO.AUXILIAR AND AUXILIAR.COMPANIA =BPPLANINDEJECUTADO_CONTRATO.COMPANIA WHERE BPPLANINDEJECUTADO_CONTRATO.COMPANIA = :COMPANIA AND BPPLANINDEJECUTADO_CONTRATO.CLASEORDEN_N = :CLASEORDEN AND BPPLANINDEJECUTADO_CONTRATO.ORDENDECOMPRA_N = :NUMERO_ORDEN AND BPPLANINDEJECUTADO_CONTRATO.NOVEDAD_N = :NOVEDAD) WHERE (CASE WHEN ID_PLAN_N IS NULL THEN ' ' ELSE UPPER(ID_PLAN_N) END)  LIKE UPPER( '%' || :ID_PLAN_N || '%')  AND (CASE WHEN VIGENCIA_META_N IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META_N) END)  LIKE UPPER( '%' || :VIGENCIA_META_N || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER( '%' || :AUXILIAR || '%')  AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER( '%' || :COMPONENTE || '%')  AND (CASE WHEN VALOR_EJECUTADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_META) END)  LIKE UPPER( '%' || :VALOR_EJECUTADO_META || '%')  AND (CASE WHEN CANTIDAD_EJECUTADO_META IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJECUTADO_META) END)  LIKE UPPER( '%' || :CANTIDAD_EJECUTADO_META || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="NOVEDAD" sqlType="STRING"/>
		<param name="ID_PLAN_N" sqlType="STRING"/>
		<param name="VIGENCIA_META_N" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADO_META" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
