	<query id="insertBpplanindejecutadocontrato" keyColumns="COMPANIA,CLASEORDEN_N,ORDENDECOMPRA_N,NOVEDAD_N,PROYECTO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BPPLANINDEJECUTADO_CONTRATO (COMPANIA, CLASEORDEN_N, ORDENDECOMPRA_N, PROYECTO, CONSECUTIVO, ID_PLAN_N, VIGENCIA_META_N, AUXILIAR, COMPONENTE, VALOR_EJECUTADO_META, CANTIDAD_EJECUTADO_META, DESCRIPCION, NOVEDAD_N, CLASET_N, TIPOT_N, FECHA_N, PORCENTAJE_EJECUCION, VIGENCIA_PLAN_N, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN_N, :ORDENDECOMPRA_N, :PROYECTO, :CONSECUTIVO, :ID_PLAN_N, :VIGENCIA_META_N, :AUXILIAR, :COMPONENTE, :VALOR_EJECUTADO_META, :CANTIDAD_EJECUTADO_META, :DESCRIPCION, :NOVEDAD_N, :CLASET_N, :TIPOT_N, TO_DATE(:FECHA_N,'DD/MM/YYYY HH24:MI:SS'), :PORCENTAJE_EJECUCION, :VIGENCIA_PLAN_N, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN_N":"$CLASEORDEN_N","KEY_ORDENDECOMPRA_N":"$ORDENDECOMPRA_N","KEY_NOVEDAD_N":"$NOVEDAD_N","KEY_PROYECTO":"$PROYECTO","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN_N" sqlType="STRING"/>
		<param defaultValue="0" name="ORDENDECOMPRA_N" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="ID_PLAN_N" sqlType="STRING"/>
