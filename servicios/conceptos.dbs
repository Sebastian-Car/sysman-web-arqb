	</resource>
	<query id="getConceptosNumListagrillaextrasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT EXTRAS.COMPANIA, EXTRAS.ID_DE_EMPLEADO, EXTRAS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO,(TO_CHAR(EXTRAS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(EXTRAS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, EXTRAS.CANTIDAD, EXTRAS.EXTRA_ACTO,(TO_CHAR(EXTRAS.EXTRA_FECHA,'DD/MM/YYYY HH24:MI:SS')) EXTRA_FECHA, CASE WHEN EXTRAS.PAGADA NOT IN 0 THEN 'true' ELSE 'false' END PAGADA FROM EXTRAS LEFT JOIN CONCEPTOS ON (EXTRAS.COMPANIA = CONCEPTOS.COMPANIA) AND (EXTRAS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO) WHERE EXTRAS.COMPANIA = :COMPANIA AND EXTRAS.ID_DE_EMPLEADO = :ID_EMPLEADO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAINICIO), '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAFINAL), '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(:CANTIDAD, '%')) AND (CASE WHEN EXTRA_ACTO IS NULL THEN ' ' ELSE UPPER(EXTRA_ACTO) END) LIKE UPPER(CONCAT(CONCAT('%',:EXTRA_ACTO), '%')) AND (CASE WHEN EXTRA_FECHA IS NULL THEN ' ' ELSE UPPER(EXTRA_FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:EXTRA_FECHA), '%')) AND (CASE WHEN PAGADA IS NULL THEN ' ' ELSE UPPER(PAGADA) END) LIKE UPPER(CONCAT(CONCAT('%',:PAGADA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="EXTRA_ACTO" sqlType="STRING"/>
		<param name="EXTRA_FECHA" sqlType="STRING"/>
		<param name="PAGADA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/listagrillaextras/num">
		<call-query href="getConceptosNumListagrillaextrasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="FECHAINICIO" query-param="FECHAINICIO"/>
			<with-param name="FECHAFINAL" query-param="FECHAFINAL"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="EXTRA_ACTO" query-param="EXTRA_ACTO"/>
			<with-param name="EXTRA_FECHA" query-param="EXTRA_FECHA"/>
			<with-param name="PAGADA" query-param="PAGADA"/>

		</call-query>
	</resource>
	<query id="getConceptosPagConceptoscuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ID_DE_CONCEPTO, NOMBRE_CONCEPTO, CASE CLASE WHEN 1 THEN 'Informativo' WHEN 3 THEN 'Remuneración' WHEN 4 THEN 'Total Devengado' WHEN 5 THEN 'Descuento' WHEN 6 THEN 'Total Deducido' WHEN 7 THEN 'Neto a Pagar' WHEN 2 THEN 'Otros Informativos' WHEN 8 THEN 'Contable' WHEN 9 THEN 'Anticipados' WHEN 99 THEN 'Bases' ELSE NULL END CLASE , CONCEPTO_CUNE,CLASE CLASECONCEPTO FROM CONCEPTOS WHERE COMPANIA = :COMPANIA ORDER BY ID_DE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE), '%')) AND (CASE WHEN CONCEPTO_CUNE IS NULL THEN ' ' ELSE UPPER(CONCEPTO_CUNE) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO_CUNE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CLASE":"$CLASE","CONCEPTO_CUNE":"$CONCEPTO_CUNE","CLASECONCEPTO":"$CLASECONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CONCEPTO_CUNE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/conceptoscune/pag">
		<call-query href="getConceptosPagConceptoscuneQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CONCEPTO_CUNE" query-param="CONCEPTO_CUNE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumConceptoscuneQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ID_DE_CONCEPTO, NOMBRE_CONCEPTO, CASE CLASE WHEN 1 THEN 'Informativo' WHEN 3 THEN 'Remuneración' WHEN 4 THEN 'Total Devengado' WHEN 5 THEN 'Descuento' WHEN 6 THEN 'Total Deducido' WHEN 7 THEN 'Neto a Pagar' WHEN 2 THEN 'Otros Informativos' WHEN 8 THEN 'Contable' WHEN 9 THEN 'Anticipados' WHEN 99 THEN 'Bases' ELSE NULL END CLASE , CONCEPTO_CUNE,CLASE CLASECONCEPTO FROM CONCEPTOS WHERE COMPANIA = :COMPANIA ORDER BY ID_DE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE), '%')) AND (CASE WHEN CONCEPTO_CUNE IS NULL THEN ' ' ELSE UPPER(CONCEPTO_CUNE) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO_CUNE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="CONCEPTO_CUNE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/conceptoscune/num">
		<call-query href="getConceptosNumConceptoscuneQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="CONCEPTO_CUNE" query-param="CONCEPTO_CUNE"/>

		</call-query>
	</resource>
	<query id="updateConceptosConceptoscune" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONCEPTOS SET CONCEPTO_CUNE=:CONCEPTO_CUNE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONCEPTOS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONCEPTO_CUNE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="conceptos/conceptoscune">
		<call-query href="updateConceptosConceptoscune">
			<with-param name="CONCEPTO_CUNE" query-param="CONCEPTO_CUNE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
		<query id="getConceptosPagConceptossubirnovedadQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.PERMITE_SUBIR_NOVEDAD != 0 ORDER BY CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/conceptossubirnovedad/pag">
		<call-query href="getConceptosPagConceptossubirnovedadQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumConceptossubirnovedadQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.PERMITE_SUBIR_NOVEDAD != 0 ORDER BY CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/conceptossubirnovedad/num">
		<call-query href="getConceptosNumConceptossubirnovedadQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

