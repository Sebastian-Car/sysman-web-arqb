	<query id="getConceptosPagNombreYClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, CONCEPTOS.CLASE  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.CLASE NOT IN (:TIPOCLASE) ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER(:CLASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CLASE":"$CLASE"}]}}		</result>
