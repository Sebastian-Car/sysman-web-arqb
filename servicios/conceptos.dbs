	<query id="updateConceptosConfpagotercero" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONCEPTOS SET MANEJA_PAGO_TERCEROS=:MANEJA_PAGO_TERCEROS, C_BANCO=:C_BANCO, C_CUENTA=:C_CUENTA, C_TIPO_CUENTA=:C_TIPO_CUENTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CONCEPTOS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MANEJA_PAGO_TERCEROS" sqlType="STRING"/>
		<param name="C_BANCO" sqlType="STRING"/>
		<param name="C_CUENTA" sqlType="STRING"/>
		<param name="C_TIPO_CUENTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="conceptos/confpagotercero">
		<call-query href="updateConceptosConfpagotercero">
			<with-param name="MANEJA_PAGO_TERCEROS" query-param="MANEJA_PAGO_TERCEROS"/>
			<with-param name="C_BANCO" query-param="C_BANCO"/>
			<with-param name="C_CUENTA" query-param="C_CUENTA"/>
			<with-param name="C_TIPO_CUENTA" query-param="C_TIPO_CUENTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptosPagListagrillaextrasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT EXTRAS.COMPANIA, EXTRAS.ID_DE_EMPLEADO, EXTRAS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO,(TO_CHAR(EXTRAS.FECHAINICIO,'DD/MM/YYYY HH24:MI:SS')) FECHAINICIO,(TO_CHAR(EXTRAS.FECHAFINAL,'DD/MM/YYYY HH24:MI:SS')) FECHAFINAL, EXTRAS.CANTIDAD, EXTRAS.EXTRA_ACTO,(TO_CHAR(EXTRAS.EXTRA_FECHA,'DD/MM/YYYY HH24:MI:SS')) EXTRA_FECHA, CASE WHEN EXTRAS.PAGADA NOT IN 0 THEN 'true' ELSE 'false' END PAGADA FROM EXTRAS LEFT JOIN CONCEPTOS ON (EXTRAS.COMPANIA = CONCEPTOS.COMPANIA) AND (EXTRAS.ID_DE_CONCEPTO = CONCEPTOS.ID_DE_CONCEPTO) WHERE EXTRAS.COMPANIA = :COMPANIA AND EXTRAS.ID_DE_EMPLEADO = :ID_EMPLEADO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN FECHAINICIO IS NULL THEN ' ' ELSE UPPER(FECHAINICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAINICIO), '%')) AND (CASE WHEN FECHAFINAL IS NULL THEN ' ' ELSE UPPER(FECHAFINAL) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAFINAL), '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(:CANTIDAD, '%')) AND (CASE WHEN EXTRA_ACTO IS NULL THEN ' ' ELSE UPPER(EXTRA_ACTO) END) LIKE UPPER(CONCAT(CONCAT('%',:EXTRA_ACTO), '%')) AND (CASE WHEN EXTRA_FECHA IS NULL THEN ' ' ELSE UPPER(EXTRA_FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:EXTRA_FECHA), '%')) AND (CASE WHEN PAGADA IS NULL THEN ' ' ELSE UPPER(PAGADA) END) LIKE UPPER(CONCAT(CONCAT('%',:PAGADA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","FECHAINICIO":"$FECHAINICIO","FECHAFINAL":"$FECHAFINAL","CANTIDAD":"$CANTIDAD","EXTRA_ACTO":"$EXTRA_ACTO","EXTRA_FECHA":"$EXTRA_FECHA","PAGADA":"$PAGADA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="FECHAINICIO" sqlType="STRING"/>
		<param name="FECHAFINAL" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="EXTRA_ACTO" sqlType="STRING"/>
		<param name="EXTRA_FECHA" sqlType="STRING"/>
		<param name="PAGADA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
