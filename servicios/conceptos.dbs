	<query id="getConceptosPagConfpagoterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCEPTOS.COMPANIA, CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, CASE CONCEPTOS.CLASE WHEN 1 THEN 'Informativo' WHEN 2 THEN 'Otros Informativos' WHEN 3 THEN 'Remuneración' WHEN 4 THEN 'Total Devengado' WHEN 5 THEN 'Descuento' WHEN 6 THEN 'Total Deducido' WHEN 7 THEN 'Neto a Pagar' WHEN 8 THEN 'Contable' WHEN 9 THEN 'Anticipados' WHEN 99 THEN 'Bases' ELSE '' END CLASE, CONCEPTOS.TERCERO, CONCEPTOS.SUCURSAL, TERCERO.NOMBRE NOMBRETERCERO, TERCERO.DIRECCIONEMAIL,(CASE CONCEPTOS.MANEJA_PAGO_TERCEROS WHEN 0 THEN 'false' ELSE 'true' END) MANEJA_PAGO_TERCEROS, CONCEPTOS.C_BANCO, BANCO.NOMBREBANCO, CONCEPTOS.C_CUENTA, CONCEPTOS.C_TIPO_CUENTA, CASE CONCEPTOS.C_TIPO_CUENTA WHEN 'A' THEN 'Ahorro' WHEN 'C' THEN 'Corriente' ELSE '' END NOMBRECUENTA FROM CONCEPTOS INNER JOIN TERCERO ON CONCEPTOS.COMPANIA = TERCERO.COMPANIA AND CONCEPTOS.TERCERO = TERCERO.NIT AND CONCEPTOS.SUCURSAL = TERCERO.SUCURSAL LEFT JOIN BANCO ON CONCEPTOS.COMPANIA = BANCO.COMPANIA AND CONCEPTOS.C_BANCO = BANCO.BANCO WHERE CONCEPTOS.COMPANIA =:COMPANIA ORDER BY CONCEPTOS.ID_DE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASE), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN DIRECCIONEMAIL IS NULL THEN ' ' ELSE UPPER(DIRECCIONEMAIL) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRECCIONEMAIL), '%')) AND (CASE WHEN MANEJA_PAGO_TERCEROS IS NULL THEN ' ' ELSE UPPER(MANEJA_PAGO_TERCEROS) END) LIKE UPPER(CONCAT(:MANEJA_PAGO_TERCEROS, '%')) AND (CASE WHEN C_BANCO IS NULL THEN ' ' ELSE UPPER(C_BANCO) END) LIKE UPPER(CONCAT(CONCAT('%',:C_BANCO), '%')) AND (CASE WHEN NOMBREBANCO IS NULL THEN ' ' ELSE UPPER(NOMBREBANCO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREBANCO), '%')) AND (CASE WHEN C_CUENTA IS NULL THEN ' ' ELSE UPPER(C_CUENTA) END) LIKE UPPER(CONCAT(:C_CUENTA, '%')) AND (CASE WHEN NOMBRECUENTA IS NULL THEN ' ' ELSE UPPER(NOMBRECUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECUENTA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CLASE":"$CLASE","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","NOMBRETERCERO":"$NOMBRETERCERO","DIRECCIONEMAIL":"$DIRECCIONEMAIL","MANEJA_PAGO_TERCEROS":"$MANEJA_PAGO_TERCEROS(type:boolean)","C_BANCO":"$C_BANCO","NOMBREBANCO":"$NOMBREBANCO","C_CUENTA":"$C_CUENTA","C_TIPO_CUENTA":"$C_TIPO_CUENTA","NOMBRECUENTA":"$NOMBRECUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="DIRECCIONEMAIL" sqlType="STRING"/>
		<param name="MANEJA_PAGO_TERCEROS" sqlType="STRING"/>
		<param name="C_BANCO" sqlType="STRING"/>
		<param name="NOMBREBANCO" sqlType="STRING"/>
		<param name="C_CUENTA" sqlType="STRING"/>
		<param name="NOMBRECUENTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
