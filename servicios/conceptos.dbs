		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.CLASE = 1 OR CONCEPTOS.CLASE = 2 ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
