<data name="conceptos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getConceptosPagTodosPorIdYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/todosporidynombre/pag">
		<call-query href="getConceptosPagTodosPorIdYNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumTodosPorIdYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/todosporidynombre/num">
		<call-query href="getConceptosNumTodosPorIdYNombreQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptosPagIdYNombreSinCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/idynombresincompania/pag">
		<call-query href="getConceptosPagIdYNombreSinCompaniaQuery">
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumIdYNombreSinCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/idynombresincompania/num">
		<call-query href="getConceptosNumIdYNombreSinCompaniaQuery">
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptosPagTodosPorIdYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO &gt;= :CONCEPTO ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/todosporidynombrefinal/pag">
		<call-query href="getConceptosPagTodosPorIdYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumTodosPorIdYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO &gt;= :CONCEPTO ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/todosporidynombrefinal/num">
		<call-query href="getConceptosNumTodosPorIdYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptosPagTodosPorConceptoYCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS WHERE CONCEPTOS.ID_DE_CONCEPTO IN( PCK_NOMINA_COM1.FC_PARAMETRO(:COMPANIA,12) ,'301' , '304','309' ) AND CONCEPTOS.COMPANIA =:COMPANIA) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/todosporconceptoycompania/pag">
		<call-query href="getConceptosPagTodosPorConceptoYCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumTodosPorConceptoYCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO  FROM CONCEPTOS WHERE CONCEPTOS.ID_DE_CONCEPTO IN( PCK_NOMINA_COM1.FC_PARAMETRO(:COMPANIA,12) ,'301' , '304','309' ) AND CONCEPTOS.COMPANIA =:COMPANIA) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/todosporconceptoycompania/num">
		<call-query href="getConceptosNumTodosPorConceptoYCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptosPagListaconcepQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, CONCEPTOS.COMPANIA  FROM CONCEPTOS WHERE CONCEPTOS.ID_DE_CONCEPTO BETWEEN '700' AND '798' AND CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.DENOVEDAD = - 1) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/listaconcep/pag">
		<call-query href="getConceptosPagListaconcepQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertConceptos" keyColumns="COMPANIA,ID_DE_CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CONCEPTOS (ID_DE_CONCEPTO, NOMBRE_CONCEPTO, CLASE, DENOVEDAD, UNIDAD, REPORTEEPS, RANGO2, RANGO1, CTA_CRD_ADMINISTRACION, CTA_DBT_ADMINISTRACION, CTA_CRD_PRODUCCION, CTA_DBT_PRODUCCION, CTA_CRD_VENTAS, CTA_DBT_VENTAS, RELACIONADO, VARCESANTIASPAR, VARPRIMASEMESTRAL, VARPRIMAANTIGUEDAD, VARPRIMAVACACIONES, VARCESANTIASCONS, DEVRETENCION, DEDRETENCION, CONTROLFECHA, TIPODEFONDO, TERCERO, SUCURSAL, CODSISE, PRIORIDAD, CTA_CRE_PPTAL, CTA_CONTRACRE_PPTAL, PERMITE_DUPLICAR, NITDE, PORCDC, RETROACTIVO, NITCONCEPTO, FACTOR_PARAFISCAL, CODJDCN, FACTOR_RETEFUENTE, GLCJD, AGRUPADOPOREMPLEADO, FACTOR_CESANTIAS, FACTOR_CESANTIASCONSOLIDADAS, FACTOR_PRIMAJUNIO, FACTOR_PRIMANAVIDAD, FACTOR_VACACIONES, FACTOR_PRIMAVACACIONES, FACTOR_PRIMAANTIGUEDAD, CTA_CRD_OTRO, CTA_DBT_OTRO, CODIGO_FIDUPREVISORA, CODDIAN, PREST_SOCIAL_CDM, TIPOAGRCONCEPTO, EQUIVALENTE_UB, CTA_CRD_SUPERNUM, CTA_DBT_SUPERNUM, FUENTE, C_BANCO, C_TIPO_CUENTA, C_CUENTA, KARDEX, C_RETRO, IND_VOLANTE, COLUMNA_SIDEF11, FACTOR_SALARIAL, FACTOR_PRESTACIONAL, FACTOR_SUELDOS, TIPOPAGO, INGRESO_NO_CONSTITUTIVO_RENTA, IND_RENTA_EXENTA, FECHA_ANTICIPO_CESANTIAS, TIPOAGRCONCEPTOS, BOLCUENTA_ADM_PRICIPAL, BOLCUENTA_VNT_PRICIPAL, BOLCUENTA_PRD_PRICIPAL, BOLCUENTA_OTRO_PRICIPAL, BOLCUENTA_SUP_PRICIPAL, OBS_228_1, OBS_228_2, FACTOR_EXTRALEGALES, FACTOR_LEGALES, FACTOR_OTROSPAGOS, COLUMNA_SIDEF111, RUBROS_SIIF, DOC_SIIF_CONCEPTO, RES273_2013, FACTOR_SALARIAL_EMB, FACTOR_PRESTACIONAL_EMB, FACTOR_SUELDOS_EMB, CN_AGR228, CN_UGPP, CUOTA_PARTE, DOCPS, DOCPV, DOCVC, DOCPN, DOCCS, CREATED_BY, DATE_CREATED, COMPANIA, SIIF_POSICION_DESCUENTO, FACTOR40, FACTOR40PRESTACION, TIPOCONSOLIDADO, DEVENGO_BENEFICIO, SIIF_ATRIBUTOPATRON, SIIF_ATRIBUTOEMPLEADO, TIPO_PAGOSIA, OTROSPAGOSLABORALES, CGR_CONCEPTO, FACTOR_BASE_IMPUESTO_COVID, PERMITE_SUBIR_NOVEDAD, IND_ING_LABORAL_PROMEDIO) VALUES (:ID_DE_CONCEPTO, :NOMBRE_CONCEPTO, :CLASE, :DENOVEDAD, :UNIDAD, :REPORTEEPS, :RANGO2, :RANGO1, :CTA_CRD_ADMINISTRACION, :CTA_DBT_ADMINISTRACION, :CTA_CRD_PRODUCCION, :CTA_DBT_PRODUCCION, :CTA_CRD_VENTAS, :CTA_DBT_VENTAS, :RELACIONADO, :VARCESANTIASPAR, :VARPRIMASEMESTRAL, :VARPRIMAANTIGUEDAD, :VARPRIMAVACACIONES, :VARCESANTIASCONS, :DEVRETENCION, :DEDRETENCION, :CONTROLFECHA, :TIPODEFONDO, :TERCERO, :SUCURSAL, :CODSISE, :PRIORIDAD, :CTA_CRE_PPTAL, :CTA_CONTRACRE_PPTAL, :PERMITE_DUPLICAR, :NITDE, :PORCDC, :RETROACTIVO, :NITCONCEPTO, :FACTOR_PARAFISCAL, :CODJDCN, :FACTOR_RETEFUENTE, :GLCJD, :AGRUPADOPOREMPLEADO, :FACTOR_CESANTIAS, :FACTOR_CESANTIASCONSOLIDADAS, :FACTOR_PRIMAJUNIO, :FACTOR_PRIMANAVIDAD, :FACTOR_VACACIONES, :FACTOR_PRIMAVACACIONES, :FACTOR_PRIMAANTIGUEDAD, :CTA_CRD_OTRO, :CTA_DBT_OTRO, :CODIGO_FIDUPREVISORA, :CODDIAN, :PREST_SOCIAL_CDM, :TIPOAGRCONCEPTO, :EQUIVALENTE_UB, :CTA_CRD_SUPERNUM, :CTA_DBT_SUPERNUM, :FUENTE, :C_BANCO, :C_TIPO_CUENTA, :C_CUENTA, :KARDEX, :C_RETRO, :IND_VOLANTE, :COLUMNA_SIDEF11, :FACTOR_SALARIAL, :FACTOR_PRESTACIONAL, :FACTOR_SUELDOS, :TIPOPAGO, :INGRESO_NO_CONSTITUTIVO_RENTA, :IND_RENTA_EXENTA, TO_DATE(:FECHA_ANTICIPO_CESANTIAS,'DD/MM/YYYY HH24:MI:SS'), :TIPOAGRCONCEPTOS, :BOLCUENTA_ADM_PRICIPAL, :BOLCUENTA_VNT_PRICIPAL, :BOLCUENTA_PRD_PRICIPAL, :BOLCUENTA_OTRO_PRICIPAL, :BOLCUENTA_SUP_PRICIPAL, :OBS_228_1, :OBS_228_2, :FACTOR_EXTRALEGALES, :FACTOR_LEGALES, :FACTOR_OTROSPAGOS, :COLUMNA_SIDEF111, :RUBROS_SIIF, :DOC_SIIF_CONCEPTO, :RES273_2013, :FACTOR_SALARIAL_EMB, :FACTOR_PRESTACIONAL_EMB, :FACTOR_SUELDOS_EMB, :CN_AGR228, :CN_UGPP, :CUOTA_PARTE, :DOCPS, :DOCPV, :DOCVC, :DOCPN, :DOCCS, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :COMPANIA, :SIIF_POSICION_DESCUENTO, :FACTOR40, :FACTOR40PRESTACION, :TIPOCONSOLIDADO, :DEVENGO_BENEFICIO, :SIIF_ATRIBUTOPATRON, :SIIF_ATRIBUTOEMPLEADO, :TIPO_PAGOSIA, :OTROSPAGOSLABORALES, :CGR_CONCEPTO, :FACTOR_BASE_IMPUESTO_COVID, :PERMITE_SUBIR_NOVEDAD, :IND_ING_LABORAL_PROMEDIO)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)"}]}}		</result>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param defaultValue="0" name="DENOVEDAD" sqlType="STRING"/>
		<param name="UNIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="REPORTEEPS" sqlType="STRING"/>
		<param defaultValue="0" name="RANGO2" sqlType="STRING"/>
		<param defaultValue="0" name="RANGO1" sqlType="STRING"/>
		<param defaultValue="" name="CTA_CRD_ADMINISTRACION" sqlType="STRING"/>
		<param defaultValue="" name="CTA_DBT_ADMINISTRACION" sqlType="STRING"/>
		<param defaultValue="" name="CTA_CRD_PRODUCCION" sqlType="STRING"/>
		<param defaultValue="" name="CTA_DBT_PRODUCCION" sqlType="STRING"/>
		<param defaultValue="" name="CTA_CRD_VENTAS" sqlType="STRING"/>
		<param defaultValue="" name="CTA_DBT_VENTAS" sqlType="STRING"/>
		<param defaultValue="" name="RELACIONADO" sqlType="STRING"/>
		<param defaultValue="0" name="VARCESANTIASPAR" sqlType="STRING"/>
		<param defaultValue="0" name="VARPRIMASEMESTRAL" sqlType="STRING"/>
		<param defaultValue="0" name="VARPRIMAANTIGUEDAD" sqlType="STRING"/>
		<param defaultValue="0" name="VARPRIMAVACACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="VARCESANTIASCONS" sqlType="STRING"/>
		<param defaultValue="0" name="DEVRETENCION" sqlType="STRING"/>
		<param defaultValue="0" name="DEDRETENCION" sqlType="STRING"/>
		<param defaultValue="0" name="CONTROLFECHA" sqlType="STRING"/>
		<param defaultValue="NIN" name="TIPODEFONDO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="CODSISE" sqlType="STRING"/>
		<param defaultValue="0" name="PRIORIDAD" sqlType="STRING"/>
		<param defaultValue="" name="CTA_CRE_PPTAL" sqlType="STRING"/>
		<param defaultValue="" name="CTA_CONTRACRE_PPTAL" sqlType="STRING"/>
		<param defaultValue="0" name="PERMITE_DUPLICAR" sqlType="STRING"/>
		<param defaultValue="" name="NITDE" sqlType="STRING"/>
		<param defaultValue="0" name="PORCDC" sqlType="STRING"/>
		<param defaultValue="0" name="RETROACTIVO" sqlType="STRING"/>
		<param defaultValue="" name="NITCONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="FACTOR_PARAFISCAL" sqlType="STRING"/>
