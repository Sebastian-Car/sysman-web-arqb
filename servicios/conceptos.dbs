	<query id="getConceptosDevengosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DEVENGO_BENEFICIO, DEVENGOBENEFICIO , ID_DE_CONCEPTO,(CASE FACTOR40PRESTACION WHEN 0 THEN 'false' ELSE 'true' END) FACTOR40PRESTACION FROM CONCEPTOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DEVENGO_BENEFICIO":"$DEVENGO_BENEFICIO(type:integer)","DEVENGOBENEFICIO":"$DEVENGOBENEFICIO(type:integer)","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","FACTOR40PRESTACION":"$FACTOR40PRESTACION(type:boolean)"}]}}		</result>
 
	</query>
	<resource method="GET" path="conceptos/devengos">
		<call-query href="getConceptosDevengosQuery">
 
		</call-query>
	</resource>
	<query id="getConceptosTotalincapacidadesindrentaexcQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(ABS(CASE WHEN ID_DE_CONCEPTO = 379 THEN IND_RENTA_EXENTA ELSE 0 END)) INDRENTACN379, SUM(ABS(CASE WHEN ID_DE_CONCEPTO &lt;&gt; 379 THEN IND_RENTA_EXENTA ELSE 0 END)) INDRETATOTALINC  FROM CONCEPTOS WHERE COMPANIA = :COMPANIA AND ID_DE_CONCEPTO BETWEEN 370 AND 379</sql>
		<result outputType="json">{"elementos":{"elemento":[{"INDRENTACN379":"$INDRENTACN379(type:integer)","INDRETATOTALINC":"$INDRETATOTALINC(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/totalincapacidadesindrentaexc">
		<call-query href="getConceptosTotalincapacidadesindrentaexcQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getConceptosPagPorremuneracionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.CLASE = 3 ORDER BY CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/porremuneracion/pag">
		<call-query href="getConceptosPagPorremuneracionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumPorremuneracionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.CLASE = 3 ORDER BY CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO) INI WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END) LIKE UPPER(CONCAT(:ID_DE_CONCEPTO, '%')) AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_CONCEPTO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
