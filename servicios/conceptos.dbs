	<query id="getConceptosAaaaaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, CONCEPTOS.CLASE,(CASE CONCEPTOS.DENOVEDAD WHEN 0 THEN 'false' ELSE 'true' END) DENOVEDAD, CONCEPTOS.UNIDAD,(CASE CONCEPTOS.REPORTEEPS WHEN 0 THEN 'false' ELSE 'true' END) REPORTEEPS, CONCEPTOS.RANGO2, CONCEPTOS.RANGO1, CONCEPTOS.CTA_CRD_ADMINISTRACION, CONCEPTOS.CTA_DBT_ADMINISTRACION, CONCEPTOS.CTA_CRD_PRODUCCION, CONCEPTOS.CTA_DBT_PRODUCCION, CONCEPTOS.CTA_CRD_VENTAS, CONCEPTOS.CTA_DBT_VENTAS, CONCEPTOS.RELACIONADO,(CASE CONCEPTOS.VARCESANTIASPAR WHEN 0 THEN 'false' ELSE 'true' END) VARCESANTIASPAR,(CASE CONCEPTOS.VARPRIMASEMESTRAL WHEN 0 THEN 'false' ELSE 'true' END) VARPRIMASEMESTRAL,(CASE CONCEPTOS.VARPRIMAANTIGUEDAD WHEN 0 THEN 'false' ELSE 'true' END) VARPRIMAANTIGUEDAD,(CASE CONCEPTOS.VARPRIMAVACACIONES WHEN 0 THEN 'false' ELSE 'true' END) VARPRIMAVACACIONES,(CASE CONCEPTOS.VARCESANTIASCONS WHEN 0 THEN 'false' ELSE 'true' END) VARCESANTIASCONS,(CASE CONCEPTOS.DEVRETENCION WHEN 0 THEN 'false' ELSE 'true' END) DEVRETENCION,(CASE CONCEPTOS.DEDRETENCION WHEN 0 THEN 'false' ELSE 'true' END) DEDRETENCION,(CASE CONCEPTOS.CONTROLFECHA WHEN 0 THEN 'false' ELSE 'true' END) CONTROLFECHA, CONCEPTOS.TIPODEFONDO, CONCEPTOS.TERCERO, CONCEPTOS.SUCURSAL, (SELECT NOMBRE FROM TERCERO WHERE COMPANIA = CONCEPTOS.COMPANIA AND NIT = CONCEPTOS.TERCERO AND SUCURSAL = TERCERO.SUCURSAL) TERCEROINTERFAZ, CONCEPTOS.CODSISE, CONCEPTOS.PRIORIDAD, CONCEPTOS.CTA_CRE_PPTAL, CONCEPTOS.CTA_CONTRACRE_PPTAL,(CASE CONCEPTOS.PERMITE_DUPLICAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_DUPLICAR, CONCEPTOS.NITDE,(CASE CONCEPTOS.PORCDC WHEN 0 THEN 'false' ELSE 'true' END) PORCDC,(CASE CONCEPTOS.RETROACTIVO WHEN 0 THEN 'false' ELSE 'true' END) RETROACTIVO, CONCEPTOS.NITCONCEPTO,(CASE CONCEPTOS.FACTOR_PARAFISCAL WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PARAFISCAL, CONCEPTOS.CODJDCN,(CASE CONCEPTOS.FACTOR_RETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_RETEFUENTE, CONCEPTOS.GLCJD,(CASE CONCEPTOS.AGRUPADOPOREMPLEADO WHEN 0 THEN 'false' ELSE 'true' END) AGRUPADOPOREMPLEADO,(CASE CONCEPTOS.FACTOR_CESANTIAS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_CESANTIAS,(CASE CONCEPTOS.FACTOR_CESANTIASCONSOLIDADAS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_CESANTIASCONSOLIDADAS,(CASE CONCEPTOS.FACTOR_PRIMAJUNIO WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMAJUNIO,(CASE CONCEPTOS.FACTOR_PRIMANAVIDAD WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMANAVIDAD,(CASE CONCEPTOS.FACTOR_VACACIONES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_VACACIONES,(CASE CONCEPTOS.FACTOR_PRIMAVACACIONES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMAVACACIONES,(CASE CONCEPTOS.FACTOR_PRIMAANTIGUEDAD WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMAANTIGUEDAD, CONCEPTOS.CTA_CRD_OTRO, CONCEPTOS.CTA_DBT_OTRO, CONCEPTOS.CODIGO_FIDUPREVISORA, CONCEPTOS.CODDIAN,(CASE CONCEPTOS.PREST_SOCIAL_CDM WHEN 0 THEN 'false' ELSE 'true' END) PREST_SOCIAL_CDM, CONCEPTOS.TIPOAGRCONCEPTO, CONCEPTOS.EQUIVALENTE_UB, CONCEPTOS.CTA_CRD_SUPERNUM, CONCEPTOS.CTA_DBT_SUPERNUM, CONCEPTOS.FUENTE, CONCEPTOS.C_BANCO, CONCEPTOS.C_TIPO_CUENTA, CONCEPTOS.C_CUENTA,(CASE CONCEPTOS.KARDEX WHEN 0 THEN 'false' ELSE 'true' END) KARDEX, CONCEPTOS.C_RETRO, (SELECT NOMBRE_CONCEPTO FROM CONCEPTOS C WHERE C.COMPANIA = CONCEPTOS.COMPANIA AND C.ID_DE_CONCEPTO = CONCEPTOS.C_RETRO) NOMCONCEPTORETRO,(CASE CONCEPTOS.IND_VOLANTE WHEN 0 THEN 'false' ELSE 'true' END) IND_VOLANTE, CONCEPTOS.COLUMNA_SIDEF11,(CASE CONCEPTOS.FACTOR_SALARIAL WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SALARIAL,(CASE CONCEPTOS.FACTOR_PRESTACIONAL WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRESTACIONAL,(CASE CONCEPTOS.FACTOR_SUELDOS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SUELDOS, CONCEPTOS.TIPOPAGO,(CASE CONCEPTOS.INGRESO_NO_CONSTITUTIVO_RENTA WHEN 0 THEN 'false' ELSE 'true' END) INGRESO_NO_CONSTITUTIVO_RENTA,(CASE CONCEPTOS.IND_RENTA_EXENTA WHEN 0 THEN 'false' ELSE 'true' END) IND_RENTA_EXENTA,(TO_CHAR(CONCEPTOS.FECHA_ANTICIPO_CESANTIAS,'DD/MM/YYYY HH24:MI:SS')) FECHA_ANTICIPO_CESANTIAS, CONCEPTOS.TIPOAGRCONCEPTOS,(CASE CONCEPTOS.BOLCUENTA_ADM_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_ADM_PRICIPAL,(CASE CONCEPTOS.BOLCUENTA_VNT_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_VNT_PRICIPAL,(CASE CONCEPTOS.BOLCUENTA_PRD_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_PRD_PRICIPAL,(CASE CONCEPTOS.BOLCUENTA_OTRO_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_OTRO_PRICIPAL,(CASE CONCEPTOS.BOLCUENTA_SUP_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_SUP_PRICIPAL, CONCEPTOS.OBS_228_1, CONCEPTOS.OBS_228_2,(CASE CONCEPTOS.FACTOR_EXTRALEGALES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_EXTRALEGALES,(CASE CONCEPTOS.FACTOR_LEGALES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_LEGALES,(CASE CONCEPTOS.FACTOR_OTROSPAGOS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_OTROSPAGOS, CONCEPTOS.COLUMNA_SIDEF111, CONCEPTOS.RUBROS_SIIF, CONCEPTOS.DOC_SIIF_CONCEPTO, CONCEPTOS.RES273_2013,(CASE CONCEPTOS.FACTOR_SALARIAL_EMB WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SALARIAL_EMB,(CASE CONCEPTOS.FACTOR_PRESTACIONAL_EMB WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRESTACIONAL_EMB,(CASE CONCEPTOS.FACTOR_SUELDOS_EMB WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SUELDOS_EMB, CONCEPTOS.CN_AGR228, CONCEPTOS.CN_UGPP, CONCEPTOS.CUOTA_PARTE, CONCEPTOS.DOCPS, CONCEPTOS.DOCPV, CONCEPTOS.DOCVC, CONCEPTOS.DOCPN, CONCEPTOS.DOCCS, CONCEPTOS.CREATED_BY,(TO_CHAR(CONCEPTOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, CONCEPTOS.MODIFIED_BY,(TO_CHAR(CONCEPTOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CONCEPTOS.COMPANIA  FROM CONCEPTOS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CLASE":"$CLASE","DENOVEDAD":"$DENOVEDAD(type:boolean)","UNIDAD":"$UNIDAD","REPORTEEPS":"$REPORTEEPS(type:boolean)","RANGO2":"$RANGO2","RANGO1":"$RANGO1","CTA_CRD_ADMINISTRACION":"$CTA_CRD_ADMINISTRACION","CTA_DBT_ADMINISTRACION":"$CTA_DBT_ADMINISTRACION","CTA_CRD_PRODUCCION":"$CTA_CRD_PRODUCCION","CTA_DBT_PRODUCCION":"$CTA_DBT_PRODUCCION","CTA_CRD_VENTAS":"$CTA_CRD_VENTAS","CTA_DBT_VENTAS":"$CTA_DBT_VENTAS","RELACIONADO":"$RELACIONADO(type:integer)","VARCESANTIASPAR":"$VARCESANTIASPAR(type:boolean)","VARPRIMASEMESTRAL":"$VARPRIMASEMESTRAL(type:boolean)","VARPRIMAANTIGUEDAD":"$VARPRIMAANTIGUEDAD(type:boolean)","VARPRIMAVACACIONES":"$VARPRIMAVACACIONES(type:boolean)","VARCESANTIASCONS":"$VARCESANTIASCONS(type:boolean)","DEVRETENCION":"$DEVRETENCION(type:boolean)","DEDRETENCION":"$DEDRETENCION(type:boolean)","CONTROLFECHA":"$CONTROLFECHA(type:boolean)","TIPODEFONDO":"$TIPODEFONDO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","TERCEROINTERFAZ":"$TERCEROINTERFAZ","CODSISE":"$CODSISE","PRIORIDAD":"$PRIORIDAD","CTA_CRE_PPTAL":"$CTA_CRE_PPTAL","CTA_CONTRACRE_PPTAL":"$CTA_CONTRACRE_PPTAL","PERMITE_DUPLICAR":"$PERMITE_DUPLICAR(type:boolean)","NITDE":"$NITDE","PORCDC":"$PORCDC(type:boolean)","RETROACTIVO":"$RETROACTIVO(type:boolean)","NITCONCEPTO":"$NITCONCEPTO","FACTOR_PARAFISCAL":"$FACTOR_PARAFISCAL(type:boolean)","CODJDCN":"$CODJDCN","FACTOR_RETEFUENTE":"$FACTOR_RETEFUENTE(type:boolean)","GLCJD":"$GLCJD","AGRUPADOPOREMPLEADO":"$AGRUPADOPOREMPLEADO(type:boolean)","FACTOR_CESANTIAS":"$FACTOR_CESANTIAS(type:boolean)","FACTOR_CESANTIASCONSOLIDADAS":"$FACTOR_CESANTIASCONSOLIDADAS(type:boolean)","FACTOR_PRIMAJUNIO":"$FACTOR_PRIMAJUNIO(type:boolean)","FACTOR_PRIMANAVIDAD":"$FACTOR_PRIMANAVIDAD(type:boolean)","FACTOR_VACACIONES":"$FACTOR_VACACIONES(type:boolean)","FACTOR_PRIMAVACACIONES":"$FACTOR_PRIMAVACACIONES(type:boolean)","FACTOR_PRIMAANTIGUEDAD":"$FACTOR_PRIMAANTIGUEDAD(type:boolean)","CTA_CRD_OTRO":"$CTA_CRD_OTRO","CTA_DBT_OTRO":"$CTA_DBT_OTRO","CODIGO_FIDUPREVISORA":"$CODIGO_FIDUPREVISORA","CODDIAN":"$CODDIAN","PREST_SOCIAL_CDM":"$PREST_SOCIAL_CDM(type:boolean)","TIPOAGRCONCEPTO":"$TIPOAGRCONCEPTO","EQUIVALENTE_UB":"$EQUIVALENTE_UB","CTA_CRD_SUPERNUM":"$CTA_CRD_SUPERNUM","CTA_DBT_SUPERNUM":"$CTA_DBT_SUPERNUM","FUENTE":"$FUENTE","C_BANCO":"$C_BANCO","C_TIPO_CUENTA":"$C_TIPO_CUENTA","C_CUENTA":"$C_CUENTA","KARDEX":"$KARDEX(type:boolean)","C_RETRO":"$C_RETRO","NOMCONCEPTORETRO":"$NOMCONCEPTORETRO","IND_VOLANTE":"$IND_VOLANTE(type:boolean)","COLUMNA_SIDEF11":"$COLUMNA_SIDEF11","FACTOR_SALARIAL":"$FACTOR_SALARIAL(type:boolean)","FACTOR_PRESTACIONAL":"$FACTOR_PRESTACIONAL(type:boolean)","FACTOR_SUELDOS":"$FACTOR_SUELDOS(type:boolean)","TIPOPAGO":"$TIPOPAGO","INGRESO_NO_CONSTITUTIVO_RENTA":"$INGRESO_NO_CONSTITUTIVO_RENTA(type:boolean)","IND_RENTA_EXENTA":"$IND_RENTA_EXENTA(type:boolean)","FECHA_ANTICIPO_CESANTIAS":"$FECHA_ANTICIPO_CESANTIAS","TIPOAGRCONCEPTOS":"$TIPOAGRCONCEPTOS","BOLCUENTA_ADM_PRICIPAL":"$BOLCUENTA_ADM_PRICIPAL(type:boolean)","BOLCUENTA_VNT_PRICIPAL":"$BOLCUENTA_VNT_PRICIPAL(type:boolean)","BOLCUENTA_PRD_PRICIPAL":"$BOLCUENTA_PRD_PRICIPAL(type:boolean)","BOLCUENTA_OTRO_PRICIPAL":"$BOLCUENTA_OTRO_PRICIPAL(type:boolean)","BOLCUENTA_SUP_PRICIPAL":"$BOLCUENTA_SUP_PRICIPAL(type:boolean)","OBS_228_1":"$OBS_228_1","OBS_228_2":"$OBS_228_2","FACTOR_EXTRALEGALES":"$FACTOR_EXTRALEGALES(type:boolean)","FACTOR_LEGALES":"$FACTOR_LEGALES(type:boolean)","FACTOR_OTROSPAGOS":"$FACTOR_OTROSPAGOS(type:boolean)","COLUMNA_SIDEF111":"$COLUMNA_SIDEF111","RUBROS_SIIF":"$RUBROS_SIIF","DOC_SIIF_CONCEPTO":"$DOC_SIIF_CONCEPTO","RES273_2013":"$RES273_2013","FACTOR_SALARIAL_EMB":"$FACTOR_SALARIAL_EMB(type:boolean)","FACTOR_PRESTACIONAL_EMB":"$FACTOR_PRESTACIONAL_EMB(type:boolean)","FACTOR_SUELDOS_EMB":"$FACTOR_SUELDOS_EMB(type:boolean)","CN_AGR228":"$CN_AGR228","CN_UGPP":"$CN_UGPP","CUOTA_PARTE":"$CUOTA_PARTE","DOCPS":"$DOCPS","DOCPV":"$DOCPV","DOCVC":"$DOCVC","DOCPN":"$DOCPN","DOCCS":"$DOCCS","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","COMPANIA":"$COMPANIA"}]}}		</result>
 
	</query>
