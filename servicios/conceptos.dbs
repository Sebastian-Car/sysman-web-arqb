	<query id="getConceptosNumListaconcepQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, CONCEPTOS.COMPANIA  FROM CONCEPTOS WHERE CONCEPTOS.ID_DE_CONCEPTO BETWEEN '700' AND '798' AND CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.DENOVEDAD = - 1) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/listaconcep/num">
		<call-query href="getConceptosNumListaconcepQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptosPagIdNomCretroPorCiaClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, CONCEPTOS.C_RETRO  FROM CONCEPTOS WHERE CONCEPTOS.C_RETRO IS NOT NULL AND CONCEPTOS.COMPANIA = :COMPANIA AND CONCEPTOS.CLASE = :CLASE ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%')  AND (CASE WHEN C_RETRO IS NULL THEN ' ' ELSE UPPER(C_RETRO) END)  LIKE UPPER(:C_RETRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","C_RETRO":"$C_RETRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="C_RETRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos/idnomcretroporciaclase/pag">
		<call-query href="getConceptosPagIdNomCretroPorCiaClaseQuery">
