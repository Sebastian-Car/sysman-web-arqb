	<query id="deleteConceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="conceptos">
		<call-query href="deleteConceptos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getConceptosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CONCEPTOS.COMPANIA, CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, ( CASE CONCEPTOS.CLASE WHEN 1 THEN 'Informativo' WHEN 3 THEN 'Remuneracion' WHEN 4 THEN 'Total Devengado' WHEN 5 THEN 'Descuento' WHEN 6 THEN 'Total Deducido' WHEN 7 THEN 'Neto a Pagar' WHEN 2 THEN 'Otros Informativos' WHEN 8 THEN 'Contable' WHEN 9 THEN 'Anticipados' WHEN 99 THEN 'Bases' ELSE ' ' END) CLASE  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CLASE":"$CLASE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="conceptos">
		<call-query href="getConceptosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getConceptosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CONCEPTOS.COMPANIA, CONCEPTOS.ID_DE_CONCEPTO, CONCEPTOS.NOMBRE_CONCEPTO, ( CASE CONCEPTOS.CLASE WHEN 1 THEN 'Informativo' WHEN 3 THEN 'Remuneracion' WHEN 4 THEN 'Total Devengado' WHEN 5 THEN 'Descuento' WHEN 6 THEN 'Total Deducido' WHEN 7 THEN 'Neto a Pagar' WHEN 2 THEN 'Otros Informativos' WHEN 8 THEN 'Contable' WHEN 9 THEN 'Anticipados' WHEN 99 THEN 'Bases' ELSE ' ' END) CLASE  FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA = :COMPANIA ORDER BY CONCEPTOS.ID_DE_CONCEPTO) WHERE (CASE WHEN ID_DE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(ID_DE_CONCEPTO) END)  LIKE UPPER(:ID_DE_CONCEPTO || '%')  AND (CASE WHEN NOMBRE_CONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_CONCEPTO) END)  LIKE UPPER( '%' || :NOMBRE_CONCEPTO || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE_CONCEPTO" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/numero">
		<call-query href="getConceptosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_CONCEPTO" query-param="ID_DE_CONCEPTO"/>
			<with-param name="NOMBRE_CONCEPTO" query-param="NOMBRE_CONCEPTO"/>
			<with-param name="CLASE" query-param="CLASE"/>

		</call-query>
	</resource>
	<query id="getConceptosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT ID_DE_CONCEPTO, NOMBRE_CONCEPTO, CLASE,(CASE DENOVEDAD WHEN 0 THEN 'false' ELSE 'true' END) DENOVEDAD, UNIDAD,(CASE REPORTEEPS WHEN 0 THEN 'false' ELSE 'true' END) REPORTEEPS, RANGO2, RANGO1, CTA_CRD_ADMINISTRACION, CTA_DBT_ADMINISTRACION, CTA_CRD_PRODUCCION, CTA_DBT_PRODUCCION, CTA_CRD_VENTAS, CTA_DBT_VENTAS, RELACIONADO, (SELECT NOMBRE_CONCEPTO FROM CONCEPTOS C WHERE C.COMPANIA = CONCEPTOS.COMPANIA AND C.ID_DE_CONCEPTO = CONCEPTOS.RELACIONADO ) NOMCONCEPTORELA,(CASE VARCESANTIASPAR WHEN 0 THEN 'false' ELSE 'true' END) VARCESANTIASPAR,(CASE VARPRIMASEMESTRAL WHEN 0 THEN 'false' ELSE 'true' END) VARPRIMASEMESTRAL,(CASE VARPRIMAANTIGUEDAD WHEN 0 THEN 'false' ELSE 'true' END) VARPRIMAANTIGUEDAD,(CASE VARPRIMAVACACIONES WHEN 0 THEN 'false' ELSE 'true' END) VARPRIMAVACACIONES,(CASE VARCESANTIASCONS WHEN 0 THEN 'false' ELSE 'true' END) VARCESANTIASCONS,(CASE DEVRETENCION WHEN 0 THEN 'false' ELSE 'true' END) DEVRETENCION,(CASE DEDRETENCION WHEN 0 THEN 'false' ELSE 'true' END) DEDRETENCION,(CASE CONTROLFECHA WHEN 0 THEN 'false' ELSE 'true' END) CONTROLFECHA, TIPODEFONDO, TERCERO, SUCURSAL, (SELECT NOMBRE FROM TERCERO WHERE COMPANIA = CONCEPTOS.COMPANIA AND NIT = CONCEPTOS.TERCERO AND SUCURSAL = TERCERO.SUCURSAL ) TERCEROINTERFAZ, CODSISE, PRIORIDAD, CTA_CRE_PPTAL, CTA_CONTRACRE_PPTAL,(CASE PERMITE_DUPLICAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_DUPLICAR, NITDE,(CASE PORCDC WHEN 0 THEN 'false' ELSE 'true' END) PORCDC,(CASE RETROACTIVO WHEN 0 THEN 'false' ELSE 'true' END) RETROACTIVO, NITCONCEPTO,(CASE FACTOR_PARAFISCAL WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PARAFISCAL, CODJDCN,(CASE FACTOR_RETEFUENTE WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_RETEFUENTE, GLCJD,(CASE AGRUPADOPOREMPLEADO WHEN 0 THEN 'false' ELSE 'true' END) AGRUPADOPOREMPLEADO,(CASE FACTOR_CESANTIAS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_CESANTIAS,(CASE FACTOR_CESANTIASCONSOLIDADAS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_CESANTIASCONSOLIDADAS,(CASE FACTOR_PRIMAJUNIO WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMAJUNIO,(CASE FACTOR_PRIMANAVIDAD WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMANAVIDAD,(CASE FACTOR_VACACIONES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_VACACIONES,(CASE FACTOR_PRIMAVACACIONES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMAVACACIONES,(CASE FACTOR_PRIMAANTIGUEDAD WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRIMAANTIGUEDAD, CTA_CRD_OTRO, CTA_DBT_OTRO, CODIGO_FIDUPREVISORA, CODDIAN,(CASE PREST_SOCIAL_CDM WHEN 0 THEN 'false' ELSE 'true' END) PREST_SOCIAL_CDM, TIPOAGRCONCEPTO, EQUIVALENTE_UB, CTA_CRD_SUPERNUM, CTA_DBT_SUPERNUM, FUENTE, C_BANCO, C_TIPO_CUENTA, C_CUENTA,(CASE KARDEX WHEN 0 THEN 'false' ELSE 'true' END) KARDEX, C_RETRO, (SELECT NOMBRE_CONCEPTO FROM CONCEPTOS C WHERE C.COMPANIA = CONCEPTOS.COMPANIA AND C.ID_DE_CONCEPTO = CONCEPTOS.C_RETRO ) NOMCONCEPTORETRO,(CASE IND_VOLANTE WHEN 0 THEN 'false' ELSE 'true' END) IND_VOLANTE, COLUMNA_SIDEF11,(CASE FACTOR_SALARIAL WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SALARIAL,(CASE FACTOR_PRESTACIONAL WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRESTACIONAL,(CASE FACTOR_SUELDOS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SUELDOS, TIPOPAGO,(CASE INGRESO_NO_CONSTITUTIVO_RENTA WHEN 0 THEN 'false' ELSE 'true' END) INGRESO_NO_CONSTITUTIVO_RENTA,(CASE IND_RENTA_EXENTA WHEN 0 THEN 'false' ELSE 'true' END) IND_RENTA_EXENTA,(TO_CHAR(FECHA_ANTICIPO_CESANTIAS,'DD/MM/YYYY HH24:MI:SS')) FECHA_ANTICIPO_CESANTIAS, TIPOAGRCONCEPTOS,(CASE BOLCUENTA_ADM_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_ADM_PRICIPAL,(CASE BOLCUENTA_VNT_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_VNT_PRICIPAL,(CASE BOLCUENTA_PRD_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_PRD_PRICIPAL,(CASE BOLCUENTA_OTRO_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_OTRO_PRICIPAL,(CASE BOLCUENTA_SUP_PRICIPAL WHEN 0 THEN 'false' ELSE 'true' END) BOLCUENTA_SUP_PRICIPAL, OBS_228_1, OBS_228_2,(CASE FACTOR_EXTRALEGALES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_EXTRALEGALES,(CASE FACTOR_LEGALES WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_LEGALES,(CASE FACTOR_OTROSPAGOS WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_OTROSPAGOS, COLUMNA_SIDEF111, RUBROS_SIIF, DOC_SIIF_CONCEPTO, RES273_2013,(CASE FACTOR_SALARIAL_EMB WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SALARIAL_EMB,(CASE FACTOR_PRESTACIONAL_EMB WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_PRESTACIONAL_EMB,(CASE FACTOR_SUELDOS_EMB WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_SUELDOS_EMB, CN_AGR228, CN_UGPP, CUOTA_PARTE, DOCPS, DOCPV, DOCVC, DOCPN, DOCCS, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, COMPANIA,(CASE FACTOR40 WHEN 0 THEN 'false' ELSE 'true' END) FACTOR40,(CASE FACTOR40PRESTACION WHEN 0 THEN 'false' ELSE 'true' END) FACTOR40PRESTACION, SIIF_POSICION_DESCUENTO, TIPOCONSOLIDADO, (CASE DEVENGO_BENEFICIO WHEN 0 THEN 'false' ELSE 'true' END) DEVENGO_BENEFICIO, SIIF_ATRIBUTOPATRON, SIIF_ATRIBUTOEMPLEADO, TIPO_PAGOSIA,(CASE OTROSPAGOSLABORALES WHEN 0 THEN 'false' ELSE 'true' END) OTROSPAGOSLABORALES,CGR_CONCEPTO,(CASE FACTOR_BASE_IMPUESTO_COVID WHEN 0 THEN 'false' ELSE 'true' END) FACTOR_BASE_IMPUESTO_COVID, (CASE PERMITE_SUBIR_NOVEDAD WHEN 0 THEN 'false' ELSE 'true' END) PERMITE_SUBIR_NOVEDAD, (CASE IND_ING_LABORAL_PROMEDIO WHEN 0 THEN 'false' ELSE 'true' END) IND_ING_LABORAL_PROMEDIO FROM CONCEPTOS WHERE CONCEPTOS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID_DE_CONCEPTO":"$ID_DE_CONCEPTO(type:integer)","NOMBRE_CONCEPTO":"$NOMBRE_CONCEPTO","CLASE":"$CLASE","DENOVEDAD":"$DENOVEDAD(type:boolean)","UNIDAD":"$UNIDAD","REPORTEEPS":"$REPORTEEPS(type:boolean)","RANGO2":"$RANGO2","RANGO1":"$RANGO1","CTA_CRD_ADMINISTRACION":"$CTA_CRD_ADMINISTRACION","CTA_DBT_ADMINISTRACION":"$CTA_DBT_ADMINISTRACION","CTA_CRD_PRODUCCION":"$CTA_CRD_PRODUCCION","CTA_DBT_PRODUCCION":"$CTA_DBT_PRODUCCION","CTA_CRD_VENTAS":"$CTA_CRD_VENTAS","CTA_DBT_VENTAS":"$CTA_DBT_VENTAS","RELACIONADO":"$RELACIONADO(type:integer)","NOMCONCEPTORELA":"$NOMCONCEPTORELA","VARCESANTIASPAR":"$VARCESANTIASPAR(type:boolean)","VARPRIMASEMESTRAL":"$VARPRIMASEMESTRAL(type:boolean)","VARPRIMAANTIGUEDAD":"$VARPRIMAANTIGUEDAD(type:boolean)","VARPRIMAVACACIONES":"$VARPRIMAVACACIONES(type:boolean)","VARCESANTIASCONS":"$VARCESANTIASCONS(type:boolean)","DEVRETENCION":"$DEVRETENCION(type:boolean)","DEDRETENCION":"$DEDRETENCION(type:boolean)","CONTROLFECHA":"$CONTROLFECHA(type:boolean)","TIPODEFONDO":"$TIPODEFONDO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","TERCEROINTERFAZ":"$TERCEROINTERFAZ","CODSISE":"$CODSISE","PRIORIDAD":"$PRIORIDAD","CTA_CRE_PPTAL":"$CTA_CRE_PPTAL","CTA_CONTRACRE_PPTAL":"$CTA_CONTRACRE_PPTAL","PERMITE_DUPLICAR":"$PERMITE_DUPLICAR(type:boolean)","NITDE":"$NITDE","PORCDC":"$PORCDC(type:boolean)","RETROACTIVO":"$RETROACTIVO(type:boolean)","NITCONCEPTO":"$NITCONCEPTO","FACTOR_PARAFISCAL":"$FACTOR_PARAFISCAL(type:boolean)","CODJDCN":"$CODJDCN","FACTOR_RETEFUENTE":"$FACTOR_RETEFUENTE(type:boolean)","GLCJD":"$GLCJD","AGRUPADOPOREMPLEADO":"$AGRUPADOPOREMPLEADO(type:boolean)","FACTOR_CESANTIAS":"$FACTOR_CESANTIAS(type:boolean)","FACTOR_CESANTIASCONSOLIDADAS":"$FACTOR_CESANTIASCONSOLIDADAS(type:boolean)","FACTOR_PRIMAJUNIO":"$FACTOR_PRIMAJUNIO(type:boolean)","FACTOR_PRIMANAVIDAD":"$FACTOR_PRIMANAVIDAD(type:boolean)","FACTOR_VACACIONES":"$FACTOR_VACACIONES(type:boolean)","FACTOR_PRIMAVACACIONES":"$FACTOR_PRIMAVACACIONES(type:boolean)","FACTOR_PRIMAANTIGUEDAD":"$FACTOR_PRIMAANTIGUEDAD(type:boolean)","CTA_CRD_OTRO":"$CTA_CRD_OTRO","CTA_DBT_OTRO":"$CTA_DBT_OTRO","CODIGO_FIDUPREVISORA":"$CODIGO_FIDUPREVISORA","CODDIAN":"$CODDIAN","PREST_SOCIAL_CDM":"$PREST_SOCIAL_CDM(type:boolean)","TIPOAGRCONCEPTO":"$TIPOAGRCONCEPTO","EQUIVALENTE_UB":"$EQUIVALENTE_UB","CTA_CRD_SUPERNUM":"$CTA_CRD_SUPERNUM","CTA_DBT_SUPERNUM":"$CTA_DBT_SUPERNUM","FUENTE":"$FUENTE","C_BANCO":"$C_BANCO","C_TIPO_CUENTA":"$C_TIPO_CUENTA","C_CUENTA":"$C_CUENTA","KARDEX":"$KARDEX(type:boolean)","C_RETRO":"$C_RETRO","NOMCONCEPTORETRO":"$NOMCONCEPTORETRO","IND_VOLANTE":"$IND_VOLANTE(type:boolean)","COLUMNA_SIDEF11":"$COLUMNA_SIDEF11","FACTOR_SALARIAL":"$FACTOR_SALARIAL(type:boolean)","FACTOR_PRESTACIONAL":"$FACTOR_PRESTACIONAL(type:boolean)","FACTOR_SUELDOS":"$FACTOR_SUELDOS(type:boolean)","TIPOPAGO":"$TIPOPAGO","INGRESO_NO_CONSTITUTIVO_RENTA":"$INGRESO_NO_CONSTITUTIVO_RENTA(type:boolean)","IND_RENTA_EXENTA":"$IND_RENTA_EXENTA(type:boolean)","FECHA_ANTICIPO_CESANTIAS":"$FECHA_ANTICIPO_CESANTIAS","TIPOAGRCONCEPTOS":"$TIPOAGRCONCEPTOS","BOLCUENTA_ADM_PRICIPAL":"$BOLCUENTA_ADM_PRICIPAL(type:boolean)","BOLCUENTA_VNT_PRICIPAL":"$BOLCUENTA_VNT_PRICIPAL(type:boolean)","BOLCUENTA_PRD_PRICIPAL":"$BOLCUENTA_PRD_PRICIPAL(type:boolean)","BOLCUENTA_OTRO_PRICIPAL":"$BOLCUENTA_OTRO_PRICIPAL(type:boolean)","BOLCUENTA_SUP_PRICIPAL":"$BOLCUENTA_SUP_PRICIPAL(type:boolean)","OBS_228_1":"$OBS_228_1","OBS_228_2":"$OBS_228_2","FACTOR_EXTRALEGALES":"$FACTOR_EXTRALEGALES(type:boolean)","FACTOR_LEGALES":"$FACTOR_LEGALES(type:boolean)","FACTOR_OTROSPAGOS":"$FACTOR_OTROSPAGOS(type:boolean)","COLUMNA_SIDEF111":"$COLUMNA_SIDEF111","RUBROS_SIIF":"$RUBROS_SIIF","DOC_SIIF_CONCEPTO":"$DOC_SIIF_CONCEPTO","RES273_2013":"$RES273_2013","FACTOR_SALARIAL_EMB":"$FACTOR_SALARIAL_EMB(type:boolean)","FACTOR_PRESTACIONAL_EMB":"$FACTOR_PRESTACIONAL_EMB(type:boolean)","FACTOR_SUELDOS_EMB":"$FACTOR_SUELDOS_EMB(type:boolean)","CN_AGR228":"$CN_AGR228","CN_UGPP":"$CN_UGPP","CUOTA_PARTE":"$CUOTA_PARTE","DOCPS":"$DOCPS","DOCPV":"$DOCPV","DOCVC":"$DOCVC","DOCPN":"$DOCPN","DOCCS":"$DOCCS","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","COMPANIA":"$COMPANIA","FACTOR40":"$FACTOR40(type:boolean)","FACTOR40PRESTACION":"$FACTOR40PRESTACION(type:boolean)","SIIF_POSICION_DESCUENTO":"$SIIF_POSICION_DESCUENTO","TIPOCONSOLIDADO":"$TIPOCONSOLIDADO","DEVENGO_BENEFICIO":"$DEVENGO_BENEFICIO","SIIF_ATRIBUTOPATRON":"$SIIF_ATRIBUTOPATRON","SIIF_ATRIBUTOEMPLEADO":"$SIIF_ATRIBUTOEMPLEADO","TIPO_PAGOSIA":"$TIPO_PAGOSIA(type:integer)","OTROSPAGOSLABORALES":"$OTROSPAGOSLABORALES(type:boolean)","CGR_CONCEPTO":"$CGR_CONCEPTO","FACTOR_BASE_IMPUESTO_COVID":"$FACTOR_BASE_IMPUESTO_COVID(type:boolean)","PERMITE_SUBIR_NOVEDAD":"$PERMITE_SUBIR_NOVEDAD(type:boolean)","IND_ING_LABORAL_PROMEDIO":"$IND_ING_LABORAL_PROMEDIO(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="conceptos/data">
		<call-query href="getConceptosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_CONCEPTO" query-param="KEY_ID_DE_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="updateConceptos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CONCEPTOS SET ID_DE_CONCEPTO=:ID_DE_CONCEPTO, NOMBRE_CONCEPTO=:NOMBRE_CONCEPTO, CLASE=:CLASE, DENOVEDAD=:DENOVEDAD, UNIDAD=:UNIDAD, REPORTEEPS=:REPORTEEPS, RANGO2=:RANGO2, RANGO1=:RANGO1, CTA_CRD_ADMINISTRACION=:CTA_CRD_ADMINISTRACION, CTA_DBT_ADMINISTRACION=:CTA_DBT_ADMINISTRACION, CTA_CRD_PRODUCCION=:CTA_CRD_PRODUCCION, CTA_DBT_PRODUCCION=:CTA_DBT_PRODUCCION, CTA_CRD_VENTAS=:CTA_CRD_VENTAS, CTA_DBT_VENTAS=:CTA_DBT_VENTAS, RELACIONADO=:RELACIONADO, VARCESANTIASPAR=:VARCESANTIASPAR, VARPRIMASEMESTRAL=:VARPRIMASEMESTRAL, VARPRIMAANTIGUEDAD=:VARPRIMAANTIGUEDAD, VARPRIMAVACACIONES=:VARPRIMAVACACIONES, VARCESANTIASCONS=:VARCESANTIASCONS, DEVRETENCION=:DEVRETENCION, DEDRETENCION=:DEDRETENCION, CONTROLFECHA=:CONTROLFECHA, TIPODEFONDO=:TIPODEFONDO, TERCERO=:TERCERO, SUCURSAL=:SUCURSAL, CODSISE=:CODSISE, PRIORIDAD=:PRIORIDAD, CTA_CRE_PPTAL=:CTA_CRE_PPTAL, CTA_CONTRACRE_PPTAL=:CTA_CONTRACRE_PPTAL, PERMITE_DUPLICAR=:PERMITE_DUPLICAR, NITDE=:NITDE, PORCDC=:PORCDC, RETROACTIVO=:RETROACTIVO, NITCONCEPTO=:NITCONCEPTO, FACTOR_PARAFISCAL=:FACTOR_PARAFISCAL, CODJDCN=:CODJDCN, FACTOR_RETEFUENTE=:FACTOR_RETEFUENTE, GLCJD=:GLCJD, AGRUPADOPOREMPLEADO=:AGRUPADOPOREMPLEADO, FACTOR_CESANTIAS=:FACTOR_CESANTIAS, FACTOR_CESANTIASCONSOLIDADAS=:FACTOR_CESANTIASCONSOLIDADAS, FACTOR_PRIMAJUNIO=:FACTOR_PRIMAJUNIO, FACTOR_PRIMANAVIDAD=:FACTOR_PRIMANAVIDAD, FACTOR_VACACIONES=:FACTOR_VACACIONES, FACTOR_PRIMAVACACIONES=:FACTOR_PRIMAVACACIONES, FACTOR_PRIMAANTIGUEDAD=:FACTOR_PRIMAANTIGUEDAD, CTA_CRD_OTRO=:CTA_CRD_OTRO, CTA_DBT_OTRO=:CTA_DBT_OTRO, CODIGO_FIDUPREVISORA=:CODIGO_FIDUPREVISORA, CODDIAN=:CODDIAN, PREST_SOCIAL_CDM=:PREST_SOCIAL_CDM, TIPOAGRCONCEPTO=:TIPOAGRCONCEPTO, EQUIVALENTE_UB=:EQUIVALENTE_UB, CTA_CRD_SUPERNUM=:CTA_CRD_SUPERNUM, CTA_DBT_SUPERNUM=:CTA_DBT_SUPERNUM, FUENTE=:FUENTE, C_BANCO=:C_BANCO, C_TIPO_CUENTA=:C_TIPO_CUENTA, C_CUENTA=:C_CUENTA, KARDEX=:KARDEX, C_RETRO=:C_RETRO, IND_VOLANTE=:IND_VOLANTE, COLUMNA_SIDEF11=:COLUMNA_SIDEF11, FACTOR_SALARIAL=:FACTOR_SALARIAL, FACTOR_PRESTACIONAL=:FACTOR_PRESTACIONAL, FACTOR_SUELDOS=:FACTOR_SUELDOS, TIPOPAGO=:TIPOPAGO, INGRESO_NO_CONSTITUTIVO_RENTA=:INGRESO_NO_CONSTITUTIVO_RENTA, IND_RENTA_EXENTA=:IND_RENTA_EXENTA, FECHA_ANTICIPO_CESANTIAS=TO_DATE(:FECHA_ANTICIPO_CESANTIAS,'DD/MM/YYYY HH24:MI:SS'), TIPOAGRCONCEPTOS=:TIPOAGRCONCEPTOS, BOLCUENTA_ADM_PRICIPAL=:BOLCUENTA_ADM_PRICIPAL, BOLCUENTA_VNT_PRICIPAL=:BOLCUENTA_VNT_PRICIPAL, BOLCUENTA_PRD_PRICIPAL=:BOLCUENTA_PRD_PRICIPAL, BOLCUENTA_OTRO_PRICIPAL=:BOLCUENTA_OTRO_PRICIPAL, BOLCUENTA_SUP_PRICIPAL=:BOLCUENTA_SUP_PRICIPAL, OBS_228_1=:OBS_228_1, OBS_228_2=:OBS_228_2, FACTOR_EXTRALEGALES=:FACTOR_EXTRALEGALES, FACTOR_LEGALES=:FACTOR_LEGALES, FACTOR_OTROSPAGOS=:FACTOR_OTROSPAGOS, COLUMNA_SIDEF111=:COLUMNA_SIDEF111, RUBROS_SIIF=:RUBROS_SIIF, DOC_SIIF_CONCEPTO=:DOC_SIIF_CONCEPTO, RES273_2013=:RES273_2013, FACTOR_SALARIAL_EMB=:FACTOR_SALARIAL_EMB, FACTOR_PRESTACIONAL_EMB=:FACTOR_PRESTACIONAL_EMB, FACTOR_SUELDOS_EMB=:FACTOR_SUELDOS_EMB, CN_AGR228=:CN_AGR228, CN_UGPP=:CN_UGPP, CUOTA_PARTE=:CUOTA_PARTE, DOCPS=:DOCPS, DOCPV=:DOCPV, DOCVC=:DOCVC, DOCPN=:DOCPN, DOCCS=:DOCCS, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), FACTOR40=:FACTOR40, FACTOR40PRESTACION=:FACTOR40PRESTACION, SIIF_POSICION_DESCUENTO=:SIIF_POSICION_DESCUENTO, TIPOCONSOLIDADO=:TIPOCONSOLIDADO, DEVENGO_BENEFICIO=:DEVENGO_BENEFICIO, SIIF_ATRIBUTOEMPLEADO=:SIIF_ATRIBUTOEMPLEADO, SIIF_ATRIBUTOPATRON=:SIIF_ATRIBUTOPATRON, TIPO_PAGOSIA=:TIPO_PAGOSIA, OTROSPAGOSLABORALES=:OTROSPAGOSLABORALES, CGR_CONCEPTO=:CGR_CONCEPTO, FACTOR_BASE_IMPUESTO_COVID=:FACTOR_BASE_IMPUESTO_COVID, PERMITE_SUBIR_NOVEDAD=:PERMITE_SUBIR_NOVEDAD, IND_ING_LABORAL_PROMEDIO =:IND_ING_LABORAL_PROMEDIO WHERE CONCEPTOS.COMPANIA= :KEY_COMPANIA AND CONCEPTOS.ID_DE_CONCEPTO= :KEY_ID_DE_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

