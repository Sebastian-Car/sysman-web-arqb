<data name="dpolizasactivos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDpolizasactivosGettotalQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(VALOR_HISTORICO),0) TOTAL_D_POLIZAS FROM D_POLIZAS_ACTIVOS WHERE COMPANIA = :COMPANIA AND ASEGURADORA = :ASEGURADORA AND NUMERO_POLIZA = :NUMERO_POLIZA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL_D_POLIZAS":"$TOTAL_D_POLIZAS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ASEGURADORA" sqlType="STRING"/>
		<param name="NUMERO_POLIZA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dpolizasactivos/gettotal">
		<call-query href="getDpolizasactivosGettotalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ASEGURADORA" query-param="ASEGURADORA"/>
			<with-param name="NUMERO_POLIZA" query-param="NUMERO_POLIZA"/>

		</call-query>
	</resource>
	<query id="deleteDpolizasactivos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_POLIZAS_ACTIVOS WHERE D_POLIZAS_ACTIVOS.COMPANIA= :KEY_COMPANIA AND D_POLIZAS_ACTIVOS.ASEGURADORA= :KEY_ASEGURADORA AND D_POLIZAS_ACTIVOS.SUCURSAL= :KEY_SUCURSAL AND D_POLIZAS_ACTIVOS.NUMERO_POLIZA= :KEY_NUMERO_POLIZA AND D_POLIZAS_ACTIVOS.ELEMENTO= :KEY_ELEMENTO AND D_POLIZAS_ACTIVOS.SERIE= :KEY_SERIE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ASEGURADORA" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_NUMERO_POLIZA" sqlType="STRING"/>
		<param name="KEY_ELEMENTO" sqlType="STRING"/>
		<param name="KEY_SERIE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dpolizasactivos">
		<call-query href="deleteDpolizasactivos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ASEGURADORA" query-param="KEY_ASEGURADORA"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_NUMERO_POLIZA" query-param="KEY_NUMERO_POLIZA"/>
			<with-param name="KEY_ELEMENTO" query-param="KEY_ELEMENTO"/>
			<with-param name="KEY_SERIE" query-param="KEY_SERIE"/>

		</call-query>
	</resource>
	<query id="getDpolizasactivosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  GRUPO ,ELEMENTO ,SERIE ,RIESGO ,COMPANIA ,ASEGURADORA ,NUMERO_POLIZA ,(TO_CHAR(FECHAI,'DD/MM/YYYY HH24:MI:SS')) FECHAI,SUCURSAL ,NOMBRE_ELEMENTO ,(TO_CHAR(FECHAF,'DD/MM/YYYY HH24:MI:SS')) FECHAF, VALOR_HISTORICO FROM D_POLIZAS_ACTIVOS WHERE COMPANIA = :COMPANIA AND ASEGURADORA = :ASEGURADORA AND NUMERO_POLIZA = :NUMERO_POLIZA) WHERE (CASE WHEN GRUPO IS NULL THEN ' ' ELSE UPPER(GRUPO) END)  LIKE UPPER( '%' || :GRUPO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER( '%' || :SERIE || '%')  AND (CASE WHEN RIESGO IS NULL THEN ' ' ELSE UPPER(RIESGO) END)  LIKE UPPER( '%' || :RIESGO || '%') AND (CASE WHEN VALOR_HISTORICO IS NULL THEN ' ' ELSE UPPER(VALOR_HISTORICO) END) LIKE UPPER(CONCAT(:VALOR_HISTORICO, '%'))) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"GRUPO":"$GRUPO","ELEMENTO":"$ELEMENTO","SERIE":"$SERIE","RIESGO":"$RIESGO","COMPANIA":"$COMPANIA","ASEGURADORA":"$ASEGURADORA","NUMERO_POLIZA":"$NUMERO_POLIZA","FECHAI":"$FECHAI","SUCURSAL":"$SUCURSAL","NOMBRE_ELEMENTO":"$NOMBRE_ELEMENTO","FECHAF":"$FECHAF","VALOR_HISTORICO":"$VALOR_HISTORICO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ASEGURADORA" sqlType="STRING"/>
		<param name="NUMERO_POLIZA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="RIESGO" sqlType="STRING"/>
		<param name="VALOR_HISTORICO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dpolizasactivos">
		<call-query href="getDpolizasactivosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ASEGURADORA" query-param="ASEGURADORA"/>
			<with-param name="NUMERO_POLIZA" query-param="NUMERO_POLIZA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="RIESGO" query-param="RIESGO"/>
			<with-param name="VALOR_HISTORICO" query-param="VALOR_HISTORICO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDpolizasactivosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  GRUPO ,ELEMENTO ,SERIE ,RIESGO ,COMPANIA ,ASEGURADORA ,NUMERO_POLIZA ,(TO_CHAR(FECHAI,'DD/MM/YYYY HH24:MI:SS')) FECHAI,SUCURSAL ,NOMBRE_ELEMENTO ,(TO_CHAR(FECHAF,'DD/MM/YYYY HH24:MI:SS')) FECHAF, VALOR_HISTORICO FROM D_POLIZAS_ACTIVOS WHERE COMPANIA = :COMPANIA AND ASEGURADORA = :ASEGURADORA AND NUMERO_POLIZA = :NUMERO_POLIZA) WHERE (CASE WHEN GRUPO IS NULL THEN ' ' ELSE UPPER(GRUPO) END)  LIKE UPPER( '%' || :GRUPO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END)  LIKE UPPER( '%' || :SERIE || '%')  AND (CASE WHEN RIESGO IS NULL THEN ' ' ELSE UPPER(RIESGO) END)  LIKE UPPER( '%' || :RIESGO || '%') AND (CASE WHEN VALOR_HISTORICO IS NULL THEN ' ' ELSE UPPER(VALOR_HISTORICO) END) LIKE UPPER(CONCAT(:VALOR_HISTORICO, '%')) ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ASEGURADORA" sqlType="STRING"/>
		<param name="NUMERO_POLIZA" sqlType="STRING"/>
		<param name="GRUPO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="SERIE" sqlType="STRING"/>
		<param name="RIESGO" sqlType="STRING"/>
		<param name="VALOR_HISTORICO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dpolizasactivos/numero">
		<call-query href="getDpolizasactivosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ASEGURADORA" query-param="ASEGURADORA"/>
			<with-param name="NUMERO_POLIZA" query-param="NUMERO_POLIZA"/>
			<with-param name="GRUPO" query-param="GRUPO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="SERIE" query-param="SERIE"/>
			<with-param name="RIESGO" query-param="RIESGO"/>
			<with-param name="VALOR_HISTORICO" query-param="VALOR_HISTORICO"/>

		</call-query>
	</resource>

</data>