			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="CENTROCOSTO" query-param="CENTROCOSTO"/>

		</call-query>
	</resource>
	<query id="getSpconceptosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_CONCEPTOS.COMPANIA, SP_CONCEPTOS.CODIGO, SP_CONCEPTOS.VALOR, SP_CONCEPTOS.INTERES, SP_CONCEPTOS.CENTROCOSTO, SP_CONCEPTOS.DESCRIPCIONINTERFACE, SP_CONCEPTOS.CUENTADBDEUDA, SP_CONCEPTOS.CUENTACRDEUDA, SP_CONCEPTOS.CUENTADBFACTURADO, SP_CONCEPTOS.CUENTACRFACTURADO, SP_CONCEPTOS.CUENTADBRECAUDADO, SP_CONCEPTOS.CUENTACRRECAUDADO, SP_CONCEPTOS.CUENTADBRECAUDADOFAC, SP_CONCEPTOS.CUENTACRRECAUDADOFAC, SP_CONCEPTOS.SERVICIO, SP_CONCEPTOS.IVA, SP_CONCEPTOS.RECARGO, SP_CONCEPTOS.AUTORETENCION, SP_CONCEPTOS.CUENTADBSALDOCREDITO, SP_CONCEPTOS.CUENTACRSALDOCREDITO, SP_CONCEPTOS.CUENTADBABONO, SP_CONCEPTOS.CUENTACRABONO, SP_CONCEPTOS.CUENTADBRECAUDADODEUDA, SP_CONCEPTOS.CUENTACRRECAUDADODEUDA, SP_CONCEPTOS.CUENTADBRECAUDADOPERIODO, SP_CONCEPTOS.CUENTACRRECAUDADOPERIODO, SP_CONCEPTOS.CUENTADBPAGOSDOBLES, SP_CONCEPTOS.CUENTACRPAGOSDOBLES, SP_CONCEPTOS.CUENTADBFINANCIACIONPERIODO, SP_CONCEPTOS.CUENTACRFINANCIACIONPERIODO, SP_CONCEPTOS.CTADBRECABONODEUDA, SP_CONCEPTOS.CTACRRECABONODEUDA, SP_CONCEPTOS.CTADBRECABONOPERIODO, SP_CONCEPTOS.CTACRRECABONOPERIODO, SP_CONCEPTOS.CTADBRECFINANCIACIONDEUDA, SP_CONCEPTOS.CTACRRECFINANCIACIONDEUDA, SP_CONCEPTOS.CTADBRECFINANCIACIONPERIODO, SP_CONCEPTOS.CTACRRECFINANCIACIONPERIODO, SP_CONCEPTOS.ORDENABONAR,(CASE SP_CONCEPTOS.NOREPORTAR WHEN 0 THEN 'false' ELSE 'true' END) NOREPORTAR,(CASE SP_CONCEPTOS.FINANCIAR WHEN 0 THEN 'false' ELSE 'true' END) FINANCIAR, SP_CONCEPTOS.NOMBRE,(CASE SP_CONCEPTOS.ACUMFIN WHEN 0 THEN 'false' ELSE 'true' END) ACUMFIN, SP_CONCEPTOS.AUXILIAR, SP_CONCEPTOS.PORC_DESCUENTO, SP_CONCEPTOS.CREATED_BY,(TO_CHAR(SP_CONCEPTOS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_CONCEPTOS.MODIFIED_BY,(TO_CHAR(SP_CONCEPTOS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, CENTRO_COSTO.NOMBRE NOMBRECENTROCOSTO  FROM SP_CONCEPTOS INNER JOIN CENTRO_COSTO ON SP_CONCEPTOS.COMPANIA = CENTRO_COSTO.COMPANIA AND EXTRACT(YEAR FROM SYSDATE) = CENTRO_COSTO.ANO AND SP_CONCEPTOS.CENTROCOSTO = CENTRO_COSTO.CODIGO WHERE SP_CONCEPTOS.COMPANIA= :KEY_COMPANIA AND SP_CONCEPTOS.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO(type:integer)","VALOR":"$VALOR","INTERES":"$INTERES","CENTROCOSTO":"$CENTROCOSTO","DESCRIPCIONINTERFACE":"$DESCRIPCIONINTERFACE","CUENTADBDEUDA":"$CUENTADBDEUDA","CUENTACRDEUDA":"$CUENTACRDEUDA","CUENTADBFACTURADO":"$CUENTADBFACTURADO","CUENTACRFACTURADO":"$CUENTACRFACTURADO","CUENTADBRECAUDADO":"$CUENTADBRECAUDADO","CUENTACRRECAUDADO":"$CUENTACRRECAUDADO","CUENTADBRECAUDADOFAC":"$CUENTADBRECAUDADOFAC","CUENTACRRECAUDADOFAC":"$CUENTACRRECAUDADOFAC","SERVICIO":"$SERVICIO","IVA":"$IVA","RECARGO":"$RECARGO","AUTORETENCION":"$AUTORETENCION","CUENTADBSALDOCREDITO":"$CUENTADBSALDOCREDITO","CUENTACRSALDOCREDITO":"$CUENTACRSALDOCREDITO","CUENTADBABONO":"$CUENTADBABONO","CUENTACRABONO":"$CUENTACRABONO","CUENTADBRECAUDADODEUDA":"$CUENTADBRECAUDADODEUDA","CUENTACRRECAUDADODEUDA":"$CUENTACRRECAUDADODEUDA","CUENTADBRECAUDADOPERIODO":"$CUENTADBRECAUDADOPERIODO","CUENTACRRECAUDADOPERIODO":"$CUENTACRRECAUDADOPERIODO","CUENTADBPAGOSDOBLES":"$CUENTADBPAGOSDOBLES","CUENTACRPAGOSDOBLES":"$CUENTACRPAGOSDOBLES","CUENTADBFINANCIACIONPERIODO":"$CUENTADBFINANCIACIONPERIODO","CUENTACRFINANCIACIONPERIODO":"$CUENTACRFINANCIACIONPERIODO","CTADBRECABONODEUDA":"$CTADBRECABONODEUDA","CTACRRECABONODEUDA":"$CTACRRECABONODEUDA","CTADBRECABONOPERIODO":"$CTADBRECABONOPERIODO","CTACRRECABONOPERIODO":"$CTACRRECABONOPERIODO","CTADBRECFINANCIACIONDEUDA":"$CTADBRECFINANCIACIONDEUDA","CTACRRECFINANCIACIONDEUDA":"$CTACRRECFINANCIACIONDEUDA","CTADBRECFINANCIACIONPERIODO":"$CTADBRECFINANCIACIONPERIODO","CTACRRECFINANCIACIONPERIODO":"$CTACRRECFINANCIACIONPERIODO","ORDENABONAR":"$ORDENABONAR","NOREPORTAR":"$NOREPORTAR(type:boolean)","FINANCIAR":"$FINANCIAR(type:boolean)","NOMBRE":"$NOMBRE","ACUMFIN":"$ACUMFIN(type:boolean)","AUXILIAR":"$AUXILIAR","PORC_DESCUENTO":"$PORC_DESCUENTO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRECENTROCOSTO":"$NOMBRECENTROCOSTO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
