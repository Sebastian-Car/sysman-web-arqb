	<query id="getSpconceptosNumConceptosFinanciablesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, NVL(VALOR,0) VALOR, NVL(INTERES,0) PORCINTERES  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND NVL(FINANCIAR,0) IN(0) AND (CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR CODIGO IN (247,47) OR INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CONCEPTOS), CODIGO, 1) &gt; 0) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTOS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>

	</query>
