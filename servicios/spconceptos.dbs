<data name="spconceptos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpconceptosExisteporcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) CUENTA  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND CODIGO = :CONCEPTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spconceptos/existeporcodigo">
		<call-query href="getSpconceptosExisteporcodigoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getSpconceptosTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spconceptos/todosporcompania">
		<call-query href="getSpconceptosTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpconceptosPagTodosPorConceptosEspecificosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_CONCEPTOS.CODIGO, SP_CONCEPTOS.NOMBRE,(CASE SP_CONCEPTOS.FINANCIAR WHEN 0 THEN 'false' ELSE 'true' END) FINANCIAR FROM SP_CONCEPTOS WHERE (SP_CONCEPTOS.FINANCIAR IN (0) AND SP_CONCEPTOS.COMPANIA = :COMPANIA AND (SP_CONCEPTOS.CODIGO BETWEEN 6 AND 16 OR SP_CONCEPTOS.CODIGO BETWEEN 25 AND 29 OR SP_CONCEPTOS.CODIGO BETWEEN 34 AND 46 OR SP_CONCEPTOS.CODIGO = CASE WHEN PCK_SYSMAN_UTL.FC_PAR(:COMPANIA,'PERMITE FINANCIAR CONCEPTO 32', PCK_DATOS.FC_MODULOSERVICIOSPUBLICOS, SYSDATE) = 'SI' THEN 32 ELSE 0 END )) OR (SP_CONCEPTOS.COMPANIA = :COMPANIA AND SP_CONCEPTOS.CODIGO IN (247, 47)) ORDER BY SP_CONCEPTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","FINANCIAR":"$FINANCIAR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spconceptos/todosporconceptosespecificos/pag">
		<call-query href="getSpconceptosPagTodosPorConceptosEspecificosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpconceptosNumTodosPorConceptosEspecificosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_CONCEPTOS.CODIGO, SP_CONCEPTOS.NOMBRE,(CASE SP_CONCEPTOS.FINANCIAR WHEN 0 THEN 'false' ELSE 'true' END) FINANCIAR FROM SP_CONCEPTOS WHERE (SP_CONCEPTOS.FINANCIAR IN (0) AND SP_CONCEPTOS.COMPANIA = :COMPANIA AND (SP_CONCEPTOS.CODIGO BETWEEN 6 AND 16 OR SP_CONCEPTOS.CODIGO BETWEEN 25 AND 29 OR SP_CONCEPTOS.CODIGO BETWEEN 34 AND 46 OR SP_CONCEPTOS.CODIGO = CASE WHEN PCK_SYSMAN_UTL.FC_PAR(:COMPANIA,'PERMITE FINANCIAR CONCEPTO 32', PCK_DATOS.FC_MODULOSERVICIOSPUBLICOS, SYSDATE) = 'SI' THEN 32 ELSE 0 END )) OR (SP_CONCEPTOS.COMPANIA = :COMPANIA AND SP_CONCEPTOS.CODIGO IN (247, 47)) ORDER BY SP_CONCEPTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spconceptos/todosporconceptosespecificos/num">
		<call-query href="getSpconceptosNumTodosPorConceptosEspecificosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpconceptosPagConceptosFinanciablesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, NVL(VALOR,0) VALOR, NVL(INTERES,0) PORCINTERES  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND NVL(FINANCIAR,0) IN(0) AND (CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR CODIGO IN (32, 247,47) OR INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CONCEPTOS), CODIGO, 1) &gt; 0 ) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","VALOR":"$VALOR(type:integer)","PORCINTERES":"$PORCINTERES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTOS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spconceptos/conceptosfinanciablesregistro/pag">
		<call-query href="getSpconceptosPagConceptosFinanciablesRegistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTOS" query-param="CONCEPTOS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpconceptosNumConceptosFinanciablesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, NVL(VALOR,0) VALOR, NVL(INTERES,0) PORCINTERES  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND NVL(FINANCIAR,0) IN(0) AND (CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR CODIGO IN (32, 247,47) OR INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CONCEPTOS), CODIGO, 1) &gt; 0 ) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTOS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spconceptos/conceptosfinanciablesregistro/num">
		<call-query href="getSpconceptosNumConceptosFinanciablesRegistroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTOS" query-param="CONCEPTOS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>

		</call-query>
	</resource>
	<query id="getSpconceptosPagFinanciaConceptosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, NVL(VALOR,0) VALOR, NVL(INTERES,0) PORCINTERES  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND NVL(FINANCIAR,0) IN(0) AND (CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR CODIGO IN (32, 247,47)) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","VALOR":"$VALOR(type:integer)","PORCINTERES":"$PORCINTERES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spconceptos/financiaconceptos/pag">
		<call-query href="getSpconceptosPagFinanciaConceptosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpconceptosNumFinanciaConceptosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, NOMBRE, NVL(VALOR,0) VALOR, NVL(INTERES,0) PORCINTERES  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND NVL(FINANCIAR,0) IN(0) AND (CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR CODIGO IN (32, 247,47)) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER( '%' || :VALOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spconceptos/financiaconceptos/num">
		<call-query href="getSpconceptosNumFinanciaConceptosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>

		</call-query>
	</resource>
	<query id="getSpconceptosPagConceptosFinanciablesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, NVL(VALOR,0) VALOR, NVL(INTERES,0) PORCINTERES  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND NVL(FINANCIAR,0) IN(0) AND (CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR CODIGO IN (247,47) OR INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(:CONCEPTOS), CODIGO, 1) &gt; 0) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","VALOR":"$VALOR(type:integer)","PORCINTERES":"$PORCINTERES(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTOS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spconceptos/conceptosfinanciables/pag">
		<call-query href="getSpconceptosPagConceptosFinanciablesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTOS" query-param="CONCEPTOS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertSpconceptos" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_CONCEPTOS (CUENTACRABONO, ACUMFIN, CODIGO, CTADBRECFINANCIACIONPERIODO, CUENTACRSALDOCREDITO, CUENTADBRECAUDADOFAC, CUENTACRRECAUDADOFAC, DESCRIPCIONINTERFACE, CUENTACRFINANCIACIONPERIODO, CUENTACRRECAUDADOPERIODO, CUENTADBRECAUDADODEUDA, AUTORETENCION, CUENTACRFACTURADO, CUENTADBFINANCIACIONPERIODO, CUENTACRDEUDA, CUENTACRRECAUDADO, CTACRRECABONODEUDA, IVA, CUENTADBFACTURADO, CTACRRECFINANCIACIONDEUDA, CTACRRECFINANCIACIONPERIODO, FINANCIAR, CTACRRECABONOPERIODO, CUENTACRRECAUDADODEUDA, PORC_DESCUENTO, CUENTADBRECAUDADOPERIODO, NOMBRE, CUENTADBDEUDA, CUENTADBPAGOSDOBLES, CUENTADBABONO, CUENTADBSALDOCREDITO, CTADBRECABONODEUDA, RECARGO, COMPANIA, INTERES, SERVICIO, CENTROCOSTO, CTADBRECABONOPERIODO, CTADBRECFINANCIACIONDEUDA, CUENTACRPAGOSDOBLES, VALOR, CUENTADBRECAUDADO, CREATED_BY, DATE_CREATED) VALUES (:CUENTACRABONO, :ACUMFIN, :CODIGO, :CTADBRECFINANCIACIONPERIODO, :CUENTACRSALDOCREDITO, :CUENTADBRECAUDADOFAC, :CUENTACRRECAUDADOFAC, :DESCRIPCIONINTERFACE, :CUENTACRFINANCIACIONPERIODO, :CUENTACRRECAUDADOPERIODO, :CUENTADBRECAUDADODEUDA, :AUTORETENCION, :CUENTACRFACTURADO, :CUENTADBFINANCIACIONPERIODO, :CUENTACRDEUDA, :CUENTACRRECAUDADO, :CTACRRECABONODEUDA, :IVA, :CUENTADBFACTURADO, :CTACRRECFINANCIACIONDEUDA, :CTACRRECFINANCIACIONPERIODO, :FINANCIAR, :CTACRRECABONOPERIODO, :CUENTACRRECAUDADODEUDA, :PORC_DESCUENTO, :CUENTADBRECAUDADOPERIODO, :NOMBRE, :CUENTADBDEUDA, :CUENTADBPAGOSDOBLES, :CUENTADBABONO, :CUENTADBSALDOCREDITO, :CTADBRECABONODEUDA, :RECARGO, :COMPANIA, :INTERES, :SERVICIO, :CENTROCOSTO, :CTADBRECABONOPERIODO, :CTADBRECFINANCIACIONDEUDA, :CUENTACRPAGOSDOBLES, :VALOR, :CUENTADBRECAUDADO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param defaultValue="" name="CUENTACRABONO" sqlType="STRING"/>
		<param defaultValue="0" name="ACUMFIN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="CTADBRECFINANCIACIONPERIODO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRSALDOCREDITO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBRECAUDADOFAC" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRRECAUDADOFAC" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCIONINTERFACE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRFINANCIACIONPERIODO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRRECAUDADOPERIODO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBRECAUDADODEUDA" sqlType="STRING"/>
		<param defaultValue="0" name="AUTORETENCION" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRFACTURADO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBFINANCIACIONPERIODO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRDEUDA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRRECAUDADO" sqlType="STRING"/>
		<param defaultValue="" name="CTACRRECABONODEUDA" sqlType="STRING"/>
		<param defaultValue="0" name="IVA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBFACTURADO" sqlType="STRING"/>
		<param defaultValue="" name="CTACRRECFINANCIACIONDEUDA" sqlType="STRING"/>
		<param defaultValue="" name="CTACRRECFINANCIACIONPERIODO" sqlType="STRING"/>
		<param defaultValue="0" name="FINANCIAR" sqlType="STRING"/>
		<param defaultValue="" name="CTACRRECABONOPERIODO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRRECAUDADODEUDA" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_DESCUENTO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBRECAUDADOPERIODO" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBDEUDA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBPAGOSDOBLES" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBABONO" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBSALDOCREDITO" sqlType="STRING"/>
		<param defaultValue="" name="CTADBRECABONODEUDA" sqlType="STRING"/>
		<param defaultValue="0" name="RECARGO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="0" name="INTERES" sqlType="STRING"/>
		<param name="SERVICIO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTROCOSTO" sqlType="STRING"/>
		<param defaultValue="" name="CTADBRECABONOPERIODO" sqlType="STRING"/>
		<param defaultValue="" name="CTADBRECFINANCIACIONDEUDA" sqlType="STRING"/>
		<param defaultValue="" name="CUENTACRPAGOSDOBLES" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="CUENTADBRECAUDADO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spconceptos">
		<call-query href="insertSpconceptos">
			<with-param name="CUENTACRABONO" query-param="CUENTACRABONO"/>
			<with-param name="ACUMFIN" query-param="ACUMFIN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CTADBRECFINANCIACIONPERIODO" query-param="CTADBRECFINANCIACIONPERIODO"/>
			<with-param name="CUENTACRSALDOCREDITO" query-param="CUENTACRSALDOCREDITO"/>
			<with-param name="CUENTADBRECAUDADOFAC" query-param="CUENTADBRECAUDADOFAC"/>
			<with-param name="CUENTACRRECAUDADOFAC" query-param="CUENTACRRECAUDADOFAC"/>
			<with-param name="DESCRIPCIONINTERFACE" query-param="DESCRIPCIONINTERFACE"/>
			<with-param name="CUENTACRFINANCIACIONPERIODO" query-param="CUENTACRFINANCIACIONPERIODO"/>
			<with-param name="CUENTACRRECAUDADOPERIODO" query-param="CUENTACRRECAUDADOPERIODO"/>
			<with-param name="CUENTADBRECAUDADODEUDA" query-param="CUENTADBRECAUDADODEUDA"/>
			<with-param name="AUTORETENCION" query-param="AUTORETENCION"/>
			<with-param name="CUENTACRFACTURADO" query-param="CUENTACRFACTURADO"/>
			<with-param name="CUENTADBFINANCIACIONPERIODO" query-param="CUENTADBFINANCIACIONPERIODO"/>
			<with-param name="CUENTACRDEUDA" query-param="CUENTACRDEUDA"/>
			<with-param name="CUENTACRRECAUDADO" query-param="CUENTACRRECAUDADO"/>
			<with-param name="CTACRRECABONODEUDA" query-param="CTACRRECABONODEUDA"/>
