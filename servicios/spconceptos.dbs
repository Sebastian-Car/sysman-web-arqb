	<query id="getSpconceptosPagPorNombreYValoresFacturadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT SP_FACTURADO.CONCEPTO, SP_CONCEPTOS.NOMBRE, SP_FACTURADO.VALOR_FACTURADO, SP_FACTURADO.DEUDA  FROM SP_CONCEPTOS INNER JOIN SP_FACTURADO ON SP_CONCEPTOS.COMPANIA = SP_FACTURADO.COMPANIA AND SP_CONCEPTOS.CODIGO = SP_FACTURADO.CONCEPTO WHERE ((SP_FACTURADO.CONCEPTO BETWEEN 0 AND 11 OR SP_FACTURADO.CONCEPTO BETWEEN 13 AND 49 OR SP_FACTURADO.CONCEPTO IN (246, 247, 248, 249)) AND SP_FACTURADO.COMPANIA = :COMPANIA AND SP_FACTURADO.CICLO = :CICLO AND SP_FACTURADO.ANO = :ANO AND SP_FACTURADO.PERIODO = :PERIODO AND SP_FACTURADO.CODIGORUTA = :CODIGORUTA AND VALOR_FACTURADO + DEUDA NOT IN (0))) WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR_FACTURADO IS NULL THEN ' ' ELSE UPPER(VALOR_FACTURADO) END)  LIKE UPPER(:VALOR_FACTURADO || '%')  AND (CASE WHEN DEUDA IS NULL THEN ' ' ELSE UPPER(DEUDA) END)  LIKE UPPER(:DEUDA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONCEPTO":"$CONCEPTO(type:integer)","NOMBRE":"$NOMBRE","VALOR_FACTURADO":"$VALOR_FACTURADO","DEUDA":"$DEUDA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR_FACTURADO" sqlType="STRING"/>
		<param name="DEUDA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
