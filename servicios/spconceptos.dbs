		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, NOMBRE, NVL(VALOR,0) VALOR, NVL(INTERES,0) PORCINTERES  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND NVL(FINANCIAR,0) IN(0) AND (CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR CODIGO IN (247,47)) ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","VALOR":"$VALOR(type:integer)","PORCINTERES":"$PORCINTERES(type:integer)"}]}}		</result>
