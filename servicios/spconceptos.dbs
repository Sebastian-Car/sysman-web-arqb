	<query id="getSpconceptosPagCodNombreEntre1A48CodsQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, + NVL( NOMBRE,'SIN NOMBRE') AS NOMBRE  FROM SP_CONCEPTOS WHERE COMPANIA = :COMPANIA AND CODIGO BETWEEN 1 AND 48 AND CODIGO NOT IN(1, 2, 3, 4, 5, 16, 17, 18, 19, 20, 21, 22, 23, 24, 31, 33)) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
