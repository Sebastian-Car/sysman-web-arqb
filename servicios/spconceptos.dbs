	<query id="getSpconceptosPagCodynomyvaloreinteresconfinanciarycodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE, VALOR, INTERES FROM SP_CONCEPTOS WHERE COMPANIA =:COMPANIA AND FINANCIAR IN ( 0 ) AND ( CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CONCEPTO,' ','') ),CONCAT('',CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS (REPLACE(CODIGO,' ','') ),'') ),1) &gt; 0 ) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN INTERES IS NULL THEN ' ' ELSE UPPER(INTERES) END) LIKE UPPER(CONCAT(:INTERES, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","VALOR":"$VALOR","INTERES":"$INTERES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spconceptos/codynomyvaloreinteresconfinanciarycod/pag">
		<call-query href="getSpconceptosPagCodynomyvaloreinteresconfinanciarycodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpconceptosNumCodynomyvaloreinteresconfinanciarycodQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO, NOMBRE, VALOR, INTERES FROM SP_CONCEPTOS WHERE COMPANIA =:COMPANIA AND FINANCIAR IN ( 0 ) AND ( CODIGO BETWEEN 6 AND 16 OR CODIGO BETWEEN 25 AND 29 OR CODIGO BETWEEN 34 AND 46 OR INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CONCEPTO,' ','') ),CONCAT('',CONCAT(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS (REPLACE(CODIGO,' ','') ),'') ),1) &gt; 0 ) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(:VALOR, '%')) AND (CASE WHEN INTERES IS NULL THEN ' ' ELSE UPPER(INTERES) END) LIKE UPPER(CONCAT(:INTERES, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spconceptos/codynomyvaloreinteresconfinanciarycod/num">
		<call-query href="getSpconceptosNumCodynomyvaloreinteresconfinanciarycodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="INTERES" query-param="INTERES"/>

		</call-query>
	</resource>
	<query id="getSpconceptosPagNombreValorPorConceptosCicloRutaPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  FACTURADO.CONCEPTO CODIGO, CONCEPTOS.NOMBRE, FACTURADO.VALOR_FACTURADO  FROM SP_CONCEPTOS CONCEPTOS INNER JOIN SP_FACTURADO FACTURADO ON CONCEPTOS.COMPANIA = FACTURADO.COMPANIA AND CONCEPTOS.CODIGO = FACTURADO.CONCEPTO WHERE FACTURADO.CONCEPTO NOT IN (12,250,17,49) AND FACTURADO.COMPANIA = :COMPANIA AND FACTURADO.CICLO = :CICLO AND FACTURADO.CODIGORUTA = :CODIGORUTA AND FACTURADO.ANO = :ANO AND FACTURADO.PERIODO = :PERIODO AND FACTURADO.VALOR_FACTURADO+FACTURADO.DEUDA &lt;&gt;0 ORDER BY FACTURADO.CONCEPTO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO(type:integer)","NOMBRE":"$NOMBRE","VALOR_FACTURADO":"$VALOR_FACTURADO"}]}}		</result>
