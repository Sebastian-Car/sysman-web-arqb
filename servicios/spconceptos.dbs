		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_CONCEPTOS.CODIGO, SP_CONCEPTOS.NOMBRE, SP_FACTURADO.VALOR_FACTURADO  FROM SP_CONCEPTOS INNER JOIN SP_FACTURADO ON SP_CONCEPTOS.COMPANIA = SP_FACTURADO.COMPANIA AND SP_CONCEPTOS.CODIGO = SP_FACTURADO.CONCEPTO WHERE SP_FACTURADO.COMPANIA = :COMPANIA AND SP_FACTURADO.CICLO = :CICLO AND SP_FACTURADO.CODIGORUTA = :CODIGORUTA AND SP_FACTURADO.ANO = :ANO AND SP_FACTURADO.PERIODO = :PERIODO ORDER BY SP_CONCEPTOS.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
