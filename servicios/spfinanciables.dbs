	<query id="getSpfinanciablesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_FINANCIABLES.COMPANIA, SP_FINANCIABLES.CICLO, SP_FINANCIABLES.CODIGORUTA, SP_FINANCIABLES.ANO, SP_FINANCIABLES.PERIODO, SP_FINANCIABLES.CONCEPTO,(TO_CHAR(SP_FINANCIABLES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_FINANCIABLES.MONTOFINANCIAR, SP_FINANCIABLES.SALDOFINANCIABLE, SP_FINANCIABLES.NUMEROCUOTAS, SP_FINANCIABLES.VALORCUOTA, SP_CONCEPTOS.NOMBRE NOMBRECONCEPTO, BLOQUEADOHASTAANO, PCK_SERVICIOS_PUBLICOS_COM2.FC_NOMBREPERIODOM(SP_FINANCIABLES.COMPANIA, SP_FINANCIABLES.BLOQUEADOHASTAPERIODO) PERUNICO, SP_FINANCIABLES.BLOQUEADOHASTAPERIODO,(CASE SP_FINANCIABLES.BLOQUEADO WHEN 0 THEN 'false' ELSE 'true' END) BLOQUEADO, SP_FINANCIABLES.ANOINICIAL  FROM SP_FINANCIABLES LEFT JOIN SP_CONCEPTOS ON SP_FINANCIABLES.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_FINANCIABLES.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_FINANCIABLES.COMPANIA = :COMPANIA AND SP_FINANCIABLES.CICLO = :CICLO AND SP_FINANCIABLES.CODIGORUTA = :CODIGORUTA AND SP_FINANCIABLES.ANO &gt;= :ANIO AND SP_FINANCIABLES.PERIODO &gt;= :PERIODOFIN ORDER BY SP_FINANCIABLES.ANO, SP_FINANCIABLES.PERIODO, SP_FINANCIABLES.CONCEPTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER( '%' || :CONCEPTO || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN MONTOFINANCIAR IS NULL THEN ' ' ELSE UPPER(MONTOFINANCIAR) END)  LIKE UPPER(:MONTOFINANCIAR || '%')  AND (CASE WHEN SALDOFINANCIABLE IS NULL THEN ' ' ELSE UPPER(SALDOFINANCIABLE) END)  LIKE UPPER(:SALDOFINANCIABLE || '%')  AND (CASE WHEN NUMEROCUOTAS IS NULL THEN ' ' ELSE UPPER(NUMEROCUOTAS) END)  LIKE UPPER(:NUMEROCUOTAS || '%')  AND (CASE WHEN VALORCUOTA IS NULL THEN ' ' ELSE UPPER(VALORCUOTA) END)  LIKE UPPER(:VALORCUOTA || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%')  AND (CASE WHEN BLOQUEADOHASTAANO IS NULL THEN ' ' ELSE UPPER(BLOQUEADOHASTAANO) END)  LIKE UPPER( '%' || :BLOQUEADOHASTAANO || '%')  AND (CASE WHEN PERUNICO IS NULL THEN ' ' ELSE UPPER(PERUNICO) END)  LIKE UPPER( '%' || :PERUNICO || '%')  AND (CASE WHEN BLOQUEADOHASTAPERIODO IS NULL THEN ' ' ELSE UPPER(BLOQUEADOHASTAPERIODO) END)  LIKE UPPER(:BLOQUEADOHASTAPERIODO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
