	</query>
	<resource method="GET" path="spfinanciables/todosporcompaniaciclocodrutainicial/pag">
		<call-query href="getSpfinanciablesPagTodosPorCompaniaCicloCodRutaInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
