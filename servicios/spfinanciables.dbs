	<query id="insertSpfinanciablesPorConsultaDeFacturacion" keyColumns="COMPANIA,CICLO,CODIGORUTA,ANO,PERIODO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_FINANCIABLES (COMPANIA, CONCEPTO, MONTOFINANCIAR, SALDOFINANCIABLE, NUMEROCUOTAS, NROCUOTA, ANOINICIAL, PERIODOINICIAL, VALORCUOTA, PERIODO, CODIGORUTA, CICLO, ANO, BLOQUEADOHASTAANO, BLOQUEADOHASTAPERIODO, BLOQUEADO, HORABLOQUEO, USUARIOBLOQUEO, FECHABLOQUEADO, CODIGOALMACEN, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CONCEPTO, :MONTOFINANCIAR, :SALDOFINANCIABLE, :NUMEROCUOTAS, :NROCUOTA, :ANOINICIAL, :PERIODOINICIAL, :VALORCUOTA, :PERIODO, :CODIGORUTA, :CICLO, :ANO, :BLOQUEADOHASTAANO, :BLOQUEADOHASTAPERIODO, :BLOQUEADO, TO_DATE(:HORABLOQUEO,'DD/MM/YYYY HH24:MI:SS'), :USUARIOBLOQUEO, TO_DATE(:FECHABLOQUEADO,'DD/MM/YYYY HH24:MI:SS'), :CODIGOALMACEN, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_CONCEPTO":"$CONCEPTO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param defaultValue="0" name="MONTOFINANCIAR" sqlType="STRING"/>
		<param defaultValue="0" name="SALDOFINANCIABLE" sqlType="STRING"/>
		<param defaultValue="0" name="NUMEROCUOTAS" sqlType="STRING"/>
		<param defaultValue="1" name="NROCUOTA" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="PERIODOINICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORCUOTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="BLOQUEADOHASTAANO" sqlType="STRING"/>
		<param defaultValue="" name="BLOQUEADOHASTAPERIODO" sqlType="STRING"/>
		<param defaultValue="0" name="BLOQUEADO" sqlType="STRING"/>
		<param defaultValue="" name="HORABLOQUEO" sqlType="STRING"/>
		<param defaultValue="" name="USUARIOBLOQUEO" sqlType="STRING"/>
		<param defaultValue="" name="FECHABLOQUEADO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOALMACEN" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
