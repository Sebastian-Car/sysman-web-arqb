	<query id="getSpfinanciablesCuentasPorCodigoRutaYConcepto12Query"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM SP_FINANCIABLES WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND CONCEPTO = 12 AND SALDOFINANCIABLE NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfinanciables/cuentasporcodigorutayconcepto12">
