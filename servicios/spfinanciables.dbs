	<query id="getSpfinanciablesNumTodosPorCompaniaCicloCodRutaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT FINANCIABLES.CONCEPTO, CONCEPTOS.NOMBRE NOMBRECONCEPTO, FINANCIABLES.ANO, FINANCIABLES.PERIODO, FINANCIABLES.MONTOFINANCIAR, FINANCIABLES.NUMEROCUOTAS, FINANCIABLES.SALDOFINANCIABLE, FINANCIABLES.INTERES, FINANCIABLES.VALORCUOTA  FROM SP_FINANCIABLES FINANCIABLES INNER JOIN SP_CONCEPTOS CONCEPTOS ON FINANCIABLES.COMPANIA = CONCEPTOS.COMPANIA AND FINANCIABLES.CONCEPTO = CONCEPTOS.CODIGO WHERE FINANCIABLES.COMPANIA =:COMPANIA AND FINANCIABLES.CICLO =:CICLO AND FINANCIABLES.CODIGORUTA =:CODIGORUTA AND FINANCIABLES.PERIODO =:PERIODO ORDER BY FINANCIABLES.CONCEPTO) WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
