	<query id="updateSpfinanciablesPorConsultaDeFacturacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_FINANCIABLES SET MONTOFINANCIAR=:MONTOFINANCIAR, SALDOFINANCIABLE=:SALDOFINANCIABLE, NUMEROCUOTAS=:NUMEROCUOTAS, ANOINICIAL=:ANOINICIAL, PERIODOINICIAL=:PERIODOINICIAL, VALORCUOTA=:VALORCUOTA, PERIODO=:PERIODO, ANO=:ANO, BLOQUEADOHASTAANO=:BLOQUEADOHASTAANO, BLOQUEADOHASTAPERIODO=:BLOQUEADOHASTAPERIODO, HORABLOQUEO=TO_DATE(:HORABLOQUEO,'DD/MM/YYYY HH24:MI:SS'), USUARIOBLOQUEO=:USUARIOBLOQUEO, FECHABLOQUEADO=TO_DATE(:FECHABLOQUEADO,'DD/MM/YYYY HH24:MI:SS'), BLOQUEADO=:BLOQUEADO, CODIGOALMACEN=:CODIGOALMACEN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_FINANCIABLES.COMPANIA= :KEY_COMPANIA AND SP_FINANCIABLES.CICLO= :KEY_CICLO AND SP_FINANCIABLES.CODIGORUTA= :KEY_CODIGORUTA AND SP_FINANCIABLES.ANO= :KEY_ANO AND SP_FINANCIABLES.PERIODO= :KEY_PERIODO AND SP_FINANCIABLES.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MONTOFINANCIAR" sqlType="STRING"/>
		<param name="SALDOFINANCIABLE" sqlType="STRING"/>
		<param name="NUMEROCUOTAS" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="PERIODOINICIAL" sqlType="STRING"/>
		<param name="VALORCUOTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
