	<query id="getSpfinanciablesPagInnerconceptosmes_porciclocodrutaanioperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SPF.COMPANIA, SPF.CICLO, SPF.CODIGORUTA, SPF.ANO, SPF.PERIODO, MES.NOMBRE PERUNICO, SPF.CONCEPTO, CON.NOMBRE NOMCONCEPTO, SPF.ANOINICIAL, SPF.PERIODOINICIAL,(TO_CHAR(SPF.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SPF.MONTOFINANCIAR, SPF.SALDOFINANCIABLE, SPF.NUMEROCUOTAS, SPF.NROCUOTA, SPF.VALORCUOTA, SPF.BLOQUEADOHASTAANO, SPF.BLOQUEADOHASTAPERIODO,(CASE SPF.BLOQUEADO WHEN 0 THEN 'false' ELSE 'true' END) BLOQUEADO,(TO_CHAR(SPF.FECHABLOQUEADO,'DD/MM/YYYY HH24:MI:SS')) FECHABLOQUEADO,(TO_CHAR(SPF.HORABLOQUEO,'DD/MM/YYYY HH24:MI:SS')) HORABLOQUEO, SPF.USUARIOBLOQUEO  FROM SP_FINANCIABLES SPF INNER JOIN SP_CONCEPTOS CON ON SPF.COMPANIA = CON.COMPANIA AND SPF.CONCEPTO = CON.CODIGO INNER JOIN MES ON SPF.COMPANIA = MES.COMPANIA AND SPF.ANO = MES.ANO AND TO_NUMBER(SPF.BLOQUEADOHASTAPERIODO) = MES.NUMERO WHERE SPF.COMPANIA = :COMPANIA AND SPF.CICLO = :CICLO AND SPF.CODIGORUTA = :CODIGORUTA AND SPF.ANO &gt;= :MI_ANIO AND SPF.PERIODO &gt;= :MI_PERIODO ORDER BY SPF.ANO, SPF.PERIODO, SPF.CONCEPTO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN PERUNICO IS NULL THEN ' ' ELSE UPPER(PERUNICO) END)  LIKE UPPER( '%' || :PERUNICO || '%')  AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN NOMCONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMCONCEPTO) END)  LIKE UPPER( '%' || :NOMCONCEPTO || '%')  AND (CASE WHEN ANOINICIAL IS NULL THEN ' ' ELSE UPPER(ANOINICIAL) END)  LIKE UPPER(:ANOINICIAL || '%')  AND (CASE WHEN PERIODOINICIAL IS NULL THEN ' ' ELSE UPPER(PERIODOINICIAL) END)  LIKE UPPER(:PERIODOINICIAL || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER( '%' || :DATE_CREATED || '%')  AND (CASE WHEN MONTOFINANCIAR IS NULL THEN ' ' ELSE UPPER(MONTOFINANCIAR) END)  LIKE UPPER(:MONTOFINANCIAR || '%')  AND (CASE WHEN SALDOFINANCIABLE IS NULL THEN ' ' ELSE UPPER(SALDOFINANCIABLE) END)  LIKE UPPER(:SALDOFINANCIABLE || '%')  AND (CASE WHEN NUMEROCUOTAS IS NULL THEN ' ' ELSE UPPER(NUMEROCUOTAS) END)  LIKE UPPER(:NUMEROCUOTAS || '%')  AND (CASE WHEN NROCUOTA IS NULL THEN ' ' ELSE UPPER(NROCUOTA) END)  LIKE UPPER(:NROCUOTA || '%')  AND (CASE WHEN VALORCUOTA IS NULL THEN ' ' ELSE UPPER(VALORCUOTA) END)  LIKE UPPER(:VALORCUOTA || '%')  AND (CASE WHEN BLOQUEADOHASTAANO IS NULL THEN ' ' ELSE UPPER(BLOQUEADOHASTAANO) END)  LIKE UPPER(:BLOQUEADOHASTAANO || '%')  AND (CASE WHEN BLOQUEADOHASTAPERIODO IS NULL THEN ' ' ELSE UPPER(BLOQUEADOHASTAPERIODO) END)  LIKE UPPER(:BLOQUEADOHASTAPERIODO || '%')  AND (CASE WHEN BLOQUEADO IS NULL THEN ' ' ELSE UPPER(BLOQUEADO) END)  LIKE UPPER(:BLOQUEADO || '%')  AND (CASE WHEN FECHABLOQUEADO IS NULL THEN ' ' ELSE UPPER(FECHABLOQUEADO) END)  LIKE UPPER( '%' || :FECHABLOQUEADO || '%')  AND (CASE WHEN HORABLOQUEO IS NULL THEN ' ' ELSE UPPER(HORABLOQUEO) END)  LIKE UPPER( '%' || :HORABLOQUEO || '%')  AND (CASE WHEN USUARIOBLOQUEO IS NULL THEN ' ' ELSE UPPER(USUARIOBLOQUEO) END)  LIKE UPPER( '%' || :USUARIOBLOQUEO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","PERUNICO":"$PERUNICO","CONCEPTO":"$CONCEPTO(type:integer)","NOMCONCEPTO":"$NOMCONCEPTO","ANOINICIAL":"$ANOINICIAL(type:integer)","PERIODOINICIAL":"$PERIODOINICIAL","DATE_CREATED":"$DATE_CREATED","MONTOFINANCIAR":"$MONTOFINANCIAR","SALDOFINANCIABLE":"$SALDOFINANCIABLE","NUMEROCUOTAS":"$NUMEROCUOTAS","NROCUOTA":"$NROCUOTA(type:integer)","VALORCUOTA":"$VALORCUOTA","BLOQUEADOHASTAANO":"$BLOQUEADOHASTAANO(type:integer)","BLOQUEADOHASTAPERIODO":"$BLOQUEADOHASTAPERIODO","BLOQUEADO":"$BLOQUEADO(type:boolean)","FECHABLOQUEADO":"$FECHABLOQUEADO","HORABLOQUEO":"$HORABLOQUEO","USUARIOBLOQUEO":"$USUARIOBLOQUEO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="MI_ANIO" sqlType="STRING"/>
		<param name="MI_PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
