	<query id="updateSpfinanciablesFinanciablesPendientes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_FINANCIABLES SET MONTOFINANCIAR=:MONTOFINANCIAR, SALDOFINANCIABLE=:SALDOFINANCIABLE, NUMEROCUOTAS=:NUMEROCUOTAS, VALORCUOTA=:VALORCUOTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_FINANCIABLES.COMPANIA= :KEY_COMPANIA AND SP_FINANCIABLES.CICLO= :KEY_CICLO AND SP_FINANCIABLES.CODIGORUTA= :KEY_CODIGORUTA AND SP_FINANCIABLES.ANO= :KEY_ANO AND SP_FINANCIABLES.PERIODO= :KEY_PERIODO AND SP_FINANCIABLES.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MONTOFINANCIAR" sqlType="STRING"/>
		<param name="SALDOFINANCIABLE" sqlType="STRING"/>
		<param name="NUMEROCUOTAS" sqlType="STRING"/>
		<param name="VALORCUOTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spfinanciables/financiablespendientes">
		<call-query href="updateSpfinanciablesFinanciablesPendientes">
			<with-param name="MONTOFINANCIAR" query-param="MONTOFINANCIAR"/>
			<with-param name="SALDOFINANCIABLE" query-param="SALDOFINANCIABLE"/>
			<with-param name="NUMEROCUOTAS" query-param="NUMEROCUOTAS"/>
			<with-param name="VALORCUOTA" query-param="VALORCUOTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
