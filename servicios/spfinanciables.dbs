<data name="spfinanciables" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpfinanciablesPagTodosPorCompaniaCicloCodRutaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT FINANCIABLES.CONCEPTO, CONCEPTOS.NOMBRE NOMBRECONCEPTO, FINANCIABLES.ANO, FINANCIABLES.PERIODO, FINANCIABLES.MONTOFINANCIAR, FINANCIABLES.NUMEROCUOTAS, FINANCIABLES.SALDOFINANCIABLE, FINANCIABLES.INTERES, FINANCIABLES.VALORCUOTA  FROM SP_FINANCIABLES FINANCIABLES INNER JOIN SP_CONCEPTOS CONCEPTOS ON FINANCIABLES.COMPANIA = CONCEPTOS.COMPANIA AND FINANCIABLES.CONCEPTO = CONCEPTOS.CODIGO WHERE FINANCIABLES.COMPANIA = :COMPANIA AND FINANCIABLES.CICLO = :CICLO AND FINANCIABLES.CODIGORUTA = :CODIGORUTA AND FINANCIABLES.PERIODO = :PERIODO AND FINANCIABLES.CONCEPTO &gt;= :CONCEPTOINICIAL ORDER BY FINANCIABLES.CONCEPTO) WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONCEPTO":"$CONCEPTO(type:integer)","NOMBRECONCEPTO":"$NOMBRECONCEPTO","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","MONTOFINANCIAR":"$MONTOFINANCIAR","NUMEROCUOTAS":"$NUMEROCUOTAS","SALDOFINANCIABLE":"$SALDOFINANCIABLE","INTERES":"$INTERES","VALORCUOTA":"$VALORCUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTOINICIAL" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spfinanciables/todosporcompaniaciclocodrutafinal/pag">
		<call-query href="getSpfinanciablesPagTodosPorCompaniaCicloCodRutaFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTOINICIAL" query-param="CONCEPTOINICIAL"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpfinanciablesNumTodosPorCompaniaCicloCodRutaFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT FINANCIABLES.CONCEPTO, CONCEPTOS.NOMBRE NOMBRECONCEPTO, FINANCIABLES.ANO, FINANCIABLES.PERIODO, FINANCIABLES.MONTOFINANCIAR, FINANCIABLES.NUMEROCUOTAS, FINANCIABLES.SALDOFINANCIABLE, FINANCIABLES.INTERES, FINANCIABLES.VALORCUOTA  FROM SP_FINANCIABLES FINANCIABLES INNER JOIN SP_CONCEPTOS CONCEPTOS ON FINANCIABLES.COMPANIA = CONCEPTOS.COMPANIA AND FINANCIABLES.CONCEPTO = CONCEPTOS.CODIGO WHERE FINANCIABLES.COMPANIA = :COMPANIA AND FINANCIABLES.CICLO = :CICLO AND FINANCIABLES.CODIGORUTA = :CODIGORUTA AND FINANCIABLES.PERIODO = :PERIODO AND FINANCIABLES.CONCEPTO &gt;= :CONCEPTOINICIAL ORDER BY FINANCIABLES.CONCEPTO) WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTOINICIAL" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spfinanciables/todosporcompaniaciclocodrutafinal/num">
		<call-query href="getSpfinanciablesNumTodosPorCompaniaCicloCodRutaFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTOINICIAL" query-param="CONCEPTOINICIAL"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRECONCEPTO" query-param="NOMBRECONCEPTO"/>

		</call-query>
	</resource>
	<query id="getSpfinanciablesPagTodosPorCompaniaCicloCodRutaInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT FINANCIABLES.CONCEPTO, CONCEPTOS.NOMBRE NOMBRECONCEPTO, FINANCIABLES.ANO, FINANCIABLES.PERIODO, FINANCIABLES.MONTOFINANCIAR, FINANCIABLES.NUMEROCUOTAS, FINANCIABLES.SALDOFINANCIABLE, FINANCIABLES.INTERES, FINANCIABLES.VALORCUOTA  FROM SP_FINANCIABLES FINANCIABLES INNER JOIN SP_CONCEPTOS CONCEPTOS ON FINANCIABLES.COMPANIA = CONCEPTOS.COMPANIA AND FINANCIABLES.CONCEPTO = CONCEPTOS.CODIGO WHERE FINANCIABLES.COMPANIA =:COMPANIA AND FINANCIABLES.CICLO =:CICLO AND FINANCIABLES.CODIGORUTA =:CODIGORUTA AND FINANCIABLES.PERIODO =:PERIODO ORDER BY FINANCIABLES.CONCEPTO) WHERE (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END)  LIKE UPPER(:CONCEPTO || '%')  AND (CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END)  LIKE UPPER( '%' || :NOMBRECONCEPTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONCEPTO":"$CONCEPTO(type:integer)","NOMBRECONCEPTO":"$NOMBRECONCEPTO","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","MONTOFINANCIAR":"$MONTOFINANCIAR","NUMEROCUOTAS":"$NUMEROCUOTAS","SALDOFINANCIABLE":"$SALDOFINANCIABLE","INTERES":"$INTERES","VALORCUOTA":"$VALORCUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
