	<query id="getSpfinanciablesPorConsultaDeFacturacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_FINANCIABLES.COMPANIA, SP_FINANCIABLES.CONCEPTO, SP_FINANCIABLES.MONTOFINANCIAR, SP_FINANCIABLES.SALDOFINANCIABLE, SP_FINANCIABLES.NUMEROCUOTAS, SP_FINANCIABLES.NROCUOTA, SP_FINANCIABLES.VALORCUOTA, SP_FINANCIABLES.PERIODO, SP_FINANCIABLES.CODIGORUTA, SP_FINANCIABLES.CICLO, SP_FINANCIABLES.ANO, SP_FINANCIABLES.BLOQUEADOHASTAANO, SP_FINANCIABLES.BLOQUEADOHASTAPERIODO,(CASE SP_FINANCIABLES.BLOQUEADO WHEN 0 THEN 'false' ELSE 'true' END) BLOQUEADO, SP_FINANCIABLES.CODIGOALMACEN, SP_CONCEPTOS.NOMBRE,(TO_CHAR(SP_FINANCIABLES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SP_FINANCIABLES.CREATED_BY ,(TO_CHAR(SP_FINANCIABLES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SP_FINANCIABLES.MODIFIED_BY  FROM SP_FINANCIABLES INNER JOIN SP_CONCEPTOS ON SP_FINANCIABLES.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_FINANCIABLES.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_FINANCIABLES.COMPANIA = :COMPANIA AND SP_FINANCIABLES.CICLO = :CICLO AND SP_FINANCIABLES.CODIGORUTA = :CODIGORUTA AND SP_FINANCIABLES.ANO = :ANO AND SP_FINANCIABLES.PERIODO = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONCEPTO":"$CONCEPTO(type:integer)","MONTOFINANCIAR":"$MONTOFINANCIAR","SALDOFINANCIABLE":"$SALDOFINANCIABLE","NUMEROCUOTAS":"$NUMEROCUOTAS","NROCUOTA":"$NROCUOTA(type:integer)","VALORCUOTA":"$VALORCUOTA","PERIODO":"$PERIODO","CODIGORUTA":"$CODIGORUTA","CICLO":"$CICLO(type:integer)","ANO":"$ANO(type:integer)","BLOQUEADOHASTAANO":"$BLOQUEADOHASTAANO(type:integer)","BLOQUEADOHASTAPERIODO":"$BLOQUEADOHASTAPERIODO","BLOQUEADO":"$BLOQUEADO(type:boolean)","CODIGOALMACEN":"$CODIGOALMACEN","NOMBRE":"$NOMBRE","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

