			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpfinanciablesNumCodigoYNombrePorCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT SP_USUARIO.CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) EXPR1, SP_USUARIO.ANO, SP_USUARIO.PERIODO, MIN(SP_USUARIO.TOTALDEUDA) KEEP(DENSE_RANK FIRST ORDER BY ROWNUM) PRIMERODETOTALDEUDA, SP_USUARIO.TOTFACTURAPERACTUAL, SP_USUARIO.BANCOPERPROCESO, MIN(SP_FINANCIABLESDEDEUDA.CONSECUTIVO) KEEP(DENSE_RANK FIRST ORDER BY ROWNUM) PRIMERODECONSECUTIVO,(TO_CHAR(SP_FINANCIABLESDEDEUDA.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, SP_FINANCIABLESDEDEUDA.NOCUOTAS, SP_FINANCIABLESDEDEUDA.VALORCUOTA FROM SP_FINANCIABLESDEDEUDA INNER JOIN SP_USUARIO ON SP_FINANCIABLESDEDEUDA.COMPANIA = SP_USUARIO.COMPANIA AND SP_FINANCIABLESDEDEUDA.CICLO = SP_USUARIO.CICLO AND SP_FINANCIABLESDEDEUDA.USUARIO = SP_USUARIO.CODIGORUTA WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO GROUP BY SP_USUARIO.CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ), SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.TOTFACTURAPERACTUAL, SP_USUARIO.BANCOPERPROCESO, SP_FINANCIABLESDEDEUDA.FECHA, SP_FINANCIABLESDEDEUDA.NOCUOTAS, SP_FINANCIABLESDEDEUDA.VALORCUOTA ORDER BY SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN EXPR1 IS NULL THEN ' ' ELSE UPPER(EXPR1) END) LIKE UPPER(CONCAT(CONCAT('%',:EXPR1), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODO), '%')) AND (CASE WHEN PRIMERODETOTALDEUDA IS NULL THEN ' ' ELSE UPPER(PRIMERODETOTALDEUDA) END) LIKE UPPER(CONCAT(CONCAT('%',:PRIMERODETOTALDEUDA), '%')) AND (CASE WHEN TOTFACTURAPERACTUAL IS NULL THEN ' ' ELSE UPPER(TOTFACTURAPERACTUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTFACTURAPERACTUAL), '%')) AND (CASE WHEN BANCOPERPROCESO IS NULL THEN ' ' ELSE UPPER(BANCOPERPROCESO) END) LIKE UPPER(CONCAT(CONCAT('%',:BANCOPERPROCESO), '%')) AND (CASE WHEN PRIMERODECONSECUTIVO IS NULL THEN ' ' ELSE UPPER(PRIMERODECONSECUTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:PRIMERODECONSECUTIVO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA), '%')) AND (CASE WHEN NOCUOTAS IS NULL THEN ' ' ELSE UPPER(NOCUOTAS) END) LIKE UPPER(CONCAT(CONCAT('%',:NOCUOTAS), '%')) AND (CASE WHEN VALORCUOTA IS NULL THEN ' ' ELSE UPPER(VALORCUOTA) END) LIKE UPPER(CONCAT(CONCAT('%',:VALORCUOTA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="EXPR1" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="PRIMERODETOTALDEUDA" sqlType="STRING"/>
		<param name="TOTFACTURAPERACTUAL" sqlType="STRING"/>
		<param name="BANCOPERPROCESO" sqlType="STRING"/>
		<param name="PRIMERODECONSECUTIVO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NOCUOTAS" sqlType="STRING"/>
		<param name="VALORCUOTA" sqlType="STRING"/>

	</query>
