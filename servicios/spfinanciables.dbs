	<query id="getSpfinanciablesTotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT NVL(SUM(NVL(MONTOFINANCIAR,0) ),0) TOTALMONTO, NVL(SUM(NVL(SALDOFINANCIABLE,0) ),0) TOTALSALDO, NVL(SUM(NVL(VALORCUOTA,0) ),0) TOTALCUOTA FROM ( SELECT ANO, PERIODO, CONCEPTO, DATE_CREATED, MONTOFINANCIAR, SALDOFINANCIABLE, NUMEROCUOTAS, VALORCUOTA, ( SELECT NOMBRE FROM SP_CONCEPTOS WHERE COMPANIA = SP_FINANCIABLES.COMPANIA AND CODIGO = SP_FINANCIABLES.CONCEPTO ) NOMBRECONCEPTO, BLOQUEADOHASTAANO, PCK_SERVICIOS_PUBLICOS_COM2.FC_NOMBREPERIODOM(COMPANIA,BLOQUEADOHASTAPERIODO) PERUNICO, BLOQUEADOHASTAPERIODO, BLOQUEADO, ANOINICIAL FROM SP_FINANCIABLES WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO AND CODIGORUTA =:CODIGORUTA AND ANO &gt;=:ANO AND PERIODO &gt;=:PERIODO ) DF WHERE ( CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END ) LIKE UPPER(CONCAT('%',CONCAT(:ANONOM, '%'))) AND ( CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END ) LIKE UPPER(CONCAT('%',CONCAT(:PERIODONOM, '%'))) AND ( CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END ) LIKE UPPER(CONCAT('%',CONCAT(:CONCEPTO, '%'))) AND ( CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END ) LIKE UPPER(CONCAT('%',CONCAT( :DATE_CREATED, '%'))) AND ( CASE WHEN MONTOFINANCIAR IS NULL THEN ' ' ELSE UPPER(MONTOFINANCIAR) END ) LIKE UPPER(CONCAT(:MONTOFINANCIAR , '%')) AND ( CASE WHEN SALDOFINANCIABLE IS NULL THEN ' ' ELSE UPPER(SALDOFINANCIABLE) END ) LIKE UPPER(CONCAT( :SALDOFINANCIABLE , '%')) AND ( CASE WHEN NUMEROCUOTAS IS NULL THEN ' ' ELSE UPPER(NUMEROCUOTAS) END ) LIKE UPPER(CONCAT(:NUMEROCUOTAS , '%')) AND ( CASE WHEN VALORCUOTA IS NULL THEN ' ' ELSE UPPER(VALORCUOTA) END ) LIKE UPPER(CONCAT(:VALORCUOTA , '%')) AND ( CASE WHEN NOMBRECONCEPTO IS NULL THEN ' ' ELSE UPPER(NOMBRECONCEPTO) END ) LIKE UPPER(CONCAT('%',CONCAT(:NOMBRECONCEPTO, '%'))) AND ( CASE WHEN BLOQUEADOHASTAANO IS NULL THEN ' ' ELSE UPPER(BLOQUEADOHASTAANO) END ) LIKE UPPER(CONCAT('%',CONCAT(:BLOQUEADOHASTAANO, '%'))) AND ( CASE WHEN PERUNICO IS NULL THEN ' ' ELSE UPPER(PERUNICO) END ) LIKE UPPER(CONCAT( '%',CONCAT( :PERUNICO , '%'))) AND ( CASE WHEN BLOQUEADOHASTAPERIODO IS NULL THEN ' ' ELSE UPPER(BLOQUEADOHASTAPERIODO) END ) LIKE UPPER(CONCAT(:BLOQUEADOHASTAPERIODO , '%'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTALMONTO":"$TOTALMONTO","TOTALSALDO":"$TOTALSALDO","TOTALCUOTA":"$TOTALCUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANONOM" sqlType="STRING"/>
		<param name="PERIODONOM" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MONTOFINANCIAR" sqlType="STRING"/>
		<param name="SALDOFINANCIABLE" sqlType="STRING"/>
		<param name="NUMEROCUOTAS" sqlType="STRING"/>
		<param name="VALORCUOTA" sqlType="STRING"/>
		<param name="NOMBRECONCEPTO" sqlType="STRING"/>
		<param name="BLOQUEADOHASTAANO" sqlType="STRING"/>
		<param name="PERUNICO" sqlType="STRING"/>
		<param name="BLOQUEADOHASTAPERIODO" sqlType="STRING"/>

	</query>
