	<query id="getSpfinanciablesTodosLosQueEstanPendientesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_FINANCIABLES.CONCEPTO, SP_FINANCIABLES.MONTOFINANCIAR, SP_FINANCIABLES.SALDOFINANCIABLE, SP_FINANCIABLES.NUMEROCUOTAS, SP_FINANCIABLES.VALORCUOTA, SP_FINANCIABLES.ANO, SP_FINANCIABLES.PERIODO, SP_FINANCIABLES.COMPANIA, SP_FINANCIABLES.CODIGORUTA, SP_FINANCIABLES.CICLO, SP_CONCEPTOS.NOMBRE NOMBREO  FROM SP_FINANCIABLES INNER JOIN SP_CONCEPTOS ON SP_FINANCIABLES.COMPANIA = SP_CONCEPTOS.COMPANIA AND SP_FINANCIABLES.CONCEPTO = SP_CONCEPTOS.CODIGO WHERE SP_FINANCIABLES.COMPANIA = :COMPANIA AND SP_FINANCIABLES.CICLO = :CICLO AND SP_FINANCIABLES.CODIGORUTA= :CODIGORUTA AND (SP_FINANCIABLES.ANO &lt;&gt; :ANO OR SP_FINANCIABLES.PERIODO &gt; :PERIODO ) ORDER BY SP_FINANCIABLES.COMPANIA, SP_FINANCIABLES.CICLO, SP_FINANCIABLES.CODIGORUTA, SP_FINANCIABLES.ANO, SP_FINANCIABLES.PERIODO, SP_FINANCIABLES.CONCEPTO</sql>
