<data name="tramitedeuda" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="deleteTramitedeudaTotal" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TRAMITE_DEUDA WHERE TRAMITE_DEUDA.COMPANIA= :KEY_COMPANIA AND TRAMITE_DEUDA.PROCESO= :KEY_PROCESO AND TRAMITE_DEUDA.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND TRAMITE_DEUDA.TRAMITE= :KEY_TRAMITE</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCESO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_TRAMITE" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tramitedeuda/total">
		<call-query href="deleteTramitedeudaTotal">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCESO" query-param="KEY_PROCESO"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_TRAMITE" query-param="KEY_TRAMITE"/>

		</call-query>
	</resource>
	<query id="insertTramitedeuda" keyColumns="COMPANIA,PROCESO,TIPO_TRAMITE,TRAMITE,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TRAMITE_DEUDA (COMPANIA, PROCESO, TIPO_TRAMITE, TRAMITE, CONSECUTIVO, ANO, PERIODO, REFERENCIA1, REFERENCIA2, CONCEPTO, NOMBRE, VALOR, AVALUO, PORCENTAJE_TARIFA, TOTAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :PROCESO, :TIPO_TRAMITE, :TRAMITE, :CONSECUTIVO, :ANO, :PERIODO, :REFERENCIA1, :REFERENCIA2, :CONCEPTO, :NOMBRE, :VALOR, :AVALUO, :PORCENTAJE_TARIFA, :TOTAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROCESO":"$PROCESO","KEY_TIPO_TRAMITE":"$TIPO_TRAMITE","KEY_TRAMITE":"$TRAMITE(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param defaultValue="- 1" name="REFERENCIA1" sqlType="STRING"/>
		<param defaultValue="- 1" name="REFERENCIA2" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="AVALUO" sqlType="STRING"/>
		<param defaultValue="" name="PORCENTAJE_TARIFA" sqlType="STRING"/>
		<param defaultValue="" name="TOTAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tramitedeuda">
		<call-query href="insertTramitedeuda">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="REFERENCIA1" query-param="REFERENCIA1"/>
			<with-param name="REFERENCIA2" query-param="REFERENCIA2"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="PORCENTAJE_TARIFA" query-param="PORCENTAJE_TARIFA"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTramitedeuda" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TRAMITE_DEUDA WHERE TRAMITE_DEUDA.COMPANIA= :KEY_COMPANIA AND TRAMITE_DEUDA.PROCESO= :KEY_PROCESO AND TRAMITE_DEUDA.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND TRAMITE_DEUDA.TRAMITE= :KEY_TRAMITE AND TRAMITE_DEUDA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCESO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_TRAMITE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="tramitedeuda">
		<call-query href="deleteTramitedeuda">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCESO" query-param="KEY_PROCESO"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_TRAMITE" query-param="KEY_TRAMITE"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getTramitedeudaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, PROCESO, TIPO_TRAMITE, TRAMITE, CONSECUTIVO, ANO, PERIODO, CONCEPTO, NOMBRE, VALOR, REFERENCIA1, REFERENCIA2 FROM TRAMITE_DEUDA WHERE COMPANIA = :COMPANIA AND PROCESO = :PROCESO AND TIPO_TRAMITE = :TIPO_TRAMITE AND TRAMITE = :TRAMITE) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN REFERENCIA1 IS NULL THEN ' ' ELSE UPPER(REFERENCIA1) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA1), '%')) AND (CASE WHEN REFERENCIA2 IS NULL THEN ' ' ELSE UPPER(REFERENCIA2) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA2), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROCESO":"$PROCESO","TIPO_TRAMITE":"$TIPO_TRAMITE","TRAMITE":"$TRAMITE(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO(type:integer)","CONCEPTO":"$CONCEPTO(type:integer)","NOMBRE":"$NOMBRE","VALOR":"$VALOR","REFERENCIA1":"$REFERENCIA1","REFERENCIA2":"$REFERENCIA2"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="REFERENCIA1" sqlType="STRING"/>
		<param name="REFERENCIA2" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tramitedeuda">
		<call-query href="getTramitedeudaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="REFERENCIA1" query-param="REFERENCIA1"/>
			<with-param name="REFERENCIA2" query-param="REFERENCIA2"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTramitedeudaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, PROCESO, TIPO_TRAMITE, TRAMITE, CONSECUTIVO, ANO, PERIODO, CONCEPTO, NOMBRE, VALOR, REFERENCIA1, REFERENCIA2 FROM TRAMITE_DEUDA WHERE COMPANIA = :COMPANIA AND PROCESO = :PROCESO AND TIPO_TRAMITE = :TIPO_TRAMITE AND TRAMITE = :TRAMITE) INI WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN CONCEPTO IS NULL THEN ' ' ELSE UPPER(CONCEPTO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR), '%')) AND (CASE WHEN REFERENCIA1 IS NULL THEN ' ' ELSE UPPER(REFERENCIA1) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA1), '%')) AND (CASE WHEN REFERENCIA2 IS NULL THEN ' ' ELSE UPPER(REFERENCIA2) END) LIKE UPPER(CONCAT(CONCAT('%',:REFERENCIA2), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROCESO" sqlType="STRING"/>
		<param name="TIPO_TRAMITE" sqlType="STRING"/>
		<param name="TRAMITE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="REFERENCIA1" sqlType="STRING"/>
		<param name="REFERENCIA2" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tramitedeuda/numero">
		<call-query href="getTramitedeudaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROCESO" query-param="PROCESO"/>
			<with-param name="TIPO_TRAMITE" query-param="TIPO_TRAMITE"/>
			<with-param name="TRAMITE" query-param="TRAMITE"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="REFERENCIA1" query-param="REFERENCIA1"/>
			<with-param name="REFERENCIA2" query-param="REFERENCIA2"/>

		</call-query>
	</resource>
	<query id="updateTramitedeuda" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TRAMITE_DEUDA SET CONSECUTIVO=:CONSECUTIVO, ANO=:ANO, PERIODO=:PERIODO, REFERENCIA1=:REFERENCIA1, REFERENCIA2=:REFERENCIA2, CONCEPTO=:CONCEPTO, NOMBRE=:NOMBRE, VALOR=:VALOR, AVALUO=:AVALUO, PORCENTAJE_TARIFA=:PORCENTAJE_TARIFA, TOTAL=:TOTAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE TRAMITE_DEUDA.COMPANIA= :KEY_COMPANIA AND TRAMITE_DEUDA.PROCESO= :KEY_PROCESO AND TRAMITE_DEUDA.TIPO_TRAMITE= :KEY_TIPO_TRAMITE AND TRAMITE_DEUDA.TRAMITE= :KEY_TRAMITE AND TRAMITE_DEUDA.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="REFERENCIA1" sqlType="STRING"/>
		<param name="REFERENCIA2" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="AVALUO" sqlType="STRING"/>
		<param name="PORCENTAJE_TARIFA" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROCESO" sqlType="STRING"/>
		<param name="KEY_TIPO_TRAMITE" sqlType="STRING"/>
		<param name="KEY_TRAMITE" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tramitedeuda">
		<call-query href="updateTramitedeuda">
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="REFERENCIA1" query-param="REFERENCIA1"/>
			<with-param name="REFERENCIA2" query-param="REFERENCIA2"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="AVALUO" query-param="AVALUO"/>
			<with-param name="PORCENTAJE_TARIFA" query-param="PORCENTAJE_TARIFA"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROCESO" query-param="KEY_PROCESO"/>
			<with-param name="KEY_TIPO_TRAMITE" query-param="KEY_TIPO_TRAMITE"/>
			<with-param name="KEY_TRAMITE" query-param="KEY_TRAMITE"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>