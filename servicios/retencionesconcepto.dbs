<data name="retencionesconcepto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertRetencionesconcepto" keyColumns="COMPANIA,TIPO,ANO,CODIGO,TIPOCOBRO,CONCEPTO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO RETENCIONESCONCEPTO (COMPANIA, TIPO, ANO, CODIGO, TIPOCOBRO, CONCEPTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :ANO, :CODIGO, :TIPOCOBRO, :CONCEPTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO","KEY_TIPOCOBRO":"$TIPOCOBRO","KEY_CONCEPTO":"$CONCEPTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="retencionesconcepto">
		<call-query href="insertRetencionesconcepto">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteRetencionesconcepto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM RETENCIONESCONCEPTO WHERE RETENCIONESCONCEPTO.COMPANIA= :KEY_COMPANIA AND RETENCIONESCONCEPTO.TIPO= :KEY_TIPO AND RETENCIONESCONCEPTO.ANO= :KEY_ANO AND RETENCIONESCONCEPTO.CODIGO= :KEY_CODIGO AND RETENCIONESCONCEPTO.TIPOCOBRO= :KEY_TIPOCOBRO AND RETENCIONESCONCEPTO.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="retencionesconcepto">
		<call-query href="deleteRetencionesconcepto">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>
	<query id="getRetencionesconceptoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT RETENCIONESCONCEPTO.COMPANIA, RETENCIONESCONCEPTO.TIPO, RETENCIONESCONCEPTO.ANO, RETENCIONESCONCEPTO.CODIGO, RETENCIONESCONCEPTO.TIPOCOBRO, RETENCIONESCONCEPTO.CONCEPTO, TIPORETENCION.NOMBRE, RETENCIONES.NOMBRE AS NOMBRERETENCION  FROM RETENCIONESCONCEPTO INNER JOIN TIPORETENCION ON TIPORETENCION.CODIGO = RETENCIONESCONCEPTO.TIPO INNER JOIN RETENCIONES ON TIPORETENCION.CODIGO = RETENCIONES.TIPO AND RETENCIONESCONCEPTO.ANO = RETENCIONES.ANO AND RETENCIONESCONCEPTO.CODIGO = RETENCIONES.CODIGO WHERE RETENCIONESCONCEPTO.COMPANIA = :COMPANIA AND RETENCIONESCONCEPTO.ANO = :ANO AND RETENCIONESCONCEPTO.TIPOCOBRO = :TIPOCOBRO AND RETENCIONESCONCEPTO.CONCEPTO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","TIPOCOBRO":"$TIPOCOBRO","CONCEPTO":"$CONCEPTO","NOMBRE":"$NOMBRE","NOMBRERETENCION":"$NOMBRERETENCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="retencionesconcepto">
		<call-query href="getRetencionesconceptoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="updateRetencionesconcepto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE RETENCIONESCONCEPTO SET TIPO=:TIPO, ANO=:ANO, CODIGO=:CODIGO, TIPOCOBRO=:TIPOCOBRO, CONCEPTO=:CONCEPTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE RETENCIONESCONCEPTO.COMPANIA= :KEY_COMPANIA AND RETENCIONESCONCEPTO.TIPO= :KEY_TIPO AND RETENCIONESCONCEPTO.ANO= :KEY_ANO AND RETENCIONESCONCEPTO.CODIGO= :KEY_CODIGO AND RETENCIONESCONCEPTO.TIPOCOBRO= :KEY_TIPOCOBRO AND RETENCIONESCONCEPTO.CONCEPTO= :KEY_CONCEPTO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPOCOBRO" sqlType="STRING"/>
		<param name="CONCEPTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_TIPOCOBRO" sqlType="STRING"/>
		<param name="KEY_CONCEPTO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="retencionesconcepto">
		<call-query href="updateRetencionesconcepto">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPOCOBRO" query-param="TIPOCOBRO"/>
			<with-param name="CONCEPTO" query-param="CONCEPTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_TIPOCOBRO" query-param="KEY_TIPOCOBRO"/>
			<with-param name="KEY_CONCEPTO" query-param="KEY_CONCEPTO"/>

		</call-query>
	</resource>

</data>