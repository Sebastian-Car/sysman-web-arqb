<data name="procesosjudiciales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getProcesosjudicialesPagGettodosprocesosjudicialesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PROCESOS_JUDICIALES.NUMEROPROCESO NUMERO, PROCESOS_JUDICIALES.CODIGO, PROCESOS_JUDICIALES.TERCERO NOMBRE FROM PROCESOS_JUDICIALES WHERE PROCESOS_JUDICIALES.COMPANIA = :COMPANIA ORDER BY PROCESOS_JUDICIALES.NUMEROPROCESO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procesosjudiciales/gettodosprocesosjudiciales/pag">
		<call-query href="getProcesosjudicialesPagGettodosprocesosjudicialesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcesosjudicialesNumGettodosprocesosjudicialesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PROCESOS_JUDICIALES.NUMEROPROCESO NUMERO, PROCESOS_JUDICIALES.CODIGO, PROCESOS_JUDICIALES.TERCERO NOMBRE FROM PROCESOS_JUDICIALES WHERE PROCESOS_JUDICIALES.COMPANIA = :COMPANIA ORDER BY PROCESOS_JUDICIALES.NUMEROPROCESO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procesosjudiciales/gettodosprocesosjudiciales/num">
		<call-query href="getProcesosjudicialesNumGettodosprocesosjudicialesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getProcesosjudicialesPagGetprocesosjudicialesxcodigoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PROCESOS_JUDICIALES.NUMEROPROCESO NUMERO, PROCESOS_JUDICIALES.CODIGO, PROCESOS_JUDICIALES.TERCERO NOMBRE FROM PROCESOS_JUDICIALES WHERE PROCESOS_JUDICIALES.COMPANIA = :COMPANIA AND PROCESOS_JUDICIALES.NUMEROPROCESO &gt;= :NUMEROPROCESO ORDER BY PROCESOS_JUDICIALES.NUMEROPROCESO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROPROCESO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procesosjudiciales/getprocesosjudicialesxcodigoinicial/pag">
		<call-query href="getProcesosjudicialesPagGetprocesosjudicialesxcodigoinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROPROCESO" query-param="NUMEROPROCESO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcesosjudicialesNumGetprocesosjudicialesxcodigoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PROCESOS_JUDICIALES.NUMEROPROCESO NUMERO, PROCESOS_JUDICIALES.CODIGO, PROCESOS_JUDICIALES.TERCERO NOMBRE FROM PROCESOS_JUDICIALES WHERE PROCESOS_JUDICIALES.COMPANIA = :COMPANIA AND PROCESOS_JUDICIALES.NUMEROPROCESO &gt;= :NUMEROPROCESO ORDER BY PROCESOS_JUDICIALES.NUMEROPROCESO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROPROCESO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procesosjudiciales/getprocesosjudicialesxcodigoinicial/num">
		<call-query href="getProcesosjudicialesNumGetprocesosjudicialesxcodigoinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROPROCESO" query-param="NUMEROPROCESO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getProcesosjudicialesPagConsultarlistacrQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PROCESOS_JUDICIALES.COMPANIA, PROCESOS_JUDICIALES.CODIGO, TERCERO.NOMBRE AS NOMBRETERCERO, PROCESOS_JUDICIALES.TERCERO NIT, PROCESOS_JUDICIALES.NUMEROPROCESO, PROCESOS_JUDICIALES.VALOR_ACTUAL FROM PROCESOS_JUDICIALES INNER JOIN TERCERO ON PROCESOS_JUDICIALES.COMPANIA = TERCERO.COMPANIA AND PROCESOS_JUDICIALES.TERCERO = TERCERO.NIT AND PROCESOS_JUDICIALES.SUCURSAL = TERCERO.SUCURSAL WHERE PROCESOS_JUDICIALES.COMPANIA = :COMPANIA AND PROCESOS_JUDICIALES.TERCERO = :TERCEROCOMPROBANTE AND PROCESOS_JUDICIALES.SUCURSAL = :SUCURSALCOMPROBANTE AND PROCESOS_JUDICIALES.TIPO_INGRESO = 'CPJ' AND PROCESOS_JUDICIALES.FECHA_INGRESO &lt;= TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY') AND VALOR_ACTUAL &gt; 0 ORDER BY PROCESOS_JUDICIALES.COMPANIA, PROCESOS_JUDICIALES.COMPROBANTE_INGRESO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(:NOMBRETERCERO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(CONCAT('%',:NIT), '%')) AND (CASE WHEN NUMEROPROCESO IS NULL THEN ' ' ELSE UPPER(NUMEROPROCESO) END) LIKE UPPER(CONCAT(:NUMEROPROCESO, '%')) AND (CASE WHEN VALOR_ACTUAL IS NULL THEN ' ' ELSE UPPER(VALOR_ACTUAL) END) LIKE UPPER(CONCAT(:VALOR_ACTUAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRETERCERO":"$NOMBRETERCERO","NIT":"$NIT","NUMEROPROCESO":"$NUMEROPROCESO","VALOR_ACTUAL":"$VALOR_ACTUAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="FECHACOMPROBANTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NUMEROPROCESO" sqlType="STRING"/>
		<param name="VALOR_ACTUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="procesosjudiciales/consultarlistacr/pag">
		<call-query href="getProcesosjudicialesPagConsultarlistacrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCEROCOMPROBANTE" query-param="TERCEROCOMPROBANTE"/>
			<with-param name="SUCURSALCOMPROBANTE" query-param="SUCURSALCOMPROBANTE"/>
			<with-param name="FECHACOMPROBANTE" query-param="FECHACOMPROBANTE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NUMEROPROCESO" query-param="NUMEROPROCESO"/>
			<with-param name="VALOR_ACTUAL" query-param="VALOR_ACTUAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getProcesosjudicialesNumConsultarlistacrQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PROCESOS_JUDICIALES.COMPANIA, PROCESOS_JUDICIALES.CODIGO, TERCERO.NOMBRE AS NOMBRETERCERO, PROCESOS_JUDICIALES.TERCERO NIT, PROCESOS_JUDICIALES.NUMEROPROCESO, PROCESOS_JUDICIALES.VALOR_ACTUAL FROM PROCESOS_JUDICIALES INNER JOIN TERCERO ON PROCESOS_JUDICIALES.COMPANIA = TERCERO.COMPANIA AND PROCESOS_JUDICIALES.TERCERO = TERCERO.NIT AND PROCESOS_JUDICIALES.SUCURSAL = TERCERO.SUCURSAL WHERE PROCESOS_JUDICIALES.COMPANIA = :COMPANIA AND PROCESOS_JUDICIALES.TERCERO = :TERCEROCOMPROBANTE AND PROCESOS_JUDICIALES.SUCURSAL = :SUCURSALCOMPROBANTE AND PROCESOS_JUDICIALES.TIPO_INGRESO = 'CPJ' AND PROCESOS_JUDICIALES.FECHA_INGRESO &lt;= TO_DATE(:FECHACOMPROBANTE,'DD/MM/YYYY') AND VALOR_ACTUAL &gt; 0 ORDER BY PROCESOS_JUDICIALES.COMPANIA, PROCESOS_JUDICIALES.COMPROBANTE_INGRESO) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(:NOMBRETERCERO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(CONCAT('%',:NIT), '%')) AND (CASE WHEN NUMEROPROCESO IS NULL THEN ' ' ELSE UPPER(NUMEROPROCESO) END) LIKE UPPER(CONCAT(:NUMEROPROCESO, '%')) AND (CASE WHEN VALOR_ACTUAL IS NULL THEN ' ' ELSE UPPER(VALOR_ACTUAL) END) LIKE UPPER(CONCAT(:VALOR_ACTUAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCEROCOMPROBANTE" sqlType="STRING"/>
		<param name="SUCURSALCOMPROBANTE" sqlType="STRING"/>
		<param name="FECHACOMPROBANTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NUMEROPROCESO" sqlType="STRING"/>
		<param name="VALOR_ACTUAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procesosjudiciales/consultarlistacr/num">
		<call-query href="getProcesosjudicialesNumConsultarlistacrQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCEROCOMPROBANTE" query-param="TERCEROCOMPROBANTE"/>
			<with-param name="SUCURSALCOMPROBANTE" query-param="SUCURSALCOMPROBANTE"/>
			<with-param name="FECHACOMPROBANTE" query-param="FECHACOMPROBANTE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NUMEROPROCESO" query-param="NUMEROPROCESO"/>
			<with-param name="VALOR_ACTUAL" query-param="VALOR_ACTUAL"/>

		</call-query>
	</resource>
	<query id="getProcesosjudicialesProcesoporterceroQuery"  useConfig="sysmandsunist">
		<sql>SELECT NUMEROPROCESO FROM PROCESOS_JUDICIALES WHERE COMPANIA = :COMPANIA AND TERCERO = :TERCERO AND SUCURSAL = :SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMEROPROCESO":"$NUMEROPROCESO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="procesosjudiciales/procesoportercero">
		<call-query href="getProcesosjudicialesProcesoporterceroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>

		</call-query>
	</resource>

</data>