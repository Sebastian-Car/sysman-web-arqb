		</call-query>
	</resource>
	<query id="getSptblhistsaldocreditoNumInnerbancosporcodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  S.ANO, S.PERIODO,(TO_CHAR(S.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, S.VALOR_SALDO, S.VALORINICIAL, S.USUARIOREG, S.VALORDES, B.NOMBRE  FROM SP_TBLHIST_SALDO_CREDITO S INNER JOIN SP_BANCOS B ON S.COMPANIA = B.COMPANIA AND S.BANCO = B.CODIGO WHERE S.COMPANIA = :COMPANIA AND S.CODIGORUTA = :CODIGORUTA ORDER BY S.ANO, S.PERIODO, S.FECHA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN VALOR_SALDO IS NULL THEN ' ' ELSE UPPER(VALOR_SALDO) END)  LIKE UPPER( '%' || :VALOR_SALDO || '%')  AND (CASE WHEN VALORINICIAL IS NULL THEN ' ' ELSE UPPER(VALORINICIAL) END)  LIKE UPPER( '%' || :VALORINICIAL || '%')  AND (CASE WHEN USUARIOREG IS NULL THEN ' ' ELSE UPPER(USUARIOREG) END)  LIKE UPPER( '%' || :USUARIOREG || '%')  AND (CASE WHEN VALORDES IS NULL THEN ' ' ELSE UPPER(VALORDES) END)  LIKE UPPER( '%' || :VALORDES || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_SALDO" sqlType="STRING"/>
		<param name="VALORINICIAL" sqlType="STRING"/>
		<param name="USUARIOREG" sqlType="STRING"/>
		<param name="VALORDES" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
