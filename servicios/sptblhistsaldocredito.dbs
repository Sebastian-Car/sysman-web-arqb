<data name="sptblhistsaldocredito" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSptblhistsaldocreditoListaSaldosCreditoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, PERIODOCREADO MES, VALOR_SALDO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CONSECUTIVO, USUARIOREG, VALORDES, VALORINICIAL, BANCO, CODINTERNO,(TO_CHAR(HORAREG,'DD/MM/YYYY HH24:MI:SS')) HORAREG,(TO_CHAR(FECHAREG,'DD/MM/YYYY HH24:MI:SS')) FECHAREG, PERIODOCREADO, ANOCREADO, ANOCREADO ANIOCREADO, CODSALDOCREDITO, OBSERVACION,(CASE ESNORMAL WHEN 0 THEN 'false' ELSE 'true' END) ESNORMAL FROM SP_TBLHIST_SALDO_CREDITO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND ANOCREADO = :ANO AND PERIODOCREADO = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","MES":"$MES","VALOR_SALDO":"$VALOR_SALDO","FECHA":"$FECHA","CONSECUTIVO":"$CONSECUTIVO","USUARIOREG":"$USUARIOREG","VALORDES":"$VALORDES","VALORINICIAL":"$VALORINICIAL","BANCO":"$BANCO","CODINTERNO":"$CODINTERNO","HORAREG":"$HORAREG","FECHAREG":"$FECHAREG","PERIODOCREADO":"$PERIODOCREADO","ANOCREADO":"$ANOCREADO(type:integer)","ANIOCREADO":"$ANIOCREADO(type:integer)","CODSALDOCREDITO":"$CODSALDOCREDITO","OBSERVACION":"$OBSERVACION","ESNORMAL":"$ESNORMAL(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptblhistsaldocredito/listasaldoscredito">
		<call-query href="getSptblhistsaldocreditoListaSaldosCreditoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSptblhistsaldocreditoSumaValorSaldoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(SUM(VALOR_SALDO), 0) VALOR  FROM SP_TBLHIST_SALDO_CREDITO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND ANOCREADO = :ANO AND PERIODOCREADO = :PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALOR":"$VALOR(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptblhistsaldocredito/sumavalorsaldo">
		<call-query href="getSptblhistsaldocreditoSumaValorSaldoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="insertSptblhistsaldocreditoFacturaSaldoCredito" keyColumns="COMPANIA,CICLO,CODIGORUTA,ANO,PERIODO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_TBLHIST_SALDO_CREDITO (COMPANIA, CICLO, CODIGORUTA, ANOCREADO, PERIODOCREADO, ANO, FECHA, BANCO, PERIODO, CONSECUTIVO, USUARIOREG, VALOR_SALDO, OBSERVACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CICLO, :CODIGORUTA, :ANOCREADO, :PERIODOCREADO, :ANO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :BANCO, :PERIODO, :CONSECUTIVO, :USUARIOREG, :VALOR_SALDO, :OBSERVACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_ANO":"$ANO(type:integer)","KEY_PERIODO":"$PERIODO","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANOCREADO" sqlType="STRING"/>
		<param name="PERIODOCREADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="USUARIOREG" sqlType="STRING"/>
		<param defaultValue="0" name="VALOR_SALDO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="sptblhistsaldocredito/facturasaldocredito">
		<call-query href="insertSptblhistsaldocreditoFacturaSaldoCredito">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANOCREADO" query-param="ANOCREADO"/>
			<with-param name="PERIODOCREADO" query-param="PERIODOCREADO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USUARIOREG" query-param="USUARIOREG"/>
			<with-param name="VALOR_SALDO" query-param="VALOR_SALDO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSptblhistsaldocreditoFacturaSaldoCredito" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_TBLHIST_SALDO_CREDITO WHERE COMPANIA = :KEY_COMPANIA AND CICLO      = :KEY_CICLO AND CODIGORUTA = :KEY_CODIGORUTA AND CONSECUTIVO= :KEY_CONSECUTIVO AND PERIODO    = :KEY_PERIODO AND ANO        = :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="sptblhistsaldocredito/facturasaldocredito">
		<call-query href="deleteSptblhistsaldocreditoFacturaSaldoCredito">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="updateSptblhistsaldocreditoFacturaSaldoCredito" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_TBLHIST_SALDO_CREDITO SET FECHA      = :FECHA,   OBSERVACION  = :OBSERVACIONES,   ANIOCREADO   =:ANIOCREADO,   BANCO        =:BANCO,   VALOR_SALDO  =:VALOR_SALDO,   ANO          = :ANO,   USUARIOREG   =:USUARIO,   PERIODOCREADO=:PERIODO WHERE COMPANIA = :KEY_COMPANIA AND CICLO      = :KEY_CICLO AND CODIGORUTA = :KEY_CODIGORUTA AND CONSECUTIVO= :KEY_CONSECUTIVO AND PERIODO    = :KEY_PERIODO AND ANO        = :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="ANIOCREADO" sqlType="STRING"/>
		<param name="BANCO" sqlType="STRING"/>
		<param name="VALOR_SALDO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="USUARIO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sptblhistsaldocredito/facturasaldocredito">
		<call-query href="updateSptblhistsaldocreditoFacturaSaldoCredito">
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="ANIOCREADO" query-param="ANIOCREADO"/>
			<with-param name="BANCO" query-param="BANCO"/>
			<with-param name="VALOR_SALDO" query-param="VALOR_SALDO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="USUARIO" query-param="USUARIO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getSptblhistsaldocreditoValidarAuditoriaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO, CODINTERNO, VALOR_SALDO, VALORDES, BANCO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA,(TO_CHAR(FECHAREG,'DD/MM/YYYY HH24:MI:SS')) FECHAREG FROM SP_TBLHIST_SALDO_CREDITO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA AND ANO = :ANO AND PERIODO = :PERIODO AND CONSECUTIVO = :CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","CODINTERNO":"$CODINTERNO","VALOR_SALDO":"$VALOR_SALDO","VALORDES":"$VALORDES","BANCO":"$BANCO","FECHA":"$FECHA","FECHAREG":"$FECHAREG"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptblhistsaldocredito/validarauditoria">
		<call-query href="getSptblhistsaldocreditoValidarAuditoriaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSptblhistsaldocreditoPagHistoricoDeSaldosPorCodigoRutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_TBLHIST_SALDO_CREDITO.ANO, SP_TBLHIST_SALDO_CREDITO.PERIODO, TO_CHAR(SP_TBLHIST_SALDO_CREDITO.FECHA, 'DD/MM/YYYY') FECHA, SP_TBLHIST_SALDO_CREDITO.VALOR_SALDO, SP_TBLHIST_SALDO_CREDITO.VALORINICIAL, SP_TBLHIST_SALDO_CREDITO.USUARIOREG, SP_TBLHIST_SALDO_CREDITO.VALORDES, SP_BANCOS.NOMBRE  FROM SP_BANCOS INNER JOIN SP_TBLHIST_SALDO_CREDITO ON SP_BANCOS.COMPANIA = SP_TBLHIST_SALDO_CREDITO.COMPANIA AND SP_BANCOS.CODIGO = SP_TBLHIST_SALDO_CREDITO.BANCO WHERE SP_BANCOS.COMPANIA = :COMPANIA AND SP_TBLHIST_SALDO_CREDITO.CICLO = :CICLO AND SP_TBLHIST_SALDO_CREDITO.CODIGORUTA = :CODIGORUTA ORDER BY SP_TBLHIST_SALDO_CREDITO.ANO, SP_TBLHIST_SALDO_CREDITO.PERIODO, SP_TBLHIST_SALDO_CREDITO.FECHA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN VALOR_SALDO IS NULL THEN ' ' ELSE UPPER(VALOR_SALDO) END)  LIKE UPPER(:VALOR_SALDO || '%')  AND (CASE WHEN VALORINICIAL IS NULL THEN ' ' ELSE UPPER(VALORINICIAL) END)  LIKE UPPER( '%' || :VALORINICIAL || '%')  AND (CASE WHEN USUARIOREG IS NULL THEN ' ' ELSE UPPER(USUARIOREG) END)  LIKE UPPER(:USUARIOREG || '%')  AND (CASE WHEN VALORDES IS NULL THEN ' ' ELSE UPPER(VALORDES) END)  LIKE UPPER(:VALORDES || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","FECHA":"$FECHA","VALOR_SALDO":"$VALOR_SALDO","VALORINICIAL":"$VALORINICIAL","USUARIOREG":"$USUARIOREG","VALORDES":"$VALORDES","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_SALDO" sqlType="STRING"/>
		<param name="VALORINICIAL" sqlType="STRING"/>
		<param name="USUARIOREG" sqlType="STRING"/>
		<param name="VALORDES" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sptblhistsaldocredito/historicodesaldosporcodigoruta/pag">
		<call-query href="getSptblhistsaldocreditoPagHistoricoDeSaldosPorCodigoRutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALOR_SALDO" query-param="VALOR_SALDO"/>
			<with-param name="VALORINICIAL" query-param="VALORINICIAL"/>
			<with-param name="USUARIOREG" query-param="USUARIOREG"/>
			<with-param name="VALORDES" query-param="VALORDES"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSptblhistsaldocreditoNumHistoricoDeSaldosPorCodigoRutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_TBLHIST_SALDO_CREDITO.ANO, SP_TBLHIST_SALDO_CREDITO.PERIODO, TO_CHAR(SP_TBLHIST_SALDO_CREDITO.FECHA, 'DD/MM/YYYY') FECHA, SP_TBLHIST_SALDO_CREDITO.VALOR_SALDO, SP_TBLHIST_SALDO_CREDITO.VALORINICIAL, SP_TBLHIST_SALDO_CREDITO.USUARIOREG, SP_TBLHIST_SALDO_CREDITO.VALORDES, SP_BANCOS.NOMBRE  FROM SP_BANCOS INNER JOIN SP_TBLHIST_SALDO_CREDITO ON SP_BANCOS.COMPANIA = SP_TBLHIST_SALDO_CREDITO.COMPANIA AND SP_BANCOS.CODIGO = SP_TBLHIST_SALDO_CREDITO.BANCO WHERE SP_BANCOS.COMPANIA = :COMPANIA AND SP_TBLHIST_SALDO_CREDITO.CICLO = :CICLO AND SP_TBLHIST_SALDO_CREDITO.CODIGORUTA = :CODIGORUTA ORDER BY SP_TBLHIST_SALDO_CREDITO.ANO, SP_TBLHIST_SALDO_CREDITO.PERIODO, SP_TBLHIST_SALDO_CREDITO.FECHA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN VALOR_SALDO IS NULL THEN ' ' ELSE UPPER(VALOR_SALDO) END)  LIKE UPPER( '%' || :VALOR_SALDO || '%')  AND (CASE WHEN VALORINICIAL IS NULL THEN ' ' ELSE UPPER(VALORINICIAL) END)  LIKE UPPER( '%' || :VALORINICIAL || '%')  AND (CASE WHEN USUARIOREG IS NULL THEN ' ' ELSE UPPER(USUARIOREG) END)  LIKE UPPER( '%' || :USUARIOREG || '%')  AND (CASE WHEN VALORDES IS NULL THEN ' ' ELSE UPPER(VALORDES) END)  LIKE UPPER( '%' || :VALORDES || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_SALDO" sqlType="STRING"/>
		<param name="VALORINICIAL" sqlType="STRING"/>
		<param name="USUARIOREG" sqlType="STRING"/>
		<param name="VALORDES" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sptblhistsaldocredito/historicodesaldosporcodigoruta/num">
		<call-query href="getSptblhistsaldocreditoNumHistoricoDeSaldosPorCodigoRutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="VALOR_SALDO" query-param="VALOR_SALDO"/>
			<with-param name="VALORINICIAL" query-param="VALORINICIAL"/>
			<with-param name="USUARIOREG" query-param="USUARIOREG"/>
			<with-param name="VALORDES" query-param="VALORDES"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSptblhistsaldocreditoPagInnerbancosporcodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  S.ANO, S.PERIODO,(TO_CHAR(S.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, S.VALOR_SALDO, S.VALORINICIAL, S.USUARIOREG, S.VALORDES, B.NOMBRE  FROM SP_TBLHIST_SALDO_CREDITO S INNER JOIN SP_BANCOS B ON S.COMPANIA = B.COMPANIA AND S.BANCO = B.CODIGO WHERE S.COMPANIA = :COMPANIA AND S.CODIGORUTA = :CODIGORUTA ORDER BY S.ANO, S.PERIODO, S.FECHA) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN VALOR_SALDO IS NULL THEN ' ' ELSE UPPER(VALOR_SALDO) END)  LIKE UPPER(:VALOR_SALDO || '%')  AND (CASE WHEN VALORINICIAL IS NULL THEN ' ' ELSE UPPER(VALORINICIAL) END)  LIKE UPPER(:VALORINICIAL || '%')  AND (CASE WHEN USUARIOREG IS NULL THEN ' ' ELSE UPPER(USUARIOREG) END)  LIKE UPPER( '%' || :USUARIOREG || '%')  AND (CASE WHEN VALORDES IS NULL THEN ' ' ELSE UPPER(VALORDES) END)  LIKE UPPER(:VALORDES || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","FECHA":"$FECHA","VALOR_SALDO":"$VALOR_SALDO","VALORINICIAL":"$VALORINICIAL","USUARIOREG":"$USUARIOREG","VALORDES":"$VALORDES","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="VALOR_SALDO" sqlType="STRING"/>
		<param name="VALORINICIAL" sqlType="STRING"/>
		<param name="USUARIOREG" sqlType="STRING"/>
		<param name="VALORDES" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sptblhistsaldocredito/innerbancosporcodruta/pag">
		<call-query href="getSptblhistsaldocreditoPagInnerbancosporcodrutaQuery">
