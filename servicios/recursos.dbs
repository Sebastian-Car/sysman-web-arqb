<data name="recursos" transports="http https local">
	<config enableOData="false" id="sysmanirisst">
		<property name="carbon_datasource_name">SYSMANIRISST</property>
	</config>
	<query id="getRecursosQuery"  useConfig="sysmanirisst">
		<sql>SELECT REC.CODIGO CODIGO, CONCAT(SERV.URL,CONCAT(SERVC.URL,REC.URL) ) URL, SERVC.NOMBRE, REC.METODO, CONCAT(REC.SERVICIO_CONTEO , REC.RECURSO_CONTEO) URLCONTEO FROM API_SERVIDORES SERV INNER JOIN API_SERVICIOS SERVC ON ( SERV.ID = SERVC.SERVIDOR ) INNER JOIN API_RECURSOS REC ON ( SERVC.ID = REC.SERVICIO ) WHERE REC.CODIGO =:CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"codigo":"$CODIGO","url":"$URL","nombre":"$NOMBRE","metodo":"$METODO","codigoConteo":"$URLCONTEO"}]}}		</result>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="codigo/">
		<call-query href="getRecursosQuery">
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>

</data>