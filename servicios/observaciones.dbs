<data name="observaciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getObservacionesObservacionesProponenteQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(PROPONENTE) PROPONENTE  FROM OBSERVACIONES WHERE COMPANIA = :COMPANIA AND TIPOCONTRATO = :TIPOCONTRATO AND TRANSACCION = :TRANSACCION AND CONSECUTIVODETALLE = :CONSECUTIVO AND PROPONENTE = :PROPONENTE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PROPONENTE":"$PROPONENTE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="observaciones/observacionesproponente">
		<call-query href="getObservacionesObservacionesProponenteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>

		</call-query>
	</resource>
	<query id="insertObservaciones" keyColumns="COMPANIA,TIPOCONTRATO,TRANSACCION,CONSECUTIVODETALLE,ID" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO OBSERVACIONES (COMPANIA, TIPOCONTRATO, TRANSACCION, CONSECUTIVODETALLE, ID, PROPONENTE, SUCURSAL, DESCRIPCION, RESPUESTA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPOCONTRATO, :TRANSACCION, :CONSECUTIVODETALLE, :ID, :PROPONENTE, :SUCURSAL, :DESCRIPCION, :RESPUESTA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPOCONTRATO":"$TIPOCONTRATO","KEY_TRANSACCION":"$TRANSACCION","KEY_CONSECUTIVODETALLE":"$CONSECUTIVODETALLE(type:integer)","KEY_ID":"$ID(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="PROPONENTE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="observaciones">
		<call-query href="insertObservaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVODETALLE" query-param="CONSECUTIVODETALLE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteObservaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM OBSERVACIONES WHERE OBSERVACIONES.COMPANIA= :KEY_COMPANIA AND OBSERVACIONES.TIPOCONTRATO= :KEY_TIPOCONTRATO AND OBSERVACIONES.TRANSACCION= :KEY_TRANSACCION AND OBSERVACIONES.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND OBSERVACIONES.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVODETALLE" sqlType="INTEGER"/>
		<param name="KEY_ID" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="observaciones">
		<call-query href="deleteObservaciones">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_TRANSACCION" query-param="KEY_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVODETALLE" query-param="KEY_CONSECUTIVODETALLE"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="getObservacionesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  OBSERVACIONES.COMPANIA, OBSERVACIONES.TIPOCONTRATO, OBSERVACIONES.TRANSACCION, OBSERVACIONES.CONSECUTIVODETALLE, OBSERVACIONES.ID, TERCERO.NOMBRE, OBSERVACIONES.DESCRIPCION, OBSERVACIONES.RESPUESTA  FROM OBSERVACIONES INNER JOIN TERCERO ON OBSERVACIONES.COMPANIA = TERCERO.COMPANIA AND OBSERVACIONES.PROPONENTE = TERCERO.NIT AND OBSERVACIONES.SUCURSAL = TERCERO.SUCURSAL WHERE OBSERVACIONES.COMPANIA = :COMPANIA AND OBSERVACIONES.PROPONENTE = :PROPONENTE AND OBSERVACIONES.TIPOCONTRATO = :TIPOCONTRATO AND OBSERVACIONES.TRANSACCION = :TRANSACCION AND OBSERVACIONES.CONSECUTIVODETALLE = :CONSECUTIVO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN TIPOCONTRATO IS NULL THEN ' ' ELSE UPPER(TIPOCONTRATO) END)  LIKE UPPER( '%' || :TIPOCONTRATO || '%')  AND (CASE WHEN TRANSACCION IS NULL THEN ' ' ELSE UPPER(TRANSACCION) END)  LIKE UPPER( '%' || :TRANSACCION || '%')  AND (CASE WHEN CONSECUTIVODETALLE IS NULL THEN ' ' ELSE UPPER(CONSECUTIVODETALLE) END)  LIKE UPPER( '%' || :CONSECUTIVODETALLE || '%')  AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER( '%' || :ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN RESPUESTA IS NULL THEN ' ' ELSE UPPER(RESPUESTA) END)  LIKE UPPER( '%' || :RESPUESTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCONTRATO":"$TIPOCONTRATO","TRANSACCION":"$TRANSACCION","CONSECUTIVODETALLE":"$CONSECUTIVODETALLE(type:integer)","ID":"$ID(type:integer)","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","RESPUESTA":"$RESPUESTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="observaciones">
		<call-query href="getObservacionesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONSECUTIVODETALLE" query-param="CONSECUTIVODETALLE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getObservacionesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  OBSERVACIONES.COMPANIA, OBSERVACIONES.TIPOCONTRATO, OBSERVACIONES.TRANSACCION, OBSERVACIONES.CONSECUTIVODETALLE, OBSERVACIONES.ID, TERCERO.NOMBRE, OBSERVACIONES.DESCRIPCION, OBSERVACIONES.RESPUESTA  FROM OBSERVACIONES INNER JOIN TERCERO ON OBSERVACIONES.COMPANIA = TERCERO.COMPANIA AND OBSERVACIONES.PROPONENTE = TERCERO.NIT AND OBSERVACIONES.SUCURSAL = TERCERO.SUCURSAL WHERE OBSERVACIONES.COMPANIA = :COMPANIA AND OBSERVACIONES.PROPONENTE = :PROPONENTE AND OBSERVACIONES.TIPOCONTRATO = :TIPOCONTRATO AND OBSERVACIONES.TRANSACCION = :TRANSACCION AND OBSERVACIONES.CONSECUTIVODETALLE = :CONSECUTIVO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN TIPOCONTRATO IS NULL THEN ' ' ELSE UPPER(TIPOCONTRATO) END)  LIKE UPPER( '%' || :TIPOCONTRATO || '%')  AND (CASE WHEN TRANSACCION IS NULL THEN ' ' ELSE UPPER(TRANSACCION) END)  LIKE UPPER( '%' || :TRANSACCION || '%')  AND (CASE WHEN CONSECUTIVODETALLE IS NULL THEN ' ' ELSE UPPER(CONSECUTIVODETALLE) END)  LIKE UPPER( '%' || :CONSECUTIVODETALLE || '%')  AND (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER( '%' || :ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN RESPUESTA IS NULL THEN ' ' ELSE UPPER(RESPUESTA) END)  LIKE UPPER( '%' || :RESPUESTA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="observaciones/numero">
		<call-query href="getObservacionesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CONSECUTIVODETALLE" query-param="CONSECUTIVODETALLE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>

		</call-query>
	</resource>
	<query id="getObservacionesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  OBSERVACIONES.COMPANIA, OBSERVACIONES.TIPOCONTRATO, OBSERVACIONES.TRANSACCION, OBSERVACIONES.CONSECUTIVODETALLE, OBSERVACIONES.ID, OBSERVACIONES.PROPONENTE, OBSERVACIONES.SUCURSAL, OBSERVACIONES.DESCRIPCION, OBSERVACIONES.RESPUESTA,(TO_CHAR(OBSERVACIONES.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, OBSERVACIONES.CREATED_BY,(TO_CHAR(OBSERVACIONES.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, OBSERVACIONES.MODIFIED_BY  FROM OBSERVACIONES INNER JOIN TERCERO ON OBSERVACIONES.COMPANIA = TERCERO.COMPANIA AND OBSERVACIONES.PROPONENTE = TERCERO.NIT AND OBSERVACIONES.SUCURSAL = TERCERO.SUCURSAL WHERE OBSERVACIONES.COMPANIA= :KEY_COMPANIA AND OBSERVACIONES.TIPOCONTRATO= :KEY_TIPOCONTRATO AND OBSERVACIONES.TRANSACCION= :KEY_TRANSACCION AND OBSERVACIONES.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND OBSERVACIONES.ID= :KEY_ID</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPOCONTRATO":"$TIPOCONTRATO","TRANSACCION":"$TRANSACCION","CONSECUTIVODETALLE":"$CONSECUTIVODETALLE(type:integer)","ID":"$ID(type:integer)","PROPONENTE":"$PROPONENTE","SUCURSAL":"$SUCURSAL","DESCRIPCION":"$DESCRIPCION","RESPUESTA":"$RESPUESTA","DATE_CREATED":"$DATE_CREATED","CREATED_BY":"$CREATED_BY","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="GET" path="observaciones/data">
		<call-query href="getObservacionesRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_TRANSACCION" query-param="KEY_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVODETALLE" query-param="KEY_CONSECUTIVODETALLE"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>
	<query id="updateObservaciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE OBSERVACIONES SET COMPANIA=:COMPANIA, TIPOCONTRATO=:TIPOCONTRATO, TRANSACCION=:TRANSACCION, CONSECUTIVODETALLE=:CONSECUTIVODETALLE, ID=:ID, PROPONENTE=:PROPONENTE, SUCURSAL=:SUCURSAL, DESCRIPCION=:DESCRIPCION, RESPUESTA=:RESPUESTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE OBSERVACIONES.COMPANIA= :KEY_COMPANIA AND OBSERVACIONES.TIPOCONTRATO= :KEY_TIPOCONTRATO AND OBSERVACIONES.TRANSACCION= :KEY_TRANSACCION AND OBSERVACIONES.CONSECUTIVODETALLE= :KEY_CONSECUTIVODETALLE AND OBSERVACIONES.ID= :KEY_ID</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="TRANSACCION" sqlType="STRING"/>
		<param name="CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="PROPONENTE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="RESPUESTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPOCONTRATO" sqlType="STRING"/>
		<param name="KEY_TRANSACCION" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVODETALLE" sqlType="STRING"/>
		<param name="KEY_ID" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="observaciones">
		<call-query href="updateObservaciones">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCONTRATO" query-param="TIPOCONTRATO"/>
			<with-param name="TRANSACCION" query-param="TRANSACCION"/>
			<with-param name="CONSECUTIVODETALLE" query-param="CONSECUTIVODETALLE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="PROPONENTE" query-param="PROPONENTE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="RESPUESTA" query-param="RESPUESTA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPOCONTRATO" query-param="KEY_TIPOCONTRATO"/>
			<with-param name="KEY_TRANSACCION" query-param="KEY_TRANSACCION"/>
			<with-param name="KEY_CONSECUTIVODETALLE" query-param="KEY_CONSECUTIVODETALLE"/>
			<with-param name="KEY_ID" query-param="KEY_ID"/>

		</call-query>
	</resource>

</data>