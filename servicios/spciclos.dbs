	<query id="getSpciclosPagUsuariosPorCiclosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT TO_CHAR(NUMERO) NUMERO, CODIGOINICIAL, CODIGOFINAL, NOMBREINICIAL, NOMBREFINAL, ROWNUM POS FROM ( SELECT NUMERO, NVL(CODIGOINICIAL,' ') CODIGOINICIAL, NVL(CODIGOFINAL,' ') CODIGOFINAL, CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(U.SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(U.NOMBRES,' ') ) ) ) ) NOMBREINICIAL , CONCAT(NVL(US.PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(US.SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(US.NOMBRES,' ') ) ) ) ) NOMBREFINAL FROM SP_CICLO C LEFT JOIN SP_USUARIO U ON C.COMPANIA = U.COMPANIA AND CODIGOINICIAL = U.CODIGORUTA AND C.NUMERO = U.CICLO LEFT JOIN SP_USUARIO US ON C.COMPANIA = US.COMPANIA AND C.CODIGOFINAL = US.CODIGORUTA AND C.NUMERO = US.CICLO WHERE C.COMPANIA =:COMPANIA ORDER BY NUMERO ) UNION SELECT 'T' NUMERO, '1', '9999999999999999', ' ', ' ', 9999999999999999 FROM DUAL ORDER BY POS) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END) LIKE UPPER(CONCAT(:CODIGOINICIAL, '%')) AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END) LIKE UPPER(CONCAT(:CODIGOFINAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","CODIGOINICIAL":"$CODIGOINICIAL","CODIGOFINAL":"$CODIGOFINAL","NOMBREINICIAL":"$NOMBREINICIAL","NOMBREFINAL":"$NOMBREFINAL","POS":"$POS(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos/usuariosporciclos/pag">
		<call-query href="getSpciclosPagUsuariosPorCiclosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumUsuariosPorCiclosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT TO_CHAR(NUMERO) NUMERO, CODIGOINICIAL, CODIGOFINAL, NOMBREINICIAL, NOMBREFINAL, ROWNUM POS FROM ( SELECT NUMERO, NVL(CODIGOINICIAL,' ') CODIGOINICIAL, NVL(CODIGOFINAL,' ') CODIGOFINAL, CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(U.SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(U.NOMBRES,' ') ) ) ) ) NOMBREINICIAL , CONCAT(NVL(US.PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(US.SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(US.NOMBRES,' ') ) ) ) ) NOMBREFINAL FROM SP_CICLO C LEFT JOIN SP_USUARIO U ON C.COMPANIA = U.COMPANIA AND CODIGOINICIAL = U.CODIGORUTA AND C.NUMERO = U.CICLO LEFT JOIN SP_USUARIO US ON C.COMPANIA = US.COMPANIA AND C.CODIGOFINAL = US.CODIGORUTA AND C.NUMERO = US.CICLO WHERE C.COMPANIA =:COMPANIA ORDER BY NUMERO ) UNION SELECT 'T' NUMERO, '1', '9999999999999999', ' ', ' ', 9999999999999999 FROM DUAL ORDER BY POS) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END) LIKE UPPER(CONCAT(:CODIGOINICIAL, '%')) AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END) LIKE UPPER(CONCAT(:CODIGOFINAL, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/usuariosporciclos/num">
		<call-query href="getSpciclosNumUsuariosPorCiclosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>

		</call-query>
	</resource>
