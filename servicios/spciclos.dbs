	<query id="getSpciclosDiferenciafechapreparaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TRUNC(SYSDATE) - TRUNC(NVL(FECHA_PREPARACION,SYSDATE)) DIFERENCIA  FROM SP_CICLO WHERE COMPANIA = :COMPANIA AND NUMERO = :CICLO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"DIFERENCIA":"$DIFERENCIA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>

	</query>
