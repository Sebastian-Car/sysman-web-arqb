	<query id="getSpciclosNumListaciclosconcodQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_CICLO.NUMERO, SP_CICLO.CODIGOINICIAL, SP_CICLO.CODIGOFINAL  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA AND NUMERO &gt;= :CICLOINICIAL ORDER BY SP_CICLO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END)  LIKE UPPER( '%' || :CODIGOINICIAL || '%')  AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END)  LIKE UPPER( '%' || :CODIGOFINAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
