	<query id="getSpciclosPagTodosLosCiclosPorCodigoInicialYFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  'T' NUMERO, '0' CODIGOINICIAL, '99999999999999' CODIGOFINAL, 0 ORDEN  FROM COMPANIA UNION SELECT TO_CHAR(SP_CICLO.NUMERO) NUMERO, SP_CICLO.CODIGOINICIAL, SP_CICLO.CODIGOFINAL, SP_CICLO.NUMERO ORDEN FROM SP_CICLO WHERE COMPANIA =:COMPANIA ORDER BY ORDEN ASC) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END)  LIKE UPPER(:CODIGOINICIAL || '%')  AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END)  LIKE UPPER(:CODIGOFINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","CODIGOINICIAL":"$CODIGOINICIAL","CODIGOFINAL":"$CODIGOFINAL","ORDEN":"$ORDEN(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
