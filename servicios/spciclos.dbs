	<query id="getSpciclosFechaeindicadorcalcQuery"  useConfig="sysmandsunist">
		<sql>SELECT (TO_CHAR(FECHA_PREPARACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_PREPARACION,(CASE INDCALCULADO WHEN 0 THEN 'false' ELSE 'true' END) INDCALCULADO FROM SP_CICLO WHERE COMPANIA = :COMPANIA AND NUMERO = :CICLO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHA_PREPARACION":"$FECHA_PREPARACION","INDCALCULADO":"$INDCALCULADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>

	</query>
