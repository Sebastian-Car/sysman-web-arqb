<data name="spciclos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpciclosPagPorcompaniacontQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUM, CICLO, ANO, PERIODO  FROM (SELECT TO_CHAR(NUMERO) NUM, NUMERO CICLO, ANO, PERIODO FROM SP_CICLO WHERE COMPANIA = :COMPANIA UNION SELECT TO_CHAR ('T') NUM, 999999 CICLO, 0 ANO, '0' PERIODO FROM DUAL ) ORDER BY CICLO) WHERE (CASE WHEN NUM IS NULL THEN ' ' ELSE UPPER(NUM) END)  LIKE UPPER(:NUM || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUM":"$NUM","CICLO":"$CICLO(type:double)","ANO":"$ANO(type:double)","PERIODO":"$PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos/porcompaniacont/pag">
		<call-query href="getSpciclosPagPorcompaniacontQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUM" query-param="NUM"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumPorcompaniacontQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NUM, CICLO, ANO, PERIODO  FROM (SELECT TO_CHAR(NUMERO) NUM, NUMERO CICLO, ANO, PERIODO FROM SP_CICLO WHERE COMPANIA = :COMPANIA UNION SELECT TO_CHAR ('T') NUM, 999999 CICLO, 0 ANO, '0' PERIODO FROM DUAL ) ORDER BY CICLO) WHERE (CASE WHEN NUM IS NULL THEN ' ' ELSE UPPER(NUM) END)  LIKE UPPER(:NUM || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUM" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/porcompaniacont/num">
		<call-query href="getSpciclosNumPorcompaniacontQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUM" query-param="NUM"/>

		</call-query>
	</resource>
	<query id="getSpciclosPagCodinicialfinalporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUMERO , CODIGOINICIAL, CODIGOFINAL,(CASE PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO FROM SP_CICLO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","CODIGOINICIAL":"$CODIGOINICIAL","CODIGOFINAL":"$CODIGOFINAL","PREFACTURANDO":"$PREFACTURANDO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos/codinicialfinalporcompania/pag">
		<call-query href="getSpciclosPagCodinicialfinalporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumCodinicialfinalporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NUMERO , CODIGOINICIAL, CODIGOFINAL,(CASE PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO FROM SP_CICLO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/codinicialfinalporcompania/num">
		<call-query href="getSpciclosNumCodinicialfinalporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getSpciclosTodoPorCicloInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_CICLO.NUMERO  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY SP_CICLO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/todoporcicloinicial">
		<call-query href="getSpciclosTodoPorCicloInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpciclosTodoPorCicloFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_CICLO.NUMERO  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA AND SP_CICLO.NUMERO &gt;= :CICLOINICIAL ORDER BY SP_CICLO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOINICIAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/todoporciclofinal">
		<call-query href="getSpciclosTodoPorCicloFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOINICIAL" query-param="CICLOINICIAL"/>

		</call-query>
	</resource>
	<query id="getSpciclosTodosPorCompaniaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NUMERO  FROM SP_CICLO WHERE COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/todosporcompanianumero">
		<call-query href="getSpciclosTodosPorCompaniaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpciclosPagNumeroAnoPeriodoFechapreparacionYPrefacturadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  NUMERO, ANO, PERIODO,(TO_CHAR(FECHA_PREPARACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_PREPARACION,(CASE PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO FROM SP_CICLO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN FECHA_PREPARACION IS NULL THEN ' ' ELSE UPPER(FECHA_PREPARACION) END)  LIKE UPPER( '%' || :FECHA_PREPARACION || '%')  AND (CASE WHEN PREFACTURANDO IS NULL THEN ' ' ELSE UPPER(PREFACTURANDO) END)  LIKE UPPER(:PREFACTURANDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","FECHA_PREPARACION":"$FECHA_PREPARACION","PREFACTURANDO":"$PREFACTURANDO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA_PREPARACION" sqlType="STRING"/>
		<param name="PREFACTURANDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos/numeroanoperiodofechapreparacionyprefacturado/pag">
		<call-query href="getSpciclosPagNumeroAnoPeriodoFechapreparacionYPrefacturadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FECHA_PREPARACION" query-param="FECHA_PREPARACION"/>
			<with-param name="PREFACTURANDO" query-param="PREFACTURANDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumNumeroAnoPeriodoFechapreparacionYPrefacturadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  NUMERO, ANO, PERIODO,(TO_CHAR(FECHA_PREPARACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_PREPARACION,(CASE PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO FROM SP_CICLO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN FECHA_PREPARACION IS NULL THEN ' ' ELSE UPPER(FECHA_PREPARACION) END)  LIKE UPPER( '%' || :FECHA_PREPARACION || '%')  AND (CASE WHEN PREFACTURANDO IS NULL THEN ' ' ELSE UPPER(PREFACTURANDO) END)  LIKE UPPER( '%' || :PREFACTURANDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="FECHA_PREPARACION" sqlType="STRING"/>
		<param name="PREFACTURANDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/numeroanoperiodofechapreparacionyprefacturado/num">
		<call-query href="getSpciclosNumNumeroAnoPeriodoFechapreparacionYPrefacturadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="FECHA_PREPARACION" query-param="FECHA_PREPARACION"/>
			<with-param name="PREFACTURANDO" query-param="PREFACTURANDO"/>

		</call-query>
	</resource>
	<query id="insertSpciclos" keyColumns="COMPANIA,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_CICLO (COMPANIA, NUMERO, ANO, PERIODO, CODIGOINICIAL, CODIGOFINAL, INDFACTURADO, INDPREPARADO, INDESTADISTICAS, INDCALCULADO, INDRECAUDADO, INDAUTORMODIFICACION, FECHAPAGO1, FECHAPAGO2, FECHAPAGO3, ANOINICIAL, PERIODOINICIAL, TASARECARGO, INDBLOQUEOMANUAL, INDSELLOFIMM, FECHA_PREPARACION, HORA_PREPARACION, PREFACTURANDO, FECHA_CIERREPREFAC, APLICADESCUENTO, EXCLUIR_ESTADISTICA_MENSUAL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :NUMERO, :ANO, :PERIODO, :CODIGOINICIAL, :CODIGOFINAL, :INDFACTURADO, :INDPREPARADO, :INDESTADISTICAS, :INDCALCULADO, :INDRECAUDADO, :INDAUTORMODIFICACION, TO_DATE(:FECHAPAGO1,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAPAGO2,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAPAGO3,'DD/MM/YYYY HH24:MI:SS'), :ANOINICIAL, :PERIODOINICIAL, :TASARECARGO, :INDBLOQUEOMANUAL, :INDSELLOFIMM, TO_DATE(:FECHA_PREPARACION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:HORA_PREPARACION,'DD/MM/YYYY HH24:MI:SS'), :PREFACTURANDO, TO_DATE(:FECHA_CIERREPREFAC,'DD/MM/YYYY HH24:MI:SS'), :APLICADESCUENTO, :EXCLUIR_ESTADISTICA_MENSUAL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO":"$NUMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param defaultValue="01" name="PERIODO" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOINICIAL" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOFINAL" sqlType="STRING"/>
		<param defaultValue="0" name="INDFACTURADO" sqlType="STRING"/>
		<param defaultValue="0" name="INDPREPARADO" sqlType="STRING"/>
		<param defaultValue="0" name="INDESTADISTICAS" sqlType="STRING"/>
		<param defaultValue="0" name="INDCALCULADO" sqlType="STRING"/>
		<param defaultValue="0" name="INDRECAUDADO" sqlType="STRING"/>
		<param defaultValue="0" name="INDAUTORMODIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="FECHAPAGO1" sqlType="STRING"/>
		<param defaultValue="" name="FECHAPAGO2" sqlType="STRING"/>
		<param defaultValue="" name="FECHAPAGO3" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param defaultValue="01" name="PERIODOINICIAL" sqlType="STRING"/>
		<param defaultValue="0" name="TASARECARGO" sqlType="STRING"/>
		<param defaultValue="0" name="INDBLOQUEOMANUAL" sqlType="STRING"/>
		<param defaultValue="0" name="INDSELLOFIMM" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_PREPARACION" sqlType="STRING"/>
		<param defaultValue="" name="HORA_PREPARACION" sqlType="STRING"/>
		<param defaultValue="0" name="PREFACTURANDO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_CIERREPREFAC" sqlType="STRING"/>
		<param defaultValue="0" name="APLICADESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="EXCLUIR_ESTADISTICA_MENSUAL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spciclos">
		<call-query href="insertSpciclos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>
			<with-param name="INDFACTURADO" query-param="INDFACTURADO"/>
			<with-param name="INDPREPARADO" query-param="INDPREPARADO"/>
			<with-param name="INDESTADISTICAS" query-param="INDESTADISTICAS"/>
			<with-param name="INDCALCULADO" query-param="INDCALCULADO"/>
			<with-param name="INDRECAUDADO" query-param="INDRECAUDADO"/>
			<with-param name="INDAUTORMODIFICACION" query-param="INDAUTORMODIFICACION"/>
			<with-param name="FECHAPAGO1" query-param="FECHAPAGO1"/>
			<with-param name="FECHAPAGO2" query-param="FECHAPAGO2"/>
			<with-param name="FECHAPAGO3" query-param="FECHAPAGO3"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="PERIODOINICIAL" query-param="PERIODOINICIAL"/>
			<with-param name="TASARECARGO" query-param="TASARECARGO"/>
			<with-param name="INDBLOQUEOMANUAL" query-param="INDBLOQUEOMANUAL"/>
			<with-param name="INDSELLOFIMM" query-param="INDSELLOFIMM"/>
			<with-param name="FECHA_PREPARACION" query-param="FECHA_PREPARACION"/>
			<with-param name="HORA_PREPARACION" query-param="HORA_PREPARACION"/>
			<with-param name="PREFACTURANDO" query-param="PREFACTURANDO"/>
			<with-param name="FECHA_CIERREPREFAC" query-param="FECHA_CIERREPREFAC"/>
			<with-param name="APLICADESCUENTO" query-param="APLICADESCUENTO"/>
			<with-param name="EXCLUIR_ESTADISTICA_MENSUAL" query-param="EXCLUIR_ESTADISTICA_MENSUAL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteSpciclos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_CICLO WHERE SP_CICLO.COMPANIA= :KEY_COMPANIA AND SP_CICLO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="spciclos">
		<call-query href="deleteSpciclos">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getSpciclosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NUMERO , ANO , PERIODO , CODIGOINICIAL , CODIGOFINAL  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY SP_CICLO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%')  AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END)  LIKE UPPER(:CODIGOINICIAL || '%')  AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END)  LIKE UPPER(:CODIGOFINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CODIGOINICIAL":"$CODIGOINICIAL","CODIGOFINAL":"$CODIGOFINAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos">
		<call-query href="getSpciclosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NUMERO , ANO , PERIODO , CODIGOINICIAL , CODIGOFINAL  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY SP_CICLO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%')  AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END)  LIKE UPPER( '%' || :CODIGOINICIAL || '%')  AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END)  LIKE UPPER( '%' || :CODIGOFINAL || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/numero">
		<call-query href="getSpciclosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>

		</call-query>
	</resource>
	<query id="getSpciclosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA , NUMERO , ANO , PERIODO , CODIGOINICIAL , CODIGOFINAL ,(CASE INDFACTURADO WHEN 0 THEN 'false' ELSE 'true' END) INDFACTURADO,(CASE INDPREPARADO WHEN 0 THEN 'false' ELSE 'true' END) INDPREPARADO,(CASE INDESTADISTICAS WHEN 0 THEN 'false' ELSE 'true' END) INDESTADISTICAS,(CASE INDCALCULADO WHEN 0 THEN 'false' ELSE 'true' END) INDCALCULADO,(CASE INDRECAUDADO WHEN 0 THEN 'false' ELSE 'true' END) INDRECAUDADO,(CASE INDAUTORMODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) INDAUTORMODIFICACION,(TO_CHAR(FECHAPAGO1,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO1,(TO_CHAR(FECHAPAGO2,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO2,(TO_CHAR(FECHAPAGO3,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO3, ANOINICIAL , PERIODOINICIAL , TASARECARGO ,(CASE INDBLOQUEOMANUAL WHEN 0 THEN 'false' ELSE 'true' END) INDBLOQUEOMANUAL,(CASE INDSELLOFIMM WHEN 0 THEN 'false' ELSE 'true' END) INDSELLOFIMM,(TO_CHAR(FECHA_PREPARACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_PREPARACION,(TO_CHAR(HORA_PREPARACION,'DD/MM/YYYY HH24:MI:SS')) HORA_PREPARACION,(CASE PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO,(TO_CHAR(FECHA_CIERREPREFAC,'DD/MM/YYYY HH24:MI:SS')) FECHA_CIERREPREFAC,(CASE APLICADESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) APLICADESCUENTO,(CASE EXCLUIR_ESTADISTICA_MENSUAL WHEN 0 THEN 'false' ELSE 'true' END) EXCLUIR_ESTADISTICA_MENSUAL, CREATED_BY ,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY ,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_CICLO WHERE SP_CICLO.COMPANIA= :KEY_COMPANIA AND SP_CICLO.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO":"$NUMERO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CODIGOINICIAL":"$CODIGOINICIAL","CODIGOFINAL":"$CODIGOFINAL","INDFACTURADO":"$INDFACTURADO(type:boolean)","INDPREPARADO":"$INDPREPARADO(type:boolean)","INDESTADISTICAS":"$INDESTADISTICAS(type:boolean)","INDCALCULADO":"$INDCALCULADO(type:boolean)","INDRECAUDADO":"$INDRECAUDADO(type:boolean)","INDAUTORMODIFICACION":"$INDAUTORMODIFICACION(type:boolean)","FECHAPAGO1":"$FECHAPAGO1","FECHAPAGO2":"$FECHAPAGO2","FECHAPAGO3":"$FECHAPAGO3","ANOINICIAL":"$ANOINICIAL(type:integer)","PERIODOINICIAL":"$PERIODOINICIAL","TASARECARGO":"$TASARECARGO","INDBLOQUEOMANUAL":"$INDBLOQUEOMANUAL(type:boolean)","INDSELLOFIMM":"$INDSELLOFIMM(type:boolean)","FECHA_PREPARACION":"$FECHA_PREPARACION","HORA_PREPARACION":"$HORA_PREPARACION","PREFACTURANDO":"$PREFACTURANDO(type:boolean)","FECHA_CIERREPREFAC":"$FECHA_CIERREPREFAC","APLICADESCUENTO":"$APLICADESCUENTO(type:boolean)","EXCLUIR_ESTADISTICA_MENSUAL":"$EXCLUIR_ESTADISTICA_MENSUAL(type:boolean)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/data">
		<call-query href="getSpciclosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateSpciclos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_CICLO SET COMPANIA=:COMPANIA, NUMERO=:NUMERO, ANO=:ANO, PERIODO=:PERIODO, CODIGOINICIAL=:CODIGOINICIAL, CODIGOFINAL=:CODIGOFINAL, INDFACTURADO=:INDFACTURADO, INDPREPARADO=:INDPREPARADO, INDESTADISTICAS=:INDESTADISTICAS, INDCALCULADO=:INDCALCULADO, INDRECAUDADO=:INDRECAUDADO, INDAUTORMODIFICACION=:INDAUTORMODIFICACION, FECHAPAGO1=TO_DATE(:FECHAPAGO1,'DD/MM/YYYY HH24:MI:SS'), FECHAPAGO2=TO_DATE(:FECHAPAGO2,'DD/MM/YYYY HH24:MI:SS'), FECHAPAGO3=TO_DATE(:FECHAPAGO3,'DD/MM/YYYY HH24:MI:SS'), ANOINICIAL=:ANOINICIAL, PERIODOINICIAL=:PERIODOINICIAL, TASARECARGO=:TASARECARGO, INDBLOQUEOMANUAL=:INDBLOQUEOMANUAL, INDSELLOFIMM=:INDSELLOFIMM, FECHA_PREPARACION=TO_DATE(:FECHA_PREPARACION,'DD/MM/YYYY HH24:MI:SS'), HORA_PREPARACION=TO_DATE(:HORA_PREPARACION,'DD/MM/YYYY HH24:MI:SS'), PREFACTURANDO=:PREFACTURANDO, FECHA_CIERREPREFAC=TO_DATE(:FECHA_CIERREPREFAC,'DD/MM/YYYY HH24:MI:SS'), APLICADESCUENTO=:APLICADESCUENTO, EXCLUIR_ESTADISTICA_MENSUAL=:EXCLUIR_ESTADISTICA_MENSUAL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_CICLO.COMPANIA= :KEY_COMPANIA AND SP_CICLO.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="INDFACTURADO" sqlType="STRING"/>
		<param name="INDPREPARADO" sqlType="STRING"/>
		<param name="INDESTADISTICAS" sqlType="STRING"/>
		<param name="INDCALCULADO" sqlType="STRING"/>
		<param name="INDRECAUDADO" sqlType="STRING"/>
		<param name="INDAUTORMODIFICACION" sqlType="STRING"/>
		<param name="FECHAPAGO1" sqlType="STRING"/>
		<param name="FECHAPAGO2" sqlType="STRING"/>
		<param name="FECHAPAGO3" sqlType="STRING"/>
		<param name="ANOINICIAL" sqlType="STRING"/>
		<param name="PERIODOINICIAL" sqlType="STRING"/>
		<param name="TASARECARGO" sqlType="STRING"/>
		<param name="INDBLOQUEOMANUAL" sqlType="STRING"/>
		<param name="INDSELLOFIMM" sqlType="STRING"/>
		<param name="FECHA_PREPARACION" sqlType="STRING"/>
		<param name="HORA_PREPARACION" sqlType="STRING"/>
		<param name="PREFACTURANDO" sqlType="STRING"/>
		<param name="FECHA_CIERREPREFAC" sqlType="STRING"/>
		<param name="APLICADESCUENTO" sqlType="STRING"/>
		<param name="EXCLUIR_ESTADISTICA_MENSUAL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spciclos">
		<call-query href="updateSpciclos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>
			<with-param name="INDFACTURADO" query-param="INDFACTURADO"/>
			<with-param name="INDPREPARADO" query-param="INDPREPARADO"/>
			<with-param name="INDESTADISTICAS" query-param="INDESTADISTICAS"/>
			<with-param name="INDCALCULADO" query-param="INDCALCULADO"/>
			<with-param name="INDRECAUDADO" query-param="INDRECAUDADO"/>
			<with-param name="INDAUTORMODIFICACION" query-param="INDAUTORMODIFICACION"/>
			<with-param name="FECHAPAGO1" query-param="FECHAPAGO1"/>
			<with-param name="FECHAPAGO2" query-param="FECHAPAGO2"/>
			<with-param name="FECHAPAGO3" query-param="FECHAPAGO3"/>
			<with-param name="ANOINICIAL" query-param="ANOINICIAL"/>
			<with-param name="PERIODOINICIAL" query-param="PERIODOINICIAL"/>
			<with-param name="TASARECARGO" query-param="TASARECARGO"/>
			<with-param name="INDBLOQUEOMANUAL" query-param="INDBLOQUEOMANUAL"/>
			<with-param name="INDSELLOFIMM" query-param="INDSELLOFIMM"/>
			<with-param name="FECHA_PREPARACION" query-param="FECHA_PREPARACION"/>
			<with-param name="HORA_PREPARACION" query-param="HORA_PREPARACION"/>
			<with-param name="PREFACTURANDO" query-param="PREFACTURANDO"/>
			<with-param name="FECHA_CIERREPREFAC" query-param="FECHA_CIERREPREFAC"/>
			<with-param name="APLICADESCUENTO" query-param="APLICADESCUENTO"/>
			<with-param name="EXCLUIR_ESTADISTICA_MENSUAL" query-param="EXCLUIR_ESTADISTICA_MENSUAL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getSpciclosPagTodosPorNumeroAnioYPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_CICLO.NUMERO, SP_CICLO.ANO, SP_CICLO.PERIODO  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY SP_CICLO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER(:PERIODO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos/todospornumeroanioyperiodo/pag">
		<call-query href="getSpciclosPagTodosPorNumeroAnioYPeriodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumTodosPorNumeroAnioYPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  SP_CICLO.NUMERO, SP_CICLO.ANO, SP_CICLO.PERIODO  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY SP_CICLO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END)  LIKE UPPER( '%' || :PERIODO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/todospornumeroanioyperiodo/num">
		<call-query href="getSpciclosNumTodosPorNumeroAnioYPeriodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpciclosTodosPorAnoPeriodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT MAX(CONCAT(ANO,PERIODO) ) PER FROM SP_CICLO WHERE SP_CICLO.COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PER":"$PER"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/todosporanoperiodo">
		<call-query href="getSpciclosTodosPorAnoPeriodoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpciclosPagPorCompaniaAnioPeriodoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT NUMERO, ANO, PERIODO, ANOINICIAL, PERIODOINICIAL,(TO_CHAR(NVL(FECHA_PREPARACION,TO_DATE(CONCAT('01/06/',TO_CHAR(SYSDATE,'YYYY') ),'DD/MM/YYYY') ),'DD/MM/YYYY HH24:MI:SS')) FECHA_PREPARACION FROM SP_CICLO WHERE COMPANIA =:COMPANIA) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","ANOINICIAL":"$ANOINICIAL(type:integer)","PERIODOINICIAL":"$PERIODOINICIAL","FECHA_PREPARACION":"$FECHA_PREPARACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos/porcompaniaanioperiodoinicial/pag">
		<call-query href="getSpciclosPagPorCompaniaAnioPeriodoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumPorCompaniaAnioPeriodoInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT NUMERO, ANO, PERIODO, ANOINICIAL, PERIODOINICIAL,(TO_CHAR(NVL(FECHA_PREPARACION,TO_DATE(CONCAT('01/06/',TO_CHAR(SYSDATE,'YYYY') ),'DD/MM/YYYY') ),'DD/MM/YYYY HH24:MI:SS')) FECHA_PREPARACION FROM SP_CICLO WHERE COMPANIA =:COMPANIA) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spciclos/porcompaniaanioperiodoinicial/num">
		<call-query href="getSpciclosNumPorCompaniaAnioPeriodoInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getSpciclosPagTodosPorCompaniaCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_CICLO.NUMERO, SP_CICLO.ANO, SP_CICLO.PERIODO, SP_CICLO.ANOINICIAL, SP_CICLO.PERIODOINICIAL,(TO_CHAR(SP_CICLO.FECHA_PREPARACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_PREPARACION,(CASE SP_CICLO.PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO, SP_CICLO.TASARECARGO  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY SP_CICLO.NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","ANOINICIAL":"$ANOINICIAL(type:integer)","PERIODOINICIAL":"$PERIODOINICIAL","FECHA_PREPARACION":"$FECHA_PREPARACION","PREFACTURANDO":"$PREFACTURANDO(type:boolean)","TASARECARGO":"$TASARECARGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
