	<query id="updateSpciclosPorCodigoFinalCiclo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_CICLO  SET CODIGOINICIAL =:CODIGOINICIAL, 	CODIGOFINAL   =:CODIGOFINAL,DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),MODIFIED_BY=:MODIFIED_BY  WHERE NUMERO	  =:CICLO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spciclos/porcodigofinalciclo">
		<call-query href="updateSpciclosPorCodigoFinalCiclo">
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="CICLO" query-param="CICLO"/>

		</call-query>
	</resource>
