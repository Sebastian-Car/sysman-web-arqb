	<query id="getSpciclosPagAnioPeriodoporCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CICLO, CASE WHEN ANO = 0 THEN ' ' ELSE TO_CHAR(ANO) END ANO , PERIODO  FROM (SELECT NUMERO , TO_CHAR(NUMERO) CICLO, ANO, PERIODO FROM SP_CICLO WHERE COMPANIA = :COMPANIA UNION SELECT 0 NUMERO , 'T' CICLO, 0 ANO, '0' PERIODO FROM DUAL ) ORDER BY NUMERO) WHERE (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER(:CICLO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CICLO":"$CICLO","ANO":"$ANO","PERIODO":"$PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spciclos/anioperiodoporcompania/pag">
		<call-query href="getSpciclosPagAnioPeriodoporCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpciclosNumAnioPeriodoporCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CICLO, CASE WHEN ANO = 0 THEN ' ' ELSE TO_CHAR(ANO) END ANO , PERIODO  FROM (SELECT NUMERO , TO_CHAR(NUMERO) CICLO, ANO, PERIODO FROM SP_CICLO WHERE COMPANIA = :COMPANIA UNION SELECT 0 NUMERO , 'T' CICLO, 0 ANO, '0' PERIODO FROM DUAL ) ORDER BY NUMERO) WHERE (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END)  LIKE UPPER(:CICLO || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
