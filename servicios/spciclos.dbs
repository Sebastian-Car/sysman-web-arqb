	<query id="getSpciclosTodosPorPrefacturadoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE SP_CICLO.PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO, SP_CICLO.NUMERO  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY SP_CICLO.NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PREFACTURANDO":"$PREFACTURANDO(type:boolean)","NUMERO":"$NUMERO(type:integer)"}]}}		</result>
