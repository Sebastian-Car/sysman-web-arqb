	<query id="getSpciclosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ANO, NUMERO, PERIODO,(CASE PREFACTURANDO WHEN 0 THEN 'false' ELSE 'true' END) PREFACTURANDO FROM SP_CICLO WHERE COMPANIA = :COMPANIA ORDER BY NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","NUMERO":"$NUMERO(type:integer)","PERIODO":"$PERIODO","PREFACTURANDO":"$PREFACTURANDO(type:boolean)"}]}}		</result>
