	<query id="getSpciclosPagConTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  TO_CHAR(NUMERO) NUMERO, CODIGOINICIAL, CODIGOFINAL, PERIODO  FROM SP_CICLO WHERE COMPANIA = :COMPANIA UNION ALL SELECT 'TODOS' NUMERO, 'TODOS' CODIGOINICIAL, 'TODOS' CODIGOFINAL, 'TODOS' PERIODO FROM DUAL ORDER BY NUMERO) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END)  LIKE UPPER(:CODIGOINICIAL || '%')  AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END)  LIKE UPPER(:CODIGOFINAL || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMERO":"$NUMERO","CODIGOINICIAL":"$CODIGOINICIAL","CODIGOFINAL":"$CODIGOFINAL","PERIODO":"$PERIODO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

