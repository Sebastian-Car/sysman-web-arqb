	<query id="getSpciclosTodosPorNumeroYNombreperiodoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TO_CHAR(SP_CICLO.NUMERO) NUMERO, SP_CICLO.NUMERO NUMEROV, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_CICLO.COMPANIA,SP_CICLO.ANO,SP_CICLO.PERIODO,NULL) NOMPERIODO  FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA UNION SELECT 'Todos' NUMERO, (MAX(NUMERO)+1) NUMEROV, 'Todos' NOMPERIODO FROM SP_CICLO WHERE SP_CICLO.COMPANIA = :COMPANIA ORDER BY NUMEROV</sql>
