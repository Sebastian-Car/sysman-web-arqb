	<query id="getSpciclosNumUnionTOrdenNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT 'T' NUMERO, '0' CODIGOINICIAL, '99999999999999' CODIGOFINAL, 0 NUMEROORD  FROM SP_CICLO WHERE COMPANIA =:COMPANIA UNION ALL SELECT TO_CHAR(SP_CICLO.NUMERO) NUMERO, SP_CICLO.CODIGOINICIAL, SP_CICLO.CODIGOFINAL, SP_CICLO.NUMERO NUMEROORD FROM SP_CICLO WHERE COMPANIA = :COMPANIA ORDER BY NUMEROORD) WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER( '%' || :NUMERO || '%')  AND (CASE WHEN CODIGOINICIAL IS NULL THEN ' ' ELSE UPPER(CODIGOINICIAL) END)  LIKE UPPER( '%' || :CODIGOINICIAL || '%')  AND (CASE WHEN CODIGOFINAL IS NULL THEN ' ' ELSE UPPER(CODIGOFINAL) END)  LIKE UPPER( '%' || :CODIGOFINAL || '%') ))</sql>
