<data name="detreclasificarniif" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertDetreclasificarniif" keyColumns="COMPANIA,ANO,TIPO,NUMERO,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_RECLASIFICAR_NIIF (COMPANIA, ANO, TIPO, NUMERO, CONSECUTIVO, CODIGOANTERIOR, NOMBREANTERIOR, CODIGONUEVO, NOMBRENUEVO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :TIPO, :NUMERO, :CONSECUTIVO, :CODIGOANTERIOR, :NOMBREANTERIOR, :CODIGONUEVO, :NOMBRENUEVO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGOANTERIOR" sqlType="STRING"/>
		<param name="NOMBREANTERIOR" sqlType="STRING"/>
		<param name="CODIGONUEVO" sqlType="STRING"/>
		<param name="NOMBRENUEVO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="detreclasificarniif">
		<call-query href="insertDetreclasificarniif">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGOANTERIOR" query-param="CODIGOANTERIOR"/>
			<with-param name="NOMBREANTERIOR" query-param="NOMBREANTERIOR"/>
			<with-param name="CODIGONUEVO" query-param="CODIGONUEVO"/>
			<with-param name="NOMBRENUEVO" query-param="NOMBRENUEVO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteDetreclasificarniif" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_RECLASIFICAR_NIIF WHERE D_RECLASIFICAR_NIIF.COMPANIA= :KEY_COMPANIA AND D_RECLASIFICAR_NIIF.ANO= :KEY_ANO AND D_RECLASIFICAR_NIIF.TIPO= :KEY_TIPO AND D_RECLASIFICAR_NIIF.NUMERO= :KEY_NUMERO AND D_RECLASIFICAR_NIIF.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="detreclasificarniif">
		<call-query href="deleteDetreclasificarniif">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getDetreclasificarniifPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ANO, TIPO, NUMERO, CONSECUTIVO, CODIGOANTERIOR, NOMBREANTERIOR, CODIGONUEVO, NOMBRENUEVO  FROM D_RECLASIFICAR_NIIF WHERE COMPANIA=:COMPANIA AND ANO=:ANO AND NUMERO=:STRNUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","CONSECUTIVO":"$CONSECUTIVO(type:long)","CODIGOANTERIOR":"$CODIGOANTERIOR","NOMBREANTERIOR":"$NOMBREANTERIOR","CODIGONUEVO":"$CODIGONUEVO","NOMBRENUEVO":"$NOMBRENUEVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="STRNUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="detreclasificarniif">
		<call-query href="getDetreclasificarniifPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="STRNUMERO" query-param="STRNUMERO"/>

		</call-query>
	</resource>
	<query id="updateDetreclasificarniif" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_RECLASIFICAR_NIIF SET TIPO=:TIPO, CONSECUTIVO=:CONSECUTIVO, CODIGOANTERIOR=:CODIGOANTERIOR, NOMBREANTERIOR=:NOMBREANTERIOR, CODIGONUEVO=:CODIGONUEVO, NOMBRENUEVO=:NOMBRENUEVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_RECLASIFICAR_NIIF.COMPANIA= :KEY_COMPANIA AND D_RECLASIFICAR_NIIF.ANO= :KEY_ANO AND D_RECLASIFICAR_NIIF.TIPO= :KEY_TIPO AND D_RECLASIFICAR_NIIF.NUMERO= :KEY_NUMERO AND D_RECLASIFICAR_NIIF.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGOANTERIOR" sqlType="STRING"/>
		<param name="NOMBREANTERIOR" sqlType="STRING"/>
		<param name="CODIGONUEVO" sqlType="STRING"/>
		<param name="NOMBRENUEVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="detreclasificarniif">
		<call-query href="updateDetreclasificarniif">
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGOANTERIOR" query-param="CODIGOANTERIOR"/>
			<with-param name="NOMBREANTERIOR" query-param="NOMBREANTERIOR"/>
			<with-param name="CODIGONUEVO" query-param="CODIGONUEVO"/>
			<with-param name="NOMBRENUEVO" query-param="NOMBRENUEVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>