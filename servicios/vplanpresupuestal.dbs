		</call-query>
	</resource>
	<query id="getVplanpresupuestalNombrePorIdYAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  V_PLAN_PRESUPUESTAL.NOMBRE NOMBRE_RUBRO_CDP  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.ID= :ID AND V_PLAN_PRESUPUESTAL.ANO = :ANO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE_RUBRO_CDP":"$NOMBRE_RUBRO_CDP"}]}}		</result>
		<param name="ID" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/nombreporidyanio">
		<call-query href="getVplanpresupuestalNombrePorIdYAnioQuery">
			<with-param name="ID" query-param="ID"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getVplanpresupuestalPagCodigoschipinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.CODIGOSCHIP, V_PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOSCHIP IS NULL THEN ' ' ELSE UPPER(CODIGOSCHIP) END)  LIKE UPPER(:CODIGOSCHIP || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","CODIGOSCHIP":"$CODIGOSCHIP","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOSCHIP" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
