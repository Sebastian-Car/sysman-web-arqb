	<query id="getVplanpresupuestalNumIdnombrexvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ID, NOMBRE, DESTINO, NVL(AUXILIAR,'99999999999999999999') AUXILIAR, CODIGO  FROM V_PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO = :VIGENCIA AND DESTINO IN ('I') ORDER BY ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
