	</resource>
	<query id="getVplanpresupuestalPagCodigoschipFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.CODIGOSCHIP, V_PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.ID &gt;= :CUENTAINICIAL ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOSCHIP IS NULL THEN ' ' ELSE UPPER(CODIGOSCHIP) END)  LIKE UPPER(:CODIGOSCHIP || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO","CODIGOSCHIP":"$CODIGOSCHIP","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOSCHIP" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/codigoschipfinal/pag">
		<call-query href="getVplanpresupuestalPagCodigoschipFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGOSCHIP" query-param="CODIGOSCHIP"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVplanpresupuestalNumCodigoschipFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.CODIGOSCHIP, V_PLAN_PRESUPUESTAL.NOMBRE  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.ID &gt;= :CUENTAINICIAL ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN CODIGOSCHIP IS NULL THEN ' ' ELSE UPPER(CODIGOSCHIP) END)  LIKE UPPER(:CODIGOSCHIP || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTAINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOSCHIP" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/codigoschipfinal/num">
		<call-query href="getVplanpresupuestalNumCodigoschipFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTAINICIAL" query-param="CUENTAINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGOSCHIP" query-param="CODIGOSCHIP"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getVplanpresupuestalTodosPorCompAnoYIdQuery"  useConfig="sysmandsunist">
		<sql>SELECT ID, CODIGO FROM V_PLAN_PRESUPUESTAL WHERE COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','') ),CONCAT('',CONCAT(TO_CHAR(ANO),'') ),1) &gt; 0 AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CODIGO,' ','') ),CONCAT('',CONCAT(TO_CHAR(ID),'') ),1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/todosporcompanoyid">
		<call-query href="getVplanpresupuestalTodosPorCompAnoYIdQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getVplanpresupuestalTodosPorVigenciasYCodsQuery"  useConfig="sysmandsunist">
		<sql>SELECT V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ANO, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE NOMBREPLAN, V_PLAN_PRESUPUESTAL.APROPIACIONINICIAL, NVL(VALORSOLICITADO_AUX1,0) VALORSOLICITADO_AUX, NVL(TOTAL_DISPONIBLE_PPTAL.TOTALDIS,0) TOTALDIS1 FROM V_PLAN_PRESUPUESTAL LEFT JOIN ( SELECT SALDO_PLAN_PPTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, SUM(SALDO_PLAN_PPTAL.DISPONIBILIDAD) TOTALDIS FROM V_PLAN_PRESUPUESTAL INNER JOIN SALDO_PLAN_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = SALDO_PLAN_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = SALDO_PLAN_PPTAL.ANO AND V_PLAN_PRESUPUESTAL.ID = SALDO_PLAN_PPTAL.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CODIGO,' ','') ),CONCAT('',CONCAT(TO_CHAR(V_PLAN_PRESUPUESTAL.CODIGO ),'') ),1) &gt; 0 AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','') ),CONCAT('',CONCAT(TO_CHAR(SALDO_PLAN_PPTAL.ANO ),'') ),1) &gt; 0 AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN ( 0 ) AND SALDO_PLAN_PPTAL.MES &lt;= EXTRACT(MONTH FROM SYSDATE) GROUP BY SALDO_PLAN_PPTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.MOVIMIENTO ) TOTAL_DISPONIBLE_PPTAL ON V_PLAN_PRESUPUESTAL.COMPANIA = TOTAL_DISPONIBLE_PPTAL.COMPANIA AND V_PLAN_PRESUPUESTAL.ID = TOTAL_DISPONIBLE_PPTAL.ID LEFT JOIN ( SELECT BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL, SUM(BP_D_NOVEDADPROYECTO.VALORSOLICITADO) VALORSOLICITADO_AUX1, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, BP_D_NOVEDADPROYECTO.ANORUBRO FROM BP_D_NOVEDADPROYECTO WHERE BP_D_NOVEDADPROYECTO.COMPANIA =:COMPANIA AND BP_D_NOVEDADPROYECTO.TIPOT = 'SVP' AND BP_D_NOVEDADPROYECTO.CLASET = 'B' AND BP_D_NOVEDADPROYECTO.NOVEDAD =:NUMERO GROUP BY BP_D_NOVEDADPROYECTO.COMPANIA, BP_D_NOVEDADPROYECTO.RUBROPRESUPUESTAL, BP_D_NOVEDADPROYECTO.FUENTERECURSOS, BP_D_NOVEDADPROYECTO.ANORUBRO ) RUBROS_NOVEDAD ON V_PLAN_PRESUPUESTAL.COMPANIA = RUBROS_NOVEDAD.COMPANIA AND V_PLAN_PRESUPUESTAL.ID = RUBROS_NOVEDAD.RUBROPRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA =:COMPANIA AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:VIGENCIA,' ','') ),CONCAT('',CONCAT(TO_CHAR(V_PLAN_PRESUPUESTAL.ANO),'' ) ),1) &gt; 0 AND INSTR(PCK_SYSMAN_UTL.FC_COLOCARCOMILLAS(REPLACE(:CODIGO,' ','') ),CONCAT('',CONCAT(TO_CHAR(V_PLAN_PRESUPUESTAL.CODIGO),'' ) ),1) &gt; 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","ID":"$ID","CODIGO":"$CODIGO","NOMBREPLAN":"$NOMBREPLAN","APROPIACIONINICIAL":"$APROPIACIONINICIAL","VALORSOLICITADO_AUX":"$VALORSOLICITADO_AUX(type:integer)","TOTALDIS1":"$TOTALDIS1(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/todosporvigenciasycods">
		<call-query href="getVplanpresupuestalTodosPorVigenciasYCodsQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
	<query id="getVplanpresupuestalPagIdnombrexvigenciaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ID, NOMBRE, DESTINO, NVL(AUXILIAR,'99999999999999999999') AUXILIAR, CODIGO  FROM V_PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO = :VIGENCIA AND DESTINO IN ('I') ORDER BY ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","DESTINO":"$DESTINO","AUXILIAR":"$AUXILIAR","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
