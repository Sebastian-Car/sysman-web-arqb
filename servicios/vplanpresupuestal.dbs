	<query id="getVplanpresupuestalPagTodosPorDimensionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  'TODOS' AS ID , 'TODOS' AS NOMBRE, 'TODOS' AS VIGENCIA  FROM DUAL UNION SELECT PLAN_PRESUPUESTAL.CODIGO ID , PLAN_PRESUPUESTAL.NOMBRE, TO_CHAR(PLAN_PRESUPUESTAL.ANO) VIGENCIA FROM V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO &gt;= :ANIOFILTRO AND ( DESTINO = 'I' OR DESTINO = 'L' OR DESTINO = 'F') AND PLAN_PRESUPUESTAL.NATURALEZA='D' ORDER BY ID,NOMBRE) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","VIGENCIA":"$VIGENCIA"}]}}		</result>
