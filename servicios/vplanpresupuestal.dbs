	<query id="getVplanpresupuestalConfpptalQuery"  useConfig="sysmandsunist">
		<sql>SELECT  V_PLAN_PRESUPUESTAL.ANO, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.CODIGOSCHIP, V_PLAN_PRESUPUESTAL.RECURSOSCHIP, V_PLAN_PRESUPUESTAL.ORIGENESPECIFICOINGRESOS, V_PLAN_PRESUPUESTAL.DESTINACIONDELOSRECURSOS, V_PLAN_PRESUPUESTAL.DEPENDENCIASCHIP, (CASE WHEN V_PLAN_PRESUPUESTAL.SITUACIONFONDOSSCHIP IN (0) THEN 0 ELSE -1 END) SITUACIONFONDOSSCHIP, (CASE WHEN V_PLAN_PRESUPUESTAL.RECAUDO_VA IN (0) THEN 0 ELSE -1 END) RECAUDO_VA, V_PLAN_PRESUPUESTAL.FINALIDADGASTO, V_PLAN_PRESUPUESTAL.VIGENCIAGASTO, V_PLAN_PRESUPUESTAL.VIGENCIATESORERIASCHIP, V_PLAN_PRESUPUESTAL.CR1_RESGUARDOSCHIP, V_PLAN_PRESUPUESTAL.CODIGOSIRECI, V_PLAN_PRESUPUESTAL.COD_RECIPROCA, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, V_PLAN_PRESUPUESTAL.TERCERO, V_PLAN_PRESUPUESTAL.SUCURSAL, V_PLAN_PRESUPUESTAL.AUXILIAR, V_PLAN_PRESUPUESTAL.REFERENCIA, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.NATURALEZA = :NATURALEZA AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) AND V_PLAN_PRESUPUESTAL.REGALIAS NOT IN ( CASE WHEN :REGALIAS IN ('R') THEN 0 ELSE 1 END) ORDER BY V_PLAN_PRESUPUESTAL.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGOSCHIP":"$CODIGOSCHIP","RECURSOSCHIP":"$RECURSOSCHIP(type:double)","ORIGENESPECIFICOINGRESOS":"$ORIGENESPECIFICOINGRESOS","DESTINACIONDELOSRECURSOS":"$DESTINACIONDELOSRECURSOS","DEPENDENCIASCHIP":"$DEPENDENCIASCHIP","SITUACIONFONDOSSCHIP":"$SITUACIONFONDOSSCHIP(type:integer)","RECAUDO_VA":"$RECAUDO_VA(type:integer)","FINALIDADGASTO":"$FINALIDADGASTO","VIGENCIAGASTO":"$VIGENCIAGASTO(type:double)","VIGENCIATESORERIASCHIP":"$VIGENCIATESORERIASCHIP(type:double)","CR1_RESGUARDOSCHIP":"$CR1_RESGUARDOSCHIP","CODIGOSIRECI":"$CODIGOSIRECI","COD_RECIPROCA":"$COD_RECIPROCA","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/confpptal">
		<call-query href="getVplanpresupuestalConfpptalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="REGALIAS" query-param="REGALIAS"/>

