	</resource>
	<query id="getVplanpresupuestalNumFiltrodelsectorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, V_PLAN_PRESUPUESTAL.REFERENCIA, REFERENCIA.NOMBRE NOMBRE_REFERENCIA, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO, FR.NOMBRE NOMBRE_FUENTE_RECURSOS  FROM V_PLAN_PRESUPUESTAL LEFT JOIN CENTRO_COSTO ON V_PLAN_PRESUPUESTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = CENTRO_COSTO.ANO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN FUENTE_RECURSOS FR ON V_PLAN_PRESUPUESTAL.COMPANIA = FR.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = FR.ANO AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = FR.CODIGO LEFT JOIN REFERENCIA ON V_PLAN_PRESUPUESTAL.COMPANIA = REFERENCIA.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = REFERENCIA.ANO AND V_PLAN_PRESUPUESTAL.REFERENCIA = REFERENCIA.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.DESTINO IN ('I','L') AND TO_NUMBER(INSTR(SUBSTR(ID, 1,LENGTH(:DIMENSION)) ,:DIMENSION,1) )NOT IN 0 AND LENGTH(ID) BETWEEN :RANGOA AND :RANGOB) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END)  LIKE UPPER(:REFERENCIA || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER(:FUENTE_RECURSO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DIMENSION" sqlType="STRING"/>
		<param name="RANGOA" sqlType="STRING"/>
		<param name="RANGOB" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/filtrodelsector/num">
		<call-query href="getVplanpresupuestalNumFiltrodelsectorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="DIMENSION" query-param="DIMENSION"/>
			<with-param name="RANGOA" query-param="RANGOA"/>
			<with-param name="RANGOB" query-param="RANGOB"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>

		</call-query>
	</resource>

</data>