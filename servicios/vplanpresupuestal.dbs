	<query id="getVplanpresupuestalNumTodosPorAnioYDestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, V_PLAN_PRESUPUESTAL.REFERENCIA, REFERENCIA.NOMBRE NOMBRE_REFERENCIA, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO, FR.NOMBRE NOMBRE_FUENTE_RECURSOS, V_PLAN_PRESUPUESTAL.AUXILIAR, AUXILIAR.NOMBRE NOMBRE_AUXILIAR_GENERAL FROM V_PLAN_PRESUPUESTAL LEFT JOIN CENTRO_COSTO ON V_PLAN_PRESUPUESTAL.COMPANIA = CENTRO_COSTO.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = CENTRO_COSTO.ANO AND V_PLAN_PRESUPUESTAL.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN FUENTE_RECURSOS FR ON V_PLAN_PRESUPUESTAL.COMPANIA = FR.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = FR.ANO AND V_PLAN_PRESUPUESTAL.FUENTE_RECURSO = FR.CODIGO LEFT JOIN REFERENCIA ON V_PLAN_PRESUPUESTAL.COMPANIA = REFERENCIA.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = REFERENCIA.ANO AND V_PLAN_PRESUPUESTAL.REFERENCIA = REFERENCIA.CODIGO LEFT JOIN AUXILIAR ON V_PLAN_PRESUPUESTAL.COMPANIA = AUXILIAR.COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = AUXILIAR.ANO AND V_PLAN_PRESUPUESTAL.AUXILIAR = AUXILIAR.CODIGO WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANO AND V_PLAN_PRESUPUESTAL.DESTINO IN ( 'I', 'L' ) AND TO_NUMBER(INSTR(SUBSTR(ID, 1, LENGTH(:DIMENSION)), :DIMENSION, 1)) NOT IN 0) INI WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END) LIKE UPPER(CONCAT(:ID, '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END) LIKE UPPER(CONCAT(:FUENTE_RECURSO, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="DIMENSION" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
