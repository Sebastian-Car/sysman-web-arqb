	<query id="getVplanpresupuestalNumPornaturalezaycodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.ANO, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.CODIGOSCHIP, V_PLAN_PRESUPUESTAL.RECURSOSCHIP, V_PLAN_PRESUPUESTAL.ORIGENESPECIFICOINGRESOS, V_PLAN_PRESUPUESTAL.DESTINACIONDELOSRECURSOS, V_PLAN_PRESUPUESTAL.DEPENDENCIASCHIP, V_PLAN_PRESUPUESTAL.SITUACIONFONDOSSCHIP, V_PLAN_PRESUPUESTAL.RECAUDO_VA, V_PLAN_PRESUPUESTAL.FINALIDADGASTO, V_PLAN_PRESUPUESTAL.VIGENCIAGASTO, V_PLAN_PRESUPUESTAL.VIGENCIATESORERIASCHIP, V_PLAN_PRESUPUESTAL.CR1_RESGUARDOSCHIP, V_PLAN_PRESUPUESTAL.CODIGOSIRECI, V_PLAN_PRESUPUESTAL.COD_RECIPROCA, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, V_PLAN_PRESUPUESTAL.TERCERO, V_PLAN_PRESUPUESTAL.SUCURSAL, V_PLAN_PRESUPUESTAL.AUXILIAR, V_PLAN_PRESUPUESTAL.REFERENCIA, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANIO AND V_PLAN_PRESUPUESTAL.NATURALEZA = :NATURALEZA AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) AND V_PLAN_PRESUPUESTAL.REGALIAS NOT IN ( CASE WHEN :REGALIAS IN ('R') THEN 0 ELSE 1 END) ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGOSCHIP IS NULL THEN ' ' ELSE UPPER(CODIGOSCHIP) END)  LIKE UPPER(:CODIGOSCHIP || '%')  AND (CASE WHEN RECURSOSCHIP IS NULL THEN ' ' ELSE UPPER(RECURSOSCHIP) END)  LIKE UPPER(:RECURSOSCHIP || '%')  AND (CASE WHEN ORIGENESPECIFICOINGRESOS IS NULL THEN ' ' ELSE UPPER(ORIGENESPECIFICOINGRESOS) END)  LIKE UPPER(:ORIGENESPECIFICOINGRESOS || '%')  AND (CASE WHEN DESTINACIONDELOSRECURSOS IS NULL THEN ' ' ELSE UPPER(DESTINACIONDELOSRECURSOS) END)  LIKE UPPER(:DESTINACIONDELOSRECURSOS || '%')  AND (CASE WHEN DEPENDENCIASCHIP IS NULL THEN ' ' ELSE UPPER(DEPENDENCIASCHIP) END)  LIKE UPPER(:DEPENDENCIASCHIP || '%')  AND (CASE WHEN SITUACIONFONDOSSCHIP IS NULL THEN ' ' ELSE UPPER(SITUACIONFONDOSSCHIP) END)  LIKE UPPER(:SITUACIONFONDOSSCHIP || '%')  AND (CASE WHEN RECAUDO_VA IS NULL THEN ' ' ELSE UPPER(RECAUDO_VA) END)  LIKE UPPER(:RECAUDO_VA || '%')  AND (CASE WHEN FINALIDADGASTO IS NULL THEN ' ' ELSE UPPER(FINALIDADGASTO) END)  LIKE UPPER(:FINALIDADGASTO || '%')  AND (CASE WHEN VIGENCIAGASTO IS NULL THEN ' ' ELSE UPPER(VIGENCIAGASTO) END)  LIKE UPPER(:VIGENCIAGASTO || '%')  AND (CASE WHEN VIGENCIATESORERIASCHIP IS NULL THEN ' ' ELSE UPPER(VIGENCIATESORERIASCHIP) END)  LIKE UPPER(:VIGENCIATESORERIASCHIP || '%')  AND (CASE WHEN CR1_RESGUARDOSCHIP IS NULL THEN ' ' ELSE UPPER(CR1_RESGUARDOSCHIP) END)  LIKE UPPER(:CR1_RESGUARDOSCHIP || '%')  AND (CASE WHEN CODIGOSIRECI IS NULL THEN ' ' ELSE UPPER(CODIGOSIRECI) END)  LIKE UPPER(:CODIGOSIRECI || '%')  AND (CASE WHEN COD_RECIPROCA IS NULL THEN ' ' ELSE UPPER(COD_RECIPROCA) END)  LIKE UPPER(:COD_RECIPROCA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
