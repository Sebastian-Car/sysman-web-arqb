	<query id="getVplanpresupuestalConsultarsaldorubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PLAN_PRESUPUESTAL.COMPANIA, PLAN_PRESUPUESTAL.ID CUENTA, PLAN_PRESUPUESTAL.ANO, PLAN_PRESUPUESTAL.NOMBRE, NVL(SUM( CASE WHEN MES = 0 THEN NVL(SALDO_PLAN_PPTAL.APROPIACION_DEBITO,0) - NVL(SALDO_PLAN_PPTAL.APROPIACION_CREDITO,0) END) + SUM(NVL(SALDO_PLAN_PPTAL.ADICION,0) + NVL(SALDO_PLAN_PPTAL.REDUCCION,0) + (NVL(SALDO_PLAN_PPTAL.TRASLADO_DEBITO,0) - NVL(SALDO_PLAN_PPTAL.TRASLADO_CREDITO,0)) + (NVL(SALDO_PLAN_PPTAL.APLAZAM_DEBITO,0) - NVL(SALDO_PLAN_PPTAL.APLAZAM_CREDITO,0))),0) APROPIACIONVIGENTE, SUM(NVL(SALDO_PLAN_PPTAL.DISPONIBILIDAD,0)) DISPONIBILIDADACUM, NVL(SUM( CASE WHEN MES = 0 THEN NVL(SALDO_PLAN_PPTAL.APROPIACION_DEBITO,0) - NVL(SALDO_PLAN_PPTAL.APROPIACION_CREDITO,0) END) + SUM(NVL(SALDO_PLAN_PPTAL.ADICION,0) + NVL(SALDO_PLAN_PPTAL.REDUCCION,0) + (NVL(SALDO_PLAN_PPTAL.TRASLADO_DEBITO,0) - NVL(SALDO_PLAN_PPTAL.TRASLADO_CREDITO,0)) + (NVL(SALDO_PLAN_PPTAL.APLAZAM_DEBITO,0) - NVL(SALDO_PLAN_PPTAL.APLAZAM_CREDITO,0))) - SUM(NVL(SALDO_PLAN_PPTAL.DISPONIBILIDAD,0)),0) SALDO  FROM V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL INNER JOIN V_SALDO_PLAN_PPTAL SALDO_PLAN_PPTAL ON PLAN_PRESUPUESTAL.COMPANIA = SALDO_PLAN_PPTAL.COMPANIA AND PLAN_PRESUPUESTAL.ANO = SALDO_PLAN_PPTAL.ANO AND PLAN_PRESUPUESTAL.ID = SALDO_PLAN_PPTAL.ID WHERE SALDO_PLAN_PPTAL.COMPANIA = :COMPANIA AND SALDO_PLAN_PPTAL.ID = :ID AND SALDO_PLAN_PPTAL.ANO = :ANO AND SALDO_PLAN_PPTAL.MES BETWEEN 0 AND :MESFINAL AND PLAN_PRESUPUESTAL.NATURALEZA IN('D') GROUP BY PLAN_PRESUPUESTAL.COMPANIA, PLAN_PRESUPUESTAL.ID, PLAN_PRESUPUESTAL.ANO, PLAN_PRESUPUESTAL.NOMBRE, SALDO_PLAN_PPTAL.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CUENTA":"$CUENTA","ANO":"$ANO(type:integer)","NOMBRE":"$NOMBRE","APROPIACIONVIGENTE":"$APROPIACIONVIGENTE(type:integer)","DISPONIBILIDADACUM":"$DISPONIBILIDADACUM(type:integer)","SALDO":"$SALDO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MESFINAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/consultarsaldorubro">
		<call-query href="getVplanpresupuestalConsultarsaldorubroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MESFINAL" query-param="MESFINAL"/>

		</call-query>
	</resource>
	<query id="getVplanpresupuestalPagPornaturalezaycodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_PLAN_PRESUPUESTAL.COMPANIA, V_PLAN_PRESUPUESTAL.ID, V_PLAN_PRESUPUESTAL.ANO, V_PLAN_PRESUPUESTAL.CODIGO, V_PLAN_PRESUPUESTAL.NOMBRE, V_PLAN_PRESUPUESTAL.CODIGOSCHIP, V_PLAN_PRESUPUESTAL.RECURSOSCHIP, V_PLAN_PRESUPUESTAL.ORIGENESPECIFICOINGRESOS, V_PLAN_PRESUPUESTAL.DESTINACIONDELOSRECURSOS, V_PLAN_PRESUPUESTAL.DEPENDENCIASCHIP, V_PLAN_PRESUPUESTAL.SITUACIONFONDOSSCHIP, V_PLAN_PRESUPUESTAL.RECAUDO_VA, V_PLAN_PRESUPUESTAL.FINALIDADGASTO, V_PLAN_PRESUPUESTAL.VIGENCIAGASTO, V_PLAN_PRESUPUESTAL.VIGENCIATESORERIASCHIP, V_PLAN_PRESUPUESTAL.CR1_RESGUARDOSCHIP, V_PLAN_PRESUPUESTAL.CODIGOSIRECI, V_PLAN_PRESUPUESTAL.COD_RECIPROCA, V_PLAN_PRESUPUESTAL.CENTRO_COSTO, V_PLAN_PRESUPUESTAL.TERCERO, V_PLAN_PRESUPUESTAL.SUCURSAL, V_PLAN_PRESUPUESTAL.AUXILIAR, V_PLAN_PRESUPUESTAL.REFERENCIA, V_PLAN_PRESUPUESTAL.FUENTE_RECURSO  FROM V_PLAN_PRESUPUESTAL WHERE V_PLAN_PRESUPUESTAL.COMPANIA = :COMPANIA AND V_PLAN_PRESUPUESTAL.ANO = :ANIO AND V_PLAN_PRESUPUESTAL.NATURALEZA = :NATURALEZA AND V_PLAN_PRESUPUESTAL.MOVIMIENTO NOT IN (0) AND V_PLAN_PRESUPUESTAL.REGALIAS NOT IN ( CASE WHEN :REGALIAS IN ('R') THEN 0 ELSE 1 END) ORDER BY V_PLAN_PRESUPUESTAL.ID) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGOSCHIP IS NULL THEN ' ' ELSE UPPER(CODIGOSCHIP) END)  LIKE UPPER(:CODIGOSCHIP || '%')  AND (CASE WHEN RECURSOSCHIP IS NULL THEN ' ' ELSE UPPER(RECURSOSCHIP) END)  LIKE UPPER(:RECURSOSCHIP || '%')  AND (CASE WHEN ORIGENESPECIFICOINGRESOS IS NULL THEN ' ' ELSE UPPER(ORIGENESPECIFICOINGRESOS) END)  LIKE UPPER(:ORIGENESPECIFICOINGRESOS || '%')  AND (CASE WHEN DESTINACIONDELOSRECURSOS IS NULL THEN ' ' ELSE UPPER(DESTINACIONDELOSRECURSOS) END)  LIKE UPPER(:DESTINACIONDELOSRECURSOS || '%')  AND (CASE WHEN DEPENDENCIASCHIP IS NULL THEN ' ' ELSE UPPER(DEPENDENCIASCHIP) END)  LIKE UPPER(:DEPENDENCIASCHIP || '%')  AND (CASE WHEN SITUACIONFONDOSSCHIP IS NULL THEN ' ' ELSE UPPER(SITUACIONFONDOSSCHIP) END)  LIKE UPPER(:SITUACIONFONDOSSCHIP || '%')  AND (CASE WHEN RECAUDO_VA IS NULL THEN ' ' ELSE UPPER(RECAUDO_VA) END)  LIKE UPPER(:RECAUDO_VA || '%')  AND (CASE WHEN FINALIDADGASTO IS NULL THEN ' ' ELSE UPPER(FINALIDADGASTO) END)  LIKE UPPER(:FINALIDADGASTO || '%')  AND (CASE WHEN VIGENCIAGASTO IS NULL THEN ' ' ELSE UPPER(VIGENCIAGASTO) END)  LIKE UPPER(:VIGENCIAGASTO || '%')  AND (CASE WHEN VIGENCIATESORERIASCHIP IS NULL THEN ' ' ELSE UPPER(VIGENCIATESORERIASCHIP) END)  LIKE UPPER(:VIGENCIATESORERIASCHIP || '%')  AND (CASE WHEN CR1_RESGUARDOSCHIP IS NULL THEN ' ' ELSE UPPER(CR1_RESGUARDOSCHIP) END)  LIKE UPPER(:CR1_RESGUARDOSCHIP || '%')  AND (CASE WHEN CODIGOSIRECI IS NULL THEN ' ' ELSE UPPER(CODIGOSIRECI) END)  LIKE UPPER(:CODIGOSIRECI || '%')  AND (CASE WHEN COD_RECIPROCA IS NULL THEN ' ' ELSE UPPER(COD_RECIPROCA) END)  LIKE UPPER(:COD_RECIPROCA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID":"$ID","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CODIGOSCHIP":"$CODIGOSCHIP","RECURSOSCHIP":"$RECURSOSCHIP(type:double)","ORIGENESPECIFICOINGRESOS":"$ORIGENESPECIFICOINGRESOS","DESTINACIONDELOSRECURSOS":"$DESTINACIONDELOSRECURSOS","DEPENDENCIASCHIP":"$DEPENDENCIASCHIP","SITUACIONFONDOSSCHIP":"$SITUACIONFONDOSSCHIP(type:boolean)","RECAUDO_VA":"$RECAUDO_VA(type:boolean)","FINALIDADGASTO":"$FINALIDADGASTO","VIGENCIAGASTO":"$VIGENCIAGASTO(type:double)","VIGENCIATESORERIASCHIP":"$VIGENCIATESORERIASCHIP(type:double)","CR1_RESGUARDOSCHIP":"$CR1_RESGUARDOSCHIP","CODIGOSIRECI":"$CODIGOSIRECI","COD_RECIPROCA":"$COD_RECIPROCA","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="REGALIAS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOSCHIP" sqlType="STRING"/>
		<param name="RECURSOSCHIP" sqlType="STRING"/>
		<param name="ORIGENESPECIFICOINGRESOS" sqlType="STRING"/>
		<param name="DESTINACIONDELOSRECURSOS" sqlType="STRING"/>
		<param name="DEPENDENCIASCHIP" sqlType="STRING"/>
		<param name="SITUACIONFONDOSSCHIP" sqlType="STRING"/>
		<param name="RECAUDO_VA" sqlType="STRING"/>
		<param name="FINALIDADGASTO" sqlType="STRING"/>
		<param name="VIGENCIAGASTO" sqlType="STRING"/>
		<param name="VIGENCIATESORERIASCHIP" sqlType="STRING"/>
		<param name="CR1_RESGUARDOSCHIP" sqlType="STRING"/>
		<param name="CODIGOSIRECI" sqlType="STRING"/>
		<param name="COD_RECIPROCA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
