	<query id="getVplanpresupuestalPagRubrosSubnovedadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.NOMBRE, V_RESUMENPPTO_BASE.FUENTE_RECURSO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD + V_RESUMENPPTO_BASE.REINTEGRO) SALDO, SUM(V_RESUMENPPTO_BASE.REINTEGRO) REINTEGRO, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD - V_RESUMENPPTO_BASE.COMPROMISOSACUM) SALDODIS, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) TOTALDIS  FROM V_RESUMENPPTO_BASE INNER JOIN BP_PROYECTOSRUBROS ON V_RESUMENPPTO_BASE.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND V_RESUMENPPTO_BASE.ID = BP_PROYECTOSRUBROS.RUBROPPTALES LEFT JOIN FUENTE_RECURSOS ON V_RESUMENPPTO_BASE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = FUENTE_RECURSOS.ANO WHERE V_RESUMENPPTO_BASE.COMPANIA = :COMPANIA AND V_RESUMENPPTO_BASE.ANO = :VIGENCIA AND V_RESUMENPPTO_BASE.DESTINO IN ('I','L') AND V_RESUMENPPTO_BASE.NATURALEZA IN('D') AND V_RESUMENPPTO_BASE.MES &lt;= TO_CHAR(SYSDATE, 'MM') AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO= :FUENTE GROUP BY V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.NOMBRE, V_RESUMENPPTO_BASE.FUENTE_RECURSO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER(:FUENTE_RECURSO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER( '%' || :SALDO || '%')  AND (CASE WHEN REINTEGRO IS NULL THEN ' ' ELSE UPPER(REINTEGRO) END)  LIKE UPPER( '%' || :REINTEGRO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","FUENTE_RECURSO":"$FUENTE_RECURSO","SALDO":"$SALDO","REINTEGRO":"$REINTEGRO","SALDODIS":"$SALDODIS","TOTALDIS":"$TOTALDIS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="REINTEGRO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vplanpresupuestal/rubrossubnovedades/pag">
		<call-query href="getVplanpresupuestalPagRubrosSubnovedadesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="FUENTE_RECURSO" query-param="FUENTE_RECURSO"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="REINTEGRO" query-param="REINTEGRO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVplanpresupuestalNumRubrosSubnovedadesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.NOMBRE, V_RESUMENPPTO_BASE.FUENTE_RECURSO, SUM(V_RESUMENPPTO_BASE.APROPIACIONVIGENTE - V_RESUMENPPTO_BASE.DISPONIBILIDAD + V_RESUMENPPTO_BASE.REINTEGRO) SALDO, SUM(V_RESUMENPPTO_BASE.REINTEGRO) REINTEGRO, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD - V_RESUMENPPTO_BASE.COMPROMISOSACUM) SALDODIS, SUM(V_RESUMENPPTO_BASE.DISPONIBILIDAD) TOTALDIS  FROM V_RESUMENPPTO_BASE INNER JOIN BP_PROYECTOSRUBROS ON V_RESUMENPPTO_BASE.COMPANIA = BP_PROYECTOSRUBROS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = BP_PROYECTOSRUBROS.VIGENCIA AND V_RESUMENPPTO_BASE.ID = BP_PROYECTOSRUBROS.RUBROPPTALES LEFT JOIN FUENTE_RECURSOS ON V_RESUMENPPTO_BASE.COMPANIA = FUENTE_RECURSOS.COMPANIA AND V_RESUMENPPTO_BASE.ANO = FUENTE_RECURSOS.ANO WHERE V_RESUMENPPTO_BASE.COMPANIA = :COMPANIA AND V_RESUMENPPTO_BASE.ANO = :VIGENCIA AND V_RESUMENPPTO_BASE.DESTINO IN ('I','L') AND V_RESUMENPPTO_BASE.NATURALEZA IN('D') AND V_RESUMENPPTO_BASE.MES &lt;= TO_CHAR(SYSDATE, 'MM') AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO= :FUENTE GROUP BY V_RESUMENPPTO_BASE.ID, V_RESUMENPPTO_BASE.NOMBRE, V_RESUMENPPTO_BASE.FUENTE_RECURSO) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN FUENTE_RECURSO IS NULL THEN ' ' ELSE UPPER(FUENTE_RECURSO) END)  LIKE UPPER(:FUENTE_RECURSO || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER( '%' || :SALDO || '%')  AND (CASE WHEN REINTEGRO IS NULL THEN ' ' ELSE UPPER(REINTEGRO) END)  LIKE UPPER( '%' || :REINTEGRO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FUENTE_RECURSO" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="REINTEGRO" sqlType="STRING"/>

	</query>
