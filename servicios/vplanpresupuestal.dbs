	<query id="getVplanpresupuestalNumTodoPorSectorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  'TODOS' AS ID , 'TODOS' AS NOMBRE, 'TODOS' AS VIGENCIA  FROM DUAL UNION SELECT PLAN_PRESUPUESTAL.ID ID, PLAN_PRESUPUESTAL.NOMBRE, TO_CHAR(PLAN_PRESUPUESTAL.ANO) VIGENCIA FROM V_PLAN_PRESUPUESTAL PLAN_PRESUPUESTAL WHERE COMPANIA = :COMPANIA AND ANO &gt;= :ANIOFILTRO AND ID &lt;&gt; :DIMENSION AND INSTR(SUBSTR(ID,1,LENGTH(:DIMENSION)),:DIMENSION)&lt;&gt;0 ORDER BY ID,NOMBRE) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END)  LIKE UPPER(:VIGENCIA || '%') ))</sql>
