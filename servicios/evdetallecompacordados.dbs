<data name="evdetallecompacordados" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getEvdetallecompacordadosTotalPesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(EV_DETALLE_COMPACORDADOS.PESO_PORCENTUAL) PESO  FROM EV_DETALLE_COMPACORDADOS WHERE EV_DETALLE_COMPACORDADOS.COMPANIA =:COMPANIA AND EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION =:TIPO_EVALUACION AND EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION =:CLASE_EVALUACION AND EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO =:CEDULA_EVALUADO AND EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO =:SUCURSAL_EVALUADO AND EV_DETALLE_COMPACORDADOS.ANO =:ANO AND EV_DETALLE_COMPACORDADOS.PERIODO =:PERIODO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PESO":"$PESO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evdetallecompacordados/totalpeso">
		<call-query href="getEvdetallecompacordadosTotalPesoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="deleteEvdetallecompacordados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_DETALLE_COMPACORDADOS WHERE EV_DETALLE_COMPACORDADOS.COMPANIA= :KEY_COMPANIA AND EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_DETALLE_COMPACORDADOS.ANO= :KEY_ANO AND EV_DETALLE_COMPACORDADOS.PERIODO= :KEY_PERIODO AND EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND EV_DETALLE_COMPACORDADOS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="INTEGER"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_PERIODO" sqlType="INTEGER"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="evdetallecompacordados">
		<call-query href="deleteEvdetallecompacordados">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEvdetallecompacordadosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_DETALLE_COMPACORDADOS.COMPANIA, EV_DETALLE_COMPACORDADOS.ANO, EV_DETALLE_COMPACORDADOS.PERIODO, EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO, EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO, EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADOR, EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADOR, EV_DETALLE_COMPACORDADOS.NUMERO_EVALUACION, EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION, EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION, EV_DETALLE_COMPACORDADOS.CONSECUTIVO, EV_META_DEPENDENCIAS.META, TO_CHAR(EV_COMPROMISOS_LABORALES.COMPROMISO) COMPROMISO, EV_DETALLE_COMPACORDADOS.PESO_PORCENTUAL, EV_DETALLE_COMPACORDADOS.CALIFICACION  FROM EV_DETALLE_COMPACORDADOS INNER JOIN EV_COMPROMISOS_LABORALES ON EV_DETALLE_COMPACORDADOS.COMPANIA = EV_COMPROMISOS_LABORALES.COMPANIA AND EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION = EV_COMPROMISOS_LABORALES.CLASE_EVALUACION AND EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION = EV_COMPROMISOS_LABORALES.TIPO_EVALUACION AND EV_DETALLE_COMPACORDADOS.ANO = EV_COMPROMISOS_LABORALES.ANO AND EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO = EV_COMPROMISOS_LABORALES.CEDULA_EVALUADO AND EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO = EV_COMPROMISOS_LABORALES.SUCURSAL_EVALUADO AND EV_DETALLE_COMPACORDADOS.CONSECUTIVO = EV_COMPROMISOS_LABORALES.CONSECUTIVO INNER JOIN EV_META_DEPENDENCIAS ON EV_COMPROMISOS_LABORALES.COMPANIA = EV_META_DEPENDENCIAS.COMPANIA AND EV_COMPROMISOS_LABORALES.DEPENDENCIA = EV_META_DEPENDENCIAS.DEPENDENCIA AND EV_COMPROMISOS_LABORALES.CODIGO_META = EV_META_DEPENDENCIAS.CODIGO_META WHERE EV_DETALLE_COMPACORDADOS.COMPANIA = :COMPANIA AND EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION = :CLASE_EVALUACION AND EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION = :TIPO_EVALUACION AND EV_DETALLE_COMPACORDADOS.ANO = :ANO AND EV_DETALLE_COMPACORDADOS.PERIODO = :PERIODO AND EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO = :SUCURSAL_EVALUADO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN META IS NULL THEN ' ' ELSE UPPER(META) END)  LIKE UPPER( '%' || :META || '%')  AND (CASE WHEN COMPROMISO IS NULL THEN ' ' ELSE UPPER(COMPROMISO) END)  LIKE UPPER( '%' || :COMPROMISO || '%')  AND (CASE WHEN PESO_PORCENTUAL IS NULL THEN ' ' ELSE UPPER(PESO_PORCENTUAL) END)  LIKE UPPER(:PESO_PORCENTUAL || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO(type:integer)","CEDULA_EVALUADO":"$CEDULA_EVALUADO","SUCURSAL_EVALUADO":"$SUCURSAL_EVALUADO","CEDULA_EVALUADOR":"$CEDULA_EVALUADOR","SUCURSAL_EVALUADOR":"$SUCURSAL_EVALUADOR","NUMERO_EVALUACION":"$NUMERO_EVALUACION(type:long)","TIPO_EVALUACION":"$TIPO_EVALUACION","CLASE_EVALUACION":"$CLASE_EVALUACION(type:integer)","CONSECUTIVO":"$CONSECUTIVO(type:long)","META":"$META","COMPROMISO":"$COMPROMISO","PESO_PORCENTUAL":"$PESO_PORCENTUAL","CALIFICACION":"$CALIFICACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="META" sqlType="STRING"/>
		<param name="COMPROMISO" sqlType="STRING"/>
		<param name="PESO_PORCENTUAL" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evdetallecompacordados">
		<call-query href="getEvdetallecompacordadosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="META" query-param="META"/>
			<with-param name="COMPROMISO" query-param="COMPROMISO"/>
			<with-param name="PESO_PORCENTUAL" query-param="PESO_PORCENTUAL"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvdetallecompacordadosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_DETALLE_COMPACORDADOS.COMPANIA, EV_DETALLE_COMPACORDADOS.ANO, EV_DETALLE_COMPACORDADOS.PERIODO, EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO, EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO, EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADOR, EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADOR, EV_DETALLE_COMPACORDADOS.NUMERO_EVALUACION, EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION, EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION, EV_DETALLE_COMPACORDADOS.CONSECUTIVO, EV_META_DEPENDENCIAS.META, TO_CHAR(EV_COMPROMISOS_LABORALES.COMPROMISO) COMPROMISO, EV_DETALLE_COMPACORDADOS.PESO_PORCENTUAL, EV_DETALLE_COMPACORDADOS.CALIFICACION  FROM EV_DETALLE_COMPACORDADOS INNER JOIN EV_COMPROMISOS_LABORALES ON EV_DETALLE_COMPACORDADOS.COMPANIA = EV_COMPROMISOS_LABORALES.COMPANIA AND EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION = EV_COMPROMISOS_LABORALES.CLASE_EVALUACION AND EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION = EV_COMPROMISOS_LABORALES.TIPO_EVALUACION AND EV_DETALLE_COMPACORDADOS.ANO = EV_COMPROMISOS_LABORALES.ANO AND EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO = EV_COMPROMISOS_LABORALES.CEDULA_EVALUADO AND EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO = EV_COMPROMISOS_LABORALES.SUCURSAL_EVALUADO AND EV_DETALLE_COMPACORDADOS.CONSECUTIVO = EV_COMPROMISOS_LABORALES.CONSECUTIVO INNER JOIN EV_META_DEPENDENCIAS ON EV_COMPROMISOS_LABORALES.COMPANIA = EV_META_DEPENDENCIAS.COMPANIA AND EV_COMPROMISOS_LABORALES.DEPENDENCIA = EV_META_DEPENDENCIAS.DEPENDENCIA AND EV_COMPROMISOS_LABORALES.CODIGO_META = EV_META_DEPENDENCIAS.CODIGO_META WHERE EV_DETALLE_COMPACORDADOS.COMPANIA = :COMPANIA AND EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION = :CLASE_EVALUACION AND EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION = :TIPO_EVALUACION AND EV_DETALLE_COMPACORDADOS.ANO = :ANO AND EV_DETALLE_COMPACORDADOS.PERIODO = :PERIODO AND EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO = :CEDULA_EVALUADO AND EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO = :SUCURSAL_EVALUADO) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN META IS NULL THEN ' ' ELSE UPPER(META) END)  LIKE UPPER( '%' || :META || '%')  AND (CASE WHEN COMPROMISO IS NULL THEN ' ' ELSE UPPER(COMPROMISO) END)  LIKE UPPER( '%' || :COMPROMISO || '%')  AND (CASE WHEN PESO_PORCENTUAL IS NULL THEN ' ' ELSE UPPER(PESO_PORCENTUAL) END)  LIKE UPPER(:PESO_PORCENTUAL || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASE_EVALUACION" sqlType="STRING"/>
		<param name="TIPO_EVALUACION" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="META" sqlType="STRING"/>
		<param name="COMPROMISO" sqlType="STRING"/>
		<param name="PESO_PORCENTUAL" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evdetallecompacordados/numero">
		<call-query href="getEvdetallecompacordadosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASE_EVALUACION" query-param="CLASE_EVALUACION"/>
			<with-param name="TIPO_EVALUACION" query-param="TIPO_EVALUACION"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CEDULA_EVALUADO" query-param="CEDULA_EVALUADO"/>
			<with-param name="SUCURSAL_EVALUADO" query-param="SUCURSAL_EVALUADO"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="META" query-param="META"/>
			<with-param name="COMPROMISO" query-param="COMPROMISO"/>
			<with-param name="PESO_PORCENTUAL" query-param="PESO_PORCENTUAL"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>

		</call-query>
	</resource>
	<query id="updateEvdetallecompacordados" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_DETALLE_COMPACORDADOS SET CALIFICACION=:CALIFICACION, PESO_PORCENTUAL=:PESO_PORCENTUAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_DETALLE_COMPACORDADOS.COMPANIA= :KEY_COMPANIA AND EV_DETALLE_COMPACORDADOS.CLASE_EVALUACION= :KEY_CLASE_EVALUACION AND EV_DETALLE_COMPACORDADOS.TIPO_EVALUACION= :KEY_TIPO_EVALUACION AND EV_DETALLE_COMPACORDADOS.ANO= :KEY_ANO AND EV_DETALLE_COMPACORDADOS.PERIODO= :KEY_PERIODO AND EV_DETALLE_COMPACORDADOS.CEDULA_EVALUADO= :KEY_CEDULA_EVALUADO AND EV_DETALLE_COMPACORDADOS.SUCURSAL_EVALUADO= :KEY_SUCURSAL_EVALUADO AND EV_DETALLE_COMPACORDADOS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="PESO_PORCENTUAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASE_EVALUACION" sqlType="STRING"/>
		<param name="KEY_TIPO_EVALUACION" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_PERIODO" sqlType="STRING"/>
		<param name="KEY_CEDULA_EVALUADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EVALUADO" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evdetallecompacordados">
		<call-query href="updateEvdetallecompacordados">
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="PESO_PORCENTUAL" query-param="PESO_PORCENTUAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASE_EVALUACION" query-param="KEY_CLASE_EVALUACION"/>
			<with-param name="KEY_TIPO_EVALUACION" query-param="KEY_TIPO_EVALUACION"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_PERIODO" query-param="KEY_PERIODO"/>
			<with-param name="KEY_CEDULA_EVALUADO" query-param="KEY_CEDULA_EVALUADO"/>
			<with-param name="KEY_SUCURSAL_EVALUADO" query-param="KEY_SUCURSAL_EVALUADO"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>