	<query id="updatePlanescontablesConfigurarFlujoEfectivo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET ANO=:ANO, NOMBRE=:NOMBRE, MOVIMIENTO=:MOVIMIENTO, MAN_AUX_FUE=:MAN_AUX_FUE, MAN_AUX_GEN=:MAN_AUX_GEN, MAN_AUX_REF=:MAN_AUX_REF, MAN_AUX_TER=:MAN_AUX_TER, MAN_CEN_CTO=:MAN_CEN_CTO, MOSTRAR_EN_FLUJO=:MOSTRAR_EN_FLUJO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_CONTABLE.COMPANIA= :KEY_COMPANIA AND PLAN_CONTABLE.ANO= :KEY_ANO AND PLAN_CONTABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>
		<param name="MAN_AUX_TER" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MOSTRAR_EN_FLUJO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planescontables/configurarflujoefectivo">
		<call-query href="updatePlanescontablesConfigurarFlujoEfectivo">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="MAN_AUX_FUE" query-param="MAN_AUX_FUE"/>
			<with-param name="MAN_AUX_GEN" query-param="MAN_AUX_GEN"/>
			<with-param name="MAN_AUX_REF" query-param="MAN_AUX_REF"/>
			<with-param name="MAN_AUX_TER" query-param="MAN_AUX_TER"/>
