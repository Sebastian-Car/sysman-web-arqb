		</call-query>
	</resource>
	<query id="getPlanescontablesNumConfiguracionContraprestacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE, CLASECUENTA,(CASE CORRIENTE WHEN 0 THEN 'false' ELSE 'true' END) CORRIENTE,(CASE CONTRAPRESTACION WHEN 0 THEN 'false' ELSE 'true' END) CONTRAPRESTACION, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(COMPANIA,'DIGITOS PARA CONFIGURACION DE INFORMES',1,SYSDATE) = LENGTH(CODIGO) THEN 'false' ELSE 'true' END BLOQUEA_PARAMETRO FROM PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND CODIGO LIKE ( '4%' ) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(:CLASECUENTA, '%')) AND (CASE WHEN CORRIENTE IS NULL THEN ' ' ELSE UPPER(CORRIENTE) END) LIKE UPPER(CONCAT(:CORRIENTE, '%')) AND (CASE WHEN CONTRAPRESTACION IS NULL THEN ' ' ELSE UPPER(CONTRAPRESTACION) END) LIKE UPPER(CONCAT(:CONTRAPRESTACION, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
