	<query id="getPlanescontablesPagTodosPorClaseiInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE  FROM PLAN_CONTABLE PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND ((PLAN_CONTABLE.MAN_AUX_TER+PLAN_CONTABLE.MAN_AUX_GEN+PLAN_CONTABLE.MAN_CEN_CTO+PLAN_CONTABLE.MOVIMIENTO+PLAN_CONTABLE.MAN_AUX_REF + PLAN_CONTABLE.MAN_AUX_FUE) NOT IN (0)) AND CLASECUENTA='I' ORDER BY PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
