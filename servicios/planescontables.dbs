			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="updatePlanescontablesIndicadoresExogenas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET EXDISTRITAL = :EXDISTRITAL , RETEPRACTICADA = :RETEPRACTICADA , RETEASUMIDA = :RETEASUMIDA , IVACOMUN = :IVACOMUN ,IVASIMPLIFICADO =:IVASIMPLIFICADO , RETEICA = :RETEICA ,MOSTRARF1001 = :MOSTRARF1001 ,IND_AGENTE_RETENCION = :IND_AGENTE_RETENCION,IND_SUJETO_RETENCION = :IND_SUJETO_RETENCION ,DATE_MODIFIED =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CUENTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="EXDISTRITAL" sqlType="STRING"/>
		<param name="RETEPRACTICADA" sqlType="STRING"/>
		<param name="RETEASUMIDA" sqlType="STRING"/>
		<param name="IVACOMUN" sqlType="STRING"/>
		<param name="IVASIMPLIFICADO" sqlType="STRING"/>
		<param name="RETEICA" sqlType="STRING"/>
		<param name="MOSTRARF1001" sqlType="STRING"/>
		<param name="IND_AGENTE_RETENCION" sqlType="STRING"/>
		<param name="IND_SUJETO_RETENCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planescontables/indicadoresexogenas">
		<call-query href="updatePlanescontablesIndicadoresExogenas">
			<with-param name="EXDISTRITAL" query-param="EXDISTRITAL"/>
			<with-param name="RETEPRACTICADA" query-param="RETEPRACTICADA"/>
			<with-param name="RETEASUMIDA" query-param="RETEASUMIDA"/>
