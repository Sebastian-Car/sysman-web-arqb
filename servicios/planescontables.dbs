	<query id="deletePlanescontables" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA= :KEY_COMPANIA AND PLAN_CONTABLE.ANO= :KEY_ANO AND PLAN_CONTABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="planescontables">
		<call-query href="deletePlanescontables">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN 'DEBITO' ELSE 'CREDITO' END NATURALEZA ,CASE BLOQUEACUENTA WHEN 'NO' THEN 'false' ELSE 'true' END  BLOQUEACUENTA, CLASECUENTA.DESCRIPCION CLASECUENTA FROM PLAN_CONTABLE INNER JOIN CLASECUENTA ON PLAN_CONTABLE.CLASECUENTA=CLASECUENTA.CODIGO WHERE COMPANIA = :COMPANIA AND ANO = :ANIOF ORDER BY PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) AND (CASE WHEN BLOQUEACUENTA IS NULL THEN ' ' ELSE UPPER(BLOQUEACUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:BLOQUEACUENTA), '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASECUENTA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","BLOQUEACUENTA":"$BLOQUEACUENTA(type:boolean)","CLASECUENTA":"$CLASECUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIOF" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="BLOQUEACUENTA" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables">
		<call-query href="getPlanescontablesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIOF" query-param="ANIOF"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="BLOQUEACUENTA" query-param="BLOQUEACUENTA"/>
			<with-param name="CLASECUENTA" query-param="CLASECUENTA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN 'DEBITO' ELSE 'CREDITO' END NATURALEZA ,CASE BLOQUEACUENTA WHEN 'NO' THEN 'false' ELSE 'true' END  BLOQUEACUENTA, CLASECUENTA.DESCRIPCION CLASECUENTA FROM PLAN_CONTABLE INNER JOIN CLASECUENTA ON PLAN_CONTABLE.CLASECUENTA=CLASECUENTA.CODIGO WHERE COMPANIA = :COMPANIA AND ANO = :ANIOF ORDER BY PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) AND (CASE WHEN BLOQUEACUENTA IS NULL THEN ' ' ELSE UPPER(BLOQUEACUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:BLOQUEACUENTA), '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASECUENTA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIOF" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="BLOQUEACUENTA" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/numero">
		<call-query href="getPlanescontablesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIOF" query-param="ANIOF"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="BLOQUEACUENTA" query-param="BLOQUEACUENTA"/>
			<with-param name="CLASECUENTA" query-param="CLASECUENTA"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.NATURALEZA,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE PLAN_CONTABLE.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE PLAN_CONTABLE.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_CONTABLE.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE PLAN_CONTABLE.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE PLAN_CONTABLE.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE PLAN_CONTABLE.OBLIGA_TERCERO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_TERCERO,(CASE PLAN_CONTABLE.OBLIGA_CENTRO WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_CENTRO,(CASE PLAN_CONTABLE.OBLIGA_AUXILIAR WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_AUXILIAR,(CASE PLAN_CONTABLE.OBLIGA_REFERENCIA WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_REFERENCIA,(CASE PLAN_CONTABLE.OBLIGA_FUENTE WHEN 0 THEN 'false' ELSE 'true' END) OBLIGA_FUENTE, PLAN_CONTABLE.DINAMICA,(CASE PLAN_CONTABLE.CORRIENTE WHEN 0 THEN 'false' ELSE 'true' END) CORRIENTE, PLAN_CONTABLE.FORMATO, PLAN_CONTABLE.CLASECUENTA, PLAN_CONTABLE.BLOQUEACUENTA,(CASE PLAN_CONTABLE.PERMITECONSOLIDAR WHEN 0 THEN 'false' ELSE 'true' END) PERMITECONSOLIDAR,(CASE PLAN_CONTABLE.GENERADESEMBOLSO WHEN 0 THEN 'false' ELSE 'true' END) GENERADESEMBOLSO, PLAN_CONTABLE.CHEQUE, PLAN_CONTABLE.PORCRETENCION,(CASE PLAN_CONTABLE.CREDITOEXTERNO WHEN 0 THEN 'false' ELSE 'true' END) CREDITOEXTERNO,(CASE PLAN_CONTABLE.PASARSALDO WHEN 0 THEN 'false' ELSE 'true' END) PASARSALDO, PLAN_CONTABLE.COD_EQUIV, PLAN_CONTABLE.FORMATOEGRESO, PLAN_CONTABLE.BANCO,(CASE PLAN_CONTABLE.MAN_FACT_ARRENDAMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_FACT_ARRENDAMIENTO, PLAN_CONTABLE.EQUIVPR_DEBITO, PLAN_CONTABLE.EQUIVPR_CREDITO, PLAN_CONTABLE.CONCEPTOEX,(CASE PLAN_CONTABLE.MAN_DISTRI_CCOSTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_DISTRI_CCOSTO, PLAN_CONTABLE.CCBALANCE, PLAN_CONTABLE.COD_FLUJOCAJA,(CASE PLAN_CONTABLE.MEN WHEN 0 THEN 'false' ELSE 'true' END) MEN,(CASE PLAN_CONTABLE.APLICA_DETERIORO WHEN 0 THEN 'false' ELSE 'true' END) APLICA_DETERIORO, PLAN_CONTABLE.DEB_CAUS_DET, PLAN_CONTABLE.CRE_CAUS_DET, PLAN_CONTABLE.DEB_REC_DET, PLAN_CONTABLE.CRE_REC_DET, PLAN_CONTABLE.DEB_RECO_DET, PLAN_CONTABLE.CRE_RECO_DET, PLAN_CONTABLE.CREATED_BY, PLAN_CONTABLE.MODIFIED_BY,(TO_CHAR(PLAN_CONTABLE.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED,(TO_CHAR(PLAN_CONTABLE.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(CASE PLAN_CONTABLE.CUENTAS_MAESTRAS_SALUD WHEN 0 THEN 'false' ELSE 'true' END) CUENTAS_MAESTRAS_SALUD,(CASE PLAN_CONTABLE.MOSTRARF1001 WHEN 0 THEN 'false' ELSE 'true' END) MOSTRARF1001, PLAN_CONTABLE.DEBITO_REVERSION_DET_ACTUAL, PLAN_CONTABLE.CREDITO_REVERSION_DET_ACTUAL, PLAN_CONTABLE.DEBITO_REVERSION_DET_ANTERIOR, PLAN_CONTABLE.CREDITO_REVERSION_DET_ANTERIOR ,PLAN_CONTABLE.COD_EQUI_CARTERA,(CASE PLAN_CONTABLE.DEDUCIBLE WHEN 0 THEN 'false' ELSE 'true' END) DEDUCIBLE,(CASE PLAN_CONTABLE.INFORME_SIA WHEN 0 THEN 'false' ELSE 'true' END) INFORME_SIA,(CASE PLAN_CONTABLE.ANTICIPO WHEN 0 THEN 'false' ELSE 'true' END) ANTICIPO,(CASE PLAN_CONTABLE.VIGENCIAANT WHEN 0 THEN 'false' ELSE 'true' END) VIGENCIAANT, PLAN_CONTABLE.EQUIVALENTE_DEVOLUCION , PLAN_CONTABLE.EQUIV_SIGEC, COD_RECONOCIMIENTO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA= :KEY_COMPANIA AND PLAN_CONTABLE.ANO= :KEY_ANO AND PLAN_CONTABLE.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","OBLIGA_TERCERO":"$OBLIGA_TERCERO(type:boolean)","OBLIGA_CENTRO":"$OBLIGA_CENTRO(type:boolean)","OBLIGA_AUXILIAR":"$OBLIGA_AUXILIAR(type:boolean)","OBLIGA_REFERENCIA":"$OBLIGA_REFERENCIA(type:boolean)","OBLIGA_FUENTE":"$OBLIGA_FUENTE(type:boolean)","DINAMICA":"$DINAMICA","CORRIENTE":"$CORRIENTE(type:boolean)","FORMATO":"$FORMATO","CLASECUENTA":"$CLASECUENTA","BLOQUEACUENTA":"$BLOQUEACUENTA","PERMITECONSOLIDAR":"$PERMITECONSOLIDAR(type:boolean)","GENERADESEMBOLSO":"$GENERADESEMBOLSO(type:boolean)","CHEQUE":"$CHEQUE(type:long)","PORCRETENCION":"$PORCRETENCION","CREDITOEXTERNO":"$CREDITOEXTERNO(type:boolean)","PASARSALDO":"$PASARSALDO(type:boolean)","COD_EQUIV":"$COD_EQUIV","FORMATOEGRESO":"$FORMATOEGRESO","BANCO":"$BANCO","MAN_FACT_ARRENDAMIENTO":"$MAN_FACT_ARRENDAMIENTO(type:boolean)","EQUIVPR_DEBITO":"$EQUIVPR_DEBITO","EQUIVPR_CREDITO":"$EQUIVPR_CREDITO","CONCEPTOEX":"$CONCEPTOEX","MAN_DISTRI_CCOSTO":"$MAN_DISTRI_CCOSTO(type:boolean)","CCBALANCE":"$CCBALANCE","COD_FLUJOCAJA":"$COD_FLUJOCAJA","MEN":"$MEN(type:boolean)","APLICA_DETERIORO":"$APLICA_DETERIORO(type:boolean)","DEB_CAUS_DET":"$DEB_CAUS_DET","CRE_CAUS_DET":"$CRE_CAUS_DET","DEB_REC_DET":"$DEB_REC_DET","CRE_REC_DET":"$CRE_REC_DET","DEB_RECO_DET":"$DEB_RECO_DET","CRE_RECO_DET":"$CRE_RECO_DET","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","DATE_CREATED":"$DATE_CREATED","CUENTAS_MAESTRAS_SALUD":"$CUENTAS_MAESTRAS_SALUD(type:boolean)","MOSTRARF1001":"$MOSTRARF1001(type:boolean)","DEBITO_REVERSION_DET_ACTUAL":"$DEBITO_REVERSION_DET_ACTUAL","CREDITO_REVERSION_DET_ACTUAL":"$CREDITO_REVERSION_DET_ACTUAL","DEBITO_REVERSION_DET_ANTERIOR":"$DEBITO_REVERSION_DET_ANTERIOR","CREDITO_REVERSION_DET_ANTERIOR":"$CREDITO_REVERSION_DET_ANTERIOR","COD_EQUI_CARTERA":"$COD_EQUI_CARTERA","DEDUCIBLE":"$DEDUCIBLE(type:boolean)","INFORME_SIA":"$INFORME_SIA(type:boolean)","ANTICIPO":"$ANTICIPO(type:boolean)","VIGENCIAANT":"$VIGENCIAANT(type:boolean)","EQUIVALENTE_DEVOLUCION":"$EQUIVALENTE_DEVOLUCION","EQUIV_SIGEC":"$EQUIV_SIGEC","COD_RECONOCIMIENTO":"$COD_RECONOCIMIENTO"}]}}		</result>
