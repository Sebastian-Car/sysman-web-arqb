	<query id="updatePlanescontablesConfiguracionPlanCuentas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET COMPANIA=:COMPANIA, ANO=:ANO, CODIGO=:CODIGO, MOVIMIENTO=:MOVIMIENTO, MAN_AUX_TER=:MAN_AUX_TER, MAN_CEN_CTO=:MAN_CEN_CTO, MAN_AUX_GEN=:MAN_AUX_GEN, MAN_AUX_FUE=:MAN_AUX_FUE, MAN_AUX_REF=:MAN_AUX_REF, CODIGO_NIIF=:CODIGO_NIIF, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_CONTABLE.COMPANIA= :KEY_COMPANIA AND PLAN_CONTABLE.ANO= :KEY_ANO AND PLAN_CONTABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="MAN_AUX_TER" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>
		<param name="CODIGO_NIIF" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
