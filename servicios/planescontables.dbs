	<query id="updatePlanescontablesPcontableChip" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET CODIGO=:CODIGO, NOMBRE=:NOMBRE, MOVIMIENTO=:MOVIMIENTO, NOREPORTARRECIPROCAS=:NOREPORTARRECIPROCAS, FUENTE=:FUENTE, COD_EQUIV=:COD_EQUIV, REPORTAR_100=:REPORTAR_100, TERCERO_RECIPROCAS=:TERCERO_RECIPROCAS, ANO=:ANO, CLASECUENTA=:CLASECUENTA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_CONTABLE.COMPANIA= :KEY_COMPANIA AND PLAN_CONTABLE.ANO= :KEY_ANO AND PLAN_CONTABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="NOREPORTARRECIPROCAS" sqlType="STRING"/>
		<param name="FUENTE" sqlType="STRING"/>
		<param name="COD_EQUIV" sqlType="STRING"/>
		<param name="REPORTAR_100" sqlType="STRING"/>
		<param name="TERCERO_RECIPROCAS" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planescontables/pcontablechip">
		<call-query href="updatePlanescontablesPcontableChip">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="NOREPORTARRECIPROCAS" query-param="NOREPORTARRECIPROCAS"/>
			<with-param name="FUENTE" query-param="FUENTE"/>
