	<query id="updatePlanescontablesUpdateestadosfinancieros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET CONCEPTOS_FINANCIEROS = CASE WHEN :CONCEPTOS_FINANCIEROS = - 1 THEN NULL WHEN :CONCEPTOS_FINANCIEROS IS NOT NULL THEN :CONCEPTOS_FINANCIEROS ELSE CONCEPTOS_FINANCIEROS END, CONCEPTOS_INTEGRAL = CASE WHEN :CONCEPTOS_INTEGRAL = - 1 THEN NULL WHEN :CONCEPTOS_INTEGRAL IS NOT NULL THEN :CONCEPTOS_INTEGRAL ELSE CONCEPTOS_INTEGRAL END, CONCEPTOS_PATRIMONIO = CASE WHEN :CONCEPTOS_PATRIMONIO = - 1 THEN NULL WHEN :CONCEPTOS_PATRIMONIO IS NOT NULL THEN :CONCEPTOS_PATRIMONIO ELSE CONCEPTOS_PATRIMONIO END, COLUMNA_REPORTE_PATR = CASE WHEN TO_CHAR(:COLUMNA_REPORTE_VACIO) = '-1' THEN NULL WHEN :COLUMNA_REPORTE_PATR IS NOT NULL THEN TO_CHAR(:COLUMNA_REPORTE_PATR) ELSE COLUMNA_REPORTE_PATR END, DATE_MODIFIED = TO_DATE(:DATE_MODIFIED, 'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY = :MODIFIED_BY WHERE COMPANIA = :KEY_COMPANIA AND CODIGO LIKE UPPER(CONCAT(:KEY_CODIGO, '%')) AND ANO = :KEY_ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONCEPTOS_FINANCIEROS" sqlType="STRING"/>
		<param name="CONCEPTOS_INTEGRAL" sqlType="STRING"/>
		<param name="CONCEPTOS_PATRIMONIO" sqlType="STRING"/>
		<param name="COLUMNA_REPORTE_VACIO" sqlType="STRING"/>
		<param name="COLUMNA_REPORTE_PATR" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planescontables/updateestadosfinancieros">
		<call-query href="updatePlanescontablesUpdateestadosfinancieros">
			<with-param name="CONCEPTOS_FINANCIEROS" query-param="CONCEPTOS_FINANCIEROS"/>
			<with-param name="CONCEPTOS_INTEGRAL" query-param="CONCEPTOS_INTEGRAL"/>
			<with-param name="CONCEPTOS_PATRIMONIO" query-param="CONCEPTOS_PATRIMONIO"/>
			<with-param name="COLUMNA_REPORTE_VACIO" query-param="COLUMNA_REPORTE_VACIO"/>
			<with-param name="COLUMNA_REPORTE_PATR" query-param="COLUMNA_REPORTE_PATR"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesGetauxiliarexcodigoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
