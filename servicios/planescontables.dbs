	<query id="getPlanescontablesPagClasecuentaxpeQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO, NOMBRE FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CLASECUENTA IN ('P','E') AND (PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0)) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
