	<query id="getPlanescontablesPagCuentas1,2,3PorAnioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.ID, PLAN_CONTABLE.NOMBRE  FROM V_PLAN_CONTABLE PLAN_CONTABLE WHERE ( PLAN_CONTABLE.ID LIKE '1%' OR PLAN_CONTABLE.ID LIKE '2%' OR PLAN_CONTABLE.ID LIKE '3%' ) AND PLAN_CONTABLE.MOVIMIENTO IN (-1) AND PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO ORDER BY PLAN_CONTABLE.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE"}]}}		</result>
