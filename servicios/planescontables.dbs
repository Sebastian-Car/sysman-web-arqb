			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPagConfiguracionContraprestacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE, CLASECUENTA,(CASE CORRIENTE WHEN 0 THEN 'false' ELSE 'true' END) CORRIENTE,(CASE CONTRAPRESTACION WHEN 0 THEN 'false' ELSE 'true' END) CONTRAPRESTACION, CASE WHEN PCK_SYSMAN_UTL.FC_PAR(COMPANIA,'DIGITOS PARA CONFIGURACION DE INFORMES',1,SYSDATE) = LENGTH(CODIGO) THEN 'false' ELSE 'true' END BLOQUEA_PARAMETRO FROM PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO =:ANO AND CODIGO LIKE ( '4%' ) ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(:CLASECUENTA, '%')) AND (CASE WHEN CORRIENTE IS NULL THEN ' ' ELSE UPPER(CORRIENTE) END) LIKE UPPER(CONCAT(:CORRIENTE, '%')) AND (CASE WHEN CONTRAPRESTACION IS NULL THEN ' ' ELSE UPPER(CONTRAPRESTACION) END) LIKE UPPER(CONCAT(:CONTRAPRESTACION, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CLASECUENTA":"$CLASECUENTA","CORRIENTE":"$CORRIENTE(type:boolean)","CONTRAPRESTACION":"$CONTRAPRESTACION(type:boolean)","BLOQUEA_PARAMETRO":"$BLOQUEA_PARAMETRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="CORRIENTE" sqlType="STRING"/>
		<param name="CONTRAPRESTACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/configuracioncontraprestacion/pag">
		<call-query href="getPlanescontablesPagConfiguracionContraprestacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASECUENTA" query-param="CLASECUENTA"/>
			<with-param name="CORRIENTE" query-param="CORRIENTE"/>
			<with-param name="CONTRAPRESTACION" query-param="CONTRAPRESTACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
