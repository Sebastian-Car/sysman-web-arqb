	<query id="getPlanescontablesSaldoAnteriorCambioPatQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO FORMULAID, ' ' FORMULA1, ' ' FORMULA2, ' ' FORMULA3, ' ' FORMULA4, ' ' FORMULA5, ' ' FORMULA6, ' ' FORMULA7 , SUM( CASE TO_NUMBER(:MES) WHEN 1 THEN SALDO1 WHEN 2 THEN SALDO2 WHEN 3 THEN SALDO3 WHEN 4 THEN SALDO4 WHEN 5 THEN SALDO5 WHEN 6 THEN SALDO6 WHEN 7 THEN SALDO7 WHEN 8 THEN SALDO8 WHEN 9 THEN SALDO9 WHEN 10 THEN SALDO10 WHEN 11 THEN SALDO11 WHEN 12 THEN SALDO12 END) VALORSALDOANT  FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND MOVIMIENTO NOT IN (0) GROUP BY CODIGO HAVING SUM( CASE TO_NUMBER(:MES) WHEN 1 THEN SALDO1 WHEN 2 THEN SALDO2 WHEN 3 THEN SALDO3 WHEN 4 THEN SALDO4 WHEN 5 THEN SALDO5 WHEN 6 THEN SALDO6 WHEN 7 THEN SALDO7 WHEN 8 THEN SALDO8 WHEN 9 THEN SALDO9 WHEN 10 THEN SALDO10 WHEN 11 THEN SALDO11 WHEN 12 THEN SALDO12 END) &lt;&gt; 0 ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FORMULAID":"$FORMULAID","FORMULA1":"$FORMULA1","FORMULA2":"$FORMULA2","FORMULA3":"$FORMULA3","FORMULA4":"$FORMULA4","FORMULA5":"$FORMULA5","FORMULA6":"$FORMULA6","FORMULA7":"$FORMULA7","VALORSALDOANT":"$VALORSALDOANT"}]}}		</result>
		<param name="MES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/saldoanteriorcambiopat">
		<call-query href="getPlanescontablesSaldoAnteriorCambioPatQuery">
			<with-param name="MES" query-param="MES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesEstadompstrarenflujoQuery"  useConfig="sysmandsunist">
		<sql>SELECT DISTINCT CASE WHEN MOSTRAR_EN_FLUJO NOT IN (0) THEN '-1' ELSE '0' END MOSTRAR_EN_FLUJO FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CUENTA AND MOSTRAR_EN_FLUJO NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MOSTRAR_EN_FLUJO":"$MOSTRAR_EN_FLUJO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>

	</query>
