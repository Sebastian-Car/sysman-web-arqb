	<query id="updatePlanescontablesConfigurarflujoefectivocgn" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET ANO=:ANO, CODIGO=:CODIGO, NOMBRE=:NOMBRE, MOVIMIENTO=:MOVIMIENTO, MAN_AUX_FUE=:MAN_AUX_FUE, MAN_AUX_GEN=:MAN_AUX_GEN, MAN_AUX_REF=:MAN_AUX_REF, MAN_AUX_TER=:MAN_AUX_TER, MAN_CEN_CTO=:MAN_CEN_CTO, MOSTRAR_EN_FLUJO_CGN=:MOSTRAR_EN_FLUJO_CGN, CONCEPTO_FLUJO_CGN=:CONCEPTO_FLUJO_CGN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_CONTABLE.COMPANIA= :KEY_COMPANIA AND PLAN_CONTABLE.ANO= :KEY_ANO AND PLAN_CONTABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

