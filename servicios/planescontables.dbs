RO) END)  LIKE UPPER(:MANEJA_TERCERO || '%')  AND (CASE WHEN MANEJA_CENTRO IS NULL THEN ' ' ELSE UPPER(MANEJA_CENTRO) END)  LIKE UPPER(:MANEJA_CENTRO || '%')  AND (CASE WHEN MANEJA_AUXILIAR IS NULL THEN ' ' ELSE UPPER(MANEJA_AUXILIAR) END)  LIKE UPPER(:MANEJA_AUXILIAR || '%')  AND (CASE WHEN MANEJA_FUENTE IS NULL THEN ' ' ELSE UPPER(MANEJA_FUENTE) END)  LIKE UPPER(:MANEJA_FUENTE || '%')  AND (CASE WHEN MANEJA_REFERENCIA IS NULL THEN ' ' ELSE UPPER(MANEJA_REFERENCIA) END)  LIKE UPPER(:MANEJA_REFERENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
