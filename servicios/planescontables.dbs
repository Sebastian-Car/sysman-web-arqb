	<query id="getPlanescontablesPagPorclasejybQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, CUENTABANCOS.BANCO  FROM PLAN_CONTABLE INNER JOIN CUENTABANCOS ON PLAN_CONTABLE.COMPANIA = CUENTABANCOS.COMPANIA AND PLAN_CONTABLE.ANO = CUENTABANCOS.ANO AND PLAN_CONTABLE.CODIGO = CUENTABANCOS.IDCONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANOCOBRO AND PLAN_CONTABLE.CLASECUENTA IN ('B','J') AND PLAN_CONTABLE.MOVIMIENTO &lt;&gt; 0) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","BANCO":"$BANCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOCOBRO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
