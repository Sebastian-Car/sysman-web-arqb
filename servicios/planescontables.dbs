	<query id="updatePlanescontablesActualizarcuentasbloque" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql> UPDATE PLAN_CONTABLE   SET TIPODESCUENTO_SIA = :TIPODESCUENTO_SIA, MODIFIED_BY = :MODIFIED_BY, DATE_MODIFIED = SYSDATE  WHERE COMPANIA = :COMPANIA    AND CODIGO = :CUENTA  AND ANO = :ANO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPODESCUENTO_SIA" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
