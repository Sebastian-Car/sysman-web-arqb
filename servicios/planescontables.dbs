	<query id="getPlanescontablesPagTodosPorCuentabancariaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, TO_CHAR(PLAN_CONTABLE.SALDO13, '99,999,999,999,999,990.90') SALDO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.CLASECUENTA IN ('B','J') AND ( PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0) OR (PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) AND SUBSTR(PLAN_CONTABLE.CODIGO, 1, 1) NOT IN (1))) AND PLAN_CONTABLE.ANO = :ANOEGRESO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SALDO":"$SALDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOEGRESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/todosporcuentabancaria/pag">
		<call-query href="getPlanescontablesPagTodosPorCuentabancariaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOEGRESO" query-param="ANOEGRESO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="SALDO" query-param="SALDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumTodosPorCuentabancariaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, TO_CHAR(PLAN_CONTABLE.SALDO13, '99,999,999,999,999,990.90') SALDO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.CLASECUENTA IN ('B','J') AND ( PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0) OR (PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) AND SUBSTR(PLAN_CONTABLE.CODIGO, 1, 1) NOT IN (1))) AND PLAN_CONTABLE.ANO = :ANOEGRESO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END) LIKE UPPER(CONCAT(:SALDO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOEGRESO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SALDO" sqlType="STRING"/>

	</query>
