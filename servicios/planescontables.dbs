	<query id="getPlanescontablesPagListaconfigurarflujoefectivocgnQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, ANO, CODIGO, NOMBRE,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF,(CASE MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE MOSTRAR_EN_FLUJO_CGN WHEN 0 THEN 'false' ELSE 'true' END) MOSTRAR_EN_FLUJO_CGN, CONCEPTO_FLUJO_CGN FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND(MOVIMIENTO + MAN_AUX_FUE + MAN_AUX_GEN + MAN_AUX_REF + MAN_AUX_TER + MAN_CEN_CTO)&lt;&gt; 0 ORDER BY ANO DESC, CODIGO ASC) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MOVIMIENTO), '%')) AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_FUE), '%')) AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_GEN), '%')) AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_REF), '%')) AND (CASE WHEN MAN_AUX_TER IS NULL THEN ' ' ELSE UPPER(MAN_AUX_TER) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_AUX_TER), '%')) AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END) LIKE UPPER(CONCAT(CONCAT('%',:MAN_CEN_CTO), '%')) AND (CASE WHEN MOSTRAR_EN_FLUJO_CGN IS NULL THEN ' ' ELSE UPPER(MOSTRAR_EN_FLUJO_CGN) END) LIKE UPPER(CONCAT(CONCAT('%',:MOSTRAR_EN_FLUJO_CGN), '%')) AND (CASE WHEN CONCEPTO_FLUJO_CGN IS NULL THEN ' ' ELSE UPPER(CONCEPTO_FLUJO_CGN) END) LIKE UPPER(CONCAT(CONCAT('%',:CONCEPTO_FLUJO_CGN), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MOSTRAR_EN_FLUJO_CGN":"$MOSTRAR_EN_FLUJO_CGN(type:boolean)","CONCEPTO_FLUJO_CGN":"$CONCEPTO_FLUJO_CGN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>
		<param name="MAN_AUX_TER" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MOSTRAR_EN_FLUJO_CGN" sqlType="STRING"/>
		<param name="CONCEPTO_FLUJO_CGN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
