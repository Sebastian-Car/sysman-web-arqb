	<query id="getPlanescontablesPagGettodaslascuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, PLAN_CONTABLE.CUENTA_PPTAL, PLAN_CONTABLE.CLASECUENTA, PLAN_CONTABLE.NATURALEZA, CASE WHEN MAN_AUX_TER NOT IN ( 0 ) OR OBLIGA_TERCERO NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_TERCERO, CASE WHEN MAN_CEN_CTO NOT IN ( 0 ) OR OBLIGA_CENTRO NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_CENTRO, CASE WHEN MAN_AUX_GEN NOT IN ( 0 ) OR OBLIGA_AUXILIAR NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_AUXILIAR, CASE WHEN MAN_AUX_FUE NOT IN ( 0 ) OR OBLIGA_FUENTE NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_FUENTE, CASE WHEN MAN_AUX_REF NOT IN ( 0 ) OR OBLIGA_REFERENCIA NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_REFERENCIA,(CASE MOSTRARF1001 WHEN 0 THEN 'false' ELSE 'true' END) MOSTRARF1001,(CASE PLAN_CONTABLE.MOSTRAR_EN_FLUJO WHEN 0 THEN 'false' ELSE 'true' END) MOSTRAR_EN_FLUJO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) AND (CASE WHEN CUENTA_PPTAL IS NULL THEN ' ' ELSE UPPER(CUENTA_PPTAL) END) LIKE UPPER(CONCAT(:CUENTA_PPTAL, '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(:CLASECUENTA, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) AND (CASE WHEN MANEJA_TERCERO IS NULL THEN ' ' ELSE UPPER(MANEJA_TERCERO) END) LIKE UPPER(CONCAT(:MANEJA_TERCERO, '%')) AND (CASE WHEN MANEJA_CENTRO IS NULL THEN ' ' ELSE UPPER(MANEJA_CENTRO) END) LIKE UPPER(CONCAT(:MANEJA_CENTRO, '%')) AND (CASE WHEN MANEJA_AUXILIAR IS NULL THEN ' ' ELSE UPPER(MANEJA_AUXILIAR) END) LIKE UPPER(CONCAT(:MANEJA_AUXILIAR, '%')) AND (CASE WHEN MANEJA_FUENTE IS NULL THEN ' ' ELSE UPPER(MANEJA_FUENTE) END) LIKE UPPER(CONCAT(:MANEJA_FUENTE, '%')) AND (CASE WHEN MANEJA_REFERENCIA IS NULL THEN ' ' ELSE UPPER(MANEJA_REFERENCIA) END) LIKE UPPER(CONCAT(:MANEJA_REFERENCIA, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","CUENTA_PPTAL":"$CUENTA_PPTAL","CLASECUENTA":"$CLASECUENTA","NATURALEZA":"$NATURALEZA","MANEJA_TERCERO":"$MANEJA_TERCERO","MANEJA_CENTRO":"$MANEJA_CENTRO","MANEJA_AUXILIAR":"$MANEJA_AUXILIAR","MANEJA_FUENTE":"$MANEJA_FUENTE","MANEJA_REFERENCIA":"$MANEJA_REFERENCIA","MOSTRARF1001":"$MOSTRARF1001(type:boolean)","MOSTRAR_EN_FLUJO":"$MOSTRAR_EN_FLUJO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CUENTA_PPTAL" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="MANEJA_TERCERO" sqlType="STRING"/>
		<param name="MANEJA_CENTRO" sqlType="STRING"/>
		<param name="MANEJA_AUXILIAR" sqlType="STRING"/>
		<param name="MANEJA_FUENTE" sqlType="STRING"/>
		<param name="MANEJA_REFERENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/gettodaslascuentas/pag">
		<call-query href="getPlanescontablesPagGettodaslascuentasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="CUENTA_PPTAL" query-param="CUENTA_PPTAL"/>
			<with-param name="CLASECUENTA" query-param="CLASECUENTA"/>
			<with-param name="NATURALEZA" query-param="NATURALEZA"/>
			<with-param name="MANEJA_TERCERO" query-param="MANEJA_TERCERO"/>
			<with-param name="MANEJA_CENTRO" query-param="MANEJA_CENTRO"/>
			<with-param name="MANEJA_AUXILIAR" query-param="MANEJA_AUXILIAR"/>
			<with-param name="MANEJA_FUENTE" query-param="MANEJA_FUENTE"/>
			<with-param name="MANEJA_REFERENCIA" query-param="MANEJA_REFERENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumGettodaslascuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, PLAN_CONTABLE.CUENTA_PPTAL, PLAN_CONTABLE.CLASECUENTA, PLAN_CONTABLE.NATURALEZA, CASE WHEN MAN_AUX_TER NOT IN ( 0 ) OR OBLIGA_TERCERO NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_TERCERO, CASE WHEN MAN_CEN_CTO NOT IN ( 0 ) OR OBLIGA_CENTRO NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_CENTRO, CASE WHEN MAN_AUX_GEN NOT IN ( 0 ) OR OBLIGA_AUXILIAR NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_AUXILIAR, CASE WHEN MAN_AUX_FUE NOT IN ( 0 ) OR OBLIGA_FUENTE NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_FUENTE, CASE WHEN MAN_AUX_REF NOT IN ( 0 ) OR OBLIGA_REFERENCIA NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_REFERENCIA,(CASE MOSTRARF1001 WHEN 0 THEN 'false' ELSE 'true' END) MOSTRARF1001,(CASE PLAN_CONTABLE.MOSTRAR_EN_FLUJO WHEN 0 THEN 'false' ELSE 'true' END) MOSTRAR_EN_FLUJO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) AND (CASE WHEN CUENTA_PPTAL IS NULL THEN ' ' ELSE UPPER(CUENTA_PPTAL) END) LIKE UPPER(CONCAT(:CUENTA_PPTAL, '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(:CLASECUENTA, '%')) AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END) LIKE UPPER(CONCAT(:NATURALEZA, '%')) AND (CASE WHEN MANEJA_TERCERO IS NULL THEN ' ' ELSE UPPER(MANEJA_TERCERO) END) LIKE UPPER(CONCAT(:MANEJA_TERCERO, '%')) AND (CASE WHEN MANEJA_CENTRO IS NULL THEN ' ' ELSE UPPER(MANEJA_CENTRO) END) LIKE UPPER(CONCAT(:MANEJA_CENTRO, '%')) AND (CASE WHEN MANEJA_AUXILIAR IS NULL THEN ' ' ELSE UPPER(MANEJA_AUXILIAR) END) LIKE UPPER(CONCAT(:MANEJA_AUXILIAR, '%')) AND (CASE WHEN MANEJA_FUENTE IS NULL THEN ' ' ELSE UPPER(MANEJA_FUENTE) END) LIKE UPPER(CONCAT(:MANEJA_FUENTE, '%')) AND (CASE WHEN MANEJA_REFERENCIA IS NULL THEN ' ' ELSE UPPER(MANEJA_REFERENCIA) END) LIKE UPPER(CONCAT(:MANEJA_REFERENCIA, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CUENTA_PPTAL" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="MANEJA_TERCERO" sqlType="STRING"/>
		<param name="MANEJA_CENTRO" sqlType="STRING"/>
		<param name="MANEJA_AUXILIAR" sqlType="STRING"/>
		<param name="MANEJA_FUENTE" sqlType="STRING"/>
		<param name="MANEJA_REFERENCIA" sqlType="STRING"/>

	</query>
