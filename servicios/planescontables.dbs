	<query id="getPlanescontablesPagConfiguracionPlanCuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  P.COMPANIA, P.ANO, C.DESCRIPCION CLASECUENTA, P.CODIGO,(CASE P.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE P.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE P.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE P.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE P.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE P.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF, P.NOMBRE, P.CODIGO_NIIF, P1.NOMBRE NOMBRECODEQUIV  FROM PLAN_CONTABLE P INNER JOIN CLASECUENTA C ON P.CLASECUENTA = C.CODIGO LEFT JOIN PLAN_CONTABLE P1 ON P1.COMPANIA = :COMPANIANIIF AND P.CODIGO_NIIF = P1.CODIGO AND P.ANO = P1.ANO WHERE P.COMPANIA = :COMPANIA AND TO_NUMBER(SUBSTR(P.CODIGO, 1, 1)) &gt; 0 ORDER BY P.ANO DESC, P.CODIGO) WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER( '%' || :ANO || '%')  AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END)  LIKE UPPER( '%' || :CLASECUENTA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN MAN_AUX_TER IS NULL THEN ' ' ELSE UPPER(MAN_AUX_TER) END)  LIKE UPPER(:MAN_AUX_TER || '%')  AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END)  LIKE UPPER(:MAN_CEN_CTO || '%')  AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END)  LIKE UPPER(:MAN_AUX_GEN || '%')  AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END)  LIKE UPPER(:MAN_AUX_FUE || '%')  AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END)  LIKE UPPER(:MAN_AUX_REF || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO_NIIF IS NULL THEN ' ' ELSE UPPER(CODIGO_NIIF) END)  LIKE UPPER( '%' || :CODIGO_NIIF || '%')  AND (CASE WHEN NOMBRECODEQUIV IS NULL THEN ' ' ELSE UPPER(NOMBRECODEQUIV) END)  LIKE UPPER( '%' || :NOMBRECODEQUIV || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CLASECUENTA":"$CLASECUENTA","CODIGO":"$CODIGO","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)","NOMBRE":"$NOMBRE","CODIGO_NIIF":"$CODIGO_NIIF","NOMBRECODEQUIV":"$NOMBRECODEQUIV"}]}}		</result>
		<param name="COMPANIANIIF" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="MAN_AUX_TER" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_NIIF" sqlType="STRING"/>
		<param name="NOMBRECODEQUIV" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
