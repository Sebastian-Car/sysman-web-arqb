	<query id="getPlanescontablesGetplancontableclasecuentayeQuery"  useConfig="sysmandsunist">
		<sql>SELECT PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.COD_EQUIV, PLAN_CONTABLE.NOMBRE, CASE WHEN PLAN_CONTABLE.NATURALEZA = 'D' THEN 'DEBITO' ELSE 'CREDITO' END NATURALEZA, CASE BLOQUEACUENTA WHEN 'NO' THEN 'false' ELSE 'true' END  BLOQUEACUENTA, CLASECUENTA.DESCRIPCION CLASECUENTA, CLASECUENTA.CODIGO CODIGOCLASECUENTA FROM PLAN_CONTABLE INNER JOIN CLASECUENTA ON PLAN_CONTABLE.CLASECUENTA = CLASECUENTA.CODIGO WHERE COMPANIA = :COMPANIA AND ANO = :ANO ORDER BY PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","COD_EQUIV":"$COD_EQUIV","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","BLOQUEACUENTA":"$BLOQUEACUENTA","CLASECUENTA":"$CLASECUENTA","CODIGOCLASECUENTA":"$CODIGOCLASECUENTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
