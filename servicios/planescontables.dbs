		<call-query href="getPlanescontablesGetplancontableclasecuentayeQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPagGetcuentascxpcomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE FROM DETALLE_COMPROBANTE_CNT INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND INSTR(REPLACE(CONCAT(CONCAT('''', REPLACE(:COMPROBANTE, ' ', '')), ''''), ',', ''','''), CONCAT(CONCAT(CONCAT(CONCAT('', TO_CHAR (DETALLE_COMPROBANTE_CNT.ANO)), DETALLE_COMPROBANTE_CNT.TIPO_CPTE), DETALLE_COMPROBANTE_CNT.COMPROBANTE), ''), 1) &gt; 0 AND PLAN_CONTABLE.CLASECUENTA IN ('P','E') AND (DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - (DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO)) &gt; 0 GROUP BY DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE ORDER BY DETALLE_COMPROBANTE_CNT.CUENTA) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/getcuentascxpcomprobante/pag">
		<call-query href="getPlanescontablesPagGetcuentascxpcomprobanteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumGetcuentascxpcomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE FROM DETALLE_COMPROBANTE_CNT INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND INSTR(REPLACE(CONCAT(CONCAT('''', REPLACE(:COMPROBANTE, ' ', '')), ''''), ',', ''','''), CONCAT(CONCAT(CONCAT(CONCAT('', TO_CHAR (DETALLE_COMPROBANTE_CNT.ANO)), DETALLE_COMPROBANTE_CNT.TIPO_CPTE), DETALLE_COMPROBANTE_CNT.COMPROBANTE), ''), 1) &gt; 0 AND PLAN_CONTABLE.CLASECUENTA IN ('P','E') AND (DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - (DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO)) &gt; 0 GROUP BY DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE ORDER BY DETALLE_COMPROBANTE_CNT.CUENTA) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(:CUENTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
