	<query id="getPlanescontablesCuentasNiifAnoDestinoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, TO_NUMBER(:ANIODESTINO) ANO, CODIGO  FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANIOFUENTE AND CODIGO_NIIF IS NOT NULL MINUS SELECT COMPANIA, TO_NUMBER(:ANIODESTINO) ANO, CODIGO FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANIODESTINO UNION ALL SELECT :COMPANIANIIF COMPANIA, TO_NUMBER(:ANIODESTINO) ANO, CODIGO_NIIF CODIGO FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANIOFUENTE AND CODIGO_NIIF IS NOT NULL MINUS SELECT :COMPANIANIIF COMPANIA, TO_NUMBER(:ANIODESTINO) ANO, CODIGO FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIANIIF AND ANO = :ANIODESTINO ORDER BY CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO","CODIGO":"$CODIGO"}]}}		</result>
		<param name="ANIODESTINO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIOFUENTE" sqlType="STRING"/>
		<param name="COMPANIANIIF" sqlType="STRING"/>

	</query>
