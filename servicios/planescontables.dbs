	<query id="getPlanescontablesGetplancontabledatosconciliacionqueryQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SALDO_CONCILIACION ,(TO_CHAR(FECHA_CONCILIACION,'DD/MM/YYYY HH24:MI:SS')) FECHA_CONCILIACION, OBSERV_CONCILIACION  FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODCUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SALDO_CONCILIACION":"$SALDO_CONCILIACION(type:long)","FECHA_CONCILIACION":"$FECHA_CONCILIACION","OBSERV_CONCILIACION":"$OBSERV_CONCILIACION"}]}}		</result>
