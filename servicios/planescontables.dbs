	<query id="getPlanescontablesPagNaturalezaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.NATURALEZA, PLAN_CONTABLE.CUENTA_PPTAL, PLAN_PRESUPUESTAL.NOMBRE NOMBREPPTAL  FROM PLAN_CONTABLE LEFT JOIN PLAN_PRESUPUESTAL ON PLAN_CONTABLE.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND PLAN_CONTABLE.ANO = PLAN_PRESUPUESTAL.ANO AND PLAN_CONTABLE.CUENTA_PPTAL = PLAN_PRESUPUESTAL.CODIGO WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND (PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0))) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","NATURALEZA":"$NATURALEZA","CUENTA_PPTAL":"$CUENTA_PPTAL","NOMBREPPTAL":"$NOMBREPPTAL"}]}}		</result>
