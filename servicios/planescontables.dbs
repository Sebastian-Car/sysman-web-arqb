	<query id="getPlanescontablesNumConfiguracionestadosfinancierosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT P.COMPANIA, P.ANO, P.CODIGO, P.NOMBRE, C.DESCRIPCION CLASECUENTA, P.CONCEPTOS_FINANCIEROS, P.CONCEPTOS_PATRIMONIO, P.CONCEPTOS_INTEGRAL, P.COLUMNA_REPORTE_PATR, CASE P.COLUMNA_REPORTE_PATR WHEN 'CAPITAL' THEN 'Capital' WHEN 'RESERVAS' THEN 'Reservas' WHEN 'RESULTADOS' THEN 'Resultados del ejercicio' WHEN 'RESULTADOS_ANT' THEN 'Resultados ejercicios anteriores' WHEN 'OTRAS' THEN 'Otras partidas de patrimonio' ELSE P.COLUMNA_REPORTE_PATR END AS DESC_COLUMNA_REPORTE_PATR,(CASE P.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_CONTABLE P INNER JOIN CLASECUENTA C ON C.CODIGO = P.CLASECUENTA WHERE P.COMPANIA = :COMPANIA AND P.ANO = :ANIO AND P.CLASECUENTA = CASE WHEN :PATRIMONIO IS NOT NULL THEN 'T' ELSE P.CLASECUENTA END ORDER BY P.ANO DESC, P.CODIGO ASC) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CLASECUENTA), '%')) AND (CASE WHEN CONCEPTOS_FINANCIEROS IS NULL THEN ' ' ELSE UPPER(CONCEPTOS_FINANCIEROS) END) LIKE UPPER(CONCAT(:CONCEPTOS_FINANCIEROS, '%')) AND (CASE WHEN CONCEPTOS_PATRIMONIO IS NULL THEN ' ' ELSE UPPER(CONCEPTOS_PATRIMONIO) END) LIKE UPPER(CONCAT(:CONCEPTOS_PATRIMONIO, '%')) AND (CASE WHEN CONCEPTOS_INTEGRAL IS NULL THEN ' ' ELSE UPPER(CONCEPTOS_INTEGRAL) END) LIKE UPPER(CONCAT(:CONCEPTOS_INTEGRAL, '%')) AND (CASE WHEN DESC_COLUMNA_REPORTE_PATR IS NULL THEN ' ' ELSE UPPER(DESC_COLUMNA_REPORTE_PATR) END) LIKE UPPER(CONCAT(CONCAT('%',:DESC_COLUMNA_REPORTE_PATR), '%')) AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END) LIKE UPPER(CONCAT(:MOVIMIENTO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="PATRIMONIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="CONCEPTOS_FINANCIEROS" sqlType="STRING"/>
		<param name="CONCEPTOS_PATRIMONIO" sqlType="STRING"/>
		<param name="CONCEPTOS_INTEGRAL" sqlType="STRING"/>
		<param name="DESC_COLUMNA_REPORTE_PATR" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>

	</query>
