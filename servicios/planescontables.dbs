	</resource>

	<query id="getPlanescontablesPagXcompaniacomprobantetipoyanoQuery" useConfig="sysmandsunist">
        <sql> SELECT * FROM (SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE FROM DETALLE_COMPROBANTE_CNT INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND (DETALLE_COMPROBANTE_CNT.ANO, TRIM(DETALLE_COMPROBANTE_CNT.TIPO_CPTE), TRIM(DETALLE_COMPROBANTE_CNT.COMPROBANTE)) IN (SELECT TO_NUMBER(SUBSTR(REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL), 1, 4)) AS ANO, SUBSTR(REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL), 5, 3) AS TIPO, SUBSTR(REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL), 8) AS COMPROBANTE FROM DUAL CONNECT BY REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL) IS NOT NULL ) AND PLAN_CONTABLE.CLASECUENTA IN ( 'P', 'E' ) AND ( DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - ( DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO ) ) &gt; 0 GROUP BY DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE ORDER BY DETALLE_COMPROBANTE_CNT.CUENTA ) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO </sql>
        <result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA","NOMBRE":"$NOMBRE"}]}}</result>
        <param name="COMPANIA" sqlType="STRING"/>
        <param name="CADENA_COMPROBANTES" sqlType="STRING"/>
        <param name="CUENTA" sqlType="STRING"/>
        <param name="NOMBRE" sqlType="STRING"/>
        <param name="PAGINICIO" sqlType="INTEGER"/>
        <param name="PAGTAMANIO" sqlType="INTEGER"/>
    </query>

    <resource method="GET" path="planescontables/xcompaniacomprobantetipoyano/pag">
        <call-query href="getPlanescontablesPagXcompaniacomprobantetipoyanoQuery">
            <with-param name="COMPANIA" query-param="COMPANIA"/>
            <with-param name="CADENA_COMPROBANTES" query-param="CADENA_COMPROBANTES"/>
            <with-param name="CUENTA" query-param="CUENTA"/>
            <with-param name="NOMBRE" query-param="NOMBRE"/>
            <with-param name="PAGINICIO" query-param="PAGINICIO"/>
            <with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>
        </call-query>
    </resource>

    <query id="getPlanescontablesNumXcompaniacomprobantetipoyanoQuery" useConfig="sysmandsunist">
        <sql> SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE FROM DETALLE_COMPROBANTE_CNT INNER JOIN PLAN_CONTABLE ON DETALLE_COMPROBANTE_CNT.COMPANIA = PLAN_CONTABLE.COMPANIA AND DETALLE_COMPROBANTE_CNT.ANO = PLAN_CONTABLE.ANO AND DETALLE_COMPROBANTE_CNT.CUENTA = PLAN_CONTABLE.CODIGO WHERE DETALLE_COMPROBANTE_CNT.COMPANIA = :COMPANIA AND (DETALLE_COMPROBANTE_CNT.ANO, TRIM(DETALLE_COMPROBANTE_CNT.TIPO_CPTE), TRIM(DETALLE_COMPROBANTE_CNT.COMPROBANTE)) IN (SELECT TO_NUMBER(SUBSTR(REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL), 1, 4)) AS ANO, SUBSTR(REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL), 5, 3) AS TIPO, SUBSTR(REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL), 8) AS COMPROBANTE FROM DUAL CONNECT BY REGEXP_SUBSTR(:CADENA_COMPROBANTES, '[^_]+', 1, LEVEL) IS NOT NULL ) AND PLAN_CONTABLE.CLASECUENTA IN ( 'P', 'E' ) AND ( DETALLE_COMPROBANTE_CNT.VALOR_CREDITO - ( DETALLE_COMPROBANTE_CNT.DEBITO_AFECTADO - DETALLE_COMPROBANTE_CNT.CREDITO_AFECTADO ) ) &gt; 0 GROUP BY DETALLE_COMPROBANTE_CNT.CUENTA, PLAN_CONTABLE.NOMBRE ORDER BY DETALLE_COMPROBANTE_CNT.CUENTA ) INI WHERE (CASE WHEN CUENTA IS NULL THEN ' ' ELSE UPPER(CUENTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CUENTA), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN </sql>
        <result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}</result>
        <param name="COMPANIA" sqlType="STRING"/>
        <param name="CADENA_COMPROBANTES" sqlType="STRING"/>
        <param name="CUENTA" sqlType="STRING"/>
        <param name="NOMBRE" sqlType="STRING"/>
    </query>

    <resource method="GET" path="planescontables/xcompaniacomprobantetipoyano/num">
        <call-query href="getPlanescontablesNumXcompaniacomprobantetipoyanoQuery">
            <with-param name="COMPANIA" query-param="COMPANIA"/>
            <with-param name="CADENA_COMPROBANTES" query-param="CADENA_COMPROBANTES"/>
            <with-param name="CUENTA" query-param="CUENTA"/>
            <with-param name="NOMBRE" query-param="NOMBRE"/>
        </call-query>
    </resource>


