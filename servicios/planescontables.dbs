			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPagCierreFiscalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, CODIGO , NOMBRE, SALDO12 SALDO, CODIGO_FUT  FROM PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO = :ANO AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN(0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0)) AND CLASECUENTA IN('I') AND SALDO12 &gt; 0 ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN SALDO IS NULL THEN ' ' ELSE UPPER(SALDO) END)  LIKE UPPER(:SALDO || '%')  AND (CASE WHEN CODIGO_FUT IS NULL THEN ' ' ELSE UPPER(CODIGO_FUT) END)  LIKE UPPER( '%' || :CODIGO_FUT || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","SALDO":"$SALDO","CODIGO_FUT":"$CODIGO_FUT"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
