F IS NULL THEN ' ' ELSE UPPER(CODIGO_NIIF) END)  LIKE UPPER( '%' || :CODIGO_NIIF || '%')  AND (CASE WHEN NOMBRECODEQUIV IS NULL THEN ' ' ELSE UPPER(NOMBRECODEQUIV) END)  LIKE UPPER( '%' || :NOMBRECODEQUIV || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
