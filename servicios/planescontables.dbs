	<query id="updatePlanescontablesActualizaCuentas567" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET MOSTRARF1001 = -1 , DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND (MOVIMIENTO NOT IN(0) OR MAN_CEN_CTO NOT IN (0) OR MAN_AUX_TER NOT IN(0) OR MAN_AUX_GEN NOT IN(0) OR MAN_AUX_REF NOT IN(0) OR MAN_AUX_FUE NOT IN(0)) AND (CODIGO LIKE '5%' OR CODIGO LIKE '6%' OR CODIGO LIKE '7%')</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
