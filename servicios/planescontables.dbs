	<query id="updatePlanescontables" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET NOMBRE=:NOMBRE, NATURALEZA=:NATURALEZA, MOVIMIENTO=:MOVIMIENTO, MAN_AUX_TER=:MAN_AUX_TER, MAN_CEN_CTO=:MAN_CEN_CTO, MAN_AUX_GEN=:MAN_AUX_GEN, MAN_AUX_REF=:MAN_AUX_REF, MAN_AUX_FUE=:MAN_AUX_FUE, OBLIGA_TERCERO=:OBLIGA_TERCERO, OBLIGA_CENTRO=:OBLIGA_CENTRO, OBLIGA_AUXILIAR=:OBLIGA_AUXILIAR, OBLIGA_REFERENCIA=:OBLIGA_REFERENCIA, OBLIGA_FUENTE=:OBLIGA_FUENTE, DINAMICA=:DINAMICA, CORRIENTE=:CORRIENTE, FORMATO=:FORMATO, CLASECUENTA=:CLASECUENTA, BLOQUEACUENTA=:BLOQUEACUENTA, PERMITECONSOLIDAR=:PERMITECONSOLIDAR, GENERADESEMBOLSO=:GENERADESEMBOLSO, CHEQUE=:CHEQUE, PORCRETENCION=:PORCRETENCION, CREDITOEXTERNO=:CREDITOEXTERNO, PASARSALDO=:PASARSALDO, COD_EQUIV=:COD_EQUIV, FORMATOEGRESO=:FORMATOEGRESO, BANCO=:BANCO, MAN_FACT_ARRENDAMIENTO=:MAN_FACT_ARRENDAMIENTO, EQUIVPR_DEBITO=:EQUIVPR_DEBITO, EQUIVPR_CREDITO=:EQUIVPR_CREDITO, CONCEPTOEX=:CONCEPTOEX, MAN_DISTRI_CCOSTO=:MAN_DISTRI_CCOSTO, CCBALANCE=:CCBALANCE, COD_FLUJOCAJA=:COD_FLUJOCAJA, MEN=:MEN, APLICA_DETERIORO=:APLICA_DETERIORO, DEB_CAUS_DET=:DEB_CAUS_DET, CRE_CAUS_DET=:CRE_CAUS_DET, DEB_REC_DET=:DEB_REC_DET, CRE_REC_DET=:CRE_REC_DET, DEB_RECO_DET=:DEB_RECO_DET, CRE_RECO_DET=:CRE_RECO_DET, CUENTAS_MAESTRAS_SALUD=:CUENTAS_MAESTRAS_SALUD, MOSTRARF1001=:MOSTRARF1001, DEBITO_REVERSION_DET_ACTUAL=:DEBITO_REVERSION_DET_ACTUAL, CREDITO_REVERSION_DET_ACTUAL=:CREDITO_REVERSION_DET_ACTUAL, DEBITO_REVERSION_DET_ANTERIOR=:DEBITO_REVERSION_DET_ANTERIOR, CREDITO_REVERSION_DET_ANTERIOR=:CREDITO_REVERSION_DET_ANTERIOR, COD_EQUI_CARTERA=:COD_EQUI_CARTERA, DEDUCIBLE=:DEDUCIBLE, INFORME_SIA=:INFORME_SIA, ANTICIPO=:ANTICIPO, VIGENCIAANT=:VIGENCIAANT, EQUIVALENTE_DEVOLUCION=:EQUIVALENTE_DEVOLUCION, EQUIV_SIGEC=:EQUIV_SIGEC, COD_RECONOCIMIENTO=:COD_RECONOCIMIENTO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PLAN_CONTABLE.COMPANIA= :KEY_COMPANIA AND PLAN_CONTABLE.ANO= :KEY_ANO AND PLAN_CONTABLE.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="MAN_AUX_TER" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="OBLIGA_TERCERO" sqlType="STRING"/>
		<param name="OBLIGA_CENTRO" sqlType="STRING"/>
		<param name="OBLIGA_AUXILIAR" sqlType="STRING"/>
		<param name="OBLIGA_REFERENCIA" sqlType="STRING"/>
		<param name="OBLIGA_FUENTE" sqlType="STRING"/>
		<param name="DINAMICA" sqlType="STRING"/>
		<param name="CORRIENTE" sqlType="STRING"/>
		<param name="FORMATO" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="BLOQUEACUENTA" sqlType="STRING"/>
		<param name="PERMITECONSOLIDAR" sqlType="STRING"/>
