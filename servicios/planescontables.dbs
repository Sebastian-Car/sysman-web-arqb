	<query id="updatePlanescontablesActsaldosplan" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>MERGE INTO PLAN_CONTABLE USING PLAN_CONTABLE PLAN2 ON (PLAN_CONTABLE.COMPANIA = PLAN2.COMPANIA AND PLAN_CONTABLE.CODIGO = PLAN2.CODIGO AND PLAN_CONTABLE.ANO = :ANO AND PLAN2.ANO = :ANO -1 AND PLAN2.AJUSTE13 != 0) WHEN MATCHED THEN UPDATE SET PLAN_CONTABLE.AJUSTE0 = PLAN2.AJUSTE13 WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
