	<query id="getPlanescontablesPorCodigoYAjusteMesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  (CASE :MES WHEN '0' THEN AJUSTE0 WHEN '1' THEN AJUSTE1 WHEN '2' THEN AJUSTE2 WHEN '3' THEN AJUSTE3 WHEN '4' THEN AJUSTE4 WHEN '5' THEN AJUSTE5 WHEN '6' THEN AJUSTE6 WHEN '7' THEN AJUSTE7 WHEN '8' THEN AJUSTE8 WHEN '9' THEN AJUSTE9 WHEN '10' THEN AJUSTE10 WHEN '11' THEN AJUSTE11 WHEN '12' THEN AJUSTE12 WHEN '13' THEN AJUSTE13 END) AJUSTE  FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODCUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"AJUSTE":"$AJUSTE"}]}}		</result>
		<param name="MES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>

	</query>
