<data name="planescontables" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPlanescontablesPagPoranotrabajofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO,PLAN_CONTABLE.NOMBRE  FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND PLAN_CONTABLE.CODIGO &gt;= :CODIGOINICIAL ORDER BY PLAN_CONTABLE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/poranotrabajofinal/pag">
		<call-query href="getPlanescontablesPagPoranotrabajofinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumPoranotrabajofinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO,PLAN_CONTABLE.NOMBRE  FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND PLAN_CONTABLE.CODIGO &gt;= :CODIGOINICIAL ORDER BY PLAN_CONTABLE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/poranotrabajofinal/num">
		<call-query href="getPlanescontablesNumPoranotrabajofinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPagPoranotrabajoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE PLAN_CONTABLE.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE PLAN_CONTABLE.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_CONTABLE.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE PLAN_CONTABLE.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE PLAN_CONTABLE.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO ORDER BY PLAN_CONTABLE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN MAN_AUX_TER IS NULL THEN ' ' ELSE UPPER(MAN_AUX_TER) END)  LIKE UPPER(:MAN_AUX_TER || '%')  AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END)  LIKE UPPER(:MAN_CEN_CTO || '%')  AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END)  LIKE UPPER(:MAN_AUX_GEN || '%')  AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END)  LIKE UPPER(:MAN_AUX_FUE || '%')  AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END)  LIKE UPPER(:MAN_AUX_REF || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="MAN_AUX_TER" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/poranotrabajoinicial/pag">
		<call-query href="getPlanescontablesPagPoranotrabajoinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="MAN_AUX_TER" query-param="MAN_AUX_TER"/>
			<with-param name="MAN_CEN_CTO" query-param="MAN_CEN_CTO"/>
			<with-param name="MAN_AUX_GEN" query-param="MAN_AUX_GEN"/>
			<with-param name="MAN_AUX_FUE" query-param="MAN_AUX_FUE"/>
			<with-param name="MAN_AUX_REF" query-param="MAN_AUX_REF"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumPoranotrabajoinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE PLAN_CONTABLE.MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE PLAN_CONTABLE.MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE PLAN_CONTABLE.MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE PLAN_CONTABLE.MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE PLAN_CONTABLE.MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO ORDER BY PLAN_CONTABLE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER( '%' || :MOVIMIENTO || '%')  AND (CASE WHEN MAN_AUX_TER IS NULL THEN ' ' ELSE UPPER(MAN_AUX_TER) END)  LIKE UPPER( '%' || :MAN_AUX_TER || '%')  AND (CASE WHEN MAN_CEN_CTO IS NULL THEN ' ' ELSE UPPER(MAN_CEN_CTO) END)  LIKE UPPER( '%' || :MAN_CEN_CTO || '%')  AND (CASE WHEN MAN_AUX_GEN IS NULL THEN ' ' ELSE UPPER(MAN_AUX_GEN) END)  LIKE UPPER( '%' || :MAN_AUX_GEN || '%')  AND (CASE WHEN MAN_AUX_FUE IS NULL THEN ' ' ELSE UPPER(MAN_AUX_FUE) END)  LIKE UPPER( '%' || :MAN_AUX_FUE || '%')  AND (CASE WHEN MAN_AUX_REF IS NULL THEN ' ' ELSE UPPER(MAN_AUX_REF) END)  LIKE UPPER( '%' || :MAN_AUX_REF || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="MAN_AUX_TER" sqlType="STRING"/>
		<param name="MAN_CEN_CTO" sqlType="STRING"/>
		<param name="MAN_AUX_GEN" sqlType="STRING"/>
		<param name="MAN_AUX_FUE" sqlType="STRING"/>
		<param name="MAN_AUX_REF" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/poranotrabajoinicial/num">
		<call-query href="getPlanescontablesNumPoranotrabajoinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="MOVIMIENTO" query-param="MOVIMIENTO"/>
			<with-param name="MAN_AUX_TER" query-param="MAN_AUX_TER"/>
			<with-param name="MAN_CEN_CTO" query-param="MAN_CEN_CTO"/>
			<with-param name="MAN_AUX_GEN" query-param="MAN_AUX_GEN"/>
			<with-param name="MAN_AUX_FUE" query-param="MAN_AUX_FUE"/>
			<with-param name="MAN_AUX_REF" query-param="MAN_AUX_REF"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT ANO  FROM PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO NOT IN (0) ORDER BY ANO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/todosporcompania">
		<call-query href="getPlanescontablesTodosPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPagTodosPoranoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.ANO  FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO ORDER BY COMPANIA, ANO, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/todosporano/pag">
		<call-query href="getPlanescontablesPagTodosPoranoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumTodosPoranoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.ANO  FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO ORDER BY COMPANIA, ANO, CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/todosporano/num">
		<call-query href="getPlanescontablesNumTodosPoranoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertPlanescontables" keyColumns="COMPANIA,ANO,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PLAN_CONTABLE (COMPANIA, ANO, CODIGO, NOMBRE, NATURALEZA, MOVIMIENTO, MAN_AUX_TER, MAN_CEN_CTO, MAN_AUX_GEN, MAN_AUX_REF, MAN_AUX_FUE, OBLIGA_TERCERO, OBLIGA_CENTRO, OBLIGA_AUXILIAR, OBLIGA_REFERENCIA, OBLIGA_FUENTE, DINAMICA, CORRIENTE, FORMATO, CLASECUENTA, BLOQUEACUENTA, PERMITECONSOLIDAR, GENERADESEMBOLSO, CHEQUE, PORCRETENCION, CREDITOEXTERNO, PASARSALDO, COD_EQUIV, FORMATOEGRESO, BANCO, MAN_FACT_ARRENDAMIENTO, EQUIVPR_DEBITO, EQUIVPR_CREDITO, CONCEPTOEX, MAN_DISTRI_CCOSTO, CCBALANCE, COD_FLUJOCAJA, MEN, APLICA_DETERIORO, DEB_CAUS_DET, CRE_CAUS_DET, DEB_REC_DET, CRE_REC_DET, DEB_RECO_DET, CRE_RECO_DET, CUENTAS_MAESTRAS_SALUD, MOSTRARF1001, DEBITO_REVERSION_DET_ACTUAL, CREDITO_REVERSION_DET_ACTUAL, DEBITO_REVERSION_DET_ANTERIOR, CREDITO_REVERSION_DET_ANTERIOR, COD_EQUI_CARTERA, DEDUCIBLE, INFORME_SIA, ANTICIPO, VIGENCIAANT, EQUIVALENTE_DEVOLUCION, EQUIV_SIGEC, COD_RECONOCIMIENTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CODIGO, :NOMBRE, :NATURALEZA, :MOVIMIENTO, :MAN_AUX_TER, :MAN_CEN_CTO, :MAN_AUX_GEN, :MAN_AUX_REF, :MAN_AUX_FUE, :OBLIGA_TERCERO, :OBLIGA_CENTRO, :OBLIGA_AUXILIAR, :OBLIGA_REFERENCIA, :OBLIGA_FUENTE, :DINAMICA, :CORRIENTE, :FORMATO, :CLASECUENTA, :BLOQUEACUENTA, :PERMITECONSOLIDAR, :GENERADESEMBOLSO, :CHEQUE, :PORCRETENCION, :CREDITOEXTERNO, :PASARSALDO, :COD_EQUIV, :FORMATOEGRESO, :BANCO, :MAN_FACT_ARRENDAMIENTO, :EQUIVPR_DEBITO, :EQUIVPR_CREDITO, :CONCEPTOEX, :MAN_DISTRI_CCOSTO, :CCBALANCE, :COD_FLUJOCAJA, :MEN, :APLICA_DETERIORO, :DEB_CAUS_DET, :CRE_CAUS_DET, :DEB_REC_DET, :CRE_REC_DET, :DEB_RECO_DET, :CRE_RECO_DET, :CUENTAS_MAESTRAS_SALUD, :MOSTRARF1001, :DEBITO_REVERSION_DET_ACTUAL, :CREDITO_REVERSION_DET_ACTUAL, :DEBITO_REVERSION_DET_ANTERIOR, :CREDITO_REVERSION_DET_ANTERIOR, :COD_EQUI_CARTERA, :DEDUCIBLE, :INFORME_SIA, :ANTICIPO, :VIGENCIAANT, :EQUIVALENTE_DEVOLUCION, :EQUIV_SIGEC, :COD_RECONOCIMIENTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param defaultValue="0" name="MOVIMIENTO" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_TER" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_CEN_CTO" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_GEN" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_REF" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_AUX_FUE" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGA_TERCERO" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGA_CENTRO" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGA_AUXILIAR" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGA_REFERENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="OBLIGA_FUENTE" sqlType="STRING"/>
		<param defaultValue="" name="DINAMICA" sqlType="STRING"/>
		<param defaultValue="0" name="CORRIENTE" sqlType="STRING"/>
		<param defaultValue="" name="FORMATO" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param defaultValue="NO" name="BLOQUEACUENTA" sqlType="STRING"/>
		<param defaultValue="0" name="PERMITECONSOLIDAR" sqlType="STRING"/>
		<param defaultValue="0" name="GENERADESEMBOLSO" sqlType="STRING"/>
		<param defaultValue="" name="CHEQUE" sqlType="STRING"/>
		<param defaultValue="0" name="PORCRETENCION" sqlType="STRING"/>
		<param defaultValue="0" name="CREDITOEXTERNO" sqlType="STRING"/>
		<param defaultValue="0" name="PASARSALDO" sqlType="STRING"/>
		<param defaultValue="" name="COD_EQUIV" sqlType="STRING"/>
		<param defaultValue="" name="FORMATOEGRESO" sqlType="STRING"/>
		<param defaultValue="" name="BANCO" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_FACT_ARRENDAMIENTO" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVPR_DEBITO" sqlType="STRING"/>
		<param defaultValue="" name="EQUIVPR_CREDITO" sqlType="STRING"/>
		<param defaultValue="" name="CONCEPTOEX" sqlType="STRING"/>
		<param defaultValue="0" name="MAN_DISTRI_CCOSTO" sqlType="STRING"/>
		<param defaultValue="" name="CCBALANCE" sqlType="STRING"/>
		<param defaultValue="" name="COD_FLUJOCAJA" sqlType="STRING"/>
