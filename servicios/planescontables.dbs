	<query id="getPlanescontablesPagGrillacuentadescuentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.ANO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.TIPODESCUENTO_SIA, PLAN_CONTABLE.NATURALEZA,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND PLAN_CONTABLE.NATURALEZA IN ('C','D') AND PLAN_CONTABLE.CLASECUENTA IN ('P','I','E') AND (PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0)) ORDER BY PLAN_CONTABLE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPODESCUENTO_SIA IS NULL THEN ' ' ELSE UPPER(TIPODESCUENTO_SIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPODESCUENTO_SIA), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","ANO":"$ANO(type:integer)","NOMBRE":"$NOMBRE","TIPODESCUENTO_SIA":"$TIPODESCUENTO_SIA","NATURALEZA":"$NATURALEZA","MOVIMIENTO":"$MOVIMIENTO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPODESCUENTO_SIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/grillacuentadescuento/pag">
		<call-query href="getPlanescontablesPagGrillacuentadescuentoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="TIPODESCUENTO_SIA" query-param="TIPODESCUENTO_SIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesNumGrillacuentadescuentoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.ANO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.TIPODESCUENTO_SIA, PLAN_CONTABLE.NATURALEZA,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND PLAN_CONTABLE.NATURALEZA IN ('C','D') AND PLAN_CONTABLE.CLASECUENTA IN ('P','I','E') AND (PLAN_CONTABLE.MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0)) ORDER BY PLAN_CONTABLE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(CONCAT('%',:ANO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN TIPODESCUENTO_SIA IS NULL THEN ' ' ELSE UPPER(TIPODESCUENTO_SIA) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPODESCUENTO_SIA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="TIPODESCUENTO_SIA" sqlType="STRING"/>

	</query>
