		<sql>SELECT COUNT(1) HIJOS FROM PLAN_CONTABLE WHERE COMPANIA =:COMPANIA AND ANO =:ANIO AND CODIGO LIKE (CONCAT('',CONCAT(:CODIGO, '%' ))) AND LENGTH(CODIGO) &gt;:LONGITUDCOD</sql>
