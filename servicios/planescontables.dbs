	<query id="getPlanescontablesGetplancontableajustepormesqueryQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ( CASE :MES WHEN '0' THEN AJUSTE0 WHEN '1' THEN AJUSTE1 WHEN '2' THEN AJUSTE2 WHEN '3' THEN AJUSTE3 WHEN '4' THEN AJUSTE4 WHEN '5' THEN AJUSTE5 WHEN '6' THEN AJUSTE6 WHEN '7' THEN AJUSTE7 WHEN '8' THEN AJUSTE8 WHEN '9' THEN AJUSTE9 WHEN '10' THEN AJUSTE10 WHEN '11' THEN AJUSTE11 WHEN '12' THEN AJUSTE12 WHEN '13' THEN AJUSTE13 END ) AJUSTE  FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO = :CODCUENTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"AJUSTE":"$AJUSTE"}]}}		</result>
		<param name="MES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/getplancontableajustepormesquery">
		<call-query href="getPlanescontablesGetplancontableajustepormesqueryQuery">
			<with-param name="MES" query-param="MES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>

		</call-query>
	</resource>
	<query id="updatePlanescontablesUpdateplancontableajustemes" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE   SET AJUSTE0 = CASE TO_CHAR(:MES) WHEN '0' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE0 END,       AJUSTE1 = CASE TO_CHAR(:MES) WHEN '1' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE1 END,       AJUSTE2 = CASE TO_CHAR(:MES) WHEN '2' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE2 END,         AJUSTE3 = CASE TO_CHAR(:MES) WHEN '3' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE3 END,       AJUSTE4 = CASE TO_CHAR(:MES) WHEN '4' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE4 END,       AJUSTE5 = CASE TO_CHAR(:MES) WHEN '5' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE5 END,          AJUSTE6 = CASE TO_CHAR(:MES) WHEN '6' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE6 END,        AJUSTE7 = CASE TO_CHAR(:MES) WHEN '7' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE7 END,        AJUSTE8 = CASE TO_CHAR(:MES) WHEN '8' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE8 END,        AJUSTE9 = CASE TO_CHAR(:MES) WHEN '9' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE9 END,        AJUSTE10 = CASE TO_CHAR(:MES) WHEN '10' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE10 END,      AJUSTE11 = CASE TO_CHAR(:MES) WHEN '11' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE11 END,      AJUSTE12 = CASE TO_CHAR(:MES) WHEN '12' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE12 END,       AJUSTE13 = CASE TO_CHAR(:MES) WHEN '13' THEN TO_NUMBER(:SALDOEXTRACTO) ELSE AJUSTE13 END,      DATE_MODIFIED=TO_DATE(:DATE_MODIFIED, 'DD/MM/YYYY HH24:MI:SS') ,      MODIFIED_BY=:MODIFIED_BY        WHERE COMPANIA            = :COMPANIA             AND ANO                 = :ANO             AND CODIGO              = :CODCUENTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="MES" sqlType="STRING"/>
		<param name="SALDOEXTRACTO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planescontables/updateplancontableajustemes">
		<call-query href="updatePlanescontablesUpdateplancontableajustemes">
			<with-param name="MES" query-param="MES"/>
			<with-param name="SALDOEXTRACTO" query-param="SALDOEXTRACTO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>

		</call-query>
	</resource>
	<query id="updatePlanescontablesUpdateplancontabledatosconciliacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE     SET FECHA_CONCILIACION  = TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS') ,         SALDO_CONCILIACION  = TO_NUMBER(:SALDOEXTRACTO) ,         OBSERV_CONCILIACION = :OBSERVACIONES,         DATE_MODIFIED       =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') ,        MODIFIED_BY         =:MODIFIED_BY   WHERE COMPANIA            = :COMPANIA     AND ANO                 = :ANO     AND CODIGO              = :CODCUENTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAINICIAL" sqlType="STRING"/>
		<param name="SALDOEXTRACTO" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="planescontables/updateplancontabledatosconciliacion">
		<call-query href="updatePlanescontablesUpdateplancontabledatosconciliacion">
			<with-param name="FECHAINICIAL" query-param="FECHAINICIAL"/>
			<with-param name="SALDOEXTRACTO" query-param="SALDOEXTRACTO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
