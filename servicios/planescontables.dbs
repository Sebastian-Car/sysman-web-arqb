			<with-param name="MES" query-param="MES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPagTodosPorNombreCodigoCompaniaAnoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE FROM V_PLAN_CONTABLE PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA =:COMPANIA AND PLAN_CONTABLE.ANO =:ANIO AND ( CONCAT(TERCERO,CONCAT(SUCURSAL,CONCAT(AUXILIAR,CONCAT(CENTRO_COSTO,CONCAT(REFERENCIA,FUENTE_RECURSO) ) ) ) ) ) IS NULL ORDER BY PLAN_CONTABLE.CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/todospornombrecodigocompaniaano/pag">
		<call-query href="getPlanescontablesPagTodosPorNombreCodigoCompaniaAnoQuery">
