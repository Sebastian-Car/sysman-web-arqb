	<query id="getPlanescontablesPagPcontableChipCodigo6Query"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE PLAN_CONTABLE.NOREPORTARRECIPROCAS WHEN 0 THEN 'false' ELSE 'true' END) NOREPORTARRECIPROCAS, PLAN_CONTABLE.FUENTE, PLAN_CONTABLE.COD_EQUIV,(CASE PLAN_CONTABLE.REPORTAR_100 WHEN 0 THEN 'false' ELSE 'true' END) REPORTAR_100, PLAN_CONTABLE.TERCERO_RECIPROCAS, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CLASECUENTA  FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND PLAN_CONTABLE.CLASECUENTA = CASE WHEN :CLASE IS NOT NULL THEN :CLASE ELSE PLAN_CONTABLE.CLASECUENTA END AND LENGTH(PLAN_CONTABLE.CODIGO) = 6 ORDER BY PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOREPORTARRECIPROCAS) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN NOREPORTARRECIPROCAS IS NULL THEN ' ' ELSE UPPER(NOREPORTARRECIPROCAS) END)  LIKE UPPER(:NOREPORTARRECIPROCAS || '%')  AND (CASE WHEN FUENTE IS NULL THEN ' ' ELSE UPPER(FUENTE) END)  LIKE UPPER(:FUENTE || '%')  AND (CASE WHEN COD_EQUIV IS NULL THEN ' ' ELSE UPPER(COD_EQUIV) END)  LIKE UPPER(:COD_EQUIV || '%')  AND (CASE WHEN REPORTAR_100 IS NULL THEN ' ' ELSE UPPER(REPORTAR_100) END)  LIKE UPPER(:REPORTAR_100 || '%')  AND (CASE WHEN TERCERO_RECIPROCAS IS NULL THEN ' ' ELSE UPPER(TERCERO_RECIPROCAS) END)  LIKE UPPER(:TERCERO_RECIPROCAS || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","NOREPORTARRECIPROCAS":"$NOREPORTARRECIPROCAS(type:boolean)","FUENTE":"$FUENTE","COD_EQUIV":"$COD_EQUIV","REPORTAR_100":"$REPORTAR_100(type:boolean)","TERCERO_RECIPROCAS":"$TERCERO_RECIPROCAS","ANO":"$ANO(type:integer)","CLASECUENTA":"$CLASECUENTA"}]}}		</result>
