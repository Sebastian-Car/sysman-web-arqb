		<param defaultValue="" name="CRE_CAUS_DET" sqlType="STRING"/>
		<param defaultValue="" name="DEB_REC_DET" sqlType="STRING"/>
		<param defaultValue="" name="CRE_REC_DET" sqlType="STRING"/>
		<param defaultValue="" name="DEB_RECO_DET" sqlType="STRING"/>
		<param defaultValue="" name="CRE_RECO_DET" sqlType="STRING"/>
		<param defaultValue="0" name="CUENTAS_MAESTRAS_SALUD" sqlType="STRING"/>
		<param defaultValue="0" name="MOSTRARF1001" sqlType="STRING"/>
		<param defaultValue="" name="DEBITO_REVERSION_DET_ACTUAL" sqlType="STRING"/>
		<param defaultValue="" name="CREDITO_REVERSION_DET_ACTUAL" sqlType="STRING"/>
		<param defaultValue="" name="DEBITO_REVERSION_DET_ANTERIOR" sqlType="STRING"/>
		<param defaultValue="" name="CREDITO_REVERSION_DET_ANTERIOR" sqlType="STRING"/>
