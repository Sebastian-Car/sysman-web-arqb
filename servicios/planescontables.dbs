			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>

		</call-query>
	</resource>
	<query id="getPlanescontablesPagClasecuentanotinsaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO ID, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.CENTRO_COSTO, PLAN_CONTABLE.TERCERO, PLAN_CONTABLE.SUCURSAL, PLAN_CONTABLE.AUXILIAR, PLAN_CONTABLE.REFERENCIA, PLAN_CONTABLE.FUENTE_RECURSO  FROM V_PLAN_CONTABLE PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND ((PLAN_CONTABLE.MOVIMIENTO NOT IN (0) AND PLAN_CONTABLE.CLASECUENTA NOT IN('S', 'A', 'J', 'B', 'P', 'C', 'X', 'O', 'E', 'N')) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0) ) ORDER BY PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.ID) WHERE (CASE WHEN ID IS NULL THEN ' ' ELSE UPPER(ID) END)  LIKE UPPER(:ID || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ID":"$ID","NOMBRE":"$NOMBRE","CENTRO_COSTO":"$CENTRO_COSTO","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","AUXILIAR":"$AUXILIAR","REFERENCIA":"$REFERENCIA","FUENTE_RECURSO":"$FUENTE_RECURSO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="ID" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
