	<query id="getPlanescontablesPagTodosAnoClasecuentaConMovimientoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE, PLAN_CONTABLE.CHEQUE, PLAN_CONTABLE.FORMATOEGRESO  FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = TO_CHAR(SYSDATE, 'YYYY') AND PLAN_CONTABLE.CLASECUENTA = 'B' AND (MOVIMIENTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_GEN NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_TER NOT IN (0) OR PLAN_CONTABLE.MAN_CEN_CTO NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_FUE NOT IN (0) OR PLAN_CONTABLE.MAN_AUX_REF NOT IN (0)) ORDER BY PLAN_CONTABLE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CHEQUE IS NULL THEN ' ' ELSE UPPER(CHEQUE) END)  LIKE UPPER(:CHEQUE || '%')  AND (CASE WHEN FORMATOEGRESO IS NULL THEN ' ' ELSE UPPER(FORMATOEGRESO) END)  LIKE UPPER(:FORMATOEGRESO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","CHEQUE":"$CHEQUE(type:long)","FORMATOEGRESO":"$FORMATOEGRESO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CHEQUE" sqlType="STRING"/>
		<param name="FORMATOEGRESO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="planescontables/todosanoclasecuentaconmovimiento/pag">
