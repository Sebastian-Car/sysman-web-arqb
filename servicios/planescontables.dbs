	<query id="getPlanescontablesPagListaCuentasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PLAN_CONTABLE.CODIGO, PLAN_CONTABLE.NOMBRE,(CASE PLAN_CONTABLE.MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO, PLAN_CONTABLE.CUENTA_PPTAL, PLAN_CONTABLE.CLASECUENTA, PLAN_CONTABLE.NATURALEZA, CASE WHEN MAN_AUX_TER NOT IN ( 0 ) OR OBLIGA_TERCERO NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_TERCERO, CASE WHEN MAN_CEN_CTO NOT IN ( 0 ) OR OBLIGA_CENTRO NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_CENTRO, CASE WHEN MAN_AUX_GEN NOT IN ( 0 ) OR OBLIGA_AUXILIAR NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_AUXILIAR, CASE WHEN MAN_AUX_FUE NOT IN ( 0 ) OR OBLIGA_FUENTE NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_FUENTE, CASE WHEN MAN_AUX_REF NOT IN ( 0 ) OR OBLIGA_REFERENCIA NOT IN ( 0 ) THEN '-1' ELSE '0' END MANEJA_REFERENCIA,(CASE MOSTRARF1001 WHEN 0 THEN 'false' ELSE 'true' END) MOSTRARF1001,(CASE PLAN_CONTABLE.MOSTRAR_EN_FLUJO WHEN 0 THEN 'false' ELSE 'true' END) MOSTRAR_EN_FLUJO FROM PLAN_CONTABLE WHERE PLAN_CONTABLE.COMPANIA = :COMPANIA AND PLAN_CONTABLE.ANO = :ANO AND PLAN_CONTABLE.MOVIMIENTO + PLAN_CONTABLE.MAN_CEN_CTO + PLAN_CONTABLE.MAN_AUX_TER + PLAN_CONTABLE.MAN_AUX_GEN + PLAN_CONTABLE. MAN_AUX_REF + PLAN_CONTABLE.MAN_AUX_FUE &lt;&gt; 0 ORDER BY PLAN_CONTABLE.COMPANIA, PLAN_CONTABLE.ANO, PLAN_CONTABLE.CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN MOVIMIENTO IS NULL THEN ' ' ELSE UPPER(MOVIMIENTO) END)  LIKE UPPER(:MOVIMIENTO || '%')  AND (CASE WHEN CUENTA_PPTAL IS NULL THEN ' ' ELSE UPPER(CUENTA_PPTAL) END)  LIKE UPPER(:CUENTA_PPTAL || '%')  AND (CASE WHEN CLASECUENTA IS NULL THEN ' ' ELSE UPPER(CLASECUENTA) END)  LIKE UPPER(:CLASECUENTA || '%')  AND (CASE WHEN NATURALEZA IS NULL THEN ' ' ELSE UPPER(NATURALEZA) END)  LIKE UPPER(:NATURALEZA || '%')  AND (CASE WHEN MANEJA_TERCERO IS NULL THEN ' ' ELSE UPPER(MANEJA_TERCERO) END)  LIKE UPPER(:MANEJA_TERCERO || '%')  AND (CASE WHEN MANEJA_CENTRO IS NULL THEN ' ' ELSE UPPER(MANEJA_CENTRO) END)  LIKE UPPER(:MANEJA_CENTRO || '%')  AND (CASE WHEN MANEJA_AUXILIAR IS NULL THEN ' ' ELSE UPPER(MANEJA_AUXILIAR) END)  LIKE UPPER(:MANEJA_AUXILIAR || '%')  AND (CASE WHEN MANEJA_FUENTE IS NULL THEN ' ' ELSE UPPER(MANEJA_FUENTE) END)  LIKE UPPER(:MANEJA_FUENTE || '%')  AND (CASE WHEN MANEJA_REFERENCIA IS NULL THEN ' ' ELSE UPPER(MANEJA_REFERENCIA) END)  LIKE UPPER(:MANEJA_REFERENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","CUENTA_PPTAL":"$CUENTA_PPTAL","CLASECUENTA":"$CLASECUENTA","NATURALEZA":"$NATURALEZA","MANEJA_TERCERO":"$MANEJA_TERCERO","MANEJA_CENTRO":"$MANEJA_CENTRO","MANEJA_AUXILIAR":"$MANEJA_AUXILIAR","MANEJA_FUENTE":"$MANEJA_FUENTE","MANEJA_REFERENCIA":"$MANEJA_REFERENCIA","MOSTRARF1001":"$MOSTRARF1001(type:boolean)","MOSTRAR_EN_FLUJO":"$MOSTRAR_EN_FLUJO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="MOVIMIENTO" sqlType="STRING"/>
		<param name="CUENTA_PPTAL" sqlType="STRING"/>
		<param name="CLASECUENTA" sqlType="STRING"/>
		<param name="NATURALEZA" sqlType="STRING"/>
		<param name="MANEJA_TERCERO" sqlType="STRING"/>
		<param name="MANEJA_CENTRO" sqlType="STRING"/>
		<param name="MANEJA_AUXILIAR" sqlType="STRING"/>
		<param name="MANEJA_FUENTE" sqlType="STRING"/>
		<param name="MANEJA_REFERENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
