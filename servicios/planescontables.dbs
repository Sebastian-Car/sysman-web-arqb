	<query id="getPlanescontablesCodigopredecesorQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NATURALEZA, CLASECUENTA,(CASE MOVIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) MOVIMIENTO,(CASE MAN_CEN_CTO WHEN 0 THEN 'false' ELSE 'true' END) MAN_CEN_CTO,(CASE MAN_AUX_TER WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_TER,(CASE MAN_AUX_GEN WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_GEN,(CASE MAN_AUX_FUE WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_FUE,(CASE MAN_AUX_REF WHEN 0 THEN 'false' ELSE 'true' END) MAN_AUX_REF FROM PLAN_CONTABLE WHERE COMPANIA = :COMPANIA AND ANO = :ANIO AND CODIGO = SUBSTR(:CODIGO,1,LENGTH(CODIGO)) AND LENGTH(CODIGO) &lt;= :CANTCODIGO ORDER BY COMPANIA, ANO, CODIGO DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NATURALEZA":"$NATURALEZA","CLASECUENTA":"$CLASECUENTA","MOVIMIENTO":"$MOVIMIENTO(type:boolean)","MAN_CEN_CTO":"$MAN_CEN_CTO(type:boolean)","MAN_AUX_TER":"$MAN_AUX_TER(type:boolean)","MAN_AUX_GEN":"$MAN_AUX_GEN(type:boolean)","MAN_AUX_FUE":"$MAN_AUX_FUE(type:boolean)","MAN_AUX_REF":"$MAN_AUX_REF(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANIO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CANTCODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="planescontables/codigopredecesor">
		<call-query href="getPlanescontablesCodigopredecesorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANIO" query-param="ANIO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CANTCODIGO" query-param="CANTCODIGO"/>

		</call-query>
	</resource>
