			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MESINICIAL" query-param="MESINICIAL"/>
			<with-param name="NITDIAN" query-param="NITDIAN"/>

		</call-query>
	</resource>
	<query id="updatePlanescontablesActualizarCuentasHijas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PLAN_CONTABLE SET NOREPORTARRECIPROCAS = :RECIPROCAS, DATE_MODIFIED = SYSDATE , MODIFIED_BY = :MODIFIED_BY  WHERE COMPANIA = :COMPANIA AND ANO = :ANO AND CODIGO LIKE CONCAT(:CODIGO,'%')</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="RECIPROCAS" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
