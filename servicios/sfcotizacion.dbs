	<query id="getSfcotizacionRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SF_COTIZACION.COMPANIA, SF_COTIZACION.TIPO, SF_COTIZACION.NUMERO,(TO_CHAR(SF_COTIZACION.FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD, SF_COTIZACION.TERCERO, SF_COTIZACION.SUCURSAL, SF_COTIZACION.CENTRO_COSTO, SF_COTIZACION.AUXILIAR,(TO_CHAR(SF_COTIZACION.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, SF_COTIZACION.VALOR_BASE, SF_COTIZACION.VALOR_IVA, SF_COTIZACION.VALOR_RETE, SF_COTIZACION.VALOR_ICA, SF_COTIZACION.VALOR_DESCUENTO, SF_COTIZACION.VALOR_TOTAL, SF_COTIZACION.TOTAL_TCOTIZADO, SF_COTIZACION.OBJETO_COTIZACION, SF_COTIZACION.TIEMPO_COTIZADO, SF_COTIZACION.TIPOCONTRATO, SF_COTIZACION.NUMCONTRATO, SF_COTIZACION.FORMA_PAGO, SF_COTIZACION.CREATED_BY,(TO_CHAR(SF_COTIZACION.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, SF_COTIZACION.MODIFIED_BY,(TO_CHAR(SF_COTIZACION.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SF_COTIZACION.ANOCONTRATO, TERCERO.NOMBRE NOMBRE_TERCERO, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO, AUXILIAR.NOMBRE NOMBRE_AUX, TERCERO.NUMEROLISTA,SF_COTIZACION.PORC_FONDO, SF_COTIZACION.EDIFICIO, SF_COTIZACION.ESTADO, SF_COTIZACION.TOTAL_PERIODO, SF_COTIZACION.TOTAL_CONTRATO ,SF_COTIZACION.TOTAL_AREA FROM SF_COTIZACION LEFT JOIN TERCERO ON SF_COTIZACION.COMPANIA=TERCERO.COMPANIA AND SF_COTIZACION.TERCERO = TERCERO.NIT LEFT JOIN CENTRO_COSTO ON SF_COTIZACION.COMPANIA=CENTRO_COSTO.COMPANIA AND SF_COTIZACION.CENTRO_COSTO=CENTRO_COSTO.CODIGO LEFT JOIN AUXILIAR ON SF_COTIZACION.COMPANIA=AUXILIAR.COMPANIA AND SF_COTIZACION.AUXILIAR=AUXILIAR.CODIGO WHERE SF_COTIZACION.COMPANIA= :KEY_COMPANIA AND SF_COTIZACION.TIPO= :KEY_TIPO AND SF_COTIZACION.NUMERO= :KEY_NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA_SOLICITUD":"$FECHA_SOLICITUD","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_ICA":"$VALOR_ICA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_TOTAL":"$VALOR_TOTAL","TOTAL_TCOTIZADO":"$TOTAL_TCOTIZADO","OBJETO_COTIZACION":"$OBJETO_COTIZACION","TIEMPO_COTIZADO":"$TIEMPO_COTIZADO","TIPOCONTRATO":"$TIPOCONTRATO","NUMCONTRATO":"$NUMCONTRATO(type:long)","FORMA_PAGO":"$FORMA_PAGO","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","ANOCONTRATO":"$ANOCONTRATO(type:integer)","NOMBRE_TERCERO":"$NOMBRE_TERCERO","NOMBRE_CENTRO":"$NOMBRE_CENTRO","NOMBRE_AUX":"$NOMBRE_AUX","NUMEROLISTA":"$NUMEROLISTA","PORC_FONDO":"$PORC_FONDO","EDIFICIO":"$EDIFICIO(type:integer)","ESTADO":"$ESTADO(type:integer)","TOTAL_PERIODO":"$TOTAL_PERIODO","TOTAL_CONTRATO":"$TOTAL_CONTRATO","TOTAL_AREA":"$TOTAL_AREA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcotizacion/data">
		<call-query href="getSfcotizacionRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateSfcotizacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_COTIZACION SET FECHA_SOLICITUD=TO_DATE(:FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS'), TERCERO=:TERCERO, CENTRO_COSTO=:CENTRO_COSTO, AUXILIAR=:AUXILIAR, FECHA_VENCIMIENTO=TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), TOTAL_TCOTIZADO=:TOTAL_TCOTIZADO, OBJETO_COTIZACION=:OBJETO_COTIZACION, TIEMPO_COTIZADO=:TIEMPO_COTIZADO, FORMA_PAGO = :FORMA_PAGO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), PORC_FONDO=:PORC_FONDO, EDIFICIO=:EDIFICIO, ESTADO=:ESTADO, TOTAL_PERIODO=:TOTAL_PERIODO, TOTAL_CONTRATO=:TOTAL_CONTRATO, TOTAL_AREA=:TOTAL_AREA WHERE SF_COTIZACION.COMPANIA= :KEY_COMPANIA AND SF_COTIZACION.TIPO= :KEY_TIPO AND SF_COTIZACION.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FECHA_VENCIMIENTO" sqlType="STRING"/>
		<param name="TOTAL_TCOTIZADO" sqlType="STRING"/>
		<param name="OBJETO_COTIZACION" sqlType="STRING"/>
		<param name="TIEMPO_COTIZADO" sqlType="STRING"/>
		<param name="FORMA_PAGO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="PORC_FONDO" sqlType="STRING"/>
		<param name="EDIFICIO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="TOTAL_PERIODO" sqlType="STRING"/>
		<param name="TOTAL_CONTRATO" sqlType="STRING"/>
		<param name="TOTAL_AREA" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfcotizacion">
		<call-query href="updateSfcotizacion">
			<with-param name="FECHA_SOLICITUD" query-param="FECHA_SOLICITUD"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="FECHA_VENCIMIENTO" query-param="FECHA_VENCIMIENTO"/>
			<with-param name="TOTAL_TCOTIZADO" query-param="TOTAL_TCOTIZADO"/>
			<with-param name="OBJETO_COTIZACION" query-param="OBJETO_COTIZACION"/>
			<with-param name="TIEMPO_COTIZADO" query-param="TIEMPO_COTIZADO"/>
			<with-param name="FORMA_PAGO" query-param="FORMA_PAGO"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="PORC_FONDO" query-param="PORC_FONDO"/>
			<with-param name="EDIFICIO" query-param="EDIFICIO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="TOTAL_PERIODO" query-param="TOTAL_PERIODO"/>
			<with-param name="TOTAL_CONTRATO" query-param="TOTAL_CONTRATO"/>
			<with-param name="TOTAL_AREA" query-param="TOTAL_AREA"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="getSfcotizacionPagCotizacionescaducadasQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT C.COMPANIA, C.TIPO, C.NUMERO, C.TERCERO, T.NOMBRE NOMBRETERCERO, TO_CHAR(C.FECHA_VENCIMIENTO,'DD/MM/YYYY') AS FECHA,(CASE C.CAMBIAR_ESTADO WHEN 0 THEN 'false' ELSE 'true' END) CAMBIAR_ESTADO FROM SF_COTIZACION C LEFT JOIN TERCERO T ON C.COMPANIA = T.COMPANIA AND C.TERCERO = T.NIT AND C.SUCURSAL = T.SUCURSAL WHERE C.COMPANIA = :COMPANIA AND C.FECHA_VENCIMIENTO &lt;= :FECHACORTE AND C.ESTADO IN (1,2) ORDER BY C.COMPANIA, C.TIPO, C.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN CAMBIAR_ESTADO IS NULL THEN ' ' ELSE UPPER(CAMBIAR_ESTADO) END) LIKE UPPER(CONCAT(:CAMBIAR_ESTADO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","TERCERO":"$TERCERO","NOMBRETERCERO":"$NOMBRETERCERO","FECHA":"$FECHA","CAMBIAR_ESTADO":"$CAMBIAR_ESTADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CAMBIAR_ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcotizacion/cotizacionescaducadas/pag">
		<call-query href="getSfcotizacionPagCotizacionescaducadasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CAMBIAR_ESTADO" query-param="CAMBIAR_ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfcotizacionNumCotizacionescaducadasQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT C.COMPANIA, C.TIPO, C.NUMERO, C.TERCERO, T.NOMBRE NOMBRETERCERO, TO_CHAR(C.FECHA_VENCIMIENTO,'DD/MM/YYYY') AS FECHA,(CASE C.CAMBIAR_ESTADO WHEN 0 THEN 'false' ELSE 'true' END) CAMBIAR_ESTADO FROM SF_COTIZACION C LEFT JOIN TERCERO T ON C.COMPANIA = T.COMPANIA AND C.TERCERO = T.NIT AND C.SUCURSAL = T.SUCURSAL WHERE C.COMPANIA = :COMPANIA AND C.FECHA_VENCIMIENTO &lt;= :FECHACORTE AND C.ESTADO IN (1,2) ORDER BY C.COMPANIA, C.TIPO, C.NUMERO) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(:TERCERO, '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END) LIKE UPPER(CONCAT(:FECHA, '%')) AND (CASE WHEN CAMBIAR_ESTADO IS NULL THEN ' ' ELSE UPPER(CAMBIAR_ESTADO) END) LIKE UPPER(CONCAT(:CAMBIAR_ESTADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="CAMBIAR_ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcotizacion/cotizacionescaducadas/num">
		<call-query href="getSfcotizacionNumCotizacionescaducadasQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="TERCERO" query-param="TERCERO"/>
			<with-param name="NOMBRETERCERO" query-param="NOMBRETERCERO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="CAMBIAR_ESTADO" query-param="CAMBIAR_ESTADO"/>

		</call-query>
	</resource>
	<query id="updateSfcotizacionCambiarestado" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_COTIZACION SET CAMBIAR_ESTADO=:CAMBIAR_ESTADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SF_COTIZACION.COMPANIA= :KEY_COMPANIA AND SF_COTIZACION.TIPO= :KEY_TIPO AND SF_COTIZACION.NUMERO= :KEY_NUMERO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CAMBIAR_ESTADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_TIPO" sqlType="STRING"/>
		<param name="KEY_NUMERO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfcotizacion/cambiarestado">
		<call-query href="updateSfcotizacionCambiarestado">
			<with-param name="CAMBIAR_ESTADO" query-param="CAMBIAR_ESTADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
