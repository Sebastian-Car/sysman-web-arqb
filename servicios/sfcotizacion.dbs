		<param name="TERCERO" sqlType="STRING"/>
		<param name="NOMBRETERCERO" sqlType="STRING"/>
		<param name="TOTAL_TCOTIZADO" sqlType="STRING"/>
		<param name="PORC_FONDO" sqlType="STRING"/>
		<param name="TOTAL_PERIODO" sqlType="STRING"/>
		<param name="TOTAL_AREA" sqlType="STRING"/>
		<param name="EDIFICIO" sqlType="STRING"/>

	</query>
