	<query id="insertSfcotizacion" keyColumns="COMPANIA,TIPO,NUMERO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SF_COTIZACION (AUXILIAR, FECHA_SOLICITUD, TOTAL_TCOTIZADO, TERCERO, OBJETO_COTIZACION, TIEMPO_COTIZADO, COMPANIA, TIPO, NUMERO, FECHA_VENCIMIENTO, CENTRO_COSTO, ANOCONTRATO, SUCURSAL, FORMA_PAGO, CREATED_BY, DATE_CREATED, PORC_FONDO, EDIFICIO, ESTADO, TOTAL_PERIODO, TOTAL_CONTRATO, TOTAL_AREA) VALUES (:AUXILIAR, TO_DATE(:FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS'), :TOTAL_TCOTIZADO, :TERCERO, :OBJETO_COTIZACION, :TIEMPO_COTIZADO, :COMPANIA, :TIPO, :NUMERO, TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :CENTRO_COSTO, :ANOCONTRATO, :SUCURSAL, :FORMA_PAGO, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :PORC_FONDO, :EDIFICIO, :ESTADO, :TOTAL_PERIODO, :TOTAL_CONTRATO, :TOTAL_AREA)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)"}]}}		</result>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param defaultValue="0" name="TOTAL_TCOTIZADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="TERCERO" sqlType="STRING"/>
		<param name="OBJETO_COTIZACION" sqlType="STRING"/>
		<param defaultValue="0" name="TIEMPO_COTIZADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_VENCIMIENTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="ANOCONTRATO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="FORMA_PAGO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param defaultValue="0" name="PORC_FONDO" sqlType="STRING"/>
		<param defaultValue="" name="EDIFICIO" sqlType="STRING"/>
		<param defaultValue="" name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="TOTAL_PERIODO" sqlType="STRING"/>
		<param defaultValue="" name="TOTAL_CONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="TOTAL_AREA" sqlType="STRING"/>

	</query>
