	<query id="getSfcotizacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, TIPO, NUMERO,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD, TIEMPO_COTIZADO, EXTRACT(YEAR FROM FECHA_SOLICITUD) ANO FROM SF_COTIZACION WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA_SOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHA_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_SOLICITUD), '%')) AND (CASE WHEN TIEMPO_COTIZADO IS NULL THEN ' ' ELSE UPPER(TIEMPO_COTIZADO) END) LIKE UPPER(CONCAT(:TIEMPO_COTIZADO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA_SOLICITUD":"$FECHA_SOLICITUD","TIEMPO_COTIZADO":"$TIEMPO_COTIZADO","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param name="TIEMPO_COTIZADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcotizacion">
		<call-query href="getSfcotizacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="FECHA_SOLICITUD" query-param="FECHA_SOLICITUD"/>
			<with-param name="TIEMPO_COTIZADO" query-param="TIEMPO_COTIZADO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSfcotizacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, TIPO, NUMERO,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD, TIEMPO_COTIZADO, EXTRACT(YEAR FROM FECHA_SOLICITUD) ANO FROM SF_COTIZACION WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(:NUMERO, '%')) AND (CASE WHEN FECHA_SOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHA_SOLICITUD) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_SOLICITUD), '%')) AND (CASE WHEN TIEMPO_COTIZADO IS NULL THEN ' ' ELSE UPPER(TIEMPO_COTIZADO) END) LIKE UPPER(CONCAT(:TIEMPO_COTIZADO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param name="TIEMPO_COTIZADO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>

	</query>
