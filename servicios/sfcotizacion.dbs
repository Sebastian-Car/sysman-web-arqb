<data name="sfcotizacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSfcotizacionConsultasfcotizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, TIPO, NUMERO,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR,(TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_ICA, VALOR_DESCUENTO, VALOR_TOTAL, TOTAL_TCOTIZADO, OBJETO_COTIZACION, TIEMPO_COTIZADO, TIPOCONTRATO, NUMCONTRATO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ANOCONTRATO  FROM SF_COTIZACION WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA_SOLICITUD":"$FECHA_SOLICITUD","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_ICA":"$VALOR_ICA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_TOTAL":"$VALOR_TOTAL","TOTAL_TCOTIZADO":"$TOTAL_TCOTIZADO","OBJETO_COTIZACION":"$OBJETO_COTIZACION","TIEMPO_COTIZADO":"$TIEMPO_COTIZADO","TIPOCONTRATO":"$TIPOCONTRATO","NUMCONTRATO":"$NUMCONTRATO(type:long)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","ANOCONTRATO":"$ANOCONTRATO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcotizacion/consultasfcotizacion">
		<call-query href="getSfcotizacionConsultasfcotizacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSfcotizacionConsultabuscarcotizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(TIPO,CONCAT(' - ',NUMERO) ) COT, TIPO, NUMERO,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD, OBJETO_COTIZACION FROM SF_COTIZACION WHERE COMPANIA =:COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COT":"$COT","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA_SOLICITUD":"$FECHA_SOLICITUD","OBJETO_COTIZACION":"$OBJETO_COTIZACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="sfcotizacion/consultabuscarcotizacion">
		<call-query href="getSfcotizacionConsultabuscarcotizacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSfcotizacionPagConsultasfcotizacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, TIPO, NUMERO,(TO_CHAR(FECHA_SOLICITUD,'DD/MM/YYYY HH24:MI:SS')) FECHA_SOLICITUD, TERCERO, SUCURSAL, CENTRO_COSTO, AUXILIAR,(TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, VALOR_BASE, VALOR_IVA, VALOR_RETE, VALOR_ICA, VALOR_DESCUENTO, VALOR_TOTAL, TOTAL_TCOTIZADO, OBJETO_COTIZACION, TIEMPO_COTIZADO, TIPOCONTRATO, NUMCONTRATO, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, ANOCONTRATO  FROM SF_COTIZACION WHERE COMPANIA = :COMPANIA) WHERE (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END)  LIKE UPPER( '%' || :TIPO || '%')  AND (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END)  LIKE UPPER(:NUMERO || '%')  AND (CASE WHEN FECHA_SOLICITUD IS NULL THEN ' ' ELSE UPPER(FECHA_SOLICITUD) END)  LIKE UPPER(:FECHA_SOLICITUD || '%')  AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END)  LIKE UPPER(:TERCERO || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END)  LIKE UPPER(:CENTRO_COSTO || '%')  AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END)  LIKE UPPER(:AUXILIAR || '%')  AND (CASE WHEN FECHA_VENCIMIENTO IS NULL THEN ' ' ELSE UPPER(FECHA_VENCIMIENTO) END)  LIKE UPPER(:FECHA_VENCIMIENTO || '%')  AND (CASE WHEN VALOR_BASE IS NULL THEN ' ' ELSE UPPER(VALOR_BASE) END)  LIKE UPPER(:VALOR_BASE || '%')  AND (CASE WHEN VALOR_IVA IS NULL THEN ' ' ELSE UPPER(VALOR_IVA) END)  LIKE UPPER(:VALOR_IVA || '%')  AND (CASE WHEN VALOR_RETE IS NULL THEN ' ' ELSE UPPER(VALOR_RETE) END)  LIKE UPPER(:VALOR_RETE || '%')  AND (CASE WHEN VALOR_ICA IS NULL THEN ' ' ELSE UPPER(VALOR_ICA) END)  LIKE UPPER(:VALOR_ICA || '%')  AND (CASE WHEN VALOR_DESCUENTO IS NULL THEN ' ' ELSE UPPER(VALOR_DESCUENTO) END)  LIKE UPPER(:VALOR_DESCUENTO || '%')  AND (CASE WHEN VALOR_TOTAL IS NULL THEN ' ' ELSE UPPER(VALOR_TOTAL) END)  LIKE UPPER(:VALOR_TOTAL || '%')  AND (CASE WHEN TOTAL_TCOTIZADO IS NULL THEN ' ' ELSE UPPER(TOTAL_TCOTIZADO) END)  LIKE UPPER(:TOTAL_TCOTIZADO || '%')  AND (CASE WHEN OBJETO_COTIZACION IS NULL THEN ' ' ELSE UPPER(OBJETO_COTIZACION) END)  LIKE UPPER( '%' || :OBJETO_COTIZACION || '%')  AND (CASE WHEN TIEMPO_COTIZADO IS NULL THEN ' ' ELSE UPPER(TIEMPO_COTIZADO) END)  LIKE UPPER(:TIEMPO_COTIZADO || '%')  AND (CASE WHEN TIPOCONTRATO IS NULL THEN ' ' ELSE UPPER(TIPOCONTRATO) END)  LIKE UPPER( '%' || :TIPOCONTRATO || '%')  AND (CASE WHEN NUMCONTRATO IS NULL THEN ' ' ELSE UPPER(NUMCONTRATO) END)  LIKE UPPER(:NUMCONTRATO || '%')  AND (CASE WHEN CREATED_BY IS NULL THEN ' ' ELSE UPPER(CREATED_BY) END)  LIKE UPPER( '%' || :CREATED_BY || '%')  AND (CASE WHEN DATE_CREATED IS NULL THEN ' ' ELSE UPPER(DATE_CREATED) END)  LIKE UPPER(:DATE_CREATED || '%')  AND (CASE WHEN MODIFIED_BY IS NULL THEN ' ' ELSE UPPER(MODIFIED_BY) END)  LIKE UPPER( '%' || :MODIFIED_BY || '%')  AND (CASE WHEN DATE_MODIFIED IS NULL THEN ' ' ELSE UPPER(DATE_MODIFIED) END)  LIKE UPPER(:DATE_MODIFIED || '%')  AND (CASE WHEN ANOCONTRATO IS NULL THEN ' ' ELSE UPPER(ANOCONTRATO) END)  LIKE UPPER(:ANOCONTRATO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","FECHA_SOLICITUD":"$FECHA_SOLICITUD","TERCERO":"$TERCERO","SUCURSAL":"$SUCURSAL","CENTRO_COSTO":"$CENTRO_COSTO","AUXILIAR":"$AUXILIAR","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","VALOR_BASE":"$VALOR_BASE","VALOR_IVA":"$VALOR_IVA","VALOR_RETE":"$VALOR_RETE","VALOR_ICA":"$VALOR_ICA","VALOR_DESCUENTO":"$VALOR_DESCUENTO","VALOR_TOTAL":"$VALOR_TOTAL","TOTAL_TCOTIZADO":"$TOTAL_TCOTIZADO","OBJETO_COTIZACION":"$OBJETO_COTIZACION","TIEMPO_COTIZADO":"$TIEMPO_COTIZADO","TIPOCONTRATO":"$TIPOCONTRATO","NUMCONTRATO":"$NUMCONTRATO(type:long)","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","ANOCONTRATO":"$ANOCONTRATO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="FECHA_SOLICITUD" sqlType="STRING"/>
		<param name="TERCERO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="FECHA_VENCIMIENTO" sqlType="STRING"/>
		<param name="VALOR_BASE" sqlType="STRING"/>
		<param name="VALOR_IVA" sqlType="STRING"/>
		<param name="VALOR_RETE" sqlType="STRING"/>
		<param name="VALOR_ICA" sqlType="STRING"/>
		<param name="VALOR_DESCUENTO" sqlType="STRING"/>
		<param name="VALOR_TOTAL" sqlType="STRING"/>
		<param name="TOTAL_TCOTIZADO" sqlType="STRING"/>
		<param name="OBJETO_COTIZACION" sqlType="STRING"/>
		<param name="TIEMPO_COTIZADO" sqlType="STRING"/>
		<param name="TIPOCONTRATO" sqlType="STRING"/>
		<param name="NUMCONTRATO" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="ANOCONTRATO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="sfcotizacion/consultasfcotizacion/pag">
		<call-query href="getSfcotizacionPagConsultasfcotizacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
