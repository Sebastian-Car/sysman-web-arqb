			<with-param name="KEY_TIPO" query-param="KEY_TIPO"/>
			<with-param name="KEY_NUMERO" query-param="KEY_NUMERO"/>

		</call-query>
	</resource>
	<query id="updateSfcotizacionCambiarcancelada" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_COTIZACION SET ESTADO = '5' WHERE COMPANIA = :COMPANIA AND FECHA_VENCIMIENTO &lt;= :FECHACORTE AND CAMBIAR_ESTADO NOT IN (0) AND ESTADO IN (1,2)</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfcotizacion/cambiarcancelada">
		<call-query href="updateSfcotizacionCambiarcancelada">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>

		</call-query>
	</resource>
	<query id="updateSfcotizacionCambiarestadotodos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SF_COTIZACION SET CAMBIAR_ESTADO = '-1' WHERE COMPANIA = :COMPANIA AND (FECHA_VENCIMIENTO &lt;= :FECHACORTE AND FECHA_VENCIMIENTO = CASE WHEN :VALOR = 1 THEN TO_DATE(:FECHA,'DD/MM/YYYY') ELSE FECHA_VENCIMIENTO END) AND ESTADO IN ( 1, 2 )</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="FECHACORTE" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="sfcotizacion/cambiarestadotodos">
		<call-query href="updateSfcotizacionCambiarestadotodos">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="FECHACORTE" query-param="FECHACORTE"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA" query-param="FECHA"/>

