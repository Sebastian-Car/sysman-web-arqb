	<query id="getSfcotizacionNumGetcotizacionesestadoaprobadaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SF_COTIZACION.NUMERO, SF_COTIZACION.TIPO, SF_COTIZACION.TIEMPO_COTIZADO, SF_COTIZACION.TERCERO, (SELECT NOMBRE FROM TERCERO WHERE NIT = SF_COTIZACION.TERCERO) NOMBRETERCERO, SF_COTIZACION.TOTAL_TCOTIZADO, SF_COTIZACION.PORC_FONDO, SF_COTIZACION.TOTAL_PERIODO, SF_COTIZACION.TOTAL_AREA, SF_COTIZACION.EDIFICIO FROM SF_COTIZACION LEFT JOIN SF_CONTRATOS ON ( SF_COTIZACION.COMPANIA = SF_CONTRATOS.COMPANIA AND SF_COTIZACION.TIPO = SF_CONTRATOS.TIPOCOTIZACION AND SF_COTIZACION.NUMERO = SF_CONTRATOS.NUMCOTIZACION) WHERE SF_COTIZACION.COMPANIA = :COMPANIA AND SF_COTIZACION.ESTADO = 3 AND NUMCOTIZACION IS NULL) INI WHERE (CASE WHEN NUMERO IS NULL THEN ' ' ELSE UPPER(NUMERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERO), '%')) AND (CASE WHEN TIPO IS NULL THEN ' ' ELSE UPPER(TIPO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO), '%')) AND (CASE WHEN TIEMPO_COTIZADO IS NULL THEN ' ' ELSE UPPER(TIEMPO_COTIZADO) END) LIKE UPPER(CONCAT(CONCAT('%',:TIEMPO_COTIZADO), '%')) AND (CASE WHEN TERCERO IS NULL THEN ' ' ELSE UPPER(TERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:TERCERO), '%')) AND (CASE WHEN NOMBRETERCERO IS NULL THEN ' ' ELSE UPPER(NOMBRETERCERO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRETERCERO), '%')) AND (CASE WHEN TOTAL_TCOTIZADO IS NULL THEN ' ' ELSE UPPER(TOTAL_TCOTIZADO) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTAL_TCOTIZADO), '%')) AND (CASE WHEN PORC_FONDO IS NULL THEN ' ' ELSE UPPER(PORC_FONDO) END) LIKE UPPER(CONCAT(CONCAT('%',:PORC_FONDO), '%')) AND (CASE WHEN TOTAL_PERIODO IS NULL THEN ' ' ELSE UPPER(TOTAL_PERIODO) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTAL_PERIODO), '%')) AND (CASE WHEN TOTAL_AREA IS NULL THEN ' ' ELSE UPPER(TOTAL_AREA) END) LIKE UPPER(CONCAT(CONCAT('%',:TOTAL_AREA), '%')) AND (CASE WHEN EDIFICIO IS NULL THEN ' ' ELSE UPPER(EDIFICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:EDIFICIO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
