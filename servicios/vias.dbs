	<query id="getViasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_VIA, NOMBRE, CLASE_VIA, ANCHO_VIA, NO_TRAMO, ESTADO, INICIO_TRAMO, FIN_TRAMO, SECTOR, LONG_SARNEL_SEPDOR, COD_FOTO, RUTA_FOTO, COD_PLANO, RUTA_PLANO, SERIE_PLACA, COD_INVENTARIO, RESPONSABLE, SUCURSAL, OBSERVACIONES, MODIFIED_BY, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM VIAS WHERE VIAS.COMPANIA= :KEY_COMPANIA AND VIAS.ID_VIA= :KEY_ID_VIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_VIA":"$ID_VIA","NOMBRE":"$NOMBRE","CLASE_VIA":"$CLASE_VIA","ANCHO_VIA":"$ANCHO_VIA","NO_TRAMO":"$NO_TRAMO","ESTADO":"$ESTADO","INICIO_TRAMO":"$INICIO_TRAMO","FIN_TRAMO":"$FIN_TRAMO","SECTOR":"$SECTOR","LONG_SARNEL_SEPDOR":"$LONG_SARNEL_SEPDOR","COD_FOTO":"$COD_FOTO","RUTA_FOTO":"$RUTA_FOTO","COD_PLANO":"$COD_PLANO","RUTA_PLANO":"$RUTA_PLANO","SERIE_PLACA":"$SERIE_PLACA(type:long)","COD_INVENTARIO":"$COD_INVENTARIO","RESPONSABLE":"$RESPONSABLE","SUCURSAL":"$SUCURSAL","OBSERVACIONES":"$OBSERVACIONES","MODIFIED_BY":"$MODIFIED_BY","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vias/data">
