			<with-param name="KEY_ID_VIA" query-param="KEY_ID_VIA"/>

		</call-query>
	</resource>
	<query id="updateVias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE VIAS SET NOMBRE=:NOMBRE, CLASE_VIA=:CLASE_VIA, ANCHO_VIA=:ANCHO_VIA, NO_TRAMO=:NO_TRAMO, ESTADO=:ESTADO, INICIO_TRAMO=:INICIO_TRAMO, FIN_TRAMO=:FIN_TRAMO, SECTOR=:SECTOR, LONG_SARNEL_SEPDOR=:LONG_SARNEL_SEPDOR, COD_FOTO=:COD_FOTO, RUTA_FOTO=:RUTA_FOTO, COD_PLANO=:COD_PLANO, RUTA_PLANO=:RUTA_PLANO, SERIE_PLACA=:SERIE_PLACA, COD_INVENTARIO=:COD_INVENTARIO, RESPONSABLE=:RESPONSABLE, SUCURSAL=:SUCURSAL, OBSERVACIONES=:OBSERVACIONES, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE VIAS.COMPANIA= :KEY_COMPANIA AND VIAS.ID_VIA= :KEY_ID_VIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_VIA" sqlType="STRING"/>
		<param name="ANCHO_VIA" sqlType="STRING"/>
		<param name="NO_TRAMO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="INICIO_TRAMO" sqlType="STRING"/>
		<param name="FIN_TRAMO" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="LONG_SARNEL_SEPDOR" sqlType="STRING"/>
		<param name="COD_FOTO" sqlType="STRING"/>
		<param name="RUTA_FOTO" sqlType="STRING"/>
		<param name="COD_PLANO" sqlType="STRING"/>
		<param name="RUTA_PLANO" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="COD_INVENTARIO" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vias">
