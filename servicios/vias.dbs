	<query id="getViasPagTodosConElementoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VIAS.ID_VIA SELECCION , VIAS.NOMBRE , TIPO_VIA.DESCRIPCION , VIAS.SERIE_PLACA , VIAS.NO_TRAMO , DEVOLUTIVO.ELEMENTO ,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA FROM VIAS INNER JOIN TIPO_VIA ON VIAS.COMPANIA = TIPO_VIA.COMPANIA AND VIAS.CLASE_VIA = TIPO_VIA.CODIGO_TIPO LEFT JOIN DEVOLUTIVO ON VIAS.COMPANIA = DEVOLUTIVO.COMPANIA AND VIAS.SERIE_PLACA = DEVOLUTIVO.SERIE WHERE VIAS.COMPANIA= :COMPANIA ORDER BY ID_VIA) WHERE (CASE WHEN SELECCION IS NULL THEN ' ' ELSE UPPER(SELECCION) END)  LIKE UPPER(:SELECCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SELECCION":"$SELECCION","NOMBRE":"$NOMBRE","DESCRIPCION":"$DESCRIPCION","SERIE_PLACA":"$SERIE_PLACA(type:long)","NO_TRAMO":"$NO_TRAMO","ELEMENTO":"$ELEMENTO","PLACAANULADA":"$PLACAANULADA(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SELECCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vias/todosconelementoporcompania/pag">
		<call-query href="getViasPagTodosConElementoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SELECCION" query-param="SELECCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViasNumTodosConElementoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VIAS.ID_VIA SELECCION , VIAS.NOMBRE , TIPO_VIA.DESCRIPCION , VIAS.SERIE_PLACA , VIAS.NO_TRAMO , DEVOLUTIVO.ELEMENTO ,(CASE DEVOLUTIVO.PLACAANULADA WHEN 0 THEN 'false' ELSE 'true' END) PLACAANULADA FROM VIAS INNER JOIN TIPO_VIA ON VIAS.COMPANIA = TIPO_VIA.COMPANIA AND VIAS.CLASE_VIA = TIPO_VIA.CODIGO_TIPO LEFT JOIN DEVOLUTIVO ON VIAS.COMPANIA = DEVOLUTIVO.COMPANIA AND VIAS.SERIE_PLACA = DEVOLUTIVO.SERIE WHERE VIAS.COMPANIA= :COMPANIA ORDER BY ID_VIA) WHERE (CASE WHEN SELECCION IS NULL THEN ' ' ELSE UPPER(SELECCION) END)  LIKE UPPER(:SELECCION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SELECCION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vias/todosconelementoporcompania/num">
		<call-query href="getViasNumTodosConElementoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SELECCION" query-param="SELECCION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getViasSoloNomterceroInnerTerceroPorIdviaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TERCERO.NOMBRE  FROM VIAS LEFT JOIN TERCERO ON VIAS.COMPANIA =TERCERO.COMPANIA AND VIAS.RESPONSABLE=TERCERO.NIT AND VIAS.SUCURSAL =TERCERO.SUCURSAL WHERE VIAS.COMPANIA = :COMPANIA AND VIAS.ID_VIA = :ID_VIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vias/solonomterceroinnerterceroporidvia">
		<call-query href="getViasSoloNomterceroInnerTerceroPorIdviaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>

		</call-query>
	</resource>
	<query id="getViasCantPorSerieplacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CUENTA  FROM VIAS WHERE COMPANIA = :COMPANIA AND SERIE_PLACA = :SERIE_PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vias/cantporserieplaca">
		<call-query href="getViasCantPorSerieplacaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>

		</call-query>
	</resource>
	<query id="getViasTodosPorCompaniaSeriePlacaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  DISTINCT 'X' AS x  FROM VIAS WHERE COMPANIA = :COMPANIA AND SERIE_PLACA = :SERIE_PLACA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"X":"$X"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vias/todosporcompaniaserieplaca">
		<call-query href="getViasTodosPorCompaniaSeriePlacaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>

		</call-query>
	</resource>

</data>