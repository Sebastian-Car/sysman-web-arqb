			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID" query-param="ID"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="insertVias" keyColumns="COMPANIA,ID_VIA" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO VIAS (COMPANIA, ID_VIA, NOMBRE, CLASE_VIA, ANCHO_VIA, NO_TRAMO, ESTADO, INICIO_TRAMO, FIN_TRAMO, SECTOR, LONG_SARNEL_SEPDOR, COD_FOTO, RUTA_FOTO, COD_PLANO, RUTA_PLANO, SERIE_PLACA, COD_INVENTARIO, RESPONSABLE, SUCURSAL, OBSERVACIONES, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_VIA, :NOMBRE, :CLASE_VIA, :ANCHO_VIA, :NO_TRAMO, :ESTADO, :INICIO_TRAMO, :FIN_TRAMO, :SECTOR, :LONG_SARNEL_SEPDOR, :COD_FOTO, :RUTA_FOTO, :COD_PLANO, :RUTA_PLANO, :SERIE_PLACA, :COD_INVENTARIO, :RESPONSABLE, :SUCURSAL, :OBSERVACIONES, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_VIA":"$ID_VIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE_VIA" sqlType="STRING"/>
		<param defaultValue="0" name="ANCHO_VIA" sqlType="STRING"/>
		<param name="NO_TRAMO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param defaultValue="" name="INICIO_TRAMO" sqlType="STRING"/>
		<param defaultValue="" name="FIN_TRAMO" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param defaultValue="0" name="LONG_SARNEL_SEPDOR" sqlType="STRING"/>
		<param defaultValue="" name="COD_FOTO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_FOTO" sqlType="STRING"/>
		<param defaultValue="" name="COD_PLANO" sqlType="STRING"/>
		<param defaultValue="" name="RUTA_PLANO" sqlType="STRING"/>
		<param name="SERIE_PLACA" sqlType="STRING"/>
		<param name="COD_INVENTARIO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="vias">
		<call-query href="insertVias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE_VIA" query-param="CLASE_VIA"/>
			<with-param name="ANCHO_VIA" query-param="ANCHO_VIA"/>
			<with-param name="NO_TRAMO" query-param="NO_TRAMO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="INICIO_TRAMO" query-param="INICIO_TRAMO"/>
			<with-param name="FIN_TRAMO" query-param="FIN_TRAMO"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="LONG_SARNEL_SEPDOR" query-param="LONG_SARNEL_SEPDOR"/>
			<with-param name="COD_FOTO" query-param="COD_FOTO"/>
			<with-param name="RUTA_FOTO" query-param="RUTA_FOTO"/>
			<with-param name="COD_PLANO" query-param="COD_PLANO"/>
			<with-param name="RUTA_PLANO" query-param="RUTA_PLANO"/>
			<with-param name="SERIE_PLACA" query-param="SERIE_PLACA"/>
			<with-param name="COD_INVENTARIO" query-param="COD_INVENTARIO"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteVias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM VIAS WHERE VIAS.COMPANIA= :KEY_COMPANIA AND VIAS.ID_VIA= :KEY_ID_VIA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="vias">
		<call-query href="deleteVias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_VIA" query-param="KEY_ID_VIA"/>

		</call-query>
	</resource>
	<query id="getViasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  VIAS.COMPANIA, VIAS.ID_VIA, VIAS.NOMBRE, TIPO_VIA.DESCRIPCION CLASE, ANCHO_VIA, SECTOR_INMUEBLE.DESCRIPCION SECTOR, ESTADO_VIA.DESCRIPCION  FROM VIAS INNER JOIN ESTADO_VIA ON VIAS.COMPANIA = ESTADO_VIA.COMPANIA AND VIAS.ESTADO = ESTADO_VIA.CODIGO_ESTADO INNER JOIN TIPO_VIA ON VIAS.COMPANIA = TIPO_VIA.COMPANIA AND VIAS.CLASE_VIA = TIPO_VIA.CODIGO_TIPO INNER JOIN SECTOR_INMUEBLE ON VIAS.COMPANIA = SECTOR_INMUEBLE.COMPANIA AND VIAS.SECTOR = SECTOR_INMUEBLE.CODIGO_SECTOR WHERE VIAS.COMPANIA = :COMPANIA ORDER BY VIAS.ID_VIA) WHERE (CASE WHEN ID_VIA IS NULL THEN ' ' ELSE UPPER(ID_VIA) END)  LIKE UPPER(:ID_VIA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN ANCHO_VIA IS NULL THEN ' ' ELSE UPPER(ANCHO_VIA) END)  LIKE UPPER(:ANCHO_VIA || '%')  AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END)  LIKE UPPER( '%' || :SECTOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_VIA":"$ID_VIA","NOMBRE":"$NOMBRE","CLASE":"$CLASE","ANCHO_VIA":"$ANCHO_VIA","SECTOR":"$SECTOR","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ANCHO_VIA" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vias">
		<call-query href="getViasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="ANCHO_VIA" query-param="ANCHO_VIA"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getViasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  VIAS.COMPANIA, VIAS.ID_VIA, VIAS.NOMBRE, TIPO_VIA.DESCRIPCION CLASE, ANCHO_VIA, SECTOR_INMUEBLE.DESCRIPCION SECTOR, ESTADO_VIA.DESCRIPCION  FROM VIAS INNER JOIN ESTADO_VIA ON VIAS.COMPANIA = ESTADO_VIA.COMPANIA AND VIAS.ESTADO = ESTADO_VIA.CODIGO_ESTADO INNER JOIN TIPO_VIA ON VIAS.COMPANIA = TIPO_VIA.COMPANIA AND VIAS.CLASE_VIA = TIPO_VIA.CODIGO_TIPO INNER JOIN SECTOR_INMUEBLE ON VIAS.COMPANIA = SECTOR_INMUEBLE.COMPANIA AND VIAS.SECTOR = SECTOR_INMUEBLE.CODIGO_SECTOR WHERE VIAS.COMPANIA = :COMPANIA ORDER BY VIAS.ID_VIA) WHERE (CASE WHEN ID_VIA IS NULL THEN ' ' ELSE UPPER(ID_VIA) END)  LIKE UPPER(:ID_VIA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CLASE IS NULL THEN ' ' ELSE UPPER(CLASE) END)  LIKE UPPER( '%' || :CLASE || '%')  AND (CASE WHEN ANCHO_VIA IS NULL THEN ' ' ELSE UPPER(ANCHO_VIA) END)  LIKE UPPER( '%' || :ANCHO_VIA || '%')  AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END)  LIKE UPPER( '%' || :SECTOR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="ANCHO_VIA" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
