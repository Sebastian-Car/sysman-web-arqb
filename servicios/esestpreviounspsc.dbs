<data name="esestpreviounspsc" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertEsestpreviounspsc" keyColumns="COMPANIA,COD_ESTUDIO,COD_UNSPSC" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_ESTPREVIO_UNSPSC (COMPANIA, COD_ESTUDIO, COD_UNSPSC, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_ESTUDIO, :COD_UNSPSC, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO","KEY_COD_UNSPSC":"$COD_UNSPSC"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="esestpreviounspsc">
		<call-query href="insertEsestpreviounspsc">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEsestpreviounspsc" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_ESTPREVIO_UNSPSC WHERE ES_ESTPREVIO_UNSPSC.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO_UNSPSC.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_ESTPREVIO_UNSPSC.COD_UNSPSC= :KEY_COD_UNSPSC</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_UNSPSC" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="esestpreviounspsc">
		<call-query href="deleteEsestpreviounspsc">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_COD_UNSPSC" query-param="KEY_COD_UNSPSC"/>

		</call-query>
	</resource>
	<query id="getEsestpreviounspscPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_ESTPREVIO_UNSPSC.COMPANIA, ES_ESTPREVIO_UNSPSC.COD_ESTUDIO, ES_ESTPREVIO_UNSPSC.COD_UNSPSC, CODIGOS_UNSPSC.NOMBRE  FROM ES_ESTPREVIO_UNSPSC INNER JOIN CODIGOS_UNSPSC ON ES_ESTPREVIO_UNSPSC.COD_UNSPSC = CODIGOS_UNSPSC.CODIGO AND ES_ESTPREVIO_UNSPSC.COMPANIA = CODIGOS_UNSPSC.COMPANIA WHERE ES_ESTPREVIO_UNSPSC.COMPANIA = :COMPANIA AND ES_ESTPREVIO_UNSPSC.COD_ESTUDIO = :COD_ESTUDIO) WHERE (CASE WHEN COD_UNSPSC IS NULL THEN ' ' ELSE UPPER(COD_UNSPSC) END)  LIKE UPPER(:COD_UNSPSC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_ESTUDIO":"$COD_ESTUDIO","COD_UNSPSC":"$COD_UNSPSC","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esestpreviounspsc">
		<call-query href="getEsestpreviounspscPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsestpreviounspscNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_ESTPREVIO_UNSPSC.COMPANIA, ES_ESTPREVIO_UNSPSC.COD_ESTUDIO, ES_ESTPREVIO_UNSPSC.COD_UNSPSC, CODIGOS_UNSPSC.NOMBRE  FROM ES_ESTPREVIO_UNSPSC INNER JOIN CODIGOS_UNSPSC ON ES_ESTPREVIO_UNSPSC.COD_UNSPSC = CODIGOS_UNSPSC.CODIGO AND ES_ESTPREVIO_UNSPSC.COMPANIA = CODIGOS_UNSPSC.COMPANIA WHERE ES_ESTPREVIO_UNSPSC.COMPANIA = :COMPANIA AND ES_ESTPREVIO_UNSPSC.COD_ESTUDIO = :COD_ESTUDIO) WHERE (CASE WHEN COD_UNSPSC IS NULL THEN ' ' ELSE UPPER(COD_UNSPSC) END)  LIKE UPPER(:COD_UNSPSC || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestpreviounspsc/numero">
		<call-query href="getEsestpreviounspscNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="updateEsestpreviounspsc" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_ESTPREVIO_UNSPSC SET COMPANIA=:COMPANIA, COD_ESTUDIO=:COD_ESTUDIO, COD_UNSPSC=:COD_UNSPSC, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_ESTPREVIO_UNSPSC.COMPANIA= :KEY_COMPANIA AND ES_ESTPREVIO_UNSPSC.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_ESTPREVIO_UNSPSC.COD_UNSPSC= :KEY_COD_UNSPSC</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_UNSPSC" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_UNSPSC" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="esestpreviounspsc">
		<call-query href="updateEsestpreviounspsc">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_UNSPSC" query-param="COD_UNSPSC"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_COD_UNSPSC" query-param="KEY_COD_UNSPSC"/>

		</call-query>
	</resource>

</data>