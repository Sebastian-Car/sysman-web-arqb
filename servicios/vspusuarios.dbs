	<query id="getVspusuariosPagPorCicloEmpexternaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CICLO, ANO, PERIODO, CONCAT(NOMBRES,CONCAT(' ',CONCAT(PRIMERAPELLIDO,CONCAT(' ',SEGUNDOAPELLIDO) ) ) ) NOMBRE, CODIGORUTA, CODIGOINTERNO, EMPRESAASEOEXT,(TO_CHAR(FECHAINGASEOEXT,'DD/MM/YYYY HH24:MI:SS')) FECHAINGASEOEXT,(CASE ASEO WHEN 0 THEN 'false' ELSE 'true' END) ASEO, CODIGO_EXTERNO, CASE ESTADO WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' END  ESTADO,(CASE ASEOBARRIDO WHEN 0 THEN 'false' ELSE 'true' END) ASEOBARRIDO,(CASE PINTADEUDATERCE WHEN 0 THEN 'false' ELSE 'true' END) PINTADEUDATERCE FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN EMPRESAASEOEXT IS NULL THEN ' ' ELSE UPPER(EMPRESAASEOEXT) END) LIKE UPPER(CONCAT(CONCAT('%',:EMPRESAASEOEXT), '%')) AND (CASE WHEN FECHAINGASEOEXT IS NULL THEN ' ' ELSE UPPER(FECHAINGASEOEXT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAINGASEOEXT), '%')) AND (CASE WHEN ASEO IS NULL THEN ' ' ELSE UPPER(ASEO) END) LIKE UPPER(CONCAT(:ASEO, '%')) AND (CASE WHEN CODIGO_EXTERNO IS NULL THEN ' ' ELSE UPPER(CODIGO_EXTERNO) END) LIKE UPPER(CONCAT(:CODIGO_EXTERNO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN ASEOBARRIDO IS NULL THEN ' ' ELSE UPPER(ASEOBARRIDO) END) LIKE UPPER(CONCAT(:ASEOBARRIDO, '%')) AND (CASE WHEN PINTADEUDATERCE IS NULL THEN ' ' ELSE UPPER(PINTADEUDATERCE) END) LIKE UPPER(CONCAT(:PINTADEUDATERCE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","NOMBRE":"$NOMBRE","CODIGORUTA":"$CODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","EMPRESAASEOEXT":"$EMPRESAASEOEXT","FECHAINGASEOEXT":"$FECHAINGASEOEXT","ASEO":"$ASEO(type:boolean)","CODIGO_EXTERNO":"$CODIGO_EXTERNO","ESTADO":"$ESTADO","ASEOBARRIDO":"$ASEOBARRIDO(type:boolean)","PINTADEUDATERCE":"$PINTADEUDATERCE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="EMPRESAASEOEXT" sqlType="STRING"/>
		<param name="FECHAINGASEOEXT" sqlType="STRING"/>
		<param name="ASEO" sqlType="STRING"/>
		<param name="CODIGO_EXTERNO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="ASEOBARRIDO" sqlType="STRING"/>
		<param name="PINTADEUDATERCE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
