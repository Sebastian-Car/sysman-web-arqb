	<query id="getVspusuariosPagTodosPorNombreCodigoInternoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.CODIGOINTERNO, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) NOMBRE, TERCERO.NOMBRE NOMBREAFORADOR, SP_AFORADORES.CODIGO, SP_USUARIO.CODIGORUTA, SP_USUARIO.LECTURA, SP_USUARIO.LECTURAAFORO,(TO_CHAR(SP_USUARIO.FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO FROM SP_USUARIO INNER JOIN SP_AFORADORES ON SP_USUARIO.COMPANIA = SP_AFORADORES.COMPANIA AND SP_USUARIO.AFORADOR = SP_AFORADORES.CODIGO INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREAFORADOR IS NULL THEN ' ' ELSE UPPER(NOMBREAFORADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAFORADOR), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN LECTURA IS NULL THEN ' ' ELSE UPPER(LECTURA) END) LIKE UPPER(CONCAT(:LECTURA, '%')) AND (CASE WHEN LECTURAAFORO IS NULL THEN ' ' ELSE UPPER(LECTURAAFORO) END) LIKE UPPER(CONCAT(:LECTURAAFORO, '%')) AND (CASE WHEN FECHALECTURAAFORO IS NULL THEN ' ' ELSE UPPER(FECHALECTURAAFORO) END) LIKE UPPER(CONCAT(:FECHALECTURAAFORO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOINTERNO":"$CODIGOINTERNO","NOMBRE":"$NOMBRE","NOMBREAFORADOR":"$NOMBREAFORADOR","CODIGO":"$CODIGO","CODIGORUTA":"$CODIGORUTA","LECTURA":"$LECTURA","LECTURAAFORO":"$LECTURAAFORO","FECHALECTURAAFORO":"$FECHALECTURAAFORO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREAFORADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="LECTURA" sqlType="STRING"/>
		<param name="LECTURAAFORO" sqlType="STRING"/>
		<param name="FECHALECTURAAFORO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vspusuarios/todospornombrecodigointerno/pag">
		<call-query href="getVspusuariosPagTodosPorNombreCodigoInternoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREAFORADOR" query-param="NOMBREAFORADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="LECTURA" query-param="LECTURA"/>
			<with-param name="LECTURAAFORO" query-param="LECTURAAFORO"/>
			<with-param name="FECHALECTURAAFORO" query-param="FECHALECTURAAFORO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVspusuariosNumTodosPorNombreCodigoInternoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_USUARIO.CODIGOINTERNO, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) NOMBRE, TERCERO.NOMBRE NOMBREAFORADOR, SP_AFORADORES.CODIGO, SP_USUARIO.CODIGORUTA, SP_USUARIO.LECTURA, SP_USUARIO.LECTURAAFORO,(TO_CHAR(SP_USUARIO.FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO FROM SP_USUARIO INNER JOIN SP_AFORADORES ON SP_USUARIO.COMPANIA = SP_AFORADORES.COMPANIA AND SP_USUARIO.AFORADOR = SP_AFORADORES.CODIGO INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBREAFORADOR IS NULL THEN ' ' ELSE UPPER(NOMBREAFORADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREAFORADOR), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN LECTURA IS NULL THEN ' ' ELSE UPPER(LECTURA) END) LIKE UPPER(CONCAT(:LECTURA, '%')) AND (CASE WHEN LECTURAAFORO IS NULL THEN ' ' ELSE UPPER(LECTURAAFORO) END) LIKE UPPER(CONCAT(:LECTURAAFORO, '%')) AND (CASE WHEN FECHALECTURAAFORO IS NULL THEN ' ' ELSE UPPER(FECHALECTURAAFORO) END) LIKE UPPER(CONCAT(:FECHALECTURAAFORO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBREAFORADOR" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="LECTURA" sqlType="STRING"/>
		<param name="LECTURAAFORO" sqlType="STRING"/>
		<param name="FECHALECTURAAFORO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vspusuarios/todospornombrecodigointerno/num">
		<call-query href="getVspusuariosNumTodosPorNombreCodigoInternoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBREAFORADOR" query-param="NOMBREAFORADOR"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="LECTURA" query-param="LECTURA"/>
			<with-param name="LECTURAAFORO" query-param="LECTURAAFORO"/>
			<with-param name="FECHALECTURAAFORO" query-param="FECHALECTURAAFORO"/>

		</call-query>
	</resource>

</data>